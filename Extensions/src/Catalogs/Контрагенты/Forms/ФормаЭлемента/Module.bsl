					Перечисления.AzRyМитигирующиеМерыРиска.ПустаяСсылка()));

	СоотвФакторыРискаКлиента.Вставить(П.БезналичныеРасчетыЧерезВендинг,
	Новый Структура("ВероятностьРиска, УровеньРиска, МитигирующиеМеры",
					Перечисления.AzRyДаНет.ПустаяСсылка(),
					Перечисления.AzRyУровеньРискаКлиента.ПустаяСсылка(),
					Перечисления.AzRyМитигирующиеМерыРиска.ПустаяСсылка()));

	СоотвФакторыРискаКлиента.Вставить(П.ЛимитСуммыОпераций,
	Новый Структура("ВероятностьРиска, УровеньРиска, МитигирующиеМеры",
					Перечисления.AzRyУровеньРискаКлиента.ПустаяСсылка(),
