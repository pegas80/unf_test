&НаСервере
Функция НайтиОрганизациюПоУмолчаниюКонтрагента()

	// Получаем ссылку на запись основной организации, созданную при первой записи контрагента
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	AzRyКонтрагентОрганизации.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.AzRyКонтрагентОрганизации КАК AzRyКонтрагентОрганизации
		|ГДЕ
		|	AzRyКонтрагентОрганизации.Владелец = &Контрагент";

	Запрос.УстановитьПараметр("Контрагент", Объект.Ссылка);

	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Возврат Результат.Выгрузить()[0]["Ссылка"];
	КонецЕсли;

	Возврат Справочники.AzRyКонтрагентОрганизации.ПустаяСсылка();

