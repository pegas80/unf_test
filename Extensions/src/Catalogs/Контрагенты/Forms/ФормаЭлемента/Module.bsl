#Область ЗаписьДанных

&НаСервере
Процедура ЗаписатьДанныеБанковскогоСчета(ТекущийОбъект, НомерСчета, БанкСчета, ВалютаСчета)

	УстановитьПривилегированныйРежим(Истина);

	НовыйСчет = Справочники.БанковскиеСчета.СоздатьЭлемент();
	НовыйСчет.НомерСчета   = НомерСчета;
	НовыйСчет.Наименование = НомерСчета;
	НовыйСчет.Владелец   = ТекущийОбъект.Ссылка;
	НовыйСчет.Банк = БанкСчета;
	НовыйСчет.ВариантУказанияКПП = Перечисления.ВариантыУказанияКПП.ВоВсехПлатежныхПоручениях;
	НовыйСчет.ВидСчета = "Расчетный";
	НовыйСчет.ВалютаДенежныхСредств = ВалютаСчета;
	НовыйСчет.Записать();

	ТекущийОбъект.БанковскийСчетПоУмолчанию = НовыйСчет.Ссылка;

	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&НаСервере
Процедура ЗаписатьДанныеОсновнойОрганизации(ТекущийОбъект, ОрганизацияПоУмолчанию)

	УстановитьПривилегированныйРежим(Истина);

	НоваяОрганизацияПУ = Справочники.AzRyКонтрагентОрганизации.СоздатьЭлемент();
	НоваяОрганизацияПУ.Организация = ОрганизацияПоУмолчанию;
	НоваяОрганизацияПУ.Владелец = ТекущийОбъект.Ссылка;
	НоваяОрганизацияПУ.Наименование = ОрганизацияПоУмолчанию.Наименование;
	НоваяОрганизацияПУ.Записать();

	// Присвоение ТекущийОбъект.AzRyОрганизацияПоУмолчанию здесь не сохраняется,
	// т.к. основной объект ещё не записан. Присвоение выполняется после записи в ПослеЗаписиПосле.

	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

#КонецОбласти
