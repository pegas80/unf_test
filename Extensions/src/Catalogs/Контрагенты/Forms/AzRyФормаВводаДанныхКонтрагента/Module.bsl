// Добавляет или обновляет строку юридического адреса контрагента
// в таблице контактной информации формы.
// Если строка с видом "ЮрАдресКонтрагента" уже существует — обновляет её,
// иначе добавляет новую строку.
//
// Параметры:
//  ЮридическийАдресКонтрагента - Строка - Текстовое представление юридического адреса.
//
&НаСервере
Процедура ДобавитьЮридическийАдресКонтрагента(ЮридическийАдресКонтрагента)
	
	ТЗ = ЭтотОбъект.КонтактнаяИнформация.Выгрузить();
	
	СтруктураПараметров = Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента);
	СтрокаКИ = ТЗ.НайтиСтроки(СтруктураПараметров);
	Если СтрокаКИ.Количество() = 0 Тогда
		СтрокаКИ = ТЗ.Добавить();
		СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
		СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
	Иначе
		СтрокаКИ = СтрокаКИ[0];
	КонецЕсли;
	
	//СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
	//СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
	СтрокаКИ.Представление = ЮридическийАдресКонтрагента;
	СтрокаКИ.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияXMLПоПредставлениюГрузия(СтрокаКИ.Представление);
	
	ЭтотОбъект.КонтактнаяИнформация.Загрузить(ТЗ);
	
КонецПроцедуры

#КонецОбласти

#Область ИнтеграцияСRS

// Обработчик команды получения информации о контрагенте из сервиса RS
// по заполненному ИНН. Выполняет серверный вызов и обновляет элементы формы.
//
// Параметры:
//  Команда - КомандаФормы - Команда, инициировавшая вызов процедуры.
//
&НаКлиенте
Процедура ПолучитьИнфоИзRS(Команда)
	
	Если Не ЗначениеЗаполнено(ИНН) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='გსნ არ არის შევსებული';ru='ИНН не заполнено.';en='VAT is not filled.'"));
		Возврат;
	КонецЕсли;
	
	ПолучитьИнфоИзRSСервер();
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

// Получает данные контрагента из сервиса RS по ИНН и заполняет реквизиты формы:
// наименование, вид контрагента, налогообложение НДС и юридический адрес.
// Выполняет два запроса к сервису: основной и расширенный (для получения статуса НДС).
//
&НаСервере
Процедура ПолучитьИнфоИзRSСервер()
	
	ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервере(ИНН);
	
	Если ДанныеКонтрагента = Неопределено Или ДанныеКонтрагента.Статус = ""  Тогда
		Сообщить(НСтр("ka='კონტრაგენტი მიმდინარე გსნ-თ ვერ მოიძებნა RS-ზე';ru='Контрагент с данным ИНН не найден на RS.';en='Counterparty with the INN is not found in the RS.'"));
		Возврат;
	КонецЕсли;	
	
	Наименование = ДанныеКонтрагента.Имя;
	Компания     = ДанныеКонтрагента.Имя;
	
	Если ДанныеКонтрагента.ТипОрганизаций = "ფიზიკური პირი" Тогда
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "შ\პ\ს" ИЛИ ДанныеКонтрагента.ТипОрганизаций = "სააქციო საზოგადოება" ИЛИ ДанныеКонтрагента.ТипОрганизаций = "საჯარო სამართლის იურიდიული პირი" Тогда	
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "სახელმწიფო ორგანოები" Тогда	
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ГосударственныйОрган;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "ინდივიდუალური მეწარმე" Тогда	
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель;
	Иначе
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	КонецЕсли;	
	
	// Юридический адрес	
	ДобавитьЮридическийАдресКонтрагента(ДанныеКонтрагента.Адрес);
	
	ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервереНов(ИНН);
	
	Если ДанныеКонтрагента = Неопределено Или ДанныеКонтрагента.UnID = 0  Тогда
		Возврат;
	КонецЕсли;	
	
	Если ДанныеКонтрагента.IsVatPayer Тогда
		Если НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
			НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
		КонецЕсли;			
	Иначе 
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	КонецЕсли;
	
КонецПроцедуры	

