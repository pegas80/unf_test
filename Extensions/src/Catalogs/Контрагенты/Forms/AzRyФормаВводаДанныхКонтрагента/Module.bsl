&НаСервере
Функция ПолучитьДоступныеОрганизации()
	
	Ответ = Новый СписокЗначений;
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	AzRyНастройкаРЛСОрганизации.Организация КАК Организация
		|ИЗ
		|	Справочник.AzRyНастройкаРЛС.Организации КАК AzRyНастройкаРЛСОрганизации
		|ГДЕ
		|	НЕ AzRyНастройкаРЛСОрганизации.Ссылка.ПометкаУдаления
		|	И AzRyНастройкаРЛСОрганизации.Ссылка.Пользователь = &Пользователь";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	Ответ.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Организация"));
	
	Возврат Ответ;
	
КонецФункции

