Функция ПолучитьОрганизациюAzRyPay()

	Возврат Константы.AzRyОрганизацияAzRyPay.Получить();	

КонецФункции

&НаСервере
Процедура ЗаполнитьТаблицуВопросов(ИмяТабличнойЧасти, ПеречислениеВопросовТекст, Колонка, КолонкаОтвет = Неопределено)
	
	Ответ = ПолучитьСоответствиеВопросовKYC();
	
	ПеречислениеВопросов = Перечисления[ПеречислениеВопросовТекст];
	
	ТаблицаВопросов = Объект[ИмяТабличнойЧасти];
	
	Для Каждого Вопрос Из ПеречислениеВопросов Цикл
		
		Если Не ВопросУжеЕсть(ТаблицаВопросов, Вопрос, Колонка) Тогда
			НоваяСтрока = ТаблицаВопросов.Добавить();
			НоваяСтрока[Колонка] = Вопрос;
			Если КолонкаОтвет = Неопределено Тогда
				Для каждого ТекСтрока Из Ответ[ПеречислениеВопросовТекст][Вопрос] Цикл
				
					НоваяСтрока[ТекСтрока.Ключ] = ТекСтрока.Значение; 
					
				КонецЦикла;	
			Иначе 	
				НоваяСтрока[КолонкаОтвет] = Ответ[ПеречислениеВопросовТекст][Вопрос];
			КонецЕсли; 
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ОчиститьТаблицуВопросов(ИмяТабличнойЧасти)
		
	ТаблицаВопросов = Объект[ИмяТабличнойЧасти];
	ТаблицаВопросов.Очистить();
	
КонецПроцедуры

&НаСервере
Функция ВопросУжеЕсть(Таблица, Вопрос, Колонка)

	Для Каждого Стр Из Таблица Цикл
		
		Если Стр[Колонка] = Вопрос Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;

	Возврат Ложь;

КонецФункции

&НаСервере
// Возвращает соответствие: Ключ = Значение перечисления, Значение = начальное значение ответа
Функция ПолучитьСоответствиеВопросовKYC() Экспорт
	
	СоотвВопросыKYCАнкетыКлиента = Новый Соответствие;
	СоотвKYCВопросыКлиента       = Новый Соответствие;
	СоотвФакторыРискаКлиента     = Новый Соответствие;
	
	Ответ = Новый Структура("AzRyВопросыKYCАнкетыКлиента, AzRyKYCВопросыКлиента, AzRyФакторыРискаКлиента", СоотвВопросыKYCАнкетыКлиента, СоотвKYCВопросыКлиента, СоотвФакторыРискаКлиента);
	
	// Вопросы анкеты KYC клиента
    П = Перечисления.AzRyВопросыKYCАнкетыКлиента;
	
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.ВидДеятельностиКлиента,                       "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.ЦельУстановленияДеловыхОтношений,             "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.СтраныОсуществленияДеятельности,              "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.ИсточникПроисхожденияСредств,                 "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.ПредполагаемыйГодовойОборот,                  "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.ДействуетЛиВИнтересахБенефициарногоВладельца, "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.СведенияОТретьемЛицеИБенефициаре,             "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.ПризнакPEP,             					  "");
	СоотвВопросыKYCАнкетыКлиента.Вставить(П.СведенияОPEP,             					  "");
	
	// Вопросы KYC анкеты клиента 2
    П = Перечисления.AzRyKYCВопросыКлиента;
	
    СоотвKYCВопросыКлиента.Вставить(П.ОписаниеДоговораОбслуживания,             "");
    СоотвKYCВопросыКлиента.Вставить(П.ОжидаемаяСтоимостьОперацийБолее3000,    Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ПризнакКомплексныхОпераций,             Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ПризнакНеобычногоПоведенияКлиента,      Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ПризнакPEP,                             Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.СложнаяСтруктураСобственности,          Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ПризнакВысокогоДоходаКлиента,           Перечисления.AzRyДаНет.ПустаяСсылка());
	
	СоотвKYCВопросыКлиента.Вставить(П.ДеятельностьСвязанаСОружиемИлиБоеприпасами,          Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ТорговляПроизведениямиИскусстваИлиПредметамиРоскоши, Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ОперацииСДрагоценнымиМеталлами,                      Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ОперацииСНефтьюИГазом,                               Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.СтроительствоИЛиНедвижимость,                        Перечисления.AzRyДаНет.ПустаяСсылка());
    СоотвKYCВопросыКлиента.Вставить(П.ВалютныеОперацииИФорекс,                             Перечисления.AzRyДаНет.ПустаяСсылка());
