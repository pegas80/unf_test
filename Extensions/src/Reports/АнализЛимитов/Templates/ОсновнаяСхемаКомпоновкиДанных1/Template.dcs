		<field xsi:type="DataSetFieldField">
			<dataPath>МинимальныйОстатокОтправителяКон</dataPath>
			<field>МинимальныйОстатокОтправителяКон</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Минимальный остаток отправителя</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>ყველა საწყობის ლიმიტების ჯამი</v8:content>
				</v8:item>
				<v8:item>
