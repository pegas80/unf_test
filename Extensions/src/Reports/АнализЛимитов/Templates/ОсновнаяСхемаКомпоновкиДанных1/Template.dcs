				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Минимальный остаток получателя</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>მიმღების ლიმიტების ჯამი</v8:content>
				</v8:item>
				<v8:item>
