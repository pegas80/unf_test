	НастройкиВариантов["ВаловаяПрибыль"].Теги = НСТР("ka='Продажи,CRM,Номенклатура,Выручка,Себестоимость,Прибыль,Рентабельность,Маржа';ru='Продажи,CRM,Номенклатура,Выручка,Себестоимость,Прибыль,Рентабельность,Маржа';en='Sales, CRM, Inventory, revenue, cost, profit, margin, margin'");
