	НастройкиВариантов["ДинамикаПродажПоМенеджерам"].Теги = НСТР("ka='Продажи,CRM,Выручка,Менеджеры';ru='Продажи,CRM,Выручка,Менеджеры';en='Sales, CRM, Revenue Managers'");
	
