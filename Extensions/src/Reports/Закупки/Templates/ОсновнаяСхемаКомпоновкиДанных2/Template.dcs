		<field xsi:type="DataSetFieldField">
			<dataPath>СтруктурнаяЕдиница</dataPath>
			<field>СтруктурнаяЕдиница</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ПриходнаяНакладнаяЗапасы.Ссылка КАК Ссылка,
	ПриходнаяНакладнаяЗапасы.Номенклатура КАК Номенклатура,
	ПриходнаяНакладнаяЗапасы.Характеристика КАК Характеристика,
	ПриходнаяНакладнаяЗапасы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
//ПОМЕСТИТЬ ВТ_Подразделение
// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
	,СУММА(ПриходнаяНакладнаяЗапасы.Сумма) КАК Сумма
	,СУММА(ПриходнаяНакладнаяЗапасы.Количество) КАК Количество
ПОМЕСТИТЬ ВТ_ПодразделениеПРЕД
// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
ИЗ
	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
// Kuzmich, 12.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
СГРУППИРОВАТЬ ПО
	ПриходнаяНакладнаяЗапасы.Ссылка,
	ПриходнаяНакладнаяЗапасы.Номенклатура,
	ПриходнаяНакладнаяЗапасы.Характеристика,
	ПриходнаяНакладнаяЗапасы.СтруктурнаяЕдиница
// Kuzmich, 12.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПриходнаяНакладнаяРасходы.Ссылка,
	ПриходнаяНакладнаяРасходы.Номенклатура,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
	ПриходнаяНакладнаяРасходы.СтруктурнаяЕдиница
// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
	,СУММА(ПриходнаяНакладнаяРасходы.Сумма) КАК Сумма
	,СУММА(ПриходнаяНакладнаяРасходы.Количество) КАК Количество
// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
ИЗ
	Документ.ПриходнаяНакладная.Расходы КАК ПриходнаяНакладнаяРасходы
// Kuzmich, 12.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
СГРУППИРОВАТЬ ПО
	ПриходнаяНакладнаяРасходы.Ссылка,
	ПриходнаяНакладнаяРасходы.Номенклатура,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
	ПриходнаяНакладнаяРасходы.СтруктурнаяЕдиница
// Kuzmich, 12.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Номенклатура,
	Характеристика
;

////////////////////////////////////////////////////////////////////////////////
// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
ВЫБРАТЬ
	ВТ_ПодразделениеПРЕД.Ссылка КАК Ссылка,
	ВТ_ПодразделениеПРЕД.Номенклатура КАК Номенклатура,
	ВТ_ПодразделениеПРЕД.Характеристика КАК Характеристика,
	СУММА(ВТ_ПодразделениеПРЕД.Сумма) КАК Сумма,
	СУММА(ВТ_ПодразделениеПРЕД.Количество) КАК Количество
ПОМЕСТИТЬ ВТ_ПодразделениеБезСтруктурнаяЕдиница
ИЗ ВТ_ПодразделениеПРЕД КАК ВТ_ПодразделениеПРЕД
СГРУППИРОВАТЬ ПО
	ВТ_ПодразделениеПРЕД.Ссылка,
	ВТ_ПодразделениеПРЕД.Номенклатура,
	ВТ_ПодразделениеПРЕД.Характеристика

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Номенклатура,
	Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ПодразделениеПРЕД.Ссылка КАК Ссылка,
	ВТ_ПодразделениеПРЕД.Номенклатура КАК Номенклатура,
	ВТ_ПодразделениеПРЕД.Характеристика КАК Характеристика,
	ВТ_ПодразделениеПРЕД.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ВЫБОР
		КОГДА ВТ_ПодразделениеБезСтруктурнаяЕдиница.Сумма &lt;&gt; 0
			ТОГДА ВТ_ПодразделениеПРЕД.Сумма / ВТ_ПодразделениеБезСтруктурнаяЕдиница.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК КоэффициентСумма,
	ВЫБОР
		КОГДА ВТ_ПодразделениеБезСтруктурнаяЕдиница.Количество &lt;&gt; 0
			ТОГДА ВТ_ПодразделениеПРЕД.Количество / ВТ_ПодразделениеБезСтруктурнаяЕдиница.Количество
		ИНАЧЕ 0
	КОНЕЦ КАК КоэффициентКоличество
ПОМЕСТИТЬ ВТ_Подразделение
ИЗ ВТ_ПодразделениеПРЕД КАК ВТ_ПодразделениеПРЕД
	ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПодразделениеБезСтруктурнаяЕдиница КАК ВТ_ПодразделениеБезСтруктурнаяЕдиница
		ПО ВТ_ПодразделениеПРЕД.Ссылка = ВТ_ПодразделениеБезСтруктурнаяЕдиница.Ссылка
		И ВТ_ПодразделениеПРЕД.Номенклатура = ВТ_ПодразделениеБезСтруктурнаяЕдиница.Номенклатура
		И ВТ_ПодразделениеПРЕД.Характеристика = ВТ_ПодразделениеБезСтруктурнаяЕдиница.Характеристика

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Номенклатура,
	Характеристика
;
////////////////////////////////////////////////////////////////////////////////
// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВЫБОР
		КОГДА ЗакупкиОбороты.Регистратор = НЕОПРЕДЕЛЕНО
			ТОГДА NULL
		ИНАЧЕ ЗакупкиОбороты.Регистратор
	КОНЕЦ КАК Регистратор,
	ЗакупкиОбороты.ПериодСекунда КАК ПериодСекунда,
	ЗакупкиОбороты.ПериодМинута КАК ПериодМинута,
	ЗакупкиОбороты.ПериодЧас КАК ПериодЧас,
	ЗакупкиОбороты.ПериодДень КАК ПериодДень,
	ЗакупкиОбороты.ПериодНеделя КАК ПериодНеделя,
	ЗакупкиОбороты.ПериодДекада КАК ПериодДекада,
	ЗакупкиОбороты.ПериодМесяц КАК ПериодМесяц,
	ЗакупкиОбороты.ПериодКвартал КАК ПериодКвартал,
	ЗакупкиОбороты.ПериодПолугодие КАК ПериодПолугодие,
	ЗакупкиОбороты.ПериодГод КАК ПериодГод,
	ЗакупкиОбороты.Организация КАК Организация,
	ВЫБОР
		КОГДА ЗакупкиОбороты.ЗаказПоставщику = НЕОПРЕДЕЛЕНО
				ИЛИ ЗакупкиОбороты.ЗаказПоставщику = ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
			ТОГДА NULL
		ИНАЧЕ ЗакупкиОбороты.ЗаказПоставщику
	КОНЕЦ КАК ЗаказПоставщику,
	ЗакупкиОбороты.Номенклатура КАК Номенклатура,
	ЗакупкиОбороты.Характеристика КАК Характеристика,
	ЗакупкиОбороты.Партия КАК Партия,
	ЗакупкиОбороты.Документ КАК Документ,
	ЗакупкиОбороты.СтавкаНДС КАК СтавкаНДС,
	ЗакупкиОбороты.Проект КАК Проект,
	//ЗакупкиОбороты.КоличествоОборот КАК Количество,
	//ЗакупкиОбороты.СуммаОборот КАК Сумма,
	//ЗакупкиОбороты.СуммаНДСОборот КАК СуммаНДС,
	// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
	ВЫРАЗИТЬ(ЗакупкиОбороты.КоличествоОборот * ВТ_Подразделение.КоэффициентКоличество КАК ЧИСЛО(15,3)) КАК Количество,	
	ВЫРАЗИТЬ(ЗакупкиОбороты.СуммаОборот * ВТ_Подразделение.КоэффициентСумма КАК ЧИСЛО(15,2)) КАК Сумма,
	ВЫРАЗИТЬ(ЗакупкиОбороты.СуммаНДСОборот * ВТ_Подразделение.КоэффициентСумма КАК ЧИСЛО(15,2)) КАК СуммаНДС,
	// Kuzmich, 20.11.2025, (ONESOFT-4503) Задвоение в отчете "закупки"
	0 КАК Цена,
	ЕСТЬNULL(ЗакупкиОбороты.ЗаказПоставщику.Контрагент, ЗакупкиОбороты.Документ.Контрагент) КАК Контрагент,
	ЕСТЬNULL(ЗакупкиОбороты.ЗаказПоставщику.Договор, ЗакупкиОбороты.Документ.Договор) КАК Договор,
	ВТ_Подразделение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		
