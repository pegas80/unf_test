
// Открывает форму текущих напоминаний пользователя.
//
Процедура AzRyПроверитьТекущиеОбсуждения() Экспорт
	
	ПараметрыРаботыКлиента = СтандартныеПодсистемыКлиентПовтИсп.ПараметрыРаботыКлиента();
	ИнтервалПроверкиНапоминаний = ПараметрыРаботыКлиента.AzRyНастройкиНапоминаний.ИнтервалПроверкиНапоминаний;
	
	ТаблицаОповещений = AzRyОбсужденияВызовСервера.ПолучитьОбсужденияТекущегоПользователя();
	ИнтервалСледующейПроверки = ИнтервалПроверкиНапоминаний * 60;
	
	Если ТаблицаОповещений.Количество() > 0 Тогда
		Для каждого ТекСтрока Из ТаблицаОповещений Цикл
			
			Если ТекСтрока.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения") Тогда
				Текст = "საჭიროა საწყობზე მიღების დადასტურება!";
				Картинка = БиблиотекаКартинок.ЗолотойШар;
			ИначеЕсли ТекСтрока.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеОдобрено") Тогда
				Текст = "საწყობზე მიღება დადასტურებულია!";
				Картинка = БиблиотекаКартинок.ЗеленыйШар;
			ИначеЕсли ТекСтрока.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеНеОдобрено") Тогда
				Текст = "საწყობზე მიღება უარყოფილია!";	
				Картинка = БиблиотекаКартинок.КрасныйШар;
			КонецЕсли; 
			
			//НапоминанияПользователяКлиент.ОткрытьФормуОповещения();		
			//ОсновнаяОрганизация = ПредопределенноеЗначение("Справочник.Организации.ОсновнаяОрганизация");
			//НавигационнаяСслыка = ПолучитьНавигационнуюСсылку(ОсновнаяОрганизация);
			ПоказатьОповещениеПользователя(Текст, "e1cib/list/РегистрСведений.AzRyНапоминанияПользователя",
											"გამომგზავნი: " + ТекСтрока.Отправитель, Картинка, СтатусОповещенияПользователя.Важное, ТекСтрока.ПредставлениеИсточника + "_" + Строка(ТекСтрока.Отправитель));
		
		КонецЦикла;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("AzRyПроверитьТекущиеОбсуждения", ИнтервалСледующейПроверки, Истина);
	
КонецПроцедуры
