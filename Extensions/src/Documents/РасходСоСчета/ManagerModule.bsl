Процедура СформироватьТаблицаОтчетПоКурсовымРазницам(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("Аналитика", Строка(СтруктураДополнительныеСвойства.ДляПроведения.Ссылка));
	
	//ПодольскийАИ #УчетПроектов 25.11.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 25.11.2020 }
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	1 КАК Порядок,
		|	1 КАК НомерСтроки,
		|	ТаблицаДокумента.Дата КАК Период,
		|	ТаблицаДокумента.ОрганизацияВНУ КАК Организация,
		|	ТаблицаДокумента.Статья КАК Статья,
		|	&Аналитика КАК Аналитика,
		|	ТаблицаДокумента.ВалютаРасчетов КАК Валюта,
		|	""Расчеты с поставщиками"" КАК Раздел,
		|	ТаблицаДокумента.СуммаУчета - ТаблицаДокумента.СуммаРасчетов * ТаблицаДокумента.КурсПоступления / ТаблицаДокумента.КратностьПоступления КАК Сумма,
		|	0 КАК СуммаДоходов,
		|	ТаблицаДокумента.СуммаУчета - ТаблицаДокумента.СуммаРасчетов * ТаблицаДокумента.КурсПоступления / ТаблицаДокумента.КратностьПоступления КАК СуммаРасходов,
		|	-(ТаблицаДокумента.СуммаУчета - ТаблицаДокумента.СуммаРасчетов * ТаблицаДокумента.КурсПоступления / ТаблицаДокумента.КратностьПоступления) КАК СуммаОстаток,
		|	0 КАК СуммаВалОстаток
		|	,ВЫБОР 
		|		КОГДА &УчетПоПроектам 
		|			ТОГДА 
		|       		ВЫбор
		|					КОГДА ТаблицаДокумента.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
		|                      ТОГДА ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
		|                    ИНАЧЕ ТаблицаДокумента.Проект 
		|				КОНЕЦ
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
		|	 КОНЕЦ КАК Проект		
		|ИЗ
		|	ВременнаяТаблицаРасшифровкаПлатежа КАК ТаблицаДокумента
		|ГДЕ
		|	ТаблицаДокумента.ЯвляетсяНеРезидентом
		|	И Не ТаблицаДокумента.ПризнакАванса
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2,
		|	1,
		|	ТаблицаДокумента.Дата,
		|	ТаблицаДокумента.ОрганизацияВНУ,
		|	ТаблицаДокумента.Статья,
		|	&Аналитика,
		|	ТаблицаДокумента.ВалютаРасчетов,
		|	""Расчеты НДФЛ"",
		|	ТаблицаДокумента.СуммаНДФЛ - (ТаблицаДокумента.СуммаНДФЛВал * ТаблицаДокумента.КурсПоступления / ТаблицаДокумента.КратностьПоступления),
		|	0,
		|	ТаблицаДокумента.СуммаНДФЛ - (ТаблицаДокумента.СуммаНДФЛВал * ТаблицаДокумента.КурсПоступления / ТаблицаДокумента.КратностьПоступления),
		|	-(ТаблицаДокумента.СуммаНДФЛ - (ТаблицаДокумента.СуммаНДФЛВал * ТаблицаДокумента.КурсПоступления / ТаблицаДокумента.КратностьПоступления)),
		|	0
		|	,ВЫБОР 
		|		КОГДА &УчетПоПроектам 
		|			ТОГДА 
		|       		ВЫбор
		|					КОГДА ТаблицаДокумента.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
		|                      ТОГДА ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
		|                    ИНАЧЕ ТаблицаДокумента.Проект 
		|				КОНЕЦ
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
		|	 КОНЕЦ КАК Проект		
		|ИЗ
		|	ВременнаяТаблицаРасшифровкаПлатежа КАК ТаблицаДокумента
		|ГДЕ
		|	ТаблицаДокумента.ЯвляетсяНеРезидентом
		|	И Не ТаблицаДокумента.ПризнакАванса";
		
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаОтчетКурсовыхРазниц", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

&Вместо("СформироватьТаблицаРасчетыПоНалогам")
Процедура РасшAzRy_СформироватьТаблицаРасчетыПоНалогам(ДокументСсылкаРасходСоСчета, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", 		ДокументСсылкаРасходСоСчета);
	Запрос.УстановитьПараметр("ВалютаУчета",	Константы.ВалютаУчета.Получить());
	//Запрос.УстановитьПараметр("ВалютаДокумента",ДокументСсылкаРасходСоСчета.ВалютаДенежныхСредств);
	Если ДокументСсылкаРасходСоСчета.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам И ЗначениеЗаполнено(ДокументСсылкаРасходСоСчета.ДоговорКредитаЗайма) Тогда 
		Запрос.УстановитьПараметр("ВалютаДокумента",	ДокументСсылкаРасходСоСчета.ДоговорКредитаЗайма.ВалютаРасчетов);
	Иначе 
		Запрос.УстановитьПараметр("ВалютаДокумента",	ДокументСсылкаРасходСоСчета.ВалютаДенежныхСредств);
	КонецЕсли;
			  
  
	Запрос.УстановитьПараметр("Организация",	СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("МоментВремени",	Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ОплатаНалога",	НСтр("ka='გადასახადის გადახდა';ru='Оплата налога';en='Payment of tax'"));
	Запрос.УстановитьПараметр("ПустаяДата", Дата('00010101'));
	Запрос.УстановитьПараметр("ИспользоватьТолькоРегламентированногоПланаСчетов", СтруктураДополнительныеСвойства.ИспользованиеТолькоРеглПланаСчетов);
	
	//ПодольскийАИ #УчетПроектов 25.11.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 25.11.2020 }
	
	//Паганини_
	//Если не ДокументСсылкаРасходСоСчета.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата тогда
	Если ДокументСсылкаРасходСоСчета.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Налоги Тогда	
	//_Паганини
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	КурсыВалютСрезПоследних.Валюта КАК Валюта,
		|	КурсыВалютСрезПоследних.Курс КАК Курс,
		|	КурсыВалютСрезПоследних.Кратность КАК Кратность
		|ПОМЕСТИТЬ КурсыВалют
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаДокумента)) КАК КурсыВалютСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	НачислениеНалоговНалоги.СрокУплаты,
		////ПодольскийАИ #УчетПроектов 10.02.2021 {
		////Исправление ошибок. Было---
		//////+++ Дмгг
		////|	РасходСоСчета.Проект КАК Проект
		//////--- Дмгг
		////Стало+++
		//|	РасходСоСчета.ПроектДляЗачетаАвансаСПомощником КАК Проект
		////ПодольскийАИ #УчетПроектов 10.02.2021 }
		
		//_Lazare 09.03.2021
		|   ВЫБОР
		|		КОГДА 	РасходСоСчета.ПроектДляЗачетаАвансаСПомощником = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
		|			ТОГДА ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
		|		ИНАЧЕ РасходСоСчета.ПроектДляЗачетаАвансаСПомощником
		|	КОНЕЦ КАК Проект
		//Lazare 09.03.2021
		|ПОМЕСТИТЬ ВременнаяТаблицаСрокУплаты
		|ИЗ
		|	Документ.РасходСоСчета КАК РасходСоСчета
