	РасшифровкаПлатежа.Очистить();
	НоваяСтрока = РасшифровкаПлатежа.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	ЭтотОбъект.СуммаДокумента = Выборка.СуммаПлатежа;
	
