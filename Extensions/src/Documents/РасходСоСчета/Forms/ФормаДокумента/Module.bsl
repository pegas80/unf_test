		КонецЦикла;
	Иначе
		ТекДанные = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
		// +++ { AzRy - [29.01.2021] - Jira:ERPM-809 - Developer:გიორგი მამულაშვილი - Comment:
		Если ЯвляетсяНеРезидентом Тогда
			AzRyОбщегоНазначения.ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные);
		Иначе 
			РС_ОбщегоНазначения.ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные);
		КонецЕсли; 
		// +++ } AzRy - [29.01.2021] - Jira:ERPM-809 - Developer:გიორგი მამულაშვილი - Comment:		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&После("ОчиститьРеквизитыНеОтносящиесяКОперации")
Процедура РасшAzRy_ОчиститьРеквизитыНеОтносящиесяКОперации()
	
	// +++ { AzRy - [25.08.2021] - Jira:ERPM-259 - Developer:გიორგი მამულაშვილი (George Mamulashvili) - Comment:დაემატა ახალი ტიპი "ანგარიშვალდებული პირი" რომელიც ანალოგიურია "მომწოდებელი"-ს
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.AzRyПоставщикуПодотчетнику") Тогда
		Объект.Корреспонденция = Неопределено;
		Объект.КорреспонденцияРегл = Неопределено; //+++ Дмгг
		Объект.ВидНалога = Неопределено;
		Объект.Контрагент = Неопределено;
		Объект.СчетКонтрагента = Неопределено;
		Объект.Подразделение = Неопределено;
		Объект.НаправлениеДеятельности = Неопределено;
		Объект.Заказ = Неопределено;
		Объект.АналитикаПрочихДоходовИРасходов = Неопределено;
		Объект.ДоговорКредитаЗайма = Неопределено;
		Объект.ВыплатаЗаработнойПлаты.Очистить();
		Объект.ПлатежныеВедомости.Очистить(); // Kuzmich, 23.02.2019,Зарплата по ведомости в разрезе сотрудников
		Для каждого СтрокаТаблицы Из Объект.РасшифровкаПлатежа Цикл
			СтрокаТаблицы.Договор = Неопределено;
			СтрокаТаблицы.ПризнакАванса = Ложь;
			СтрокаТаблицы.Документ = Неопределено;
			СтрокаТаблицы.Заказ = Неопределено;
			СтрокаТаблицы.СчетНаОплату = Неопределено;
			СтрокаТаблицы.СтавкаНДС = Неопределено;
			СтрокаТаблицы.СуммаНДС = Неопределено;
		КонецЦикла;
		Объект.ЭквайринговыеОперации.Очистить();
	КонецЕсли;	
	// +++ } AzRy - [25.08.2021] - Jira:ERPM-259 - Developer:გიორგი მამულაშვილი (George Mamulashvili) - Comment:დაემატა ახალი ტიპი "ანგარიშვალდებული პირი" რომელიც ანალოგიურია "მომწოდებელი"-ს
	
КонецПроцедуры

&НаСервере
&После("УстановитьВидимостьЭлементовВЗависимостиОтВидаОперации")
Процедура РасшAzRy_УстановитьВидимостьЭлементовВЗависимостиОтВидаОперации(ПриСозданииНаСервере)
			
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику") Тогда		
		
		Элементы.ГруппаКонтрагент.Видимость = Ложь;
		Элементы.Контрагент.Видимость = Ложь;
		
		Элементы.РасчетыСКонтрагентом.Видимость = Истина;
		Элементы.РасшифровкаПлатежаПодбор.Видимость = Истина;
		Элементы.РасшифровкаПлатежаЗаполнитьРасшифровку.Видимость = Истина;
		
		Элементы.ГруппаКонтрагент.Видимость = Истина;
		//Элементы.Контрагент.Видимость = Истина;
		Элементы.Контрагент.Заголовок = НСтр("ka='მომწოდებელი';ru='Поставщик';en='Supplier'");
		Элементы.СчетКонтрагента.Видимость = Истина;
		Элементы.НалогообложениеНДС.Видимость = Истина;
			
		Элементы.РасшифровкаПлатежаДоговор.Видимость      = Ложь;
		//Элементы.РасшифровкаПлатежаСуммаПлатежа.Видимость = Ложь;
				
		Элементы.СтраницыРасчетовСКонтрагентом.ТекущаяСтраница = Элементы.СтраницаРучноеЗаполнение;
		Элементы.СтраницыРасчетовСКонтрагентомПодвал.ТекущаяСтраница = Элементы.ПодвалВручную;
				
	КонецЕсли;	
	
КонецПроцедуры

#Область AzRy

&НаКлиенте
Процедура РасшAzRy_ГиперссылкаJiraНажатиеПосле(Элемент)
	
	Если ЗначениеЗаполнено(Объект.AzRyJiraCode) Тогда
		ЗапуститьПриложение(AzRyОбщегоНазначения.ПолучитьАдресВебРесурсаJira() + Объект.AzRyJiraCode);
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти
