&НаСервере
Функция НайтиОрганизациюExcel(Наименование)
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Возврат Справочники.Организации.ПустаяСсылка();
	КонецЕсли;
	Возврат Справочники.Организации.НайтиПоНаименованию(Наименование, Истина);
КонецФункции

&НаСервере
Функция НайтиКонтрагентаExcel(Наименование)
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;

	// При совпадении наименования у нескольких контрагентов выбираем
	// того, у кого наибольший код - он был создан последним
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Контрагенты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Наименование = &Наименование
		|	И НЕ Контрагенты.ПометкаУдаления
		|УПОРЯДОЧИТЬ ПО
		|	Контрагенты.Код УБЫВ";
	Запрос.УстановитьПараметр("Наименование", Наименование);

	РезЗапроса = Запрос.Выполнить();
	Если РезЗапроса.Пустой() Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	Выборка = РезЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;

КонецФункции

&НаСервере
Функция НайтиБанковскийСчетExcel(НомерСчета, Организация)
	Если НЕ ЗначениеЗаполнено(НомерСчета) Тогда
		Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	БанковскиеСчета.Ссылка
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	БанковскиеСчета.НомерСчета = &НомерСчета
		|	И БанковскиеСчета.Владелец = &Организация
		|	И НЕ БанковскиеСчета.ПометкаУдаления";
	Запрос.УстановитьПараметр("НомерСчета",  НомерСчета);
	Запрос.УстановитьПараметр("Организация", Организация);

	РезЗапроса = Запрос.Выполнить();
	Если РезЗапроса.Пустой() Тогда
		Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
	КонецЕсли;
	Выборка = РезЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
КонецФункции

&НаСервере
Функция НайтиДоговорExcel(Наименование, Контрагент)
