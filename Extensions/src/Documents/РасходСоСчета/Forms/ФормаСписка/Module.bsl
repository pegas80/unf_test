
#Область ЗагрузкаИзExcel

// Обработчик команды «Загрузить из Excel».
&НаКлиенте
Процедура РасшAzRy_ЗагрузитьИзExcel(Команда)

	ДиалогВыбора = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	ДиалогВыбора.Фильтр             = "Excel файлы (*.xlsx)|*.xlsx|Все файлы (*.*)|*.*";
	ДиалогВыбора.МножественныйВыбор = Ложь;
	ДиалогВыбора.Заголовок          = "Выберите файл Excel для загрузки РасходСоСчета";

	Если НЕ ДиалогВыбора.Выбрать() Тогда
		Возврат;
	КонецЕсли;

	АдресФайлаВХранилище = "";
	ПоместитьФайл(АдресФайлаВХранилище, ДиалогВыбора.ПолноеИмяФайла, , Ложь, УникальныйИдентификатор);

	Результат = ЗагрузитьИзExcelНаСервере(АдресФайлаВХранилище);

	Элементы.Список.Обновить();

	ПоказатьРезультатЗагрузкиExcel(Результат);

КонецПроцедуры

// Показывает итоговое сообщение с результатами импорта.
&НаКлиенте
Процедура ПоказатьРезультатЗагрузкиExcel(Результат)

	ТекстСообщения =
		"Результат загрузки из Excel:"         + Символы.ПС
		+ "  Строк прочитано:    " + Результат.ВсегоСтрок        + Символы.ПС
		+ "  Документов создано: " + Результат.ДокументовСоздано  + Символы.ПС
		+ "  Строк пропущено:    " + Результат.СтрокПропущено;

	Если Результат.ТекстыОшибок.Количество() > 0 Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + Символы.ПС + "Причины пропуска:";
		Для Каждого ТекстОшибки Из Результат.ТекстыОшибок Цикл
			ТекстСообщения = ТекстСообщения + Символы.ПС + "  • " + ТекстОшибки;
		КонецЦикла;
	КонецЕсли;

	ПоказатьПредупреждение(, ТекстСообщения, , "Загрузка из Excel");

КонецПроцедуры

// Читает файл Excel и создаёт документы РасходСоСчета.
//
// Структура колонок (строки 1-2 - заголовки, данные начинаются со строки 3):
//   A(1)  - Дата документа                              [обязательный]
//   B(2)  - Организация (наименование)                  [обязательный]
//   C(3)  - Банковский счёт организации (номер счёта)   [обязательный]
//   D(4)  - Контрагент (наименование)                   [обязательный]
//   E(5)  - Договор контрагента (наименование)          [обязательный]
//   F(6)  - Сумма                                       [обязательный]
//   G(7)  - Статья движения денежных средств (наименование) [обязательный]
//   H(8)  - Назначение платежа                          [необязательный]
//   I(9)  - Номер документа взаимозачёта                [обязательный]
//   J(10) - Дата документа взаимозачёта                 [обязательный]
// Валюта берётся автоматически из банковского счёта.
//
// Возвращает структуру: ВсегоСтрок, ДокументовСоздано, СтрокПропущено, ТекстыОшибок.
&НаСервере
Функция ЗагрузитьИзExcelНаСервере(АдресФайлаВХранилище)

	// ---- Номера колонок (изменить здесь при другой структуре файла) ---- //
	КолДата              = 1;
	КолОрганизация       = 2;
	КолБанковскийСчет    = 3;
	КолКонтрагент        = 4;
	КолДоговор           = 5;
	КолСумма             = 6;
	КолСтатьяДДС         = 7;
	КолНазначениеПлатежа = 8;
	КолНомерВзаимозачет  = 9;
	КолДатаВзаимозачет   = 10;
	НачальнаяСтрокаДанных = 3; // строки 1-2 - заголовки

	Результат = Новый Структура(
		"ВсегоСтрок, ДокументовСоздано, СтрокПропущено, ТекстыОшибок",
		0, 0, 0, Новый Массив);

	// Читаем xlsx напрямую как XML (не требует Excel на сервере)
	Данные = ПрочитатьExcelВМассив(АдресФайлаВХранилище);

	ВсегоСтрокФайла = Данные.Количество();
	Результат.ВсегоСтрок = Макс(0, ВсегоСтрокФайла - НачальнаяСтрокаДанных + 1);

	Для НомерСтроки = НачальнаяСтрокаДанных По ВсегоСтрокФайла Цикл

		// Читаем значения ячеек строки
		ЗначДата       = ЗначЯч(Данные, НомерСтроки, КолДата);
		ЗначОрганизация = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолОрганизация)));
		ЗначБанкСчет    = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолБанковскийСчет)));
		ЗначКонтрагент  = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолКонтрагент)));
		ЗначДоговор     = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолДоговор)));
		ЗначСумма            = ЗначЯч(Данные, НомерСтроки, КолСумма);
		ЗначСтатьяДДС        = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолСтатьяДДС)));
		ЗначНазначение       = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолНазначениеПлатежа)));
		ЗначНомерВзаимозачет = СокрЛП(Строка(ЗначЯч(Данные, НомерСтроки, КолНомерВзаимозачет)));
		ЗначДатаВзаимозачет  = ЗначЯч(Данные, НомерСтроки, КолДатаВзаимозачет);

		// Пропускаем полностью пустые строки (не считаем их ошибкой)
		Если НЕ ЗначениеЗаполнено(ЗначДата)
			И НЕ ЗначениеЗаполнено(ЗначОрганизация)
			И НЕ ЗначениеЗаполнено(ЗначСумма) Тогда
			Результат.ВсегоСтрок = Результат.ВсегоСтрок - 1;
			Продолжить;
		КонецЕсли;

		// ---- Обязательные реквизиты ---- //
		РезПроверки = ПроверитьОбязательныеExcel(НомерСтроки, ЗначДата, ЗначОрганизация, ЗначБанкСчет, ЗначСумма);
		Если РезПроверки.ЕстьОшибки Тогда
			Результат.ТекстыОшибок.Добавить(РезПроверки.ТекстОшибки);
			Результат.СтрокПропущено = Результат.СтрокПропущено + 1;
			Продолжить;
		КонецЕсли;

		ДатаДокумента  = РезПроверки.ДатаДокумента;
		Организация    = РезПроверки.Организация;
		БанковскийСчет = РезПроверки.БанковскийСчет;
		СуммаЧисло     = РезПроверки.СуммаЧисло;

		// ---- Поиск и проверка остальных обязательных реквизитов ---- //
		ТекстОшибки   = "";
		ПрефиксОшибки = "Строка " + НомерСтроки + ": ";

		Контрагент = НайтиКонтрагентаExcel(ЗначКонтрагент);
		Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
			ТекстОшибки = ТекстОшибки + ПрефиксОшибки + "контрагент «" + ЗначКонтрагент + "» не найден. ";
		КонецЕсли;

		Договор = НайтиДоговорExcel(ЗначДоговор, Контрагент);
		Если НЕ ЗначениеЗаполнено(Договор) Тогда
			ТекстОшибки = ТекстОшибки + ПрефиксОшибки + "договор «" + ЗначДоговор + "» не найден. ";
		КонецЕсли;

		СтатьяДДС = НайтиСтатьюДДСExcel(ЗначСтатьяДДС);
		Если НЕ ЗначениеЗаполнено(СтатьяДДС) Тогда
			ТекстОшибки = ТекстОшибки + ПрефиксОшибки + "статья ДДС «" + ЗначСтатьяДДС + "» не найдена. ";
		КонецЕсли;

		ДокументВзаимозачет = НайтиДокументВзаимозачетExcel(ЗначНомерВзаимозачет, ЗначДатаВзаимозачет);
		Если НЕ ЗначениеЗаполнено(ДокументВзаимозачет) Тогда
			ТекстОшибки = ТекстОшибки + ПрефиксОшибки
				+ "документ взаимозачёта «" + ЗначНомерВзаимозачет + "» не найден. ";
		КонецЕсли;

		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			Результат.ТекстыОшибок.Добавить(ТекстОшибки);
			Результат.СтрокПропущено = Результат.СтрокПропущено + 1;
			Продолжить;
		КонецЕсли;

		// ---- Создание документа ---- //
		ДопРеквизиты = Новый Структура;
		ДопРеквизиты.Вставить("Контрагент",          Контрагент);
		ДопРеквизиты.Вставить("Договор",             Договор);
		ДопРеквизиты.Вставить("СтатьяДДС",           СтатьяДДС);
		ДопРеквизиты.Вставить("НазначениеПлатежа",   ЗначНазначение);
		ДопРеквизиты.Вставить("ДокументВзаимозачет", ДокументВзаимозачет);

		Попытка
			СоздатьДокументРасходСоСчетаExcel(
				ДатаДокумента, Организация, БанковскийСчет,
				СуммаЧисло, ДопРеквизиты);
			Результат.ДокументовСоздано = Результат.ДокументовСоздано + 1;
		Исключение
			Результат.ТекстыОшибок.Добавить(
				"Строка " + НомерСтроки + ": ошибка записи - " + ОписаниеОшибки());
			Результат.СтрокПропущено = Результат.СтрокПропущено + 1;
		КонецПопытки;

	КонецЦикла;

	Возврат Результат;

КонецФункции

// Преобразует значение ячейки Excel в тип Дата.
// Поддерживает: числовой серийный номер Excel, тип Дата, строки DD.MM.YYYY и DD.MM.YYYY HH:MM:SS.
//
// Параметры:
//  ЗначДата - Произвольный - значение ячейки Excel.
//
// Возвращаемое значение:
//  Дата - преобразованная дата или '00010101' при ошибке.
&НаСервере
Функция ПреобразоватьДатуExcel(ЗначДата)
	Если ТипЗнч(ЗначДата) = Тип("Число") И ЗначДата > 0 Тогда
		Возврат ExcelСерийноеЧислоВДату(ЗначДата);
	ИначеЕсли ТипЗнч(ЗначДата) = Тип("Дата") И ЗначениеЗаполнено(ЗначДата) Тогда
		Возврат ЗначДата;
	Иначе
		// Строка: поддерживаем формат DD.MM.YYYY [HH:MM:SS]
		Попытка
			// Позиции символов в формате DD.MM.YYYY
			МинДлинаДаты    = 10; // DD.MM.YYYY = 10 символов
			ПозПервойТочки  = 3;
			ПозВторойТочки  = 6;
			ПозГода         = 7;
			ДлинаГода       = 4;
			ПозМесяца       = 4;
			ДлинаМесяца     = 2;
			ДлинаДня        = 2;

			СтрДата = СокрЛП(Строка(ЗначДата));
			Если СтрДлина(СтрДата) >= МинДлинаДаты
				И Сред(СтрДата, ПозПервойТочки, 1) = "."
				И Сред(СтрДата, ПозВторойТочки, 1) = "." Тогда
				// DD.MM.YYYY -> YYYYMMDD
				СтрДата = Сред(СтрДата, ПозГода, ДлинаГода)
					+ Сред(СтрДата, ПозМесяца, ДлинаМесяца)
					+ Лев(СтрДата, ДлинаДня);
			КонецЕсли;
			Рез = Дата(СтрДата);
			Если НЕ ЗначениеЗаполнено(Рез) Тогда
				ВызватьИсключение "пустая дата";
			КонецЕсли;
			Возврат Рез;
		Исключение
			Возврат '00010101';
		КонецПопытки;
	КонецЕсли;
КонецФункции

// Проверяет обязательные реквизиты строки Excel.
// Возвращает структуру: ТекстОшибки, ДатаДокумента, Организация, БанковскийСчет, СуммаЧисло, ЕстьОшибки.
&НаСервере
Функция ПроверитьОбязательныеExcel(НомерСтроки, ЗначДата, ЗначОрганизация, ЗначБанкСчет, ЗначСумма)
	Рез = Новый Структура(
		"ТекстОшибки, ДатаДокумента, Организация, БанковскийСчет, СуммаЧисло, ЕстьОшибки",
		"", '00010101',
		Справочники.Организации.ПустаяСсылка(),
		Справочники.БанковскиеСчета.ПустаяСсылка(),
		0, Ложь);

	Пфх = "Строка " + НомерСтроки + ": "; // префикс для сообщений об ошибках

	Рез.ДатаДокумента = ПреобразоватьДатуExcel(ЗначДата);
	Если НЕ ЗначениеЗаполнено(Рез.ДатаДокумента) Тогда
		Рез.ТекстОшибки = Рез.ТекстОшибки + Пфх + "некорректная дата «" + ЗначДата + "». ";
	КонецЕсли;

	Рез.Организация = НайтиОрганизациюExcel(ЗначОрганизация);
	Если НЕ ЗначениеЗаполнено(Рез.Организация) Тогда
		Рез.ТекстОшибки = Рез.ТекстОшибки + Пфх + "организация «" + ЗначОрганизация + "» не найдена. ";
	КонецЕсли;

	Рез.БанковскийСчет = НайтиБанковскийСчетExcel(ЗначБанкСчет, Рез.Организация);
	Если НЕ ЗначениеЗаполнено(Рез.БанковскийСчет) Тогда
		Рез.ТекстОшибки = Рез.ТекстОшибки + Пфх + "счёт «" + ЗначБанкСчет + "» не найден. ";
	КонецЕсли;

	Попытка
		Рез.СуммаЧисло = Число(ЗначСумма);
	Исключение
		Рез.СуммаЧисло = 0;
	КонецПопытки;
	Если Рез.СуммаЧисло = 0 Тогда
		Рез.ТекстОшибки = Рез.ТекстОшибки + Пфх + "сумма не заполнена или равна нулю. ";
	КонецЕсли;

	Рез.ЕстьОшибки = НЕ ЗначениеЗаполнено(Рез.ДатаДокумента)
		ИЛИ НЕ ЗначениеЗаполнено(Рез.Организация)
		ИЛИ НЕ ЗначениеЗаполнено(Рез.БанковскийСчет)
		ИЛИ Рез.СуммаЧисло = 0;

	Возврат Рез;
КонецФункции

// Создаёт и записывает документ РасходСоСчета на основе данных из строки Excel.
// Параметры:
//   ДатаДокумента - Дата   - дата создаваемого документа.
//   Организация   - СправочникСсылка.Организации - организация документа.
//   БанковскийСчет - СправочникСсылка.БанковскиеСчета - счёт списания.
//   СуммаЧисло    - Число  - сумма документа в валюте счёта.
//   ДопРеквизиты  - Структура - поля: Контрагент, Договор, СтатьяДДС,
//                              НазначениеПлатежа, ДокументВзаимозачет.
&НаСервере
Процедура СоздатьДокументРасходСоСчетаExcel(
	ДатаДокумента, Организация, БанковскийСчет,
	СуммаЧисло, ДопРеквизиты)

	// Валюта берётся из реквизита банковского счёта
	Валюта = БанковскийСчет.ВалютаДенежныхСредств;

	КурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(
		ДатаДокумента, Новый Структура("Валюта", Валюта));

	НовыйДокумент = Документы.РасходСоСчета.СоздатьДокумент();
	НовыйДокумент.Дата                  = ДатаДокумента;
	НовыйДокумент.Организация           = Организация;
	НовыйДокумент.БанковскийСчет        = БанковскийСчет;
	НовыйДокумент.Контрагент            = ДопРеквизиты.Контрагент;
	НовыйДокумент.НалогообложениеНДС    = Организация.НалогообложениеНДС;
	НовыйДокумент.ВидОперации           = Перечисления.ВидыОперацийРасходСоСчета.Поставщику;
	НовыйДокумент.СуммаДокумента        = СуммаЧисло;
	НовыйДокумент.ВалютаДенежныхСредств = Валюта;
	НовыйДокумент.Статья                = ДопРеквизиты.СтатьяДДС;
	НовыйДокумент.НазначениеПлатежа     = ДопРеквизиты.НазначениеПлатежа;

	СтрокаРасшифровки = НовыйДокумент.РасшифровкаПлатежа.Добавить();
	СтрокаРасшифровки.Договор      = ДопРеквизиты.Договор;
	СтрокаРасшифровки.Документ     = ДопРеквизиты.ДокументВзаимозачет;
	СтрокаРасшифровки.Курс         = КурсКратность.Курс;
	СтрокаРасшифровки.Кратность    = КурсКратность.Кратность;
	СтрокаРасшифровки.СуммаПлатежа = СуммаЧисло;

	Если НовыйДокумент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НаЭкспорт Тогда
		СтрокаРасшифровки.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
	ИначеЕсли НовыйДокумент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
		СтрокаРасшифровки.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
	Иначе
		СтрокаРасшифровки.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС18");
	КонецЕсли;
	ПроцентнаяБаза = 100; // делитель для перевода ставки НДС из процентов в коэффициент
	СтрокаРасшифровки.СуммаНДС = СтрокаРасшифровки.СуммаПлатежа
		- СтрокаРасшифровки.СуммаПлатежа / ((СтрокаРасшифровки.СтавкаНДС.Ставка + ПроцентнаяБаза) / ПроцентнаяБаза);

	ПересчитатьСуммыДокумента(НовыйДокумент, СтрокаРасшифровки,
		СтрокаРасшифровки.Курс, СтрокаРасшифровки.Кратность, БанковскийСчет);

	НовыйДокумент.Записать(РежимЗаписиДокумента.Запись);

КонецПроцедуры

Процедура ПересчитатьСуммыДокумента(ДокументБанк,СтрокаТабличнойЧасти, Курс, Кратность, БанковскийСчет)
	СтруктураДанные = Новый Структура;
	
	СтруктураДанные.Вставить("ВалютаКурсКратность",РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументБанк.Дата,	Новый Структура("Валюта", БанковскийСчет.ВалютаДенежныхСредств)));
	СтруктураДанные.Вставить("ВалютаДенежныхСредств",БанковскийСчет.ВалютаДенежныхСредств);
	
	естьПоступлениеНаСчет = ТипЗнч(ДокументБанк) = Тип("ДокументОбъект.ПоступлениеНаСчет");
	Если ЗначениеЗаполнено(ДокументБанк.ВалютаДенежныхСредств) И естьПоступлениеНаСчет Тогда
		Курс = ?(
		СтруктураДанные.ВалютаКурсКратность.Курс = 0,
		1,
		СтруктураДанные.ВалютаКурсКратность.Курс
		);
		Кратность = ?(
		СтруктураДанные.ВалютаКурсКратность.Кратность = 0,
		1,
		СтруктураДанные.ВалютаКурсКратность.Кратность
		);
		//Если ДокументБанк.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ПокупкаВалюты") Тогда
		//	ДокументБанк.Курс = Курс;
		//	ДокументБанк.Кратность = Кратность;
		//КонецЕсли;
		
		ДокументБанк.Курс = ?(
		ДокументБанк.Курс = 0,
		1,
		ДокументБанк.Курс
		);
		ДокументБанк.Кратность = ?(
		ДокументБанк.Кратность = 0,
		1,
		ДокументБанк.Кратность
		);
		
		ДокументБанк.СуммаУчета = УправлениеНебольшойФирмойСервер.ПересчитатьИзВалютыВВалюту(
		ДокументБанк.СуммаДокумента,
		ДокументБанк.Курс,
		Курс,
		ДокументБанк.Кратность,
		Кратность
		);

	КонецЕсли;
	
	Если Не СтрокаТабличнойЧасти = Неопределено Тогда  
		СтрокаТабличнойЧасти.Курс = ?(
		СтрокаТабличнойЧасти.Курс = 0,
		1,
		СтрокаТабличнойЧасти.Курс
		);
		СтрокаТабличнойЧасти.Кратность = ?(
		СтрокаТабличнойЧасти.Кратность = 0,
		1,
		СтрокаТабличнойЧасти.Кратность
		);
		СтрокаТабличнойЧасти.СуммаРасчетов = УправлениеНебольшойФирмойСервер.ПересчитатьИзВалютыВВалюту(
		СтрокаТабличнойЧасти.СуммаПлатежа,
		Курс,
		СтрокаТабличнойЧасти.Курс,
		Кратность,
		СтрокаТабличнойЧасти.Кратность
		);
	КонецЕсли;
	
КонецПроцедуры // ПересчитатьСуммыДокумента()


//------------------------------------------------------------------------------
// Чтение xlsx через XML (не требует Excel на сервере)
//------------------------------------------------------------------------------

// Читает xlsx-файл из временного хранилища.
// Возвращает Массив строк, каждая строка — Массив значений (1-индексированный интерфейс).
&НаСервере
Функция ПрочитатьExcelВМассив(АдресФайлаВХранилище)

	// Сохраняем двоичные данные во временный файл - нужен физический файл для ЧтениеZIP
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресФайлаВХранилище);
	ИмяXlsx        = ПолучитьИмяВременногоФайла("xlsx");
	ДвоичныеДанные.Записать(ИмяXlsx);

	// xlsx - это ZIP-архив; создаём рядом каталог для извлечённого содержимого
	ПапкаВременная = ИмяXlsx + "_dir";
	СоздатьКаталог(ПапкаВременная);

	// Распаковываем архив; при ошибке удаляем оба временных объекта перед пробросом исключения
	Попытка
		ЧтениеZip = Новый ЧтениеZipФайла(ИмяXlsx);
		ЧтениеZip.ИзвлечьВсе(ПапкаВременная, РежимВосстановленияПутейФайловZIP.Восстанавливать);
		ЧтениеZip.Закрыть();
	Исключение
		УдалитьФайлы(ИмяXlsx);
		УдалитьФайлы(ПапкаВременная);
		ВызватьИсключение НСТР("ru = 'Не удалось распаковать xlsx: ';
			|en = 'Failed to unpack xlsx: ';
			|ka = 'xlsx ფაილის გახსნა ვერ მოხერხდა: '") + ОписаниеОшибки();
	КонецПопытки;

	// Исходный xlsx-файл больше не нужен - удаляем сразу после распаковки
	УдалитьФайлы(ИмяXlsx);

	// Ищем нужные XML-файлы по имени (рекурсивно - путь внутри zip может различаться)
	ФайлыSS   = НайтиФайлы(ПапкаВременная, "sharedStrings.xml", Истина);
	ПутьSS    = ?(ФайлыSS.Количество()  > 0, ФайлыSS[0].ПолноеИмя,  "");

	ФайлыЛист = НайтиФайлы(ПапкаВременная, "sheet1.xml", Истина);
	ПутьЛист  = ?(ФайлыЛист.Количество() > 0, ФайлыЛист[0].ПолноеИмя, "");

	// sheet1.xml обязателен; отсутствие означает, что файл не является корректным xlsx
	Если НЕ ЗначениеЗаполнено(ПутьЛист) Тогда
		УдалитьФайлы(ПапкаВременная);
		ВызватьИсключение НСТР("ru = 'В файле не найден лист (sheet1.xml). Файл должен быть формата .xlsx.';
			|en = 'Sheet not found in the file (sheet1.xml). The file must be in .xlsx format.';
			|ka = 'ფაილში ფურცელი ვერ მოიძებნა (sheet1.xml). ფაილი უნდა იყოს .xlsx ფორმატის.'");
	КонецЕсли;

	// Читаем XML; при любой ошибке чтения гарантируем удаление временной папки
	Попытка
		ОбщиеСтроки = ПрочитатьОбщиеСтрокиXml(ПутьSS);
		МассивСтрок = ПрочитатьЛистXml(ПутьЛист, ОбщиеСтроки);
	Исключение
		УдалитьФайлы(ПапкаВременная);
		ВызватьИсключение;
	КонецПопытки;

	// Чтение завершено - удаляем временный каталог
	УдалитьФайлы(ПапкаВременная);

	Возврат МассивСтрок;

КонецФункции

// Возвращает значение ячейки из двумерного массива (1-индексированный).
&НаСервере
Функция ЗначЯч(Данные, Строка, Колонка)
	Если Строка > Данные.Количество() Тогда
		Возврат "";
	КонецЕсли;
	СтрокаДанных = Данные[Строка - 1];
	Если Колонка > СтрокаДанных.Количество() Тогда
		Возврат "";
	КонецЕсли;
	Возврат СтрокаДанных[Колонка - 1];
КонецФункции

// Читает xl/sharedStrings.xml и возвращает Массив строк.
// Строки в xlsx хранятся в отдельной таблице — ячейки ссылаются на них по индексу.
&НаСервере
Функция ПрочитатьОбщиеСтрокиXml(ПутьКФайлу)
	ОбщиеСтроки = Новый Массив;
	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда
		Возврат ОбщиеСтроки; // файл отсутствует — нет строковых значений
	КонецЕсли;

	ЧтениеXML = Новый ЧтениеXML;
	Попытка
		ЧтениеXML.ОткрытьФайл(ПутьКФайлу);
	Исключение
		Возврат ОбщиеСтроки;
	КонецПопытки;

	ТекСтрока = "";
	ВнутриT   = Ложь;

	Пока ЧтениеXML.Прочитать() Цикл
		Тип = ЧтениеXML.ТипУзла;
		Имя = ЧтениеXML.ЛокальноеИмя;

		Если Тип = ТипУзлаXML.НачалоЭлемента Тогда
			Если    Имя = "si" Тогда ТекСтрока = "";
			ИначеЕсли Имя = "t"  Тогда ВнутриT = Истина;
			КонецЕсли;
		ИначеЕсли Тип = ТипУзлаXML.КонецЭлемента Тогда
			Если    Имя = "si" Тогда ОбщиеСтроки.Добавить(ТекСтрока);
			ИначеЕсли Имя = "t"  Тогда ВнутриT = Ложь;
			КонецЕсли;
		ИначеЕсли Тип = ТипУзлаXML.Текст И ВнутриT Тогда
			ТекСтрока = ТекСтрока + ЧтениеXML.Значение;
		КонецЕсли;
	КонецЦикла;

	ЧтениеXML.Закрыть();
	Возврат ОбщиеСтроки;
КонецФункции

// Читает xl/worksheets/sheet1.xml и возвращает двумерный Массив значений.
// Тип ячейки (атрибут t): "s"=SharedString, "str"/"inlineStr"=строка, "b"=булево, ""=число/дата.
&НаСервере
Функция ПрочитатьЛистXml(ПутьКФайлу, ОбщиеСтроки)
	МассивСтрок = Новый Массив;

	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.ОткрытьФайл(ПутьКФайлу);

	ТекСтрока    = Неопределено;
	ТекСсылка    = ""; // cell reference, e.g. "A3"
	ТекТип       = ""; // cell type attribute
	ВнутриV      = Ложь;
	ВнутриIS     = Ложь; // inline string <is><t>...</t></is>
	ЗначениеV    = "";

	Пока ЧтениеXML.Прочитать() Цикл
		Тип = ЧтениеXML.ТипУзла;
		Имя = ЧтениеXML.ЛокальноеИмя;

		Если Тип = ТипУзлаXML.НачалоЭлемента Тогда

			Если Имя = "row" Тогда
				ТекСтрока = Новый Массив;

			ИначеЕсли Имя = "c" Тогда
				АтрR = ЧтениеXML.ПолучитьАтрибут("r");
				АтрT = ЧтениеXML.ПолучитьАтрибут("t");
				ТекСсылка = ?(АтрR = Неопределено, "", АтрR);
				ТекТип    = ?(АтрT = Неопределено, "", АтрT);
				ВнутриV  = Ложь;
				ВнутриIS = Ложь;
				ЗначениеV = "";

			ИначеЕсли Имя = "v"  Тогда ВнутриV  = Истина;
			ИначеЕсли Имя = "is" Тогда ВнутриIS = Истина;
			КонецЕсли;

		ИначеЕсли Тип = ТипУзлаXML.КонецЭлемента Тогда

			Если Имя = "row" И ТекСтрока <> Неопределено Тогда
				МассивСтрок.Добавить(ТекСтрока);
				ТекСтрока = Неопределено;

			ИначеЕсли Имя = "c" И ТекСтрока <> Неопределено И ЗначениеЗаполнено(ТекСсылка) Тогда
				НомКол = КолонкаИзСсылки(ТекСсылка);

				// Заполняем пропуски — xlsx хранит только непустые ячейки
				Пока ТекСтрока.Количество() < НомКол - 1 Цикл
					ТекСтрока.Добавить("");
				КонецЦикла;

				Если ТекТип = "s" Тогда
					// Shared string — значение это индекс в ОбщиеСтроки
					Инд = 0;
					Попытка Инд = Число(ЗначениеV); Исключение КонецПопытки;
					ТекСтрока.Добавить(?(Инд < ОбщиеСтроки.Количество(), ОбщиеСтроки[Инд], ""));

				ИначеЕсли ТекТип = "str" ИЛИ ТекТип = "inlineStr" Тогда
					ТекСтрока.Добавить(ЗначениеV);

				ИначеЕсли ТекТип = "b" Тогда
					ТекСтрока.Добавить(ЗначениеV = "1");

				Иначе // число или дата (даты в xlsx — числа с форматом стиля)
					Если НЕ ЗначениеЗаполнено(ЗначениеV) Тогда
						ТекСтрока.Добавить("");
					Иначе
						Попытка
							ТекСтрока.Добавить(Число(ЗначениеV));
						Исключение
							ТекСтрока.Добавить(ЗначениеV);
						КонецПопытки;
					КонецЕсли;
				КонецЕсли;

			ИначеЕсли Имя = "v"  Тогда ВнутриV  = Ложь;
			ИначеЕсли Имя = "is" Тогда ВнутриIS = Ложь;
			КонецЕсли;

		ИначеЕсли Тип = ТипУзлаXML.Текст И (ВнутриV ИЛИ ВнутриIS) Тогда
			ЗначениеV = ЗначениеV + ЧтениеXML.Значение;

		КонецЕсли;
	КонецЦикла;

	ЧтениеXML.Закрыть();
	Возврат МассивСтрок;
КонецФункции

// Преобразует ссылку ячейки (напр. "AB12") в номер колонки (1-based).
&НаСервере
Функция КолонкаИзСсылки(Ссылка)
	Буквы = "";
	Для Н = 1 По СтрДлина(Ссылка) Цикл
		Симв = Сред(Ссылка, Н, 1);
		Если Симв >= "A" И Симв <= "Z" Тогда
			Буквы = Буквы + Симв;
		КонецЕсли;
	КонецЦикла;
	Результат = 0;
	Для Н = 1 По СтрДлина(Буквы) Цикл
		Результат = Результат * 26 + (КодСимвола(Сред(Буквы, Н, 1)) - КодСимвола("A") + 1);
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Преобразует серийный номер Excel в дату 1С.
// Excel день 1 = 01.01.1900; у Excel ошибка — считает 1900 год високосным (день 60 несуществующий).
&НаСервере
Функция ExcelСерийноеЧислоВДату(СерийноеЧисло)
	ЧислоДней = Цел(СерийноеЧисло) - 1;
	Если СерийноеЧисло >= 61 Тогда
		ЧислоДней = ЧислоДней - 1; // компенсация несуществующего 29.02.1900
	КонецЕсли;
	Возврат '19000101' + ЧислоДней * 86400;
КонецФункции

