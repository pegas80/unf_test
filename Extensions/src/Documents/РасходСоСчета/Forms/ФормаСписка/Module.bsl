КонецФункции

&НаСервере
Функция НайтиВалютуExcel(КодИлиНаименование)
	Если НЕ ЗначениеЗаполнено(КодИлиНаименование) Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Валюты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Валюты КАК Валюты
		|ГДЕ
		|	НЕ Валюты.ПометкаУдаления
		|	И (Валюты.Код = &Значение
		|			ИЛИ Валюты.Наименование = &Значение)";
	Запрос.УстановитьПараметр("Значение", КодИлиНаименование);

	РезЗапроса = Запрос.Выполнить();
	Если РезЗапроса.Пустой() Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	Выборка = РезЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Ссылка;
КонецФункции

&НаСервере
Функция НайтиСтатьюДДСExcel(Наименование)
	Если НЕ ЗначениеЗаполнено(Наименование) Тогда
		Возврат Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
	КонецЕсли;
	Возврат Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоНаименованию(Наименование, Истина);
КонецФункции

&НаСервере
Функция НайтиДокументВзаимозачетExcel(Номер, Дата)
	Если НЕ ЗначениеЗаполнено(Номер) И НЕ ЗначениеЗаполнено(Дата) Тогда
		Возврат Документы.Взаимозачет.ПустаяСсылка();
	КонецЕсли;
	Возврат Документы.Взаимозачет.НайтиПоНомеру(Номер, Дата);
КонецФункции

