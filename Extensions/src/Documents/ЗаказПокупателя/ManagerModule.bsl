&Вместо("СформироватьТаблицаОплатаСчетовИЗаказов")
Процедура РасшAzRy_СформироватьТаблицаОплатаСчетовИЗаказов(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства)
	
		Запрос = Новый Запрос;
		
		Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаЗаказПокупателя);
		Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
		Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
		
		//ПМ Глухов 03.12.19 Для Счетов и заказов не учитываем сумму по подаркам
		Запрос.Текст =
		"ВЫБРАТЬ
		|	СУММА(ЗаказПокупателяЗапасы.Всего) КАК СуммаПодарка,
		|	ЗаказПокупателяЗапасы.Ссылка
		|ПОМЕСТИТЬ БезУчетаПодарков
		|ИЗ
		|	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
		|ГДЕ
		|	ЗаказПокупателяЗапасы.Ссылка = &Ссылка
		|	И ЗаказПокупателяЗапасы.ЭтоПодарок
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказПокупателяЗапасы.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаДокумента.Дата КАК Период,
		|	&Организация КАК Организация,
		|	ТаблицаДокумента.Ссылка КАК СчетНаОплату,
		|	ТаблицаДокумента.СуммаДокумента - ЕСТЬNULL(БезУчетаПодарков.СуммаПодарка, 0) КАК Сумма
		// +++ { AzRy - [19.04.2022] - Jira:ERPM-883 - Developer:გიორგი მამულაშვილი - Comment:
		|	,ТаблицаДокумента.Проект КАК Проект
		// +++ } AzRy - [19.04.2022] - Jira:ERPM-883 - Developer:გიორგი მამულაშვილი - Comment:		
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ТаблицаДокумента
		|		ЛЕВОЕ СОЕДИНЕНИЕ БезУчетаПодарков КАК БезУчетаПодарков
		|		ПО БезУчетаПодарков.Ссылка = ТаблицаДокумента.Ссылка
		|ГДЕ
		|	ТаблицаДокумента.Контрагент.ВестиУчетОплатыПоСчетам
		|	И ТаблицаДокумента.Ссылка = &Ссылка
		|	И ТаблицаДокумента.ВариантЗавершения <> ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
		|	И ТаблицаДокумента.СуммаДокумента <> 0";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаОплатаСчетовИЗаказов", РезультатЗапроса.Выгрузить());

