
&Вместо("ДобавитьТаблицуЗапасыВМенеджерВременныхТаблиц")
Процедура РасшAzRy_ДобавитьТаблицуЗапасыВМенеджерВременныхТаблиц(Знач Заказы, МенеджерВременныхТаблиц, ВключитьНоменклатуруДоставки)
	
	Если ТипЗнч(Заказы) <> Тип("Массив") Тогда
		Заказы = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Заказы);
	КонецЕсли;
	
	//ПодольскийАИ #УчетПроектов 30.09.2021 {
	УстановитьПривилегированныйРежим(Истина);
	УчетПоПроектам = ПолучитьФункциональнуюОпцию("УчетПоПроектам");
	УстановитьПривилегированныйРежим(Ложь);
	//ПодольскийАИ #УчетПроектов 30.09.2021 }
	
	Запрос = Новый Запрос;
	
	Если МенеджерВременныхТаблиц = Неопределено Тогда
		МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	КонецЕсли;
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказПокупателя.Ссылка КАК Ссылка,
	|	ЗаказПокупателя.ОсновнойВариантКП КАК ОсновнойВариантКП
	|ПОМЕСТИТЬ ВТЗаказы
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|ГДЕ
	|	ЗаказПокупателя.Ссылка В(&Ссылки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказПокупателяЗапасы.Ссылка КАК Ссылка,
	|	МАКСИМУМ(ЗаказПокупателяЗапасы.НомерСтроки) КАК НомерСтроки
	|ПОМЕСТИТЬ ВТМаксНомерСтрокиЗапасы
	|ИЗ
	|	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
	|ГДЕ
	|	ЗаказПокупателяЗапасы.Ссылка В(&Ссылки)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказПокупателяЗапасы.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказПокупателяЗапасы.Ссылка,
	|	ЗаказПокупателяЗапасы.НомерСтроки,
	|	ЗаказПокупателяЗапасы.НомерВариантаКП,
	|	ЗаказПокупателяЗапасы.Номенклатура,
	|	ЗаказПокупателяЗапасы.ТипНоменклатурыЗапас,
	|	ЗаказПокупателяЗапасы.Характеристика,
	//ПодольскийАИ #УчетПроектов 30.09.2021 {
	|	Выбор
	|		Когда Не &УчетПоПроектам
	|			Тогда Значение(Справочник.Проекты.ПустаяСсылка)
	|		Когда ЗаказПокупателяЗапасы.Ссылка.Проект = Значение(Справочник.Проекты.ПустаяСсылка)
	|			Тогда Значение(Справочник.Проекты.БезПроекта)
	|		Иначе ЗаказПокупателяЗапасы.Ссылка.Проект
	|	Конец КАК Проект,
	//ПодольскийАИ #УчетПроектов 30.09.2021 }
	|	ЗаказПокупателяЗапасы.Партия,
	|	ЗаказПокупателяЗапасы.СерийныеНомера,
	|	ЗаказПокупателяЗапасы.Резерв,
	|	ЗаказПокупателяЗапасы.РезервОтгрузка,
	|	ЗаказПокупателяЗапасы.ЕдиницаИзмерения,
	|	ЗаказПокупателяЗапасы.Цена,
	|	ЗаказПокупателяЗапасы.ПроцентСкидкиНаценки,
	|	ЗаказПокупателяЗапасы.Сумма,
	|	ЗаказПокупателяЗапасы.СтавкаНДС,
	|	ЗаказПокупателяЗапасы.СуммаНДС,
	|	ЗаказПокупателяЗапасы.Всего,
	|	ЗаказПокупателяЗапасы.ДатаОтгрузки,
	|	ЗаказПокупателяЗапасы.Спецификация,
	|	ЗаказПокупателяЗапасы.Содержание,
	|	ЗаказПокупателяЗапасы.ПроцентАвтоматическойСкидки,
	|	ЗаказПокупателяЗапасы.СуммаАвтоматическойСкидки,
	|	ЗаказПокупателяЗапасы.Количество,
	|	ЗаказПокупателяЗапасы.КлючСвязи,
	|	ЗаказПокупателяЗапасы.СтранаПроисхождения,
	|	ЗаказПокупателяЗапасы.НомерГТД,
	|	ЗаказПокупателяЗапасы.Вес,
	|	ЗаказПокупателяЗапасы.Объем,
	|	ЗаказПокупателяЗапасы.ЭтоПодарок,
	//_Lazare
	|   ЗаказПокупателяЗапасы.СтруктурнаяЕдиницаЗапасы КАК СтруктурнаяЕдиницаЗапасы,
	|	ЕСТЬNULL(ЗаказПокупателяЗапасы.КоличествоСобр, 0) КАК КоличествоСобр,
	//Lazare_
	|	ЗаказПокупателяЗапасы.НаименованиеДляРС
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	|	,ЗаказПокупателяЗапасы.Усушка_Потери
	|	,ЗаказПокупателяЗапасы.Усушка_СписаниеНаПотери
	|	,ЕСТЬNULL(ЗаказПокупателяЗапасы.Усушка_КоличествоСобрNET, 0) КАК Усушка_КоличествоСобрNET
	|	,ЗаказПокупателяЗапасы.Усушка_КоличествоСобрПотери
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	|	,ЗаказПокупателяЗапасы.Исполнитель КАК Исполнитель //++Lazare 27.10.2021
	// +++ { AzRy - [19.04.2022] - Jira:ERPM-883 - Developer:გიორგი მამულაშვილი - Comment:
	//|	,ЗаказПокупателяЗапасы.Ссылка.Проект КАК Проект
	// +++ } AzRy - [19.04.2022] - Jira:ERPM-883 - Developer:გიორგი მამულაშვილი - Comment:	
	|ПОМЕСТИТЬ ВТЗаказПокупателяЗапасы
	|ИЗ
	|	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЗаказы КАК Заказы
	|		ПО (Заказы.Ссылка = ЗаказПокупателяЗапасы.Ссылка)
	|			И (Заказы.ОсновнойВариантКП = ЗаказПокупателяЗапасы.НомерВариантаКП)
	|ГДЕ
	|	НЕ ЗаказПокупателяЗапасы.ЭтоРазделитель
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказПокупателя.Ссылка,
	|	ЕСТЬNULL(ВТМаксНомерСтрокиЗапасы.НомерСтроки, 0) + 1,
	|	Заказы.ОсновнойВариантКП,
	|	ЗаказПокупателя.НоменклатураДоставки,
	|	ЛОЖЬ,
	|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
	//ПодольскийАИ #УчетПроектов 30.09.2021 {
	|	Выбор
	|		Когда &УчетПоПроектам
	|			Тогда Значение(Справочник.Проекты.БезПроекта)
	|		Иначе Значение(Справочник.Проекты.ПустаяСсылка)
	|	Конец,
	//ПодольскийАИ #УчетПроектов 30.09.2021 }
	|	ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка),
	|	"""",
	|	0,
	|	0,
	|	ЗаказПокупателя.НоменклатураДоставки.ЕдиницаИзмерения,
	|	ЗаказПокупателя.СтоимостьДоставки,
	|	0,
	|	ЗаказПокупателя.СтоимостьДоставки,
	|	ЗаказПокупателя.СтавкаНДСДоставки,
	|	ЗаказПокупателя.СуммаНДСДоставки,
	|	ЗаказПокупателя.СтоимостьДоставки,
	|	ЗаказПокупателя.ДатаОтгрузки,
	|	ЗНАЧЕНИЕ(Справочник.Спецификации.ПустаяСсылка),
	|	"""",
	|	0,
	|	0,
	|	1,
	|	0,
	|	ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка),
	|	ЗНАЧЕНИЕ(Справочник.НомераГТД.ПустаяСсылка),
	|	0,
	|	0,
	|	ЛОЖЬ,
	//_Lazare
	|   ЗаказПокупателя.СтруктурнаяЕдиницаРезерв КАК СтруктурнаяЕдиницаРезерв,
	|   0,
	//Lazare_
	|	""""
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	|	,NULL
	|	,NULL
	|	,0
	|	,NULL
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	|	,NULL //++Lazare	
	// +++ { AzRy - [19.04.2022] - Jira:ERPM-883 - Developer:გიორგი მამულაშვილი - Comment:
	//|	,NULL
	// +++ } AzRy - [19.04.2022] - Jira:ERPM-883 - Developer:გიორგი მამულაშვილი - Comment:	
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЗаказы КАК Заказы
	|		ПО (Заказы.Ссылка = ЗаказПокупателя.Ссылка)
	|			И (ЗаказПокупателя.НоменклатураДоставки <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка))
	|			И (&ВключитьНоменклатуруДоставки)
	|			И (ЗаказПокупателя.СпособДоставки <> ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.ПустаяСсылка))
	|			И (ЗаказПокупателя.СпособДоставки <> ЗНАЧЕНИЕ(Перечисление.СпособыДоставки.Самовывоз))
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТМаксНомерСтрокиЗапасы КАК ВТМаксНомерСтрокиЗапасы
	|		ПО (ВТМаксНомерСтрокиЗапасы.Ссылка = ЗаказПокупателя.Ссылка)";
	
	Запрос.УстановитьПараметр("Ссылки", Заказы);
	Запрос.УстановитьПараметр("ВключитьНоменклатуруДоставки", ВключитьНоменклатуруДоставки);
	
	//ПодольскийАИ #УчетПроектов 30.09.2021 {
	Запрос.УстановитьПараметр("УчетПоПроектам", УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 30.09.2021 }
	
	РезультатЗапроса = Запрос.Выполнить();
 
КонецПроцедуры

&Вместо("ИнициализироватьДанныеДокументаЗаказНаряд")
Процедура РасшAzRy_ИнициализироватьДанныеДокументаЗаказНаряд(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства)
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ЗаказНаряд.Договор.ЭтоДоговорОбслуживания КАК ЭтоДоговорОбслуживания,
		|	ВЫБОР
		|		КОГДА ЗаказНаряд.Договор.ЭтоДоговорОбслуживания
		|				И ЗаказНаряд.Договор.ДоговорОбслуживанияНаправлениеДеятельности <> ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ВестиУчетРасходовПоДоговорамОбслуживания,
		|	ЗаказНаряд.Договор.ДоговорОбслуживанияНаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ВидыЗаказНарядовПорядокСостояний.НомерСтроки >= ВЫРАЗИТЬ(ЗаказНаряд.ВидЗаказа КАК Справочник.ВидыЗаказНарядов).НомерСостоянияВыполнения КАК ЭтоСостояниеВыполненияЗаказНаряда,
		|	ЗаказНаряд.ВариантЗавершения КАК ВариантЗавершения
		//+++ Дмгг
		|,	ЗаказНаряд.Пробег КАК Пробег,
		|	ЗаказНаряд.ТранпсортноеСедство КАК ТранспортноеСредство,
		|	ЗаказНаряд.Дата КАК Период
		//--- Дмгг
		|ПОМЕСТИТЬ ВременнаяТаблицаШапка
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказНаряд
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЗаказНарядов.ПорядокСостояний КАК ВидыЗаказНарядовПорядокСостояний
		|		ПО ЗаказНаряд.ВидЗаказа = ВидыЗаказНарядовПорядокСостояний.Ссылка
		|			И ЗаказНаряд.СостояниеЗаказа = ВидыЗаказНарядовПорядокСостояний.Состояние
		|ГДЕ
		|	ЗаказНаряд.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КурсыВалютСрезПоследних.Валюта КАК Валюта,
		|	КурсыВалютСрезПоследних.Курс КАК Курс,
		|	КурсыВалютСрезПоследних.Кратность КАК Кратность
		|ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаНациональная)) КАК КурсыВалютСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		//+++ Дмгг, Переписан алгоритм получения среднего курса документа
		|ВЫБРАТЬ
		|	ЗаказПокупателяПредоплата.Ссылка,
		|	СУММА(ЗаказПокупателяПредоплата.СуммаРасчетов) КАК СуммаРасчетов,
		|	СУММА(ЗаказПокупателяПредоплата.СуммаРасчетов * ЗаказПокупателяПредоплата.Курс / ЗаказПокупателяПредоплата.Кратность) КАК СуммаРасчетовРеглПоКурсуПредоплаты
		|ПОМЕСТИТЬ ВременнаяТаблицаСуммаПредоплатыГрупп
		|ИЗ
		|	Документ.ЗаказПокупателя.Предоплата КАК ЗаказПокупателяПредоплата
		|ГДЕ
		|	ЗаказПокупателяПредоплата.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказПокупателяПредоплата.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказПокупателя.Ссылка КАК Ссылка,
		|	ЗаказПокупателя.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаНеОплаченаВал,
		|	(ЗаказПокупателя.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК СуммаНеОплаченаРегл,
		|	ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаРасчетовВал,
		|	ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты КАК СуммаРасчетовРегл,
		|	(ЗаказПокупателя.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) КАК СуммаДокументаРеглПоВсемКурсам,
		|	ВЫБОР
		|		КОГДА ЗаказПокупателя.СуммаДокумента = 0
		|			ТОГДА 1
		|		ИНАЧЕ ((ЗаказПокупателя.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0)) / ЗаказПокупателя.СуммаДокумента
		|	КОНЕЦ КАК СреднийКурсДокумента,
		|	1 КАК Кратность
		|ПОМЕСТИТЬ ВременнаяТаблицаСреднегоКурсаПредоплаты
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаСуммаПредоплатыГрупп КАК ВременнаяТаблицаСуммаПредоплатыГрупп
		|		ПО ЗаказПокупателя.Ссылка = ВременнаяТаблицаСуммаПредоплатыГрупп.Ссылка
		|ГДЕ
		|	ЗаказПокупателя.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты.Ссылка,
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты.СреднийКурсДокумента КАК Курс,
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты.Кратность
		|ПОМЕСТИТЬ ВременнаяТаблицаСреднегоКурсаПоДокументу
		|ИЗ
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты КАК ВременнаяТаблицаСреднегоКурсаПредоплаты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		//--- Дмгг
		|ВЫБРАТЬ
		|	ЗаказНарядРаботы.НомерСтроки КАК НомерСтроки,
		|	ЗаказНарядРаботы.Ссылка.Дата КАК Период,
		|	ЗаказНарядРаботы.Ссылка.Финиш,
		|	&Организация КАК Организация,
		|	ЗаказНарядРаботы.Ссылка.СтруктурнаяЕдиницаПродажи КАК СтруктурнаяЕдиница,
		|	ЗаказНарядРаботы.Ссылка.Ответственный КАК Ответственный,
		|	ЗНАЧЕНИЕ(Справочник.СценарииПланирования.Фактический) КАК СценарийПланирования,
