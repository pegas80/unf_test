      <segments>Список.СтатусЗаказа</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.СтатусСостоянияЗаказа</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ЭлектроннаяПочтаКонтактногоЛица</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ЭлектроннаяПочтаКонтрагента</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Закрыт</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.КонтактноеЛицо</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Контрагент</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.СостояниеЗаказа</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ВЫБОР
		КОГДА НЕ ДокументЗаказПоставщику.Проведен
				ИЛИ ДокументЗаказПоставщику.ВариантЗавершения = ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
			ТОГДА 2
		КОГДА ГрафикВыполнения.Заказ ЕСТЬ NULL 
				И ГрафикВыполненияПлан.Заказ ЕСТЬ NULL 
			ТОГДА 0
		КОГДА ЕСТЬNULL(ГрафикВыполнения.Выполнено, 0) = 0
				И ЕСТЬNULL(ГрафикВыполненияПлан.Выполнено, 0) = 0
			ТОГДА ВЫБОР
					КОГДА ГрафикВыполнения.Заказ ЕСТЬ NULL 
						ТОГДА 2
					КОГДА ГрафикВыполнения.Период &lt; &amp;АкутальнаяДатаСеанса
						ТОГДА 6
					КОГДА ГрафикВыполнения.Период = &amp;АкутальнаяДатаСеанса
						ТОГДА 4
					ИНАЧЕ 2
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ГрафикВыполнения.Заказ ЕСТЬ NULL 
					ТОГДА 1
				КОГДА ГрафикВыполнения.Период &lt; &amp;АкутальнаяДатаСеанса
					ТОГДА 5
				КОГДА ГрафикВыполнения.Период = &amp;АкутальнаяДатаСеанса
					ТОГДА 3
				ИНАЧЕ 1
			КОНЕЦ
	КОНЕЦ КАК НомерКартинкиОтгрузки,
	ВЫБОР
		КОГДА НЕ ДокументЗаказПоставщику.Проведен
				ИЛИ ДокументЗаказПоставщику.ВариантЗавершения = ЗНАЧЕНИЕ(Перечисление.ВариантыЗавершенияЗаказа.Отменен)
			ТОГДА 2
		КОГДА ЕСТЬNULL(ФактОплаты.Сумма, 0) &lt;> 0
				И ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) = 0
			ТОГДА ВЫБОР
					КОГДА ДокументЗаказПоставщику.ЗапланироватьОплату
							И НЕ ГрафикОплаты.СчетНаОплату ЕСТЬ NULL 
							И НЕ ДокументЗаказПоставщику.СостояниеЗаказа = ЗНАЧЕНИЕ(Справочник.СостоянияЗаказовПокупателей.Завершен)
						ТОГДА ВЫБОР
								КОГДА ГрафикОплаты.Период &lt; &amp;АкутальнаяДатаСеанса
									ТОГДА 6
								КОГДА ГрафикОплаты.Период = &amp;АкутальнаяДатаСеанса
									ТОГДА 4
								ИНАЧЕ 2
							КОНЕЦ
					ИНАЧЕ 2
				КОНЕЦ
		КОГДА ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) >= ЕСТЬNULL(ФактОплаты.Сумма, 0)
			ТОГДА 0
		ИНАЧЕ ВЫБОР
				КОГДА ДокументЗаказПоставщику.ЗапланироватьОплату
						И НЕ ГрафикОплаты.СчетНаОплату ЕСТЬ NULL 
						И НЕ ДокументЗаказПоставщику.СостояниеЗаказа = ЗНАЧЕНИЕ(Справочник.СостоянияЗаказовПокупателей.Завершен)
					ТОГДА ВЫБОР
							КОГДА ГрафикОплаты.Период &lt; &amp;АкутальнаяДатаСеанса
								ТОГДА 5
							КОГДА ГрафикОплаты.Период = &amp;АкутальнаяДатаСеанса
								ТОГДА 3
							ИНАЧЕ 1
						КОНЕЦ
				ИНАЧЕ 1
			КОНЕЦ
	КОНЕЦ КАК НомерКартинкиОплаты,
	ВЫБОР
		КОГДА ДокументЗаказПоставщику.Проведен
				И ДокументЗаказПоставщику.СуммаДокумента > 0
			ТОГДА ВЫРАЗИТЬ((ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0)) * 100 / ДокументЗаказПоставщику.СуммаДокумента КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК ПроцентОплаты,
	ВЫБОР
		КОГДА НЕ ГрафикВыполнения.Заказ ЕСТЬ NULL 
				И ГрафикВыполнения.Период &lt; НАЧАЛОПЕРИОДА(&amp;АкутальнаяДатаСеанса, ДЕНЬ)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ПросроченоВыполнение,
	ВЫБОР
		КОГДА ДокументЗаказПоставщику.ЗапланироватьОплату
				И НЕ ГрафикОплаты.СчетНаОплату ЕСТЬ NULL 
				И ГрафикОплаты.Период &lt; НАЧАЛОПЕРИОДА(&amp;АкутальнаяДатаСеанса, ДЕНЬ)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ПросроченаОплата,
	ВЫБОР
		КОГДА НЕ ГрафикВыполнения.Заказ ЕСТЬ NULL 
				И ГрафикВыполнения.Период = НАЧАЛОПЕРИОДА(&amp;АкутальнаяДатаСеанса, ДЕНЬ)
			ТОГДА ИСТИНА
		КОГДА ДокументЗаказПоставщику.ЗапланироватьОплату
				И НЕ ГрафикОплаты.СчетНаОплату ЕСТЬ NULL 
				И ГрафикОплаты.Период = НАЧАЛОПЕРИОДА(&amp;АкутальнаяДатаСеанса, ДЕНЬ)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК НаСегодня,
	ДокументЗаказПоставщику.Ссылка,
	ДокументЗаказПоставщику.ПометкаУдаления,
	ДокументЗаказПоставщику.Номер,
	ДокументЗаказПоставщику.Дата,
	ДокументЗаказПоставщику.Проведен,
	ДокументЗаказПоставщику.Организация,
	ДокументЗаказПоставщику.ВидОперации,
	ДокументЗаказПоставщику.Контрагент,
	ДокументЗаказПоставщику.Контрагент.КонтактноеЛицо КАК КонтактноеЛицо,
	ДокументЗаказПоставщику.Договор,
	ДокументЗаказПоставщику.ДатаПоступления КАК ДатаПоступления,
	ДокументЗаказПоставщику.ВалютаДокумента,
	ДокументЗаказПоставщику.СуммаВключаетНДС,
	ДокументЗаказПоставщику.НДСВключатьВСтоимость,
	ДокументЗаказПоставщику.Курс,
	ДокументЗаказПоставщику.Кратность,
	ДокументЗаказПоставщику.СтруктурнаяЕдиницаРезерв,
	ДокументЗаказПоставщику.ЗаказПокупателя,
	ДокументЗаказПоставщику.СуммаДокумента,
	ДокументЗаказПоставщику.ВидЦенКонтрагента,
	ДокументЗаказПоставщику.Событие,
	ДокументЗаказПоставщику.ЗапретРедактированияДокументов,
	ДокументЗаказПоставщику.Ответственный,
	ДокументЗаказПоставщику.СтруктурнаяЕдиница,
	ДокументЗаказПоставщику.Комментарий,
	ДокументЗаказПоставщику.ЗапланироватьОплату,
	ДокументЗаказПоставщику.Касса,
	ДокументЗаказПоставщику.БанковскийСчет,
	ДокументЗаказПоставщику.ТипДенежныхСредств,
	ДокументЗаказПоставщику.СостояниеЗаказа,
	ВЫБОР
		КОГДА ДокументЗаказПоставщику.Проведен
				И ДокументЗаказПоставщику.СуммаДокумента > 0
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) - ДокументЗаказПоставщику.СуммаДокумента >= 0
						ТОГДА &quot;Оплачен полностью&quot;
					КОГДА ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) > 0
						ТОГДА &quot;Оплачен частично&quot;
					ИНАЧЕ &quot;Без оплаты&quot;
				КОНЕЦ
		ИНАЧЕ &quot;Без оплаты&quot;
	КОНЕЦ КАК СтатусОплаты,
	ВЫБОР
		КОГДА ДокументЗаказПоставщику.Проведен
			ТОГДА ВЫБОР
					КОГДА ГрафикВыполнения.Выполнено = 0
						ТОГДА 2
					КОГДА ГрафикВыполнения.Выполнено > 0
						ТОГДА 1
					КОГДА ГрафикВыполненияПлан.Выполнено = 0
						ТОГДА 2
					КОГДА ГрафикВыполненияПлан.Выполнено > 0
						ТОГДА 1
					КОГДА ГрафикВыполнения.Заказ ЕСТЬ NULL 
							И ГрафикВыполненияПлан.Заказ ЕСТЬ NULL 
						ТОГДА 0
					ИНАЧЕ 2
				КОНЕЦ
		ИНАЧЕ 2
	КОНЕЦ КАК СтатусОтгрузки,
	ДокументЗаказПоставщику.НомерВходящегоДокумента,
	ДокументЗаказПоставщику.ДатаВходящегоДокумента,
	ДокументЗаказПоставщику.Автор,
	ДокументЗаказПоставщику.МоментВремени,
	ЕСТЬNULL(ФактОплаты.Сумма, 0) - ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) - ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) КАК КОплате,
	ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) КАК СуммаОплатыОборот,
	СостоянияЭД.СостояниеВерсииЭД,
	ДокументЗаказПоставщику.Закрыт,
	ДокументЗаказПоставщику.ВариантЗавершения
	
	// +++ { AzRy - [21.02.2022] - Jira:ERPM-809 - Developer:გიორგი მამულაშვილი - Comment: დაემატა პროექტის რეკვიზიტი	
	,ДокументЗаказПоставщику.AzRyПроекты КАК AzRyПроекты 					
	// +++ } AzRy - [21.02.2022] - Jira:ERPM-809 - Developer:გიორგი მამულაშვილი - Comment: დაემატა პროექტის რეკვიზიტი
	// +++ { AzRy - [15.04.2022] - Jira:ERPM-880 - Developer:გიორგი მამულაშვილი - Comment:
	,ДокументЗаказПоставщику.AzRyJiraCode КАК AzRyJiraCode
	// +++ } AzRy - [15.04.2022] - Jira:ERPM-880 - Developer:გიორგი მამულაშვილი - Comment:	
	
ИЗ
	Документ.ЗаказПоставщику КАК ДокументЗаказПоставщику
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикВыполненияЗаказов КАК ГрафикВыполнения
		ПО ДокументЗаказПоставщику.Ссылка = ГрафикВыполнения.Заказ
			И (ГрафикВыполнения.Период &lt;= &amp;АкутальнаяДатаСеанса)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикВыполненияЗаказов КАК ГрафикВыполненияПлан
		ПО ДокументЗаказПоставщику.Ссылка = ГрафикВыполненияПлан.Заказ
			И (ГрафикВыполненияПлан.Период > &amp;АкутальнаяДатаСеанса)
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикОплатыЗаказов КАК ГрафикОплаты
		ПО ДокументЗаказПоставщику.Ссылка = ГрафикОплаты.СчетНаОплату
			И (ГрафикОплаты.Период &lt;= &amp;АкутальнаяДатаСеанса)}
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФактОплатыЗаказов КАК ФактОплаты
		ПО ДокументЗаказПоставщику.Ссылка = ФактОплаты.СчетНаОплату
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияЭД КАК СостоянияЭД
		ПО ДокументЗаказПоставщику.Ссылка = СостоянияЭД.СсылкаНаОбъект</queryText>
      <mainTable>Document.ЗаказПоставщику</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
