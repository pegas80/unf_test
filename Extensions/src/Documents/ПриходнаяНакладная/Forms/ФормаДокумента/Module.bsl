Процедура РасшAzRy_ПересчитатьСуммыСтрокиРасхода(Идентификатор, ИмяПоля)
	// Kuzmich, 13.10.2023, (ONESOFT-2587) Расчет НДС неправильный в документ приходная накладная (услуги)
	КонтрагентЯвляетсяНеРезидентом = ЛОЖЬ;
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда		
		// +++ { AzRy - [29.01.2021] - Jira:ERPM-809 - Developer:გიორგი მამულაშვილი - Comment:
		//КонтрагентЯвляетсяНеРезидентом = Объект.Контрагент.ЯвляетсяНеРезидентом;
		КонтрагентЯвляетсяНеРезидентом = Объект.Контрагент.ЯвляетсяНеРезидентом И Объект.Контрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС И Объект.Договор.УчитыватьНДФЛ;
		// +++ } AzRy - [29.01.2021] - Jira:ERPM-809 - Developer:გიორგი მამულაშვილი - Comment:
	КонецЕсли;
	// Kuzmich, 13.10.2023, (ONESOFT-2587) Расчет НДС неправильный в документ приходная накладная (услуги)
	Если Идентификатор = Неопределено Тогда
		Для Каждого СтрокаТЧ ИЗ Объект.Расходы Цикл
			Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			ТекДанные = Объект.Расходы.НайтиПоИдентификатору(Идентификатор);
			//РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
			РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС, КонтрагентЯвляетсяНеРезидентом);// Kuzmich, 13.10.2023, (ONESOFT-2587) Расчет НДС неправильный в документ приходная накладная (услуги)
		КонецЦикла;
	Иначе
		ТекДанные = Объект.Расходы.НайтиПоИдентификатору(Идентификатор);
		//РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
		РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС, КонтрагентЯвляетсяНеРезидентом);// Kuzmich, 13.10.2023, (ONESOFT-2587) Расчет НДС неправильный в документ приходная накладная (услуги)
	КонецЕсли;
КонецПроцедуры
