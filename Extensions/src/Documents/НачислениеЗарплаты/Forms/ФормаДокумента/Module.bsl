
#Область AzRy

&НаКлиенте
Процедура РасшAzRy_ГиперссылкаJiraНажатиеПосле(Элемент)
	
	Если ЗначениеЗаполнено(Объект.AzRyJiraCode) Тогда
		ЗапуститьПриложение(AzRyОбщегоНазначения.ПолучитьАдресВебРесурсаJira() + Объект.AzRyJiraCode);
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти

&НаСервере
&Вместо("ПерсчитатьСуммы_ПФ_И_НДФЛ")
Процедура РасшAzRy_ПерсчитатьСуммы_ПФ_И_НДФЛ(Идентификатор)
	
	СтрокаНачислений = Объект.НачисленияУдержания.НайтиПоИдентификатору(Идентификатор);
	Если ЗначениеЗаполнено(СтрокаНачислений.ВидУдержанияПФ) Тогда
		СтавкаПФ = СтрокаНачислений.ВидУдержанияПФ.СтавкаПФ;
		СтрокаНачислений.СуммаПФ	= Окр(СтрокаНачислений.Сумма * СтавкаПФ/100, 2);
	Иначе
		СтавкаПФ = 0;
		СтрокаНачислений.СуммаПФ	= 0;
	КонецЕсли;
	
	НайденныеСтроки_Долга = Объект.ПогашениеЗаймов.НайтиСтроки(Новый Структура("Сотрудник", СтрокаНачислений.Сотрудник));
	СуммаДолга	= 0;
	Для Каждого СтрокаДолга Из НайденныеСтроки_Долга Цикл
		СуммаДолга = СуммаДолга + СтрокаДолга.ПогашеноЗайма;
	КонецЦикла;
	
	НайденныеСтроки_Налоги = Объект.НалогиНаДоходы.НайтиСтроки(Новый Структура("Сотрудник", СтрокаНачислений.Сотрудник));
	СтавкаНДФЛ	= 0;
	Для Каждого СтрокаНалога ИЗ НайденныеСтроки_Налоги Цикл
		Если ЗначениеЗаполнено(СтрокаНалога.ВидНачисленияУдержания) Тогда
			СтавкаНДФЛ	= СтрокаНалога.ВидНачисленияУдержания.СтавкаНДФЛ;
		КонецЕсли;
		СтрокаНалога.Сумма = Окр((СтрокаНачислений.Сумма - СтрокаНачислений.СуммаПФ - СуммаДолга) * СтавкаНДФЛ/100, 2);
	КонецЦикла;
	
	//Другие строки начисления текущего Сотрудника
	СтрокиНачисленияТекСотрудника = Объект.НачисленияУдержания.НайтиСтроки(Новый Структура("Сотрудник", СтрокаНачислений.Сотрудник));
	Если СтрокиНачисленияТекСотрудника.Количество() > 1 Тогда
		СуммаДляВычисленияНДФЛ = 0;
		Для Каждого СтрокаНач ИЗ СтрокиНачисленияТекСотрудника Цикл
			// +++ { AzRy - [09.08.2022] - Jira: - Developer:გიორგი მამულაშვილი - Comment:
			Если СтрокаНач.ВидНачисленияУдержания.Тип = Перечисления.ТипыНачисленийИУдержаний.Удержание Тогда
				Продолжить;
			КонецЕсли; 
			// +++ } AzRy - [09.08.2022] - Jira: - Developer:გიორგი მამულაშვილი - Comment:
			СуммаДляВычисленияНДФЛ = СуммаДляВычисленияНДФЛ + (СтрокаНач.Сумма - СтрокаНач.СуммаПФ);
		КонецЦикла;
		СуммаДляВычисленияНДФЛ = СуммаДляВычисленияНДФЛ - СуммаДолга;
		Для Каждого СтрокаНалога ИЗ НайденныеСтроки_Налоги Цикл
			Если ЗначениеЗаполнено(СтрокаНалога.ВидНачисленияУдержания) Тогда
				СтавкаНДФЛ	= СтрокаНалога.ВидНачисленияУдержания.СтавкаНДФЛ;
			КонецЕсли;
			СтрокаНалога.Сумма = Окр(СуммаДляВычисленияНДФЛ * СтавкаНДФЛ/100, 2);
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры
