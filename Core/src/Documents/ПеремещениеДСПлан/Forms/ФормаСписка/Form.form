  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументПеремещениеДСПлан.Ссылка,
	ДокументПеремещениеДСПлан.ПометкаУдаления,
	ДокументПеремещениеДСПлан.Номер,
	ДокументПеремещениеДСПлан.Дата,
	ДокументПеремещениеДСПлан.Проведен,
	ДокументПеремещениеДСПлан.Организация,
	ДокументПеремещениеДСПлан.Комментарий,
	ДокументПеремещениеДСПлан.СуммаДокумента,
	ДокументПеремещениеДСПлан.ВалютаДокумента,
	ДокументПеремещениеДСПлан.СтатьяДвиженияДенежныхСредств,
	ДокументПеремещениеДСПлан.ТипДенежныхСредств,
	ДокументПеремещениеДСПлан.БанковскийСчет,
	ДокументПеремещениеДСПлан.Касса,
	ДокументПеремещениеДСПлан.ТипДенежныхСредствПолучатель,
	ДокументПеремещениеДСПлан.БанковскийСчетПолучатель,
	ДокументПеремещениеДСПлан.КассаПолучатель,
	ДокументПеремещениеДСПлан.СтатусУтвержденияПлатежа,
	ДокументПеремещениеДСПлан.Автор,
	ДокументПеремещениеДСПлан.ХозяйственнаяОперация,
	ДокументПеремещениеДСПлан.МоментВремени,
	ДокументПеремещениеДСПлан.ЗапретРедактированияДокументов,
	ВЫБОР
		КОГДА ДокументПеремещениеДСПлан.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
				И ДокументПеремещениеДСПлан.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
			ТОГДА &quot;Между кассами&quot;
		КОГДА ДокументПеремещениеДСПлан.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
				И ДокументПеремещениеДСПлан.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
			ТОГДА &quot;Из кассы на счет&quot;
		КОГДА ДокументПеремещениеДСПлан.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
				И ДокументПеремещениеДСПлан.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
			ТОГДА &quot;Между счетами&quot;
		КОГДА ДокументПеремещениеДСПлан.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
				И ДокументПеремещениеДСПлан.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
			ТОГДА &quot;Со счета в кассу&quot;
	КОНЕЦ КАК ВидОперации,
	ВЫБОР
		КОГДА ДокументПеремещениеДСПлан.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
			ТОГДА ДокументПеремещениеДСПлан.Касса
		ИНАЧЕ ДокументПеремещениеДСПлан.БанковскийСчет
	КОНЕЦ КАК СчетКассаДляОтбора,
	ВЫБОР
		КОГДА ДокументПеремещениеДСПлан.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
			ТОГДА ДокументПеремещениеДСПлан.КассаПолучатель
		ИНАЧЕ ДокументПеремещениеДСПлан.БанковскийСчетПолучатель
	КОНЕЦ КАК СчетКассаПолучательДляОтбора
ИЗ
	Документ.ПеремещениеДСПлан КАК ДокументПеремещениеДСПлан</queryText>
