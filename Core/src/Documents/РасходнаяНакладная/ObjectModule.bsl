Функция ПолучитьТаблицуПоследнихЗакупочнихЦен(тзНоменклатуры)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	тзНоменклатуры.НомерСтроки,
		|	тзНоменклатуры.Номенклатура,
		|	тзНоменклатуры.Характеристика
		|ПОМЕСТИТЬ ВТ_Номенклатура
		|ИЗ
		|	&тзНоменклатуры КАК тзНоменклатуры
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗакупкиОбороты.Период,
		|	ЗакупкиОбороты.Номенклатура,
		|	ЗакупкиОбороты.Характеристика,
		|	ЗакупкиОбороты.СуммаОборот,
		|	ЗакупкиОбороты.КоличествоОборот
		|ПОМЕСТИТЬ ВТ_Закупки
		|ИЗ
		|	РегистрНакопления.Закупки.Обороты(
		|			,
		|			,
		|			Запись,
		|			(Номенклатура, Характеристика) В
		|					(ВЫБРАТЬ
		|						а.Номенклатура,
		|						а.Характеристика
		|					ИЗ
		|						ВТ_Номенклатура КАК а)
		|				И Организация = &Организация) КАК ЗакупкиОбороты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТ_Закупки.Период) КАК Период,
		|	ВТ_Закупки.Номенклатура,
		|	ВТ_Закупки.Характеристика
		|ПОМЕСТИТЬ ВТ_МаксПериод
		|ИЗ
		|	ВТ_Закупки КАК ВТ_Закупки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Закупки.Номенклатура,
		|	ВТ_Закупки.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Номенклатура.НомерСтроки,
		|	ВТ_Номенклатура.Номенклатура,
		|	ВТ_Номенклатура.Характеристика,
		|	ВТ_МаксПериод.Период,
		|	ВТ_Закупки.СуммаОборот,
		|	ВТ_Закупки.КоличествоОборот,
		|	ВЫРАЗИТЬ(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВТ_Закупки.КоличествоОборот, 0) = 0
		|				ТОГДА 0
		|			ИНАЧЕ ВТ_Закупки.СуммаОборот / ВТ_Закупки.КоличествоОборот
		|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК Цена
		|ИЗ
		|	ВТ_Номенклатура КАК ВТ_Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_МаксПериод КАК ВТ_МаксПериод
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Закупки КАК ВТ_Закупки
		|			ПО ВТ_МаксПериод.Период = ВТ_Закупки.Период
		|				И ВТ_МаксПериод.Номенклатура = ВТ_Закупки.Номенклатура
		|				И ВТ_МаксПериод.Характеристика = ВТ_Закупки.Характеристика
		|		ПО ВТ_Номенклатура.Номенклатура = ВТ_МаксПериод.Номенклатура
		|			И ВТ_Номенклатура.Характеристика = ВТ_МаксПериод.Характеристика";
	
	Запрос.УстановитьПараметр("тзНоменклатуры", тзНоменклатуры);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
