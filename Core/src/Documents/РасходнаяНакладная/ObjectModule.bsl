// Процедура - обработчик события ОбработкаЗаполнения.
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	СтратегияЗаполнения = Новый Соответствие;
	СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
	СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнойНакладной";
	СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
	СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказуПоставщику";
	СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплату")] = "ЗаполнитьПоСчетуНаОплату";
	СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениюЗапасов";
	СтратегияЗаполнения[Тип("ДокументСсылка.СборкаЗапасов")] = "ЗаполнитьПоСборкеЗапасов";
	СтратегияЗаполнения[Тип("ДокументСсылка.ПриемИПередачаВРемонт")] = "ЗаполнитьПоПриемуВРемонт";
	
	ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ЭтотОбъект, ДанныеЗаполнения, СтратегияЗаполнения);
	// Kuzmich, 12.05.2019, Заполнение типа цен из настроек склада
	Если Константы.ЗаполнениеТипаЦенИзНастроекСклада.Получить() Тогда
		Если ЗначениеЗаполнено(ЭтотОбъект.СтруктурнаяЕдиница) Тогда
			ЭтотОбъект.ВидЦен = ЭтотОбъект.СтруктурнаяЕдиница.РозничныйВидЦен;
		КонецЕсли;
	КонецЕсли;
	
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КомПредложение") Тогда
		Контрагент =  ДанныеЗаполнения.Контрагент;
		Договор=  ДанныеЗаполнения.Договор;
		Организация =  ДанныеЗаполнения.Организация;
		Дата  =  ДанныеЗаполнения.Дата;
		СтруктурнаяЕдиницаРезерв =  ДанныеЗаполнения.СтруктурнаяЕдиница;
		Ответственный =  ДанныеЗаполнения.Ответственный;
		ВалютаДокумента  =  ДанныеЗаполнения.ВалютаДокумента;
		Курс =  ДанныеЗаполнения.Курс;
		Кратность =  ДанныеЗаполнения.Кратность;
		СуммаВключаетНДС =  ДанныеЗаполнения.СуммаВключаетНДС;
		ВидЦен =  ДанныеЗаполнения.ВидЦен;
		НДСВключатьВСтоимость =  ДанныеЗаполнения.НДСВключатьВСтоимость;
		НалогообложениеНДС =  ДанныеЗаполнения.НалогообложениеНДС;
		ВидСкидкиНаценки  =  ДанныеЗаполнения.ВидСкидкиНаценки;
		ВидОперации  =  ДанныеЗаполнения.ВидОперации;
		
		
		
		Для Каждого ТекСтрока Из ДанныеЗаполнения.ТаблицаПредложений Цикл
			НоваяСтрока = Запасы.Добавить();
			НоваяСтрока.Количество = ТекСтрока.Количество;
			НоваяСтрока.Номенклатура = ТекСтрока.Номенклатура;
			НоваяСтрока.ЕдиницаИзмерения = ТекСтрока.ЕдиницаИзмерения;
			НоваяСтрока.Характеристика = ТекСтрока.Характеристика;
			НоваяСтрока.ПроцентСкидкиНаценки = ТекСтрока.ПроцентСкидкиНаценки;
			НоваяСтрока.СтавкаНДС = ТекСтрока.СтавкаНДС;
			НоваяСтрока.СуммаНДС = ТекСтрока.СуммаНДС;
			СтавкаНДС=ПолучитьСтавкуНДСЧислом(НоваяСтрока.СтавкаНДС);
			НоваяСтрока.Сумма = ТекСтрока.Сумма;
			//Если Не ДанныеЗаполнения.ЦенаВклюЧаетНалоги Тогда
			НоваяСтрока.Цена = ТекСтрока.Цена;
			//				НоваяСтрока.ЦенаСкидком = ТекСтрока.Цена * (1-ТекСтрока.ПроцентСкидки/100);
			//НоваяСтрока.Всего = ТекСтрока.Сумма*(1+СтавкаНДС/100);    
			//Иначе
			//	НоваяСтрока.Цена = ТекСтрока.ЦенаСкидком/(1-ТекСтрока.ПроцентСкидки/100);
			//				НоваяСтрока.ЦенаСкидком = НоваяСтрока.Цена* ТекСтрока.Количество*(1-ТекСтрока.ПроцентСкидки/100);
			// ТекущиеДанные.Сумма = Цена * (1-ТекущиеДанные.ПроцентСкидки/100) * ТекущиеДанные.Количество;
			//НоваяСтрока.Всего = ТекСтрока.Сумма*(1+СтавкаНДС/100)
			//КонецЕсли;	
			НоваяСтрока.Всего =  ТекСтрока.Всего;
			
		КонецЦикла;
		
	//+++ Дмгг
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.СборкаЗапасов") Тогда 
		
		Если ЗначениеЗаполнено(ДанныеЗаполнения.ЗаказПокупателя) Тогда 
			
			тзЗапасы = ДанныеЗаполнения.ЗаказПокупателя.Запасы.Выгрузить();
			
			Для Каждого Строк Из Запасы Цикл 
				
				ПоискСтрок = тзЗапасы.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", Строк.Номенклатура, Строк.Характеристика));
				Если ПоискСтрок.Количество() > 0 Тогда 
					Строк.Цена = ПоискСтрок[0].Цена;
					Строк.Сумма = ПоискСтрок[0].Сумма;
					Строк.Всего = ПоискСтрок[0].Всего;
					Строк.СуммаНДС = ПоискСтрок[0].СуммаНДС;
					Строк.СтавкаНДС = ПоискСтрок[0].СтавкаНДС;
				КонецЕсли;
				
			КонецЦикла;
			
			
		КонецЕсли;
	//--- Дмгг	
	КонецЕсли;
	
	
	// Kuzmich, 12.05.2019, Заполнение типа цен из настроек склада
КонецПроцедуры // ОбработкаЗаполнения()

// Процедура - обработчик события ПередЗаписью объекта.
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Проведен  и РежимЗаписи = РежимЗаписиДокумента.Проведение   Тогда 
		АвтоматическоеПроизводство = АвтоматическоеПроизводство();
	КонецЕсли;
	
	Если ПоложениеЗаказаПокупателя = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке Тогда
		Для каждого СтрокаТабличнойЧасти Из Запасы Цикл
			СтрокаТабличнойЧасти.Заказ = ?(ЗначениеЗаполнено(Заказ), Заказ, Неопределено);
		КонецЦикла;
		Если Контрагент.ВестиРасчетыПоЗаказам Тогда
			Для каждого СтрокаТабличнойЧасти Из Предоплата Цикл
				СтрокаТабличнойЧасти.Заказ = ?(ЗначениеЗаполнено(Заказ), Заказ, Неопределено);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	//_Lazare
	Если  ПоложениеСклада = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ПустаяСсылка") Тогда  
		ПоложениеСклада  = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВШапке")  ;
	КонецЕсли;
	//Lazare_	
	Если ЗначениеЗаполнено(Контрагент)
	И НЕ Контрагент.ВестиРасчетыПоДоговорам
	И НЕ ЗначениеЗаполнено(Договор) Тогда
		Договор = Контрагент.ДоговорПоУмолчанию;
	КонецЕсли;
	
	СуммаДокумента = Запасы.Итог("Всего") + СтоимостьДоставки + ?(СуммаВключаетНДС, 0, СуммаНДСДоставки);
	
	// МобильноеПриложение
	Если МобильноеПриложениеВызовСервера.НужноОграничитьФункциональность()
		И НЕ ПометкаУдаления Тогда
		РежимЗаписи = РежимЗаписиДокумента.Проведение;
	КонецЕсли;
		
	// Конец МобильноеПриложение
	
	// ИнтеграцияГИСМ
	ЕстьМаркируемаяПродукцияГИСМ = ИнтеграцияГИСМУНФ.ЕстьМаркируемаяПродукцияГИСМ(Запасы);
	// Конец ИнтеграцияГИСМ
	
	//Паганини_
	Если НЕ ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю Тогда
		ФактурыАвансов.Очистить();
	КонецЕсли;//_Паганини
	
	КоличествоТоваров = Запасы.Итог("Количество"); //+++ Дмгг
	
	//+++ Lazare
	Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройкиЗачетаАвансов() = Перечисления.ДаНет.Да
		И ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю Тогда
		Предоплата.Очистить();
		ЗаполнитьПредоплату();
	КонецЕсли;
	//--- Lazare

	
	
КонецПроцедуры // ПередЗаписью()

