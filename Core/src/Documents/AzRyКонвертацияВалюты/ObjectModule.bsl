////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ

// Процедура - обработчик события ПередЗаписью объекта.
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ Константы.ФункциональнаяОпцияУчетПоНесколькимНаправлениямДеятельности.Получить()
		И Корреспонденция.ТипСчета = Перечисления.ТипыСчетов.Расходы Тогда
		
		НаправлениеДеятельности = Справочники.НаправленияДеятельности.ОсновноеНаправление;
		
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	//ИзменитьКурсыВалют();
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();	
	
	// Безналичные денежные средство
	Если ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Безналичные Тогда 	
		
		
		// Проверка заполнения реквизита банковский счет
		Если БанковскийСчет1 = Справочники.БанковскиеСчета.ПустаяСсылка() Или БанковскийСчет2 = Справочники.БанковскиеСчета.ПустаяСсылка() Тогда 
			Отказ = Истина;
			Сообщить(НСтр("ru = 'Поле банковскийСчет не заполнено'; ka = 'საბანკო ანგარიშის ველი შევსებული არაა'"));
			Возврат;
		КонецЕсли;	
		
		// 1) Поступление на счет -------------------------------------------------------------------------------------------------
		
		// Инициализация дополнительных свойств для проведения документа	
		УправлениеНебольшойФирмойСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
		
		// Инициализация данных документа
		Документы.AzRyКонвертацияВалюты.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства, "ПоступлениеНаСчет");
		
		// Подготовка наборов записей
		УправлениеНебольшойФирмойСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
		
		// Отражение в разделах учета
		//УправлениеНебольшойФирмойСервер.ОтразитьДенежныеСредства(ДополнительныеСвойства, Движения, Отказ);
		//УправлениеНебольшойФирмойСервер.ОтразитьУправленческий(ДополнительныеСвойства, Движения, Отказ);
		//УправлениеНебольшойФирмойСервер.ОтразитьПлатежныйКалендарь(ДополнительныеСвойства, Движения, Отказ);
		
		СТР = ДополнительныеСвойства.ТаблицыДляДвижений;
		
		// Запись наборов записей
		УправлениеНебольшойФирмойСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);
		
		//ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц.Закрыть();
		
		
		// 2) Расход со счета  -------------------------------------------------------------------------------------------------
		
		ДополнительныеСвойства.Очистить();
		
		// Инициализация дополнительных свойств для проведения документа
		УправлениеНебольшойФирмойСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
		
		// Инициализация данных документа
		Документы.AzRyКонвертацияВалюты.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства, "РасходСоСчета");
		
		// Подготовка наборов записей
		УправлениеНебольшойФирмойСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
		
		Для каждого ТекСтрока Из СТР Цикл
			
			Если ТекСтрока.Ключ = "ТаблицаДенежныеСредства" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДенежныеСредства.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;	 
			
			Если ТекСтрока.Ключ = "ТаблицаУправленческий" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУправленческий.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;
			
			Если ТекСтрока.Ключ = "ТаблицаПлатежныйКалендарь" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаПлатежныйКалендарь.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;
			
			Если ТекСтрока.Ключ = "ТаблицаДоходыИРасходы" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДоходыИРасходы.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;
			
		КонецЦикла;
		
		// Отражение в разделах учета
		УправлениеНебольшойФирмойСервер.ОтразитьДенежныеСредства(ДополнительныеСвойства, Движения, Отказ);
		УправлениеНебольшойФирмойСервер.ОтразитьПлатежныйКалендарь(ДополнительныеСвойства, Движения, Отказ);
		УправлениеНебольшойФирмойСервер.ОтразитьУправленческий(ДополнительныеСвойства, Движения, Отказ);
		УправлениеНебольшойФирмойСервер.ОтразитьДоходыИРасходы(ДополнительныеСвойства, Движения, Отказ);		
		// Запись наборов записей
		УправлениеНебольшойФирмойСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);
		
		ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц.Закрыть();
		
	ИначеЕсли ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Наличные Тогда // Наличные денежные средство
		
        // Проверка заполнения реквизита касса
		Если Касса1 = Справочники.Кассы.ПустаяСсылка() Или Касса2 = Справочники.Кассы.ПустаяСсылка() Тогда 
			Отказ = Истина;
			Сообщить(НСтр("ru = 'Поле касса не заполнено'; ka = 'სალაროს ველი შევსებული არაა'"));
			Возврат;
		КонецЕсли;
		
		// 1) Поступление в кассу -------------------------------------------------------------------------------------------------
		
		// Инициализация дополнительных свойств для проведения документа	
		УправлениеНебольшойФирмойСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
		
		// Инициализация данных документа
		Документы.AzRyКонвертацияВалюты.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства, "ПоступлениеВКассу");
		
		// Подготовка наборов записей
		УправлениеНебольшойФирмойСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);

		СТР = ДополнительныеСвойства.ТаблицыДляДвижений;
		
		// Запись наборов записей
		УправлениеНебольшойФирмойСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);

		
		// 1) Расход из кассы  ------------------------------------------------------------------------------------------------- 
		
		ДополнительныеСвойства.Очистить();
		
		// Инициализация дополнительных свойств для проведения документа
		УправлениеНебольшойФирмойСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
		
		// Инициализация данных документа
		Документы.AzRyКонвертацияВалюты.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства, "РасходИзКассы");
		
		// Подготовка наборов записей
		УправлениеНебольшойФирмойСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
		
		Для каждого ТекСтрока Из СТР Цикл
			
			Если ТекСтрока.Ключ = "ТаблицаДенежныеСредства" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДенежныеСредства.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;	 
			
			Если ТекСтрока.Ключ = "ТаблицаУправленческий" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаУправленческий.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;
			
			Если ТекСтрока.Ключ = "ТаблицаПлатежныйКалендарь" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаПлатежныйКалендарь.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;
			
			Если ТекСтрока.Ключ = "ТаблицаДоходыИРасходы" Тогда 			
				Для каждого ТекСтрока2 Из ТекСтрока.Значение Цикл
					НовСтрока = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДоходыИРасходы.Добавить();
					ЗаполнитьЗначенияСвойств(НовСтрока, ТекСтрока2);
				КонецЦикла; 
			КонецЕсли;

		КонецЦикла;
		
		// Отражение в разделах учета
		УправлениеНебольшойФирмойСервер.ОтразитьДенежныеСредства(ДополнительныеСвойства, Движения, Отказ);
		УправлениеНебольшойФирмойСервер.ОтразитьПлатежныйКалендарь(ДополнительныеСвойства, Движения, Отказ);
		УправлениеНебольшойФирмойСервер.ОтразитьУправленческий(ДополнительныеСвойства, Движения, Отказ);
		УправлениеНебольшойФирмойСервер.ОтразитьДоходыИРасходы(ДополнительныеСвойства, Движения, Отказ);
		
		// Запись наборов записей
		УправлениеНебольшойФирмойСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);
		
		ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц.Закрыть();
		
	Иначе 
		
		Сообщить(НСтр("ru = 'Не указан тип конвертаций'; ka = 'არ არის მითითებული კონვერტაციის ტიპი'"));
		Отказ = Истина;	
		
	КонецЕсли;
	
	
КонецПроцедуры




