// Процедура - обработчик события ПриСозданииНаСервере.
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УправлениеНебольшойФирмойСервер.ЗаполнитьШапкуДокумента(
	Объект,
	,
	Параметры.ЗначениеКопирования,
	Параметры.Основание,
	СостояниеДокумента,
	КартинкаСостоянияДокумента,
	РазрешеноПроведение,
	Параметры.ЗначенияЗаполнения
	);
	
	Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Объект.ВидОперации       = Перечисления.AzRyВидыОперацийКонвертацияВалюты.КонвертацияВалюты;		
	
	// Если новый объект 
	Если Объект.Ссылка.Пустая() Тогда 	
		
		//Объект.Корреспонденция       = ПланыСчетов.Управленческий.Банк;
		Объект.ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Безналичные;
		
		Объект.СчетДебетРасход       = Константы.AzRyКонвертацияВалютыСчетДебетРасход.Получить();
		Объект.СчетКредитПриход      = Константы.AzRyКонвертацияВалютыСчетКредитПриход.Получить();
		
	КонецЕсли;
	
	УстановитьТекущуюСтраницу();
	
	//Объект.ВалютаУчета     = Константы.ВалютаУчета.Получить();
	
	// Обработчик подсистемы "Дополнительные отчеты и обработки"
	ДополнительныеОтчетыИОбработки.ПриСозданииНаСервере(ЭтаФорма);
	
КонецПроцедуры

// Процедура - обработчик события ПослеЗаписи.
&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	УправлениеНебольшойФирмойКлиент.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

&НаСервере
// Устанавливает текущую страницу для типа денежных средств.
//
// Параметры:
//	ХозяйственнаяОперация - ПеречислениеСсылка.ХозяйственныеОперации - Хозяйственная операции
//
Процедура УстановитьТекущуюСтраницу()
	
	Если Объект.ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Безналичные Тогда 
		
		Элементы.БанковскийСчет1.Доступность = Истина;
		Элементы.БанковскийСчет1.Видимость   = Истина;
		Элементы.БанковскийСчет2.Доступность = Истина;
		Элементы.БанковскийСчет2.Видимость   = Истина;

		Элементы.Касса1.Видимость 			 = Ложь;
		Элементы.Касса2.Видимость 			 = Ложь;
		
	ИначеЕсли Объект.ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Наличные Тогда
		
		Элементы.Касса1.Доступность 	   = Истина;
		Элементы.Касса2.Доступность 	   = Истина;
		Элементы.БанковскийСчет1.Видимость = Ложь;
		Элементы.БанковскийСчет2.Видимость = Ложь;
		Элементы.Касса1.Видимость 		   = Истина;
		Элементы.Касса2.Видимость 		   = Истина;
		
	Иначе
		
		Элементы.БанковскийСчет1.Доступность = Ложь;
		Элементы.БанковскийСчет2.Доступность = Ложь;
		Элементы.Касса1.Доступность 			= Ложь;
		Элементы.Касса2.Доступность 			= Ложь;
		
	КонецЕсли;
	
КонецПроцедуры // УстановитьТекущуюСтраницу()

&НаКлиенте
Процедура ТипыКонвертацияВалютыПриИзменении(Элемент)
	
	УстановитьТекущуюСтраницу();
	
КонецПроцедуры 

&НаСервере
Процедура ИзменитьКурсыВалют()
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	                                                          
	ВалютаУчетаКурс = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаУчета, Объект.Дата);
	
	Валюта1 = Справочники.Валюты.ПустаяСсылка();
	Валюта2 = Справочники.Валюты.ПустаяСсылка();
	
	Если Объект.ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Безналичные Тогда 
		Валюта1 = Объект.БанковскийСчет1.ВалютаДенежныхСредств;
		Валюта2 = Объект.БанковскийСчет2.ВалютаДенежныхСредств;
	ИначеЕсли Объект.ТипыКонвертацияВалюты = Перечисления.AzRyТипыКонвертацияВалюты.Безналичные Тогда
		Валюта1 = Объект.Касса1.ВалютаДенежныхСредств;
		Валюта2 = Объект.Касса2.ВалютаДенежныхСредств;
	КонецЕсли;	
	
	ВалютаКурс1 = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Валюта1, Объект.Дата);
	ВалютаКурс2 = РаботаСКурсамиВалют.ПолучитьКурсВалюты(Валюта2, Объект.Дата);
	
	Объект.КурсВалюты1 = ВалютаКурс1.Курс;   
	Объект.КурсВалюты2 = ВалютаКурс2.Курс;
	
КонецПроцедуры // ИзменитьКурсыВалют()

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ИзменитьКурсыВалют();
КонецПроцедуры

&НаКлиенте
Процедура БанковскийСчет1ПриИзменении(Элемент)
	ИзменитьКурсыВалют();
КонецПроцедуры

&НаКлиенте
Процедура Касса1ПриИзменении(Элемент)
	ИзменитьКурсыВалют();
КонецПроцедуры

&НаКлиенте
Процедура БанковскийСчет2ПриИзменении(Элемент)
