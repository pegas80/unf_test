	НовСтрока.Сумма                    = Сумма;
	НовСтрока.СуммаДоходов             = 0;
	НовСтрока.СуммаРасходов            = Сумма;
	НовСтрока.СчетУчета                = ДокументСсылкаРасходСоСчета.СчетДебетРасход;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДоходыИРасходы", ТД);
	
КонецПроцедуры // СформироватьТаблицаДоходыИРасходыРасходСоСчета()


