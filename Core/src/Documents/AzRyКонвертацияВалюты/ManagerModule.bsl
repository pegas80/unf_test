// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаДенежныеСредстваРасходСоСчета(ДокументСсылкаРасходСоСчета, СтруктураДополнительныеСвойства)
			
	ТД = Новый ТаблицаЗначений;
	ТД.Колонки.Добавить("БанковскийСчетКасса");
	ТД.Колонки.Добавить("Валюта");
	ТД.Колонки.Добавить("ВидДвижения");
	ТД.Колонки.Добавить("ВидДвиженияУправленческий");
	ТД.Колонки.Добавить("НомерСтроки");
	ТД.Колонки.Добавить("Организация");
	ТД.Колонки.Добавить("Период");
	ТД.Колонки.Добавить("Порядок");
	ТД.Колонки.Добавить("СодержаниеПроводки");
	ТД.Колонки.Добавить("Статья");
	ТД.Колонки.Добавить("Сумма");
	ТД.Колонки.Добавить("СуммаВал");
	ТД.Колонки.Добавить("СчетУчета");
	ТД.Колонки.Добавить("ТипДенежныхСредств");
	
	НовСтрока = ТД.Добавить();
	НовСтрока.БанковскийСчетКасса       = ДокументСсылкаРасходСоСчета.БанковскийСчет1;
	НовСтрока.Валюта                    = ДокументСсылкаРасходСоСчета.БанковскийСчет1.ВалютаДенежныхСредств;
	НовСтрока.ВидДвижения               = ВидДвиженияНакопления.Расход;
	НовСтрока.ВидДвиженияУправленческий = ВидДвиженияБухгалтерии.Кредит;
	НовСтрока.НомерСтроки               = 1;
	НовСтрока.Организация               = ДокументСсылкаРасходСоСчета.Организация;
	НовСтрока.Период                    = ДокументСсылкаРасходСоСчета.Дата;
	НовСтрока.Порядок                   = 1;
	НовСтрока.СодержаниеПроводки        = "Расход денежных средств";
	НовСтрока.Статья                    = Неопределено;
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();					
	
	ВалютаУчетаКурс = AzRyFunctions.ПолучитьКурсВалюты(ВалютаУчета, ДокументСсылкаРасходСоСчета.Дата);
	ВалютаКурс      = AzRyFunctions.ПолучитьКурсВалюты(ДокументСсылкаРасходСоСчета.БанковскийСчет1.ВалютаДенежныхСредств, ДокументСсылкаРасходСоСчета.Дата);
	
	Сумма    = AzRyFunctions.ПересчитатьПоКурсу(ДокументСсылкаРасходСоСчета.Сумма1, ВалютаКурс, ВалютаУчетаКурс); 
	СуммаВал = ДокументСсылкаРасходСоСчета.Сумма1; 
	
	НовСтрока.Сумма                     = Сумма;
	НовСтрока.СуммаВал                  = СуммаВал;
	НовСтрока.СчетУчета                 = ПланыСчетов.Управленческий.Банк;
	НовСтрока.ТипДенежныхСредств        = Перечисления.ТипыДенежныхСредств.Безналичные;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДенежныеСредства", ТД);
	
КонецПроцедуры // СформироватьТаблицаДенежныеСредстваРасходСоСчета()

