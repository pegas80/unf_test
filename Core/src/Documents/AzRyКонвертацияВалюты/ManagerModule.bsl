// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства, ТипОпераций) Экспорт
	
	Если ТипОпераций = "РасходСоСчета" Тогда  
		
		// Формирование таблиц движений по разделам учета.
		СформироватьТаблицаДенежныеСредстваРасходСоСчета(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаУправленческийРасходСоСчета(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаПлатежныйКалендарьРасходСоСчета(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаДоходыИРасходыРасходСоСчета(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		
	ИначеЕсли ТипОпераций = "ПоступлениеНаСчет" Тогда  
		
		// Формирование таблиц движений по разделам учета.
		СформироватьТаблицаДенежныеСредстваПоступлениеНаСчет(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаПлатежныйКалендарьПоступлениеНаСчет(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаУправленческийПоступлениеНаСчет(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаДоходыИРасходыПоступлениеНаСчет(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		
	ИначеЕсли ТипОпераций = "РасходИзКассы" Тогда  
		
		// Формирование таблиц движений по разделам учета.
		СформироватьТаблицаДенежныеСредстваРасходИзКассы(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаУправленческийРасходИзКассы(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаПлатежныйКалендарьРасходИзКассы(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаДоходыИРасходыРасходИзКассы(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		
	ИначеЕсли ТипОпераций = "ПоступлениеВКассу" Тогда  
		
		// Формирование таблиц движений по разделам учета.
		СформироватьТаблицаДенежныеСредстваПоступлениеВКассу(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаПлатежныйКалендарьПоступлениеВКассу(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		СформироватьТаблицаУправленческийПоступлениеВКассу(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);	
		СформироватьТаблицаДоходыИРасходыПоступлениеВКассу(ДокументСсылкаAzRyКонвертацияВалюты, СтруктураДополнительныеСвойства);
		
	КонецЕсли;
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()


Процедура Печать(ТабДок, Ссылка) Экспорт
	//{{_КОНСТРУКТОР_ПЕЧАТИ(Печать)
	Макет = Документы.AzRyКонвертацияВалюты.ПолучитьМакет("Печать");
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	AzRyКонвертацияВалюты.Автор,
	|	AzRyКонвертацияВалюты.БанковскийСчет1,
	|	AzRyКонвертацияВалюты.БанковскийСчет2,
	|	AzRyКонвертацияВалюты.ВалютаОпераций,
	|	AzRyКонвертацияВалюты.ВидОперации,
	|	AzRyКонвертацияВалюты.Дата,
	|	AzRyКонвертацияВалюты.ДатаКурсаВалюты,
	|	AzRyКонвертацияВалюты.Договор,
	|	AzRyКонвертацияВалюты.Документ,
	|	AzRyКонвертацияВалюты.Заказ,
	|	AzRyКонвертацияВалюты.Комментарий,
	|	AzRyКонвертацияВалюты.Контрагент,
	|	AzRyКонвертацияВалюты.Корреспонденция,
	|	AzRyКонвертацияВалюты.Кратность,
	|	AzRyКонвертацияВалюты.Курс,
