	|	AzRyКонвертацияВалюты.Номер,
	|	AzRyКонвертацияВалюты.Организация,
	|	AzRyКонвертацияВалюты.ПризнакАванса,
	|	AzRyКонвертацияВалюты.Статья,
	|	AzRyКонвертацияВалюты.Сумма1,
	|	AzRyКонвертацияВалюты.Сумма2,
	|	AzRyКонвертацияВалюты.СуммаПлатежа,
	|	AzRyКонвертацияВалюты.СуммаРасчетов,
	|	AzRyКонвертацияВалюты.СчетНаОплату
	|ИЗ
	|	Документ.AzRyКонвертацияВалюты КАК AzRyКонвертацияВалюты
	|ГДЕ
	|	AzRyКонвертацияВалюты.Ссылка В (&Ссылка)";
	Запрос.Параметры.Вставить("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();

	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
