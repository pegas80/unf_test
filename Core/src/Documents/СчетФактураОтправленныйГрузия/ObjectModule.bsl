Функция НайтиФактуруПоНакладной(Накладная)
	
	Если Не ЗначениеЗаполнено(Накладная) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка КАК СФ
		|ИЗ
		|	Документ.СчетФактураОтправленныйГрузия.ДокументыОснования КАК СчетФактураОтправленныйГрузияДокументыОснования
		|ГДЕ
		|	СчетФактураОтправленныйГрузияДокументыОснования.ДокументОснование = &Накладная
		|	И НЕ СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.ПометкаУдаления";
	Запрос.УстановитьПараметр("Накладная", Накладная);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.СФ;
	КонецЕсли;
	
	Возврат Неопределено;

КонецФункции
