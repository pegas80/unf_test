Процедура ЗаполнитьИзПриходнаяНакладная(ВыбранныеДокументы) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МИНИМУМ(ПриходнаяНакладнаяЗапасы.НомерСтроки) КАК НомерСтроки,
		|	ПриходнаяНакладнаяЗапасы.Номенклатура,
		|	ПриходнаяНакладнаяЗапасы.Характеристика,
		|	СУММА(ПриходнаяНакладнаяЗапасы.Количество) КАК Количество,
		|	СУММА(ПриходнаяНакладнаяЗапасы.Цена) КАК Цена,
		|	СУММА(ПриходнаяНакладнаяЗапасы.Сумма) КАК Сумма,
		|	СУММА(ПриходнаяНакладнаяЗапасы.СуммаНДС) КАК СуммаНДС,
		|	СУММА(ПриходнаяНакладнаяЗапасы.Всего) КАК Всего,
		|	ПриходнаяНакладнаяЗапасы.СтавкаНДС,
		|	ПриходнаяНакладнаяЗапасы.ЕдиницаИзмерения
		|ПОМЕСТИТЬ ВТВозвраты
		|ИЗ
		|	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
		|ГДЕ
		|	ПриходнаяНакладнаяЗапасы.Ссылка В(&ВыбранныеДокументы)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриходнаяНакладнаяЗапасы.Номенклатура,
		|	ПриходнаяНакладнаяЗапасы.Характеристика,
		|	ПриходнаяНакладнаяЗапасы.СтавкаНДС,
		|	ПриходнаяНакладнаяЗапасы.ЕдиницаИзмерения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МИНИМУМ(СчетФактураОтправленныйГрузияЗапасы.НомерСтроки) КАК НомерСтроки,
		|	СчетФактураОтправленныйГрузияЗапасы.Номенклатура КАК Номенклатура,
		|	СчетФактураОтправленныйГрузияЗапасы.Характеристика КАК Характеристика,
		|	СУММА(СчетФактураОтправленныйГрузияЗапасы.Количество) КАК Количество,
		|	СУММА(СчетФактураОтправленныйГрузияЗапасы.Цена) КАК Цена,
		|	СУММА(СчетФактураОтправленныйГрузияЗапасы.Сумма) КАК Сумма,
		|	СУММА(СчетФактураОтправленныйГрузияЗапасы.СуммаНДС) КАК СуммаНДС,
		|	СУММА(СчетФактураОтправленныйГрузияЗапасы.Всего) КАК Всего,
		|	СчетФактураОтправленныйГрузияЗапасы.СтавкаНДС КАК СтавкаНДС,
		|	СчетФактураОтправленныйГрузияЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ПОМЕСТИТЬ ВТРеализации
		|ИЗ
		|	Документ.СчетФактураОтправленныйГрузия.Запасы КАК СчетФактураОтправленныйГрузияЗапасы
		|ГДЕ
		|	СчетФактураОтправленныйГрузияЗапасы.Ссылка = &ОснованиеКорректировки
		|
		|СГРУППИРОВАТЬ ПО
		|	СчетФактураОтправленныйГрузияЗапасы.СтавкаНДС,
		|	СчетФактураОтправленныйГрузияЗапасы.Характеристика,
		|	СчетФактураОтправленныйГрузияЗапасы.Номенклатура,
		|	СчетФактураОтправленныйГрузияЗапасы.ЕдиницаИзмерения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТРеализации.НомерСтроки,
		|	ВТРеализации.Номенклатура,
		|	ВТРеализации.Характеристика,
		|	ВТРеализации.Количество - ЕСТЬNULL(ВТВозвраты.Количество, 0) КАК Количество,
		|	ВТРеализации.Цена,
		|	ВТРеализации.Сумма - ЕСТЬNULL(ВТВозвраты.Сумма, 0) КАК Сумма,
		|	ВТРеализации.СуммаНДС - ЕСТЬNULL(ВТВозвраты.СуммаНДС, 0) КАК СуммаНДС,
		|	ВТРеализации.Всего - ЕСТЬNULL(ВТВозвраты.Всего, 0) КАК Всего,
		|	ВТРеализации.СтавкаНДС,
		|	ВТРеализации.ЕдиницаИзмерения
		|ИЗ
		|	ВТРеализации КАК ВТРеализации
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВозвраты КАК ВТВозвраты
		|		ПО ВТРеализации.Номенклатура = ВТВозвраты.Номенклатура
		|			И ВТРеализации.Характеристика = ВТВозвраты.Характеристика
		|ГДЕ
		|	ВТРеализации.Количество - ЕСТЬNULL(ВТВозвраты.Количество, 0) > 0";
	Запрос.УстановитьПараметр("ОснованиеКорректировки", ОснованиеКорректировки);
	Запрос.УстановитьПараметр("ВыбранныеДокументы",		ВыбранныеДокументы);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;

