// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

// Заполняет шапку документа из данных заполнения
// 
// Параметры:
//	ДанныеЗаполнения - Массив - Заданные данные заполнения
//	
// Возвращаемое значение:
//	
//	
Процедура ЗаполнитьШапкуДокумента(ДанныеЗаполнения) Экспорт
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив") Тогда
		Документ = ДанныеЗаполнения[0];
		Автор					= ПараметрыСеанса.ТекущийПользователь;
		Контрагент				= Документ.Контрагент;
		Договор					= Документ.Договор;
		Организация 			= Документ.Организация;
		ДатаВходящегоДокумента	= Документ.Дата;
		
		Для Каждого ДокументСсылка Из ДанныеЗаполнения Цикл
			НоваяСтрока = ДокументыОснования.Добавить();
			НоваяСтрока.ДокументОснование	= ДокументСсылка.Ссылка;
			НоваяСтрока.Всего = ДокументСсылка.Запасы.Итог("Всего") + ?(ТипЗнч(НоваяСтрока.ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя"), ДокументСсылка.Работы.Итог("Всего"), 	0);
			НоваяСтрока.СуммаНДС = ДокументСсылка.Запасы.Итог("СуммаНДС") + ?(ТипЗнч(НоваяСтрока.ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя"), ДокументСсылка.Работы.Итог("СуммаНДС"),	0);
			НоваяСтрока.СуммаДокумента = НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Заполняет запасы документа из данных заполнения
// 
// Параметры:
//	ДанныеЗаполнения - Массив - Заданные данные заполнения
//	
// Возвращаемое значение:
//	
//	
Процедура ЗаполнитьЗапасы(ДанныеЗаполнения) Экспорт
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив") Тогда
		КЧ = Новый КвалификаторыЧисла(12,3);
		Массив = Новый Массив;
		Массив.Добавить(Тип("Число"));
		ОписаниеТиповЧ = Новый ОписаниеТипов(Массив, , КЧ);
		
		Массив.Очистить();
		Массив.Добавить(Тип("СправочникСсылка.Номенклатура"));
		ОписаниеТиповН = Новый ОписаниеТипов(Массив, , ,);
		
		Массив.Очистить();
		Массив.Добавить(Тип("СправочникСсылка.ХарактеристикиНоменклатуры"));
		ОписаниеТиповХ = Новый ОписаниеТипов(Массив, , ,);
		
		Массив.Очистить();
		Массив.Добавить(Тип("СправочникСсылка.ЕдиницыИзмерения"));
		Массив.Добавить(Тип("СправочникСсылка.КлассификаторЕдиницИзмерения"));
		ОписаниеТиповЕИ = Новый ОписаниеТипов(Массив, , ,);
		
		Таблица = Новый ТаблицаЗначений;
		Таблица.Колонки.Добавить("Номенклатура", ОписаниеТиповН);
		Таблица.Колонки.Добавить("Характеристика", ОписаниеТиповХ);
		Таблица.Колонки.Добавить("ЕдиницаИзмерения", ОписаниеТиповЕИ);
		Таблица.Колонки.Добавить("Количество", ОписаниеТиповЧ);
		Таблица.Колонки.Добавить("Цена", ОписаниеТиповЧ);
		Таблица.Колонки.Добавить("Сумма", ОписаниеТиповЧ);
		Таблица.Колонки.Добавить("СтавкаНДС", Новый ОписаниеТипов("СправочникСсылка.СтавкиНДС"));
		Таблица.Колонки.Добавить("СуммаНДС", ОписаниеТиповЧ);
		Таблица.Колонки.Добавить("Всего", ОписаниеТиповЧ);
		Таблица.Колонки.Добавить("Вид", ОписаниеТиповЧ);
		Для Каждого ДокументСсылка Из ДанныеЗаполнения Цикл
			Если ДокументСсылка.Курс = 1 ИЛИ ДокументСсылка.Курс = 0 Тогда//Паганини
				Если Не ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
					Для Каждого ТЗ Из ДокументСсылка.Запасы Цикл
						НоваяСтрока = Таблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТЗ);			
						Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
							НоваяСтрока.Вид = -1; 
						Иначе
							НоваяСтрока.Вид = 1;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
					Для Каждого ТЗ Из ДокументСсылка.Работы Цикл
						НоваяСтрока = Таблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТЗ);			
						НоваяСтрока.ЕдиницаИзмерения = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
						НоваяСтрока.Вид = 1;
					КонецЦикла;
				КонецЕсли;
				
				Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
					Для Каждого ТЗ Из ДокументСсылка.РаботыИУслуги Цикл
						НоваяСтрока = Таблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТЗ);			
						НоваяСтрока.ЕдиницаИзмерения = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
						НоваяСтрока.Вид = 1;
					КонецЦикла;
				КонецЕсли;
			//Паганини_
			Иначе
				
				//1.
				Если Не ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
					ТаблицаПродаж = ПолучитьТаблицуПродаж(ДокументСсылка);
					Сумма_ТЧ  = 0;
					НДС_ТЧ    = 0;
					Всего_ТЧ  = 0;
					Для Каждого ТЗ Из ДокументСсылка.Запасы Цикл
						СтруктураПойска = Новый Структура("Номенклатура, Характеристика, Партия, СтавкаНДС", ТЗ.Номенклатура, ТЗ.Характеристика, ТЗ.Партия, ТЗ.СтавкаНДС);
						НоваяСтрока = Таблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТЗ);
						НайденныеСтрокиПродаж 		= ТаблицаПродаж.НайтиСтроки(СтруктураПойска);
						Если НайденныеСтрокиПродаж.Количество() > 0 Тогда
							НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов = НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов - 1;
							Если НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов = 0 Тогда
								НоваяСтрока.Всего 		= НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить;
								НоваяСтрока.СуммаНДС 	= НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить;
								НоваяСтрока.Сумма 		= НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
							Иначе
								Коэффициент = ТЗ.Всего / НайденныеСтрокиПродаж[0].ИтогВсего;
								НоваяСтрока.Всего 		= Окр(НайденныеСтрокиПродаж[0].СуммаОборот		* Коэффициент, 2);
								НоваяСтрока.СуммаНДС 	= Окр(НайденныеСтрокиПродаж[0].СуммаНДСОборот	* Коэффициент, 2);
								НоваяСтрока.Сумма 		= НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
								
								НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить		= НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить	- НоваяСтрока.Всего;
								НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить	= НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить	- НоваяСтрока.СуммаНДС;
							КонецЕсли;
						Иначе
							НоваяСтрока.Всего 		= 0;
							НоваяСтрока.СуммаНДС 	= 0;
							НоваяСтрока.Сумма 		= 0;
						КонецЕсли;
						Всего_ТЧ  = Всего_ТЧ + НоваяСтрока.Всего;
						НДС_ТЧ    = НДС_ТЧ   + НоваяСтрока.СуммаНДС;
						Сумма_ТЧ  = Сумма_ТЧ + НоваяСтрока.Сумма;
						Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
							НоваяСтрока.Вид = -1; 
						Иначе
							НоваяСтрока.Вид = 1;
						КонецЕсли;
					КонецЦикла;
					НайденныеСтроки = ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", ДокументСсылка.Ссылка));
					НайденныеСтроки[0].Всего 				= Всего_ТЧ;
					НайденныеСтроки[0].СуммаНДС 			= НДС_ТЧ;
					НайденныеСтроки[0].СуммаДокумента 		= Сумма_ТЧ;
				КонецЕсли;
				
				//2.
				Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
					ТаблицаПродаж = ПолучитьТаблицуПродаж(ДокументСсылка, "Работы", Ложь);
					Сумма_ТЧ  = 0;
					НДС_ТЧ    = 0;
					Всего_ТЧ  = 0;
					Для Каждого ТЗ Из ДокументСсылка.Работы Цикл
						СтруктураПойска = Новый Структура("Номенклатура, Характеристика, СтавкаНДС", ТЗ.Номенклатура, ТЗ.Характеристика, ТЗ.СтавкаНДС);
						НоваяСтрока = Таблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТЗ);
						НайденныеСтрокиПродаж 		= ТаблицаПродаж.НайтиСтроки(СтруктураПойска);
						Если НайденныеСтрокиПродаж.Количество() > 0 Тогда
							НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов = НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов - 1;
							Если НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов = 0 Тогда
								НоваяСтрока.Всего 		= НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить;
								НоваяСтрока.СуммаНДС 	= НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить;
								НоваяСтрока.Сумма 		= НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
							Иначе
								Коэффициент = ТЗ.Всего / НайденныеСтрокиПродаж[0].ИтогВсего;
								НоваяСтрока.Всего 		= Окр(НайденныеСтрокиПродаж[0].СуммаОборот		* Коэффициент, 2);
								НоваяСтрока.СуммаНДС 	= Окр(НайденныеСтрокиПродаж[0].СуммаНДСОборот	* Коэффициент, 2);
								НоваяСтрока.Сумма 		= НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
								
								НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить		= НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить	- НоваяСтрока.Всего;
								НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить	= НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить	- НоваяСтрока.СуммаНДС;
							КонецЕсли;
						Иначе
							НоваяСтрока.Всего 		= 0;
							НоваяСтрока.СуммаНДС 	= 0;
							НоваяСтрока.Сумма 		= 0;
						КонецЕсли;
						
						Всего_ТЧ  = Всего_ТЧ + НоваяСтрока.Всего;
						НДС_ТЧ    = НДС_ТЧ   + НоваяСтрока.СуммаНДС;
						Сумма_ТЧ  = Сумма_ТЧ + НоваяСтрока.Сумма;
						НоваяСтрока.ЕдиницаИзмерения = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
						НоваяСтрока.Вид = 1;
					КонецЦикла;
					НайденныеСтроки = ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", ДокументСсылка.Ссылка));
					НайденныеСтроки[0].Всего 				= Всего_ТЧ;
					НайденныеСтроки[0].СуммаНДС 			= НДС_ТЧ;
					НайденныеСтроки[0].СуммаДокумента 		= Сумма_ТЧ;
				КонецЕсли;
				
				//3.
				Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
					ТаблицаПродаж = ПолучитьТаблицуПродаж(ДокументСсылка, "РаботыИУслуги", Ложь);
					Сумма_ТЧ  = 0;
					НДС_ТЧ    = 0;
					Всего_ТЧ  = 0;
					Для Каждого ТЗ Из ДокументСсылка.РаботыИУслуги Цикл
						СтруктураПойска = Новый Структура("Номенклатура, Характеристика, СтавкаНДС", ТЗ.Номенклатура, ТЗ.Характеристика, ТЗ.СтавкаНДС);
						НоваяСтрока = Таблица.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, ТЗ);
						НайденныеСтрокиПродаж 		= ТаблицаПродаж.НайтиСтроки(СтруктураПойска);
						Если НайденныеСтрокиПродаж.Количество() > 0 Тогда
							НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов = НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов - 1;
							Если НайденныеСтрокиПродаж[0].КоличествоСтрокЗапасов = 0 Тогда
								НоваяСтрока.Всего 		= НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить;
								НоваяСтрока.СуммаНДС 	= НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить;
								НоваяСтрока.Сумма 		= НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
							Иначе
								Коэффициент = ТЗ.Всего / НайденныеСтрокиПродаж[0].ИтогВсего;
								НоваяСтрока.Всего 		= Окр(НайденныеСтрокиПродаж[0].СуммаОборот		* Коэффициент, 2);
								НоваяСтрока.СуммаНДС 	= Окр(НайденныеСтрокиПродаж[0].СуммаНДСОборот	* Коэффициент, 2);
								НоваяСтрока.Сумма 		= НоваяСтрока.Всего - НоваяСтрока.СуммаНДС;
								
								НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить		= НайденныеСтрокиПродаж[0].СуммаОсталосьРаспределить	- НоваяСтрока.Всего;
								НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить	= НайденныеСтрокиПродаж[0].СуммаНДСОсталосьРаспределить	- НоваяСтрока.СуммаНДС;
							КонецЕсли;
						Иначе
							НоваяСтрока.Всего 		= 0;
							НоваяСтрока.СуммаНДС 	= 0;
							НоваяСтрока.Сумма 		= 0;
						КонецЕсли;
						Всего_ТЧ  = Всего_ТЧ + НоваяСтрока.Всего;
						НДС_ТЧ    = НДС_ТЧ   + НоваяСтрока.СуммаНДС;
						Сумма_ТЧ  = Сумма_ТЧ + НоваяСтрока.Сумма;
						НоваяСтрока.ЕдиницаИзмерения = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
						НоваяСтрока.Вид = 1;
					КонецЦикла;
					НайденныеСтроки = ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", ДокументСсылка.Ссылка));
					НайденныеСтроки[0].Всего 				= Всего_ТЧ;
					НайденныеСтроки[0].СуммаНДС 			= НДС_ТЧ;
					НайденныеСтроки[0].СуммаДокумента 		= Сумма_ТЧ;
				КонецЕсли;
			КонецЕсли;
			//_Паганини
		КонецЦикла;
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	Таблица.Номенклатура,
		               |	Таблица.Характеристика,
		               |	Таблица.Количество,
		               |	Таблица.Цена,
		               |	Таблица.Сумма,
		               |	Таблица.СтавкаНДС,
		               |	Таблица.СуммаНДС,
		               |	Таблица.Всего,
		               |	Таблица.Вид,
		               |	Таблица.ЕдиницаИзмерения
		               |ПОМЕСТИТЬ Запасы
		               |ИЗ
		               |	&Таблица КАК Таблица
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	Запасы.Номенклатура,
		               |	Запасы.Характеристика,
		               |	Запасы.СтавкаНДС,
		               |	Сумма(Запасы.Количество * Запасы.вид) Как Количество ,
		               |	СУММА(Запасы.Всего * Запасы.Вид) / Сумма(Запасы.Количество * Запасы.вид) Как Цена,
		               |	СУММА(Запасы.СуммаНДС * Запасы.Вид) КАК СуммаНДС,
		               |	СУММА((Запасы.Всего - Запасы.СуммаНДС) * Запасы.Вид) КАК Сумма,
		               |	СУММА(Запасы.Всего * Запасы.Вид) КАК Всего,
		               |	Запасы.ЕдиницаИзмерения
		               |ИЗ
		               |	Запасы КАК Запасы
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	Запасы.Номенклатура,
		               |	Запасы.Характеристика,
		               |	Запасы.Цена,
		               |	Запасы.СтавкаНДС,
		               |	Запасы.ЕдиницаИзмерения";
		Запрос.УстановитьПараметр("Таблица", Таблица);
		Результат = Запрос.Выполнить();
		Выборка = Результат.Выбрать();
		Запасы.Очистить();
		Пока Выборка.Следующий() Цикл
			НоваяСтрока = Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры


Функция ПолучитьТаблицуПродаж(ДокументСсылка, ИмяТЗ = "Запасы", ЕстьРеквизитПартия = Истина)
	
	ЗапросПродаж = Новый Запрос;
	Если ЕстьРеквизитПартия Тогда
		ЗапросПродаж.Текст =
			"ВЫБРАТЬ
			|	ИмяТЗ.Номенклатура,
			|	ИмяТЗ.Характеристика,
			|	ИмяТЗ.Партия КАК Партия,
			|	ИмяТЗ.СтавкаНДС,
			|	ИмяТЗ.СуммаНДС,
			|	ИмяТЗ.Всего
			|ПОМЕСТИТЬ ВТ_ЗапасыДокумента
			|ИЗ
			|	&ИмяТЗ КАК ИмяТЗ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_ЗапасыДокумента.Номенклатура,
			|	ВТ_ЗапасыДокумента.Характеристика,
			|	ВТ_ЗапасыДокумента.Партия,
			|	ВТ_ЗапасыДокумента.СтавкаНДС,
			|	СУММА(ВТ_ЗапасыДокумента.СуммаНДС) КАК СуммаНДС,
			|	СУММА(ВТ_ЗапасыДокумента.Всего) КАК Всего,
			|	СУММА(1) КАК КоличествоСтрокЗапасов
			|ПОМЕСТИТЬ ЗапасыСвенутая
			|ИЗ
			|	ВТ_ЗапасыДокумента КАК ВТ_ЗапасыДокумента
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_ЗапасыДокумента.Номенклатура,
			|	ВТ_ЗапасыДокумента.Партия,
			|	ВТ_ЗапасыДокумента.Характеристика,
			|	ВТ_ЗапасыДокумента.СтавкаНДС
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ПродажиОбороты.Номенклатура,
			|	ПродажиОбороты.Характеристика,
			|	ПродажиОбороты.Партия,
			|	ПродажиОбороты.СтавкаНДС,
			|	СУММА(ПродажиОбороты.КоличествоОборот) КАК КоличествоОборот,
			|	СУММА(ПродажиОбороты.СуммаОборот) КАК СуммаОборот,
			|	СУММА(ПродажиОбороты.СуммаНДСОборот) КАК СуммаНДСОборот
			|ПОМЕСТИТЬ Продажи
			|ИЗ
			|	РегистрНакопления.Продажи.Обороты(, , Регистратор, Документ = &ДокументСсылка) КАК ПродажиОбороты
			|ГДЕ
			|	ПродажиОбороты.Регистратор = &ДокументСсылка
			|
			|СГРУППИРОВАТЬ ПО
			|	ПродажиОбороты.Партия,
			|	ПродажиОбороты.Номенклатура,
			|	ПродажиОбороты.Характеристика,
			|	ПродажиОбороты.СтавкаНДС
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Продажи.Номенклатура,
			|	Продажи.Характеристика,
			|	Продажи.Партия,
			|	Продажи.СтавкаНДС,
			|	Продажи.КоличествоОборот,
			|	Продажи.СуммаОборот,
			|	Продажи.СуммаНДСОборот,
			|	ЗапасыСвенутая.СуммаНДС КАК ИтогСуммаНДС,
			|	ЗапасыСвенутая.Всего КАК ИтогВсего,
			|	ЗапасыСвенутая.КоличествоСтрокЗапасов,
			|	Продажи.СуммаОборот КАК СуммаОсталосьРаспределить,
			|	Продажи.СуммаНДСОборот КАК СуммаНДСОсталосьРаспределить
			|ИЗ
			|	Продажи КАК Продажи
			|		ЛЕВОЕ СОЕДИНЕНИЕ ЗапасыСвенутая КАК ЗапасыСвенутая
			|		ПО Продажи.Номенклатура = ЗапасыСвенутая.Номенклатура
			|			И Продажи.Характеристика = ЗапасыСвенутая.Характеристика
			|			И Продажи.Партия = ЗапасыСвенутая.Партия
			|			И Продажи.СтавкаНДС = ЗапасыСвенутая.СтавкаНДС";
		ЗапросПродаж.УстановитьПараметр("ИмяТЗ", 			ДокументСсылка[ИмяТЗ].Выгрузить());
		ЗапросПродаж.УстановитьПараметр("ДокументСсылка", 	ДокументСсылка);
	Иначе
		ЗапросПродаж.Текст =
			"ВЫБРАТЬ
			|	ИмяТЗ.Номенклатура,
			|	ИмяТЗ.Характеристика,
			|	ИмяТЗ.СтавкаНДС,
			|	ИмяТЗ.СуммаНДС,
			|	ИмяТЗ.Всего
			|ПОМЕСТИТЬ ВТ_ЗапасыДокумента
			|ИЗ
			|	&ИмяТЗ КАК ИмяТЗ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_ЗапасыДокумента.Номенклатура,
			|	ВТ_ЗапасыДокумента.Характеристика,
			|	ВТ_ЗапасыДокумента.СтавкаНДС,
			|	СУММА(ВТ_ЗапасыДокумента.СуммаНДС) КАК СуммаНДС,
			|	СУММА(ВТ_ЗапасыДокумента.Всего) КАК Всего,
			|	СУММА(1) КАК КоличествоСтрокЗапасов
			|ПОМЕСТИТЬ ЗапасыСвенутая
			|ИЗ
			|	ВТ_ЗапасыДокумента КАК ВТ_ЗапасыДокумента
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_ЗапасыДокумента.Номенклатура,
			|	ВТ_ЗапасыДокумента.Характеристика,
			|	ВТ_ЗапасыДокумента.СтавкаНДС
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ПродажиОбороты.Номенклатура,
			|	ПродажиОбороты.Характеристика,
			|	ПродажиОбороты.СтавкаНДС,
			|	СУММА(ПродажиОбороты.КоличествоОборот) КАК КоличествоОборот,
			|	СУММА(ПродажиОбороты.СуммаОборот) КАК СуммаОборот,
			|	СУММА(ПродажиОбороты.СуммаНДСОборот) КАК СуммаНДСОборот
			|ПОМЕСТИТЬ Продажи
			|ИЗ
			|	РегистрНакопления.Продажи.Обороты(, , Регистратор, Документ = &ДокументСсылка) КАК ПродажиОбороты
			|ГДЕ
			|	ПродажиОбороты.Регистратор = &ДокументСсылка
			|
			|СГРУППИРОВАТЬ ПО
			|	ПродажиОбороты.Номенклатура,
			|	ПродажиОбороты.Характеристика,
			|	ПродажиОбороты.СтавкаНДС
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Продажи.Номенклатура,
			|	Продажи.Характеристика,
			|	Продажи.СтавкаНДС,
			|	Продажи.КоличествоОборот,
			|	Продажи.СуммаОборот,
			|	Продажи.СуммаНДСОборот,
			|	ЗапасыСвенутая.СуммаНДС КАК ИтогСуммаНДС,
			|	ЗапасыСвенутая.Всего КАК ИтогВсего,
			|	ЗапасыСвенутая.КоличествоСтрокЗапасов,
			|	Продажи.СуммаОборот КАК СуммаОсталосьРаспределить,
			|	Продажи.СуммаНДСОборот КАК СуммаНДСОсталосьРаспределить
			|ИЗ
			|	Продажи КАК Продажи
			|		ЛЕВОЕ СОЕДИНЕНИЕ ЗапасыСвенутая КАК ЗапасыСвенутая
			|		ПО Продажи.Номенклатура = ЗапасыСвенутая.Номенклатура
			|			И Продажи.Характеристика = ЗапасыСвенутая.Характеристика
			|			И Продажи.СтавкаНДС = ЗапасыСвенутая.СтавкаНДС";
		ЗапросПродаж.УстановитьПараметр("ИмяТЗ", 			ДокументСсылка[ИмяТЗ].Выгрузить());
		ЗапросПродаж.УстановитьПараметр("ДокументСсылка", 	ДокументСсылка);
	КонецЕсли;
	Возврат ЗапросПродаж.Выполнить().Выгрузить();
	
КонецФункции

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если Аванс Тогда
		//ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.Документ");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.Договор");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.Сумма");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.СуммаНДС");
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Инициализация дополнительных свойств для проведения документа.
	УправлениеНебольшойФирмойСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
	
	// Инициализация данных документа.
	Документы.СчетФактураОтправленныйГрузия.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства);
	
	// Подготовка наборов записей.
	УправлениеНебольшойФирмойСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтразитьХозрасчетный(ДополнительныеСвойства, Движения, Отказ);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтразитьАвансыОтправленныхФактур(ДополнительныеСвойства, Движения, Отказ);
	Если ЗначениеЗаполнено(ВидНалога) Тогда // Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		УправлениеНебольшойФирмойСервер.ОтразитьРасчетыПоНалогам(ДополнительныеСвойства, Движения, Отказ);// Kuzmich, 16.09.2019, Добавление бух проводок в счет фактурах
	КонецЕсли;
	
	// Запись наборов записей
	УправлениеНебольшойФирмойСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);
	
	ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц.Закрыть();
	
КонецПроцедуры

















