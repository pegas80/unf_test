// ОБРАБОТЧИКИ СОБЫТИЙ

// Процедура - обработчик события ОбработкаПроверкиЗаполнения объекта.
//
Процедура ОбработкаПроверкиЗаполненияЛок(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив") Тогда
		КоличествоДокументов = ДанныеЗаполнения.Количество();
		Контрагент = ДанныеЗаполнения[0].Контрагент;
		
		Для Каждого ДокументСсылка Из ДанныеЗаполнения Цикл
			Если Не ДокументСсылка.Контрагент = Контрагент Тогда
				Сообщить(НСТР("ka = ""კონტრაგენტები განსხვავდებიან ერთმანეთისგან"";  ru = ""კონტრაგენტები განსხვავდებიან ერთმანეთისგან"";"));
				СтандартнаяОбработка = Ложь;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ДокументСсылка.Организация) Тогда
				Сообщить(НСТР("ka = ""შევსებული არ არის ორგანიზაციის ველი დოკუმენტში: ""; ru = ""შევსებული არ არის ორგანიზაციის ველი დოკუმენტში: ""; ") + ДокументСсылка);	
				СтандартнаяОбработка = Ложь;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ДокументСсылка.Контрагент) Тогда
				Сообщить(НСТР("ka = ""შევსებული არ არის კონტრაგენტის ველი დოკუმენტში: ""; ru = ""შევსებული არ არის კონტრაგენტის ველი დოკუმენტში: ""; ") + ДокументСсылка);	
				СтандартнаяОбработка = Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры // ОбработкаПроверкиЗаполнения()

// Процедура - обработчик события ОбработкаЗаполнения объекта.
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка) Экспорт
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив") Тогда
		ОбработкаПроверкиЗаполненияЛок(ДанныеЗаполнения, СтандартнаяОбработка);
		ЗаполнитьШапкуДокумента(ДанныеЗаполнения);
		//Паганини#OneSoft_
		Если ДанныеЗаполнения.Количество() > 0 И ТипЗнч(ДанныеЗаполнения[0]) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
			Корректировочная					= Истина;
			ПричинаКорректировки				= Перечисления.ПричиныКорректировкиСФ.ИзмененаСуммаОперации;
			ОснованиеКорректировки				= НайтиФактуруПоНакладной(ДанныеЗаполнения[0].ДокументОснование);
			ЗаполнитьИзКорректировкиРеализации(ДанныеЗаполнения);
		ИначеЕсли ДанныеЗаполнения.Количество() > 0 И ТипЗнч(ДанныеЗаполнения[0]) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Корректировочная					= Истина;
			ПричинаКорректировки				= Перечисления.ПричиныКорректировкиСФ.ВозвратТовара;
			ОснованиеКорректировки				= НайтиФактуруПоНакладной(ДанныеЗаполнения[0].ДокументОснование);
			ЗаполнитьИзПриходнаяНакладная(ДанныеЗаполнения);
		Иначе
		//_Паганини#OneSoft
		ЗаполнитьЗапасы(ДанныеЗаполнения);
		//Паганини#OneSoft_
	    КонецЕсли;
		//_Паганини#OneSoft
	Иначе
		ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ЭтотОбъект, ДанныеЗаполнения);
	КонецЕсли;
	
КонецПроцедуры

// Процедура - обработчик события ПередЗаписью.
//
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	//Паганини_
	//СуммаДокумента = Запасы.Итог("Всего");
	//СуммаНДС = Запасы.Итог("СуммаНДС");
	Если Аванс Тогда
		ДокументыОснования.Очистить();
		Запасы.Очистить();
		СуммаДокумента	= ДокументыПлатежа.Итог("Сумма");
		СуммаНДС 		= ДокументыПлатежа.Итог("СуммаНДС");
	Иначе
		СуммаДокумента	= 0;
		СуммаНДС 		= 0;
		Для Каждого СтрокаТЧ ИЗ ДокументыОснования Цикл
			//Если НЕ ТипЗнч(СтрокаТЧ.ДокументОснование) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда//Паганини#OneSoft
				СуммаДокумента 		= СуммаДокумента	+ СтрокаТЧ.СуммаДокумента;
				СуммаНДС 			= СуммаНДС 			+ СтрокаТЧ.СуммаНДС;
			//КонецЕсли;//Паганини#OneSoft
		КонецЦикла;
		ДокументыПлатежа.Очистить();
	КонецЕсли;
	
	Если ДокументыОснования.Количество() > 0 И (ТипЗнч(ДокументыОснования[0].ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") ИЛИ ТипЗнч(ДокументыОснования[0].ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя")) Тогда
		ЗаписыватьДокумент = Ложь;
		Док = ДокументыОснования[0].ДокументОснование;
		Если НЕ Идентификатор = Док.IDСФ Тогда
			ЗаписыватьДокумент = Истина;
		КонецЕсли;
		Если НЕ НомерВходящегоДокумента = Док.НомерСФ Тогда
			ЗаписыватьДокумент = Истина;
		КонецЕсли;
		Если ЗаписыватьДокумент Тогда
			ДокументОбъект = Док.ПолучитьОбъект();
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.НомерСФ = НомерВходящегоДокумента;
			ДокументОбъект.IDСФ	= Формат(Идентификатор, "ЧН=' '; ЧГ=0");
			ДокументОбъект.Записать();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


