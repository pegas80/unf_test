

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Идентификатор			= 0;
		Объект.НомерСчетФактуры 		= "";
		Объект.Серия                    = "";
		Объект.НомерВходящегоДокумента 	= "";
		Объект.Статус					= Неопределено;
		Объект.ПериодРегистрации		= Дата(1,1,1);
		Для Каждого СтрокаТЧ ИЗ Объект.Запасы Цикл
			СтрокаТЧ.ID = 0;
		КонецЦикла;
		Объект.ДокументыПлатежа.Очистить();
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		Объект.ВидНалога = НЕОПРЕДЕЛЕНО;
		Объект.СчетУчетаРегл = НЕОПРЕДЕЛЕНО;
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	КонецЕсли;
	Контрагент = Объект.Контрагент;
	УстановитьВидимость();
	ОбщегоНазначенияПереопределяемый.УстановитьДополнительноеПоведениеСтандартныхКнопокТЧЗапасы(ЭтаФорма);// Kuzmich, 07.08.2019, Дополнительные инструменты в табличных частях документов движения товаров
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ДатаВходящегоДокументаПриИзменении(Неопределено);
	
	// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.Организация) Тогда
		УстановитьСчетНДСИзУчетнойПолитики();
	КонецЕсли;
	// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПерепрочитатьФорму" Тогда
		Прочитать();
	КонецЕсли;
	
КонецПроцедуры




