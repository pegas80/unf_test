&НаКлиенте
Процедура ДокументыПлатежаДокументНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВыбора = Новый СписокЗначений; 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ПоступлениеВКассу")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ПоступлениеНаСчет")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ОперацияПоПлатежнымКартам")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.Взаимозачет"));
	
	ВыбранноеЗначение = ВыбратьИзСписка(СписокВыбора);
	
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗначениеОтбора  = Новый Структура;
	Если ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда 
		
		ИмяДокумента = "ПоступлениеВКассу";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеВКассу.ОтПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда 
		
		ИмяДокумента = "ПоступлениеНаСчет";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ОтПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда 
		 
		ИмяДокумента = "ОперацияПоПлатежнымКартам";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийЭквайринга.ПоступлениеОплатыОтПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.Взаимозачет") Тогда 
		 
		ИмяДокумента = "ОперацияПоПлатежнымКартам";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимозачет.ПереуступкаДолгаПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	КонецЕсли;
	
	ЗначениеОтбора.Вставить("Проведен", Истина);
	пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);   
	Форма = ОткрытьФорму("Документ." +ИмяДокумента+".ФормаВыбора",пПараметрыВыбора,Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПлатежаДокументОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ЗаполнитьДанныеДокументаАванса(ВыбранноеЗначение, Элементы.ДокументыПлатежа.ТекущаяСтрока);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеДокументаАванса(Документ, ИД)
	
	РасчетыСПокупателями = Документ.Получитьобъект().Движения.РасчетыСПокупателями;
	РасчетыСПокупателями.Прочитать();
	ЕстьСтрокиАвансов	= Ложь;
	ПерваяСтрока		= Истина;
	Для Каждого СтрокаДвижения Из РасчетыСПокупателями Цикл
		Если СтрокаДвижения.ТипРасчетов = Перечисления.ТипыРасчетов.Аванс Тогда
			Если ПерваяСтрока Тогда
				НовСтрока = Объект.ДокументыПлатежа.НайтиПоИдентификатору(ИД);
				ПерваяСтрока = Ложь;
			Иначе
				НовСтрока = Объект.ДокументыПлатежа.Добавить();
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаДвижения);
			НовСтрока.СуммаНДС = Окр(СтрокаДвижения.Сумма * 18/118, 2);
			ЕстьСтрокиАвансов	= Истина;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ЕстьСтрокиАвансов Тогда
		ТекСтрока = Объект.ДокументыПлатежа.НайтиПоИдентификатору(ИД);
		ТекСтрока.Сумма		= 0;
		ТекСтрока.СуммаНДС	= 0;
		ТекСтрока.Договор	= Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПлатежаДокументПриИзменении(Элемент)
	ТекСтрока = Элементы.ДокументыПлатежа.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ТекСтрока.Документ) Тогда
		ТекСтрока.Сумма		= 0;
		ТекСтрока.СуммаНДС	= 0;
		ТекСтрока.Договор	= Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьАвансы(Команда)
	СтруктураАдреса = ПолучитьАдресТаблицыОстатков();
	Результат = ОткрытьФормуМодально("Документ.СчетФактураОтправленныйГрузия.Форма.ФормаОстаткиАвансов", СтруктураАдреса);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьВыделенныеСтроки(Результат.АдресТаблицы);
	Модифицированность = Истина;
КонецПроцедуры

Процедура ЗаполнитьВыделенныеСтроки(АдресТаблицы)
	ВыделенныеСтроки = ПолучитьИзВременногоХранилища(АдресТаблицы);
	Для Каждого СтрокаТЧ ИЗ ВыделенныеСтроки Цикл
		НовСтрока = Объект.ДокументыПлатежа.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
	КонецЦикла;
КонецПроцедуры

