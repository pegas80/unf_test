&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	
	КонтрагентПередИзменением = Контрагент;
	Контрагент = Объект.Контрагент;
	
	Если КонтрагентПередИзменением <> Объект.Контрагент Тогда
		Если Объект.ДокументыПлатежа.Количество() > 0 Тогда
			ПараметрыДокумента = Новый Структура;
			ПараметрыДокумента.Вставить("КонтрагентПередИзменением", КонтрагентПередИзменением);
			ОписаниеОповещения = Новый ОписаниеОповещения("ВопросОбОчисткеДокументовПлатежаЗавершение", ЭтотОбъект, ПараметрыДокумента);
			ТекстВопроса = НСтр("ka='გადახდის დოკუმენტები გაიწმინდება, გავაგრძელოთ?';ru='Документы платежа будет очищен, продолжить?';en='payment documents will be cleared to continue?'");
			
			ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросОбОчисткеДокументовПлатежаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Объект.ДокументыПлатежа.Очистить();
	Иначе
		Объект.Контрагент	= ДополнительныеПараметры.КонтрагентПередИзменением;
		Контрагент			= ДополнительныеПараметры.КонтрагентПередИзменением;
	КонецЕсли;

КонецПроцедуры

