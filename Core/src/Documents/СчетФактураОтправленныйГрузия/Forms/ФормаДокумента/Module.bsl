&НаСервере
Процедура ЗаполнитьИзДокументовСервер()
	
	МассивДокументов = Новый Массив;
	Для Каждого СтрокаТЧ Из ЭтаФорма.Объект.ДокументыОснования Цикл
		МассивДокументов.Добавить(СтрокаТЧ.ДокументОснование);	
	КонецЦикла;
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.ЗаполнитьЗапасы(МассивДокументов);
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Функция ПолучитьИтоги(Документ)
	
	Структура = Новый Структура;
	//Паганини_
	//Структура.Вставить("Всего", ?(Не ТипЗнч(Документ) = Тип("ДокументСсылка.АктВыполненныхРабот"), Документ.Запасы.Итог("Всего"), Документ.РаботыИУслуги.Итог("Всего")));	
	//Структура.Вставить("СуммаНДС", ?(Не ТипЗнч(Документ) = Тип("ДокументСсылка.АктВыполненныхРабот"), Документ.Запасы.Итог("СуммаНДС"), Документ.РаботыИУслуги.Итог("СуммаНДС")));
	//Структура.Вставить("СуммаДокумента", Структура.Всего - Структура.СуммаНДС);
	Если НЕ (Документ.Курс = 1 ИЛИ Документ.Курс = 0) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПродажиОбороты.Регистратор,
			|	СУММА(ПродажиОбороты.СуммаОборот) КАК Всего,
			|	СУММА(ПродажиОбороты.СуммаНДСОборот) КАК СуммаНДС
			|ИЗ
			|	РегистрНакопления.Продажи.Обороты(, , Регистратор, Документ = &ДокументСсылка) КАК ПродажиОбороты
			|ГДЕ
			|	ПродажиОбороты.Регистратор = &ДокументСсылка
			|
			|СГРУППИРОВАТЬ ПО
			|	ПродажиОбороты.Регистратор";
		Запрос.УстановитьПараметр("ДокументСсылка", Документ);
		ТЗПродажи = Запрос.Выполнить().Выгрузить();
		Если ТЗПродажи.Количество() = 0 Тогда
			Структура.Вставить("Всего",				0);
			Структура.Вставить("СуммаНДС",       	0);
			Структура.Вставить("СуммаДокумента", 	0);
		Иначе
			Структура.Вставить("Всего",				ТЗПродажи[0].Всего);
			Структура.Вставить("СуммаНДС",       	ТЗПродажи[0].СуммаНДС);
			Структура.Вставить("СуммаДокумента", 	ТЗПродажи[0].Всего - ТЗПродажи[0].СуммаНДС);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.Взаимозачет") Тогда	
		
		Структура.Вставить("Всего", 		Документ.СуммаРасчетов);																																							
		Структура.Вставить("СуммаНДС", 		0);
		Структура.Вставить("СуммаДокумента", Структура.Всего - Структура.СуммаНДС);
		
	Иначе
		Структура.Вставить("Всего", 		?(ТипЗнч(Документ) = Тип("ДокументСсылка.АктВыполненныхРабот"), Документ.РаботыИУслуги.Итог("Всего"), 		Документ.Запасы.Итог("Всего") +
																																						?(ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказПокупателя"), Документ.Работы.Итог("Всего"), 	0)));	
		Структура.Вставить("СуммаНДС", 		?(ТипЗнч(Документ) = Тип("ДокументСсылка.АктВыполненныхРабот"), Документ.РаботыИУслуги.Итог("СуммаНДС"), 	Документ.Запасы.Итог("СуммаНДС") +
																																						?(ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказПокупателя"), Документ.Работы.Итог("СуммаНДС"),	0)));
		Структура.Вставить("СуммаДокумента", Структура.Всего - Структура.СуммаНДС);
	КонецЕсли;//_Паганини
	
	Возврат Структура;
	
КонецФункции

&НаКлиенте
Процедура ПриИзмененииПериодаРегистрации(ПереданнаяФорма, ИмяРеквизита, ИмяОтображения)
    	
	ПереданнаяФорма.Объект[ИмяРеквизита] 	= НачалоМесяца(ПереданнаяФорма.Объект[ИмяРеквизита]);
	ПереданнаяФорма[ИмяОтображения] 		= Формат(ПереданнаяФорма.Объект[ИмяРеквизита], НСТР("ka=""Л=ka; ДФ='MMMM yyyy'"";ru=""ДФ='MMMM yyyy'"""));
	
КонецПроцедуры 

&НаКлиенте
Процедура ПриРегулированииПериодаРегистрации(ПереданнаяФорма, Направление, ИмяРеквизита) Экспорт
	
	ПереданнаяФорма.Объект[ИмяРеквизита] = ?(ЗначениеЗаполнено(ПереданнаяФорма.Объект[ИмяРеквизита]), 
						ДобавитьМесяц(ПереданнаяФорма.Объект[ИмяРеквизита], Направление),
						ДобавитьМесяц(НачалоМесяца(ТекущаяДата()), Направление));
		
КонецПроцедуры

&НаКлиенте
Процедура ДокументыОснованияДокументОснованиеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВыбора = Новый СписокЗначений; 
	СписокВыбора.Добавить(Тип("ДокументСсылка.РасходнаяНакладная")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ПриходнаяНакладная")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.АктВыполненныхРабот")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ЗаказПокупателя"));
	СписокВыбора.Добавить(Тип("ДокументСсылка.Взаимозачет"));	
	
	ВыбранноеЗначение = ВыбратьИзСписка(СписокВыбора);
	
	Если ВыбранноеЗначение <> Неопределено Тогда 
		Если ВыбранноеЗначение.Значение = Тип("ДокументСсылка.РасходнаяНакладная") Тогда 
			
			ЗначениеОтбора  = Новый Структура("ВидОперации", ПолучитьДанныеПеречисления("ВидыОперацийРасходнаяНакладная","ПродажаПокупателю"));
			ЗначениеОтбора.Вставить("Контрагент",Объект.Контрагент);
			пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);   
			Форма = ОткрытьФорму("Документ.РасходнаяНакладная.ФормаВыбора",пПараметрыВыбора,Элемент);
			
		ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда 
			
			ЗначениеОтбора  = Новый Структура("ВидОперации", ПолучитьДанныеПеречисления("ВидыОперацийПриходнаяНакладная","ВозвратОтПокупателя"));
			ЗначениеОтбора.Вставить("Контрагент",Объект.Контрагент);
			пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);   
			Форма = ОткрытьФорму("Документ.ПриходнаяНакладная.ФормаВыбора",пПараметрыВыбора,Элемент);
			
		ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда 
			//
			//ЗначениеОтбора  = Новый Структура("ВидОперации", ПолучитьДанныеПеречисления("ВидыОперацийРасходнаяНакладная.ПередачаНаКомиссию"));
			//ПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора); 
			ЗначениеОтбора  = Новый Структура();
			ЗначениеОтбора.Вставить("Контрагент",Объект.Контрагент);
			пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);
			Форма = ОткрытьФорму("Документ.АктВыполненныхРабот.ФормаВыбора",пПараметрыВыбора,Элемент);  
			
		ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.Взаимозачет") Тогда 
			//
			//ПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора); 
			ЗначениеОтбора  = Новый Структура();
			ЗначениеОтбора.Вставить("Контрагент",Объект.Контрагент);
			ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимозачет.ПереуступкаДолгаПокупателя"));
			пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);
			Форма = ОткрытьФорму("Документ.Взаимозачет.ФормаВыбора",пПараметрыВыбора,Элемент);	
			
		ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
			
			ЗначениеОтбора  = Новый Структура("ВидОперации", ПолучитьДанныеПеречисления("ВидыОперацийЗаказПокупателя","ЗаказНаряд"));
			ЗначениеОтбора.Вставить("Контрагент",Объект.Контрагент);
			пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);   
			Форма = ОткрытьФорму("Документ.ЗаказПокупателя.ФормаВыбора",пПараметрыВыбора,Элемент);
		КонецЕсли; 
		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция  ПолучитьДанныеПеречисления(ИмяПереч,ЗнчПереч)
	Возврат Перечисления[ИмяПереч][ЗнчПереч];
КонецФункции

Функция ПолучитьПараметрыФормыВыбора(Документ, Организация, Контрагент)
	
	СписокВидовДоговоров = Справочники.ДоговорыКонтрагентов.ПолучитьСписокВидовДоговораДляДокумента(Документ);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("КонтролироватьВыборДоговора", Контрагент.ВестиРасчетыПоДоговорам);
	ПараметрыФормы.Вставить("Контрагент", Контрагент);
	ПараметрыФормы.Вставить("Организация", Организация);
	//ПараметрыФормы.Вставить("ВидыДоговоров", СписокВидовДоговоров);
	
	Возврат ПараметрыФормы;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьРасходныеНакладные(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю"));
	ПараметрыОтбора.Вставить("Контрагент",	Объект.Контрагент);
	ПараметрыОтбора.Вставить("Проведен",	Истина);
	
	пПараметрыВыбора = Новый Структура;
	пПараметрыВыбора.Вставить("Отбор", 				ПараметрыОтбора);
	пПараметрыВыбора.Вставить("МножественныйВыбор",	Истина);
	
	Результат = ОткрытьФормуМодально("Документ.РасходнаяНакладная.Форма.ФормаВыбора", пПараметрыВыбора);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	ЗаполнитьДокументы(Результат);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЗаказНаряды(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаряд"));
	ПараметрыОтбора.Вставить("Контрагент",	Объект.Контрагент);
	ПараметрыОтбора.Вставить("Проведен",	Истина);
	
	пПараметрыВыбора = Новый Структура;
	пПараметрыВыбора.Вставить("Отбор", 				ПараметрыОтбора);
	пПараметрыВыбора.Вставить("МножественныйВыбор",	Истина);
	
	Результат = ОткрытьФормуМодально("Документ.ЗаказПокупателя.Форма.ФормаВыбора", пПараметрыВыбора);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	ЗаполнитьДокументы(Результат);
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьВозвраты(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя"));
	ПараметрыОтбора.Вставить("Контрагент",	Объект.Контрагент);
	ПараметрыОтбора.Вставить("Проведен",	Истина);
	
	пПараметрыВыбора = Новый Структура;
	пПараметрыВыбора.Вставить("Отбор", 				ПараметрыОтбора);
	пПараметрыВыбора.Вставить("МножественныйВыбор",	Истина);
	
	Результат = ОткрытьФормуМодально("Документ.ПриходнаяНакладная.Форма.ФормаВыбора", пПараметрыВыбора);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	ЗаполнитьДокументы(Результат);
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДокументы(ВыбранныеДокументы)
	Для Каждого Док ИЗ ВыбранныеДокументы Цикл
		Если Объект.ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", Док)).Количество() = 0 Тогда
			НовСтрока = Объект.ДокументыОснования.Добавить();
			НовСтрока.ДокументОснование = Док;
			ЗаполнитьЗначенияСвойств(НовСтрока, ПолучитьИтоги(НовСтрока.ДокументОснование));
		Иначе
			Сообщить(Строка(Док) + " უკვე შეყვანილია ანგარიშ-ფაქტურაში");
		КонецЕсли;
	КонецЦикла;
	ЗаполнитьИзДокументовСервер();
КонецПроцедуры

&НаКлиенте
Процедура АвансПриИзменении(Элемент)
	УстановитьВидимость();
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
	
	Если Объект.Аванс Тогда
		Элементы.ГруппаДокументыОснования.Видимость = Ложь;
		Элементы.ГруппаЗапасы.Видимость 			= Ложь;
		Элементы.Итоги.Видимость 					= Ложь;
		Элементы.ГруппаАвансы.Видимость 			= Истина;
		Элементы.ИтогиАванс.Видимость 				= Истина;
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		Объект.ВидНалога = НЕОПРЕДЕЛЕНО;
		Объект.СчетУчетаРегл = НЕОПРЕДЕЛЕНО;
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	Иначе
		Элементы.ГруппаДокументыОснования.Видимость = Истина;
		Элементы.ГруппаЗапасы.Видимость 			= Истина;
		Элементы.Итоги.Видимость 					= Истина;
		Элементы.ИтогиАванс.Видимость 				= Ложь;
		Элементы.ГруппаАвансы.Видимость 			= Ложь;
	КонецЕсли;
	
	Элементы.СчетНДС.Видимость = НЕ (Объект.Аванс); // Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАвансы(Команда)
	ЗаполнитьАвансыНаСервере();
	Модифицированность = Истина;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАвансыНаСервере()
	
	ТаблицаАвансов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьТаблицуАвансов(Объект.Ссылка, "СчетФактураОтправленныйГрузия", Объект.ДатаВходящегоДокумента, Объект.Организация, Объект.Контрагент);
	Объект.ДокументыПлатежа.Загрузить(ТаблицаАвансов);
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПлатежаДокументНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВыбора = Новый СписокЗначений; 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ПоступлениеВКассу")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ПоступлениеНаСчет")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.ОперацияПоПлатежнымКартам")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.Взаимозачет"));
	
	ВыбранноеЗначение = ВыбратьИзСписка(СписокВыбора);
	
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗначениеОтбора  = Новый Структура;
	Если ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ПоступлениеВКассу") Тогда 
		
		ИмяДокумента = "ПоступлениеВКассу";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеВКассу.ОтПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда 
		
		ИмяДокумента = "ПоступлениеНаСчет";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ОтПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда 
		 
		ИмяДокумента = "ОперацияПоПлатежнымКартам";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийЭквайринга.ПоступлениеОплатыОтПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.Взаимозачет") Тогда 
		 
		ИмяДокумента = "ОперацияПоПлатежнымКартам";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийВзаимозачет.ПереуступкаДолгаПокупателя"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	КонецЕсли;
	
	ЗначениеОтбора.Вставить("Проведен", Истина);
	пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);   
	Форма = ОткрытьФорму("Документ." +ИмяДокумента+".ФормаВыбора",пПараметрыВыбора,Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПлатежаДокументОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ЗаполнитьДанныеДокументаАванса(ВыбранноеЗначение, Элементы.ДокументыПлатежа.ТекущаяСтрока);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеДокументаАванса(Документ, ИД)
	
	РасчетыСПокупателями = Документ.Получитьобъект().Движения.РасчетыСПокупателями;
	РасчетыСПокупателями.Прочитать();
	ЕстьСтрокиАвансов	= Ложь;
	ПерваяСтрока		= Истина;
	Для Каждого СтрокаДвижения Из РасчетыСПокупателями Цикл
		Если СтрокаДвижения.ТипРасчетов = Перечисления.ТипыРасчетов.Аванс Тогда
			Если ПерваяСтрока Тогда
				НовСтрока = Объект.ДокументыПлатежа.НайтиПоИдентификатору(ИД);
				ПерваяСтрока = Ложь;
			Иначе
				НовСтрока = Объект.ДокументыПлатежа.Добавить();
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаДвижения);
			НовСтрока.СуммаНДС = Окр(СтрокаДвижения.Сумма * 18/118, 2);
			ЕстьСтрокиАвансов	= Истина;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ЕстьСтрокиАвансов Тогда
		ТекСтрока = Объект.ДокументыПлатежа.НайтиПоИдентификатору(ИД);
		ТекСтрока.Сумма		= 0;
		ТекСтрока.СуммаНДС	= 0;
		ТекСтрока.Договор	= Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПлатежаДокументПриИзменении(Элемент)
	ТекСтрока = Элементы.ДокументыПлатежа.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ТекСтрока.Документ) Тогда
		ТекСтрока.Сумма		= 0;
		ТекСтрока.СуммаНДС	= 0;
		ТекСтрока.Договор	= Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьАвансы(Команда)
	СтруктураАдреса = ПолучитьАдресТаблицыОстатков();
	Результат = ОткрытьФормуМодально("Документ.СчетФактураОтправленныйГрузия.Форма.ФормаОстаткиАвансов", СтруктураАдреса);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьВыделенныеСтроки(Результат.АдресТаблицы);
	Модифицированность = Истина;
КонецПроцедуры

Процедура ЗаполнитьВыделенныеСтроки(АдресТаблицы)
	ВыделенныеСтроки = ПолучитьИзВременногоХранилища(АдресТаблицы);
	Для Каждого СтрокаТЧ ИЗ ВыделенныеСтроки Цикл
		НовСтрока = Объект.ДокументыПлатежа.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьАдресТаблицыОстатков()
	ТаблицаАвансов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьТаблицуАвансов(Объект.Ссылка, "СчетФактураОтправленныйГрузия", Объект.ДатаВходящегоДокумента, Объект.Организация, Объект.Контрагент, Объект.ДокументыПлатежа);
	Возврат Новый Структура("АдресТаблицы", ПоместитьВоВременноеХранилище(ТаблицаАвансов));
КонецФункции

&НаКлиенте
Процедура ДокументыПлатежаСуммаПриИзменении(Элемент)
	ТекДанные = Элементы.ДокументыПлатежа.ТекущиеДанные;
	ТекДанные.СуммаНДС = Окр(ТекДанные.Сумма * 18/118, 2);
КонецПроцедуры

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	
	КонтрагентПередИзменением = Контрагент;
	Контрагент = Объект.Контрагент;
	
	Если КонтрагентПередИзменением <> Объект.Контрагент Тогда
		Если Объект.ДокументыПлатежа.Количество() > 0 Тогда
			ПараметрыДокумента = Новый Структура;
			ПараметрыДокумента.Вставить("КонтрагентПередИзменением", КонтрагентПередИзменением);
			ОписаниеОповещения = Новый ОписаниеОповещения("ВопросОбОчисткеДокументовПлатежаЗавершение", ЭтотОбъект, ПараметрыДокумента);
			ТекстВопроса = НСтр("ka='გადახდის დოკუმენტები გაიწმინდება, გავაგრძელოთ?';ru='Документы платежа будет очищен, продолжить?'");
			
			ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросОбОчисткеДокументовПлатежаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Объект.ДокументыПлатежа.Очистить();
	Иначе
		Объект.Контрагент	= ДополнительныеПараметры.КонтрагентПередИзменением;
		Контрагент			= ДополнительныеПараметры.КонтрагентПередИзменением;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	РС_ОбщегоНазначенияКлиент.ПроверкаМодифицированостиВопрос(Объект.Ссылка, Модифицированность, Отказ);//Паганини
КонецПроцедуры

