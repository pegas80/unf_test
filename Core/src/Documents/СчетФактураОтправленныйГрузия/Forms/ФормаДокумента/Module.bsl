// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ЗаполнитьИзДокументов(Команда)
	
	ЗаполнитьИзДокументовСервер();
	//Паганини#OneSoft_
	Если Объект.Корректировочная Тогда
		Объект.Запасы.Очистить();
		ЗаполнитьИзКорректировкиРеализации();
		ЗаполнитьИзПриходнаяНакладная();
	КонецЕсли;
	Модифицированность = Истина;
	//_Паганини#OneSoft   
	
	ЗаполнитьIDНоменклатур();
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыОснованияДокументОснованиеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	Если Объект.ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", ВыбранноеЗначение)).Количество() > 1 Тогда
		Сообщить(НСтр("ka = 'ზედნადები უკვე შეყვანილია ანგარიშ-ფაქტურაში'; ru = 'ზედნადები უკვე შეყვანილია ანგარიშ-ფაქტურაში'; "));
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыОснованияДокументОснованиеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДокументыОснования.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ДокументОснование) Тогда
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, ПолучитьИтоги(ТекущиеДанные.ДокументОснование));	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаВходящегоДокументаПриИзменении(Элемент)
	
	ПриИзмененииПериодаРегистрации(ЭтаФорма, "ДатаВходящегоДокумента", "ОтображениеПериода");
	Если НЕ Элемент = Неопределено Тогда
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаВходящегоДокументаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметров = Новый Структура("ДатаКалендаря", ?(ЭтаФорма.Объект.ДатаВходящегоДокумента = Дата('00010101'), ТекущаяДата(), ЭтаФорма.Объект.ДатаВходящегоДокумента));
	ДатаКалендаряНачало = ОткрытьФормуМодально("ОбщаяФорма.ФормаКалендаря", СтруктураПараметров);
	
	Если ДатаКалендаряНачало = Неопределено Тогда
		Объект.ДатаВходящегоДокумента = КонецДня(Объект.ДатаВходящегоДокумента);
	Иначе
		Объект.ДатаВходящегоДокумента = КонецДня(ДатаКалендаряНачало);
	КонецЕсли;
	
	ДатаВходящегоДокументаПриИзменении(Элемент);
	Модифицированность = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ДатаВходящегоДокументаРегулирование(Элемент, Направление, СтандартнаяОбработка)
	
	ПриРегулированииПериодаРегистрации(ЭтаФорма, Направление, "ДатаВходящегоДокумента");
	ДатаВходящегоДокументаПриИзменении(Элемент);
	Модифицированность = Истина;
	
КонецПроцедуры





