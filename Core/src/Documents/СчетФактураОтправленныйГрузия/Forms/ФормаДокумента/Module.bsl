&НаСервере
Процедура ЗаполнитьИзКорректировкиРеализации(ВыбранныеДокументы = Неопределено)

	Если ВыбранныеДокументы = Неопределено Тогда
		ВыбранныеДокументы = Новый Массив;
		Для Каждого СтрокаТЧ Из Объект.ДокументыОснования Цикл
			Если ТипЗнч(СтрокаТЧ.ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
				ВыбранныеДокументы.Добавить(СтрокаТЧ.ДокументОснование);
			КонецЕсли;
		КонецЦикла;
		Если ВыбранныеДокументы.Количество() = 0 Тогда
			Возврат;
		КонецЕсли;
	Иначе
		Для Каждого Док ИЗ ВыбранныеДокументы Цикл
			Если Объект.ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", Док)).Количество() = 0 Тогда
				НовСтрока = Объект.ДокументыОснования.Добавить();
				НовСтрока.ДокументОснование = Док;
				ЗаполнитьЗначенияСвойств(НовСтрока, ПолучитьИтоги(НовСтрока.ДокументОснование));
			Иначе
				Сообщить(Строка(Док) + " უკვე შეყვანილია ანგარიშ-ფაქტურაში");
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.ЗаполнитьИзКорректировкиРеализации(ВыбранныеДокументы);
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");

