&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	УстановитьСчетНДСИзУчетнойПолитики();
КонецПроцедуры

&НаСервере
Процедура УстановитьСчетНДСИзУчетнойПолитики()

	Если ЗначениеЗаполнено(Объект.Организация) Тогда
	
		ТекДата = ?(ЗначениеЗаполнено(Объект.Дата),Объект.Дата,ТекущаяДата());
		ТекУчетнаяПолитика = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(ТекДата, Новый Структура("Организация", Объект.Организация));
		
		Если НЕ ЗначениеЗаполнено(Объект.ВидНалога) Тогда
		
			Объект.ВидНалога = ТекУчетнаяПолитика.ВидНадогаДляСчетовНДС;
		
		КонецЕсли;
		
		УстановитьСчетУчетаРеглИзВидаНалога();
	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура УстановитьСчетУчетаРеглИзВидаНалога()

	Если ЗначениеЗаполнено(Объект.ВидНалога) Тогда
	
		//Если  НЕ ЗначениеЗаполнено(Объект.СчетУчетаРегл)  Тогда
		
			Объект.СчетУчетаРегл = Объект.ВидНалога.СчетУчетаРегл;
		
		//КонецЕсли;
	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВидНалогаПриИзменении(Элемент)
	
	УстановитьСчетУчетаРеглИзВидаНалога();
	
КонецПроцедуры
