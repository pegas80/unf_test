

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	// СтандартныеПодсистемы.Печать
	УправлениеПечатью.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюПечать);
	// Конец СтандартныеПодсистемы.Печать
	УправлениеНебольшойФирмойСервер.УстановитьОтображаниеПодменюПечати(Элементы.ПодменюПечать);
	
	Если Объект.Ссылка.Пустая() Тогда
	//Paganini_ONESOFT-2337_
	Если ЗначениеЗаполнено(Параметры.Основание) И
		(ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.ПоступлениеВКассу") ИЛИ
		 ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.ПоступлениеНаСчет") ИЛИ
		 //++ONESOFT-4426
		 ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.РасходСоСчета")) Тогда   
		 //++ONESOFT-4426
		Объект.ВидНалога = НЕОПРЕДЕЛЕНО;
		Объект.СчетУчетаРегл = НЕОПРЕДЕЛЕНО;
		УстановитьАналитикуНалогаИзУчетнойПолитики();
	Иначе
	//_Paganini_ONESOFT-2337	
		Объект.Идентификатор			= 0;
		Объект.НомерСчетФактуры 		= "";
		Объект.Серия                    = "";
		Объект.НомерВходящегоДокумента 	= "";
		Объект.Статус					= Неопределено;
		Объект.ПериодРегистрации		= Дата(1,1,1);
		Для Каждого СтрокаТЧ ИЗ Объект.Запасы Цикл
			СтрокаТЧ.ID = 0;
		КонецЦикла;
		Объект.ДокументыПлатежа.Очистить();
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		Объект.ВидНалога = НЕОПРЕДЕЛЕНО;
		Объект.СчетУчетаРегл = НЕОПРЕДЕЛЕНО;
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		УстановитьАналитикуНалогаИзУчетнойПолитики(); //++lyskov 20.02.2023
	//Paganini_ONESOFT-2337_
	КонецЕсли;
	//_Paganini_ONESOFT-2337
	КонецЕсли;
	Контрагент = Объект.Контрагент;
	УстановитьВидимость();
	ОбщегоНазначенияПереопределяемый.УстановитьДополнительноеПоведениеСтандартныхКнопокТЧЗапасы(ЭтаФорма);// Kuzmich, 07.08.2019, Дополнительные инструменты в табличных частях документов движения товаров
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ДатаВходящегоДокументаПриИзменении(Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ПерепрочитатьФорму" Тогда
		Прочитать();      
	ИначеЕсли ИмяСобытия = "ЗаполнитьIDНоменклатур" Тогда	
		ЗаполнитьТзIDНоменклатур(); 	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте 
Процедура Подключаемый_ВыполнитьКомандуПечати(Команда)
	
	УправлениеПечатьюКлиент.ВыполнитьПодключаемуюКомандуПечати(Команда, ЭтаФорма, Объект)
	
КонецПроцедуры


