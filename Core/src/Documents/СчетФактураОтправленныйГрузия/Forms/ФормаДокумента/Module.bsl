&НаСервере
Процедура ПересчитатьСуммы(Идентификатор, ИмяКолонки)
	
	СтрокаТЧ = Объект.Запасы.НайтиПоИдентификатору(Идентификатор);
	СтавкаНДС = СтрокаТЧ.СтавкаНДС.Ставка;
	
	Если ИмяКолонки = "Количество_Цена" Тогда
		СтрокаТЧ.Всего		= СтрокаТЧ.Цена			* СтрокаТЧ.Количество;
		СтрокаТЧ.СуммаНДС	= Окр(СтрокаТЧ.Всего	* СтавкаНДС/(100+СтавкаНДС), 2);
		СтрокаТЧ.Сумма 		= СтрокаТЧ.Всего - СтрокаТЧ.СуммаНДС;
	ИначеЕсли ИмяКолонки = "Сумма_СтавкаНДС" Тогда
		СтрокаТЧ.СуммаНДС	= Окр(СтрокаТЧ.Сумма	* СтавкаНДС/100, 2);
		СтрокаТЧ.Всего		= СтрокаТЧ.СуммаНДС + СтрокаТЧ.Сумма;
	ИначеЕсли ИмяКолонки = "СуммаНДС" Тогда
		СтрокаТЧ.Сумма		= СтрокаТЧ.Всего	- СтрокаТЧ.СуммаНДС;
	КонецЕсли;

КонецПроцедуры




