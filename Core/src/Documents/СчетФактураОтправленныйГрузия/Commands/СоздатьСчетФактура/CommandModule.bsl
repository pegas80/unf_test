
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Структура = Новый Структура;
	Структура.Вставить("Основание", ПараметрКоманды);
	Форма = ПолучитьФорму("Документ.СчетФактураОтправленныйГрузия.Форма.ФормаДокумента", Структура); 
	Форма.Открыть();	
	
КонецПроцедуры
