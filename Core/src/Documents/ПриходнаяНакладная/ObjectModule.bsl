	Запрос.УстановитьПараметр("Ссылка",?(ТипЗнЧ(ДокументОснование) = ПредопределенноеЗначение("Документ.ЧекККМ"),
	ДокументОснование.КассоваяСмена ,ДокументОснование));

	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
