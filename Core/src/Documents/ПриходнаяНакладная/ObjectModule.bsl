	НаборЗаписейЗапасы = РегистрыНакопления.Запасы.СоздатьНаборЗаписей();	
	НаборЗаписейЗапасы.Отбор.Регистратор.Установить(Ссылка);
	НаборЗаписейЗапасы.Прочитать();

	// Создадим набор записей регистра накопления Продажи.
	НаборЗаписейПродажи = РегистрыНакопления.Продажи.СоздатьНаборЗаписей();
	НаборЗаписейПродажи.Отбор.Регистратор.Установить(Ссылка);
	НаборЗаписейПродажи.Прочитать();
		
	// Создадим набор записей регистра накопления УчетДоходовИРасходов.
	НаборЗаписейДоходыИРасходы = РегистрыНакопления.ДоходыИРасходы.СоздатьНаборЗаписей();
	НаборЗаписейДоходыИРасходы.Отбор.Регистратор.Установить(Ссылка);
	НаборЗаписейДоходыИРасходы.Прочитать();
	
	// Создадим набор записей регистра накопления СебестоимостьЗакупки.
	НаборЗаписейСебестоимостьЗакупки = РегистрыНакопления.СебестоимостьЗакупки.СоздатьНаборЗаписей();
	НаборЗаписейСебестоимостьЗакупки.Отбор.Регистратор.Установить(Ссылка);
	НаборЗаписейСебестоимостьЗакупки.Прочитать();	
	
	//// Создадим набор записей регистра накопления Управленческий.
	//НаборЗаписейУправленческий = РегистрыБухгалтерии.Управленческий.СоздатьНаборЗаписей();
	//НаборЗаписейУправленческий.Отбор.Регистратор.Установить(Ссылка);
	//НаборЗаписейУправленческий.Прочитать();

	// Создадим набор записей регистра накопления Хозрасчетный.
	//НаборЗаписейХозрасчетный = РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
	//НаборЗаписейХозрасчетный.Отбор.Регистратор.Установить(Ссылка);
	//НаборЗаписейХозрасчетный.Прочитать();
	НаборЗаписейХозрасчетный1 = РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
	НаборЗаписейХозрасчетный1.Отбор.Регистратор.Установить(Ссылка);	
	НаборЗаписейХозрасчетный1.Прочитать();
	
	
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	ИндХозрасчетный = 0 ;
	инд1 = НаборЗаписейХозрасчетный1.количество() ;
	Инд = 0;
	ИндХозрасчетный = НаборЗаписейЗапасы.количество();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СуммаРасходов = 0  ;
		Если ВыборкаДетальныеЗаписи.КоличествоПродаж = 0 Тогда
			СуммаКорректировки = 0;
		Иначе                  
			ЦенаПродажи = ВыборкаДетальныеЗаписи.СуммаПродаж / ВыборкаДетальныеЗаписи.КоличествоПродаж;
			СуммаВозвратов = ЦенаПродажи * ВыборкаДетальныеЗаписи.КоличествоВозвратов;
			СуммаКорректировки = ВыборкаДетальныеЗаписи.СуммаВозвратов - ЦенаПродажи * ВыборкаДетальныеЗаписи.КоличествоВозвратов;
			//Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура ;
			//Характеристика = ВыборкаДетальныеЗаписи.Характеристика;	
			//Партия = ВыборкаДетальныеЗаписи.Партия;
		КонецЕсли;
		
		//Отбор = Новый  Структура ;
		//Отбор.Вставить("Номенклатура" ,Номенклатура);
		//Отбор.Вставить("Характеристика",Характеристика);
		//Отбор.Вставить("Партия", Партия);
		
		//Строки  = Запасы.НайтиСтроки(Отбор) ;	
		//Для Каждого Ст из Строки Цикл 
		//	Ст.Себестоимость = (СуммаКорректировки )*-1;	
		//КонецЦикла;
		
		
		Если (НЕ Окр(СуммаКорректировки, 2) = 0) Тогда
			
			//Запасы
			НаборЗаписейЗапасы[Инд].Сумма =  СуммаКорректировки ;
			НаборЗаписейЗапасы[Инд].ФиксированнаяСтоимость =  Истина ;
			//Продажи
			НаборЗаписейПродажи[Инд].Себестоимость = СуммаКорректировки ;	
			//Доходы и расходы
			НаборЗаписейДоходыИРасходы[0].СуммаРасходов = НаборЗаписейДоходыИРасходы[0].СуммаРасходов+ СуммаКорректировки ;	
			//ебестоимость закупки
			НаборЗаписейСебестоимостьЗакупки[Инд].Сумма =  СуммаКорректировки ; 
			//Хозрасчетный
			//НаборЗаписейХозрасчетный[ИндХозрасчетный].Сумма =  СуммаКорректировки ;
		КонецЕсли;
		Инд =Инд +1; 
		ИндХозрасчетный = ИндХозрасчетный +1 ;
		
		Если ТипЗнЧ(ДокументОснование) = ПредопределенноеЗначение("Документ.ЧекККМ") Тогда 
			
			НоваяСтрока = НаборЗаписейХозрасчетный1.Вставить(инд1);
			НоваяСтрока.Период = Дата;
			НоваяСтрока.Регистратор = Ссылка;
			НоваяСтрока.Организация = ВыборкаДетальныеЗаписи.Организация;
			//НоваяСтрока.СчетДт = ВыборкаДетальныеЗаписи.НаправлениеДеятельностиПродажиСчетУчетаСебестоимостиПродажРегл;
			//НоваяСтрока.СчетКт = ВыборкаДетальныеЗаписи.СчетУчетаРегл;
			НоваяСтрока.СчетДт = ВыборкаДетальныеЗаписи.СчетУчетаРегл;
			НоваяСтрока.СчетКт = ВыборкаДетальныеЗаписи.НаправлениеДеятельностиПродажиСчетУчетаСебестоимостиПродажРегл;
			НоваяСтрока.Содержание = НСтр("ka='ხარჯების ასახვა';ru='Отражение расходов';en='reflection expenditure'");
			//НоваяСтрока.Сумма = СуммаКорректировки;
			НоваяСтрока.Сумма = -СуммаКорректировки;
			НоваяСтрока.КоличествоДт = ВыборкаДетальныеЗаписи.КоличествоВозвратов ;
			
			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, "Номенклатура", ВыборкаДетальныеЗаписи.Номенклатура);
			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, "Подразделения", ВыборкаДетальныеЗаписи.Подразделение);
			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, "Склады", ВыборкаДетальныеЗаписи.СтруктурнаяЕдиница);
			
			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Номенклатура", ВыборкаДетальныеЗаписи.Номенклатура);
			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Подразделения", ВыборкаДетальныеЗаписи.Подразделение);
			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Склады", ВыборкаДетальныеЗаписи.СтруктурнаяЕдиница);
			
			инд1 = инд1+1;
			НаборЗаписейХозрасчетный1.Записать(Истина);

		КонецЕсли;
		
	КонецЦикла;
	
	//Записать(РежимЗаписиДокумента.Проведение);
	
	// Пишем оставшиеся записи Учет запасов и затрат.
	НаборЗаписейЗапасы.Записать(Истина);
	
	// Пишем оставшиеся записи Продажи.
	НаборЗаписейПродажи.Записать(Истина);
	
	// Пишем оставшиеся записи Учет доходов и расходов.
	НаборЗаписейДоходыИРасходы.Записать(Истина);
	
	// Пишем оставшиеся записи Учет Себестоимость закупки 
	НаборЗаписейСебестоимостьЗакупки.Записать(Истина);
	
	
	//////// Пишем оставшиеся записи Управленческий.
	//////Если НЕ ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ТекущаяДата()) Тогда  //+++ Дмгг
