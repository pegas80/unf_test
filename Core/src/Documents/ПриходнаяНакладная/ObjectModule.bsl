	// Конец Заказы покупателей в Рознице
	
	Курс = 1; // Чеки оформляются в валюте регламентированного учёта.
	Кратность = 1; // Чеки оформляются в валюте регламентированного учёта.
	
	// Заполнение табличной части документа.
	Запасы.Очистить();
