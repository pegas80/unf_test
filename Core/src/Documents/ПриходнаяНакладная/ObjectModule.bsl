#Область РаспределениеУслугПоВесуОбъему

Функция РаспределитьТабЧастьРасходыПоВесу() ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Массив();
	
	ИсхСумма = 0;
	ИсхСуммаНДС = 0;
	БазаРаспределенияВес = 0;
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.Номенклатура.Вес) Тогда
			Если СтрокаЗапасы.Номенклатура.Вес>0 Тогда
				БазаРаспределенияВес = БазаРаспределенияВес + СтрокаЗапасы.Количество*СтрокаЗапасы.Номенклатура.Вес;
			Иначе
				Если РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
					РЕЗ.Добавить(СтрокаЗапасы.Номенклатура);
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
				РЕЗ.Добавить(СтрокаЗапасы.Номенклатура);
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла; 
	ВсегоРасходы = Расходы.Итог("СуммаБезНалогов");//Паганини Расходы.Итог("Всего")
	ВсегоНДСРасходы = Расходы.Итог("СуммаНДС");
	//Паганини_
	ИсхСуммаНДФЛ = 0;	
	ВсегоРасходыНДФЛ = Расходы.Итог("СуммаНДФЛ");
	ИсхСуммаПФ = 0;	
	ВсегоРасходыПФ = Расходы.Итог("СуммаПФ");
	//_Паганини
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		СтрокаЗапасы.СуммаРасходов = 0;
		СтрокаЗапасы.СуммаРасходовНДФЛ = 0;
		СтрокаЗапасы.СуммаРасходовПФ = 0;
		
		Если НЕ РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
			Продолжить;
		КонецЕсли;
		
		ТекКоэффицинтВес = СтрокаЗапасы.Количество*СтрокаЗапасы.Номенклатура.Вес;
		
		СтрокаЗапасы.СуммаРасходов = ?(БазаРаспределенияВес <> 0, Окр((ВсегоРасходы - ИсхСумма) * ТекКоэффицинтВес / БазаРаспределенияВес, 2, 1),0);
		СтрокаЗапасы.СуммаРасходовНДФЛ = ?(БазаРаспределенияВес <> 0, Окр((ВсегоРасходыНДФЛ - ИсхСуммаНДФЛ) * ТекКоэффицинтВес / БазаРаспределенияВес, 2, 1),0);//Паганини
		СтрокаЗапасы.СуммаРасходовПФ   = ?(БазаРаспределенияВес <> 0, Окр((ВсегоРасходыПФ   - ИсхСуммаПФ)   * ТекКоэффицинтВес / БазаРаспределенияВес, 2, 1),0);//Паганини ПФ
		БазаРаспределенияВес = БазаРаспределенияВес - ТекКоэффицинтВес;
		ИсхСумма = ИсхСумма + СтрокаЗапасы.СуммаРасходов;
		ИсхСуммаНДФЛ = ИсхСуммаНДФЛ + СтрокаЗапасы.СуммаРасходовНДФЛ;//Паганини
		ИсхСуммаПФ   = ИсхСуммаПФ   + СтрокаЗапасы.СуммаРасходовПФ;//Паганини ПФ
		
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции


Функция РаспределитьТабЧастьРасходыПоОбъему() ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Массив();
	
	ИсхСумма = 0;
	ИсхСуммаНДС = 0;
	БазаРаспределенияОбъем = 0;
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.Номенклатура.Объем) Тогда
			Если СтрокаЗапасы.Номенклатура.Объем>0 Тогда
				БазаРаспределенияОбъем = БазаРаспределенияОбъем + СтрокаЗапасы.Количество*СтрокаЗапасы.Номенклатура.Объем;
			Иначе
				Если РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
					РЕЗ.Добавить(СтрокаЗапасы.Номенклатура);
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
				РЕЗ.Добавить(СтрокаЗапасы.Номенклатура);
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла; 
	ВсегоРасходы = Расходы.Итог("СуммаБезНалогов");//Паганини Расходы.Итог("Всего")
	ВсегоНДСРасходы = Расходы.Итог("СуммаНДС");
	//Паганини_
	ИсхСуммаНДФЛ = 0;	
	ВсегоРасходыНДФЛ = Расходы.Итог("СуммаНДФЛ");
	ИсхСуммаПФ = 0;	
	ВсегоРасходыПФ = Расходы.Итог("СуммаПФ");
	//_Паганини
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		СтрокаЗапасы.СуммаРасходов = 0;
		СтрокаЗапасы.СуммаРасходовНДФЛ = 0;
		СтрокаЗапасы.СуммаРасходовПФ = 0;
		
		Если НЕ РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
			Продолжить;
		КонецЕсли;
		
		ТекКоэффицинтОбъем = СтрокаЗапасы.Количество*СтрокаЗапасы.Номенклатура.Объем;
		
		СтрокаЗапасы.СуммаРасходов = ?(БазаРаспределенияОбъем <> 0, Окр((ВсегоРасходы - ИсхСумма) * ТекКоэффицинтОбъем / БазаРаспределенияОбъем, 2, 1),0);
		СтрокаЗапасы.СуммаРасходовНДФЛ = ?(БазаРаспределенияОбъем <> 0, Окр((ВсегоРасходыНДФЛ - ИсхСуммаНДФЛ) * ТекКоэффицинтОбъем / БазаРаспределенияОбъем, 2, 1),0);//Паганини
		СтрокаЗапасы.СуммаРасходовПФ   = ?(БазаРаспределенияОбъем <> 0, Окр((ВсегоРасходыПФ   - ИсхСуммаПФ)   * ТекКоэффицинтОбъем / БазаРаспределенияОбъем, 2, 1),0);//Паганини ПФ
		БазаРаспределенияОбъем = БазаРаспределенияОбъем - ТекКоэффицинтОбъем;
		ИсхСумма = ИсхСумма + СтрокаЗапасы.СуммаРасходов;
		ИсхСуммаНДФЛ = ИсхСуммаНДФЛ + СтрокаЗапасы.СуммаРасходовНДФЛ;//Паганини
		ИсхСуммаПФ   = ИсхСуммаПФ   + СтрокаЗапасы.СуммаРасходовПФ;//Паганини ПФ
		
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции

