		|		КОГДА СчетНаОплатуЗапасы.Ссылка.Организация.НаименованиеАнглийское = """"
		|			ТОГДА СчетНаОплатуЗапасы.Ссылка.Организация.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Ссылка.Организация.НаименованиеАнглийское
		|	КОНЕЦ КАК Продавец,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(СчетНаОплатуЗапасы.Ссылка.Контрагент.НаименованиеПолное КАК СТРОКА(100))) = """"
		|			ТОГДА СчетНаОплатуЗапасы.Ссылка.Контрагент.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Ссылка.Контрагент.НаименованиеПолное
		|	КОНЕЦ КАК Покупатель,
		|	СчетНаОплатуЗапасы.Ссылка.Договор КАК Договор,
		|	СчетНаОплатуЗапасы.Ссылка.СуммаДокумента КАК Сумма,
		|	СчетНаОплатуЗапасы.Ссылка.ВалютаДокумента КАК Валюта,
		|	СчетНаОплатуЗапасы.НомерСтроки КАК НомерСтроки,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(СчетНаОплатуЗапасы.Номенклатура.НаименованиеПолное КАК СТРОКА(100))) = """"
		|			ТОГДА СчетНаОплатуЗапасы.Номенклатура.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Номенклатура.НаименованиеПолное
		|	КОНЕЦ КАК Номенклатура,
		|	СчетНаОплатуЗапасы.Характеристика КАК Характеристика,
		|	СчетНаОплатуЗапасы.Количество КАК Количество,
		|	СчетНаОплатуЗапасы.Цена КАК Цена,
		|	СчетНаОплатуЗапасы.СуммаНДС КАК СуммаНДС,
		|	СчетНаОплатуЗапасы.Всего КАК Всего,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.НомерСчета КАК БанковскийСчет,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.Код КАК БанкКод,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.НаименованиеАнглиское КАК СТРОКА(100))) = """"
		|			ТОГДА СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.НаименованиеАнглиское
		|	КОНЕЦ КАК Банк,
		|	СчетНаОплатуЗапасы.Ссылка.Контрагент.ИНН КАК ПокупательИНН,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.ИНН КАК ПродавецИНН,
		|	СчетНаОплатуЗапасы.Ссылка.Ответственный.Физлицо КАК Ответственный,
