//Паганини_
Функция НапечататьInvoice(МассивОбъектов, ОбъектыПечати)

	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПараметрыПечати_Invoice";
	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_СчетНаОплату_Invoice";
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетНаОплатуЗапасы.Ссылка КАК Документ,
		|	СчетНаОплатуЗапасы.Ссылка.Дата КАК Дата,
		|	СчетНаОплатуЗапасы.Ссылка.Номер КАК Номер,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(СчетНаОплатуЗапасы.Ссылка.Организация.НаименованиеПолное КАК СТРОКА(100))) = """"
		|			ТОГДА СчетНаОплатуЗапасы.Ссылка.Организация.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Ссылка.Организация.НаименованиеПолное
		|	КОНЕЦ КАК Продавец,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(СчетНаОплатуЗапасы.Ссылка.Контрагент.НаименованиеПолное КАК СТРОКА(100))) = """"
		|			ТОГДА СчетНаОплатуЗапасы.Ссылка.Контрагент.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Ссылка.Контрагент.НаименованиеПолное
		|	КОНЕЦ КАК Покупатель,
		|	СчетНаОплатуЗапасы.Ссылка.Договор КАК Договор,
		|	СчетНаОплатуЗапасы.Ссылка.СуммаДокумента КАК Сумма,
		|	СчетНаОплатуЗапасы.Ссылка.ВалютаДокумента КАК Валюта,
		|	СчетНаОплатуЗапасы.НомерСтроки КАК НомерСтроки,
		|	ВЫБОР
		|		КОГДА (ВЫРАЗИТЬ(СчетНаОплатуЗапасы.Номенклатура.НаименованиеПолное КАК СТРОКА(100))) = """"
		|			ТОГДА СчетНаОплатуЗапасы.Номенклатура.Наименование
		|		ИНАЧЕ СчетНаОплатуЗапасы.Номенклатура.НаименованиеПолное
		|	КОНЕЦ КАК Номенклатура,
		|	СчетНаОплатуЗапасы.Характеристика КАК Характеристика,
		|	СчетНаОплатуЗапасы.Количество КАК Количество,
		|	СчетНаОплатуЗапасы.Цена КАК Цена,
		|	СчетНаОплатуЗапасы.СуммаНДС КАК СуммаНДС,
		|	СчетНаОплатуЗапасы.Всего КАК Всего,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.НомерСчета КАК БанковскийСчет,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.Код КАК БанкКод,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.Наименование КАК Банк,
		|	СчетНаОплатуЗапасы.Ссылка.Контрагент.ИНН КАК ПокупательИНН,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.ИНН КАК ПродавецИНН,
		|	СчетНаОплатуЗапасы.Ссылка.Ответственный.Физлицо КАК Ответственный,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.ФайлЛоготип КАК ФайлЛоготип,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.ФайлФаксимильнаяПечать КАК ФайлФаксимильнаяПечать,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.ФайлПечати КАК ФайлПечати,
		|	СчетНаОплатуЗапасы.Ссылка.Организация.ПодписьРуководителя.ФизическоеЛицо КАК Руководитель
		|ИЗ
		|	Документ.СчетНаОплату.Запасы КАК СчетНаОплатуЗапасы
		|ГДЕ
		|	СчетНаОплатуЗапасы.Ссылка В(&МассивОбъектов)
		|ИТОГИ
		|	МАКСИМУМ(Продавец),
		|	МАКСИМУМ(Покупатель),
		|	КОЛИЧЕСТВО(НомерСтроки),
		|	СУММА(СуммаНДС),
		|	СУММА(Всего),
		|	МАКСИМУМ(БанковскийСчет)
		|ПО
		|	Документ";
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ВыборкаДокумент = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ПервыйДокумент = Истина;
	
	Пока ВыборкаДокумент.Следующий() Цикл
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало	= ТабличныйДокумент.ВысотаТаблицы + 1;
		МакетПечатнойФормы	= УправлениеПечатью.МакетПечатнойФормы("Документ.СчетНаОплату.ПФ_MXL_Invoice");//ПолучитьМакет("ПФ_MXL_Invoice");
		
		// Вывод шапки для документа
		ОбластьШапки = МакетПечатнойФормы.ПолучитьОбласть("Шапка");
		ОбластьШапки.Параметры.Заполнить(ВыборкаДокумент);
		Попытка
			ОбластьШапки.Параметры.Дата	= Формат(ВыборкаДокумент.Дата , "ДФ=dd.MM.yyyy");
		Исключение
		КонецПопытки;
		
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлЛоготип) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлЛоготип);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьШапки.Рисунки.Лого.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьШапки);
				
		// Вывод таблицной части
		ВыборкаДанныхДокумента = ВыборкаДокумент.Выбрать();
		ОбластьСтрока = МакетПечатнойФормы.ПолучитьОбласть("ТабличаяЧасть");
		Пока ВыборкаДанныхДокумента.Следующий() Цикл 
			ОбластьСтрока.Параметры.Заполнить(ВыборкаДанныхДокумента);
			ТабличныйДокумент.Вывести(ОбластьСтрока);
		КонецЦикла;
		
		// Вывод подвала для документа
		ОбластьПодвал = МакетПечатнойФормы.ПолучитьОбласть("Подвал");
		ОбластьПодвал.Параметры.Заполнить(ВыборкаДокумент);
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлФаксимильнаяПечать) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлФаксимильнаяПечать);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьПодвал.Рисунки.Факсимилия.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлПечати) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлПечати);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьПодвал.Рисунки.Печать.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаДокумент.Руководитель) Тогда
			Попытка
				ОбластьПодвал.Параметры.Руководитель = РС_ОбщегоНазначения.ПолучитьФИОФизЛиц(ВыборкаДокумент.Руководитель, ВыборкаДокумент.Дата);
			Исключение
			КонецПопытки;
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
