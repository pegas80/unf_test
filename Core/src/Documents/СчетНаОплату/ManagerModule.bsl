		|	МАКСИМУМ(Покупатель),
		|	КОЛИЧЕСТВО(НомерСтроки),
		|	СУММА(СуммаНДС),
		|	СУММА(Всего),
		|	МАКСИМУМ(БанковскийСчет)
		|ПО
		|	Документ";
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
