  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ЭлектроннаяПочтаКонтактногоЛица</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.ЭлектроннаяПочтаКонтрагента</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.КонтактноеЛицо</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Список.Контрагент</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ВЫБОР
		КОГДА ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) = 0
			ТОГДА ВЫБОР
					КОГДА ДокументСчетНаОплату.ЗапланироватьОплату
							И НЕ ГрафикОплаты.СчетНаОплату ЕСТЬ NULL 
						ТОГДА ВЫБОР
								КОГДА ГрафикОплаты.Период &lt; &amp;АкутальнаяДатаСеанса
									ТОГДА 6
								КОГДА ГрафикОплаты.Период = &amp;АкутальнаяДатаСеанса
									ТОГДА 4
								ИНАЧЕ 2
							КОНЕЦ
					ИНАЧЕ 2
				КОНЕЦ
		КОГДА ЕСТЬNULL(ФактОплаты.Сумма, 0) &lt;= ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0)
			ТОГДА 0
		ИНАЧЕ ВЫБОР
				КОГДА ДокументСчетНаОплату.ЗапланироватьОплату
						И НЕ ГрафикОплаты.СчетНаОплату ЕСТЬ NULL 
					ТОГДА ВЫБОР
							КОГДА ГрафикОплаты.Период &lt; &amp;АкутальнаяДатаСеанса
								ТОГДА 5
							КОГДА ГрафикОплаты.Период = &amp;АкутальнаяДатаСеанса
								ТОГДА 3
							ИНАЧЕ 1
						КОНЕЦ
				ИНАЧЕ 1
			КОНЕЦ
	КОНЕЦ КАК НомерКартинкиОплаты,
	ДокументСчетНаОплату.Ссылка,
	ДокументСчетНаОплату.ПометкаУдаления,
	ДокументСчетНаОплату.Номер,
	ДокументСчетНаОплату.Дата,
	ДокументСчетНаОплату.Проведен,
	ДокументСчетНаОплату.Организация,
	ДокументСчетНаОплату.Комментарий,
	ДокументСчетНаОплату.ДокументОснование,
	ДокументСчетНаОплату.Контрагент,
	ДокументСчетНаОплату.Контрагент.КонтактноеЛицо КАК КонтактноеЛицо,
	ДокументСчетНаОплату.Договор,
	ДокументСчетНаОплату.ТипДенежныхСредств,
	ДокументСчетНаОплату.БанковскийСчет,
	ДокументСчетНаОплату.ВалютаДокумента,
	ДокументСчетНаОплату.Кратность,
	ДокументСчетНаОплату.Курс,
	ДокументСчетНаОплату.СуммаВключаетНДС,
	ДокументСчетНаОплату.ВидЦен,
	ДокументСчетНаОплату.ВидСкидкиНаценки,
	ДокументСчетНаОплату.Подразделение,
	ДокументСчетНаОплату.СуммаДокумента,
	ДокументСчетНаОплату.Касса,
	ДокументСчетНаОплату.Ответственный,
	ДокументСчетНаОплату.МоментВремени,
	ДокументСчетНаОплату.Автор,
	ДокументСчетНаОплату.ЗапретРедактированияДокументов,
	ВЫБОР
		КОГДА ДокументСчетНаОплату.Проведен
				И ДокументСчетНаОплату.СуммаДокумента > 0
			ТОГДА ВЫРАЗИТЬ((ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0)) * 100 / ДокументСчетНаОплату.СуммаДокумента КАК ЧИСЛО(15, 2))
		ИНАЧЕ 0
	КОНЕЦ КАК ПроцентОплаты,
	ВЫБОР
		КОГДА ДокументСчетНаОплату.Проведен
				И ДокументСчетНаОплату.СуммаДокумента > 0
			ТОГДА ВЫБОР
					КОГДА ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) - ДокументСчетНаОплату.СуммаДокумента >= 0
						ТОГДА &quot;Оплачен полностью&quot;
					КОГДА ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) > 0
						ТОГДА &quot;Оплачен частично&quot;
					ИНАЧЕ &quot;Без оплаты&quot;
				КОНЕЦ
		ИНАЧЕ &quot;Без оплаты&quot;
	КОНЕЦ КАК СтатусОплаты,
	ЕСТЬNULL(ФактОплаты.СуммаОплаты, 0) + ЕСТЬNULL(ФактОплаты.СуммаАванса, 0) КАК СуммаОплатыОборот,
	СостоянияЭД.СостояниеВерсииЭД
ИЗ
	Документ.СчетНаОплату КАК ДокументСчетНаОплату
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФактОплатыЗаказов КАК ФактОплаты
		ПО ДокументСчетНаОплату.Ссылка = ФактОплаты.СчетНаОплату
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикОплатыЗаказов КАК ГрафикОплаты
		ПО ДокументСчетНаОплату.Ссылка = ГрафикОплаты.СчетНаОплату
			И (ГрафикОплаты.Период &lt;= &amp;АкутальнаяДатаСеанса)}
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияЭД КАК СостоянияЭД
		ПО ДокументСчетНаОплату.Ссылка = СостоянияЭД.СсылкаНаОбъект</queryText>
      <mainTable>Document.СчетНаОплату</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
