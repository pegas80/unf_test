
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства) Экспорт

	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаКомплектацияВА);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ВалютаУчета", УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета());
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	КомплектацияВА.Ссылка,
	|	КомплектацияВА.ВерсияДанных,
	|	КомплектацияВА.ПометкаУдаления,
	|	КомплектацияВА.Номер,
	|	КомплектацияВА.Дата,
	|	КомплектацияВА.Проведен,
	|	КомплектацияВА.Организация,
	|	КомплектацияВА.ВидОперации,
	|	КомплектацияВА.СчетСписанияВА,
	|	КомплектацияВА.Имущество КАК ВнеоборотныйАктив,
	|	КомплектацияВА.СтруктурнаяЕдиница,
	|	ВЫРАЗИТЬ(КомплектацияВА.Адрес КАК СТРОКА(250)) КАК Адрес,
	|	КомплектацияВА.ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	КомплектацияВА.ПервоначальнаяСтоимость,
	|	КомплектацияВА.НачислятьАмортизациюВТекущемМесяце,
	|	КомплектацияВА.СрокИспользованияДляВычисленияАмортизации,
	|	ВЫБОР
	|		КОГДА КомплектацияВА.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКомплектацииВА.Комплектация)
	|			ТОГДА КомплектацияВА.СчетЗатрат.СчетАналогУУ
	|		ИНАЧЕ ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатратРегл.СчетАналогУУ
	|	КОНЕЦ КАК СчетЗатрат,
	|	ВЫБОР
	|		КОГДА КомплектацияВА.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКомплектацииВА.Комплектация)
	|			ТОГДА КомплектацияВА.СчетЗатрат
	|		ИНАЧЕ ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатратРегл
	|	КОНЕЦ КАК СчетЗатратРегл,
	|	КомплектацияВА.НаправлениеДеятельности,
	|	КомплектацияВА.СтоимостьДляВычисленияАмортизации,
	|	КомплектацияВА.Автор,
	|	&ВалютаУчета КАК Валюта,
	|	КомплектацияВА.Ответственный,
	|	КомплектацияВА.Комментарий,
	|	КомплектацияВА.НачислятьАмортизацию,
	|	КомплектацияВА.ЗапретРедактированияДокументов,
	|	КомплектацияВА.НеСписывать,
	|	КомплектацияВА.Стоимость,
	|	КомплектацияВА.ОстаточнаяСтоимость,
	|	КомплектацияВА.Амортизация,
	|	КомплектацияВА.АмортизацияЗаМесяц,
	|	КомплектацияВА.ДоляСтоимости,
	|	КомплектацияВА.СтоимостьПослеПроведения,
	|	КомплектацияВА.АмортизацияПослеПроведения,
	|	КомплектацияВА.АмортизацияЗаМесяцПослеПровледения
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|	Документ.КомплектацияВА КАК КомплектацияВА
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних(&МоментВремени, ) КАК ПараметрыВнеоборотныхАктивовСрезПоследних
	|		ПО КомплектацияВА.Имущество = ПараметрыВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
	|			И КомплектацияВА.Организация = ПараметрыВнеоборотныхАктивовСрезПоследних.Организация
	|ГДЕ
	|	КомплектацияВА.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КомплектацияВАКомплектующиеВА.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	КомплектацияВАКомплектующиеВА.Ссылка КАК Ссылка,
	|	КомплектацияВАКомплектующиеВА.НомерСтроки КАК НомерСтроки,
	|	КомплектацияВАКомплектующиеВА.Ссылка.Дата КАК Дата,
	|	КомплектацияВАКомплектующиеВА.Ссылка.Организация КАК ОРганизация,
	|	КомплектацияВАКомплектующиеВА.Ссылка.ВидОперации КАК ВидОперации,
	|	КомплектацияВАКомплектующиеВА.Ссылка.СчетЗатрат КАК СчетЗатрат,
	|	КомплектацияВАКомплектующиеВА.Ссылка.СчетСписанияВА КАК СчетСписанияВА,
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	&ВалютаУчета КАК Валюта,
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.НаправлениеДеятельности,
	|	СУММА(КомплектацияВАКомплектующиеВА.Стоимость) КАК ТекСтоимость,
	|	СУММА(КомплектацияВАКомплектующиеВА.Амортизация) КАК НакопленнаяАмортизация,
	|	СУММА(КомплектацияВАКомплектующиеВА.ОстаточнаяСтоимость) КАК ОстаточнаяСтоимость,
	|	СУММА(КомплектацияВАКомплектующиеВА.АмортизацияЗаМесяц) КАК АмортизацияЗаМесяц
	|ПОМЕСТИТЬ ВременнаяТаблицаКомплектующиеОС
	|ИЗ
	|	Документ.КомплектацияВА.КомплектующиеВА КАК КомплектацияВАКомплектующиеВА
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних(&МоментВремени, Регистратор <> &Ссылка) КАК ПараметрыВнеоборотныхАктивовСрезПоследних
	|		ПО КомплектацияВАКомплектующиеВА.ВнеоборотныйАктив = ПараметрыВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
	|			И КомплектацияВАКомплектующиеВА.Ссылка.Организация = ПараметрыВнеоборотныхАктивовСрезПоследних.Организация
	|ГДЕ
	|	КомплектацияВАКомплектующиеВА.Ссылка = &Ссылка
	|	И КомплектацияВАКомплектующиеВА.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКомплектацииВА.Комплектация)
	|
	|СГРУППИРОВАТЬ ПО
	|	КомплектацияВАКомплектующиеВА.ВнеоборотныйАктив,
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.СтруктурнаяЕдиница,
	|	КомплектацияВАКомплектующиеВА.Ссылка,
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.НаправлениеДеятельности,
	|	КомплектацияВАКомплектующиеВА.НомерСтроки,
	|	КомплектацияВАКомплектующиеВА.Ссылка.Дата,
	|	КомплектацияВАКомплектующиеВА.Ссылка.Организация,
	|	КомплектацияВАКомплектующиеВА.Ссылка.ВидОперации,
	|	КомплектацияВАКомплектующиеВА.Ссылка.СчетЗатрат,
	|	КомплектацияВАКомплектующиеВА.Ссылка.СчетСписанияВА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КомплектацияВАДекомплектующиеВА.ВнеоборотныйАктив,
	|	&ВалютаУчета КАК Валюта,
	|	КомплектацияВАДекомплектующиеВА.Ссылка,
	|	КомплектацияВАДекомплектующиеВА.НомерСтроки,
	|	КомплектацияВАДекомплектующиеВА.Ссылка.Организация,
	|	КомплектацияВАДекомплектующиеВА.Ссылка.Дата,
	|	КомплектацияВАДекомплектующиеВА.Ссылка.СчетСписанияВА,
	|	КомплектацияВАДекомплектующиеВА.СтруктурнаяЕдиница,
	|	КомплектацияВАДекомплектующиеВА.ДоляСтоимости,
	|	КомплектацияВАДекомплектующиеВА.СостояниеВА,
	|	КомплектацияВАДекомплектующиеВА.СрокИспользованияДляВычисленияАмортизации,
	|	КомплектацияВАДекомплектующиеВА.ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	КомплектацияВАДекомплектующиеВА.Выработка,
	|	КомплектацияВАДекомплектующиеВА.ПервоначальнаяСтоимость,
	|	КомплектацияВАДекомплектующиеВА.НачислятьАмортизацию,
	|	КомплектацияВАДекомплектующиеВА.Амортизация,
	|	КомплектацияВАДекомплектующиеВА.НачислятьАмортизациюВТекущемМесяце,
	|	КомплектацияВАДекомплектующиеВА.СчетЗатрат КАК СчетЗатрат,
	|	КомплектацияВАДекомплектующиеВА.СчетЗатратРегл КАК СчетЗатратРегл,
	|	КомплектацияВАДекомплектующиеВА.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ВЫРАЗИТЬ(КомплектацияВАДекомплектующиеВА.Адрес КАК СТРОКА(250)) КАК Адрес,
	|	КомплектацияВАДекомплектующиеВА.Ссылка.ВидОперации КАК ВидОперации,
	|	КомплектацияВАДекомплектующиеВА.Ссылка.Имущество КАК СписуемоеВА,
	|	КомплектацияВАДекомплектующиеВА.Ссылка.СтруктурнаяЕдиница КАК СписуемаяСтруктурнаяЕдиница,
	|	КомплектацияВАДекомплектующиеВА.АмортизацияЗаМесяц
	|ПОМЕСТИТЬ ВременнаяТаблицаДеукомплектация
	|ИЗ
	|	Документ.КомплектацияВА.ДекомплектующиеВА КАК КомплектацияВАДекомплектующиеВА
	|ГДЕ
	|	КомплектацияВАДекомплектующиеВА.Ссылка = &Ссылка
	|	И КомплектацияВАДекомплектующиеВА.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКомплектацииВА.Разукомплектация)";
	
	Запрос.ВыполнитьПакет();
	
	// Формирование таблиц движений по разделам учета.
	СформироватьТаблицаЗапасы(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства);
	СформироватьПараметрыВнеоборотныхАктивов(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства);
	СформироватьТаблицаВнеоборотныеАктивы(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства);
	СформироватьСостоянияВнеоборотныхАктивов(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_КомплектацияВА(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства);	

КонецПроцедуры

Процедура СформироватьТаблицаЗапасы(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.Дата КАК Период,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаДокумента.СчетЗатрат.СчетАналогУУ КАК СчетУчета,
	|	ТаблицаДокумента.СчетЗатрат КАК СчетУчетаРегл,
	|	NULL КАК Номенклатура,
	|	NULL КАК Характеристика,
	|	ИСТИНА КАК ФиксированнаяСтоимость,
	|	ЛОЖЬ КАК ЗатратыНаВыпуск,
	|	ЛОЖЬ КАК Возврат,
	|	ЛОЖЬ КАК ПеремещениеВРозницуСуммовойУчет,
	|	&ОприходованиеЗапасов КАК СодержаниеПроводки,
	|	ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СписаниеВА) КАК ХозяйственнаяОперация,
	|	0 КАК Количество,
	|	СУММА(ТаблицаДокумента.НакопленнаяАмортизация) КАК Сумма
	|ИЗ
	|	ВременнаяТаблицаКомплектующиеОС КАК ТаблицаДокумента
	|ГДЕ
	|	ТаблицаДокумента.НакопленнаяАмортизация > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДокумента.НомерСтроки,
	|	ТаблицаДокумента.СчетЗатрат,
	|	ТаблицаДокумента.Дата,
	|	ТаблицаДокумента.СчетЗатрат.СчетАналогУУ,
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.СтруктурнаяЕдиница
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	1,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаДокумента.Дата,
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.СтруктурнаяЕдиница,
	|	ТаблицаДокумента.СчетЗатрат,
	|	ТаблицаДокумента.СчетЗатратРегл,
	|	NULL,
	|	NULL,
	|	ИСТИНА,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	&ОприходованиеЗапасов,
	|	ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СписаниеВА),
	|	0,
	|	СУММА((ТаблицаДокумента.АмортизацияПослеПроведения - ТаблицаДокумента.АмортизацияЗаМесяц - ТаблицаДокумента.Амортизация) * (-1))
	|ИЗ
	|	ВременнаяТаблицаШапка КАК ТаблицаДокумента
	|ГДЕ
	|	ТаблицаДокумента.АмортизацияПослеПроведения - ТаблицаДокумента.АмортизацияЗаМесяц - ТаблицаДокумента.Амортизация <> 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДокумента.НомерСтроки,
	|	ТаблицаДокумента.СчетЗатрат,
	|	ТаблицаДокумента.Дата,
	|	ТаблицаДокумента.СчетЗатратРегл,
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.СтруктурнаяЕдиница";
	
	Запрос.УстановитьПараметр("ОприходованиеЗапасов", НСтр("ka='ამორტიზაციის საფასური';ru='Начисление амортизации';en='depreciation is calculated'"));
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасы", РезультатЗапроса.Выгрузить());	

КонецПроцедуры

Процедура СформироватьПараметрыВнеоборотныхАктивов(ДокументСсылкаКомплектацияВА, СтруктураДополнительныеСвойства)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	ТаблицаДокумента.Дата КАК Период,
	|	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ТаблицаДокумента.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.ОбъемПродукцииРаботДляВычисленияАмортизации КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	СУММА(ТаблицаСумм.ТекСтоимость) КАК СтоимостьДляВычисленияАмортизации,
	|	ТаблицаДокумента.НачислятьАмортизациюВТекущемМесяце КАК ПрименитьВТекущемМесяце,
	|	ТаблицаДокумента.СрокИспользованияДляВычисленияАмортизации КАК СрокИспользованияДляВычисленияАмортизации,
	|	ТаблицаДокумента.СчетЗатрат КАК СчетЗатрат,
	|	ТаблицаДокумента.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ТаблицаДокумента.Адрес КАК Адрес,
	|	ТаблицаДокумента.СчетЗатратРегл КАК СчетЗатратРегл
	|ИЗ
	|	ВременнаяТаблицаШапка КАК ТаблицаДокумента,
