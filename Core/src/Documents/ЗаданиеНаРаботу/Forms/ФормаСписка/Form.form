    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументЗаданиеНаРаботу.Ссылка,
	ДокументЗаданиеНаРаботу.ВерсияДанных,
	ДокументЗаданиеНаРаботу.ПометкаУдаления,
	ДокументЗаданиеНаРаботу.Номер,
	ДокументЗаданиеНаРаботу.Дата,
	ДокументЗаданиеНаРаботу.Проведен,
	ДокументЗаданиеНаРаботу.Организация,
	ДокументЗаданиеНаРаботу.ВидОперации,
	ДокументЗаданиеНаРаботу.Состояние,
	ДокументЗаданиеНаРаботу.ВидРабот,
	ДокументЗаданиеНаРаботу.ВидЦен,
	ДокументЗаданиеНаРаботу.Сотрудник,
	ДокументЗаданиеНаРаботу.СтруктурнаяЕдиница,
	ДокументЗаданиеНаРаботу.СуммаДокумента,
	ДокументЗаданиеНаРаботу.ПоложениеВидаРабот,
	ДокументЗаданиеНаРаботу.Событие,
	ДокументЗаданиеНаРаботу.Комментарий,
	ДокументЗаданиеНаРаботу.Автор,
	ДокументЗаданиеНаРаботу.ЗапретРедактированияДокументов,
	ДокументЗаданиеНаРаботу.Работы.(
		Ссылка,
		НомерСтроки,
		ВидРабот,
		Заказчик,
		Номенклатура,
		Характеристика,
		ДатаНачала,
		ДатаОкончания,
		Трудоемкость,
		Цена,
		Сумма,
		Комментарий
	),
	ДокументЗаданиеНаРаботу.МоментВремени,
	ВЫБОР
		КОГДА &amp;ПериодНачала = ДАТАВРЕМЯ(1, 1, 1)
				И 1 В
					(ВЫБРАТЬ ПЕРВЫЕ 1
						1
					ИЗ
						РегистрНакопления.ЗаданияНаРаботу КАК ТаблицаПросроченные
					ГДЕ
						ТаблицаПросроченные.Регистратор = ДокументЗаданиеНаРаботу.Ссылка
						И ТаблицаПросроченные.ВремяОкончания &lt; &amp;ПериодОкончания
						И ТаблицаПросроченные.ВремяНачала &lt;> ДАТАВРЕМЯ(1, 1, 1))
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК Просрочено,
	ВЫБОР
		КОГДА &amp;ПериодНачала &lt;> ДАТАВРЕМЯ(1, 1, 1)
				И 1 В
					(ВЫБРАТЬ ПЕРВЫЕ 1
						1
					ИЗ
						РегистрНакопления.ЗаданияНаРаботу КАК ТаблицаНаСегодня
					ГДЕ
						ТаблицаНаСегодня.Регистратор = ДокументЗаданиеНаРаботу.Ссылка
						И ТаблицаНаСегодня.ВремяОкончания >= &amp;ПериодОкончания
						И ТаблицаНаСегодня.ВремяНачала &lt;= &amp;ПериодНачала)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК НаСегодня
ИЗ
	Документ.ЗаданиеНаРаботу КАК ДокументЗаданиеНаРаботу</queryText>
      <mainTable>Document.ЗаданиеНаРаботу</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
