		МассивРезультатов = Запрос.ВыполнитьПакет();
		
		Если НЕ МассивРезультатов[0].Пустой()
			ИЛИ НЕ МассивРезультатов[1].Пустой()
			ИЛИ НЕ МассивРезультатов[2].Пустой()
			//+++ Дмгг
			//ИЛИ НЕ МассивРезультатов[3].Пустой() Тогда
			ИЛИ НЕ МассивРезультатов[3].Пустой()
			ИЛИ (МассивРезультатов.Количество() = 5 И НЕ МассивРезультатов[4].Пустой()) Тогда
			//--- Дмгг
			ДокументОбъектРасходСоСчета = ДокументСсылкаРасходСоСчета.ПолучитьОбъект()
		КонецЕсли;
		
		// Отрицательный остаток по денежным средствам.
		Если НЕ МассивРезультатов[0].Пустой()И НЕ Константы.ОтключениеКонтроляОстатковВДокументахДенежныхСредств.Получить() Тогда
			ВыборкаИзРезультатаЗапроса = МассивРезультатов[0].Выбрать();
