	Запрос.УстановитьПараметр("УчетПоПроектам", ПолучитьФункциональнуюОпцию("УчетПоПроектам"));
	//ПодольскийАИ #УчетПроектов 25.11.2020 }
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПлатежнаяВедомость.Ссылка
	|ИЗ
	|	Документ.ПлатежнаяВедомость КАК ПлатежнаяВедомость
