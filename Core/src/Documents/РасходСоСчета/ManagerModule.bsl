		//_Паганини
		|";
		
		//Паганини_
		РезультатЗапроса = Запрос.Выполнить();
		врТаблицаРасчетыНДФЛ = РезультатЗапроса.Выгрузить();  
		врТаблицаРасчетыПоНалогам = врТаблицаРасчетыНДФЛ.Скопировать();	
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыНДФЛ", Новый ТаблицаЗначений);		
		
		врТаблицаРасчетыПоНалогам.Свернуть("Период,ВидДвижения,Организация,ВидНалога,СчетУчета,СрокУплаты,СодержаниеПроводки","Сумма");
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоНалогам", врТаблицаРасчетыПоНалогам);
		//_Паганини
		
	ИначеЕсли ДокументСсылкаРасходСоСчета.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата Или ДокументСсылкаРасходСоСчета.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам Тогда
		
		Запрос.УстановитьПараметр("НачислениеНалога",	НСтр("ka='გადასახადის დარიცხვა';ru='Начисление налога';en='tax accrual'"));
		Запрос.УстановитьПараметр("ПогашениеНалога",	НСтр("ka='გადასახადის დაფარვა';ru='Погашение налога';en='repayment of the tax'"));
