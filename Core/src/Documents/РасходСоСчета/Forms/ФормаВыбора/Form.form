    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументРасходСоСчета.Ссылка,
	ДокументРасходСоСчета.ПометкаУдаления,
	ДокументРасходСоСчета.Номер,
	ДокументРасходСоСчета.Дата,
	ДокументРасходСоСчета.Проведен,
	ДокументРасходСоСчета.Организация,
	ДокументРасходСоСчета.Комментарий,
	ДокументРасходСоСчета.ВидОперации,
	ДокументРасходСоСчета.БанковскийСчет,
	ДокументРасходСоСчета.Статья,
	ДокументРасходСоСчета.ДокументОснование,
	ДокументРасходСоСчета.Контрагент,
	ДокументРасходСоСчета.Подотчетник,
	ДокументРасходСоСчета.Документ,
	ДокументРасходСоСчета.СуммаДокумента КАК СуммаДокумента,
	ДокументРасходСоСчета.ВалютаДенежныхСредств,
	ДокументРасходСоСчета.Корреспонденция,
	ДокументРасходСоСчета.ВидНалога,
	ДокументРасходСоСчета.ДатаВходящегоДокумента,
	ДокументРасходСоСчета.НомерВходящегоДокумента,
	ДокументРасходСоСчета.НазначениеПлатежа,
	ДокументРасходСоСчета.НаправлениеДеятельности,
	ДокументРасходСоСчета.Подразделение,
	ДокументРасходСоСчета.Заказ,
	ДокументРасходСоСчета.НалогообложениеНДС,
	ДокументРасходСоСчета.СчетКонтрагента,
	ДокументРасходСоСчета.Автор,
	ДокументРасходСоСчета.РасшифровкаПлатежа.(
		Ссылка,
		НомерСтроки,
		Договор,
		ПризнакАванса,
		Документ,
		СуммаРасчетов,
		Курс,
		Кратность,
		СуммаПлатежа,
		СтавкаНДС,
		СуммаНДС,
		Заказ,
		СчетНаОплату,
		ДокументПланирования,
		СуммаРасчетовКомиссии,
		СуммаПлатежаКомиссии,
		ТипСуммы,
		СтатьяДДС,
		ТипНДФЛ,
		ВидУдержанияНДФЛ,
		СуммаНДФЛ,
		ВидУдержанияПФ,
		СуммаПФ
	),
	ДокументРасходСоСчета.ВыплатаЗаработнойПлаты.(
		Ссылка,
		НомерСтроки,
		Ведомость,
		СуммаПлатежа,
		ДокументПланирования,
		Сотрудник,
		БанковскийСчет,
		Банк,
		НДФЛПлатежа,
		СуммаПФПлатежа,
		ВидУдержанияНДФЛ,
		ВидУдержанияПФ
	),
	ДокументРасходСоСчета.МоментВремени,
	ЕСТЬNULL(СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.ПрисутствуетТолькоВТекущейБазе)) КАК Статус,
	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, &quot;&quot;) КАК УИД,
	ВЫБОР
		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.Выгружен, ЛОЖЬ) = ЛОЖЬ
				И ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, &quot;&quot;) &lt;> &quot;&quot;
			ТОГДА ИСТИНА
		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.Выгружен, ЛОЖЬ) = ЛОЖЬ
			ТОГДА ЛОЖЬ
		ИНАЧЕ УИДДокументовВИнтернетБанке.Выгружен
	КОНЕЦ КАК Выгружен,
	ИспользоватьЗагрузкуИзБанка.Значение КАК ИспользоватьИнтернетБанк
ИЗ
	Документ.РасходСоСчета КАК ДокументРасходСоСчета
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(, ) КАК СтатусыДокументовВИнтернетБанке
		ПО ДокументРасходСоСчета.Ссылка = СтатусыДокументовВИнтернетБанке.ДокументСсылка
			И ДокументРасходСоСчета.БанковскийСчет.Банк = СтатусыДокументовВИнтернетБанке.Банк
			И (СтатусыДокументовВИнтернетБанке.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		ПО ДокументРасходСоСчета.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
			И ДокументРасходСоСчета.БанковскийСчет.Банк = УИДДокументовВИнтернетБанке.Банк
			И (УИДДокументовВИнтернетБанке.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)),
	Константа.ИспользоватьЗагрузкуИзБанка КАК ИспользоватьЗагрузкуИзБанка</queryText>
      <mainTable>Document.РасходСоСчета</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
