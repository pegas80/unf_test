#Область ЗарплатаВРазрезеСотрудников
// Kuzmich, 25.02.2019,Зарплата по ведомости в разрезе сотрудников
&НаСервере
Процедура ВыплатаЗаработнойПлатыБанковскийСчетПриИзмененииНаСервере(Идентификатор)
	СтрокаТЧ = Объект.ВыплатаЗаработнойПлаты.НайтиПоИдентификатору(Идентификатор);
	СтрокаТЧ.Банк = СтрокаТЧ.БанковскийСчет.Банк;
КонецПроцедуры


&НаКлиенте
Процедура ВыплатаЗаработнойПлатыБанковскийСчетПриИзменении(Элемент)
	ВыплатаЗаработнойПлатыБанковскийСчетПриИзмененииНаСервере(Элементы.ВыплатаЗаработнойПлаты.ТекущаяСтрока);
КонецПроцедуры


&НаКлиенте
Процедура ОбработкаПодбораЗарплатаВРазрезеСотрудниковПоВедомости(Результат, ДополнительныеПараметры) ЭКСПОРТ
	Если ТипЗНЧ(Результат)=Тип("Массив") Тогда
		Для каждого СтрРезультат Из Результат Цикл
			ИдентификаторСтроки = ОбработкаПодбораЗарплатаВРазрезеСотрудниковПоВедомостиНаСервере(СтрРезультат);
			Если НЕ ИдентификаторСтроки=НЕОПРЕДЕЛЕНО Тогда
				Элементы.ВыплатаЗаработнойПлаты.ТекущаяСтрока = Объект.ВыплатаЗаработнойПлаты.НайтиПоИдентификатору(ИдентификаторСтроки);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры


&НаСервере
Функция ОбработкаПодбораЗарплатаВРазрезеСотрудниковПоВедомостиНаСервере(СтрРезультат)
	Если ТипЗНЧ(СтрРезультат)=Тип("Структура") Тогда
		СтруктураПоиска = Новый Структура("Ведомость,Сотрудник");
		ЗаполнитьЗначенияСвойств(СтруктураПоиска,СтрРезультат);
		МассивСтрок = Объект.ВыплатаЗаработнойПлаты.НайтиСтроки(СтруктураПоиска);
		Если МассивСтрок.Количество()=0 Тогда
			СтрВыплатаЗаработнойПлаты = Объект.ВыплатаЗаработнойПлаты.Добавить();
		Иначе	
			СтрВыплатаЗаработнойПлаты = МассивСтрок[0];
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтрВыплатаЗаработнойПлаты,СтрРезультат);
		ИдентификаторСтроки = СтрВыплатаЗаработнойПлаты.ПолучитьИдентификатор();
		НайтиБанковскийСчетСотрудника(ИдентификаторСтроки);
		Возврат ИдентификаторСтроки;
	Иначе
		Возврат НЕОПРЕДЕЛЕНО;
	КонецЕсли;
КонецФункции


&НаСервере
Процедура НайтиБанковскийСчетСотрудника(ИдентификаторСтроки)
	ТекущаяСтрокаВыплатаЗаработнойПлаты = Объект.ВыплатаЗаработнойПлаты.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если НЕ ТекущаяСтрокаВыплатаЗаработнойПлаты = НЕОПРЕДЕЛЕНО Тогда
		ТекущийСотрудник = ТекущаяСтрокаВыплатаЗаработнойПлаты.Сотрудник;
		Если ЗначениеЗаполнено(ТекущийСотрудник) Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	БанковскиеСчета.Ссылка КАК БанковскийСчет,
			|	БанковскиеСчета.Банк КАК Банк 
			|ИЗ
			|	Справочник.БанковскиеСчета КАК БанковскиеСчета
			|ГДЕ
			|	БанковскиеСчета.Владелец = &Владелец";
			
			Запрос.УстановитьПараметр("Владелец", ТекущийСотрудник);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(ТекущаяСтрокаВыплатаЗаработнойПлаты,ВыборкаДетальныеЗаписи);
			КонецЦикла;

		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ОткрытьПодборПоВедомости(МассивВедомостей,ТекущийСотрудник=НЕОПРЕДЕЛЕНО)
	Если НЕ ЗначениеЗаполнено(МассивВедомостей) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(МассивВедомостей)=Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	Если МассивВедомостей.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	//Паганини_
	//ПараметрыФормы.Вставить("ДатаДокумента",?(ЗначениеЗаполнено(Объект.Дата),Объект.Дата,ТекущаяДата()));
	ПараметрыФормы.Вставить("ДатаДокумента", ?(Объект.Ссылка.Пустая() И НачалоДня(Объект.Дата) = НачалоДня(ТекущаяДата()), ТекущаяДата(), Объект.Дата));
	//_Паганини
	ПараметрыФормы.Вставить("Организация",Объект.Организация);
	ПараметрыФормы.Вставить("Подразделение",Объект.Подразделение);
	ПараметрыФормы.Вставить("Сотрудник",ТекущийСотрудник);
	ПараметрыФормы.Вставить("МассивВедомостей",МассивВедомостей);
	оп = Новый ОписаниеОповещения("ОбработкаПодбораЗарплатаВРазрезеСотрудниковПоВедомости", ЭтотОбъект);
	ОткрытьФорму("ОбщаяФорма.ПодборПоВедомости",ПараметрыФормы,,,,,оп,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры


&НаКлиенте
Процедура ПодборПоВедомости(Команда)
	Если Объект.ПлатежныеВедомости.Количество()=0 Тогда
		Возврат;
	КонецЕсли;
	
	МассивВедомостей = Новый Массив();
	Для каждого СтрПлатежныеВедомости Из Объект.ПлатежныеВедомости Цикл
		МассивВедомостей.Добавить(СтрПлатежныеВедомости.Ведомость);
	КонецЦикла; 
	ОткрытьПодборПоВедомости(МассивВедомостей);
КонецПроцедуры

&НаКлиенте
Процедура ВыплатаЗаработнойПлатыСотрудникПриИзменении(Элемент)
	ТекВедомость = Элементы.ВыплатаЗаработнойПлаты.ТекущиеДанные.Ведомость;
	ТекСотрудник = Элементы.ВыплатаЗаработнойПлаты.ТекущиеДанные.Сотрудник;
	Если ЗначениеЗаполнено(ТекВедомость) И ЗначениеЗаполнено(ТекСотрудник) Тогда
		МассивВедомостей = Новый Массив();
		МассивВедомостей.Добавить(ТекВедомость);
		ОткрытьПодборПоВедомости(МассивВедомостей,ТекСотрудник);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПлатежныеВедомостиВедомостьПриИзменении(Элемент)
	ТекущиеДанныеПлатежныеВедомости = Элементы.ПлатежныеВедомости.ТекущиеДанные;
	ТекВедомость = ТекущиеДанныеПлатежныеВедомости.Ведомость;
	Если ЗначениеЗаполнено(ТекВедомость) Тогда
		МассивВедомостей = Новый Массив();
		МассивВедомостей.Добавить(ТекВедомость);
		ОткрытьПодборПоВедомости(МассивВедомостей);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти


#Область ПаганиниПФ
&НаКлиенте
Процедура ВыплатаЗаработнойПлатыВидУдержанияНДФЛПриИзменении(Элемент)
	РасчитатьСуммы_ПФ_НДФЛ(Элементы.ВыплатаЗаработнойПлаты.ТекущаяСтрока);
КонецПроцедуры

&НаКлиенте
Процедура ВыплатаЗаработнойПлатыВидУдержанияПФПриИзменении(Элемент)
	РасчитатьСуммы_ПФ_НДФЛ(Элементы.ВыплатаЗаработнойПлаты.ТекущаяСтрока);
КонецПроцедуры

&НаСервере
Процедура РасчитатьСуммы_ПФ_НДФЛ(Идентификатор)
	
	СтавкаНДФЛ	= 0;
	СтавкаПФ	= 0;
	
	ТекСтрока = Объект.ВыплатаЗаработнойПлаты.НайтиПоИдентификатору(Идентификатор);
	Если ЗначениеЗаполнено(ТекСтрока.ВидУдержанияНДФЛ) Тогда
		СтавкаНДФЛ = ТекСтрока.ВидУдержанияНДФЛ.СтавкаНДФЛ;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекСтрока.ВидУдержанияПФ) Тогда
		СтавкаПФ = ТекСтрока.ВидУдержанияПФ.СтавкаПФ;
	КонецЕсли;
	
	ТекСтрока.НДФЛПлатежа		= Окр(ТекСтрока.СуммаПлатежа * СтавкаНДФЛ/(100 - СтавкаНДФЛ), 2);
	ТекСтрока.СуммаПФПлатежа	= Окр((ТекСтрока.СуммаПлатежа + ТекСтрока.НДФЛПлатежа) * СтавкаПФ/(100 - СтавкаПФ), 2);
	
КонецПроцедуры

//Паганини_
&НаКлиенте
Процедура ЗаполнитьПФПоОстаткам(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.ВидУдержания) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ka='ველი ""დაკავების ტიპი"" არ არის შევსებული';ru='Поле ""Вид удержания"" не заполнен';en='The ""type retention"" is empty'");
		Сообщение.Поле =  "Объект.ВидУдержания";
		Сообщение.УстановитьДанные(Объект);
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;	
	ЗаполнитьПФПоОстаткамНаСервере();
	Модифицированность = Истина;
	
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьПФПоОстаткамНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасчетыСПенсионнымФондомОбороты.ВидНачисленияУдержания,
		|	СУММА(РасчетыСПенсионнымФондомОбороты.СуммаОборот) КАК Сумма
		|ИЗ
		|	РегистрНакопления.РасчетыСПенсионнымФондом.Обороты(
		|			,
		|			&Дата,
		|			Авто,
		|			Организация = &Организация
		|				И ВидНачисленияУдержания = &ВидНачисленияУдержания
		|				И Операция = ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.КОплате)) КАК РасчетыСПенсионнымФондомОбороты
		|ГДЕ
		|	НЕ РасчетыСПенсионнымФондомОбороты.Регистратор = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	РасчетыСПенсионнымФондомОбороты.ВидНачисленияУдержания
		|
		|ИМЕЮЩИЕ
		|	СУММА(РасчетыСПенсионнымФондомОбороты.СуммаОборот) > 0";
	Если Объект.Ссылка.Пустая() И НачалоДня(Объект.Дата) = НачалоДня(ТекущаяДата()) Тогда
		Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Иначе
		Запрос.УстановитьПараметр("Дата", Новый МоментВремени(Объект.Дата, Объект.Ссылка));
	КонецЕсли;
	Запрос.УстановитьПараметр("Ссылка",						Объект.Ссылка);
	Запрос.УстановитьПараметр("Организация", 				Объект.Организация);
	Запрос.УстановитьПараметр("ВидНачисленияУдержания",		Объект.ВидУдержания);
	
	Объект.СуммаДокумента = Запрос.Выполнить().Выгрузить().Итог("Сумма");
	
КонецПроцедуры

&НаКлиенте
Процедура РасшифровкаПлатежаВидУдержанияНДФЛПриИзменении(Элемент)
	ПересчитатьСуммыВСтрокиРасходов(Элементы.РасшифровкаПлатежа.ТекущаяСтрока, "ВидУдержанияНДФЛ");
КонецПроцедуры

&НаКлиенте
Процедура РасшифровкаПлатежаВидУдержанияПФПриИзменении(Элемент)
	ПересчитатьСуммыВСтрокиРасходов(Элементы.РасшифровкаПлатежа.ТекущаяСтрока, "ВидУдержанияПФ");
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммыВСтрокиРасходов(Идентификатор, ИмяПоля)
	Если Идентификатор = Неопределено ИЛИ Идентификатор = 0 Тогда
		Для Каждого СтрокаТЧ ИЗ Объект.РасшифровкаПлатежа Цикл
			Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			ТекДанные = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
			РС_ОбщегоНазначения.ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные);
		КонецЦикла;
	Иначе
		ТекДанные = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
		РС_ОбщегоНазначения.ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные);
	КонецЕсли;
КонецПроцедуры

//+++ Истомин
// Нужно для операции пенсионного фонда при выгрузке в банк что бы был заполнен контрагент
// Для фильтра банковского счета
&НаСервере
Процедура ВидУдержанияПриИзмененииНаСервере()
	Объект.Контрагент = Объект.ВидУдержания.Контрагент;
КонецПроцедуры

&НаКлиенте
Процедура ВидУдержанияПриИзменении(Элемент)
	ВидУдержанияПриИзмененииНаСервере();
КонецПроцедуры

//--- Истомин

&НаКлиенте
Процедура ТаблицаДолговВидУдержанияНДФЛПриИзменении(Элемент)
	ПересчитатьСуммыВСтрокиРасходовТаблицаДолгов(Элементы.ТаблицаДолгов.ТекущаяСтрока, "ВидУдержанияНДФЛ");
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммыВСтрокиРасходовТаблицаДолгов(Идентификатор, ИмяПоля)
	Если Идентификатор = Неопределено ИЛИ Идентификатор = 0 Тогда
		Для Каждого СтрокаТЧ ИЗ Объект.РасшифровкаПлатежа Цикл
			Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			ТекДанные = ТаблицаДолгов.НайтиПоИдентификатору(Идентификатор);
			ПересчитатьСуммСтавкиНДФЛ(ТекДанные);
		КонецЦикла;
	Иначе
		ТекДанные = ТаблицаДолгов.НайтиПоИдентификатору(Идентификатор);
		ПересчитатьСуммСтавкиНДФЛ(ТекДанные);
	КонецЕсли;
	
	
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммСтавкиНДФЛ(Строка)
	
	Строка.СуммаНДФЛ		= Окр(Строка.СуммаДокумента *Строка.ВидУдержанияНДФЛ.СтавкаНДФЛ/(100 - Строка.ВидУдержанияНДФЛ.СтавкаНДФЛ), 2);

	
КонецПроцедуры	


&НаСервере
Процедура РасшифровкаПлатежаРасчетыПоКредитамТипСуммыПриИзмененииНаСервере(Идентификатор = Неопределено)
	Если Идентификатор = Неопределено Тогда
		Для Каждого СтрокаТЧ ИЗ Объект.РасшифровкаПлатежа Цикл
			Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			ТекДанные = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
			ПересчитатьСуммыСтроки(ТекДанные);
		КонецЦикла;
	Иначе
		ТекДанные = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
		ПересчитатьСуммыСтроки(ТекДанные);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммыСтроки(ТекДанные)
		
	Если ТекДанные.ТипСуммы = Перечисления.ТипыСуммГрафикаКредитовИЗаймов.Проценты И Объект.ДоговорКредитаЗайма.СуммаВключаетНДФЛ Тогда
		
		ТекДанные.ВидУдержанияНДФЛ = Объект.ДоговорКредитаЗайма.ВидНачисленияУдержанияНДФЛ;
		
		Ставки	= РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, , 0, 0, 0);
		СуммаБезНалогов     = ТекДанные.СуммаПлатежа;
		ТекДанные.СуммаНДФЛ	= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		
	Иначе
		ТекДанные.СуммаНДФЛ = 0;	
		ТекДанные.ВидУдержанияНДФЛ = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры	


&НаКлиенте
Процедура РасшифровкаПлатежаРасчетыПоКредитамТипСуммыПриИзменении(Элемент)
	РасшифровкаПлатежаРасчетыПоКредитамТипСуммыПриИзмененииНаСервере(Элементы.РасшифровкаПлатежаРасчетыПоКредитам.ТекущаяСтрока);
КонецПроцедуры


&НаКлиенте
Процедура РасшифровкаПлатежаРасчетыПоКредитамВидУдержанияНДФЛПриИзменении(Элемент)
	РасшифровкаПлатежаРасчетыПоКредитамТипСуммыПриИзмененииНаСервере(Элементы.РасшифровкаПлатежаРасчетыПоКредитам.ТекущаяСтрока);
КонецПроцедуры

