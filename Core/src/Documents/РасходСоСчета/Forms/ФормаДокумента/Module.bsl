#Область Паганини_

&НаСервере
Процедура ЗаполнитьКолонкуУчитыватьНДФЛ(Идентификатор = Неопределено, ИмяСобытия = Неопределено)
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам Тогда
		Возврат;
	КонецЕсли;	
	
	Если НЕ ИмяСобытия = "ПослеУдаленияСтроки" Тогда
		Если Идентификатор = Неопределено Тогда
			Для Каждого СтрокаТЧ Из Объект.РасшифровкаПлатежа Цикл
				СтрокаТЧ.УчитыватьНДФЛ = СтрокаТЧ.Договор.УчитыватьНДФЛ;
				//Если ИмяСобытия = "ИзменениеДоговора" Тогда
				//	Если СтрокаТЧ.УчитыватьНДФЛ Тогда
				//		Если НЕ СтрокаТЧ.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль() Тогда
				//			СтрокаТЧ.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
				//			ПересчитатьСуммыВСтрокиРасходов(СтрокаТЧ.ПолучитьИдентификатор(), "СтавкаНДС");
				//		КонецЕсли;
				//	Иначе
				//		Если НЕ СтрокаТЧ.СтавкаНДС = СтавкаНДСПоУмолчанию Тогда
				//			СтрокаТЧ.СтавкаНДС = СтавкаНДСПоУмолчанию;
				//			ПересчитатьСуммыВСтрокиРасходов(СтрокаТЧ.ПолучитьИдентификатор(), "СтавкаНДС");
				//		КонецЕсли;
				//	КонецЕсли;
				//КонецЕсли;
				//+++ Дмгг
				ДатаЗапроса = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата());
				СтруктураСтавок = РС_ОбщегоНазначения.ПолучитьСтавкиНалогов(ДатаЗапроса, Объект.Контрагент, СтрокаТЧ.Договор, Объект.Организация);
				СтрокаТЧ.ВидУдержанияНДФЛ = СтруктураСтавок.ВидУдержанияНДФЛ;
				СтрокаТЧ.ВидУдержанияПФ = СтруктураСтавок.ВидУдержанияПФ;
				ПересчитатьСуммыВСтрокиРасходов(СтрокаТЧ.ПолучитьИдентификатор(), "СуммаПлатежа");
				//--- Дмгг
			КонецЦикла;
		Иначе
			СтрокаТЧ = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
			СтрокаТЧ.УчитыватьНДФЛ  = СтрокаТЧ.Договор.УчитыватьНДФЛ;
			Если ИмяСобытия = "ИзменениеДоговора" Тогда
				//СтрокаТЧ.ВидУдержанияНДФЛ	= СтрокаТЧ.Договор.ВидУдержанияНДФЛ;
				Ставки = РС_ОбщегоНазначения.ПолучитьСтавкиНалогов(Объект.Дата, Объект.Контрагент, СтрокаТЧ.Договор, Объект.Организация);
				СтрокаТЧ.ПредСтавкаНДС 			= СтрокаТЧ.СтавкаНДС;
				СтрокаТЧ.ПредВидУдержанияПФ		= СтрокаТЧ.ВидУдержанияПФ;
				СтрокаТЧ.ПредВидУдержанияНДФЛ	= СтрокаТЧ.ВидУдержанияНДФЛ;
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, Ставки);
				Если НЕ ЗначениеЗаполнено(Ставки.СтавкаНДС) Тогда
					СтрокаТЧ.СуммаНДС = 0;
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Ставки.ВидУдержанияНДФЛ) Тогда
					СтрокаТЧ.СуммаНДФЛ = 0;
				КонецЕсли;
				Если НЕ ЗначениеЗаполнено(Ставки.ВидУдержанияПФ) Тогда
					СтрокаТЧ.СуммаПФ = 0;
				КонецЕсли;
				ПересчитатьСуммыВСтрокиРасходов(СтрокаТЧ.ПолучитьИдентификатор(), "СуммаПлатежа");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Поставщику Тогда
		Элементы.РасшифровкаПлатежаГруппаНДФЛ.Видимость = Объект.РасшифровкаПлатежа.НайтиСтроки(Новый Структура("УчитыватьНДФЛ", Истина)).Количество() > 0;
	Иначе
		Элементы.РасшифровкаПлатежаГруппаНДФЛ.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КорреспонденцияРеглПриИзменении(Элемент)
	
	Если КорреспонденцияРегл <> Объект.КорреспонденцияРегл Тогда
		КорреспонденцияРегл = Объект.КорреспонденцияРегл;
		
		Если НЕ ИспользоватьТолькоРегламентированногоПланаСчетов Тогда 
			РегламентированныйУчетСервер.УстановитьУпрСчетИзПланаСчетовХозрасчетный(Объект.КорреспонденцияРегл, Объект.Корреспонденция);
			
			КорреспонденцияПриИзменении(Элементы.Корреспонденция);
		КонецЕсли;
		
		Объект.АналитикаПрочихДоходовИРасходов = Неопределено;
		КорреспонденцияРегл = Объект.КорреспонденцияРегл;
	КонецЕсли;
	
КонецПроцедуры

