// Процедура выполняет распределение затрат по количеству.
//
Процедура РаспределитьСуммуСчетовНаТоварыПоКоличеству() Экспорт
	
	ИсхСумма = 0;
	
	//ПодольскийАИ #УчетПроектов 24.12.2020 {
	Если ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам Тогда
		
		тзОстаткиПоСчетам = ОстаткиПоСчетам.Выгрузить();
		тзОстаткиПоСчетам.Свернуть("Проект", "Сумма");
		
		Для Каждого СтрокаСчет Из тзОстаткиПоСчетам Цикл
			
			ИсхСумма = 0;
			
			ОтборПоПроекту = Новый Структура("Отметка,Проект", Истина, СтрокаСчет.Проект);
			тзВыбранныеСтроки = ОстаткиТоваровНаСкладе.Выгрузить(ОтборПоПроекту);
		
			БазаРаспределенияКоличество = тзВыбранныеСтроки.Итог("Количество");
			ВсегоРасходы = СтрокаСчет.Сумма;// - Расходы.Итог("СуммаНДС");
			НОД = УправлениеНебольшойФирмойСервер.ПолучитьНОДДляМассива(тзВыбранныеСтроки.ВыгрузитьКолонку("Количество"), 1000);
			
			Если НОД = 0 Тогда
				Возврат;
			КонецЕсли;
			
			СтрокиПоОтбору = ОстаткиТоваровНаСкладе.НайтиСтроки(ОтборПоПроекту);
			Для каждого СтрокаТовары Из СтрокиПоОтбору Цикл
				
				Если СтрокаТовары.Отметка Тогда
					
					Коэффициент = СтрокаТовары.Количество / НОД * 1000;
					СтрокаТовары.СуммаРасходов = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоРасходы - ИсхСумма) * СтрокаТовары.Количество / БазаРаспределенияКоличество, 2, 1),0);
					
					БазаРаспределенияКоличество = БазаРаспределенияКоличество - СтрокаТовары.Количество;
					
					ИсхСумма = ИсхСумма + СтрокаТовары.СуммаРасходов;
					
				КонецЕсли;
				
			КонецЦикла;
		
		КонецЦикла;
	Иначе
			
		тзВыбранныеСтроки = ОстаткиТоваровНаСкладе.Выгрузить(Новый Структура("Отметка", Истина));
		
		БазаРаспределенияКоличество = тзВыбранныеСтроки.Итог("Количество");
		ВсегоРасходы = ОстаткиПоСчетам.Итог("Сумма");// - Расходы.Итог("СуммаНДС");
		НОД = УправлениеНебольшойФирмойСервер.ПолучитьНОДДляМассива(тзВыбранныеСтроки.ВыгрузитьКолонку("Количество"), 1000);
		
		Если НОД = 0 Тогда
			Возврат;
		КонецЕсли;
		
		Для каждого СтрокаТовары Из ОстаткиТоваровНаСкладе Цикл
			
			Если СтрокаТовары.Отметка Тогда
				
				Коэффициент = СтрокаТовары.Количество / НОД * 1000;
				СтрокаТовары.СуммаРасходов = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоРасходы - ИсхСумма) * СтрокаТовары.Количество / БазаРаспределенияКоличество, 2, 1),0);
				
				БазаРаспределенияКоличество = БазаРаспределенияКоличество - СтрокаТовары.Количество;
				
				ИсхСумма = ИсхСумма + СтрокаТовары.СуммаРасходов;
				
			КонецЕсли;
			
		КонецЦикла;
		
	//ПодольскийАИ #УчетПроектов 24.12.2020 {
	КонецЕсли;
	//ПодольскийАИ #УчетПроектов 24.12.2020 }
	
КонецПроцедуры // РаспределитьТабЧастьРасходыПоКоличеству()

