
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//ПодольскийАИ #УчетПроектов 15.12.2020 {
	ФОУчетПоПроектам = ПолучитьФункциональнуюОпцию("УчетПоПроектам");
	//ПодольскийАИ #УчетПроектов 15.12.2020 }
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
	
		Объект.ДатаНачала = НачалоМесяца(ТекущаяДата());
		Объект.ДатаОкончания = КонецМесяца(ТекущаяДата());
		//Период
		Период.ДатаНачала = Объект.ДатаНачала;
		Период.ДатаОкончания = Объект.ДатаОкончания;
		
		Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары;
		
	Иначе
		
		Период.ДатаНачала = Объект.ДатаНачала;
		Период.ДатаОкончания = Объект.ДатаОкончания;
		
	КонецЕсли;
	
	ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(Объект.ДатаНачала); //+++ Дмгг
	
	ПредыдущаяКонечнаяДатаПериода = Период.ДатаОкончания;
	
	ЭтоРаспределениеНаТовары = Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары;
	
	ИспользоватьХарактеристики = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики");

	// Олег Литвиненко 30.06.23 --->
	ЭтоРаспределениеНаИмущество = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество");
	// Олег Литвиненко <---
	
	//ПодольскиАИ #УчетПроектов 15.12.2020 {
	ЭтоРаспределениеПоПроектам = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам");
		 
	ПрошлыйВидОперации = Объект.ВидОперации;
	//ПодольскиАИ #УчетПроектов 15.12.2020 }
	
	Если Параметры.Ключ.Пустая() И ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда
		// При копировании нужно прочитать отборы из хранилищ скопированного документа.
		ПрочитатьОтборы(Параметры.ЗначениеКопирования.ПолучитьОбъект());
	КонецЕсли;
	
	//+++ Дмгг
	ИспользоватьПроекты = ПолучитьФункциональнуюОпцию("УчетПоПроектам");
	ИспользоватьПартии = ПолучитьФункциональнуюОпцию("ИспользоватьПартии");
	//--- Дмгг
	
	ИнициализироватьКомпоновщикНастроек();
	УстановитьВидимость();
		
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
	
	//ПодольскийАИ #УчетПроектов 15.12.2020 {
	//Было---
	//Элементы.ГруппаОстаткиОтваровНаСкладе.Видимость = ЭтоРаспределениеНаТовары;
	//Элементы.ГруппаИмущество.Видимость = НЕ ЭтоРаспределениеНаТовары;
	//Стало+++
	Элементы.ГруппаОстаткиОтваровНаСкладе.Видимость = ЭтоРаспределениеНаТовары ИЛИ ЭтоРаспределениеПоПроектам;
	Элементы.ГруппаИмущество.Видимость = НЕ ЭтоРаспределениеНаТовары И НЕ ЭтоРаспределениеПоПроектам;
	////
	
	// Олег Литвиненко 30.06.23 --->
	// Закомментировал. Поле теперь применяется для всех видов операций
	//Элементы.Подразделение.Видимость = ЭтоРаспределениеНаТовары;
	//Элементы.ОстаткиПоСчетамСтруктурнаяЕдиница.Видимость = ЭтоРаспределениеНаТовары;
	Элементы.ИспользоватьХарактеристики.Видимость = ЭтоРаспределениеПоПроектам;
	// Олег Литвиненко 30.06.23 --->
	// Закомментировал. Поле теперь применяется для всех видов операций
	//Элементы.ОстаткиПоСчетамПроект.Видимость = ЭтоРаспределениеПоПроектам Или ЭтоРаспределениеНаИмущество;
	
	Если ФОУчетПоПроектам Тогда
		Элементы.ВидОперации.РежимВыбораИзСписка = Истина;
		
		СписокОпераций = Новый Массив;
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары);
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество);
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам);
		
		Элементы.ВидОперации.СписокВыбора.ЗагрузитьЗначения(СписокОпераций);
	КонецЕсли;
	//ПодольскийАИ #УчетПроектов 15.12.2020 }
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьКомпоновщикНастроек()

	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	// ОстаткиТоваров
	НаборыДанныхОстаткиТоваров = Новый Структура;
	
	//СКД_Остатки = ДокументОбъект.ПолучитьМакет("СКД_ОстаткиТоваровНаСкладе");
	//ПодольскийАИ #УчетПроектов 16.12.2020 {
	//Если Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам Тогда
		//СКД_Остатки = ДокументОбъект.ПолучитьМакет("СКД_ОстаткиТоваровНаСкладеПоПроекту");
	//КонецЕсли;
	//ПодольскийАИ #УчетПроектов 16.12.2020 }           
	
	УчетСебестоимостиВРазрезеОрганизации = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(Объект.Дата, Новый Структура("Организация", Объект.Организация)).УчетСебестоимостиВРазрезеОрганизации;
	ИмяМакета = "СКД_ОстаткиТоваровНаСкладеНовый";
	//ИмяМакета = "СКД_ОстаткиТоваровНаСкладе";
	//ИмяМакета = ИмяМакета +  ?(УчетСебестоимостиВРазрезеОрганизации, "_ВРазрезеОрганизаций", "");
	//Если ИспользоватьПроекты Тогда 
	//	ИмяМакета = "СКД_ОстаткиТоваровНаСкладеПоПроекту";
	//ИначеЕсли ИспользоватьПартии Тогда 
	//	ИмяМакета = "СКД_ОстаткиТоваровНаСкладеПартии";
	//	ИмяМакета = ИмяМакета +  ?(УчетСебестоимостиВРазрезеОрганизации, "_ВРазрезеОрганизаций", "");
	//КонецЕсли;            
	
	СКД_Остатки = ДокументОбъект.ПолучитьМакет(ИмяМакета);
	
	НастройкиОстатки = СКД_Остатки.НастройкиПоУмолчанию;
	
	АдресВоВременномХранилищеОстатки = ПоместитьВоВременноеХранилище(СКД_Остатки, УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресВоВременномХранилищеОстатки);
	КомпоновщикНастроекОстаткиТовары.Инициализировать(ИсточникНастроек);	
	КомпоновщикНастроекОстаткиТовары.ЗагрузитьНастройки(СКД_Остатки.НастройкиПоУмолчанию);
	
	// ОборотыСчетов
	НаборыДанныхОборотыСчетов = Новый Структура;
	
	//СКД_Обороты = ДокументОбъект.ПолучитьМакет("СКД_ОборотыПоСчетам");
	//ПодольскийАИ #УчетПроектов 15.12.2020 {
	//Если Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам Тогда
		СКД_Обороты = ДокументОбъект.ПолучитьМакет("СКД_ОборотыПоСчетамПроектов");
	//КонецЕсли;
	//ПодольскийАИ #УчетПроектов 15.12.2020 }
	
	НастройкиОбороты = СКД_Обороты.НастройкиПоУмолчанию;
	
	АдресВоВременномХранилищеОбороты = ПоместитьВоВременноеХранилище(СКД_Обороты, УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресВоВременномХранилищеОбороты);
	КомпоновщикНастроекОборотыПоСчетам.Инициализировать(ИсточникНастроек);	
	КомпоновщикНастроекОборотыПоСчетам.ЗагрузитьНастройки(СКД_Обороты.НастройкиПоУмолчанию);

КонецПроцедуры

&НаКлиенте
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияКомментария(Элемент.ТекстРедактирования, ЭтотОбъект, "Объект.Комментарий");
	СтатистикаИспользованияФормКлиент.ПриИнтерактивномДействии(ЭтотОбъект, Элемент, "НачалоВыбора");
	
КонецПроцедуры

&НаКлиенте
Процедура КомментарийПриИзменении(Элемент)
	
	СтатистикаИспользованияФормКлиент.ПриИнтерактивномДействии(ЭтотОбъект, Элемент, "ПриИзменении");
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	
	Объект.ДатаНачала = Период.ДатаНачала;
	Объект.ДатаОкончания = Период.ДатаОкончания;
	
	Если НЕ Объект.Проведен Тогда 
		ПредыдущаяКонечнаяДатаПериода = Период.ДатаОкончания;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОстаткиПоТоварамНаСервере()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	//Получаем схему из макета
		
	НаборыДанных = Новый Структура;
	
	//+++ Дмгг 20.09.23
	//Перестала заполняться таб часть ОстаткиТоваровНаСкладе
	//Из-за того что не особо деляться информацией, исхожу из логики включены ли константы
	////--------------------------------------------------------------------------
	//// © Шишка В.В. [22 октября 2021]  НАЧАЛО
	////СхемаКомпоновкиДанных = ДокументОбъект.ПолучитьМакет("СКД_ОстаткиТоваровНаСкладе");
	//УчетСебестоимостиВРазрезеОрганизации = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(Объект.Дата, Новый Структура("Организация", Объект.Организация)).УчетСебестоимостиВРазрезеОрганизации;
	//СхемаКомпоновкиДанных = ДокументОбъект.ПолучитьМакет("СКД_ОстаткиТоваровНаСкладе" + ?(УчетСебестоимостиВРазрезеОрганизации, "_ВРазрезеОрганизаций", ""));
	//// © Шишка В.В. [22 октября 2021]  КОНЕЦ
	////--------------------------------------------------------------------------
	////ПодольскийАИ #УчетПроектов 16.12.2020 {
	////Если Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам Тогда
	//	СхемаКомпоновкиДанных = ДокументОбъект.ПолучитьМакет("СКД_ОстаткиТоваровНаСкладеПоПроекту");
	////КонецЕсли;
	////ПодольскийАИ #УчетПроектов 16.12.2020 }
	УчетСебестоимостиВРазрезеОрганизации = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(Объект.Дата, Новый Структура("Организация", Объект.Организация)).УчетСебестоимостиВРазрезеОрганизации;
	//ИмяМакета = "СКД_ОстаткиТоваровНаСкладе";
	//ИмяМакета = ИмяМакета +  ?(УчетСебестоимостиВРазрезеОрганизации, "_ВРазрезеОрганизаций", "");
	//Если ИспользоватьПроекты Тогда 
	//	ИмяМакета = "СКД_ОстаткиТоваровНаСкладеПоПроекту";
	//ИначеЕсли ИспользоватьПартии Тогда 
	//	ИмяМакета = "СКД_ОстаткиТоваровНаСкладеПартии";
	//	ИмяМакета = ИмяМакета +  ?(УчетСебестоимостиВРазрезеОрганизации, "_ВРазрезеОрганизаций", "");
	//КонецЕсли;
	ИмяМакета = "СКД_ОстаткиТоваровНаСкладеНовый";
	
	СхемаКомпоновкиДанных = ДокументОбъект.ПолучитьМакет(ИмяМакета);
	//СхемаКомпоновкиДанных = ДокументОбъект.ПолучитьМакет("СКД_ОстаткиТоваровНаСкладеНовый");
	//--- Дмгг
	
	Настройки = КомпоновщикНастроекОстаткиТовары.ПолучитьНастройки();//Настройки;
	ТолькоПроекты = Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам; 
	
	//установка параметров отчета, без КомпоновщикНастроекКомпоновкиДанных делать это гораздо сложнее
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("НаДату", Объект.ДатаОкончания);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("УчетСебестоимостиВРазрезеОрганизации", УчетСебестоимостиВРазрезеОрганизации);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ИспользоватьПартии", ИспользоватьПартии);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ИспользоватьПроекты", ИспользоватьПроекты);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("Организация", Объект.Организация);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ВидОперацииНаПроекты", ТолькоПроекты);
	ЕстьПроекты = ЛОЖЬ;
	МассивПроектов = ПроектСклад.ВыгрузитьЗначения();
	ЕстьПроекты = МассивПроектов.Количество() > 0;
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("СписокПроектов", МассивПроектов);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ЕстьПроекты", ЕстьПроекты);
	//Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("Ссылка", Объект.Ссылка);
	
	//ПодольскийАИ #УчетПроектов 22.12.2020 {
	//Если Объект.ВидОперации = Перечисления.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам Тогда
	//Если ИспользоватьПроекты Тогда
		//ТаблицаПосчетам = Объект.ОстаткиПоСчетам.Выгрузить( , "Проект");
		//Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("СписокПроектов", ТаблицаПосчетам.ВыгрузитьКолонку("Проект"));
	//КонецЕсли;
	//ПодольскийАИ #УчетПроектов 22.12.2020 }
	
	ЕстьНоменклатураОтбора = ЛОЖЬ;
	МассивНоменклатур = Номенклатура.ВыгрузитьЗначения();
	ЕстьНоменклатураОтбора = МассивНоменклатур.Количество() > 0; 
	
	ЕстьСкладыОтбора = ЛОЖЬ;
	МассивСкладов = Склад.ВыгрузитьЗначения();
	ЕстьСкладыОтбора = МассивСкладов.Количество() > 0;                                                   
	
	// Kuzmich, 09.04.2024, (ONESOFT-2793) Добавление фильтров в документе распределение затрат на товары
	МассивКатегорииНоменклатуры = КатегорииНоменклатуры.ВыгрузитьЗначения();
	ЕстьКатегорииНоменклатуры = КатегорииНоменклатуры.Количество() > 0;
	// Kuzmich, 09.04.2024, (ONESOFT-2793) Добавление фильтров в документе распределение затрат на товары
	
	Для Каждого ЭлемОтбора Из Настройки.Отбор.Элементы Цикл 
		
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Номенклатура") Тогда 
			Если ЕстьНоменклатураОтбора Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивНоменклатур;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = Справочники.Номенклатура.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СтруктурнаяЕдиница") Тогда 
			Если ЕстьСкладыОтбора Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивСкладов;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СписокПроектов") Тогда 
			Если ЕстьПроекты Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивПроектов;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = Справочники.Проекты.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		// Kuzmich, 09.04.2024, (ONESOFT-2793) Добавление фильтров в документе распределение затрат на товары
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("КатегорииНоменклатуры") Тогда 
			Если ЕстьКатегорииНоменклатуры Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивКатегорииНоменклатуры;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = Справочники.КатегорииНоменклатуры.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		// Kuzmich, 09.04.2024, (ONESOFT-2793) Добавление фильтров в документе распределение затрат на товары
		
	КонецЦикла;
	
	//Помещаем в переменную данные о расшифровке данных - здесь ненужный пункт, но пусть будет.
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;

	//Формируем макет, с помощью компоновщика макета
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;

	//Передаем в макет компоновки схему, настройки и данные расшифровки
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки, ,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	//Выполним компоновку с помощью процессора компоновки
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки);

	//Выводим результат в табличный документ
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ТаблицаИзСКД = ТаблицаИзСКДОстатки.Выгрузить();
	
	ПроцессорВывода.УстановитьОбъект(ТаблицаИзСКД);

	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Объект.ОстаткиТоваровНаСкладе.Очистить();
	Для Каждого Строк Из ТаблицаИзСКД Цикл
		
		НовСтрокОстатокТоваров = Объект.ОстаткиТоваровНаСкладе.Добавить();
		
		НовСтрокОстатокТоваров.Отметка 				= Истина;
		НовСтрокОстатокТоваров.СтруктурнаяЕдиница 	= Строк.СтруктурнаяЕдиница;
		НовСтрокОстатокТоваров.Номенклатура 		= Строк.Номенклатура;
		НовСтрокОстатокТоваров.Характеристика 		= Строк.Характеристика;
		НовСтрокОстатокТоваров.Количество 			= Строк.Количество;
		НовСтрокОстатокТоваров.СуммаРасходов 		= 0;
		НовСтрокОстатокТоваров.Себистоимость 		= Строк.Себистоимость;
		НовСтрокОстатокТоваров.ДокументПоступления	= Строк.ДокументПоступления; //Малышев 2024-11-29 ONESOFT-3641
		
		//ПодольскийАИ #УчетПроектов 24.12.2020 {
		//Если ЭтоРаспределениеПоПроектам Тогда
			НовСтрокОстатокТоваров.Проект	= Строк.Проект;
		//КонецЕсли;
		//ПодольскийАИ #УчетПроектов 24.12.2020 } 
		Если ИспользоватьПартии Тогда
			НовСтрокОстатокТоваров.Партия	= Строк.Партия;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОстаткиПоТоварам(Команда)
	
	Если Объект.Проведен И ПредыдущаяКонечнаяДатаПериода < Период.ДатаОкончания Тогда 
		Режим = РежимДиалогаВопрос.ДаНет;
		
		Ответ = Вопрос(НСтр("ru='Перед заполнением ""таблица остатков"" требуется распровести документ. Продолжить?';ka='შევსების შემდეგ ცხრილური ნაწილი ""მარაგები"" გასუფთავდება. გაგრძელდეს ?';en='Before filling the ""table balances"" required rasprovesti document. Proceed?'"	), Режим, 0);
		
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		Иначе
			РаспровестиДокумент();
		КонецЕсли;
		
	КонецЕсли;

	Режим = РежимДиалогаВопрос.ДаНет;
	Если Объект.ОстаткиТоваровНаСкладе.Количество() <> 0 Тогда 
		
		Ответ = Вопрос(НСтр("ru='Перед заполнением ""таблица остатков"" будет очищена. Продолжить?';ka='შევსების შემდეგ ცხრილური ნაწილი ""მარაგები"" გასუფთავდება. გაგრძელდეს ?';en='Before filling the ""table residues"" will be cleared. Proceed?'"), Режим, 0);
		
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		Иначе
			ЗаполнитьОстаткиПоТоварамНаСервере();
		КонецЕсли;
		
	Иначе
		ЗаполнитьОстаткиПоТоварамНаСервере();
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура РаспровестиДокумент()

	Попытка
		
		ДокОбъект = ДанныеФормыВЗначение(Объект,Тип("ДокументОбъект.РасспределениеЗатратНаТовары"));
		
		ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		
		ЗначениеВданныеФормы(ДокОбъект,Объект);
		
		ПредыдущаяКонечнаяДатаПериода = Период.ДатаОкончания;
		
	Исключение
		
	КонецПопытки;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОстаткиПоСчетамНаСервере()

	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	//Получаем схему из макета
		
	НаборыДанных = Новый Структура;
		
	СхемаКомпоновкиДанных = ДокументОбъект.ПолучитьМакет("СКД_ОборотыПоСчетамПроектов");
	
	Настройки = КомпоновщикНастроекОборотыПоСчетам.ПолучитьНастройки();//Настройки;
	
	//установка параметров отчета, без КомпоновщикНастроекКомпоновкиДанных делать это гораздо сложнее
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ДатаНачала", ?(ЗначениеЗаполнено(Период.ДатаНачала), Период.ДатаНачала, Дата('00010101')));
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("ДатаОкончания", ?(ЗначениеЗаполнено(Период.ДатаОкончания), Период.ДатаОкончания, Дата('39990101')));
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("Организация", Объект.Организация);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("Ссылка", Объект.Ссылка);
	
	//ПодольскийАИ #БухПроводки 11.01.2022 {
	УстановитьПривилегированныйРежим(Истина);
	УчетБухПроводок = Константы.ПоказыватьБухгалтерскиеПроводки.Получить();
	УстановитьПривилегированныйРежим(Ложь);
	//ПодольскийАИ #БухПроводки 11.01.2022 }
	
	ЕстьСчетаОтбора = ЛОЖЬ;
	МассивСчетов = СчетаУчетаРегл.ВыгрузитьЗначения();
	ЕстьСчетаОтбора = МассивСчетов.Количество() > 0; 
	
	ЕстьПодразделениеОтбора = ЛОЖЬ;
	МассивПодразделений = Подразделение.ВыгрузитьЗначения();
	ЕстьПодразделениеОтбора = МассивПодразделений.Количество() > 0;
	
	//ПодольскийАИ #УчетПроектов 15.12.2020 {
	ЕстьПроектОтбора = ЛОЖЬ;
	МассивПроектов = Проект.ВыгрузитьЗначения();
	ЕстьПроектОтбора = МассивПроектов.Количество() > 0;
	//ПодольскийАИ #УчетПроектов 15.12.2020 }
	
	Для Каждого ЭлемОтбора Из Настройки.Отбор.Элементы Цикл 
		
		//ПодольскийАИ #УчетПроектов 15.12.2020 {
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Проект") Тогда 
			Если ЕстьПроектОтбора Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивПроектов;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = Справочники.Проекты.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		//ПодольскийАИ #УчетПроектов 15.12.2020 }
		
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Подразделение") Тогда 
			Если ЕстьПодразделениеОтбора Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивПодразделений;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		Если ЭлемОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СчетУчета") Тогда 
			Если ЕстьСчетаОтбора Тогда 
				ЭлемОтбора.Использование = Истина;
				ЭлемОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
				ЭлемОтбора.ПравоеЗначение = МассивСчетов;
			Иначе
				ЭлемОтбора.Использование = Ложь;
				ЭлемОтбора.ПравоеЗначение = ПланыСчетов.Хозрасчетный.ПустаяСсылка();
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
	КонецЦикла;
	
	//Помещаем в переменную данные о расшифровке данных - здесь ненужный пункт, но пусть будет.
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;

	//Формируем макет, с помощью компоновщика макета
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;

	//Передаем в макет компоновки схему, настройки и данные расшифровки
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки, ,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

	//Выполним компоновку с помощью процессора компоновки
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки);

	//Выводим результат в табличный документ
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	
	ТаблицаИзСКД = ТаблицаИзСКДОбороты.Выгрузить();
	ТаблицаИзСКД.Очистить();
	
	ПроцессорВывода.УстановитьОбъект(ТаблицаИзСКД);

	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	объект.ОстаткиПоСчетам.Очистить();
	объект.ОстаткиТоваровНаСкладе.Очистить();
	Для Каждого Строк Из ТаблицаИзСКД Цикл
		
		НовСтрокОстатокТоваров = Объект.ОстаткиПоСчетам.Добавить();
		
		НовСтрокОстатокТоваров.СчетУчета			= Строк.СчетУчета;
		НовСтрокОстатокТоваров.Сумма				= Строк.Сумма;
		
		//ПодольскийАИ #учетПроектов 15.12.2020 {
		//Было---
		//НовСтрокОстатокТоваров.СтруктурнаяЕдиница	= Строк.Подразделение;
		//Стало+++
		//Если ЭтоРаспределениеПоПроектам Тогда
			НовСтрокОстатокТоваров.Проект = Строк.Проект;
		//Иначе
			НовСтрокОстатокТоваров.СтруктурнаяЕдиница	= Строк.Подразделение;
		//КонецЕсли;
		//ПодольскийАИ #учетПроектов 15.12.2020 }
		
		//ПодольскийАИ #БухПроводки 11.01.2022 {
		Если УчетБухПроводок Тогда
			НовСтрокОстатокТоваров.ВидСубконто1			= Строк.ВидСубконто1;
			НовСтрокОстатокТоваров.ВидСубконто2			= Строк.ВидСубконто2;
			НовСтрокОстатокТоваров.ВидСубконто3			= Строк.ВидСубконто3;
		КонецЕсли;
		//ПодольскийАИ #БухПроводки 11.01.2022 }
		
		НовСтрокОстатокТоваров.СуммаКотроль			= Строк.Сумма;
		НовСтрокОстатокТоваров.Номенклатура			= Строк.Номенклатура;
		Если ИспользоватьХарактеристики Тогда
			НовСтрокОстатокТоваров.Характеристика		= Строк.Характеристика;
		КонецЕсли;
		//НовСтрокОстатокТоваров.Субконто3			= Строк.Субконто3;
		
	КонецЦикла;
	
	//ПодольскийАИ #учетПроектов 18.12.2020 {
	//Было---
	//Если НЕ ЭтоРаспределениеНаТовары И ЗначениеЗаполнено(Объект.ВнеоборотныйАктив) Тогда 
	//Стало+++
	Если НЕ ЭтоРаспределениеНаТовары И НЕ ЭтоРаспределениеПоПроектам И ЗначениеЗаполнено(Объект.ВнеоборотныйАктив) Тогда 
	//ПодольскийАИ #учетПроектов 18.12.2020 }
		Объект.СтоимостьДляВычисленияАмортизацииНов = Объект.СтоимостьДляВычисленияАмортизацииТек + Объект.ОстаткиПоСчетам.Итог("Сумма");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьОстаткиПоСчетам(Команда)
	
	Режим = РежимДиалогаВопрос.ДаНет;
	Если Объект.ОстаткиПоСчетам.Количество() <> 0 Тогда 
		
		Ответ = Вопрос(НСтр("ru='Перед заполнением ""таблица оборотов"" будет очищена. Продолжить?';ka='შევსების შემდეგ ცხრილური ნაწილი ""დანახარჯები"" გასუფთავდება. გაგრძელდეს ?';en='Before filling the ""speed table"" it will be cleared. Proceed?'"), Режим, 0);
		
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаполнитьОстаткиПоСчетамНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура РаспределитьПоСуммеНаСервере()
	
	Документ = РеквизитФормыВЗначение("Объект");
	Документ.РаспределитьСуммуСчетовНаТоварыПоСумме();
	ЗначениеВРеквизитФормы(Документ, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьПоСумме(Команда)
	
	Если Объект.ОстаткиПоСчетам.Количество() = 0 Тогда
		УправлениеНебольшойФирмойКлиент.СообщитьОбОшибке(Объект, НСтр("ka='ცხრილ ""ანგარიშები""-ში ჩანაწერები არ არის!';ru='В табличной части ""Счета"" нет записей!';en='In the tables of the ""Accounts"" no entries!'"));
		Возврат;
	КонецЕсли;
	
	Если Объект.ОстаткиТоваровНаСкладе.Количество() = 0 Тогда
		УправлениеНебольшойФирмойКлиент.СообщитьОбОшибке(Объект, НСтр("ka='ცხრილ ""ნარჩენები""-ში ჩანაწერები არ არის!';ru='В табличной части ""Остатки"" нет записей!';en='The tables of ""Remains"" no entries!'"));
		Возврат;
	КонецЕсли;
	
	РаспределитьПоСуммеНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура РаспределитьПоКоличествуНаСервере()
	
	Документ = РеквизитФормыВЗначение("Объект");
	Документ.РаспределитьСуммуСчетовНаТоварыПоКоличеству();
	ЗначениеВРеквизитФормы(Документ, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьПоКоличеству(Команда)
	
	Если Объект.ОстаткиПоСчетам.Количество() = 0 Тогда
		УправлениеНебольшойФирмойКлиент.СообщитьОбОшибке(Объект, НСтр("ka='ცხრილ ""ანგარიშები""-ში ჩანაწერები არ არის!';ru='В табличной части ""Счета"" нет записей!';en='In the tables of the ""Accounts"" no entries!'"));
		Возврат;
	КонецЕсли;
	
	Если Объект.ОстаткиТоваровНаСкладе.Количество() = 0 Тогда
		УправлениеНебольшойФирмойКлиент.СообщитьОбОшибке(Объект, НСтр("ka='ცხრილ ""ნარჩენები""-ში ჩანაწერები არ არის!';ru='В табличной части ""Остатки"" нет записей!';en='The tables of ""Remains"" no entries!'"));
		Возврат;
	КонецЕсли;
	
	РаспределитьПоКоличествуНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	ЭтоРаспределениеНаТовары = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары");
	
	// Олег Литвиненко 30.06.23 --->
	ЭтоРаспределениеНаИмущество = Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество");
