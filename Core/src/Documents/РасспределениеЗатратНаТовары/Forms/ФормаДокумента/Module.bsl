#Область ЧтениеОтборов

&НаСервере
Процедура ПрочитатьОтборы(ОбъектДокумента)
	
	ЗагрузитьСписокИзХранилища(СчетаУчетаРегл, ОбъектДокумента.СписокСчетовУчетаРегл);
	ЗагрузитьСписокИзХранилища(Подразделение,  ОбъектДокумента.СписокПодразделений);
	ЗагрузитьСписокИзХранилища(Проект,         ОбъектДокумента.СписокПроектов);
	ЗагрузитьСписокИзХранилища(Номенклатура,   ОбъектДокумента.СписокНоменклатуры);
	ЗагрузитьСписокИзХранилища(Склад,          ОбъектДокумента.СписокСкладов);
	ЗагрузитьСписокИзХранилища(КатегорииНоменклатуры, ОбъектДокумента.СписокКатегорийНоменклатуры);// Kuzmich, 09.04.2024, (ONESOFT-2793) Добавление фильтров в документе распределение затрат на товары
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗагрузитьСписокИзХранилища(Список, Хранилище)
	
	ЗначенияХранилища = Хранилище.Получить();
	
	Если ТипЗнч(ЗначенияХранилища) = Тип("Массив") Тогда
		Список.ЗагрузитьЗначения(ЗначенияХранилища);
	ИначеЕсли ТипЗнч(ЗначенияХранилища) = Тип("СписокЗначений") Тогда
		// Поддержка обратной совместимости: изначально СписокПроектов сохранялся в СписокЗначений, а не в Массив.
		Список.ЗагрузитьЗначения(ЗначенияХранилища.ВыгрузитьЗначения());
	Иначе
		// Другие форматы данных в хранилище значения не поддерживаем. Ничего не делаем.
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

