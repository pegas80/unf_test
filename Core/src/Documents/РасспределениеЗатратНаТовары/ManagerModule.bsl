	Запрос.УстановитьПараметр("ДатаНачала", ?(ЗначениеЗаполнено(ДокументСсылкаРасспределениеЗатратНаТовары.ДатаНачала), ДокументСсылкаРасспределениеЗатратНаТовары.ДатаНачала, Дата('00010101')));
	Запрос.УстановитьПараметр("ДатаОкончания", ?(ЗначениеЗаполнено(ДокументСсылкаРасспределениеЗатратНаТовары.ДатаОкончания), ДокументСсылкаРасспределениеЗатратНаТовары.ДатаОкончания, Дата('39990101')));
	Запрос.УстановитьПараметр("ЗаполнитьПроект", ЗаполнитьПроект);
	
