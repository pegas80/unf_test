
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.Ссылка,
		|	РасспределениеЗатратНаТовары.Номер,
		|	РасспределениеЗатратНаТовары.Дата,
		|	РасспределениеЗатратНаТовары.ДатаНачала,
		|	РасспределениеЗатратНаТовары.ДатаОкончания,
		|	РасспределениеЗатратНаТовары.Организация
		|ПОМЕСТИТЬ ВременнаяТаблицаШапка
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары КАК РасспределениеЗатратНаТовары
		|ГДЕ
		|	РасспределениеЗатратНаТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СчетУчета,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.ВидСубконто1,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.ВидСубконто2,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.ВидСубконто3,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка.Дата КАК Период,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница_Подразделение,
		//ПодольскийАИ #УчетПроектов 16.12.2020 {
		|	Выбор 
		|		Когда &УчетПоПроектам 
		|			Тогда РасспределениеЗатратНаТоварыОстаткиПоСчетам.Проект
		|		Иначе Значение(Справочник.Проекты.ПустаяСсылка)
		|	Конец КАК Проект,
		//ПодольскийАИ #УчетПроектов 16.12.2020 }
		//+++ Дмгг
		|	Выбор 
		|		Когда &ИспользоватьПартии 
		|			Тогда РасспределениеЗатратНаТоварыОстаткиПоСчетам.Партия
		|		Иначе Значение(Справочник.ПартииНоменклатуры.ПустаяСсылка)
		|	Конец КАК Партия,
		//--- Дмгг
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Номенклатура КАК НоменклатураРаспределения,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Характеристика КАК ХарактеристикаРаспределения,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Сумма
		|ПОМЕСТИТЬ ВременнаяТаблицаОборотыПоСчетам
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары.ОстаткиПоСчетам КАК РасспределениеЗатратНаТоварыОстаткиПоСчетам
		|ГДЕ
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.НомерСтроки,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.Организация КАК Организация,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.Дата КАК Период,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Отметка,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Партия, //+++ Дмгг
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница_Склад,
		//ПодольскийАИ #УчетПроектов 24.12.2020 {
		|	Выбор
		|		Когда &УчетПоПроектам
		|			Тогда РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Проект
		|		Иначе Значение(Справочник.Проекты.ПустаяСсылка)
		|	Конец КАК Проект,
		//ПодольскийАИ #УчетПроектов 24.12.2020 }
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Номенклатура,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Номенклатура.СчетУчетаЗапасовРегл КАК СчетУчетаЗапасовРегл,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Характеристика,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.ДокументПоступления, //Малышев 2024-11-29 ONESOFT-3641
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Количество,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Себистоимость,
		|	&ВалютаУчета КАК Валюта,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.СуммаРасходов КАК СуммаРасходов
		|ПОМЕСТИТЬ ВременнаяТаблицаОстаткиТоваров
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары.ОстаткиТоваровНаСкладе КАК РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе
		|ГДЕ
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Отметка
		|	И РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка = &Ссылка
		//ПодольскийАИ #УчетПроектов 16.12.2020 {
		//Было---
		//|	И РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары)
		//Стало+++
		|	И (&УчетПоПроектам И РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам)
		|		ИЛИ РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары))
		//ПодольскийАИ #УчетПроектов 16.12.2020 }
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.ОбъемПродукцииРаботДляВычисленияАмортизацииНов КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СрокИспользованияДляВычисленияАмортизацииНов КАК СрокИспользованияДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СчетЗатратНов КАК СчетЗатрат,
		|	РасспределениеЗатратНаТовары.СтруктурнаяЕдиницаНов КАК СтруктурнаяЕдиница,
		|	РасспределениеЗатратНаТовары.НаправлениеДеятельностиТек КАК НаправлениеДеятельности,
		|	РасспределениеЗатратНаТовары.СчетЗатратРеглНов КАК СчетЗатратРегл,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов КАК СтоимостьДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов - РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииТек КАК РазницаСтоимости,
		|	РасспределениеЗатратНаТовары.НачислятьАмортизациюВТекущемМесяцеНов КАК ПрименитьВТекущемМесяце,
		|	РасспределениеЗатратНаТовары.Организация,
		|	РасспределениеЗатратНаТовары.ВнеоборотныйАктив,
		|	РасспределениеЗатратНаТовары.Ссылка КАК Ссылка,
		|	&ВалютаУчета КАК Валюта,
		|	РасспределениеЗатратНаТовары.Дата КАК Период,
		|	РасспределениеЗатратНаТовары.АдресНовый КАК Адрес,
		|	РасспределениеЗатратНаТовары.ГодовойПроцентАмортизацииДляУменьшенногоОстаткаНов КАК ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
		|	РасспределениеЗатратНаТовары.ЛиквидационнаяСтоимостьДляУменьшенногоОстаткаНов КАК ЛиквидационнаяСтоимостьДляУменьшенногоОстатка
		|ПОМЕСТИТЬ ВременнаяТаблицаИмущество
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары КАК РасспределениеЗатратНаТовары
		|ГДЕ
		|	РасспределениеЗатратНаТовары.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
		|	И РасспределениеЗатратНаТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.ОбъемПродукцииРаботДляВычисленияАмортизацииНов КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СрокИспользованияДляВычисленияАмортизацииНов КАК СрокИспользованияДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СчетЗатратНов КАК СчетЗатрат,
		|	РасспределениеЗатратНаТовары.СтруктурнаяЕдиницаНов КАК СтруктурнаяЕдиница,
		|	РасспределениеЗатратНаТовары.НаправлениеДеятельностиТек КАК НаправлениеДеятельности,
		|	РасспределениеЗатратНаТовары.СчетЗатратРеглНов КАК СчетДт,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов КАК СтоимостьДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов - РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииТек КАК РазницаСтоимости,
		//|	РасспределениеЗатратНаТовары.СчетПереоценкиНов КАК СчетПереоценки,
		//|	РасспределениеЗатратНаТовары.СчетПереоценкиРеглНов КАК СчетПереоценкиРегл,
		|	РасспределениеЗатратНаТовары.НачислятьАмортизациюВТекущемМесяцеНов КАК ПрименитьВТекущемМесяце,
		|	РасспределениеЗатратНаТовары.Организация,
		|	РасспределениеЗатратНаТовары.ВнеоборотныйАктив,
		|	РасспределениеЗатратНаТовары.Дата КАК Период,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СчетУчета КАК СчетКт,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Сумма,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница_Подразделение,
		|	&ВалютаУчета КАК Валюта
		|ПОМЕСТИТЬ ВременнаяТаблицаИмуществоДляХозрасчетного
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары.ОстаткиПоСчетам КАК РасспределениеЗатратНаТоварыОстаткиПоСчетам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасспределениеЗатратНаТовары КАК РасспределениеЗатратНаТовары
		|		ПО РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка = РасспределениеЗатратНаТовары.Ссылка
		|ГДЕ
		|	РасспределениеЗатратНаТовары.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
		|	И РасспределениеЗатратНаТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", 		ДокументСсылкаРасспределениеЗатратНаТовары);
	Запрос.УстановитьПараметр("ВалютаУчета", 		УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета());
	
	//ПодольскийАИ #УчетПроектов 19.12.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 19.12.2020 }
	//+++ Дмгг
	Запрос.УстановитьПараметр("ИспользоватьПартии", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьПартии);
	//--- Дмгг
	
	Запрос.Выполнить();
	// Kuzmuch, 26.07.2024,(ONESOFT-3263) Расспределение затрат на товары - операция: на товары, закомментировал
	//ПодольскийАИ #УчетПроектов 16.12.2020 {
	//Если СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам Тогда
	//	ЗаполнитьРаспределитьСуммыПоИзмерениямПодразделениеПроект(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	//КонецЕсли;
	//ПодольскийАИ #УчетПроектов 16.12.2020 }
	// Kuzmuch, 26.07.2024,(ONESOFT-3263) Расспределение затрат на товары - операция: на товары
	
	СформироватьВременнаяТаблицаВычислениеДолиСуммРаспределения(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	СформироватьВременнаяТаблицаОпределенияСубконто(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьВременнаяТаблицаДанныхСубконто(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_РасспределениеЗатратНаТовары(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	
	СформироватьТаблицаЗапасы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	//СформироватьТаблицаДоходыИРасходы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	СформироватьТаблицаВнеоборотныеАктивы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	СформироватьТаблицаПараметрыВнеоборотныхАктивов(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗапасы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("СодержаниеПроводки", НСТР("ka='Расспределение затрат';ru='Расспределение затрат';en='ALLOTMENT costs'"));
	Запрос.УстановитьПараметр("Период", ДокументСсылкаРасспределениеЗатратНаТовары.Дата);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	2 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.Период КАК Период,
	//|	&Период КАК Период,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Склад КАК СтруктурнаяЕдиница,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение КАК КоррСтруктурнаяЕдиница,
	
	//ПодольскийАИ #УчетПроектов 19.12.2020 {
	|	Выбор
	|		Когда ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.ПоПроектам)
	|			ТОГДА ТаблицаДокумента.Номенклатура.Проект
	//Малышев 2024-08-23 (--
	//|		ИНАЧЕ ТаблицаДокумента.Проект
	|       ИНАЧЕ ТаблицаДокумента.КоррПроект 
	//Малышев 2024-08-23 --)
	|	Конец КАК Проект,
	
	//ПодольскийАИ #УчетПроектов 19.12.2020 }
	//+++ Дмгг
