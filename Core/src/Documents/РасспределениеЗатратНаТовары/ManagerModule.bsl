// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаДоходыИРасходы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("ОтражениеДоходов", НСтр("ka='შემოსავლების ასახვა';ru='Отражение доходов';en='income'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК Порядок,
	|	1 КАК НомерСтроки,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение КАК СтруктурнаяЕдиница,
	|	НЕОПРЕДЕЛЕНО КАК Заказ,
	|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее) КАК НаправлениеДеятельности,
	|	ТаблицаДокумента.СчетУчета.СчетАналогУУ КАК СчетУчета,
	|	ТаблицаДокумента.СчетУчета КАК СчетУчетаРегл,
	|	НЕОПРЕДЕЛЕНО КАК Аналитика,
	|	&ОтражениеДоходов КАК СодержаниеПроводки,
	|	0 КАК СуммаДоходов,
	|	-ТаблицаДокумента.Сумма КАК СуммаРасходов,
	|	-ТаблицаДокумента.Сумма КАК Сумма
	|ИЗ
	|	ВременнаяТаблицаРаспределениеСумм КАК ТаблицаДокумента
	|ГДЕ
	|	НЕ ТаблицаДокумента.СчетУчета.СчетАналогУУ.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.НезавершенноеПроизводство)
	|	И НЕ ТаблицаДокумента.СчетУчета.СчетАналогУУ.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.КосвенныеЗатраты)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	1,
	|	ТаблицаДокумента.Период,
	|	ТаблицаДокумента.Организация,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	ТаблицаДокумента.НаправлениеДеятельности,
	|	ТаблицаДокумента.СчетПереоценки,
	|	ТаблицаДокумента.СчетПереоценкиРегл,
	|	ТаблицаДокумента.ВнеоборотныйАктив,
	|	&ОтражениеДоходов,
	|	ВЫБОР КОГДА ТаблицаДокумента.РазницаСтоимости < 0 ТОГДА 0 Иначе ТаблицаДокумента.РазницаСтоимости КОНЕЦ,
	|	ВЫБОР КОГДА ТаблицаДокумента.РазницаСтоимости < 0 ТОГДА -ТаблицаДокумента.РазницаСтоимости Иначе 0 КОНЕЦ,
	|	ВЫБОР КОГДА ТаблицаДокумента.РазницаСтоимости < 0 ТОГДА -ТаблицаДокумента.РазницаСтоимости Иначе ТаблицаДокумента.РазницаСтоимости КОНЕЦ
	|ИЗ
	|	ВременнаяТаблицаИмущество КАК ТаблицаДокумента";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТаблицаДоходыИРасходы = РегистрыНакопления.ДоходыИРасходы.СоздатьНаборЗаписей().ВыгрузитьКолонки();
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДоходыИРасходы", ТаблицаДоходыИРасходы);
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДоходыИРасходы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Активность = Истина;
	КонецЦикла; 
	
КонецПроцедуры // СформироватьТаблицаДоходыИРасходы()

