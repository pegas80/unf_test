		Запрос.Текст = ПолучитьТекстЗапросаРаспределенияСуммПоПроектам();
		// Kuzmich, 18.07.2027, (ONESOFT-3263) Расспределение затрат на товары - операция: на товары
		СписокПроектов = ДокументСсылкаРасспределениеЗатратНаТовары.СписокПроектов.Получить();
