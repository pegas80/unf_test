
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.Ссылка,
		|	РасспределениеЗатратНаТовары.Номер,
		|	РасспределениеЗатратНаТовары.Дата,
		|	РасспределениеЗатратНаТовары.ДатаНачала,
		|	РасспределениеЗатратНаТовары.ДатаОкончания,
		|	РасспределениеЗатратНаТовары.Организация
		|ПОМЕСТИТЬ ВременнаяТаблицаШапка
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары КАК РасспределениеЗатратНаТовары
		|ГДЕ
		|	РасспределениеЗатратНаТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СчетУчета,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.ВидСубконто1,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.ВидСубконто2,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.ВидСубконто3,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница_Подразделение,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Сумма
		|ПОМЕСТИТЬ ВременнаяТаблицаОборотыПоСчетам
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары.ОстаткиПоСчетам КАК РасспределениеЗатратНаТоварыОстаткиПоСчетам
		|ГДЕ
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.НомерСтроки,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.Организация КАК Организация,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.Дата КАК Период,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Отметка,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница_Склад,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Номенклатура,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Номенклатура.СчетУчетаЗапасовРегл КАК СчетУчетаЗапасовРегл,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Характеристика,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Количество,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Себистоимость,
		|	&ВалютаУчета КАК Валюта,
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.СуммаРасходов КАК СуммаРасходов
		|ПОМЕСТИТЬ ВременнаяТаблицаОстаткиТоваров
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары.ОстаткиТоваровНаСкладе КАК РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе
		|ГДЕ
		|	РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Отметка
		|	И РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка = &Ссылка
		|	И РасспределениеЗатратНаТоварыОстаткиТоваровНаСкладе.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.ОбъемПродукцииРаботДляВычисленияАмортизацииНов КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СрокИспользованияДляВычисленияАмортизацииНов КАК СрокИспользованияДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СчетЗатратНов КАК СчетЗатрат,
		|	РасспределениеЗатратНаТовары.СтруктурнаяЕдиницаНов КАК СтруктурнаяЕдиница,
		|	РасспределениеЗатратНаТовары.НаправлениеДеятельностиТек КАК НаправлениеДеятельности,
		|	РасспределениеЗатратНаТовары.СчетЗатратРеглНов КАК СчетЗатратРегл,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов КАК СтоимостьДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов - РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииТек КАК РазницаСтоимости,
		|	РасспределениеЗатратНаТовары.НачислятьАмортизациюВТекущемМесяцеНов КАК ПрименитьВТекущемМесяце,
		|	РасспределениеЗатратНаТовары.Организация,
		|	РасспределениеЗатратНаТовары.ВнеоборотныйАктив,
		|	РасспределениеЗатратНаТовары.Ссылка КАК Ссылка,
		|	&ВалютаУчета КАК Валюта,
		|	РасспределениеЗатратНаТовары.Дата КАК Период
		|ПОМЕСТИТЬ ВременнаяТаблицаИмущество
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары КАК РасспределениеЗатратНаТовары
		|ГДЕ
		|	РасспределениеЗатратНаТовары.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
		|	И РасспределениеЗатратНаТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.ОбъемПродукцииРаботДляВычисленияАмортизацииНов КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СрокИспользованияДляВычисленияАмортизацииНов КАК СрокИспользованияДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СчетЗатратНов КАК СчетЗатрат,
		|	РасспределениеЗатратНаТовары.СтруктурнаяЕдиницаНов КАК СтруктурнаяЕдиница,
		|	РасспределениеЗатратНаТовары.НаправлениеДеятельностиТек КАК НаправлениеДеятельности,
		|	РасспределениеЗатратНаТовары.СчетЗатратРеглНов КАК СчетДт,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов КАК СтоимостьДляВычисленияАмортизации,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииНов - РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизацииТек КАК РазницаСтоимости,
		//|	РасспределениеЗатратНаТовары.СчетПереоценкиНов КАК СчетПереоценки,
		//|	РасспределениеЗатратНаТовары.СчетПереоценкиРеглНов КАК СчетПереоценкиРегл,
		|	РасспределениеЗатратНаТовары.НачислятьАмортизациюВТекущемМесяцеНов КАК ПрименитьВТекущемМесяце,
		|	РасспределениеЗатратНаТовары.Организация,
		|	РасспределениеЗатратНаТовары.ВнеоборотныйАктив,
		|	РасспределениеЗатратНаТовары.Дата КАК Период,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СчетУчета КАК СчетКт,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.Сумма,
		|	РасспределениеЗатратНаТоварыОстаткиПоСчетам.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница_Подразделение,
		|	&ВалютаУчета КАК Валюта
		|ПОМЕСТИТЬ ВременнаяТаблицаИмуществоДляХозрасчетного
		|ИЗ
		|	Документ.РасспределениеЗатратНаТовары.ОстаткиПоСчетам КАК РасспределениеЗатратНаТоварыОстаткиПоСчетам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасспределениеЗатратНаТовары КАК РасспределениеЗатратНаТовары
		|		ПО РасспределениеЗатратНаТоварыОстаткиПоСчетам.Ссылка = РасспределениеЗатратНаТовары.Ссылка
		|ГДЕ
		|	РасспределениеЗатратНаТовары.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
		|	И РасспределениеЗатратНаТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", 		ДокументСсылкаРасспределениеЗатратНаТовары);
	Запрос.УстановитьПараметр("ВалютаУчета", 		УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета());
	Запрос.Выполнить();
	
	СформироватьВременнаяТаблицаВычислениеДолиСуммРаспределения(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	СформироватьВременнаяТаблицаОпределенияСубконто(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьВременнаяТаблицаДанныхСубконто(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_РасспределениеЗатратНаТовары(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	
	СформироватьТаблицаЗапасы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	//СформироватьТаблицаДоходыИРасходы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	СформироватьТаблицаВнеоборотныеАктивы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	СформироватьТаблицаПараметрыВнеоборотныхАктивов(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗапасы(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("СодержаниеПроводки", НСТР("ka='Расспределение затрат';ru='Расспределение затрат';en='ALLOTMENT costs'"));
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Склад КАК СтруктурнаяЕдиница,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение КАК КоррСтруктурнаяЕдиница,
	|	ТаблицаДокумента.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары)
	|			ТОГДА ТаблицаДокумента.Номенклатура.СчетУчетаЗапасовРегл.СчетАналогУУ
	|		КОГДА ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
	|			ТОГДА ТаблицаДокумента.Номенклатура.СчетУчетаРегл.СчетАналогУУ
	|	КОНЕЦ КАК СчетУчета,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары)
	|			ТОГДА ТаблицаДокумента.Номенклатура.СчетУчетаЗапасовРегл
	|		КОГДА ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
	|			ТОГДА ТаблицаДокумента.Номенклатура.СчетУчетаРегл
	|	КОНЕЦ КАК СчетУчетаРегл,
	|	ТаблицаДокумента.Номенклатура.СчетУчетаЗатрат КАК СчетУчетаЗатрат,
	|	ТаблицаДокумента.Номенклатура.СчетУчетаЗатратРегл КАК СчетУчетаЗатратРегл,
	|	ТаблицаДокумента.СчетУчета КАК КоррСчетУчетаРегл,
	|	ТаблицаДокумента.СчетУчета.СчетАналогУУ КАК КоррСчетУчета,
	|	ТаблицаДокумента.Характеристика КАК Характеристика,
	|	ТаблицаДокумента.Номенклатура КАК КоррНоменклатура,
	|	ТаблицаДокумента.Характеристика КАК КоррХарактеристика,
	|	0 КАК Количество,
	|	&СодержаниеПроводки КАК СодержаниеПроводки,
	|	ТаблицаДокумента.Сумма КАК Сумма
	|ИЗ
	|	ВременнаяТаблицаРаспределениеСумм КАК ТаблицаДокумента
	|ГДЕ
	|	ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.Период,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Склад,
	|	Значение(Справочник.Номенклатура.ПустаяСсылка),//ТаблицаДокумента.Номенклатура,
	|	ТаблицаДокумента.СчетУчета.СчетАналогУУ,
	|	ТаблицаДокумента.СчетУчета,
	|	NULL,
	|	NULL,
	|	ТаблицаДокумента.Номенклатура.СчетУчетаЗапасовРегл,
	|	ТаблицаДокумента.Номенклатура.СчетУчетаЗапасов,
	|	Значение(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),//ТаблицаДокумента.Характеристика,
	|	ТаблицаДокумента.Номенклатура,
	|	Значение(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),//ТаблицаДокумента.Характеристика,
	|	0,
	|	&СодержаниеПроводки,
	|	ТаблицаДокумента.Сумма
	|ИЗ
	|	ВременнаяТаблицаРаспределениеСумм КАК ТаблицаДокумента
	|ГДЕ
	|	(ТаблицаДокумента.СчетУчета.СчетАналогУУ.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.НезавершенноеПроизводство)
	|			ИЛИ ТаблицаДокумента.СчетУчета.СчетАналогУУ.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.КосвенныеЗатраты))";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасы", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаЗапасы()

// Подготовка таблицы для определения Субконто
// в колонках временной таблицы на выходе должны быть СчетДт, СчетКт и колонки с именами всех сумконто
Процедура СформироватьВременнаяТаблицаОпределенияСубконто(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.НаТовары)
	|			ТОГДА ТаблицаДокумента.Номенклатура.СчетУчетаЗапасовРегл
	|		КОГДА ТаблицаДокумента.Ссылка.ВидОперации = ЗНАЧЕНИЕ(ПЕРеЧИСЛЕНИЕ.ВидыОперацийРасспределениеЗатратНаТовары.НаИмущество)
	|			ТОГДА ТаблицаДокумента.Номенклатура.СчетУчетаРегл
	|	КОНЕЦ КАК СчетДт,
	|	ТаблицаДокумента.СчетУчета КАК СчетКт,
	|	ТаблицаДокумента.Сумма КАК Сумма,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.Валюта КАК Валюта,
	|	НЕОПРЕДЕЛЕНО КАК ПродавцыДт,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Склад КАК ПодразделенияДт,
	|	НЕОПРЕДЕЛЕНО КАК СчетФактураПокупателяДт,
	|	ТаблицаДокумента.Валюта КАК ВалютыДт,
	|	НЕОПРЕДЕЛЕНО КАК СотрудникиДт,
	|	ТаблицаДокумента.Номенклатура КАК СотрудникНоменклатураДт,
	|	НЕОПРЕДЕЛЕНО КАК КонтрагентыСотрудникиДт,
	|	НЕОПРЕДЕЛЕНО КАК КонтрагентыДт,
	|	НЕОПРЕДЕЛЕНО КАК СчетФактураПоставщикаДт,
	|	ТаблицаДокумента.Номенклатура КАК НоменклатураДт,
	|	ТаблицаДокумента.Характеристика КАК ХарактеристикиНоменклатурыДт,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение КАК ОбособленныеПодразделенияДт,
	|	ТаблицаДокумента.Номенклатура КАК ПродукцияДт,
	|	НЕОПРЕДЕЛЕНО КАК БанковскиеСчетаДт,
	|	НЕОПРЕДЕЛЕНО КАК КассаДт,
	|	НЕОПРЕДЕЛЕНО КАК СтавкиНДФЛДт,
	|	ТаблицаДокумента.Ссылка КАК ДокументДт,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Склад КАК СкладыДт,
	|	НЕОПРЕДЕЛЕНО КАК ТипыСуммГрафикаКредитовИЗаймовДт,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорыКредитовИЗаймовДт,
	|	НЕОПРЕДЕЛЕНО КАК НомераГТДДт,
	|	НЕОПРЕДЕЛЕНО КАК РаботникиОрганизацийДт,
	|	НЕОПРЕДЕЛЕНО КАК СтатьиДвиженияДенежныхСредствДт,
	|	ТаблицаДокумента.Номенклатура КАК ИмуществоДт,
	|	НЕОПРЕДЕЛЕНО КАК ДокументыРасчетовСКонтрагентамиДт,
	|	НЕОПРЕДЕЛЕНО КАК ПартииДт,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорыДт,
	|	ТаблицаДокумента.Номенклатура КАК ОСТСДт,
	|	НЕОПРЕДЕЛЕНО КАК ПродавцыКт,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение КАК ПодразделенияКт,
	|	НЕОПРЕДЕЛЕНО КАК СчетФактураПокупателяКт,
	|	ТаблицаДокумента.Валюта КАК ВалютыКт,
	|	НЕОПРЕДЕЛЕНО КАК СотрудникиКт,
	|	ТаблицаДокумента.Номенклатура КАК СотрудникНоменклатураКт,
	|	НЕОПРЕДЕЛЕНО КАК КонтрагентыСотрудникиКт,
	|	НЕОПРЕДЕЛЕНО КАК КонтрагентыКт,
	|	НЕОПРЕДЕЛЕНО КАК СчетФактураПоставщикаКт,
	|	ТаблицаДокумента.Номенклатура КАК НоменклатураКт,
	|	ТаблицаДокумента.Характеристика КАК ХарактеристикиНоменклатурыКт,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Подразделение КАК ОбособленныеПодразделенияКт,
	|	ТаблицаДокумента.Номенклатура КАК ПродукцияКт,
	|	НЕОПРЕДЕЛЕНО КАК БанковскиеСчетаКт,
	|	НЕОПРЕДЕЛЕНО КАК КассаКт,
	|	НЕОПРЕДЕЛЕНО КАК СтавкиНДФЛКт,
	|	ТаблицаДокумента.СтруктурнаяЕдиница_Склад КАК СкладыКт,
	|	НЕОПРЕДЕЛЕНО КАК ТипыСуммГрафикаКредитовИЗаймовКт,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорыКредитовИЗаймовКт,
	|	НЕОПРЕДЕЛЕНО КАК НомераГТДКт,
	|	НЕОПРЕДЕЛЕНО КАК РаботникиОрганизацийКт,
	|	НЕОПРЕДЕЛЕНО КАК СтатьиДвиженияДенежныхСредствКт,
	|	ТаблицаДокумента.Номенклатура КАК ИмуществоКт,
	|	НЕОПРЕДЕЛЕНО КАК ДокументыРасчетовСКонтрагентамиКт,
	|	ТаблицаДокумента.Ссылка КАК ДокументКт,
	|	НЕОПРЕДЕЛЕНО КАК ПартииКт,
	|	НЕОПРЕДЕЛЕНО КАК ДоговорыКт,
	|	ТаблицаДокумента.Номенклатура КАК ОСТСКт
	|ПОМЕСТИТЬ ВременнаяТаблицаОпределенияСубконто
	|ИЗ
	|	ВременнаяТаблицаРаспределениеСумм КАК ТаблицаДокумента";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	//СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасы", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

Процедура СформироватьВременнаяТаблицаВычислениеДолиСуммРаспределения(ДокументСсылкаРасспределениеЗатратНаТовары, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВременнаяТаблицаОстаткиТоваров.Номенклатура КАК Номенклатура,
		|	ВременнаяТаблицаОстаткиТоваров.Характеристика КАК Характеристика,
		|	ВременнаяТаблицаОстаткиТоваров.СтруктурнаяЕдиница_Склад КАК СтруктурнаяЕдиница_Склад,
		|	ВременнаяТаблицаОстаткиТоваров.Количество КАК Количество,
		|	ВременнаяТаблицаОстаткиТоваров.Себистоимость КАК Себистоимость,
		|	ВременнаяТаблицаОстаткиТоваров.Ссылка КАК Ссылка,
		|	ВременнаяТаблицаОстаткиТоваров.Организация КАК Организация,
		|	ВременнаяТаблицаОстаткиТоваров.Период КАК Период,
		|	ВременнаяТаблицаОстаткиТоваров.Валюта КАК Валюта,
		|	ВременнаяТаблицаОстаткиТоваров.СуммаРасходов КАК СуммаРасходов
		|ПОМЕСТИТЬ ВТ_ОстаткиТоваров
		|ИЗ
		|	ВременнаяТаблицаОстаткиТоваров КАК ВременнаяТаблицаОстаткиТоваров
		|ГДЕ
		|	ВременнаяТаблицаОстаткиТоваров.Отметка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РасспределениеЗатратНаТовары.ВнеоборотныйАктив,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
		|	РасспределениеЗатратНаТовары.СтруктурнаяЕдиница,
		|	1,
		|	РасспределениеЗатратНаТовары.СтоимостьДляВычисленияАмортизации - РасспределениеЗатратНаТовары.РазницаСтоимости,
		|	РасспределениеЗатратНаТовары.Ссылка,
		|	РасспределениеЗатратНаТовары.Организация,
		|	РасспределениеЗатратНаТовары.Период,
		|	РасспределениеЗатратНаТовары.Валюта,
		|	РасспределениеЗатратНаТовары.РазницаСтоимости
		|ИЗ
		|	ВременнаяТаблицаИмущество КАК РасспределениеЗатратНаТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблицаОборотыПоСчетам.СчетУчета КАК СчетУчета,
		|	ВременнаяТаблицаОборотыПоСчетам.СтруктурнаяЕдиница_Подразделение КАК СтруктурнаяЕдиница_Подразделение,
		|	ВременнаяТаблицаОборотыПоСчетам.ВидСубконто1 КАК ВидСубконто1,
		|	ВременнаяТаблицаОборотыПоСчетам.ВидСубконто2 КАК ВидСубконто2,
		|	ВременнаяТаблицаОборотыПоСчетам.ВидСубконто3 КАК ВидСубконто3,
		|	ВЫРАЗИТЬ(ВременнаяТаблицаОборотыПоСчетам.Сумма КАК ЧИСЛО(15, 2)) КАК Сумма
		|ПОМЕСТИТЬ ВТ_Обороты
		|ИЗ
		|	ВременнаяТаблицаОборотыПоСчетам КАК ВременнаяТаблицаОборотыПоСчетам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТ_Обороты.Сумма) КАК Сумма
		|ПОМЕСТИТЬ ВТ_ОборотыГрупп
		|ИЗ
		|	ВТ_Обороты КАК ВТ_Обороты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ОстаткиТоваров.Номенклатура КАК Номенклатура,
		|	ВТ_ОстаткиТоваров.Характеристика КАК Характеристика,
		|	ВТ_ОстаткиТоваров.СуммаРасходов КАК СуммаРасходов,
		|	ВТ_Обороты.СчетУчета КАК СчетУчета,
		|	ВТ_Обороты.Сумма КАК СуммаПоСчету,
		|	ВТ_ОборотыГрупп.Сумма КАК СуммаГрупп,
		|	ВТ_ОборотыГрупп.Сумма / ВТ_ОстаткиТоваров.СуммаРасходов КАК Коэф,
		|	ВЫРАЗИТЬ(ВТ_Обороты.Сумма / (ВТ_ОборотыГрупп.Сумма / ВТ_ОстаткиТоваров.СуммаРасходов) КАК ЧИСЛО(15, 2)) КАК ЧастьСуммы,
		|	ВТ_Обороты.СтруктурнаяЕдиница_Подразделение,
		|	ВТ_Обороты.ВидСубконто1,
		|	ВТ_Обороты.ВидСубконто2,
		|	ВТ_Обороты.ВидСубконто3,
		|	ВТ_ОстаткиТоваров.СтруктурнаяЕдиница_Склад,
		|	ВТ_ОстаткиТоваров.Количество,
		|	ВТ_ОстаткиТоваров.Себистоимость,
		|	ВТ_ОстаткиТоваров.Валюта,
		|	ВТ_ОстаткиТоваров.Организация,
		|	ВТ_ОстаткиТоваров.Период,
		|	ВТ_ОстаткиТоваров.Ссылка
		|ПОМЕСТИТЬ ВТРаспред
		|ИЗ
		|	ВТ_ОстаткиТоваров КАК ВТ_ОстаткиТоваров,
		|	ВТ_Обороты КАК ВТ_Обороты,
		|	ВТ_ОборотыГрупп КАК ВТ_ОборотыГрупп
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТРаспред.ЧастьСуммы) КАК МаксЧасть,
		|	ВТРаспред.СуммаПоСчету,
		|	СУММА(ВТРаспред.ЧастьСуммы) КАК ЧастьСуммы,
		|	ВТРаспред.СуммаПоСчету - СУММА(ВТРаспред.ЧастьСуммы) КАК Разница,
		|	ВТРаспред.СчетУчета
		|ПОМЕСТИТЬ ВТ_РаспредГруппПроверка
		|ИЗ
		|	ВТРаспред КАК ВТРаспред
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТРаспред.СуммаПоСчету,
		|	ВТРаспред.СчетУчета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_РаспредГруппПроверка.МаксЧасть КАК МаксЧасть,
		|	ВТ_РаспредГруппПроверка.СуммаПоСчету КАК СуммаПоСчету,
		|	ВТ_РаспредГруппПроверка.ЧастьСуммы КАК ЧастьСуммы,
		|	ВТ_РаспредГруппПроверка.Разница КАК Разница,
		|	ВТ_РаспредГруппПроверка.СчетУчета КАК СчетУчета,
		|	ВТРаспред.Номенклатура КАК Номенклатура,
		|	ВТРаспред.Характеристика КАК Характеристика,
		|	МАКСИМУМ(ВТРаспред.Себистоимость) КАК Себистоимость
		|ПОМЕСТИТЬ ВТ_РаспредГруппПроверка2
		|ИЗ
		|	ВТ_РаспредГруппПроверка КАК ВТ_РаспредГруппПроверка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРаспред КАК ВТРаспред
		|		ПО ВТ_РаспредГруппПроверка.СуммаПоСчету = ВТРаспред.СуммаПоСчету
		|			И ВТ_РаспредГруппПроверка.МаксЧасть = ВТРаспред.ЧастьСуммы
		|			И ВТ_РаспредГруппПроверка.СчетУчета = ВТРаспред.СчетУчета
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_РаспредГруппПроверка.МаксЧасть,
		|	ВТ_РаспредГруппПроверка.СуммаПоСчету,
		|	ВТ_РаспредГруппПроверка.ЧастьСуммы,
		|	ВТ_РаспредГруппПроверка.Разница,
		|	ВТ_РаспредГруппПроверка.СчетУчета,
		|	ВТРаспред.Номенклатура,
		|	ВТРаспред.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТРаспред.Номенклатура КАК Номенклатура,
		|	ВТРаспред.Характеристика КАК Характеристика,
		|	МИНИМУМ(ВТРаспред.ЧастьСуммы) КАК МинимальнаяЧасть,
		|	СУММА(ВТРаспред.ЧастьСуммы) КАК ЧастьСуммы,
		|	ВТРаспред.СчетУчета,
		|	ВТРаспред.СтруктурнаяЕдиница_Подразделение,
		|	ВТРаспред.ВидСубконто1,
		|	ВТРаспред.ВидСубконто2,
		|	ВТРаспред.ВидСубконто3,
		|	ВТРаспред.СтруктурнаяЕдиница_Склад,
		|	ВТРаспред.Количество,
		|	ВТРаспред.Себистоимость,
		|	ВТРаспред.Валюта
		|ПОМЕСТИТЬ ВТ_РаспредГрупп
		|ИЗ
		|	ВТРаспред КАК ВТРаспред
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТРаспред.Номенклатура,
		|	ВТРаспред.Характеристика,
		|	ВТРаспред.СчетУчета,
		|	ВТРаспред.СтруктурнаяЕдиница_Подразделение,
		|	ВТРаспред.ВидСубконто3,
		|	ВТРаспред.СтруктурнаяЕдиница_Склад,
		|	ВТРаспред.ВидСубконто1,
		|	ВТРаспред.ВидСубконто2,
		|	ВТРаспред.Количество,
		|	ВТРаспред.Себистоимость,
		|	ВТРаспред.Валюта
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТРаспред.Номенклатура КАК Номенклатура,
		|	ВТРаспред.Характеристика КАК Характеристика,
		|	ВТРаспред.СуммаРасходов КАК СуммаРасходов,
		|	ВТРаспред.СчетУчета КАК СчетУчета,
		|	ВТРаспред.СуммаПоСчету КАК СуммаПоСчету,
		|	ВТРаспред.СуммаГрупп КАК СуммаГрупп,
		|	ВТРаспред.Коэф КАК Коэф,
		|	ВТРаспред.ЧастьСуммы КАК ЧастьСуммы,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_РаспредГрупп.ЧастьСуммы, 0) = 0
		|			ТОГДА 0
		|		ИНАЧЕ ВТ_РаспредГрупп.ЧастьСуммы
		|	КОНЕЦ КАК СуммаПоСчетуРаспределение,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_РаспредГрупп.МинимальнаяЧасть, 0) = 0
		|			ТОГДА ВТРаспред.ЧастьСуммы
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ВТРаспред.СуммаПоСчету - ВЫБОР
		|						КОГДА ЕСТЬNULL(ВТ_РаспредГрупп.ЧастьСуммы, 0) = 0
		|							ТОГДА ВТРаспред.СуммаПоСчету
		|						ИНАЧЕ ВТ_РаспредГрупп.ЧастьСуммы
		|					КОНЕЦ = 0
		|					ТОГДА ВТ_РаспредГрупп.МинимальнаяЧасть
