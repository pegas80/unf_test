
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ЭтотОбъект, ДанныеЗаполнения);
		
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения);
		Если ДанныеЗаполнения.Свойство("ДокументыОснования") Тогда
			Для Каждого ДокументОснование Из ДанныеЗаполнения.ДокументыОснования Цикл
				НоваяСтрока = ДокументыОснования.Добавить();
				НоваяСтрока.ДокументОснование = ДокументОснование;
			КонецЦикла;
		КонецЕсли;
	ИначеЕсли  Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(ДанныеЗаполнения))Тогда 
		ЗаполнитьДанныеДляОбмена(ДанныеЗаполнения);
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Отпустил) Тогда
		Отпустил = "";
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Получил) Тогда
		Получил = "";
	КонецЕсли;
	
	ДругойТранспорт = Константы.ТипТранспортировкиДрогое.Получить();
	
КонецПроцедуры

Процедура ЗаполнитьДанныеДляОбмена(СсылкаНаДокумент)
	Дата = ТекущаяДата();
	ИспользоватьАдресИзДоговораДляТТН = Константы.ОПТИМУС_ИспользоватьАдресИзДоговораДляТТН.Получить();
		
	
	Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		МобильныйСклад = СсылкаНаДокумент.СтруктурнаяЕдиница.МобильныйСклад;//Перем
		Договор = СсылкаНаДокумент.Договор;//Перем
		АдресПоДоговору = СсылкаНаДокумент.Договор.Адрес;
		АдресКонтрагента = УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.Контрагент, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);

		
		ТипТН 					= ?((СсылкаНаДокумент.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратСОтветхранения Или
									СсылкаНаДокумент.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаНаОтветхранение ИЛИ СсылкаНаДокумент.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаВПереработку)  
									,Перечисления.РС_ТипыТН.ВнутреннееПеремещение, ?(МобильныйСклад, Перечисления.РС_ТипыТН.ПодчиненнаяТН, Перечисления.РС_ТипыТН.РеализацияСТранспортировкой));
		ВидТранспортировки 		= Перечисления.РС_ВидыТранспортировки.Автомобильная;
		ГрузоОтправитель   		= СсылкаНаДокумент.Организация;
		АдресОтправки 			= УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
		ГрузоПолучатель         = СсылкаНаДокумент.Контрагент;
		АдресДоставки 			= ?(ИспользоватьАдресИзДоговораДляТТН, АдресПоДоговору,АдресКонтрагента);
		Если НЕ МобильныйСклад Тогда
			ТранспортноеСредство 	= Договор.ТранспортноеСредство;
			ГосНомерАвтомобиля	 	= ТранспортноеСредство.Код;
			Водитель			 	= Договор.Водитель;
			НомерУдостоверения   	= Водитель.ИНН;
		КонецЕсли;
		
		//Перевозчик			= СсылкаНаДокумент.Организация;
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ПеренестиКомментарийВДокументЭлектроннаяНакладная") Тогда
			КомментарийТН			= СсылкаНаДокумент.Комментарий;
		КонецЕсли;
	ИначеЕсли ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		МобильныйСклад = СсылкаНаДокумент.СтруктурнаяЕдиницаРезерв.МобильныйСклад;//Перем
		Договор = СсылкаНаДокумент.Договор;//Перем
		АдресПоДоговору = СсылкаНаДокумент.Договор.Адрес;
		АдресКонтрагента = УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.Контрагент, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);
		
		
		ТипТН 					= Перечисления.РС_ТипыТН.РеализацияСТранспортировкой;
		ВидТранспортировки 		= Перечисления.РС_ВидыТранспортировки.Автомобильная;
		ГрузоОтправитель   		= СсылкаНаДокумент.Организация;
		АдресОтправки 			= УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.СтруктурнаяЕдиницаРезерв, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
		ГрузоПолучатель         = СсылкаНаДокумент.Контрагент;
		АдресДоставки 			= ?(ИспользоватьАдресИзДоговораДляТТН, АдресПоДоговору,АдресКонтрагента);
		Если НЕ МобильныйСклад Тогда
			ТранспортноеСредство 	= Договор.ТранспортноеСредство;
			ГосНомерАвтомобиля	 	= ТранспортноеСредство.Код;
			Водитель			 	= Договор.Водитель;
			НомерУдостоверения   	= Водитель.ИНН;
		КонецЕсли;
		
		//Перевозчик			= СсылкаНаДокумент.Организация;
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ПеренестиКомментарийВДокументЭлектроннаяНакладная") Тогда
			КомментарийТН			= СсылкаНаДокумент.Комментарий;
		КонецЕсли;			
	ИначеЕсли ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		
		Договор = СсылкаНаДокумент.Договор;//перем
		
		АдресПоДоговору = СсылкаНаДокумент.Договор.Адрес;
		АдресКонтрагента = УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.Контрагент, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента);

		
		ТипТН 					= Перечисления.РС_ТипыТН.ВозвратОтПокупателя;
		ВидТранспортировки 		= Перечисления.РС_ВидыТранспортировки.Автомобильная;
		ГрузоОтправитель 		= СсылкаНаДокумент.Контрагент;
		АдресОтправки	 		= ?(ИспользоватьАдресИзДоговораДляТТН, АдресПоДоговору,АдресКонтрагента);		
		ГрузоПолучатель 		= СсылкаНаДокумент.Организация;
		АдресДоставки   		= УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
		ТранспортноеСредство 	= Договор.ТранспортноеСредство;
		ГосНомерАвтомобиля	 	= ТранспортноеСредство.Код;		
		Водитель			 	= Договор.Водитель;
		НомерУдостоверения   	= Водитель.ИНН;
		//Перевозчик			= СсылкаНаДокумент.Организация;
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ПеренестиКомментарийВДокументЭлектроннаяНакладная") Тогда
			КомментарийТН			= СсылкаНаДокумент.Комментарий;
		КонецЕсли;

	ИначеЕсли ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
		ФактАдрес = Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы;		
		
		Если СсылкаНаДокумент.СтруктурнаяЕдиницаПолучатель.МобильныйСклад Тогда
			ТипТН 					= Перечисления.РС_ТипыТН.Дистрибуция;
			ТранспортноеСредство 	= СсылкаНаДокумент.СтруктурнаяЕдиницаПолучатель.ТранспортноеСредство;
			ГосНомерАвтомобиля	 	= ТранспортноеСредство.Код;
			Водитель			 	= ТранспортноеСредство.ОсновнойВодитель;
			НомерУдостоверения   	= Водитель.ИНН;
		Иначе
			ТипТН 					= Перечисления.РС_ТипыТН.ВнутреннееПеремещение;
		КонецЕсли;
		ВидТранспортировки 		= Перечисления.РС_ВидыТранспортировки.Автомобильная;
		ГрузоОтправитель 		= Организация;
		АдресОтправки	 		= УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.СтруктурнаяЕдиница,				ФактАдрес);
		ГрузоПолучатель 		= Организация;
		АдресДоставки 			= УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(СсылкаНаДокумент.СтруктурнаяЕдиницаПолучатель,	ФактАдрес);		
		//Перевозчик			= СсылкаНаДокумент.Организация;
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ПеренестиКомментарийВДокументЭлектроннаяНакладная") Тогда
			КомментарийТН			= СсылкаНаДокумент.Комментарий;
		КонецЕсли;
		//ВидЦены				= УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("ВидыЦен", "Оптовая");
		
		//ТранспортноеСредство = СсылкаНаДокумент.Договор.ТранспортноеСредство;
		//Водитель			 = СсылкаНаДокумент.Договор.Водитель;
		//НомерУдостоверения   = Водитель.ИНН;
		//ГосНомерАвтомобиля	 = ТранспортноеСредство.Код;
	ИначеЕсли ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПеремещениеВА") Тогда
		
		ТипТН 					= Перечисления.РС_ТипыТН.ВнутреннееПеремещение;
		ВидТранспортировки 		= Перечисления.РС_ВидыТранспортировки.Автомобильная;
		ГрузоОтправитель 		= Организация;
		АдресОтправки	 		= ?(СсылкаНаДокумент.ВнеоборотныеАктивы.Количество() = 0, "", СсылкаНаДокумент.ВнеоборотныеАктивы[0].Адрес);
		ГрузоПолучатель 		= Организация;
		АдресДоставки 			= ?(СсылкаНаДокумент.ВнеоборотныеАктивы.Количество() = 0, "", СсылкаНаДокумент.ВнеоборотныеАктивы[0].АдресПолучатель);		
		//Перевозчик			= СсылкаНаДокумент.Организация;
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ПеренестиКомментарийВДокументЭлектроннаяНакладная") Тогда
			КомментарийТН			= СсылкаНаДокумент.Комментарий;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры // ()

Функция СформироватьТаблицуЭлНакладных() Экспорт 
	
	Организация_СоответствиеНоменклатур = Организация.СоответствиеНоменклатур;
	ВнутреннееПеремещение				= (ТипТН = Перечисления.РС_ТипыТН.ВнутреннееПеремещение);
	ПредставлениеНоменклатуры			= ?(Организация.ОтправитьПолноеНаименованиеНоменклатуры, "НаименованиеПолное", "Наименование");
	ТоварыЭлНакладных.Очистить();

	НоменклатураИмущество = "Номенклатура";
	Если ДокументыОснования.Количество() = 0 Тогда
		ЭтаПеремещениеВА = Ложь;
	Иначе
		Если ТипЗнч(ДокументыОснования[0].ДокументОснование) = Тип("ДокументСсылка.ПеремещениеВА") Тогда
			ЭтаПеремещениеВА = Истина;
			НоменклатураИмущество = "Имущество"
		Иначе
			ЭтаПеремещениеВА = Ложь;
		КонецЕсли;		
	КонецЕсли;
	
	Для каждого СтрТаб Из Товары  Цикл
		СтрЭлНТаб = ТоварыЭлНакладных.Добавить();
		
		Если Не ЗначениеЗаполнено(СтрТаб[НоменклатураИмущество]) Тогда 
			Продолжить;
		КонецЕсли;
		//("GOODS"); //GOODS

		СтрЭлНТаб.ID       = 0;//СтрТаб.НомерСтроки-1 Паганини
		Если ЭтаПеремещениеВА Тогда
			СтрЭлНТаб.W_NAME   = Строка(СтрТаб.Имущество);
			СтрЭлНТаб.BAR_CODE = СтрТаб.Имущество.Код;
		Иначе
			СтрЭлНТаб.W_NAME   = ПредставлениеНоменклатуры(СтрТаб.Номенклатура[ПредставлениеНоменклатуры],СтрТаб.Характеристика,СтрТаб.Партия);
			Если Организация_СоответствиеНоменклатур = Перечисления.СоответствияНоменклатуры.ПоАртикулу Тогда
				СтрЭлНТаб.BAR_CODE = СтрТаб.Номенклатура.Артикул;
			ИначеЕсли Организация_СоответствиеНоменклатур = Перечисления.СоответствияНоменклатуры.ПоШтрихкоду Тогда
				СтрЭлНТаб.BAR_CODE = ПолучитьКодШтрихКода(СтрТаб);
			ИначеЕсли Организация.СоответствиеНоменклатур = Перечисления.СоответствияНоменклатуры.ПоХарактеристике Тогда
				СтрЭлНТаб.BAR_CODE = ПолучитьКодХарактеристики(СтрТаб);        
			Иначе
				СтрЭлНТаб.BAR_CODE = СтрТаб.Номенклатура.Код;
			КонецЕсли;
		КонецЕсли;
		
		СтрЭлНТаб.UNIT_ID  = СтрТаб.ЕдиницаИзмерения.КодДляНалоговой;
		СтрЭлНТаб.UNIT_TXT = СтрТаб.ЕдиницаИзмерения.Наименование;
		СтрЭлНТаб.QUANTITY = СтрТаб.Количество;
		СтрЭлНТаб.STATUS   = "1";		
		Если ВнутреннееПеремещение Тогда
			СтрЭлНТаб.PRICE	   = 0;
			СтрЭлНТаб.AMOUNT   = 0;
		Иначе
			СтрЭлНТаб.PRICE	   = СтрТаб.Цена;
			СтрЭлНТаб.AMOUNT   = СтрТаб.Сумма;
		КонецЕсли;
		
		Если СтрТаб.ЭтоПодарок Тогда
			СтрЭлНТаб.AMOUNT   = 0;
		КонецЕсли;	
			
		
		СтрЭлНТаб.A_ID     = 0;//Акциз		
		Если ВнутреннееПеремещение Тогда
			СтрТаб.СтавкаНДС = СтрТаб.Номенклатура.СтавкаНДС;
		КонецЕсли;
		Если СтрТаб.СтавкаНДС.НеОблагается Тогда
			СтрЭлНТаб.VAT_TYPE = 2;
		ИначеЕсли СтрТаб.СтавкаНДС.Ставка = 0 Тогда
			СтрЭлНТаб.VAT_TYPE = 1;
		ИначеЕсли СтрТаб.СтавкаНДС.Ставка = 18 Тогда
			СтрЭлНТаб.VAT_TYPE = 0;
		КонецЕсли;
		//СтрЭлНТаб.QUANTITY_EXT =  СтрТаб.Количество;
		
	КонецЦикла;
	

КонецФункции

Функция СформироватьТаблицуШапкаRS() Экспорт 
	
	TRANS_ID = 0;
	TRANS_TXT = "";
	документы.РС_ЭлектроннаяНакладная.ПолучитьВидТранспортировкиЭл(ТипТН, ВидТранспортировки, Прицеп, ДругойТранспорт, TRANS_ID, TRANS_TXT);
	СтатусыОперацииТН = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСтатусОперацииТН();
	
	СтрукПар = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИнициализацияОтправкиТН(Новый Структура, Организация);
	Если ТипЗнч(СтрукПар) = Тип("Строка") Тогда 
		Возврат СтрукПар;
	КонецЕсли;
	seller_un_id = СтрукПар.un_id;

	ШапкаRS.Очистить();
	
	//ID
	СтрШапкаRS = ШапкаRS.Добавить();
	СтрШапкаRS.ИмяПараметраRS = "ID"; 
	СтрШапкаRS.ЗначениеПараметраRS = ID_ТН; 
	
	//STATUS
	СтрШапкаRS = ШапкаRS.Добавить();
	СтрШапкаRS.ИмяПараметраRS = "STATUS"; 
	СтрШапкаRS.ЗначениеПараметраRS =?(ЗначениеЗаполнено(СтатусТН),СтатусыОперацииТН[СтатусТН],0); 

	//TYPE
	СтрШапкаRS = ШапкаRS.Добавить();
	СтрШапкаRS.ИмяПараметраRS = "TYPE"; 
	СтрШапкаRS.ЗначениеПараметраRS = документы.РС_ЭлектроннаяНакладная.ОпределитьТипТН(ТипТН); 
	
	//ACTIVATE_DATE
	СтрШапкаRS = ШапкаRS.Добавить();
	СтрШапкаRS.ИмяПараметраRS = "ACTIVATE_DATE"; 
	СтрШапкаRS.ЗначениеПараметраRS = ДатаНачалаТранспортировки; 
	
	//+++ Дмгг
	ГрузополучательОтправки = ГрузоПолучатель; 
	Если НЕ ЗначениеЗаполнено(ГрузоПолучатель) Тогда 
		Если ДокументыОснования.Количество() > 0 Тогда 
			Для Каждого Строк Из ДокументыОснования Цикл 
				Если ЗначениеЗаполнено(Строк.ДокументОснование) Тогда 
					ГрузополучательОтправки = Строк.ДокументОснование.Контрагент;
					Прервать;
