//Возвращает строковое представление номенклатуры с характеристикой для отображения в сообщениях
//Параметры
// 		НоменклатураПредставление - строковое предствление номенклатуры или ссылка на элемент справочника "Номенклатура"
// 		ХарактеристикаПредставление - строковое предствление характеристики или ссылка на элемент справочника "Номенклатура"
Функция ПредставлениеНоменклатуры(Номенклатура, Характеристика, Серия) Экспорт

	СтрПредставление = СокрЛП(Номенклатура);

	Если ЗначениеЗаполнено(Характеристика)Тогда
		СтрПредставление = СтрПредставление + " / " + СокрЛП(Характеристика.Наименование);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Серия) Тогда
		СтрПредставление = СтрПредставление + " / " + СокрЛП(Серия.Наименование);
	КонецЕсли;

	Возврат СтрПредставление;

КонецФункции

Процедура ПриКопировании(ОбъектКопирования)
	
	ID_ТН 		= 0;
	СтатусТН 	= Неопределено;
	НомерТН  	= "";
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	//+++ Дмгг
	Если НЕ ЗначениеЗаполнено(ЭтотОбъект.ГрузоПолучатель) Тогда 
		Если ДокументыОснования.Количество() > 0 Тогда 
			Для Каждого Строк Из ДокументыОснования Цикл 
				Если ЗначениеЗаполнено(Строк.ДокументОснование) Тогда 
					ЭтотОбъект.ГрузоПолучатель = Строк.ДокументОснование.Контрагент;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	//--- Дмгг
	
	Если ДокументыОснования.Количество() > 0 Тогда
		ЗаписыватьДокумент = Ложь;
		Если НЕ ID_ТН = Ссылка.ID_ТН Тогда
			ЗаписыватьДокумент = Истина;
		КонецЕсли;
		Если НЕ НомерТН = Ссылка.НомерТН Тогда
			ЗаписыватьДокумент = Истина;
		КонецЕсли;
		Если ЗаписыватьДокумент Тогда
			ДокументОбъект = ДокументыОснования[0].ДокументОснование.ПолучитьОбъект();
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.НомерТТН = НомерТН;
			ДокументОбъект.IDTТН	= Формат(ID_ТН, "ЧН=' '; ЧГ=0");
			ДокументОбъект.Записать();
		КонецЕсли;
	КонецЕсли;
	Если НЕ ТипТН = Перечисления.РС_ТипыТН.ПодчиненнаяТН Тогда
		НакладнаяДистрибюций = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если ДокументыОснования.Количество() > 0 Тогда
		Если ТипЗнч(ДокументыОснования[0].ДокументОснование) = Тип("ДокументСсылка.ПеремещениеВА") Тогда
			ПроверяемыеРеквизиты.Добавить("Товары.Имущество");
		Иначе
			ПроверяемыеРеквизиты.Добавить("Товары.Номенклатура");
		КонецЕсли;		
	КонецЕсли;
КонецПроцедуры

//ДД
Функция ПолучитьКодХарактеристики(Стр)
	
	Если ЗначениеЗаполнено(Стр.Характеристика) Тогда
		Возврат Стр.Характеристика.Код;
	Иначе
		Возврат Стр.Номенклатура.Код;
	КонецЕсли;	
	
КонецФункции

//ДД
Функция ПолучитьКодШтрихКода(Стр)
	
	Если ЗначениеЗаполнено(Стр.Характеристика) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		               |	ШтрихкодыНоменклатуры.Штрихкод
		               |ИЗ
		               |	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		               |ГДЕ
		               |	ШтрихкодыНоменклатуры.Номенклатура = &Номенклатура
		               |	И ШтрихкодыНоменклатуры.Характеристика = &Характеристика";
		
	    Запрос.УстановитьПараметр("Номенклатура",Стр.Номенклатура);
		Запрос.УстановитьПараметр("Характеристика",Стр.Характеристика);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда 
			Возврат Выборка.Штрихкод;
		Иначе
			Возврат "";
		КонецЕсли;	
				
	Иначе
		Возврат Стр.Номенклатура.ОсновнойШтрихКод;
	КонецЕсли;	
	
КонецФункции