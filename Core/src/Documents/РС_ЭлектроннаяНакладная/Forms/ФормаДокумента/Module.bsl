&НаКлиенте
Процедура ОтменитьТН(Команда) Экспорт
	
	Режим = РежимДиалогаВопрос.ДаНет;
	Ответ = Вопрос(НСтр("ru = 'Вы уверены что хотите отменить ТН?';"
	+ " ka = 'დარწმუნებული ხართ რომ გნებავთ ზედნადების გაუქმება?'"), Режим, 0);
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	// Олег Литвиненко 22.11.22 --->
	МассивСФ = НайтиСвязанныеСчетаФактуры();
	Если МассивСФ.Количество() Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Нстр("ka='ყურადღება!!! ვინაიდან არჩეული ზედნადები უკვე მიბმულია საგადასახადო ა/ფაქტურაზე , მისი წაშლა შეუძლებელია. 
			|წასაშლელად საჭიროა  ა/ფაქტურის რეესტრიდან მოხსნა.რეესტრიდან მოსახსნელი ა/ფაქტურა/ები:';ru='Внимание!!! Поскольку выбранный счет-фактура уже связан с налоговым счетом-фактурой, его нельзя удалить. 
			|Для удаления необходимо удалить счет-фактуру из реестра.Счета-фактуры, подлежащие удалению из реестра:'"));
		
		Для Каждого СФ Из МассивСФ Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(СФ), СФ);
		КонецЦикла;
		
		Возврат;
		
	КонецЕсли;
	// Олег Литвиненко <---
	
	ОбновитьДанныеОтправкиНаСервере();
	Операция_ЭлНакладная(Команда.Имя);
	Прочитать();
КонецПроцедуры

