&НаСервере
Функция НайтиСвязанныеСчетаФактуры()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.СчетФактураОтправленныйГрузия.ДокументыОснования КАК СчетФактураОтправленныйГрузияДокументыОснования
	               |ГДЕ
	               |	СчетФактураОтправленныйГрузияДокументыОснования.ДокументОснование В(&МассивДокументов)
	               |	И НЕ СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.ПометкаУдаления";
	Запрос.УстановитьПараметр("МассивДокументов", Объект.ДокументыОснования.Выгрузить().ВыгрузитьКолонку("ДокументОснование"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат ?(РезультатЗапроса.Пустой(), Новый Массив, РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка"));
	
КонецФункции// Олег Литвиненко <---

