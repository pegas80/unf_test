&НаСервере
Процедура УстановитьПараметрыВыбора_ТипТН(ПриОткрытии = Ложь)
	
	ЭтаПеремещениеВА = Ложь;
	Если СписокДокументыОснования.Количество() = 0 Тогда
		Объект.ДокументыОснования.Очистить();
		Возврат;
	КонецЕсли;
	ТипЗнченияДокумента = ТипЗнч(СписокДокументыОснования[0].Значение);
	ЭтаПеремещениеВА	= (ТипЗнченияДокумента = Тип("ДокументСсылка.ПеремещениеВА"));
	
	Если СписокДокументыОснования[0].Значение <> Неопределено Тогда
		Попытка
			ВидОперации = СписокДокументыОснования[0].Значение.ВидОперации;
		Исключение
		КонецПопытки;
	КонецЕсли;	
	
	Массив_ТипТН = Новый Массив;
	Если ТипЗнченияДокумента = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВнутреннееПеремещение"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.Дистрибуция"));
	ИначеЕсли ТипЗнченияДокумента = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВозвратОтПокупателя"));
	ИначеЕсли ЭтаПеремещениеВА Тогда
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВнутреннееПеремещение"));
	Иначе
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ПодчиненнаяТН"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.РеализацияБезТранспортировки"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.РеализацияСТранспортировкой"));
		Если ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПередачаВПереработку") Тогда
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВнутреннееПеремещение"));
		КонецЕсли;				
	КонецЕсли;
	
	Элементы.ТипТН.СписокВыбора.ЗагрузитьЗначения(Массив_ТипТН);
	
	Если НЕ ПриОткрытии И Массив_ТипТН.Найти(Объект.ТипТН) = Неопределено Тогда
		Если ТипЗнченияДокумента = Тип("ДокументСсылка.ПеремещениеЗапасов") ИЛИ
			 ТипЗнченияДокумента = Тип("ДокументСсылка.ПеремещениеВА") Тогда
			Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВнутреннееПеремещение");
		ИначеЕсли ТипЗнченияДокумента = Тип("ДокументСсылка.ЗаказПокупателя") Тогда	
			Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.РеализацияСТранспортировкой");	
		ИначеЕсли ТипЗнченияДокумента = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВозвратОтПокупателя");
		Иначе
			Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.РеализацияСТранспортировкой");
			Если ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаВПереработку Тогда
				Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.ВнутреннееПеремещение");
			КонецЕсли;
		КонецЕсли;
		УстановитьВидимостьИДоступность();
	КонецЕсли;
	
КонецПроцедуры

