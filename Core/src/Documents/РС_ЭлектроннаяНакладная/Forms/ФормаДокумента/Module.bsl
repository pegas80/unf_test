&НаСервере
Процедура УстановитьЦенуЗакупкиВСтрокеЗапасы()

	Если НЕ ПолучитьФункциональнуюОпцию("ВыводЦеныПоследнейЗакупкиВДокументеПеремещениеЗапасов")
		Или Объект.ДокументыОснования.Количество() <> 1
		ИЛИ ТипЗнч(Объект.ДокументыОснования[0].ДокументОснование) <> Тип("ДокументСсылка.ПеремещениеЗапасов")
		Тогда
	
		Возврат;	
	
	КонецЕсли;
	ДокументОснование = Объект.ДокументыОснования[0].ДокументОснование;
	
	ТаблицаЗапасы = Объект.Товары.Выгрузить(); 

	ДатаКонтроля =   ?(НачалоДня(ДокументОснование.Дата) = НачалоДня(ТекущаяДатаСеанса()), КонецДня(ТекущаяДатаСеанса()), ДокументОснование.Дата);
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Запасы", ТаблицаЗапасы);
	Запрос.УстановитьПараметр("КонецПериода", Новый Граница(ДатаКонтроля, ВидГраницы.Исключая));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Запасы.Номенклатура КАК Номенклатура,
	|	Запасы.Характеристика КАК Характеристика,
	|	Запасы.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТ_Запасы
	|ИЗ
	|	&Запасы КАК Запасы
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗакупкиОбороты.Период КАК Период,
	|	ЗакупкиОбороты.Номенклатура КАК Номенклатура,
	|	ЗакупкиОбороты.Характеристика КАК Характеристика,
	|	ЗакупкиОбороты.СуммаОборот КАК Сумма,
	|	ЗакупкиОбороты.КоличествоОборот КАК Количество
	|ПОМЕСТИТЬ ВТ_Закупки
	|ИЗ
	|	РегистрНакопления.Закупки.Обороты(
	|			,
	|			&КонецПериода,
	|			Регистратор,
	|			Организация = &Организация
	|				И (Номенклатура, Характеристика) В
	|					(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|						ВТ_Запасы.Номенклатура КАК Номенклатура,
	|						ВТ_Запасы.Характеристика КАК Характеристика
	|					ИЗ
	|						ВТ_Запасы КАК ВТ_Запасы)) КАК ЗакупкиОбороты
	|ГДЕ
	|	ЗакупкиОбороты.Регистратор ССЫЛКА Документ.ПриходнаяНакладная
	|	И ЗакупкиОбороты.КоличествоОборот > 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВТ_Закупки.Период) КАК Период,
	|	ВТ_Закупки.Номенклатура КАК Номенклатура,
	|	ВТ_Закупки.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ ВТ_ЗакупкиАктуальные
	|ИЗ
	|	ВТ_Закупки КАК ВТ_Закупки
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Закупки.Номенклатура,
	|	ВТ_Закупки.Характеристика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ЗакупкиАктуальные.Номенклатура КАК Номенклатура,
	|	ВТ_ЗакупкиАктуальные.Характеристика КАК Характеристика,
	|	ВТ_Закупки.Сумма / ВТ_Закупки.Количество КАК ЦенаЗакупки
	|ПОМЕСТИТЬ ВТ_ЦеныЗакупки
	|ИЗ
	|	ВТ_ЗакупкиАктуальные КАК ВТ_ЗакупкиАктуальные
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Закупки КАК ВТ_Закупки
	|		ПО ВТ_ЗакупкиАктуальные.Период = ВТ_Закупки.Период
	|			И ВТ_ЗакупкиАктуальные.Номенклатура = ВТ_Закупки.Номенклатура
	|			И ВТ_ЗакупкиАктуальные.Характеристика = ВТ_Закупки.Характеристика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Запасы.НомерСтроки КАК НомерСтроки,
	|	ВТ_ЦеныЗакупки.ЦенаЗакупки КАК ЦенаЗакупки
	|ИЗ
	|	ВТ_Запасы КАК ВТ_Запасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ЦеныЗакупки КАК ВТ_ЦеныЗакупки
	|		ПО ВТ_Запасы.Номенклатура = ВТ_ЦеныЗакупки.Номенклатура
	|			И ВТ_Запасы.Характеристика = ВТ_ЦеныЗакупки.Характеристика";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		ТекДанные = Объект.Товары[Выборка.НомерСтроки - 1];
		ТекДанные.Цена = Выборка.ЦенаЗакупки;
		СтавкаНДС = ПолучитьЗначенияРеквизита(ТекДанные.СтавкаНДС, "Ставка");
		ТекДанные.Сумма 	= ТекДанные.Количество	* ТекДанные.Цена;
		ТекДанные.СуммаНДС	= Окр(ТекДанные.Сумма	* СтавкаНДС/(100 + СтавкаНДС), 2);
		
	КонецЦикла; 

КонецПроцедуры // УстановитьЦенуЗакупкиВСтрокеЗапасы()
	
