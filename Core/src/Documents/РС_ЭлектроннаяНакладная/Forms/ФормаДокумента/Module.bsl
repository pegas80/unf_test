
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
		
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	
КонецПроцедуры


&НаСервере
Процедура УстановитьВидимостьИДоступность()
	
	Элементы.ГруппаОбщееДеталная.Видимость	= ЗначениеЗаполнено(Объект.ТипТН);
	Элементы.ГруппаДистрибуция.Видимость	= Объект.ТипТН = Перечисления.РС_ТипыТН.ПодчиненнаяТН;
	Элементы.ВидЦены.Видимость				= Объект.ТипТН = Перечисления.РС_ТипыТН.Дистрибуция;
	
	
	пБезТранспортировки = (Объект.ТипТН = Перечисления.РС_ТипыТН.РеализацияБезТранспортировки);
	Элементы.АдресДоставки.Видимость		= НЕ пБезТранспортировки;
	Элементы.ГруппаПеревозчика.Видимость	= НЕ пБезТранспортировки И Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Перегрузчик_Автомобильная;
	Элементы.ДругойТранспорт.Видимость 		= НЕ пБезТранспортировки И Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Прочее;
	
	Если Объект.ТипТН = Перечисления.РС_ТипыТН.РеализацияСТранспортировкой ИЛИ Объект.ТипТН = Перечисления.РС_ТипыТН.ВозвратОтПокупателя Тогда
		Элементы.ЗатратаТранспортировки.Видимость = Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Автомобильная ИЛИ
													Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Автомобильная_Заграничная ИЛИ
													Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Перегрузчик_Автомобильная;
	Иначе
		Элементы.ЗатратаТранспортировки.Видимость = Ложь;
	КонецЕсли;
	Если ЭтаПеремещениеВА Тогда
		Элементы.ТоварыИмущество.Видимость		= Истина;
		Элементы.ТоварыНоменклатура.Видимость	= Ложь;
		Элементы.ТоварыХарактеристика.Видимость = Ложь;
	Иначе
		Элементы.ТоварыИмущество.Видимость		= Ложь;
		Элементы.ТоварыНоменклатура.Видимость	= Истина;
		Элементы.ТоварыХарактеристика.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.Печать
	УправлениеПечатью.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюПечать);
	// Конец СтандартныеПодсистемы.Печать
	УправлениеНебольшойФирмойСервер.УстановитьОтображаниеПодменюПечати(Элементы.ПодменюПечать);
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И Параметры.Свойство("ДокументыОснования") Тогда
		
		Для Каждого ДокументОснование Из Параметры.ДокументыОснования Цикл
			НоваяСтрока = Объект.ДокументыОснования.Добавить();
			НоваяСтрока.ДокументОснование = ДокументОснование;
		КонецЦикла;
		Если Параметры.Свойство("НакладнаяДистрибюций") Тогда 
			Объект.НакладнаяДистрибюций = Параметры.НакладнаяДистрибюций;
			СсылкаЭН = Параметры.СсылкаЭН;
			Объект.ТранспортноеСредство	= СсылкаЭН.ТранспортноеСредство;
			Объект.ГосНомерАвтомобиля	= СсылкаЭН.ГосНомерАвтомобиля;
			Объект.Водитель				= СсылкаЭН.Водитель;
			Объект.НомерУдостоверения	= СсылкаЭН.НомерУдостоверения;
			Объект.ДругойТранспорт      = СсылкаЭН.ДругойТранспорт;
		КонецЕсли;
		ЗапольнитьРеквизитиНакладной(Параметры.ДокументыОснования);
	КонецЕсли;
	СписокДокументыОснования.ЗагрузитьЗначения(Объект.ДокументыОснования.Выгрузить().ВыгрузитьКолонку("ДокументОснование"));
	УстановитьПараметрыВыбора_ТипТН(Истина);	
	УстановитьВидимостьИДоступность();
	
	ЗаполнитьИНН_ПеревозчикаГрузоотправителяГрузополучателя(ИННГрузополучателя, 	Объект.ГрузоПолучатель); //ГрузоПолучатель
	ЗаполнитьИНН_ПеревозчикаГрузоотправителяГрузополучателя(ИННГрузоотправителя, 	Объект.ГрузоОтправитель);//ГрузоОтправитель
	ЗаполнитьИНН_ПеревозчикаГрузоотправителяГрузополучателя(ИННПеревозчика, 		Объект.Перевозчик);      //Перевозчик
	
	ВидТранспортировкиПриИзмененииНаСервере();// Kuzmich, 16.05.2022. ПлательщикТранспортировкиТН по-умолчанию
	УстановкаФорматовЦен();	
КонецПроцедуры

&НаКлиенте
Процедура ТипТНПриИзменении(Элемент)
	УстановитьВидимостьИДоступность();
	Если Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.Дистрибуция") Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ВидЦены) Тогда
			Объект.ВидЦены = УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("ВидыЦен", "Оптовая");
		КонецЕсли;
		ЗаполнитьЦеныПоДистрибюции();
	ИначеЕсли Объект.ТипТН = ПредопределенноеЗначение("Перечисление.РС_ТипыТН.РеализацияБезТранспортировки") Тогда
		Объект.АдресДоставки		= "";
		Объект.ВидТранспортировки	= Неопределено;
		//Объект.ДругойТранспорт		= "";
		Объект.Перевозчик			= Неопределено;
		ИННПеревозчика				= "";
		Объект.НомерУдостоверения	= "";
		Объект.Водитель				= "";
		Объект.ТранспортноеСредство = "";
		Объект.ГосНомерАвтомобиля	= "";
		Объект.Прицеп               = "";
	КонецЕсли;
КонецПроцедуры
 
 
