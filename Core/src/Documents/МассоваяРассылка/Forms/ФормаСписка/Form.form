	ДокументМассоваяРассылка.СпособОтправки,
	ДокументМассоваяРассылка.Состояние,
	ДокументМассоваяРассылка.Тема,
	ДокументМассоваяРассылка.Содержание,
	ДокументМассоваяРассылка.СодержаниеHTML,
	ДокументМассоваяРассылка.КартинкиHTML,
	ДокументМассоваяРассылка.УчетнаяЗапись,
	ДокументМассоваяРассылка.СоздаватьСобытия,
	ДокументМассоваяРассылка.ДатаРассылки,
	ДокументМассоваяРассылка.Ответственный,
	ДокументМассоваяРассылка.Автор,
	ДокументМассоваяРассылка.Комментарий,
	ДокументМассоваяРассылка.Получатели,
	ДокументМассоваяРассылка.МоментВремени,
	ДокументМассоваяРассылка.ЗапретРедактированияДокументов,
	ВЫБОР
		КОГДА ДокументМассоваяРассылка.СпособОтправки = ЗНАЧЕНИЕ(Перечисление.ВидыКаналовСвязи.Email)
			ТОГДА 0
		ИНАЧЕ 3
	КОНЕЦ КАК ИндексКартинки
ИЗ
	Документ.МассоваяРассылка КАК ДокументМассоваяРассылка</queryText>
