Процедура ЗаполнитьФрагмент()
	
	//+++ Дмгг
	Если НЕ ИспользоватьТолькоРегламентированныйПланСчетов Тогда
		ЗаполнитьПоПодразделению();
	Иначе 
		ЗаполнитьПоПодразделениюРегл();
	КонецЕсли;
	//--- Дмгг
	
