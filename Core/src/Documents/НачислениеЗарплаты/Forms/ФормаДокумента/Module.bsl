					//Паганини_ ПФ
					Если Объект.НалогиНаДоходы.НайтиСтроки(Новый Структура("Сотрудник, ВидНачисленияУдержания", 
														   Выборка.Сотрудник, Выборка.ВидНачисленияУдержания)).Количество() > 0 Тогда
						Продолжить;
					КонецЕсли;//_Паганини ПФ
					НоваяСтрока							= Объект.НалогиНаДоходы.Добавить();
					НоваяСтрока.Сотрудник 				= Выборка.Сотрудник;
					НоваяСтрока.ВидНачисленияУдержания 	= Выборка.ВидНачисленияУдержания;
