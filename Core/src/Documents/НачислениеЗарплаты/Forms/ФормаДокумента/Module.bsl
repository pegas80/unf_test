//DD საშემოსავლო შეღავათების გადანაწილება გადახდებზე
&НаСервере
Процедура РаспределитьНДФЛ()
	
	ЗаполнитьНДФЛ();
	
	РассчитатьУдержания();
	РассчитатьПогашениеЗайма();
	
	СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаУдержания.НомерСтроки КАК НомерСтроки,
	|	ТаблицаУдержания.Сотрудник,
	|	ТаблицаУдержания.СуммаНДФЛ КАК СуммаНДФЛ,
	|	""Удержания"" КАК Тип,
	|	1 КАК Сортировка,
	|	ВЫРАЗИТЬ(ТаблицаУдержания.ВидУдержания КАК Справочник.ВидыНачисленийИУдержаний).Тип КАК ТипУдержания,
	|	ВЫРАЗИТЬ(ТаблицаУдержания.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержания
	|ПОМЕСТИТЬ ВТ1
	|ИЗ
	|	&ТаблицаУдержания КАК ТаблицаУдержания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаУдержания.НомерСтроки,
	|	ТаблицаУдержания.Сотрудник,
	|	ТаблицаУдержания.СуммаНДФЛ,
	|	""Удержания"" КАК Тип,
	|	0 КАК Сортировка,
	|	ВЫРАЗИТЬ(ТаблицаУдержания.ВидУдержания КАК Справочник.ВидыНачисленийИУдержаний).Тип КАК ТипУдержания,
	|	ВЫРАЗИТЬ(ТаблицаУдержания.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержания
	|ПОМЕСТИТЬ ВТ2
	|ИЗ
	|	&ТаблицаУдержания КАК ТаблицаУдержания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПогашениеЗаймов.НомерСтроки,
	|	ТаблицаПогашениеЗаймов.Сотрудник,
	|	ТаблицаПогашениеЗаймов.СуммаНДФЛПогашеноЗайма КАК СуммаНДФЛ,
	|	""Займ"" КАК Тип,
	|	1 КАК Сортировка,
	|	ТаблицаПогашениеЗаймов.ВидУдержанияНДФЛ КАК ВидУдержания
	|ПОМЕСТИТЬ ВТ3
	|ИЗ
	|	&ТаблицаПогашениеЗаймов КАК ТаблицаПогашениеЗаймов
	|ГДЕ
	|	НЕ ТаблицаПогашениеЗаймов.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаПогашениеЗаймов.НомерСтроки,
	|	ТаблицаПогашениеЗаймов.Сотрудник,
	|	ТаблицаПогашениеЗаймов.СуммаНДФЛПогашеноПроцентов КАК СуммаНДФЛ,
	|	""Процент"" КАК Тип,
	|	1 КАК Сортировка,
	|	ТаблицаПогашениеЗаймов.ВидУдержанияНДФЛ КАК ВидУдержания
	|ПОМЕСТИТЬ ВТ4
	|ИЗ
	|	&ТаблицаПогашениеЗаймов КАК ТаблицаПогашениеЗаймов
	|ГДЕ
	|	НЕ ТаблицаПогашениеЗаймов.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.НомерСтроки,
	|	ВТ.СуммаНДФЛ,
	|	ВТ.Тип,
	|	ВТ.Сортировка,
	|	ВТ.Сотрудник КАК Сотрудник,
	|	ВТ.ВидУдержания
	|ИЗ
	|	ВТ1 КАК ВТ
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВТ.ТипУдержания = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.Удержание)
	|					ИЛИ &СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении
	|						И ВТ.ТипУдержания = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.УдержаниеДляКонтрагента)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ.НомерСтроки,
	|	ВТ.СуммаНДФЛ,
	|	ВТ.Тип,
	|	ВТ.Сортировка,
	|	ВТ.Сотрудник,
	|	ВТ.ВидУдержания
	|ИЗ
	|	ВТ2 КАК ВТ
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВТ.ТипУдержания = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.Удержание)
	|					ИЛИ &СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении
	|						И ВТ.ТипУдержания = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.УдержаниеДляКонтрагента)
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ.НомерСтроки,
	|	ВТ.СуммаНДФЛ,
	|	ВТ.Тип,
	|	ВТ.Сортировка,
	|	ВТ.Сотрудник,
	|	ВТ.ВидУдержания
	|ИЗ
	|	ВТ3 КАК ВТ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ.НомерСтроки,
	|	ВТ.СуммаНДФЛ,
	|	ВТ.Тип,
	|	ВТ.Сортировка,
	|	ВТ.Сотрудник,
	|	ВТ.ВидУдержания
	|ИЗ
	|	ВТ4 КАК ВТ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ.Сортировка УБЫВ,
	|	ВТ.СуммаНДФЛ УБЫВ";
	
	Запрос.УстановитьПараметр("ТаблицаУдержания", Объект.Удержания.Выгрузить());
	Запрос.УстановитьПараметр("ТаблицаПогашениеЗаймов", Объект.ПогашениеЗаймов.Выгрузить());
	Запрос.УстановитьПараметр("СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении",	УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ТЗ = ТаблицаНДФЛДляРаспределения.Выгрузить();		
	ТЗ.Свернуть("Сотрудник","НДФЛДляРаспределения");
	
	Пока Выборка.Следующий() Цикл 
		
		СтруктураОтбора = Новый Структура;
		СтруктураОтбора.Вставить("Сотрудник",Выборка.Сотрудник);
		//
		СтрукОтвета = РС_ОбщегоНазначения.ПолучитьСуммоНалоговыхЛгот(Объект.Организация,Выборка.Сотрудник,Объект.СтруктурнаяЕдиница,Объект.Дата);
		//
		ПроцентПодоходного = СтрукОтвета.ПроцентПодоходного;
		СтавкаНДФЛ = Выборка.ВидУдержания.СтавкаНДФЛ;
		
		СтавкаЛгот = СтавкаНДФЛ-ПроцентПодоходного;
		СтавкаЛгот =?(СтавкаЛгот<0,0,СтавкаЛгот);
		
		
		//
		//Если СтавкаНДФЛ <> 0 Тогда
		//	КоэфициентРаспределения = ПроцентПодоходного/СтавкаНДФЛ;
		//Иначе
		//	КоэфициентРаспределения = 0;
		//КонецЕсли;	
		
		СтрокаНДФЛ = ТЗ.НайтиСтроки(СтруктураОтбора);
		
		Если СтрокаНДФЛ.Количество() <> 0 Тогда	
			НДФЛДляРаспределения = СтрокаНДФЛ[0].НДФЛДляРаспределения;
		Иначе
			НДФЛДляРаспределения = 0;
		КонецЕсли;
		
		
		ВидУдержанияПФУказан = Истина;
		Если Выборка.Тип = "Удержания" Тогда
			
			Стр = Объект.Удержания[Выборка.НомерСтроки-1];
			
			Если ЗначениеЗаполнено(Стр.ВидУдержанияПФ) Тогда
				СтавкаПФ = Стр.ВидУдержанияПФ.СтавкаПФ;
				ВидУдержанияПФУказан = Истина;
			Иначе 
				СтавкаПФ = 0;
				ВидУдержанияПФУказан = ЛОЖЬ;
			КонецЕсли;
			
			
			Если НДФЛДляРаспределения < Окр(Стр.Сумма/((100-СтавкаЛгот)/100),2) Тогда
				
				Если НДФЛДляРаспределения = 0 Тогда
					Стр.СуммаЛгот = 0;
				Иначе
					
					НДФЛБезЛгот = Окр((Стр.Сумма - НДФЛДляРаспределения) / ((100-СтавкаНДФЛ)/100), 2) - (Стр.Сумма-НДФЛДляРаспределения);
					НДФЛЛгот    = Окр((НДФЛДляРаспределения) / ((100-СтавкаНДФЛ)/100), 2) - (НДФЛДляРаспределения);
					
					Стр.СуммаНДФЛ = НДФЛБезЛгот + НДФЛЛгот;
					Стр.СуммаЛгот = НДФЛДляРаспределения;
					
					НДФЛДляРаспределения = 0;
					
				КонецЕсли;	
				
			Иначе
				
				Стр.СуммаНДФЛ = Окр(Стр.Сумма/((100-СтавкаЛгот)/100),2) - Стр.Сумма;
				Стр.СуммаЛгот = Стр.Сумма + Стр.СуммаНДФЛ;
				НДФЛДляРаспределения = НДФЛДляРаспределения - Стр.СуммаЛгот;
				
			КонецЕсли;
			
			Если ВидУдержанияПФУказан Тогда 
				Стр.СуммаПФ = (Стр.Сумма + Стр.СуммаНДФЛ) * СтавкаПФ / (100 - СтавкаПФ);
			Иначе
				Стр.СуммаПФ = 0;
			КонецЕсли;
			
		КонецЕсли;	
		
		Если Выборка.Тип = "Займ" Тогда
			Стр = Объект.ПогашениеЗаймов[Выборка.НомерСтроки-1];
			
			Если ЗначениеЗаполнено(Стр.ВидУдержанияПФ) Тогда
				СтавкаПФ = Стр.ВидУдержанияПФ.СтавкаПФ;
			КонецЕсли;
			
			Если НДФЛДляРаспределения < Стр.ПогашеноЗайма / ((100-СтавкаЛгот)/100) Тогда
				Если НДФЛДляРаспределения = 0 Тогда
					Стр.СуммаЛгот = 0;
				Иначе
					НДФЛБезЛгот = Окр((Стр.СуммаПогашеноЗайма - НДФЛДляРаспределения)  / ((100 - СтавкаНДФЛ)/100), 2) - (Стр.СуммаПогашеноЗайма - НДФЛДляРаспределения);
					НДФЛЛгот    = Окр((НДФЛДляРаспределения) / ((100-СтавкаЛгот)/100), 2) - НДФЛДляРаспределения ;
					
					Стр.ПогашеноЗайма = НДФЛБезЛгот + НДФЛЛгот;
					Стр.СуммаЛгот = НДФЛДляРаспределения;
					
					НДФЛДляРаспределения = 0;
				КонецЕсли;	
			Иначе
				Стр.СуммаНДФЛПогашеноЗайма = Окр(Стр.ПогашеноЗайма / ((100-СтавкаЛгот)/100) - Стр.ПогашеноЗайма,2);
				Стр.СуммаЛгот = Стр.ПогашеноЗайма + Стр.СуммаНДФЛПогашеноЗайма;
				НДФЛДляРаспределения = НДФЛДляРаспределения - Стр.СуммаЛгот;
				//Стр.СуммаЛгот = 0;
				 
			КонецЕсли;
			Стр.СуммаПФПогашеноЗайма = (Стр.ПогашеноЗайма + Стр.СуммаНДФЛПогашеноЗайма) * СтавкаПФ / (100 - СтавкаПФ);
		КонецЕсли;	
		
		
		Если Выборка.Тип = "Процент" Тогда
			Стр = Объект.ПогашениеЗаймов[Выборка.НомерСтроки-1];
			
			Если ЗначениеЗаполнено(Стр.ВидУдержанияПФ) Тогда
				СтавкаПФ = Стр.ВидУдержанияПФ.СтавкаПФ;
			КонецЕсли;

			Если НДФЛДляРаспределения < Стр.ПогашеноПроцентов / ((100-СтавкаЛгот)/100) Тогда
				Если НДФЛДляРаспределения = 0 Тогда
					Стр.СуммаЛготПроцента = 0;
				Иначе
					НДФЛБезЛгот = Окр((Стр.ПогашеноПроцентов - НДФЛДляРаспределения)  / ((100 - СтавкаНДФЛ)/100), 2) - (Стр.ПогашеноПроцентов - НДФЛДляРаспределения);
					НДФЛЛгот    = Окр((НДФЛДляРаспределения) / ((100-СтавкаЛгот)/100), 2) - НДФЛДляРаспределения;
					
					Стр.ПогашеноПроцентов = НДФЛБезЛгот + НДФЛЛгот;
					Стр.СуммаЛготПроцента = НДФЛДляРаспределения;
					
					НДФЛДляРаспределения = 0;
				КонецЕсли;	
			Иначе
				Стр.СуммаНДФЛПогашеноПроцентов = Окр(Стр.ПогашеноПроцентов / ((100-СтавкаЛгот)/100) - Стр.ПогашеноПроцентов,2);
				Стр.СуммаЛготПроцента = Стр.ПогашеноПроцентов + Стр.СуммаНДФЛПогашеноПроцентов;
				НДФЛДляРаспределения = НДФЛДляРаспределения - Стр.СуммаЛготПроцента;				 
			КонецЕсли;
			
			Стр.СуммаПФПогашеноПроцентов = (Стр.ПогашеноПроцентов + Стр.СуммаНДФЛПогашеноПроцентов) * СтавкаПФ / (100 - СтавкаПФ);
			
		КонецЕсли;
		
		Если СтрокаНДФЛ.Количество() <> 0 Тогда
			СтрокаНДФЛ[0].НДФЛДляРаспределения = НДФЛДляРаспределения;
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры	

//ПодольскийАИ #УчетПроектов  27.10.2020 {

&НаСервере
Процедура РаспределитьТаблицыПоПроектам(ЭтоНачисление = Ложь, ТолькоРасчет = Ложь)
	
	Если Не УчетПоПроектам Тогда
		Возврат;
	КонецЕсли;
	
	Перезаполнить = ЭтоНачисление И Не ТолькоРасчет;
	
	Если ЭтоНачисление Тогда
		ЗаполнитьРассчитатьОтработаноеВремяПоПроектам(ТолькоРасчет);
	КонецЕсли;
	
	ТаблицаКоэффициентов = ПолучитьТаблицуРассчитанныхКоэффициентовПоПроектам();
	
	Если Не ЭтоНачисление Тогда
		
		//НАЛОГИ НА ДОХОДЫ
		РесурсыТЧ = "Сумма,СуммаЛгот";
		ЗаполнитьПроектыпоРаспределению(ТаблицаКоэффициентов, "НалогиНаДоходы", РесурсыТЧ);
		
		//УДЕРЖАНИЕ
		РесурсыТЧ = "Сумма,СуммаНДФЛ,СуммаПФ,СуммаЛгот";
		ЗаполнитьПроектыпоРаспределению(ТаблицаКоэффициентов, "Удержания", РесурсыТЧ);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРассчитатьОтработаноеВремяПоПроектам(ТолькоРасчет = Ложь)
	
	Если ТолькоРасчет Тогда
		Для Каждого СтрокаТабличнойЧасти Из Объект.НачисленияУдержания Цикл
			
			// 3. Поиск всех параметров-идентификаторов формулы
			СтруктураПараметров = Новый Структура;
			УправлениеНебольшойФирмойСервер.ДобавитьПараметрыВСтруктуру(СтрокаТабличнойЧасти.ВидНачисленияУдержания.Формула, СтруктураПараметров);
			
			// 4. Добавление показателя
			Для каждого ПараметрСтруктуры Из СтруктураПараметров Цикл
				
				Если ПараметрСтруктуры.Ключ = "ОтработаноДней"
					ИЛИ ПараметрСтруктуры.Ключ = "ОтработаноЧасов"
					ИЛИ ПараметрСтруктуры.Ключ = "ТарифнаяСтавка" 
				Тогда
					
					//ПодольскийАИ #УчетПроектов 10.11.2020 {
					Если УчетПоПроектам Тогда
						СтрокаТабличнойЧасти.ЗависитОтДней = ПараметрСтруктуры.Ключ = "ОтработаноДней";
						СтрокаТабличнойЧасти.ЗависитОтЧасов = ПараметрСтруктуры.Ключ = "ОтработаноЧасов";
					КонецЕсли;
					//ПодольскийАИ #УчетПроектов 10.11.2020 }
					
					Продолжить;
					
				КонецЕсли;
			КонецЦикла;
			
		КонецЦикла;
	КонецЕсли;
	
	СписокКолонокТЧ = ПолучитьСписокКолонокТЧ("НачисленияУдержания");
	ТаблицаНачисленийДляПроектов = Объект.НачисленияУдержания.Выгрузить( , СписокКолонокТЧ);
	
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("ТаблицаНачисленияУдержания", ТаблицаНачисленийДляПроектов);
	Запрос.Параметры.Вставить("УчетПоПроектам", УчетПоПроектам);
	//Запрос.Параметры.Вставить("НачалоМесяца", 		Объект.ПериодРегистрации);
	//Запрос.Параметры.Вставить("ОкончаниеМесяца",	КонецМесяца(Объект.ПериодРегистрации));
	Запрос.Параметры.Вставить("Организация", 		УправлениеНебольшойФирмойСервер.ПолучитьОрганизацию(Объект.Организация));
	Запрос.Параметры.Вставить("СтруктурнаяЕдиница", Объект.СтруктурнаяЕдиница);
	//Запрос.Параметры.Вставить("Валюта", 			Объект.ВалютаДокумента);
	
	Если ТолькоРасчет Тогда
		Запрос.Текст = ПолучитьТекстЗапросаДляРасчетаПоОтработанномуВремени();
	Иначе
		Запрос.Текст = ПолучитьТекстЗапросаДляЗаполненияПоОтработанномуВремени();
	КонецЕсли;
	
	Объект.НачисленияУдержания.Очистить();
	
	ВыборкаСотрудник = Запрос.ВыполнитьПакет()[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСотрудник.Следующий() Цикл
		
		ВыборкаВидНачисления = ВыборкаСотрудник.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВидНачисления.Следующий() Цикл
			
			ОсталосьСумма = ВыборкаВидНачисления.Сумма;
			ОсталосьСуммаПФ = ВыборкаВидНачисления.СуммаПФ;
			ВыборкаДет = ВыборкаВидНачисления.Выбрать();
			Пока ВыборкаДет.Следующий() Цикл
				СтрокаНачисления = Объект.НачисленияУдержания.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаНачисления, ВыборкаДет);
				
				Если СтрокаНачисления.ЗависитОтЧасов Тогда
					СтрокаНачисления.КоэффициентПоПроекту = ?(ВыборкаДет.ОтработаноЧасов = 0, 0, Окр(ВыборкаДет.ОтработаноЧасовПоПроекту / ВыборкаДет.ОтработаноЧасов, 4));
				Иначе
					СтрокаНачисления.КоэффициентПоПроекту = ?(ВыборкаДет.ОтработаноДней = 0, 0, Окр(ВыборкаДет.ОтработаноДнейПоПроекту / ВыборкаДет.ОтработаноДней, 4));
				КонецЕсли;
				
				СтрокаНачисления.Сумма = Окр(СтрокаНачисления.Сумма * СтрокаНачисления.КоэффициентПоПроекту, 2);
				СтрокаНачисления.СуммаПФ = Окр(СтрокаНачисления.СуммаПФ * СтрокаНачисления.КоэффициентПоПроекту, 2);
				
				ОсталосьСумма = ОсталосьСумма - СтрокаНачисления.Сумма;
				ОсталосьСуммаПФ = ОсталосьСуммаПФ - СтрокаНачисления.СуммаПФ;
			КонецЦикла;
			
			Если ОсталосьСумма <> 0 Тогда
				СтрокаНачисления.Сумма = СтрокаНачисления.Сумма + ОсталосьСумма;
			КонецЕсли;
			
			Если ОсталосьСуммаПФ <> 0 Тогда
				СтрокаНачисления.СуммаПФ = СтрокаНачисления.СуммаПФ + ОсталосьСуммаПФ;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокКолонокТЧ(ИмяТЧ)
	
	СписокКолонок = "";
	Если ИмяТЧ = "НачисленияУдержания" Тогда
		СписокКолонок = "Сотрудник,Должность,ВидНачисленияУдержания,ДатаНачала,ДатаОкончания,ОтработаноДней,ОтработаноЧасов,Размер,Сумма,СчетЗатрат,НаправлениеДеятельности";
		СписокКолонок = СписокКолонок + ",ЗаказПокупателя,РучнаяКорректировка,Показатель1,Представление1,Значение1,Показатель2,Представление2,Значение2";
		СписокКолонок = СписокКолонок + ",Показатель3,Представление3,Значение3,ТипСчета,СчетЗатратРегл,ВидУдержанияПФ,СуммаПФ,ЗависитОтДней,ЗависитОтЧасов";
		СписокКолонок = СписокКолонок + ",Проект,КоэффициентПоПроекту,ОтработаноДнейПоПроекту,ОтработаноЧасовПоПроекту";
	КонецЕсли;
	
	Возврат СписокКолонок;
	
КонецФункции

&НаСервере
Функция ПолучитьТаблицуРассчитанныхКоэффициентовПоПроектам()
	
	ТаблицаКоэффициентов = Объект.НачисленияУдержания.Выгрузить( , "Сотрудник,Проект,КоэффициентПоПроекту");
	ТаблицаКоэффициентов.Свернуть("Сотрудник,Проект,КоэффициентПоПроекту");
	Возврат ТаблицаКоэффициентов;
	
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапросаДляЗаполненияПоОтработанномуВремени()
	
	Возврат "ВЫБРАТЬ
			|	ТаблицаНачисленияУдержания.Сотрудник,
			|	ТаблицаНачисленияУдержания.Должность,
			|	ТаблицаНачисленияУдержания.ВидНачисленияУдержания,
			|	ТаблицаНачисленияУдержания.ДатаНачала,
			|	ТаблицаНачисленияУдержания.ДатаОкончания,
			|	ТаблицаНачисленияУдержания.ОтработаноДней,
			|	ТаблицаНачисленияУдержания.ОтработаноЧасов,
			|	ТаблицаНачисленияУдержания.Размер,
			|	ТаблицаНачисленияУдержания.Сумма,
			|	ТаблицаНачисленияУдержания.СчетЗатрат,
			|	ТаблицаНачисленияУдержания.НаправлениеДеятельности,
			|	ТаблицаНачисленияУдержания.ЗаказПокупателя,
			|	ТаблицаНачисленияУдержания.РучнаяКорректировка,
			|	ТаблицаНачисленияУдержания.Показатель1,
			|	ТаблицаНачисленияУдержания.Представление1,
			|	ТаблицаНачисленияУдержания.Значение1,
			|	ТаблицаНачисленияУдержания.Показатель2,
			|	ТаблицаНачисленияУдержания.Представление2,
			|	ТаблицаНачисленияУдержания.Значение2,
			|	ТаблицаНачисленияУдержания.Показатель3,
			|	ТаблицаНачисленияУдержания.Представление3,
			|	ТаблицаНачисленияУдержания.Значение3,
			|	ТаблицаНачисленияУдержания.ТипСчета,
			|	ТаблицаНачисленияУдержания.СчетЗатратРегл,
			|	ТаблицаНачисленияУдержания.ВидУдержанияПФ,
			|	ТаблицаНачисленияУдержания.СуммаПФ,
			|	ТаблицаНачисленияУдержания.ЗависитОтДней,
			|	ТаблицаНачисленияУдержания.ЗависитОтЧасов
			|ПОМЕСТИТЬ ТаблицаНачисленияУдержания
			|ИЗ
			|	&ТаблицаНачисленияУдержания КАК ТаблицаНачисленияУдержания
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ДокументНачисление.Сотрудник КАК Сотрудник,
			|	ДокументНачисление.Должность КАК Должность,
			|	ДокументНачисление.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
			|	ЕСТЬNULL(ДанныеТабеля.ДатаНачала, ДокументНачисление.ДатаНачала) КАК ДатаНачала,
			|	ЕСТЬNULL(ДанныеТабеля.ДатаОкончания, ДокументНачисление.ДатаОкончания) КАК ДатаОкончания,
			|	ЕСТЬNULL(ДанныеТабеля.Проект, ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)) КАК Проект,
			|	ДокументНачисление.ОтработаноДней КАК ОтработаноДней,
			|	ДокументНачисление.ОтработаноЧасов КАК ОтработаноЧасов,
			|	ДокументНачисление.Размер,
			|	ДокументНачисление.Сумма КАК Сумма,
			|	ДокументНачисление.СчетЗатрат,
			|	ДокументНачисление.НаправлениеДеятельности,
			|	ДокументНачисление.ЗаказПокупателя,
			|	ДокументНачисление.РучнаяКорректировка,
			|	ДокументНачисление.Показатель1,
			|	ДокументНачисление.Представление1,
			|	ДокументНачисление.Значение1,
			|	ДокументНачисление.Показатель2,
			|	ДокументНачисление.Представление2,
			|	ДокументНачисление.Значение2,
			|	ДокументНачисление.Показатель3,
			|	ДокументНачисление.Представление3,
			|	ДокументНачисление.Значение3,
			|	ДокументНачисление.ТипСчета,
			|	ДокументНачисление.СчетЗатратРегл,
			|	ДокументНачисление.ВидУдержанияПФ,
			|	ДокументНачисление.СуммаПФ КАК СуммаПФ,
			|	ДокументНачисление.ЗависитОтДней,
			|	ДокументНачисление.ЗависитОтЧасов,
			|	ЕСТЬNULL(ДанныеТабеля.ОтработаноДней, 0) КАК ОтработаноДнейПоПроекту,
			|	ЕСТЬNULL(ДанныеТабеля.ОтработаноЧасов, 0) КАК ОтработаноЧасовПоПроекту,
			|	ЕСТЬNULL(ДанныеТабеля.ВЦеломЗаПериод, ЛОЖЬ) КАК ВЦеломЗаПериод
			|ИЗ
			|	ТаблицаНачисленияУдержания КАК ДокументНачисление
			|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			|			ДокументНачисление.Сотрудник КАК Сотрудник,
			|			ВЫБОР
			|				КОГДА &УчетПоПроектам
			|					ТОГДА ЕСТЬNULL(Табель.Проект, ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка))
			|				ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
			|			КОНЕЦ КАК Проект,
			|			СУММА(Табель.Дней) КАК ОтработаноДней,
			|			СУММА(Табель.Часов) КАК ОтработаноЧасов,
			|			МИНИМУМ(ВЫБОР
			|					КОГДА ЕСТЬNULL(Табель.ВЦеломЗаПериод, ИСТИНА)
			|						ТОГДА ДокументНачисление.ДатаНачала
			|					ИНАЧЕ Табель.Период
			|				КОНЕЦ) КАК ДатаНачала,
			|			МАКСИМУМ(ВЫБОР
			|					КОГДА ЕСТЬNULL(Табель.ВЦеломЗаПериод, ИСТИНА)
			|						ТОГДА ДокументНачисление.ДатаОкончания
			|					ИНАЧЕ Табель.Период
			|				КОНЕЦ) КАК ДатаОкончания,
			|			МАКСИМУМ(Табель.ВЦеломЗаПериод) КАК ВЦеломЗаПериод
			|		ИЗ
			|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
			|				ДокументНачисление.Сотрудник КАК Сотрудник,
			|				ДокументНачисление.ДатаНачала КАК ДатаНачала,
			|				ДокументНачисление.ДатаОкончания КАК ДатаОкончания
			|			ИЗ
			|				ТаблицаНачисленияУдержания КАК ДокументНачисление) КАК ДокументНачисление
			|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Табель КАК Табель
			|				ПО ДокументНачисление.Сотрудник = Табель.Сотрудник
			|					И (ВЫБОР
			|						КОГДА &УчетПоПроектам
			|							ТОГДА ИСТИНА
			|						ИНАЧЕ Табель.ВидВремени = ЗНАЧЕНИЕ(Справочник.ВидыРабочегоВремени.Работа)
			|					КОНЕЦ)
			|					И (Табель.Организация = &Организация)
			|					И (Табель.СтруктурнаяЕдиница = &СтруктурнаяЕдиница)
			|					И (НЕ Табель.ВЦеломЗаПериод
			|							И ДокументНачисление.ДатаНачала <= Табель.Период
			|							И ДокументНачисление.ДатаОкончания >= Табель.Период
			|						ИЛИ Табель.ВЦеломЗаПериод
			|							И Табель.Период = НАЧАЛОПЕРИОДА(ДокументНачисление.ДатаНачала, МЕСЯЦ))
			|		
			|		СГРУППИРОВАТЬ ПО
			|			ДокументНачисление.Сотрудник,
			|			ВЫБОР
			|				КОГДА &УчетПоПроектам
			|					ТОГДА ЕСТЬNULL(Табель.Проект, ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка))
			|				ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
			|			КОНЕЦ,
			|			ДокументНачисление.ДатаНачала,
			|			ДокументНачисление.ДатаОкончания) КАК ДанныеТабеля
			|		ПО ДокументНачисление.Сотрудник = ДанныеТабеля.Сотрудник
			|ИТОГИ
			|	МАКСИМУМ(ОтработаноДней),
			|	МАКСИМУМ(ОтработаноЧасов),
			|	МАКСИМУМ(Сумма),
			|	МАКСИМУМ(СуммаПФ),
			|	СУММА(ОтработаноДнейПоПроекту),
			|	СУММА(ОтработаноЧасовПоПроекту)
			|ПО
			|	Сотрудник,
			|	ВидНачисленияУдержания";
	
КонецФункции

