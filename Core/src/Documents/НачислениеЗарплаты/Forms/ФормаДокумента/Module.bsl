&НаСервере
Процедура ЗаполнитьПересчитатьКоэффициентыПоПроектамНачисления(ТаблицаКоэффициентов, ИмяТЧ, РесурсыТЧ)
	
	МассивРесурсов = Новый Массив;
	ИменаРесурсов = СтрРазделить(РесурсыТЧ, ",", Ложь);
	Для Каждого РесурсТЧ Из ИменаРесурсов Цикл
		текРесурс = Новый Структура("ИмяПоля,Значение", РесурсТЧ, 0);
		МассивРесурсов.Добавить(текРесурс);
	КонецЦикла;
	
	ТекущийСотрудник = Неопределено;
	НомерСтроки = 0;
	Пересчитывать = Истина;
	
	Для Каждого СтрокаТЧ Из Объект[ИмяТЧ] Цикл
		
		Если СтрокаТЧ.ЗависитОтДней ИЛИ СтрокаТЧ.ЗависитОтЧасов Тогда
			Пересчитывать = Ложь;
			
		Иначе
			
			Пересчитывать = Истина;
			
			Если ТекущийСотрудник = Неопределено Тогда 
				ТекущийСотрудник = СтрокаТЧ.Сотрудник;
				
				Для Каждого РесурсТЧ Из МассивРесурсов Цикл
					РесурсТЧ.Значение = СтрокаТЧ[РесурсТЧ.ИмяПоля];
				КонецЦикла;
				
			ИначеЕсли ТекущийСотрудник <> СтрокаТЧ.Сотрудник Тогда
				ТекущийСотрудник = СтрокаТЧ.Сотрудник;
				СтрокаПрошлая = Объект[ИмяТЧ][НомерСтроки - 1];
				
				Для Каждого РесурсТЧ Из МассивРесурсов Цикл
					СтрокаПрошлая[РесурсТЧ.ИмяПоля] = СтрокаПрошлая[РесурсТЧ.ИмяПоля] + РесурсТЧ.Значение;
				КонецЦикла;
		
				Для Каждого РесурсТЧ Из МассивРесурсов Цикл
					РесурсТЧ.Значение = СтрокаТЧ[РесурсТЧ.ИмяПоля];
				КонецЦикла;
				
			КонецЕсли;
		
		КонецЕсли; 
		
		ОтборСтрок = Новый Структура("Сотрудник,Проект", СтрокаТЧ.Сотрудник, СтрокаТЧ.Проект);
		СтрокиОтбора = ТаблицаКоэффициентов.НайтиСтроки(ОтборСтрок);
		Для Каждого СтрокаОтбора Из СтрокиОтбора Цикл
			
			СтрокаТЧ.КоэффициентПоПроекту = СтрокаОтбора.КоэффициентПоПроекту;
			
			Если Пересчитывать Тогда
				Для Каждого РесурсТЧ Из МассивРесурсов Цикл
					СтрокаТЧ[РесурсТЧ.ИмяПоля] = СтрокаТЧ[РесурсТЧ.ИмяПоля] * СтрокаОтбора.КоэффициентПоПроекту;
					РесурсТЧ.Значение = РесурсТЧ.Значение - СтрокаТЧ[РесурсТЧ.ИмяПоля];
				КонецЦикла;
			КонецЕсли;
			
		КонецЦикла;
		
		НомерСтроки = СтрокаТЧ.НомерСтроки;
		
	КонецЦикла;
	
	Если Пересчитывать Тогда
		СтрокаПрошлая = Объект[ИмяТЧ][НомерСтроки - 1];
		Для Каждого РесурсТЧ Из МассивРесурсов Цикл
			СтрокаПрошлая[РесурсТЧ.ИмяПоля] = СтрокаПрошлая[РесурсТЧ.ИмяПоля] + РесурсТЧ.Значение;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПроектыпоРаспределению(ТаблицаКоэффициентов, ИмяТЧ, РесурсыТЧ)
	
	ТаблицаДляРаспределения = Объект[ИмяТЧ].Выгрузить();
	ТаблицаДляРаспределения.Очистить();
	
	МассивРесурсов = Новый Массив;
	ИменаРесурсов = СтрРазделить(РесурсыТЧ, ",", Ложь);
	Для Каждого РесурсТЧ Из ИменаРесурсов Цикл
		текРесурс = Новый Структура("ИмяПоля,Значение", РесурсТЧ, 0);
		МассивРесурсов.Добавить(текРесурс);
	КонецЦикла;
	
	ТекущийСотрудник = Неопределено;
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЧ Из Объект[ИмяТЧ] Цикл
		
		Для Каждого РесурсТЧ Из МассивРесурсов Цикл
			РесурсТЧ.Значение = СтрокаТЧ[РесурсТЧ.ИмяПоля];
		КонецЦикла;
		
		ОтборСтрок = Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник);
		СтрокиОтбора = ТаблицаКоэффициентов.НайтиСтроки(ОтборСтрок);
		Для Каждого СтрокаОтбора Из СтрокиОтбора Цикл
			
			СтрокаРаспредения = ТаблицаДляРаспределения.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаРаспредения, СтрокаТЧ);
			СтрокаРаспредения.Проект = СтрокаОтбора.Проект;
			
			Для Каждого РесурсТЧ Из МассивРесурсов Цикл
				СтрокаРаспредения[РесурсТЧ.ИмяПоля] = СтрокаТЧ[РесурсТЧ.ИмяПоля] * СтрокаОтбора.КоэффициентПоПроекту;
				РесурсТЧ.Значение = РесурсТЧ.Значение - СтрокаРаспредения[РесурсТЧ.ИмяПоля];
			КонецЦикла;
			
		КонецЦикла;
		
		Для Каждого РесурсТЧ Из МассивРесурсов Цикл
			СтрокаРаспредения[РесурсТЧ.ИмяПоля] = СтрокаРаспредения[РесурсТЧ.ИмяПоля] + РесурсТЧ.Значение;
		КонецЦикла;
		
	КонецЦикла;
	
	Объект[ИмяТЧ].Загрузить(ТаблицаДляРаспределения);
	
КонецПроцедуры

