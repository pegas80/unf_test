					Если Выборка.Размер > 0 Тогда
						НоваяСтрокаУ = Объект.Удержания.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрокаУ, Выборка);
						НоваяСтрокаУ.ВидУдержания 	= Выборка.ВидНачисленияУдержания;
						НоваяСтрокаУ.ВидУдержанияПФ = Выборка.ВидУдержанияПФ_;
						НоваяСтрокаУ.Сумма			= Выборка.Размер;
						НоваяСтрокаУ.СуммаНДФЛ		= НоваяСтрокаУ.Сумма * Выборка.СтавкаНДФЛ / (100 - Выборка.СтавкаНДФЛ);
						НоваяСтрокаУ.СуммаПФ		= ?(ЗначениеЗаполнено(НоваяСтрокаУ.ВидУдержанияПФ), 
														(НоваяСтрокаУ.Сумма + НоваяСтрокаУ.СуммаНДФЛ) * Выборка.СтавкаПФ / (100 - Выборка.СтавкаПФ),
