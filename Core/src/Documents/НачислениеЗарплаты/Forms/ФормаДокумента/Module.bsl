&НаКлиенте
Процедура ПогашениеЗаймовСотрудникПриИзменении(Элемент)
	
	ТекСтрока = Элементы.ПогашениеЗаймов.ТекущиеДанные;
	
	СтруктураСтроки = Новый Структура("Сотрудник, Организация", ТекСтрока.Сотрудник, Объект.Организация);
	
	СтруктураЗАполнения = ПолучитьВидУдержанияНДФЛ(СтруктураСтроки, Объект.Дата);
	ТекСтрока.ВидУдержанияНДФЛ = СтруктураЗАполнения.ВидУдержанияНДФЛ;
	ТекСтрока.ВидУдержанияПФ = СтруктураЗАполнения.ВидУдержанияПФ;
	
	РаспределитьНДФЛ();
	
КонецПроцедуры

&НаСервереБезКонтекста                                                   
Функция ПолучитьВидУдержанияНДФЛ(СтруктураСтроки, Дата)
	                                                            
	тзСотрудника = РегистрыСведений.Сотрудники.СрезПоследних(Дата, СтруктураСтроки);
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("ВидУдержанияНДФЛ", Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка());
	СтруктураВозврата.Вставить("ВидУдержанияПФ", Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка())
	
	;
	Если тзСотрудника.Количество() <> 0 Тогда 
		СтруктураВозврата.ВидУдержанияНДФЛ = тзСотрудника[0].ВидУдержанияНДФЛ;
		СтруктураВозврата.ВидУдержанияПФ = тзСотрудника[0].ВидУдержанияПФ;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

