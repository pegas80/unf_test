	//               |ИЗ
	//               |	&НачисленияИУдержания КАК НачислениеЗаработнойПлаты
	//               |;
	//               |
	//               |////////////////////////////////////////////////////////////////////////////////
	//               |ВЫБРАТЬ
	//               |	ВтНачисления.Сотрудник,
	//               |	СУММА(ВтНачисления.Сумма) КАК Сумма
	//               |ИЗ
	//               |	ВтНачисления КАК ВтНачисления
	//               |ГДЕ
	//               |	ВтНачисления.ВидНачисленияУдержания.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.Начисление)
	//               |
	//               |СГРУППИРОВАТЬ ПО
	//               |	ВтНачисления.Сотрудник";
