#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаНачислениеЗарплаты, СтруктураДополнительныеСвойства) Экспорт
	
	МассивСчетовФинРезРасходы = РегламентированныйУчетСервер.ПолучитьСчетаФинРезРасход();
	МассивСчетовФинРезДоходы = РегламентированныйУчетСервер.ПолучитьСчетаФинРезДоход();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	КурсыВалютРасчетов.Валюта,
	|	КурсыВалютРасчетов.Курс,
	|	КурсыВалютРасчетов.Кратность
	|ПОМЕСТИТЬ КурсыВалютРасчетов
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта = &ВалютаДокумента) КАК КурсыВалютРасчетов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КурсыВалютУчета.Валюта,
	|	КурсыВалютУчета.Курс,
	|	КурсыВалютУчета.Кратность
	|ПОМЕСТИТЬ КурсыВалютУчета
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта = &ВалютаУчета) КАК КурсыВалютУчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Удержания.НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	Удержания.Ссылка КАК Регистратор,
	|	Удержания.Ссылка.Дата КАК Период,
	|	Удержания.Ссылка.Организация,
	|	Удержания.Ссылка.СтруктурнаяЕдиница,
	|	Удержания.Ссылка.ВалютаДокумента КАК Валюта,
	|	Удержания.Сотрудник,
	|	Удержания.ВидУдержания,
	|	Удержания.ВидУдержания.Контрагент КАК Контрагент,
	|	Удержания.ВидУдержания.Договор КАК Договор,
	|	Удержания.Ссылка.ПериодРегистрации,
	|	Удержания.Ссылка.ПериодРегистрации КАК ДатаНачала,
	|	КОНЕЦПЕРИОДА(Удержания.Ссылка.ПериодРегистрации, МЕСЯЦ) КАК ДатаОкончания,
	|	Удержания.Сотрудник.СчетРасчетовСПерсоналомРегл КАК СчетРасчетовСПерсоналомРегл,
	|	Удержания.ВидУдержания.СчетЗатрат КАК СчетЗатрат,
	|	Удержания.ВидУдержания.СчетЗатратРегл КАК СчетЗатратРегл,
	|	Удержания.ВидУдержания.Контрагент.СчетУчетаРасчетовСПоставщикомРегл КАК СчетРасчетовСКонтрагентомРегл,
	|	ВЫРАЗИТЬ(Удержания.Сумма * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	Удержания.Сумма КАК СуммаВал,
	|	Удержания.ВидУдержанияПФ,
	|	Удержания.ВидУдержанияПФ.ПенсионныйНалогСотрудника КАК ПенсионныйНалогСотрудника,
	|	Удержания.ВидУдержанияПФ.ПенсионныйНалогОрганизации КАК ПенсионныйНалогОрганизации,
	|	Удержания.ВидУдержанияПФ.ПенсионныйНалогОрганизации.СчетУчетаРегл КАК СчетНачисленииПФОрганизации,
	|	Удержания.ВидУдержанияПФ.ПенсионныйНалогОрганизации.СчетУчетаКВозмещениюРегл КАК СчетКОплатеПФОрганизации,
	|	Удержания.ВидУдержанияПФ.ПенсионныйНалогСотрудника.СчетУчетаРегл КАК СчетНачисленииПФСотрудника,
	|	Удержания.ВидУдержанияПФ.ПенсионныйНалогСотрудника.СчетУчетаКВозмещениюРегл КАК СчетКОплатеПФСотрудника,
	|	Удержания.ВидУдержанияПФ.Контрагент КАК КонтрагентПФ,
	|	Удержания.ВидУдержанияПФ.Договор КАК ДоговорПФ,
	|	ВЫРАЗИТЬ(Удержания.СуммаПФ * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК СуммаПФ,
	|	Удержания.СуммаПФ КАК СуммаПФВал,
	|	Удержания.ВидУдержанияПФ.СчетЗатрат КАК СчетЗатратПФ,
	|	Удержания.ВидУдержанияПФ.СчетЗатратРегл КАК СчетЗатратПФРегл,
	|	Удержания.ВидУдержанияНДФЛ,
	|	Удержания.ВидУдержанияНДФЛ.ВидНалога КАК НДФЛНачислении,
	|	Удержания.ВидУдержанияНДФЛ.ВидНалогаВыплат КАК НДФЛКОплате,
	|	ВЫРАЗИТЬ(Удержания.СуммаНДФЛ * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК СуммаНДФЛ,
	|	Удержания.СуммаНДФЛ КАК СуммаНДФЛВал,
	|	Удержания.ВидУдержанияНДФЛ.СчетЗатрат КАК СчетЗатратНДФЛ,
	|	Удержания.ВидУдержанияНДФЛ.СчетЗатратРегл КАК СчетЗатратНДФЛРегл,
	|	Удержания.ВидУдержанияНДФЛ.ВидНалога.СчетУчета КАК НДФЛНачисленииСчетУчета,
	|	Удержания.ВидУдержанияНДФЛ.ВидНалога.СчетУчетаРегл КАК НДФЛНачисленииСчетУчетаРегл,
	|	Удержания.ВидУдержанияНДФЛ.ВидНалогаВыплат.СчетУчетаКВозмещению КАК НДФЛКОплатеСчетУчета,
	|	Удержания.ВидУдержанияНДФЛ.ВидНалогаВыплат.СчетУчетаКВозмещениюРегл КАК НДФЛКОплатеСчетУчетаРегл,
	|	Удержания.ВидУдержания.Тип,
	|	Удержания.Ссылка,
	|	Удержания.СуммаЛгот КАК СуммаЛгот
	|ПОМЕСТИТЬ Удержания
	|ИЗ
	|	Документ.НачислениеЗарплаты.Удержания КАК Удержания
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютУчета КАК КурсыВалютУчета
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютРасчетов КАК КурсыВалютРасчетов
	|		ПО Удержания.Ссылка.ВалютаДокумента = КурсыВалютРасчетов.Валюта
	|ГДЕ
	|	Удержания.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	НачислениеЗарплатыНачисленияУдержания.НомерСтроки КАК НомерСтроки,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.Дата КАК Период,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.ПериодРегистрации КАК ПериодРегистрации,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.ВалютаДокумента КАК Валюта,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НачислениеЗарплатыНачисленияУдержания.Сотрудник КАК Сотрудник,
	|	НачислениеЗарплатыНачисленияУдержания.СчетЗатрат КАК СчетЗатрат,
	|	НачислениеЗарплатыНачисленияУдержания.СчетЗатратРегл КАК СчетЗатратРегл,
	|	НачислениеЗарплатыНачисленияУдержания.ЗаказПокупателя КАК ЗаказПокупателя,
	|	НачислениеЗарплатыНачисленияУдержания.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	НачислениеЗарплатыНачисленияУдержания.ДатаНачала КАК ДатаНачала,
	|	НачислениеЗарплатыНачисленияУдержания.ДатаОкончания КАК ДатаОкончания,
	|	НачислениеЗарплатыНачисленияУдержания.ОтработаноДней КАК ОтработаноДней,
	|	НачислениеЗарплатыНачисленияУдержания.ОтработаноЧасов КАК ОтработаноЧасов,
	|	НачислениеЗарплатыНачисленияУдержания.Размер КАК Размер,
	|	НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
	|	ВЫРАЗИТЬ(НачислениеЗарплатыНачисленияУдержания.Сумма * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ,
	|	НачислениеЗарплатыНачисленияУдержания.СуммаПФ КАК СуммаПФВал,
	|	ВЫРАЗИТЬ(НачислениеЗарплатыНачисленияУдержания.СуммаПФ * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК СуммаПФ,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.ПенсионныйНалогСотрудника КАК ПенсионныйНалогСотрудника,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.ПенсионныйНалогОрганизации КАК ПенсионныйНалогОрганизации,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.СчетЗатрат КАК СчетЗатратПФ,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.СчетЗатратРегл КАК СчетЗатратРеглПФ,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.ПенсионныйНалогСотрудника.СчетУчетаРегл КАК СчетНачисленииПФСотрудника,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.ПенсионныйНалогОрганизации.СчетУчетаРегл КАК СчетНачисленииПФОрганизации,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.Контрагент КАК Контрагент,
	|	НачислениеЗарплатыНачисленияУдержания.ВидУдержанияПФ.Договор КАК Договор,
	|	НачислениеЗарплатыНачисленияУдержания.Сумма КАК СуммаВал,
	|   0
	|ПОМЕСТИТЬ ТаблицаНачисления
	|ИЗ
	|	Документ.НачислениеЗарплаты.НачисленияУдержания КАК НачислениеЗарплатыНачисленияУдержания
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютУчета КАК КурсыВалютУчета
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютРасчетов КАК КурсыВалютРасчетов
	|		ПО НачислениеЗарплатыНачисленияУдержания.Ссылка.ВалютаДокумента = КурсыВалютРасчетов.Валюта
	|ГДЕ
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Организация,
	|	НачислениеЗарплатыНачисленияУдержания.НомерСтроки,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.Дата,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.ПериодРегистрации,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.ВалютаДокумента,
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.СтруктурнаяЕдиница,
	|	НачислениеЗарплатыНачисленияУдержания.Сотрудник,
	|	НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания.ВидНалога.СчетУчета,
	|	НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания.ВидНалога.СчетУчетаРегл,
	|	ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка),
	|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка),
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка.ПериодРегистрации,
	|	КОНЕЦПЕРИОДА(НачислениеЗарплатыНачисленияУдержания.Ссылка.ПериодРегистрации, МЕСЯЦ),
	|	0,
	|	0,
	|	0,
	|	НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания,
	|	ВЫРАЗИТЬ(НачислениеЗарплатыНачисленияУдержания.Сумма * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)),
	|	НЕОПРЕДЕЛЕНО,
	|	0,
	|	0,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НЕОПРЕДЕЛЕНО,
	|	НачислениеЗарплатыНачисленияУдержания.Сумма,
	|   НачислениеЗарплатыНачисленияУдержания.СуммаЛгот
	|ИЗ
	|	Документ.НачислениеЗарплаты.НалогиНаДоходы КАК НачислениеЗарплатыНачисленияУдержания
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютУчета КАК КурсыВалютУчета
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютРасчетов КАК КурсыВалютРасчетов
	|		ПО НачислениеЗарплатыНачисленияУдержания.Ссылка.ВалютаДокумента = КурсыВалютРасчетов.Валюта
	|ГДЕ
	|	НачислениеЗарплатыНачисленияУдержания.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	НачислениеЗарплатыВзносы.НомерСтроки КАК НомерСтроки,
	|	НачислениеЗарплатыВзносы.Ссылка.Дата КАК Период,
	|	НачислениеЗарплатыВзносы.Ссылка.ПериодРегистрации КАК ПериодРегистрации,
	|	НачислениеЗарплатыВзносы.Ссылка.ВалютаДокумента КАК Валюта,
	|	НачислениеЗарплатыВзносы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НачислениеЗарплатыВзносы.Сотрудник КАК Сотрудник,
	|	НачислениеЗарплатыВзносы.СчетЗатрат КАК СчетЗатрат,
	|	НачислениеЗарплатыВзносы.СчетЗатратРегл КАК СчетЗатратРегл,
	|	НачислениеЗарплатыВзносы.ЗаказПокупателя КАК ЗаказПокупателя,
	|	НачислениеЗарплатыВзносы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	НачислениеЗарплатыВзносы.Ссылка.ПериодРегистрации КАК ДатаНачала,
	|	КОНЕЦПЕРИОДА(НачислениеЗарплатыВзносы.Ссылка.ПериодРегистрации, МЕСЯЦ) КАК ДатаОкончания,
	|	0 КАК ОтработаноДней,
	|	0 КАК ОтработаноЧасов,
	|	0 КАК Размер,
	|	НачислениеЗарплатыВзносы.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
	|	ВЫРАЗИТЬ(НачислениеЗарплатыВзносы.Сумма * КурсыВалютРасчетов.Курс * КурсыВалютУчета.Кратность / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	НачислениеЗарплатыВзносы.Сумма КАК СуммаВал
	|ПОМЕСТИТЬ ТаблицаВзносов
	|ИЗ
	|	Документ.НачислениеЗарплаты.Взносы КАК НачислениеЗарплатыВзносы
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютУчета КАК КурсыВалютУчета
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ КурсыВалютРасчетов КАК КурсыВалютРасчетов
	|		ПО НачислениеЗарплатыВзносы.Ссылка.ВалютаДокумента = КурсыВалютРасчетов.Валюта
	|ГДЕ
	|	НачислениеЗарплатыВзносы.Ссылка = &Ссылка 
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
