Процедура РаспределитьНДФЛДекларации(ТаблицаЗначений,СтруктураДополнительныеСвойства)
	
	ТаблицаЗначений.Сортировать("Сумма Возр");
	
	СтаршийИндексКолонок = ТаблицаЗначений.Колонки.Количество() - 1; 

	Индекс = ТаблицаЗначений.Количество() - 1; 	
	
	//Получить сумму начисения НДФЛ для распределения 
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(НачислениеЗарплатыНачисленияУдержания.Сумма) КАК Сумма
	               |ИЗ
	               |	ТаблицаНачисления КАК НачислениеЗарплатыНачисленияУдержания
	               |ГДЕ
	               |	НачислениеЗарплатыНачисленияУдержания.СуммаВал <> 0
	               |	И НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.Налог)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		СуммаНДФЛ    = Выборка.Сумма;
	Иначе
		СуммаНДФЛ    = 0;
	КонецЕсли;	
	
	СуммаНДФЛ = СуммаНДФЛ / 0.2;
		
	Пока Индекс >= 0 Цикл 								 					
		
		Если ТаблицаЗначений[Индекс].ВидДвижения = ВидДвиженияНакопления.Расход Тогда
			
			Если СуммаНДФЛ < ТаблицаЗначений[Индекс].Сумма Тогда
				Если СуммаНДФЛ <> 0 Тогда	
					ТаблицаЗначений[Индекс].Сумма = (ТаблицаЗначений[Индекс].Сумма - СуммаНДФЛ);	
					СуммаНДФЛ = 0;								
				КонецЕсли;	
			Иначе
				СуммаНДФЛ = СуммаНДФЛ - ТаблицаЗначений[Индекс].Сумма;
				ТаблицаЗначений.Удалить(Индекс);	 
			КонецЕсли;		
						
			
		КонецЕсли;
		
		Индекс = Индекс - 1;
		
	КонецЦикла;
	
КонецПроцедуры


