Процедура РаспределитьНДФЛ(ТаблицаЗначений,СтруктураДополнительныеСвойства)
	
	ТаблицаЗначений.Сортировать("Сумма Возр");
	
	СтаршийИндексКолонок = ТаблицаЗначений.Колонки.Количество() - 1; 

	Индекс = ТаблицаЗначений.Количество() - 1; 	
	
	//Получить сумму начисения НДФЛ для распределения 
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(НачислениеЗарплатыНачисленияУдержания.Сумма) КАК Сумма
	               |ИЗ
	               |	ТаблицаНачисления КАК НачислениеЗарплатыНачисленияУдержания
	               |ГДЕ
	               |	НачислениеЗарплатыНачисленияУдержания.СуммаВал <> 0
	               |	И НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.Налог)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		СуммаНДФЛ    = Выборка.Сумма;
		СуммаНДФЛРас = Выборка.Сумма;
	Иначе
		СуммаНДФЛ    = 0;
		СуммаНДФЛРас = 0;
	КонецЕсли;	
		
	Пока Индекс >= 0 Цикл 								 					
		
		Если ТаблицаЗначений[Индекс].Распределить  Тогда
			
			Если ТаблицаЗначений[Индекс].ВидДвижения = ВидДвиженияНакопления.Приход Тогда
				Если СуммаНДФЛ < ТаблицаЗначений[Индекс].Сумма Тогда
					Если СуммаНДФЛ = 0 Тогда
						ТаблицаЗначений.Удалить(Индекс);
					Иначе
						ТаблицаЗначений[Индекс].Сумма = СуммаНДФЛ;
						СуммаНДФЛ = 0;
					КонецЕсли;	
				Иначе
					СуммаНДФЛ = СуммаНДФЛ - ТаблицаЗначений[Индекс].Сумма; 
				КонецЕсли;
			Иначе
				Если СуммаНДФЛРас < ТаблицаЗначений[Индекс].Сумма Тогда
					Если СуммаНДФЛРас = 0 Тогда
						ТаблицаЗначений.Удалить(Индекс);
					Иначе
						ТаблицаЗначений[Индекс].Сумма = СуммаНДФЛРас;
						СуммаНДФЛРас = 0;
					КонецЕсли;	
				Иначе
					СуммаНДФЛРас = СуммаНДФЛРас - ТаблицаЗначений[Индекс].Сумма; 
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		Индекс = Индекс - 1;
		
    КонецЦикла;
	
КонецПроцедуры	

// Выполняет контроль возникновения отрицательных остатков.
//
Процедура ВыполнитьКонтроль(ДокументСсылкаНачислениеЗарплаты, ДополнительныеСвойства, Отказ, УдалениеПроведения = Ложь) Экспорт
	
	Если Не УправлениеНебольшойФирмойСервер.ВыполнитьКонтрольОстатков() Тогда
		Возврат;
	КонецЕсли;
	
	// Kuzmich, 13.01.2020, Запрет проведения документов зарплаты, если нет присоединенных файлов.
	Если НЕ УдалениеПроведения Тогда
		
		ДокументСсылкаНачислениеЗарплаты_Объект = ДокументСсылкаНачислениеЗарплаты.ПолучитьОбъект();
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НачислениеЗарплатыНачисленияУдержания.Сотрудник,
		|	НачислениеЗарплатыНачисленияУдержания.НомерСтроки
		|ИЗ
		|	Справочник.СотрудникиПрисоединенныеФайлы КАК СотрудникиПрисоединенныеФайлы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты.НачисленияУдержания КАК НачислениеЗарплатыНачисленияУдержания
		|		ПО СотрудникиПрисоединенныеФайлы.ВладелецФайла = НачислениеЗарплатыНачисленияУдержания.Сотрудник
		|			И (НЕ СотрудникиПрисоединенныеФайлы.Одобрен)
		|			И (НачислениеЗарплатыНачисленияУдержания.Ссылка = &Ссылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	НачислениеЗарплатыНачисленияУдержания.Сотрудник,
		|	НачислениеЗарплатыНачисленияУдержания.НомерСтроки";
		
		Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаНачислениеЗарплаты.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka='თანამშრომელმა %1 არ წარადგინა ყველა აუცილებელი დოკუმენტი';ru='Сотрудник %1 не принес все необходимые документы'"),
			ВыборкаДетальныеЗаписи.Сотрудник);
			УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ДокументСсылкаНачислениеЗарплаты_Объект,СтрокаСообщения,"НачисленияУдержания",ВыборкаДетальныеЗаписи.НомерСтроки,"Сотрудник",Отказ);
			Отказ = ИСТИНА;
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НачислениеЗарплатыУдержания.Сотрудник,
		|	НачислениеЗарплатыУдержания.НомерСтроки
		|ИЗ
		|	Справочник.СотрудникиПрисоединенныеФайлы КАК СотрудникиПрисоединенныеФайлы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты.Удержания КАК НачислениеЗарплатыУдержания
		|		ПО СотрудникиПрисоединенныеФайлы.ВладелецФайла = НачислениеЗарплатыУдержания.Сотрудник
		|			И (НЕ СотрудникиПрисоединенныеФайлы.Одобрен)
		|			И (НачислениеЗарплатыУдержания.Ссылка = &Ссылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	НачислениеЗарплатыУдержания.Сотрудник,
		|	НачислениеЗарплатыУдержания.НомерСтроки";
		
		Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаНачислениеЗарплаты.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтрокаСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka='თანამშრომელმა %1 არ წარადგინა ყველა აუცილებელი დოკუმენტი';ru='Сотрудник %1 не принес все необходимые документы'"),
			ВыборкаДетальныеЗаписи.Сотрудник);
			УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ДокументСсылкаНачислениеЗарплаты_Объект,СтрокаСообщения,"Удержания",ВыборкаДетальныеЗаписи.НомерСтроки,"Сотрудник",Отказ);
			Отказ = ИСТИНА;
		КонецЦикла;
		
	КонецЕсли;
	// Kuzmich, 13.01.2020, Запрет проведения документов зарплаты, если нет присоединенных файлов.

	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
КонецПроцедуры

