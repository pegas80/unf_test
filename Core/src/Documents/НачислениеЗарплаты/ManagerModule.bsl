	|					ИЛИ &СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении
	|						И Удержания.ВидУдержанияТип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.УдержаниеДляКонтрагента)
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И Удержания.СуммаЛгот <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	Удержания.ПериодРегистрации,
	|	Удержания.Организация,
	|	Удержания.Сотрудник,
	|	Удержания.СтруктурнаяЕдиница,
	|	Удержания.СуммаЛгот,
	|	ЗНАЧЕНИЕ(Перечисление.ТипЛгот.Прочее)
	|ИЗ
	|	Удержания КАК Удержания
	|ГДЕ
	|	НЕ Удержания.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
	|	И ВЫБОР
	|			КОГДА Удержания.ВидУдержанияТип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.Удержание)
	|					ИЛИ &СуммыНалоговУдержаниеДляКонтрагентаКОплатеПриНачислении
	|						И Удержания.ВидУдержанияТип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний.УдержаниеДляКонтрагента)
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ
	|	И Удержания.СуммаЛгот <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	ТаблицаПогашениеЗаймов.ПериодРегистрации,
	|	ТаблицаПогашениеЗаймов.Организация,
	|	ТаблицаПогашениеЗаймов.Сотрудник,
	|	ТаблицаПогашениеЗаймов.СтруктурнаяЕдиница,
	|	ТаблицаПогашениеЗаймов.СуммаЛгот,
	|	ЗНАЧЕНИЕ(Перечисление.ТипЛгот.Прочее)
	|ИЗ
	|	ТаблицаПогашениеЗаймов КАК ТаблицаПогашениеЗаймов
	|ГДЕ
	|	НЕ ТаблицаПогашениеЗаймов.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
	|	И ТаблицаПогашениеЗаймов.ПогашеноЗайма <> 0
	|	И ТаблицаПогашениеЗаймов.СуммаЛгот <> 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
	|	ТаблицаПогашениеЗаймов.ПериодРегистрации,
	|	ТаблицаПогашениеЗаймов.Организация,
	|	ТаблицаПогашениеЗаймов.Сотрудник,
	|	ТаблицаПогашениеЗаймов.СтруктурнаяЕдиница,
	|	ТаблицаПогашениеЗаймов.СуммаЛготПроцента,
	|	ЗНАЧЕНИЕ(Перечисление.ТипЛгот.Прочее)
	|ИЗ
	|	ТаблицаПогашениеЗаймов КАК ТаблицаПогашениеЗаймов
	|ГДЕ
	|	НЕ ТаблицаПогашениеЗаймов.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
	|	И ТаблицаПогашениеЗаймов.ПогашеноПроцентов <> 0
	|	И ТаблицаПогашениеЗаймов.СуммаЛготПроцента <> 0";
		
	
	Запрос.УстановитьПараметр("Ссылка",ДокументСсылкаНачислениеЗарплаты);
	
	ТаблицаНалоговыеЛготы = Запрос.Выполнить().Выгрузить();
	
