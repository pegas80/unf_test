

&НаКлиенте
Процедура ДобавитьПоГруппе(Команда)
	
	СтруктураВыбора = Новый Структура("МножественныйВыбор", Истина);
	ВыбранныеГруппы = ПолучитьФорму("Справочник.Номенклатура.Форма.ФормаВыбораГруппы", СтруктураВыбора);
	Результат = ВыбранныеГруппы.ОткрытьМодально();
	Если НЕ Результат = Неопределено Тогда
		ДобавитьПоГруппеНаСервере(Результат);
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьПоГруппеНаСервере(ВыбранныеГруппы)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Запасы.Номенклатура
		|ПОМЕСТИТЬ Запасы
		|ИЗ
		|	&Запасы КАК Запасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Номенклатура
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И НЕ Номенклатура.ЭтоГруппа
		|	И Номенклатура.Ссылка В ИЕРАРХИИ(&ВыбранныеГруппы)
		|	И НЕ Номенклатура.Ссылка В
		|				(ВЫБРАТЬ
		|					Запасы.Номенклатура
		|				ИЗ
		|					Запасы КАК Запасы)";
	Запрос.УстановитьПараметр("ВыбранныеГруппы",	ВыбранныеГруппы);
	Запрос.УстановитьПараметр("Запасы", 			Объект.Запасы.Выгрузить());
	ТаблицаНоменклатур = Запрос.Выполнить().Выгрузить();
		
	Для Каждого СтрокаТЧ ИЗ ТаблицаНоменклатур Цикл
		НовСтрока = Объект.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	РС_ОбщегоНазначенияКлиент.ПроверкаМодифицированостиВопрос(Объект.Ссылка, Модифицированность, Отказ);//Паганини
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияПереопределяемый.УстановитьДополнительноеПоведениеСтандартныхКнопокТЧЗапасы(ЭтаФорма);// Kuzmich, 07.08.2019, Дополнительные инструменты в табличных частях документов движения товаров
КонецПроцедуры
