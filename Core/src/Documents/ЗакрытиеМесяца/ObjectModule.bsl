										СтрокаДвижения.Вставить("СчетУчета"             , ОбходПоСчетамУчета.СчетУчетаСчетЗакрытия);
										СтрокаДвижения.Вставить("СчетУчетаРегл"         , СчетНезавершенноеПроизводство);
