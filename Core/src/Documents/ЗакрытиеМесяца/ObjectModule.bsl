		//ТаблицаРаспределенияСвернутая.Свернуть("Организация,СчетУчета,Номенклатура,Характеристика,Партия,ЗаказПокупателя,СчетУчетаРегл,СчетУчетаЗатратРегл,Проект,ДокументПоступления","Сумма");
		// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
		ТаблицаРаспределенияСвернутая.Свернуть("Организация,СчетУчета,Номенклатура,Характеристика,Партия,ЗаказПокупателя,СчетУчетаРегл,СчетУчетаЗатратРегл,Проект,ДокументПоступления","Сумма,СуммаРасход");
		// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
		
		Для каждого СтрокаТаблицаРаспределенияСвернутая Из ТаблицаРаспределенияСвернутая Цикл
			
			СтараяСумма = СтрокаТаблицаРаспределенияСвернутая.Сумма;
			НоваяСумма = 0;
		
			СтрокаМаксимум = НЕОПРЕДЕЛЕНО;
			СуммаМаксимум = 0;
			СтрокаМинимум = НЕОПРЕДЕЛЕНО;
			СуммаМинимум = 9999999999;
			
			// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
			СтараяСуммаРасход = СтрокаТаблицаРаспределенияСвернутая.СуммаРасход;
			НоваяСуммаРасход = 0;
		
			СтрокаМаксимумРасход = НЕОПРЕДЕЛЕНО;
			СуммаМаксимумРасход = 0;
			СтрокаМинимумРасход = НЕОПРЕДЕЛЕНО;
			СуммаМинимумРасход = 9999999999;
			// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
			
			СтруктураПоиска = Новый Структура("Организация,СчетУчета,Номенклатура,Характеристика,Партия,ЗаказПокупателя,СчетУчетаРегл,СчетУчетаЗатратРегл,Проект,ДокументПоступления", 
			СтрокаТаблицаРаспределенияСвернутая.Организация,СтрокаТаблицаРаспределенияСвернутая.СчетУчета,
			СтрокаТаблицаРаспределенияСвернутая.Номенклатура,СтрокаТаблицаРаспределенияСвернутая.Характеристика,СтрокаТаблицаРаспределенияСвернутая.Партия,
			СтрокаТаблицаРаспределенияСвернутая.ЗаказПокупателя,СтрокаТаблицаРаспределенияСвернутая.СчетУчетаРегл,
			СтрокаТаблицаРаспределенияСвернутая.СчетУчетаЗатратРегл,СтрокаТаблицаРаспределенияСвернутая.Проект,СтрокаТаблицаРаспределенияСвернутая.ДокументПоступления);
			
			НайденныеСтроки = ТаблицаРаспределения.НайтиСтроки(СтруктураПоиска);
			Для каждого СтрокаНайденныеСтроки Из НайденныеСтроки Цикл
			
				СтрокаНайденныеСтроки.Сумма = ОКР(СтрокаНайденныеСтроки.Сумма,2,РежимОкругления.Окр15как20);
				НоваяСумма = НоваяСумма + СтрокаНайденныеСтроки.Сумма;
				
				Если СтрокаНайденныеСтроки.Сумма>СуммаМаксимум Тогда
				
					СуммаМаксимум = СтрокаНайденныеСтроки.Сумма;
					СтрокаМаксимум = СтрокаНайденныеСтроки;
				
				КонецЕсли;
				
				Если СтрокаНайденныеСтроки.Сумма<СуммаМинимум Тогда
				
					СуммаМинимум = СтрокаНайденныеСтроки.Сумма;
					СтрокаМинимум = СтрокаНайденныеСтроки;
				
				КонецЕсли;
				
				// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
				СтрокаНайденныеСтроки.СуммаРасход = ОКР(СтрокаНайденныеСтроки.СуммаРасход,2,РежимОкругления.Окр15как20);
				НоваяСуммаРасход = НоваяСуммаРасход + СтрокаНайденныеСтроки.СуммаРасход;
				
				Если СтрокаНайденныеСтроки.СуммаРасход>СуммаМаксимумРасход Тогда
				
					СуммаМаксимумРасход = СтрокаНайденныеСтроки.СуммаРасход;
					СтрокаМаксимумРасход = СтрокаНайденныеСтроки;
				
				КонецЕсли;
				
				Если СтрокаНайденныеСтроки.СуммаРасход<СуммаМинимумРасход Тогда
				
					СуммаМинимумРасход = СтрокаНайденныеСтроки.СуммаРасход;
					СтрокаМинимумРасход = СтрокаНайденныеСтроки;
				
				КонецЕсли
				// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
			
			КонецЦикла;
			
			Дельта = СтараяСумма - НоваяСумма;
			
			Если Дельта>0 Тогда
			
				СтрокаМинимум.Сумма = СтрокаМинимум.Сумма + Дельта;
				
			ИначеЕсли Дельта<0 Тогда
			
				СтрокаМаксимум.Сумма = СтрокаМаксимум.Сумма + Дельта;
			
			КонецЕсли;
			
			// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
			ДельтаРасход = СтараяСуммаРасход - НоваяСуммаРасход;
			
			Если ДельтаРасход>0 Тогда
			
				СтрокаМинимумРасход.СуммаРасход = СтрокаМинимумРасход.СуммаРасход + ДельтаРасход;
				
			ИначеЕсли ДельтаРасход<0 Тогда
			
				СтрокаМаксимумРасход.СуммаРасход = СтрокаМаксимумРасход.СуммаРасход + ДельтаРасход;
			
			КонецЕсли;
			// Kuzmich, 18.11.2025, (ONESOFT-4515) Закрытие месяца - распределение накладных (прямих) расходов на расходы пропорционально списанию/продажи
		
		КонецЦикла;
	
	КонецЕсли;	

КонецПроцедуры

Процедура СформироватьКорректирующиеДвиженияПоРегиструУчетаЗатрат_ОтключениеУсреднения(ТаблицаРаспределения)
	
	Если НЕ(ТипЗНЧ(ТаблицаРаспределения)=Тип("ТаблицаЗначений"))Тогда
		Возврат;
	ИначеЕсли  НЕ(ТаблицаРаспределения.Количество()>0) ТОГДА
		Возврат;
	КонецЕсли;
	
	// Создадим набор записей регистра накопления Учет запасов и затрат.
	НаборЗаписейЗапасы = РегистрыНакопления.Запасы.СоздатьНаборЗаписей();
