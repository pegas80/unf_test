									//БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, "Подразделения", НаправлениеРаспределения.СтруктурнаяЕдиница);
									////БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, "Склады", СтрокаДвижения.КоррСтруктурнаяЕдиница);
									//
									////БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Номенклатура", СтрокаДвижения.Номенклатура);
									//БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Подразделения", НаправлениеРаспределения.СтруктурнаяЕдиница);
