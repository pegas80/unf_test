						ДобавитьОшибкуВТаблицу(ОписаниеОшибки, "РаспределениеЗатрат", ТаблицаОшибок, ФильтрПоЗаказ);
						Продолжить;
					КонецЕсли;
					
					ВсегоБазаРаспределения = ТаблицаБазы.Итог("База");
					КоличествоНаправлений  = ТаблицаБазы.Количество() - 1;
					
