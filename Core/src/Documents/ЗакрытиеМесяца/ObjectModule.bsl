										КонецЕсли;	
											
										
										СтрокаДвижения.Вставить("ЗаказПокупателя"       , Документы.ЗаказПокупателя.ПустаяСсылка());
										СтрокаДвижения.Вставить("КоррСтруктурнаяЕдиница", НаправлениеРаспределения.СтруктурнаяЕдиница);
