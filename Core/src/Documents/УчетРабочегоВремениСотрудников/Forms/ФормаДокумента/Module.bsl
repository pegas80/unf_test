&НаКлиенте
Процедура ЗаполнитьПоДаннымУчета(Команда)
	
	Если Объект.ПериодыВремени.Количество() Тогда
	
		ТекстВопроса = НСтр("ka='Табличная часть будет очищена! Продолжить?';ru='Табличная часть будет очищена! Продолжить?';en='Табличная часть будет очищена! Продолжить?'");
		ПоказатьВопрос(Новый ОписаниеОповещения("ЗаполнитьПоДаннымУчетаЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	
	Иначе
	
		ЗаполнитьПоДаннымУчетаНаСервере();
	    ОбновитьКоличествоВремени(); //+++ Дмгг
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоДаннымУчетаЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
	
		ЗаполнитьПоДаннымУчетаНаСервере();
	
	КонецЕсли; 

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДаннымУчетаНаСервере()
	
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	ДокОбъект.ЗаполнитьПоДаннымУчета();
	ЗначениеВДанныеФормы(ДокОбъект, Объект);
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодыВремениПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.ПериодыВремени.ТекущиеДанные;
	ИДСтроки = ?(ТекущиеДанные = Неопределено, Неопределено, ТекущиеДанные.ПолучитьИдентификатор());
	ОтобразитьПроходыСотрудникаСтроки(ИДСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьПроходыСотрудникаСтроки(ИДСтроки)

	ТекущиеДанные = ?(ИДСтроки = Неопределено, Неопределено, Объект.ПериодыВремени.НайтиПоИдентификатору(ИДСтроки));
	ПроходыСотрудников.Параметры.УстановитьЗначениеПараметра("РабочийДень", НачалоДня(Объект.Дата));
	ПроходыСотрудников.Параметры.УстановитьЗначениеПараметра("Сотрудник", ?(ТекущиеДанные = Неопределено, ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка"), ТекущиеДанные.Сотрудник));
	Элементы.ПроходыСотрудников.Обновить();

КонецПроцедуры // ОтобразитьПроходыСотрудникаСтроки()
 
&НаКлиенте
Процедура ОбновитьКоличествоВремени()

	Для Каждого Строк Из Объект.ПериодыВремени Цикл 
		
		ВремяОкончания = ?(ЗначениеЗаполнено(Строк.Уход), Строк.Уход, Строк.ВремяОкончания);
		ВремяНачала = ?(ЗначениеЗаполнено(Строк.Приход), Строк.Приход, Строк.ВремяНачала);
		Строк.КоличествоВремени = Дата(1,1,1) + (ВремяОкончания - ВремяНачала);
		
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПериодыПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ПериодыВремени.ТекущиеДанные;
	
	Если НЕ ТекущиеДанные = Неопределено Тогда 
		ВремяОкончания = ?(ЗначениеЗаполнено(ТекущиеДанные.Уход), ТекущиеДанные.Уход, ТекущиеДанные.ВремяОкончания);
		ВремяНачала = ?(ЗначениеЗаполнено(ТекущиеДанные.Приход), ТекущиеДанные.Приход, ТекущиеДанные.ВремяНачала);
		ТекущиеДанные.КоличествоВремени = Дата(1,1,1) + (ВремяОкончания - ВремяНачала);
		
		ВремяБезТекущейСтроки = ПолучитьВремяДругихСтрокНаСервере(ТекущиеДанные.НомерСтроки, ТекущиеДанные.Сотрудник, ТекущиеДанные.СтруктурнаяЕдиница);

		КолвоМинут = Цел((ВремяОкончания - ВремяНачала) / 60);
		КолвоЧасов = Цел(КолвоМинут / 60);
		ЧисловоеЗначениеМинут = (КолвоМинут - КолвоЧасов * 60) / 60;
		ТекущиеДанные.КоличествоЧасов = КолвоЧасов + ЧисловоеЗначениеМинут - ВремяБезТекущейСтроки;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьВремяДругихСтрокНаСервере(НомерСтроки, Сотрудник, СтруктурнаяЕдиница)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	тзВремени.НомерСтроки КАК НомерСтроки,
		|	тзВремени.Сотрудник КАК Сотрудник,
		|	тзВремени.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	тзВремени.ГрафикРаботы КАК ГрафикРаботы,
		|	тзВремени.КоличествоЧасов КАК КоличествоЧасов,
		|	тзВремени.ПричинаНевыхода КАК ПричинаНевыхода
		|ПОМЕСТИТЬ ВТ_Периоды
		|ИЗ
		|	&тзВремени КАК тзВремени
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Периоды.Сотрудник КАК Сотрудник,
		|	ВТ_Периоды.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	СУММА(ВТ_Периоды.КоличествоЧасов) КАК КоличествоЧасов
		|ИЗ
		|	ВТ_Периоды КАК ВТ_Периоды
		|ГДЕ
		|	ВТ_Периоды.Сотрудник = &Сотрудник
		|	И ВТ_Периоды.СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|	И ВТ_Периоды.НомерСтроки <> &НомерСтроки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Периоды.Сотрудник,
		|	ВТ_Периоды.СтруктурнаяЕдиница";
	
	Запрос.УстановитьПараметр("тзВремени", Объект.ПериодыВремени.Выгрузить());
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("НомерСтроки", НомерСтроки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ЗначениеВозврата = 0;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗначениеВозврата = ВыборкаДетальныеЗаписи.КоличествоЧасов;
	КонецЦикла;
	
	Возврат ЗначениеВозврата;
	
КонецФункции // ПолучитьВремяДругихСтрокНаСервере()

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	ОбновитьКоличествоВремени();
КонецПроцедуры
