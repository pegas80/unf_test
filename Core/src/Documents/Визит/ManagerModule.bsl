Функция НайтиИлиСоздатьДокументРеализации(ДокументСсылка) Экспорт
	Документ = Документы.РасходнаяНакладная.НайтиПоРеквизиту("ДокументВизита", ДокументСсылка);
	
	// Если документ не был найден то создадим его
	Если Документ.Пустая() Тогда 
	    ДокументОбъект = Документы.РасходнаяНакладная.СоздатьДокумент();
		ДокументОбъект.ДокументВизита = ДокументСсылка;
	Иначе 
		ДокументОбъект = Документ.ПолучитьОбъект();
	КонецЕсли;
	
	ДокументОбъект.Запасы.Очистить();
	
	Если ДокументСсылка.Реализация.Количество() > 0 Тогда	
		ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю;
		
		СостояниеДокумента = "";
		КартинкаСостоянияДокумента = 0;
		РазрешеноПроведение = Истина;
		
		УправлениеНебольшойФирмойСервер.ЗаполнитьШапкуДокумента(
			ДокументОбъект, 
			ДокументОбъект.ВидОперации,
			Документы.РасходнаяНакладная.ПустаяСсылка(), // Пустая ссылка на документ для парамента копирования
			Неопределено,  // Основание для создания
			СостояниеДокумента,
			Новый Структура() // Параметры заполнения
		);
		
		// Заполним реквизиты по документу "Визит"
		ДокументОбъект.Дата			= ДокументСсылка.Дата;
		ДокументОбъект.Автор		= ДокументСсылка.Автор;
		ДокументОбъект.ТорговаяТочка= ДокументСсылка.ТорговаяТочка;
		ДокументОбъект.Комментарий	= ДокументСсылка.Комментарий;
		ДокументОбъект.Ответственный= ДокументСсылка.Ответственный;
		ДокументОбъект.ВидЭлектронногоДокумента = Перечисления.ВидыЭД.ТОРГ12Продавец;
		
		ДокументОбъект.Контрагент	= ДокументСсылка.Контрагент;
		ДокументОбъект.Договор		= ДокументСсылка.Договор;
		ДокументОбъект.Организация	= ДокументОбъект.Договор.Организация;
		ДокументОбъект.СтруктурнаяЕдиница = ДокументСсылка.СтруктурнаяЕдиница;
			
		СтруктураСчетовКурсРазниц = РегистрыСведений.УчетнаяПолитикаРегл.СоздатьМенеджерЗаписи();
		СтруктураСчетовКурсРазниц.Организация = ?(НЕ ЗначениеЗаполнено(ДокументОбъект.Организация), УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ПараметрыСеанса.ТекущийПользователь, "ОсновнаяОрганизация"), ДокументОбъект.Организация);
		СтруктураСчетовКурсРазниц.Период = ?(НЕ ЗначениеЗаполнено(ДокументОбъект.Дата), ТекущаяДата(),ДокументОбъект.Дата);
		СтруктураСчетовКурсРазниц.Прочитать();
		Если СтруктураСчетовКурсРазниц.Выбран() Тогда
			ДокументОбъект.СчетЗатратБезвозмезднойПродажи 			= СтруктураСчетовКурсРазниц.СчетЗатратБезвозмезднойПродажи;
			ДокументОбъект.СчетЗатратНДСБезвозмезднойПродажи   		= СтруктураСчетовКурсРазниц.СчетЗатратНДСБезвозмезднойПродажи;
			ДокументОбъект.СчетУчетаНалогаНаПрибыль     			= СтруктураСчетовКурсРазниц.СчетУчетаНалогаНаПрибыль;
			ДокументОбъект.СчетУчетаНалогаНаПрибыльПодлежащийОплате = СтруктураСчетовКурсРазниц.СчетУчетаНалогаНаПрибыльПодлежащийОплате;
		КонецЕсли;	

		// Заполним валюту и курс по валюте из договора
		ДокументОбъект.ВалютаДокумента	= ДокументОбъект.Договор.ВалютаРасчетов;
		ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументОбъект.Дата, Новый Структура("Валюта", ДокументОбъект.Договор.ВалютаРасчетов));
		ДокументОбъект.Курс			= ?(ВалютаРасчетовКурсКратность.Курс = 0, 1, ВалютаРасчетовКурсКратность.Курс);
		ДокументОбъект.Кратность			= ?(ВалютаРасчетовКурсКратность.Кратность = 0, 1, ВалютаРасчетовКурсКратность.Кратность);
		ДокументОбъект.ВидСкидкиНаценки		= ДокументОбъект.Договор.ВидСкидкиНаценки;
		Если ЗначениеЗаполнено(ДокументСсылка.ВидЦен) Тогда
		    ДокументОбъект.ВидЦен				= ДокументСсылка.ВидЦен;
		Иначе
			ДокументОбъект.ВидЦен				= ДокументОбъект.Договор.ВидЦен;
		КонецЕсли; 
		
		ДокументОбъект.СуммаВключаетНДС		= ДокументОбъект.ВидЦен.ЦенаВключаетНДС;
		ДокументОбъект.ТранспортноеСредство	= ДокументОбъект.ТранспортноеСредство;
		
		// Найдём банковский счет и кассу по организации и валюте		
		// Если основной банковский счет организации имеет туже валюту что валюта документа используем его в документе
		Если ДокументОбъект.Организация.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств = ДокументОбъект.ВалютаДокумента Тогда 
			ДокументОбъект.БанковскийСчет = ДокументОбъект.Организация.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств
		КонецЕсли;
		
		
		
		ДокументОбъект.НалогообложениеНДС = УправлениеНебольшойФирмойСервер.НалогообложениеНДС(ДокументОбъект.Организация,, ДокументОбъект.Дата);
		//ДокументОбъект.НалогообложениеНДС = ПроведениеНДС_И_RSGE.ПолучитьЗначечениеНалогооблажение(ДокументОбъект.Организация, ДокументОбъект.Контрагент, ДокументОбъект.Договор, ДокументОбъект.Дата, Истина);
		
		// Заполним товары
		Для Каждого Эл Из ДокументСсылка.Реализация Цикл
			СтрокаЗапасы = ДокументОбъект.Запасы.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаЗапасы, Эл);
			СтрокаЗапасы.ЭтоПодарок=Эл.Подарок;
			// Заполним единицу измерения  базовой единице (в документе визит нет единицы!!!)
			СтрокаЗапасы.ЕдиницаИзмерения	= СтрокаЗапасы.Номенклатура.ЕдиницаИзмерения;
			
			// Расчет суммы НДС
			СтрокаЗапасы.СтавкаНДС	= СтрокаЗапасы.Номенклатура.СтавкаНДС;
			СтрокаЗапасы.ТипНоменклатурыЗапас = Истина;
			
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаЗапасы.СтавкаНДС);
			
			Если ДокументОбъект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда 
				СтрокаЗапасы.СуммаНДС = ?(ДокументОбъект.СуммаВключаетНДС, СтрокаЗапасы.Сумма - (СтрокаЗапасы.Сумма) / ((СтавкаНДС + 100) / 100),
										  							СтрокаЗапасы.Сумма * СтавкаНДС / 100);
			Иначе
				СтрокаЗапасы.СуммаНДС = 0;
			КонецЕсли;
			
			СтрокаЗапасы.Всего		= ?(ДокументОбъект.СуммаВключаетНДС, СтрокаЗапасы.Сумма, СтрокаЗапасы.Сумма + СтрокаЗапасы.СуммаНДС);
		КонецЦикла;		
		
		// Если документ был помечен на удаление снимим пометку
		Если Не ДокументОбъект.ЭтоНовый() Тогда 
			ДокументОбъект.Записать(); // Сначала запишем документ
			ДокументОбъект.УстановитьПометкуУдаления(Ложь);
		КонецЕсли;
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
	Иначе
		
		Если Не ДокументОбъект.ЭтоНовый() Тогда 
			ДокументОбъект.Записать(); // Сначала запишем документ
		    ДокументОбъект.УстановитьПометкуУдаления(Истина);
		    ДокументОбъект.Записать();
		КонецЕсли;		
	КонецЕсли;
	
	Возврат ДокументОбъект.Ссылка;	
КонецФункции

Функция НайтиИлиСоздатьДокументПКО(ДокументСсылка) Экспорт
	Документ = Документы.ПоступлениеВКассу.НайтиПоРеквизиту("ДокументВизита", ДокументСсылка);
	
	// Если документ не был найден то создадим его
	Если Документ.Пустая() Тогда 
	    ДокументОбъект = Документы.ПоступлениеВКассу.СоздатьДокумент();
		ДокументОбъект.ДокументВизита = ДокументСсылка;
	Иначе 
		ДокументОбъект = Документ.ПолучитьОбъект();
	КонецЕсли;
	
	ДокументОбъект.РасшифровкаПлатежа.Очистить();
	
	Если ДокументСсылка.СуммаПолученная > 0 Тогда	
        ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийПоступлениеВКассу.ОтПокупателя;
		
		СостояниеДокумента = "";
		КартинкаСостоянияДокумента = 0;
		РазрешеноПроведение = Истина;
		
		УправлениеНебольшойФирмойСервер.ЗаполнитьШапкуДокумента(
			ДокументОбъект, 
			ДокументОбъект.ВидОперации,
			Документы.ЗаказПокупателя.ПустаяСсылка(), // Пустая ссылка на документ для парамента копирования
			Неопределено,  // Основание для создания
			СостояниеДокумента,
			Новый Структура() // Параметры заполнения
		);
		
		// Заполним реквизиты по документу "Визит"
		ДокументОбъект.Дата			= ДокументСсылка.Дата;
		ДокументОбъект.Автор		= ДокументСсылка.Автор;
		ДокументОбъект.ТорговаяТочка= ДокументСсылка.ТорговаяТочка;
