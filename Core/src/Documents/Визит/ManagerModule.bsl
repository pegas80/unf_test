		//ДокументОбъект.Договор      = ДокументСсылка.Договор;
		
		//ДокументОбъект.Договор		= ДокументОбъект.ТорговаяТочка.Договор; //договор указываеться в табличной части расшифровки платежа
		ДокументОбъект.Организация	= ДокументСсылка.Договор.Организация;
		ДокументОбъект.Касса		= ДокументСсылка.Касса;
		
		ДокументОбъект.СуммаДокумента	= ДокументСсылка.СуммаПолученная;
		ДокументОбъект.Статья			= Справочники.СтатьиДвиженияДенежныхСредств.ОплатаОтПокупателей;
		// Заполним валюту и курс по валюте из договора
		ДокументОбъект.ВалютаДенежныхСредств= ДокументОбъект.Касса.ВалютаПоУмолчанию;
		ВалютаРасчетовКурсКратность			= РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументОбъект.Дата, Новый Структура("Валюта", ДокументОбъект.Касса.ВалютаПоУмолчанию));
		ДокументОбъект.Курс					= ?(ВалютаРасчетовКурсКратность.Курс = 0, 1, ВалютаРасчетовКурсКратность.Курс);
		ДокументОбъект.Кратность			= ?(ВалютаРасчетовКурсКратность.Кратность = 0, 1, ВалютаРасчетовКурсКратность.Кратность);

		//СтрокаРасшифровки = ДокументОбъект.РасшифровкаПлатежа.Добавить();
		//
		//СтрокаРасшифровки.Договор = ДокументСсылка.Договор;
		//
		//ВалютаРасчетовКурсКратность	= РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументОбъект.Дата, Новый Структура("Валюта", СтрокаРасшифровки.Договор.ВалютаРасчетов));
		//СтрокаРасшифровки.Курс		= ?(ВалютаРасчетовКурсКратность.Курс = 0, 1, ВалютаРасчетовКурсКратность.Курс);
		//СтрокаРасшифровки.Кратность	= ?(ВалютаРасчетовКурсКратность.Кратность = 0, 1, ВалютаРасчетовКурсКратность.Кратность);
		//СтрокаРасшифровки.СуммаРасчетов	= ДокументСсылка.СуммаПолученная;
		//СтрокаРасшифровки.СуммаПлатежа	= СтрокаРасшифровки.СуммаРасчетов * СтрокаРасшифровки.Курс / СтрокаРасшифровки.Кратность;
		
		ЗаполнитьРасшифровкуПлатежа(ДокументОбъект,ДокументСсылка.Договор);
		
		// Если документ был помечен на удаление снимим пометку
		// Kuzmich, 20.05.2019, ошибка проведения документа Визит
		Если ЗначениеЗаполнено(ДокументОбъект.Ссылка) Тогда
			Если ДокументОбъект.ПометкаУдаления Тогда
