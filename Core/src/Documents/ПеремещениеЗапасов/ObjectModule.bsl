Процедура СоздатьИлиИзменитьДокументПеремещения(Отказ)
	
	Если Отказ ИЛИ ЗначениеЗаполнено(ДокументПеремещенияВТранзит) Тогда
		Возврат;
	КонецЕсли;

	ПеремещенияИзТранзита = Документы.ПеремещениеЗапасов.НайтиПоРеквизиту("ДокументПеремещенияВТранзит", Ссылка);
	Если НЕ ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.Перемещение Тогда
		Если ЗначениеЗаполнено(ПеремещенияИзТранзита) Тогда
			ПеремещенияИзТранзита = ПеремещенияИзТранзита.ПолучитьОбъект();
			Попытка
				ПеремещенияИзТранзита.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли;
	Иначе
		Если ЧерезТранзитныйСклад Тогда
			Если ЗначениеЗаполнено(ПеремещенияИзТранзита) Тогда
				ПеремещенияИзТранзита = ПеремещенияИзТранзита.ПолучитьОбъект();
				Если Не ЗначениеЗаполнено(ДатаПеремещенияИзТранзита) Тогда
					Попытка
						ПеремещенияИзТранзита.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					Исключение
						Сообщить(ОписаниеОшибки());
					КонецПопытки;
					Возврат;
				КонецЕсли;
			Иначе
				Если Не ЗначениеЗаполнено(ДатаПеремещенияИзТранзита) Тогда
					Возврат;
				КонецЕсли;
				ПеремещенияИзТранзита = Документы.ПеремещениеЗапасов.СоздатьДокумент();
			КонецЕсли;
			

			ПеремещенияИзТранзита.Заполнить(Ссылка);
			РеквизитыШапки = Метаданные.Документы.ПеремещениеЗапасов.Реквизиты;
			Для Каждого РеквизитаДок Из РеквизитыШапки Цикл
				ИмяРеквизита = РеквизитаДок.Имя;
				Если НЕ ИмяРеквизита = "IDTТН" И
					 НЕ ИмяРеквизита = "НомерТТН" И
					 НЕ ИмяРеквизита = "Автор" ИЛИ
					 НЕ ИмяРеквизита = "ДокументОснование" Тогда
					ПеремещенияИзТранзита[ИмяРеквизита] = Ссылка[ИмяРеквизита];
				КонецЕсли;
			КонецЦикла;
			ПеремещенияИзТранзита.ЧерезТранзитныйСклад          = Ложь;
			ПеремещенияИзТранзита.Дата							= ДатаПеремещенияИзТранзита;
			ПеремещенияИзТранзита.ДатаПеремещенияИзТранзита     = Дата(1,1,1);
			ПеремещенияИзТранзита.ДокументПеремещенияВТранзит 	= Ссылка;
			ПеремещенияИзТранзита.СтруктурнаяЕдиница 			= ПеремещенияИзТранзита.СтруктурнаяЕдиницаПолучатель;
			ПеремещенияИзТранзита.СтруктурнаяЕдиницаПолучатель 	= ПеремещенияИзТранзита.СтруктурнаяЕдиницаКонечныйПолучатель;
			
			ПеремещенияИзТранзита.Запасы.Очистить();
			Для Каждого СтрокаТЧ Из Запасы Цикл
				Если СтрокаТЧ.Количество - СтрокаТЧ.КоличествоВДороге > 0 Тогда
					СтрЗапасы = ПеремещенияИзТранзита.Запасы.Добавить();
					ЗаполнитьЗначенияСвойств(СтрЗапасы, СтрокаТЧ);
					СтрЗапасы.Количество 		= СтрокаТЧ.Количество - СтрокаТЧ.КоличествоВДороге;
					СтрЗапасы.Резерв			= ?(СтрокаТЧ.Резерв = 0, 0, Мин(СтрокаТЧ.Резерв, СтрЗапасы.Количество));
					СтрЗапасы.КоличествоВДороге = 0;
				КонецЕсли;
			КонецЦикла;
			Попытка
				ПеремещенияИзТранзита.Записать(мРежимЗаписи);
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		Иначе
			Если ЗначениеЗаполнено(ПеремещенияИзТранзита) Тогда
				ПеремещенияИзТранзита = ПеремещенияИзТранзита.ПолучитьОбъект();
				Попытка
					ПеремещенияИзТранзита.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				Исключение
					Сообщить(ОписаниеОшибки());
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
ИспользоватьТолькоРегламентированногоПланаСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(?(ЗначениеЗаполнено(Дата),Дата,ТекущаяДата())); //+++ Дмгг
#КонецЕсли