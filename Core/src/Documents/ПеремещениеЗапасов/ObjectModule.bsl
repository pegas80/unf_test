Процедура ЗаполнитьПоВнутреннийЗаказ(ДанныеЗаполнения) Экспорт
	
	Если Не ДанныеЗаполнения.Проведен Тогда
		ТекстОшибки = НСтр("ka='დოკუმენტი %Документ% არ არის გატარებული. გაუტარებელი დოკუმენტის საფუძველზე შეყვანა აკრძალულია.';ru='Документ %Документ% не проведен. Ввод на основании непроведенного документа запрещен.';en='Document%% Document not conducted. Putting on the basis of failure to the document denied.'");
  		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Документ%", ДанныеЗаполнения.Ссылка);
  		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах");
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	&Ссылка КАК ДокументОснование,
		|	ВнутреннийЗаказ.Организация КАК Организация,
		|	ВнутреннийЗаказ.СтруктурнаяЕдиницаОтправитель КАК СтруктурнаяЕдиница,
		|	ВнутреннийЗаказ.СтруктурнаяЕдиница КАК СтруктурнаяЕдиницаПолучатель,
		|	ВнутреннийЗаказ.Запасы.(
		|		Ссылка,
		|		НомерСтроки,
		|		Номенклатура,
		|		Характеристика,
		|		ЕдиницаИзмерения," +
			 ?(ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах,"		УтвержденноеКоличество КАК Количество,","		Количество КАК Количество,")		 
		 +	 
		"		УтвержденноеКоличество КАК КоличествоВДороге
		|	)
		|ИЗ
		|	Документ.ВнутреннийЗаказ КАК ВнутреннийЗаказ
		|ГДЕ
		|	ВнутреннийЗаказ.Ссылка = &Ссылка";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	ЧерезТранзитныйСклад = ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах;
	СтруктурнаяЕдиницаКонечныйПолучатель = ДанныеЗаполнения.СтруктурнаяЕдиница;
	
	Если ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах Тогда	
		Запасы.Загрузить(ПолучитьОстаткиВнутреногоЗаказа(ДанныеЗаполнения));
	Иначе	
		Запасы.Загрузить(Выборка.Запасы.Выгрузить());
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьОстаткиВнутреногоЗаказа(ВнутреныйЗаказСслка)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказыНаПеремещениеОстатки.Номенклатура,
	               |	ЗаказыНаПеремещениеОстатки.Характеристика,
	               |	ЗаказыНаПеремещениеОстатки.Партия,
	               |	ЗаказыНаПеремещениеОстатки.КоличествоОстаток КАК Количество,
				   |	ЗаказыНаПеремещениеОстатки.КоличествоОстаток КАК КоличествоВДороге,
	               |	ЗаказыНаПеремещениеОстатки.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	               |ИЗ
	               |	РегистрНакопления.ЗаказыНаПеремещение.Остатки(, Заказ = &Заказ) КАК ЗаказыНаПеремещениеОстатки";
	
	Запрос.УстановитьПараметр("Заказ",ВнутреныйЗаказСслка);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

