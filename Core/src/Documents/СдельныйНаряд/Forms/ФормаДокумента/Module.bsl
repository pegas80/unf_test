&НаСервере
Процедура ПересчитатьСуммуНДФЛиПФ()
	
	СтавкаНДФЛ	= 0;
	СтавкаПФ	= 0;
	
	Если ЗначениеЗаполнено(Объект.ВидУдержанияНДФЛ) Тогда
		СтавкаНДФЛ = Объект.ВидУдержанияНДФЛ.СтавкаНДФЛ;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ВидУдержанияПФ) Тогда
		СтавкаПФ = Объект.ВидУдержанияПФ.СтавкаПФ;
	КонецЕсли;
		
	Объект.СуммаПФ		=  Окр(Объект.Операции.Итог("Стоимость") * СтавкаПФ/100, 2);	
	Объект.СуммаНДФЛ	=  Окр((Объект.Операции.Итог("Стоимость")-Объект.СуммаПФ) * СтавкаНДФЛ/100, 2);
			
КонецПроцедуры // ПересчитатьСуммуНДФЛЗарплаты()

