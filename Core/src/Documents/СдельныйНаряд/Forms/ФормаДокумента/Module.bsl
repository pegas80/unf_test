&НаСервере
Процедура ПересчитатьСуммыСтрокиСоставБригады(Идентификатор, ИмяПоля)
	Если Идентификатор = Неопределено Тогда
		Для Каждого СтрокаТЧ ИЗ Объект.СоставБригады Цикл
			Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			ТекДанные = Объект.СоставБригады.НайтиПоИдентификатору(Идентификатор);
			//РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
		КонецЦикла;
	Иначе
		ТекДанные = Объект.СоставБригады.НайтиПоИдентификатору(Идентификатор);
		//РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
		ПересчитатьСуммыСтрокиСоставБригады_СоставБригады(ИмяПоля, ТекДанные);
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура ПересчитатьСуммыСтрокиСоставБригады_СоставБригады(ИмяПоля, ТекДанные)
	
Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекДанные.Свойство("ВидУдержанияНДФЛ") Тогда 	
		СтавкаНДФЛ = ТекДанные.ВидУдержанияНДФЛ.СтавкаНДФЛ ;
	КонецЕсли;
	Если ТекДанные.Свойство("ВидУдержанияПФ") Тогда 
		СтавкаПФ   = ТекДанные.ВидУдержанияПФ.СтавкаПФ ;
	КонецЕсли;
	
	ПересчитатьЦену = Истина;	
	
	Сумма = 0 ;
	Если Объект.Операции.Количество()> 0 Тогда 
		Для Каждого Стр  из Объект.Операции Цикл 		
			Сумма =  Сумма + Стр.Стоимость ;
		КонецЦикла;
	КонецЕсли;
	
	//получитьКоефициентсотрудников(Сумма);Коэффициент
	
	СуммаКТУ = 0;
	Если Объект.СоставБригады.Количество()> 0 Тогда 
		Для Каждого Стр  из Объект.СоставБригады Цикл 		
			СуммаКТУ =  СуммаКТУ + Стр.КТУ ;
		КонецЦикла;
		
		Для Каждого Стр  из Объект.СоставБригады Цикл 		
			Стр.Коэффициент =  Стр.КТУ / СуммаКТУ ;
		КонецЦикла;
		
	КонецЕсли;
	
	
	Если ИмяПоля = "СуммаБезНалогов" ИЛИ ИмяПоля = "ВидУдержанияНДФЛ" ИЛИ ИмяПоля = "ВидУдержанияПФ" Тогда		
		//Если ИмяПоля = "ВидУдержанияНДФЛ"  Тогда 		
		СуммаНДФЛ = Окр(Сумма/((100-СтавкаНДФЛ)/100)*(СтавкаНДФЛ/100), 2);
		СуммаПФ	  = Окр(((Сумма+СуммаНДФЛ)/((100-СтавкаПФ)/100))*(СтавкаПФ/100), 2);
		Всего =  СуммаНДФЛ + СуммаПФ ;
	КонецЕсли;

	ТекДанные.СуммаНДФЛ = СуммаНДФЛ ;
	ТекДанные.СуммаПФ   = СуммаПФ ;
	
	
	
	
	
КонецПроцедуры

&НаСервере
Процедура  ПолучитьКоефициентысотрудниковИЗаполнитьНалоги(ДокументСсылкаСдельныйНаряд)
	
	СуммаДокумента = 0 ;
	СуммаДокумента1 =  Объект.Операции.Итог("Стоимость");
	Если  Объект.Операции.Количество()> 0 Тогда 
		Для Каждого Стр  из Объект.Операции Цикл 		
			СуммаДокумента =  СуммаДокумента + Стр.Стоимость ;
		КонецЦикла;	
	Иначе 
		Возврат ;	
	КонецЕсли;
	
	СуммаКТУ = 0;
	
	Если Объект.СоставБригады.Количество()> 0 Тогда
		
		Для Каждого Стр  из Объект.СоставБригады Цикл 		
			СуммаКТУ =  СуммаКТУ + Стр.КТУ ;	
		КонецЦикла;
		
		Для Каждого Стр  из Объект.СоставБригады Цикл 		
			Стр.Коэффициент =  Стр.КТУ / СуммаКТУ ;
			Стр.Сумма       =  Окр(СуммаДокумента * Стр.Коэффициент, 2);			
			СтавкаНДФЛ  	=  Стр.ВидУдержанияНДФЛ.СтавкаНДФЛ ;
			СтавкаПФ    	=  Стр.ВидУдержанияПФ.СтавкаПФ ;					
			Стр.СуммаПФ		=  Окр(Стр.Сумма * СтавкаПФ/100, 2);
			Стр.СуммаНДФЛ	=  Окр((Стр.Сумма-Стр.СуммаПФ) * СтавкаНДФЛ/100, 2);
			Стр.СуммаБезНалогов = Стр.Сумма - Стр.СуммаПФ - Стр.СуммаНДФЛ ;
		КонецЦикла;
		
	КонецЕсли;
		
КонецПроцедуры

