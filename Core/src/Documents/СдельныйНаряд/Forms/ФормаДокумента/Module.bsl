&НаСервере
Процедура ЗаполнитьНачисленияУдержанияНаСервере(МассивСотрудников)
	
	Если ТипЗнч(Объект.Исполнитель) = Тип("СправочникСсылка.Бригады") Тогда
		МассивСотрудников = Объект.СоставБригады.Выгрузить().ВыгрузитьКолонку("Сотрудник");
		ТаблицаВидовУдержания = ПолучитьВидыУдержания(МассивСотрудников);
		Для Каждого СтрокаТЧ ИЗ Объект.СоставБригады Цикл 
			НайденныеСтавкиТекСотрудника = ТаблицаВидовУдержания.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			Если НайденныеСтавкиТекСотрудника.Количество() > 0 Тогда
				ЗаполнитьЗначенияСвойств(СтрокаТЧ, НайденныеСтавкиТекСотрудника[0]);		
			Иначе
				СтрокаТЧ.ВидУдержанияНДФЛ 	= Неопределено;
				СтрокаТЧ.ВидУдержанияПФ 	= Неопределено;
				СтрокаТЧ.СуммаНДФЛ 			= 0;
				СтрокаТЧ.СуммаПФ 			= 0;
				СтрокаТЧ.СуммаЛгот 			= 0;
			КонецЕсли;
		КонецЦикла;
		
	Иначе 	
		Сотрудник = МассивСотрудников ;
		ТаблицаВидовУдержания   = ПолучитьВидыУдержания(Сотрудник);
		Если ТаблицаВидовУдержания.Количество() > 0 Тогда 
			Для Каждого Стр Из ТаблицаВидовУдержания Цикл 
				Объект.ВидУдержанияНДФЛ = Стр.ВидУдержанияНДФЛ;
				Объект.ВидУдержанияПФ   = Стр.ВидУдержанияПФ;	
			КонецЦикла;
		Иначе 
			Объект.ВидУдержанияНДФЛ  = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
			Объект.ВидУдержанияПФ    = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
		КонецЕсли;
		ПересчитатьСуммуНДФЛиПФ();	
	КонецЕсли;
	
		
КонецПроцедуры

Функция ПолучитьВидыУдержания(МассивСотрудников)
	
	Запрос = Новый Запрос;
	Запрос.Параметры.Вставить("ДатаЗакрытия", 		Объект.ДатаЗакрытия);
	Запрос.Параметры.Вставить("МассивСотрудников", 	МассивСотрудников);	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиСрезПоследних.Сотрудник,
		|	СотрудникиСрезПоследних.ВидУдержанияПФ,
		|	СотрудникиСрезПоследних.ВидУдержанияНДФЛ,
		|	СотрудникиСрезПоследних.ВидУдержанияНДФЛ.СтавкаНДФЛ КАК СтавкаНДФЛ,
		|	СотрудникиСрезПоследних.ВидУдержанияПФ.СтавкаПФ КАК СтавкаПФ
		|ИЗ
		|	РегистрСведений.Сотрудники.СрезПоследних(&ДатаЗакрытия, Сотрудник В (&МассивСотрудников)) КАК СотрудникиСрезПоследних";
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

