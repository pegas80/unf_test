&НаСервере
Процедура ТранспортноеСредствоПриИзмененииНаСервере()
	
	Если ТипЗнч(Объект.ТранспортноеСредство) = Тип("СправочникСсылка.ТранспортныеСредства") Тогда
		Объект.ГосНомерАвтомобиля = Объект.ТранспортноеСредство.Код;
		ОсновнойВодитель = Объект.ТранспортноеСредство.ОсновнойВодитель;
		Если ЗначениеЗаполнено(ОсновнойВодитель) Тогда
			Если НЕ ЗначениеЗаполнено(Объект.Водитель) Тогда
				Объект.Водитель 			= ОсновнойВодитель;
				Объект.НомерУдостоверения 	= ОсновнойВодитель.ИНН;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

