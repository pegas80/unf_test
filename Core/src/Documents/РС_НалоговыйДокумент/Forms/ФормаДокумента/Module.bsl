&НаСервере
Процедура УстановитьПараметрыВыбора_ТипТН(ПриОткрытии = Ложь)
	
	Если СписокДокументыОснования.Количество() = 0 Тогда
		Объект.ДокументыОснования.Очистить();
		Возврат;
	КонецЕсли;
	ТипЗнченияДокумента = ТипЗнч(СписокДокументыОснования[0].Значение);
	
	Массив_ТипТН = Новый Массив;
	Массив_Назначения = Новый Массив;
	
	Если Объект.Получен Тогда
		
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.ВнутреннееПеремещение"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Дистрибуция"));		
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.ВозвратОтПокупателя"));		
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.РеализацияБезТранспортировки"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.РеализацияСТранспортировкой"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Услуга"));
		Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Аванс"));
		Массив_Назначения.Добавить(ПредопределенноеЗначение("Перечисление.РС_НазначенияНД.Аванс"));		
		Массив_Назначения.Добавить(ПредопределенноеЗначение("Перечисление.РС_НазначенияНД.ДоставкаУслуга"));
		
	Иначе
		Если ТипЗнченияДокумента = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.ВнутреннееПеремещение"));
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Дистрибуция"));
		ИначеЕсли ТипЗнченияДокумента = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.ВозвратОтПокупателя"));
		Иначе
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.РеализацияБезТранспортировки"));
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.РеализацияСТранспортировкой"));
			Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Услуга"));
			//Массив_ТипТН.Добавить(ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Аванс"));
			Массив_Назначения.Добавить(ПредопределенноеЗначение("Перечисление.РС_НазначенияНД.Аванс"));
		КонецЕсли;
		
		Массив_Назначения.Добавить(ПредопределенноеЗначение("Перечисление.РС_НазначенияНД.ДоставкаУслуга"));
		
	КонецЕсли;
	
	Элементы.ТипНД.СписокВыбора.ЗагрузитьЗначения(Массив_ТипТН);
	Элементы.НазначениеНД.СписокВыбора.ЗагрузитьЗначения(Массив_Назначения);
	
	Если НЕ ПриОткрытии И Массив_ТипТН.Найти(Объект.ТипНД) = Неопределено Тогда
		Если ТипЗнченияДокумента = Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
			Объект.ТипНД = ПредопределенноеЗначение("Перечисление.РС_ТипыНД.ВнутреннееПеремещение");
		ИначеЕсли ТипЗнченияДокумента = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			Объект.ТипНД = ПредопределенноеЗначение("Перечисление.РС_ТипыНД.ВозвратОтПокупателя");
		Иначе
			Объект.ТипНД = ПредопределенноеЗначение("Перечисление.РС_ТипыНД.РеализацияСТранспортировкой");
		КонецЕсли;
		УстановитьВидимостьИДоступность();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СписокДокументыОснованияПриИзменении(Элемент)
	УстановитьПараметрыВыбора_ТипТН();
	Модифицированность = Истина;
КонецПроцедуры

