&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Объект.ДокументыОснования.Очистить();
	Для Каждого ЗнДокумента ИЗ СписокДокументыОснования Цикл
		НоваяСтрока = Объект.ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ЗнДокумента.Значение;
	КонецЦикла;
	РС_ОбщегоНазначенияКлиент.ПроверкаМодифицированостиВопрос(Объект.Ссылка, Модифицированность, Отказ);//Паганини
КонецПроцедуры

&НаСервере
Процедура НазначениеНДПриИзмененииНаСервере()
	
	Если Объект.НазначениеНД = Перечисления.РС_НазначенияНД.ДоставкаУслуга Тогда
		Если Не ЗначениеЗаполнено(Объект.ТипНД) ИЛИ Объект.ТипНД = Перечисления.РС_ТипыНД.Аванс Тогда			
			Объект.ТипНД = Перечисления.РС_ТипыНД.ПустаяСсылка();		
		КонецЕсли;					
	Иначе 		
		Объект.ТипНД = Перечисления.РС_ТипыНД.Аванс;		
	КонецЕсли;	
	УстановитьВидимостьИДоступность();
	
КонецПроцедуры

&НаКлиенте
Процедура НазначениеНДПриИзменении(Элемент)
	НазначениеНДПриИзмененииНаСервере();
КонецПроцедуры
