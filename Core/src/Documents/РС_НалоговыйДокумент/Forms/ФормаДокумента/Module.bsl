	// Конец СтандартныеПодсистемы.Свойства
	
	
КонецПроцедуры


&НаСервере
Процедура УстановитьВидимостьИДоступность()
	
	Элементы.ГруппаОбщееДеталная.Видимость	= ЗначениеЗаполнено(Объект.НазначениеНД);	
	//ДД
	Элементы.ТоварыНаименованиеДляРС.Видимость = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ФункционалНаименованияРС");
	
	Если Объект.ТипНД = Перечисления.РС_ТипыНД.Аванс ИЛИ Объект.ТипНД = Перечисления.РС_ТипыНД.Услуга Тогда	
		Элементы.АдресПогрузки.Видимость = Ложь;	
	Иначе		
		Элементы.АдресПогрузки.Видимость = Истина;		
	КонецЕсли;
	
	Если Объект.ТипНД = Перечисления.РС_ТипыНД.Аванс ИЛИ Объект.ТипНД = Перечисления.РС_ТипыНД.Услуга ИЛИ Объект.ТипНД = Перечисления.РС_ТипыНД.РеализацияБезТранспортировки  Тогда	
		пБезТранспортировки = Истина;	
	Иначе
		пБезТранспортировки = Ложь;		
	КонецЕсли;
	
	Если Объект.ТипНД = Перечисления.РС_ТипыНД.ВнутреннееПеремещение ИЛИ Объект.ТипНД = Перечисления.РС_ТипыНД.Дистрибуция  Тогда	
		Элементы.ИнформацияОПолучателе.Видимость = Ложь;	
	Иначе		
		Элементы.ИнформацияОПолучателе.Видимость = Истина;		
	КонецЕсли;
	
	Элементы.ТипНД.Видимость = НЕ Объект.ТипНД = Перечисления.РС_ТипыНД.Аванс;
	
	Прочее = Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Прочее;
	
	Элементы.ГруппаПеревозчика.Видимость = НЕ Прочее И Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Перегрузчик_Автомобильная;
	Элементы.ГруппаТранспортноеСредство.Видимость = НЕ Прочее;		
	Элементы.ГруппаТранспортировка.Видимость = НЕ пБезТранспортировки;
	Элементы.АдресДоставки.Видимость		 = НЕ пБезТранспортировки;
	Элементы.ДругойТранспорт.Видимость 		 = НЕ пБезТранспортировки И Прочее;
	
	ВидимостьТранспорта = ЗначениеЗаполнено(Объект.ВидТранспортировки);
	
	Элементы.ГруппаНачалоТранспортировки.Видимость = ВидимостьТранспорта;
	Элементы.ГруппаКонецТранспортировки.Видимость  = ВидимостьТранспорта;
	Если НЕ ВидимостьТранспорта Тогда		
		Элементы.ГруппаПеревозчика.Видимость           = Ложь;
		Элементы.ГруппаТранспортноеСредство.Видимость  = Ложь;		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.Печать
	УправлениеПечатью.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюПечать);
	// Конец СтандартныеПодсистемы.Печать
	УправлениеНебольшойФирмойСервер.УстановитьОтображаниеПодменюПечати(Элементы.ПодменюПечать);
	
	УстановитьВидимостьИДоступность();
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И Параметры.Свойство("ДокументыОснования") Тогда
		
		Для Каждого ДокументОснование Из Параметры.ДокументыОснования Цикл
			НоваяСтрока = Объект.ДокументыОснования.Добавить();
			НоваяСтрока.ДокументОснование = ДокументОснование;
		КонецЦикла;
		Если Параметры.Свойство("НакладнаяДистрибюций") Тогда 
			Объект.НакладнаяДистрибюций = Параметры.НакладнаяДистрибюций;
			СсылкаЭН = Параметры.СсылкаЭН;
			Объект.ТранспортноеСредство	= СсылкаЭН.ТранспортноеСредство;
			Объект.ГосНомерАвтомобиля	= СсылкаЭН.ГосНомерАвтомобиля;
			Объект.Водитель				= СсылкаЭН.Водитель;
			Объект.НомерУдостоверения	= СсылкаЭН.НомерУдостоверения;
			Объект.ДругойТранспорт      = СсылкаЭН.ДругойТранспорт;
		КонецЕсли;
		ЗапольнитьРеквизитиНакладной(Параметры.ДокументыОснования);
	КонецЕсли;
	ЗаполнитьИНН_ПеревозчикаГрузоотправителяГрузополучателя(ИННГрузополучателя, 	Объект.ГрузоПолучатель); //ГрузоПолучатель
	ЗаполнитьИНН_ПеревозчикаГрузоотправителяГрузополучателя(ИННГрузоотправителя, 	Объект.ГрузоОтправитель);//ГрузоОтправитель
	ЗаполнитьИНН_ПеревозчикаГрузоотправителяГрузополучателя(ИННПеревозчика, 		Объект.Перевозчик);      //Перевозчик
	СписокДокументыОснования.ЗагрузитьЗначения(Объект.ДокументыОснования.Выгрузить().ВыгрузитьКолонку("ДокументОснование"));
	УстановитьПараметрыВыбора_ТипТН(Истина);
	НазначениеНДПриИзмененииНаСервере();
	
	Массив_Транспорт = Новый Массив;
	Массив_Транспорт.Добавить(ПредопределенноеЗначение("Перечисление.РС_ВидыТранспортировки.Автомобильная"));
	Массив_Транспорт.Добавить(ПредопределенноеЗначение("Перечисление.РС_ВидыТранспортировки.Перегрузчик_Автомобильная"));
	Массив_Транспорт.Добавить(ПредопределенноеЗначение("Перечисление.РС_ВидыТранспортировки.Прочее"));
	
	Элементы.ВидТранспортировки.СписокВыбора.ЗагрузитьЗначения(Массив_Транспорт);
	
	
КонецПроцедуры

&НаКлиенте
Процедура ТипТНПриИзменении(Элемент)
	УстановитьВидимостьИДоступность();
	Если Объект.ТипНД = ПредопределенноеЗначение("Перечисление.РС_ТипыНД.Дистрибуция") Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ВидЦены) Тогда
			Объект.ВидЦены = УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("ВидыЦен", "Оптовая");
		КонецЕсли;
		ЗаполнитьЦеныПоДистрибюции();
	ИначеЕсли Объект.ТипНД = ПредопределенноеЗначение("Перечисление.РС_ТипыНД.РеализацияБезТранспортировки") Тогда
		Объект.АдресДоставки		= "";
		Объект.ВидТранспортировки	= Неопределено;
		Объект.ДругойТранспорт		= "";
		Объект.Перевозчик			= Неопределено;
		ИННПеревозчика				= "";
		Объект.НомерУдостоверения	= "";
		Объект.Водитель				= "";
		Объект.ТранспортноеСредство = "";
		Объект.ГосНомерАвтомобиля	= "";
		Объект.Прицеп               = "";
	КонецЕсли;
КонецПроцедуры
 
 
