  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументКонвертация.Ссылка,
	ДокументКонвертация.ПометкаУдаления,
	ДокументКонвертация.Номер,
	ДокументКонвертация.Дата,
	ДокументКонвертация.Проведен,
	ДокументКонвертация.Организация,
	ДокументКонвертация.ВидОперации,
	ДокументКонвертация.Отправитель,
	ДокументКонвертация.Получатель,
	ДокументКонвертация.Комментарий,
	ДокументКонвертация.ВалютаОтправитель,
	ДокументКонвертация.ВалютаПолучатель,
	ДокументКонвертация.КурсОтправитель,
	ДокументКонвертация.КурсПолучатель,
	ДокументКонвертация.КратностьОтправитель,
	ДокументКонвертация.КратностьПолучатель,
	ДокументКонвертация.СуммаКонвертации,
	ДокументКонвертация.СуммаПолучено,
	ДокументКонвертация.Автор,
	ДокументКонвертация.Статья,
	ДокументКонвертация.Подотчетник,
	ДокументКонвертация.КроссКурс,
	ДокументКонвертация.КоммерческийКурс,
	ДокументКонвертация.МоментВремени,
	ДокументКонвертация.ЗапретРедактированияДокументов,
	ЕСТЬNULL(СтатусыДокументовBOGСрезПоследних.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.ПрисутствуетТолькоВТекущейБазе)) КАК СтатусДокументаВИнтернетБанке,
	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, &quot;&quot;) КАК УИДДокументаВБанке,
	ДокументКонвертация.TransactionID,
	ВЫБОР
		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.Выгружен, ЛОЖЬ) = ЛОЖЬ
				И ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, &quot;&quot;) &lt;> &quot;&quot;
			ТОГДА ИСТИНА
		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.Выгружен, ЛОЖЬ) = ЛОЖЬ
			ТОГДА ЛОЖЬ
		ИНАЧЕ УИДДокументовВИнтернетБанке.Выгружен
	КОНЕЦ КАК Выгружен,
	ИспользоватьЗагрузкуИзБанка.Значение КАК ИспользоватьИнтернетБанк,
	ДокументКонвертация.НазначениеПлатежа
ИЗ
	Документ.Конвертация КАК ДокументКонвертация
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовBOGСрезПоследних
		ПО ДокументКонвертация.Ссылка = СтатусыДокументовBOGСрезПоследних.ДокументСсылка
			И (ВЫБОР
				КОГДА ДокументКонвертация.ВидОперации = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.ВидыОперацийКонвертация.СоСчета)
					ТОГДА ДокументКонвертация.Отправитель.Банк = СтатусыДокументовBOGСрезПоследних.Банк
				ИНАЧЕ ЛОЖЬ
			КОНЕЦ)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		ПО ДокументКонвертация.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
			И (ВЫБОР
				КОГДА ДокументКонвертация.ВидОперации = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.ВидыОперацийКонвертация.СоСчета)
					ТОГДА ДокументКонвертация.Отправитель.Банк = УИДДокументовВИнтернетБанке.Банк
				ИНАЧЕ ЛОЖЬ
			КОНЕЦ),
	Константа.ИспользоватьЗагрузкуИзБанка КАК ИспользоватьЗагрузкуИзБанка</queryText>
      <mainTable>Document.Конвертация</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
