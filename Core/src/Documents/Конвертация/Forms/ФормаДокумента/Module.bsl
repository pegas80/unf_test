КонецПроцедуры

&НаКлиенте
Процедура ВалютаОтправительПриИзменении(Элемент)
	ОбновитьКурсКратность("Отправитель");
КонецПроцедуры

&НаКлиенте
Процедура ВалютаПолучательПриИзменении(Элемент)
	ОбновитьКурсКратность("Получатель");
КонецПроцедуры


&НаСервере
Процедура ОбновитьКурсКратность(ОтправительПолучатель)
	
	Если ОтправительПолучатель = "Отправитель" Тогда 
		СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаОтправитель));
		
		Объект.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
		Объект.КратностьОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
	ИначеЕсли ОтправительПолучатель = "Получатель" Тогда 
		СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаПолучатель));
		
		Объект.КурсПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
		Объект.КратностьПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьИнформациюКоммерческогоКроссКурсов()

	Если НЕ Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.СоСчета Тогда 
		Возврат;
	КонецЕсли;
	
	Если НЕ ИспользоватьИнтеграциюСБанком Тогда 
		Возврат;
	КонецЕсли;
	
	БанкОтправительРаботаетСИнтеграцией = Объект.Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком;
	
	Если НЕ БанкОтправительРаботаетСИнтеграцией Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Объект.Получатель) <> Тип("СправочникСсылка.БанковскиеСчета") 
		ИЛИ НЕ ЗначениеЗаполнено(Объект.Получатель)
		ИЛИ ТипЗнч(Объект.Отправитель) <> Тип("СправочникСсылка.БанковскиеСчета") 
		ИЛИ НЕ ЗначениеЗаполнено(Объект.Отправитель) Тогда 
		
		Объект.КоммерческийКурс = 1;
		объект.КроссКурс = 1;
		Возврат;
		
	КонецЕсли;
	
	Если Объект.Получатель.Банк <> Объект.Отправитель.Банк Тогда 
		Объект.КоммерческийКурс = 1;
		объект.КроссКурс = 1;
		Возврат;
	КонецЕсли;
	
	ДатаСреда = ?(НЕ ЗначениеЗаполнено(Объект.Дата), ТекущаяДата(), Объект.Дата);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КурсыВалютБанковСрезПоследних.Период,
		|	ВЫБОР
		|		КОГДА КурсыВалютБанковСрезПоследних.ВидКурса = ЗНАЧЕНИЕ(Перечисление.ВидыКурсовВалютБанка.Коммерческий)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоКоммерческий,
		|	КурсыВалютБанковСрезПоследних.Банк,
		|	КурсыВалютБанковСрезПоследних.Валюта,
		|	КурсыВалютБанковСрезПоследних.ВалютаПокупки,
		|	КурсыВалютБанковСрезПоследних.ВалютаПродажи,
		|	КурсыВалютБанковСрезПоследних.КурсПокупки,
		|	КурсыВалютБанковСрезПоследних.КратностьПокупки,
		|	КурсыВалютБанковСрезПоследних.КурсПродажи,
		|	КурсыВалютБанковСрезПоследних.КратностьПродажи,
		|	КурсыВалютБанковСрезПоследних.КурсКросс,
		|	КурсыВалютБанковСрезПоследних.КратностьКросс
		|ИЗ
		|	РегистрСведений.КурсыВалютБанков.СрезПоследних(
		|			&НаДату,
		|			Банк = &Банк
		|				И (Валюта = &Валюта
		|					ИЛИ ВалютаПокупки = &ВалютаПокупки
		|						И ВалютаПродажи = &ВалютаПродажи)) КАК КурсыВалютБанковСрезПоследних";
	
	Запрос.УстановитьПараметр("Банк", Объект.Отправитель.Банк);
	Запрос.УстановитьПараметр("Валюта", ?(Объект.КурсОтправитель = 1, Объект.ВалютаПолучатель, Объект.ВалютаОтправитель));
	Запрос.УстановитьПараметр("ВалютаПокупки", Объект.ВалютаОтправитель);
	Запрос.УстановитьПараметр("ВалютаПродажи", Объект.ВалютаПолучатель);
	Запрос.УстановитьПараметр("НаДату", ДатаСреда);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.ЭтоКоммерческий Тогда 
			Если НацВалюта = Объект.ВалютаОтправитель Тогда 
				Объект.КоммерческийКурс = ВыборкаДетальныеЗаписи.КурсПокупки;
			ИначеЕсли НацВалюта = Объект.ВалютаПолучатель Тогда 
				Объект.КоммерческийКурс = ВыборкаДетальныеЗаписи.КурсПродажи;
			Иначе 
				Объект.КоммерческийКурс = 1;
			КонецЕсли;
		ИНаче
			объект.КроссКурс =ВыборкаДетальныеЗаписи.КурсКросс;
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатусДокументаВИнтернетБанке()
	
	Если ИспользоватьИнтеграциюСБанком И БанкОтправительРаботаетСИнтеграцией Тогда 
		
		СоответствиеДокумента = Обработки.ИнтеграцияСБанком.ПолучитьДанныеДокументовПоИнтернетБанку(Объект.Ссылка, ТекущаяДата());
		
		ДанныеДокумента = СоответствиеДокумента.Получить(Объект.Ссылка);
		
		Если ДанныеДокумента <> Неопределено Тогда 
			СтатусДокумментаВИнтернетБанке = ДанныеДокумента.Статус;
			НомерДокументаВИнтернетБанке = ДанныеДокумента.УИД;
			
			Если ДанныеДокумента.Выгружено Тогда 
				Выгружено = Истина;
				Элементы.ДекорацияВыгружено.Заголовок = НСтр("ka='Выгружен';ru='Выгружен';en='unloaded'");
				Элементы.ДекорацияВыгружено.ЦветТекста = Новый Цвет(0,255,0);
			Иначе
				Выгружено = Ложь;
				Элементы.ДекорацияВыгружено.Заголовок = НСтр("ka='Не выгружен';ru='Не выгружен';en='not unloaded'");
				Элементы.ДекорацияВыгружено.ЦветТекста = Новый Цвет(255,0,0);
			КонецЕсли;
			
			
		Иначе 
			
			СтатусДокумментаВИнтернетБанке = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ПрисутствуетТолькоВТекущейБазе");
			НомерДокументаВИнтернетБанке = "";
			Выгружено = Ложь;
			Элементы.ДекорацияВыгружено.Заголовок = НСтр("ka='Не выгружен';ru='Не выгружен';en='not unloaded'");
			Элементы.ДекорацияВыгружено.ЦветТекста = Новый Цвет(255,0,0);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	УстановитьОбновитьСтатутДокументаИнтернетБанкНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОбновитьСтатутДокументаИнтернетБанкНаСервере()
	
	Если НЕ ИспользоватьИнтеграциюСБанком 
		И БанкОтправительРаботаетСИнтеграцией Тогда 
		
		Возврат;
		
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура("ДокументСсылка", Объект.Ссылка);
	тзСрезСтатусов = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(ТекущаяДата(), СтруктураОтбора);
	Если тзСрезСтатусов.Количество() > 0 Тогда 
		//Обновим статус
		СтатусДокумментаВИнтернетБанке = тзСрезСтатусов[0].СтатусДокументаВИнтернетБанке;
		
	Иначе
		//Еще нет ни однойЗаписи. Создадим
		Если Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.СоСчета Тогда
			ДатаЗаписи = ТекущаяДата();
			НаборЗаписейСтатусыДокументовВИнтернетБанке = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
			НаборЗаписейСтатусыДокументовВИнтернетБанке.Отбор.ДокументСсылка.Установить(Объект.Ссылка);
			НаборЗаписейСтатусыДокументовВИнтернетБанке.Отбор.Период.Установить(ДатаЗаписи);
			НаборЗаписейСтатусыДокументовВИнтернетБанке.Отбор.Банк.Установить(Объект.Отправитель.Банк);
			
			Запись = НаборЗаписейСтатусыДокументовВИнтернетБанке.Добавить();
			Запись.ДокументСсылка = Объект.Ссылка;
			Запись.Период = ДатаЗаписи;
			Запись.Банк		= Объект.Отправитель.Банк;
			Запись.СтатусДокументаВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке.ПрисутствуетТолькоВТекущейБазе;
			
			НаборЗаписейСтатусыДокументовВИнтернетБанке.Записать();
		КонецЕсли;
		//Запись.УИДДокументаВБанке
		
	КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнформациюВПоИнтернетБанку(Команда)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		ОбновитьСтатусДокументаВИнтернетБанке();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИнтеграцияСБанком_ВыгрузкаЗавершина" Тогда
		
		Если Параметр.Свойство("ВыгруженныеСсылки") Тогда
			ОбновитьСтатусДокументаВИнтернетБанке();
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	УстановитьВалютуПоУмолчанию("Отправитель");
	УстановитьВалютуПоУмолчанию("Получатель");
	
	Если ИспользоватьИнтеграциюСБанком Тогда 
		ПолучитьИнформациюКоммерческогоКроссКурсов();
	КонецЕсли;
	
	РасчитатьСуммуПолучателя();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	РС_ОбщегоНазначенияКлиент.ПроверкаМодифицированостиВопрос(Объект.Ссылка, Модифицированность, Отказ);//Паганини
КонецПроцедуры
