
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИспользоватьИнтеграциюСБанком = Справочники.ИнтеграцииСБанками.BAGAGE22.ЗначениеКонстанты;//ПолучитьФункциональнуюОпцию("ИспользоватьЗагрузкуИзБанка");
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Если НЕ ЗначениеЗаполнено(Объект.ВидОперации) Тогда 
			Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.СоСчета;
			Если ИспользоватьИнтеграциюСБанком Тогда 
				БанкОтправительРаботаетСИнтеграцией = ?(ЗначениеЗаполнено(Объект.Отправитель), Объект.Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком, ЛОЖЬ);
			Иначе
				БанкОтправительРаботаетСИнтеграцией = Ложь
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		ОбновитьСтатусДокументаВИнтернетБанке();
		
		Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета") И ИспользоватьИнтеграциюСБанком Тогда 
			БанкОтправительРаботаетСИнтеграцией = Объект.Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком;
		Иначе
			БанкОтправительРаботаетСИнтеграцией = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	//Паганини_
	Если ТипЗнч(Объект.Отправитель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда 
	    БанкОтправитель = объект.Отправитель.Банк;
	КонецЕсли;
	//_Паганини
	
	НацВалюта = Константы.НациональнаяВалюта.Получить();
	
	ОграничитьТипОтправительПолучатель();
	ОбновитьОстаткиДенежныхСредствОтправитель();
	ОбновитьОстаткиДенежныхСредствПолучатель();
	УстановитьВидимостьИДоступность();
	
	УстановитьЗаголовкиОтрпвительПолучатель();
	
	ПолучитьИнформациюКоммерческогоКроссКурсов();
	
	//+++ Дмгг
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ПустойРеквизитСтатьяВДокументах") Тогда 
		Объект.Статья = Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
	КонецЕсли;
	//--- Дмгг
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовкиОтрпвительПолучатель()

	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.Касса Тогда 
		Элементы.Отправитель.Заголовок = Новый ФорматированнаяСтрока(НСтр("ka='სალარო';ru='Касса';en='Cashbox'"), , ЦветаСтиля.ТекстВторостепеннойНадписи);
		Элементы.Получатель.Заголовок = Новый ФорматированнаяСтрока(НСтр("ka='სალარო (მიმღები)';ru='Касса (получатель)';en='Cash box (receiver)'"), , ЦветаСтиля.ТекстВторостепеннойНадписи);
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.СоСчета Тогда
		Элементы.Отправитель.Заголовок = Новый ФорматированнаяСтрока(НСтр("ka='ანგარიში';ru='Счет';en='Score'"), , ЦветаСтиля.ТекстВторостепеннойНадписи);
		Элементы.Получатель.Заголовок = Новый ФорматированнаяСтрока(НСтр("ka='ანგარიში (მიმღები)';ru='Счет (получатель)';en='Account (the recipient)'"), , ЦветаСтиля.ТекстВторостепеннойНадписи);
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.Подотчетник Тогда
		Элементы.Отправитель.Заголовок = Новый ФорматированнаяСтрока(НСтр("ka='ანგარიში';ru='Счет';en='Score'"), , ЦветаСтиля.ТекстВторостепеннойНадписи);
		Элементы.Получатель.Заголовок = Новый ФорматированнаяСтрока(НСтр("ka='ანგარიში (მიმღები)';ru='Счет (получатель)';en='Account (the recipient)'"), , ЦветаСтиля.ТекстВторостепеннойНадписи);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьИДоступность(ИзмененВидОперации = Ложь)
	
	Элементы.Подотчетник.Видимость = Объект.ВидОперации = Перечисления.ВидыОперацийКонвертация.Подотчетник;
	
	Элементы.Отправитель.Видимость = Объект.ВидОперации <> Перечисления.ВидыОперацийКонвертация.Подотчетник;
	Элементы.Получатель.Видимость = Объект.ВидОперации <> Перечисления.ВидыОперацийКонвертация.Подотчетник;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета") 
		И БанкОтправительРаботаетСИнтеграцией Тогда
		
		Элементы.КоммерческийКурс.Видимость = ИспользоватьИнтеграциюСБанком;
		Элементы.КроссКуср.Видимость = ИспользоватьИнтеграциюСБанком;
		Элементы.ГруппаДанныеИнтернетБанка.Видимость = ИспользоватьИнтеграциюСБанком;
	Иначе 
		Элементы.ГруппаДанныеИнтернетБанка.Видимость = Ложь;
		Элементы.КоммерческийКурс.Видимость = Ложь;
		Элементы.КроссКуср.Видимость = Ложь;
		
	КонецЕсли;
	
	
КонецПроцедуры // УстановитьВидимостьИДоступность()

&НаСервере
Процедура ОбновитьОстаткиДенежныхСредствОтправитель()
	
	Элементы.ОстатокДенежныхСредствОправитель.Видимость = НЕ ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.Отправитель);
	ОстатокДенежныхСредствОтправитель = 0;
	
	Если НЕ Элементы.ОстатокДенежныхСредствОправитель.Видимость Тогда
		//Только для новых объектов
		Элементы.Отправитель.АвтоМаксимальнаяШирина = Истина;
		
		Если ТолькоПросмотр Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.Отправитель.АвтоМаксимальнаяШирина = Ложь;
	Элементы.Отправитель.МаксимальнаяШирина = 22;
	Элементы.ОстатокДенежныхСредствОправитель.Заголовок = ДвиженияДенежныхСредствВызовСервера.ЗаголовокНадписиОстатковДС(Объект.Отправитель, Объект.Организация, ОстатокДенежныхСредствОтправитель);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьОстаткиДенежныхСредствПолучатель()

	Элементы.ОстатокДенежныхСредствПолучатель.Видимость = НЕ ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.Получатель);
	ОстатокДенежныхСредствПолучатель = 0;	

	Если НЕ Элементы.ОстатокДенежныхСредствПолучатель.Видимость Тогда
		//Только для новых объектов
		Элементы.Получатель.АвтоМаксимальнаяШирина = Истина;
		
		Если ТолькоПросмотр Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Элементы.Получатель.АвтоМаксимальнаяШирина = Ложь;
	Элементы.Получатель.МаксимальнаяШирина = 22;
	Элементы.ОстатокДенежныхСредствПолучатель.Заголовок = ДвиженияДенежныхСредствВызовСервера.ЗаголовокНадписиОстатковДС(Объект.Получатель, Объект.Организация, ОстатокДенежныхСредствПолучатель);

КонецПроцедуры

&НаСервере
Процедура ОграничитьТипОтправительПолучатель(ИзменениеВидаОперации = ЛОЖЬ)
	
	Элементы.Отправитель.ВыбиратьТип = Ложь;
	Элементы.Получатель.ВыбиратьТип = Ложь;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета") Тогда 
		Элементы.Отправитель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		Элементы.Получатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		Если ИзменениеВидаОперации Тогда 
			Объект.Отправитель = Справочники.БанковскиеСчета.ПустаяСсылка();
			Объект.Получатель = Справочники.БанковскиеСчета.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли  Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.Касса") Тогда 
		Элементы.Отправитель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Кассы");
		Элементы.Получатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Кассы");
		Если ИзменениеВидаОперации Тогда
			Объект.Отправитель = Справочники.Кассы.ПустаяСсылка();
			Объект.Получатель = Справочники.Кассы.ПустаяСсылка();
		КонецЕсли;
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.Подотчетник") Тогда 
		Элементы.Отправитель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		Элементы.Получатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
		Если ИзменениеВидаОперации Тогда
			Объект.Отправитель = Справочники.БанковскиеСчета.ПустаяСсылка();
			Объект.Получатель = Справочники.БанковскиеСчета.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры


&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	ОграничитьТипОтправительПолучатель(Истина);
	УстановитьВидимостьИДоступность();
	УстановитьЗаголовкиОтрпвительПолучатель();
	УстановитьВидПоляВалют();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидПоляВалют()
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета") 
		ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.Касса") Тогда 
		Элементы.ВалютаОтправитель.Вид = ВидПоляФормы.ПолеНадписи;
		Элементы.ВалютаПолучатель.Вид = ВидПоляФормы.ПолеНадписи;
	Иначе 
		
		Элементы.ВалютаОтправитель.Вид = ВидПоляФормы.ПолеВвода;
		Элементы.ВалютаПолучатель.Вид = ВидПоляФормы.ПолеВвода;
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВалютуПоУмолчанию(ОтправительПолучатель)
	
	Если ОтправительПолучатель = "Отправитель" Тогда 
		Если ТипЗнч(Объект.Отправитель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда 
			Объект.ВалютаОтправитель = Объект.Отправитель.ВалютаДенежныхСредств;
			СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаОтправитель));
			
			Объект.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			Объект.КратностьОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
			//Паганини_
		    БанкОтправитель = объект.Отправитель.Банк;
			Если ЗначениеЗаполнено(Объект.Получатель) И НЕ Объект.Получатель.Банк = БанкОтправитель Тогда
				Объект.Получатель = Неопределено;
			КонецЕсли;
			//_Паганини
		ИначеЕсли ТипЗнч(Объект.Отправитель) = Тип("СправочникСсылка.Кассы") Тогда
			Объект.ВалютаОтправитель = ПолучитьВалютуПоУмолчаниюКассыНаСервере(Объект.Отправитель);
			СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаОтправитель));
			
			Объект.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			Объект.КратностьОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
		ИначеЕсли ТипЗнч(Объект.Отправитель) = Тип("СправочникСсылка.Сотрудники") Тогда
			Объект.ВалютаОтправитель = Константы.ВалютаУчета.Получить();
			Объект.КурсОтправитель = 1;
			Объект.КратностьОтправитель = 1;
		КонецЕсли;
	ИначеЕсли ОтправительПолучатель = "Получатель" Тогда 
		Если ТипЗнч(Объект.Получатель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда
			Объект.ВалютаПолучатель = Объект.Получатель.ВалютаДенежныхСредств;
			СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаПолучатель));
			
			Объект.КурсПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			Объект.КратностьПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
			
			БанкОтправитель = объект.Отправитель.Банк;
			
		ИначеЕсли ТипЗнч(Объект.Получатель) = Тип("СправочникСсылка.Кассы") Тогда
			Объект.ВалютаПолучатель = ПолучитьВалютуПоУмолчаниюКассыНаСервере(Объект.Получатель);
			СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаПолучатель));
			
			Объект.КурсПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			Объект.КратностьПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
		ИначеЕсли ТипЗнч(Объект.Получатель) = Тип("СправочникСсылка.Сотрудники") Тогда
			Объект.ВалютаОтправитель = Константы.ВалютаУчета.Получить();
			Объект.КурсПолучатель = 1;
			Объект.КратностьПолучатель = 1;
		КонецЕсли;
	КонецЕсли;
	
	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьВалютуПоУмолчаниюКассыНаСервере(Касса)
	
	Возврат Касса.ВалютаПоУмолчанию;
	
КонецФункции

&НаКлиенте
Процедура ОтправительПриИзменении(Элемент)
	
	УстановитьВалютуПоУмолчанию("Отправитель");
	ОбновитьОстаткиДенежныхСредствОтправитель();
	
	ПолучитьИнформациюКоммерческогоКроссКурсов();
	
	УстановитьВидимостьИДоступность();
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучательПриИзменении(Элемент)
	
	УстановитьВалютуПоУмолчанию("Получатель");
	ОбновитьОстаткиДенежныхСредствПолучатель();
	
	ПолучитьИнформациюКоммерческогоКроссКурсов();
	
КонецПроцедуры

&НаКлиенте
Процедура СуммаКонвертацииПриИзменении(Элемент)
	
	РасчитатьСуммуПолучателя();
	
КонецПроцедуры

&НаКлиенте
Процедура РасчитатьСуммуПолучателя()
	
	Если НЕ ЗначениеЗаполнено(Объект.КурсПолучатель) Тогда 
		Возврат;
	КонецЕсли;
	
	Если ИспользоватьИнтеграциюСБанком 
		И Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета") 
		И БанкОтправительРаботаетСИнтеграцией Тогда
		
		Если НацВалюта = Объект.ВалютаОтправитель ИЛИ НацВалюта = Объект.ВалютаПолучатель Тогда 
			
			Если Объект.ВалютаОтправитель = НацВалюта И НацВалюта <> Объект.ВалютаПолучатель Тогда 
				Объект.СуммаПолучено = Объект.СуммаКонвертации / Объект.КоммерческийКурс; //кратность = 1
			ИначеЕсли Объект.ВалютаОтправитель <> НацВалюта И НацВалюта = Объект.ВалютаПолучатель Тогда 
				Объект.СуммаПолучено = Объект.СуммаКонвертации * Объект.КоммерческийКурс;
			КонецЕсли;
			
		Иначе
			
			// Крос Курс учитывает отправителя и получателя
			Объект.СуммаПолучено = Объект.СуммаКонвертации * Объект.КроссКурс;
		КонецЕсли;
		
	Иначе 
		Объект.СуммаПолучено = Объект.СуммаКонвертации * (Объект.КурсОтправитель * Объект.КратностьПолучатель) / (Объект.КурсПолучатель * Объект.КратностьОтправитель);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОстатокДенежныхСредствОправительНажатие(Элемент)
	
	СтандартнаяОбработка = Ложь;
	РаботаСФормойДокументаКлиент.ОткрытьОтчетДенежныеСредства(Объект.Отправитель, Объект.Организация);
	
КонецПроцедуры

&НаКлиенте
Процедура ОстатокДенежныхСредствПолучательНажатие(Элемент)
	
	СтандартнаяОбработка = Ложь;
	РаботаСФормойДокументаКлиент.ОткрытьОтчетДенежныеСредства(Объект.Получатель, Объект.Организация);
	
КонецПроцедуры

&НаКлиенте
Процедура КурсПриИзменении(Элемент)
	РасчитатьСуммуПолучателя();
КонецПроцедуры

&НаКлиенте
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияКомментария(Элемент.ТекстРедактирования, ЭтотОбъект, "Объект.Комментарий");
