
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос(ТекстЗапросаИнициализироватьДанныеДокумента());
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаКонвертация);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ВалютаОтправитель", ДокументСсылкаКонвертация.ВалютаОтправитель);
	Запрос.УстановитьПараметр("ВалютаПолучатель", ДокументСсылкаКонвертация.ВалютаПолучатель);
	Запрос.УстановитьПараметр("ВалютаНациональная", Константы.НациональнаяВалюта.Получить());
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	
	Запрос.ВыполнитьПакет();
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_Конвертация(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства);
	СформироватьТаблицаДенежныеСредства(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства);
	СформироватьТаблицаДоходыИРасходы(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства);
	СформироватьТаблицаРасчетыСПодотчетниками(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства);
	СформироватьТаблицаОтчетПоКурсовымРазницам(ДокументСсылкаКонвертация, СтруктураДополнительныеСвойства);
	
КонецПроцедуры

Функция ТекстЗапросаИнициализироватьДанныеДокумента()
	
	Возврат
	"ВЫБРАТЬ
	|	Конвертация.Ссылка,
	|	ИспользоватьЗагрузкуИзБанка.Значение КАК ИспользоватьИнтеграциюСБанком,
	|	ЕСТЬNULL(СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.ПрисутствуетТОлькоВТекущейБазе)) КАК СтатусВИнтернеБанке,
	|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИДВИнтернетБанке,
	|	ВЫБОР
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.видыоперацийконвертация.сосчета)
	|			ТОГДА Конвертация.Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК БанкИспользуетсяДляИнтеграцииСБанком,
	|	Конвертация.ВидОперации
	|ПОМЕСТИТЬ ВременнаяТаблицаДанныеИнтернетБанка
	|ИЗ
	|	Константа.ИспользоватьЗагрузкуИзБанка КАК ИспользоватьЗагрузкуИзБанка,
	|	Документ.Конвертация КАК Конвертация
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	|		ПО Конвертация.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанке
	|		ПО Конвертация.Ссылка = СтатусыДокументовВИнтернетБанке.ДокументСсылка
	|ГДЕ
	|	Конвертация.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаДанныеИнтернетБанка.Ссылка,
	|	ВЫБОР
	|		КОГДА НЕ ВременнаяТаблицаДанныеИнтернетБанка.ИспользоватьИнтеграциюСБанком
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НЕ ВременнаяТаблицаДанныеИнтернетБанка.ВидОперации = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.ВИДЫОПЕРАЦИЙКОНВЕРТАЦИЯ.СОСЧЕТА)
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ВЫБОР
	|						КОГДА НЕ ВременнаяТаблицаДанныеИнтернетБанка.БанкИспользуетсяДляИнтеграцииСБанком
	|							ТОГДА ИСТИНА
	|						ИНАЧЕ ВЫБОР
	|								КОГДА ВременнаяТаблицаДанныеИнтернетБанка.СтатусВИнтернеБанке = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СТАТУСЫДОКУМЕНТОВВИНТЕРНЕТБАНКЕ.S)
	|										ИЛИ ВременнаяТаблицаДанныеИнтернетБанка.СтатусВИнтернеБанке = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СТАТУСЫДОКУМЕНТОВВИНТЕРНЕТБАНКЕ.P)
	|										ИЛИ ВременнаяТаблицаДанныеИнтернетБанка.СтатусВИнтернеБанке = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.СТАТУСЫДОКУМЕНТОВВИНТЕРНЕТБАНКЕ.зАГРУЖЕНИЗИНТЕРНЕТБАНКА)
	|									ТОГДА ИСТИНА
	|								ИНАЧЕ ЛОЖЬ
	|							КОНЕЦ
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК СформироватьПроводки
	|ПОМЕСТИТЬ ВременнаяТаблицаПроверкиИНтернетБанка
	|ИЗ
	|	ВременнаяТаблицаДанныеИнтернетБанка КАК ВременнаяТаблицаДанныеИнтернетБанка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КурсыВалютСрезПоследних.Валюта,
	|	КурсыВалютСрезПоследних.Курс,
	|	КурсыВалютСрезПоследних.Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаОтправитель, &ВалютаПолучатель, &ВалютаУчета, &ВалютаНациональная)) КАК КурсыВалютСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Конвертация.Номер,
	|	Конвертация.Дата,
	|	Конвертация.Организация,
	|	Конвертация.ВидОперации,
	|	Конвертация.Отправитель,
	|	Конвертация.Получатель,
	|	Конвертация.ВалютаОтправитель,
	|	Конвертация.ВалютаПолучатель,
	|	Конвертация.СуммаКонвертации КАК СуммаКонвертацииВал,
	|	Конвертация.СуммаПолучено КАК СуммаПолученоВал,
	|	ВЫБОР
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	|				ИЛИ Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Касса)
	|			ТОГДА Конвертация.Отправитель.СчетУчетаРегл
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Подотчетник)
	|			ТОГДА Конвертация.Подотчетник.СчетРасчетовСПодотчетникамиРегл
	|	КОНЕЦ КАК ОтправительСчетУчетаРегл,
	|	ВЫБОР
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	|				ИЛИ Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Касса)
	|			ТОГДА Конвертация.Получатель.СчетУчетаРегл
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Подотчетник)
	|			ТОГДА Конвертация.Подотчетник.СчетРасчетовСПодотчетникамиРегл
	|	КОНЕЦ КАК ПолучательСчетУчетаРегл,
	|	Конвертация.Статья,
	|	ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель * Конвертация.КратностьОтправитель / Конвертация.КурсПолучатель * Конвертация.КратностьПолучатель КАК ЧИСЛО(15, 2)) КАК СуммаОтправительВалПолучатель,
	|	ВЫБОР
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	|				ИЛИ Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Подотчетник)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоБанковскийСчет,
	|	Конвертация.КурсОтправитель,
	|	Конвертация.КурсПолучатель,
	|	Конвертация.КратностьОтправитель,
	|	Конвертация.КратностьПолучатель,
	|	Конвертация.Подотчетник,
	//ПодольскийАИ #УчетПроектов 21.04.2021 {
	|	Выбор 
	|		Когда Конвертация.Проект = Значение(Справочник.Проекты.ПустаяСсылка)
	|			Тогда Значение(Справочник.Проекты.БезПроекта)
	|		Иначе Конвертация.Проект
	|	Конец КАК Проект,
	//ПодольскийАИ #УчетПроектов 21.04.2021 }
	|	ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * (Конвертация.КурсОтправитель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьОтправитель) КАК ЧИСЛО(15, 2)) КАК СуммаОтправительРегл,
	|	ВЫРАЗИТЬ(Конвертация.СуммаПолучено * (Конвертация.КурсПолучатель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьПолучатель) КАК ЧИСЛО(15, 2)) КАК СуммаПолучательРегл,
	|	ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * (Конвертация.КурсОтправитель * втВалютаУчета.Кратность) / (втВалютаУчета.Курс * Конвертация.КратностьОтправитель) КАК ЧИСЛО(15, 2)) КАК СуммаОтправительУпр,
	|	ВЫБОР
	|		КОГДА Конвертация.СуммаПолучено = (ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель / Конвертация.КурсПолучатель КАК ЧИСЛО(15, 2)))
	|			ТОГДА Конвертация.СуммаКонвертации
	|		ИНАЧЕ ВЫРАЗИТЬ(Конвертация.СуммаПолучено * (Конвертация.КурсПолучатель * втВалютаУчета.Кратность) / (втВалютаУчета.Курс * Конвертация.КратностьПолучатель) КАК ЧИСЛО(15, 2))
	|	КОНЕЦ КАК СуммаПолучательУпр,
	|	ВЫБОР
	|		КОГДА Конвертация.СуммаПолучено = (ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель / Конвертация.КурсПолучатель КАК ЧИСЛО(15, 2)))
	|			ТОГДА 0
	|		ИНАЧЕ ВЫРАЗИТЬ(ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * (Конвертация.КурсОтправитель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьОтправитель) КАК ЧИСЛО(15,2)) - ВЫРАЗИТЬ(Конвертация.СуммаПолучено * (Конвертация.КурсПолучатель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьПолучатель) КАК ЧИСЛО(15,2)) КАК ЧИСЛО(15, 2))
	|	КОНЕЦ КАК РазницаРегл,
	|	ВЫБОР
	|		КОГДА Конвертация.СуммаПолучено = (ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель / Конвертация.КурсПолучатель КАК ЧИСЛО(15, 2)))
	|			ТОГДА 0
	|		ИНАЧЕ ВЫРАЗИТЬ(ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * (Конвертация.КурсОтправитель * втВалютаУчета.Кратность) / (втВалютаУчета.Курс * Конвертация.КратностьОтправитель) КАК ЧИСЛО(15,2)) - ВЫРАЗИТЬ(Конвертация.СуммаПолучено * (Конвертация.КурсПолучатель * втВалютаУчета.Кратность) / (втВалютаУчета.Курс * Конвертация.КратностьПолучатель) КАК ЧИСЛО(15,2)) КАК ЧИСЛО(15, 2))
	|	КОНЕЦ КАК РазницаУпр,
	|	ВЫБОР
	|		КОГДА Конвертация.СуммаПолучено = (ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель / Конвертация.КурсПолучатель КАК ЧИСЛО(15, 2)))
	|			ТОГДА 0
	|		ИНАЧЕ ВЫРАЗИТЬ(ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * (Конвертация.КурсОтправитель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьОтправитель) КАК ЧИСЛО(15,2)) - ВЫРАЗИТЬ(Конвертация.СуммаПолучено * (Конвертация.КурсПолучатель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьПолучатель) / (втВалютаПолучатель.Курс * втВалютаПолучатель.Кратность) КАК ЧИСЛО(15,2)) КАК ЧИСЛО(15, 2))
	|	КОНЕЦ КАК РазницаОтправитель,
	|	ВЫБОР
	|		КОГДА Конвертация.СуммаПолучено = (ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель / Конвертация.КурсПолучатель КАК ЧИСЛО(15, 2)))
	|			ТОГДА 0
	|		ИНАЧЕ ВЫРАЗИТЬ(ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * (Конвертация.КурсОтправитель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьОтправитель) КАК ЧИСЛО(15,2)) - ВЫРАЗИТЬ(Конвертация.СуммаПолучено * (Конвертация.КурсПолучатель * втНацВалюта.Кратность) / (втНацВалюта.Курс * Конвертация.КратностьПолучатель) / (втВалютаПолучатель.Курс * втВалютаПолучатель.Кратность) КАК ЧИСЛО(15, 2)) КАК ЧИСЛО(15,2))
	|	КОНЕЦ КАК РазницаПолучатель,
	|	(ВЫРАЗИТЬ(Конвертация.СуммаКонвертации * Конвертация.КурсОтправитель / Конвертация.КурсПолучатель КАК ЧИСЛО(15, 2))) = Конвертация.СуммаПолучено КАК БезКурсовыхРазниц
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|	Документ.Конвертация КАК Конвертация
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК втНацВалюта
	|		ПО (втНацВалюта.Валюта = &ВалютаНациональная)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК втВалютаУчета
	|		ПО (втВалютаУчета.Валюта = &ВалютаУчета)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК втВалютаОтправитель
	|		ПО Конвертация.ВалютаОтправитель = втВалютаОтправитель.Валюта
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК втВалютаПолучатель
	|		ПО Конвертация.ВалютаПолучатель = втВалютаПолучатель.Валюта
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаПроверкиИНтернетБанка КАК ВременнаяТаблицаПроверкиИНтернетБанка
	|		ПО Конвертация.Ссылка = ВременнаяТаблицаПроверкиИНтернетБанка.Ссылка
	|ГДЕ
	|	Конвертация.Ссылка = &Ссылка
	|	И ВременнаяТаблицаПроверкиИНтернетБанка.СформироватьПроводки
	|
	|СГРУППИРОВАТЬ ПО
	|	Конвертация.ВалютаОтправитель,
	|	Конвертация.Получатель,
	|	Конвертация.ВидОперации,
	|	Конвертация.Дата,
	|	Конвертация.Организация,
	|	ВЫБОР
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	|				ИЛИ Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Касса)
	|			ТОГДА Конвертация.Получатель.СчетУчетаРегл
	|		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.Подотчетник)
	|			ТОГДА Конвертация.Подотчетник.СчетРасчетовСПодотчетникамиРегл
	|	КОНЕЦ,
	|	Конвертация.Статья,
	|	Конвертация.Номер,
	|	Конвертация.Подотчетник,
	//ПодольскийАИ #УчетПроектов 21.04.2021 {
	|	Выбор 
	|		Когда Конвертация.Проект = Значение(Справочник.Проекты.ПустаяСсылка)
