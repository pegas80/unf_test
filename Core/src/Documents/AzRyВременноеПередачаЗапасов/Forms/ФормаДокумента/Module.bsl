	СтруктураПараметров.Вставить("БылиВнесеныИзменения", 							Ложь);
	
	// 2. Открвыаем форму "Цены и Валюта".
	СтруктураНастройкаДокумента = ОткрытьФормуМодально("ОбщаяФорма.НастройкаДокумента", СтруктураПараметров);
	
