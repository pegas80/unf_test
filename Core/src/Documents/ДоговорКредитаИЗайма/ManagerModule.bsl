КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыСПокупателями(ДокументСсылкаДоговорКредита, СтруктураДополнительныеСвойства)
	
	//Малышев 2024-06-10 ONESOFT-2926
	Если не ЗначениеЗаполнено(ДокументСсылкаДоговорКредита.ДокументРеализации) 
		и ДокументСсылкаДоговорКредита.ГрафикПлатежейИНачислений.Количество()>0 
		Тогда
			СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПокупателями", Новый ТаблицаЗначений);
			Возврат;	
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаДоговорКредита);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ПериодКонтроля", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени.Дата);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("СодержаниеПроводкиПереносДолга",
		НСтр("ka='სესხის დავალიანების გადაცემა სესხის დავალიანებაზე';ru='Перенос долга на расчеты по кредиту';en='Transfer of debt to loan debt'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК НомерСтроки,
	|	&СодержаниеПроводкиПереносДолга КАК СодержаниеПроводки,
	|	&Организация КАК Организация,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаДокумента.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.Договор КАК Договор,
	|	ТаблицаДокумента.ВалютаРасчетов КАК Валюта,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА ТаблицаДокумента.Документ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Документ,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.Заказ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
	|	КОНЕЦ КАК Заказ,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг) КАК ТипРасчетов,
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта) КАК Проект,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателем КАК СчетУчета,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателемРегл КАК СчетУчетаРегл,
	|	ТаблицаДокумента.Дата КАК Дата,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.НачислитьПроценты
	|			ТОГДА ТаблицаДокумента.СуммаОсновногоДолга + ТаблицаДокумента.СуммаПроцентов
	|		ИНАЧЕ ТаблицаДокумента.Сумма
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.НачислитьПроценты
	|			ТОГДА ТаблицаДокумента.СуммаОсновногоДолгаВал + ТаблицаДокумента.СуммаПроцентовВал
	|		ИНАЧЕ ТаблицаДокумента.СуммаВал
	|	КОНЕЦ КАК СуммаВал,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.НачислитьПроценты
	|			ТОГДА -(ТаблицаДокумента.СуммаОсновногоДолга + ТаблицаДокумента.СуммаПроцентов)
	|		ИНАЧЕ -ТаблицаДокумента.Сумма
	|	КОНЕЦ КАК СуммаДляОстатка,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.НачислитьПроценты
	|			ТОГДА -(ТаблицаДокумента.СуммаОсновногоДолгаВал + ТаблицаДокумента.СуммаПроцентовВал)
	|		ИНАЧЕ -ТаблицаДокумента.СуммаВал
	|	КОНЕЦ КАК СуммаВалДляОстатка
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПокупателями
	|ИЗ
	|	ТаблицаДокумента КАК ТаблицаДокумента
	|ГДЕ
	|	ТаблицаДокумента.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитВыданный)
	|	И ТаблицаДокумента.Документ <> ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент,
	|	Договор,
	|	Валюта,
	|	Документ,
	|	Заказ,
	|	ТипРасчетов,
	|	СчетУчета";
	
	Запрос.Выполнить();
	
	// Установка исключительной блокировки контролируемых остатков расчетов с контрагентами.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВременнаяТаблицаРасчетыСПокупателями.Организация КАК Организация,
	|	ВременнаяТаблицаРасчетыСПокупателями.Контрагент КАК Контрагент,
	|	ВременнаяТаблицаРасчетыСПокупателями.Договор КАК Договор,
	|	ВременнаяТаблицаРасчетыСПокупателями.Документ КАК Документ,
	|	ВременнаяТаблицаРасчетыСПокупателями.Заказ КАК Заказ,
	|	ВременнаяТаблицаРасчетыСПокупателями.ТипРасчетов КАК ТипРасчетов
	|ИЗ
	|	ВременнаяТаблицаРасчетыСПокупателями";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РасчетыСПокупателями");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	
	Для каждого КолонкаРезультатЗапроса Из РезультатЗапроса.Колонки Цикл
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных(КолонкаРезультатЗапроса.Имя, КолонкаРезультатЗапроса.Имя);
	КонецЦикла;
	Блокировка.Заблокировать();
	
	НомерЗапроса = 0;
	Запрос.Текст = УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПокупателями(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	// Щербаков +++
	Запрос.Текст = Запрос.Текст + ";" + УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПокупателямиРегл(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	// Щербаков ---
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПокупателями", МассивРезультатов[НомерЗапроса].Выгрузить());
	
КонецПроцедуры

// Формирует таблицу значений, содержащую данные для проведения по регистру РасчетыПоКредитамИЗаймам.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыПоКредитамИЗаймам(ДокументСсылкаДоговорКредита, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("УчетРасчетовПоКредитамВыданным", НСтр("ka='კრედიტი მყიდველს';ru='Выдача кредита покупателю';en='Issuance of the loan to the buyer'"));
	Запрос.УстановитьПараметр("УчетРасчетовПоНачисленнымПроцентам",
		НСтр("ka='კრედიტის (გაცემული) თაობაზე დარიცხულია პროცენტები';ru='Начислены проценты по кредиту (выданному)';en='Chargeable loan interest (iccued)'"));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаДоговорКредита);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ПериодКонтроля", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени.Дата);
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ka='სხვაობა კურსებს შორის';ru='Курсовая разница';en='Exchange difference'"));
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.ВидДоговора КАК ВидДоговора,
	|	ТаблицаДокумента.Дата КАК Дата,
	|	ТаблицаДокумента.Дата КАК Период,
	|	&УчетРасчетовПоКредитамВыданным КАК СодержаниеПроводки,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаВал КАК ЧИСЛО(15, 2)) КАК ОсновнойДолгВал,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.Сумма КАК ЧИСЛО(15, 2)) КАК ОсновнойДолг,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаВал КАК ЧИСЛО(15, 2)) КАК ОсновнойДолгВалДляОстатка,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.Сумма КАК ЧИСЛО(15, 2)) КАК ОсновнойДолгДляОстатка,
	|	0 КАК ПроцентыВал,
	|	0 КАК Проценты,
	|	0 КАК ПроцентыВалДляОстатка,
	|	0 КАК ПроцентыДляОстатка,
	|	0 КАК КомиссияВал,
	|	0 КАК Комиссия,
	|	0 КАК КомиссияВалДляОстатка,
	|	0 КАК КомиссияДляОстатка,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаВал КАК ЧИСЛО(15, 2)) КАК СуммаВал,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.Сумма КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	ТаблицаДокумента.Ссылка КАК ДоговорКредитаЗайма,
	|	ТаблицаДокумента.ВалютаРасчетов КАК Валюта,
	|	ТаблицаДокумента.СчетУчета КАК СчетУчета,
	|	ТаблицаДокумента.СчетУчетаРегл КАК СчетУчетаРегл,
	|	ЛОЖЬ КАК УдержаноИзЗарплаты,
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта) КАК Проект,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателем КАК СчетУчетаРасчетовСПокупателем,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателемРегл КАК СчетУчетаРасчетовСПокупателемРегл,
	|	ТаблицаДокумента.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.Договор КАК Договор
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыПоКредитамИЗаймам
	|ИЗ
	|	ТаблицаДокумента КАК ТаблицаДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсыВалютДоговора
	|		ПО (КурсыВалютДоговора.Валюта = ТаблицаДокумента.ВалютаРасчетов)
	|ГДЕ
	|	ТаблицаДокумента.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитВыданный)
	|	И ТаблицаДокумента.Документ <> ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)
	|	И НЕ ТаблицаДокумента.НачислитьПроценты
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Организация,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаДокумента.ВидДоговора,
	|	ТаблицаДокумента.Дата,
	|	ТаблицаДокумента.Дата,
	|	&УчетРасчетовПоКредитамВыданным,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаОсновногоДолгаВал КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаОсновногоДолга КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаОсновногоДолгаВал КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаОсновногоДолга КАК ЧИСЛО(15, 2)),
	|	0,
	|	0,
	|	0,
	|	0,
	|	0,
	|	0,
	|	0,
	|	0,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаВал КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.Сумма КАК ЧИСЛО(15, 2)),
	|	ТаблицаДокумента.Ссылка,
	|	ТаблицаДокумента.ВалютаРасчетов,
	|	ТаблицаДокумента.СчетУчета,
	|	ТаблицаДокумента.СчетУчетаРегл,
	|	ЛОЖЬ,
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта),
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателем,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателемРегл,
	|	ТаблицаДокумента.Контрагент,
	|	ТаблицаДокумента.Договор
	|ИЗ
	|	ТаблицаДокумента КАК ТаблицаДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсыВалютДоговора
	|		ПО (КурсыВалютДоговора.Валюта = ТаблицаДокумента.ВалютаРасчетов)
	|ГДЕ
	|	ТаблицаДокумента.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитВыданный)
	|	И ТаблицаДокумента.Документ <> ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)
	|	И ТаблицаДокумента.НачислитьПроценты
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&Организация,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаДокумента.ВидДоговора,
	|	ТаблицаДокумента.Дата,
	|	ТаблицаДокумента.Дата,
	|	&УчетРасчетовПоНачисленнымПроцентам,
	|	0,
	|	0,
	|	0,
	|	0,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаПроцентовВал КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаПроцентов КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаПроцентовВал КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаПроцентов КАК ЧИСЛО(15, 2)),
	|	0,
	|	0,
	|	0,
	|	0,
	|	ВЫРАЗИТЬ(ТаблицаДокумента.СуммаВал КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ТаблицаДокумента.Сумма КАК ЧИСЛО(15, 2)),
	|	ТаблицаДокумента.Ссылка,
	|	ТаблицаДокумента.ВалютаРасчетов,
	|	ТаблицаДокумента.СчетУчетаПроцентов,
	|	ТаблицаДокумента.СчетУчетаПроцентовРегл,
	|	ЛОЖЬ,
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта),
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателем,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПокупателемРегл,
	|	ТаблицаДокумента.Контрагент,
	|	ТаблицаДокумента.Договор
	|ИЗ
	|	ТаблицаДокумента КАК ТаблицаДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаКурсыВалютСрезПоследних КАК КурсыВалютДоговора
	|		ПО (КурсыВалютДоговора.Валюта = ТаблицаДокумента.ВалютаРасчетов)
	|ГДЕ
	|	ТаблицаДокумента.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитВыданный)
	|	И ТаблицаДокумента.Документ <> ЗНАЧЕНИЕ(Документ.РасходнаяНакладная.ПустаяСсылка)
	|	И ТаблицаДокумента.НачислитьПроценты";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	НомерЗапроса = 0;
	
	Запрос.Текст = УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыПоКредитамИЗаймамРегл(Запрос.МенеджерВременныхТаблиц, НомерЗапроса);
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоКредитамИЗаймам", МассивРезультатов[НомерЗапроса].Выгрузить());
	
КонецПроцедуры

#Область СчетаУчета

Функция НовыйСчетаУчета()
	
	СчетаУчета = Новый Структура;
	
	СчетаУчета.Вставить("СчетУчетаРегл", ПланыСчетов.Хозрасчетный.ПустаяСсылка());
	СчетаУчета.Вставить("СчетУчетаПроцентовРегл", ПланыСчетов.Хозрасчетный.ПустаяСсылка());
	СчетаУчета.Вставить("СчетУчетаКомиссииРегл", ПланыСчетов.Хозрасчетный.ПустаяСсылка());
	СчетаУчета.Вставить("СчетЗатратРегл", ПланыСчетов.Хозрасчетный.ПустаяСсылка());
	
	Возврат СчетаУчета;
	
КонецФункции

Функция ИменаРесурсовУчетнойПолитикиСчетаУчета(СчетаУчета, ВидДоговора)
	
	ИменаРесурсов = Новый Массив;
	
	ВидДоговораСтрокой = ВидДоговораКредитаЗаймаСтрокой(ВидДоговора);
	
	Для Каждого КлючИЗначение Из СчетаУчета Цикл
		ИменаРесурсов.Добавить(КлючИЗначение.Ключ + ВидДоговораСтрокой);
	КонецЦикла;
	
	Возврат ИменаРесурсов;
	
КонецФункции

Функция ВидДоговораКредитаЗаймаСтрокой(ВидДоговора)
	
	Возврат ОбщегоНазначения.ИмяЗначенияПеречисления(ВидДоговора);
	
КонецФункции

