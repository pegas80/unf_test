
&НаКлиенте
Процедура ДабавитьКолонку(Команда)
	
	ДабавитьКолонкНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ДабавитьКолонкНаСервере(СписокКолонок = Неопределено)
	
	Если СписокКолонок = Неопределено Тогда
		
		КоличествоКолонок = КоличествоКолонок + 1;
		
		НовыеРеквизиты = Новый Массив;
		
		НовыйРеквизит = Новый РеквизитФормы("Колонка" + КоличествоКолонок, Новый ОписаниеТипов("Строка"),, НСтр("ru = 'Колонка " + КоличествоКолонок + "'; ka = 'სვეტი " + КоличествоКолонок + "'"));
		
		НовыеРеквизиты.Добавить(НовыйРеквизит);
		ИзменитьРеквизиты(НовыеРеквизиты);
		
		НовыйЭлемент = Элементы.Вставить("Колонка" + КоличествоКолонок, Тип("ПолеФормы"), Элементы.ГруппаКолонок);
		НовыйЭлемент.ПутьКДанным = "Колонка" + КоличествоКолонок;
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.УстановитьДействие("НачалоВыбора", "КолонкиНачалоВыбора");
		НовыйЭлемент.УстановитьДействие("ПриИзменении", "КолонкиПриИзменении");
		
		Элементы["Колонка" + КоличествоКолонок].КнопкаВыбора = Истина;
		Элементы["Колонка" + КоличествоКолонок].КнопкаОчистки = Истина;
		Элементы["Колонка" + КоличествоКолонок].РежимВыбораИзСписка = Истина;
		
	Иначе
		
		Для Каждого ЭлементСписка Из СписокКолонок Цикл 
			
			НовыеРеквизиты = Новый Массив;
			
			НомерКолонки = СокрЛП(СтрЗаменить(Строка(ЭлементСписка.Значение), "Колонка", ""));
			
			НомерКолонкиЧисло = КоличествоКолонок;
			Попытка
				НомерКолонкиЧисло = Число(НомерКолонки);
				КоличествоКолонок = ?(НомерКолонкиЧисло > КоличествоКолонок, НомерКолонкиЧисло, КоличествоКолонок);
			Исключение
			КонецПопытки;
			
			НовыйРеквизит = Новый РеквизитФормы(ЭлементСписка.Значение, Новый ОписаниеТипов("Строка"),, НСтр("ru = 'Колонка " + НомерКолонки + "'; ka = 'სვეტი " + НомерКолонки + "'"));
			
			НовыеРеквизиты.Добавить(НовыйРеквизит);
			ИзменитьРеквизиты(НовыеРеквизиты);
			
			НовыйЭлемент = Элементы.Вставить(ЭлементСписка.Значение, Тип("ПолеФормы"), Элементы.ГруппаКолонок);
			НовыйЭлемент.ПутьКДанным = ЭлементСписка.Значение;
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.УстановитьДействие("НачалоВыбора", "КолонкиНачалоВыбора");
			НовыйЭлемент.УстановитьДействие("ПриИзменении", "КолонкиПриИзменении");
			
			Элементы[ЭлементСписка.Значение].КнопкаВыбора = Истина;
			Элементы[ЭлементСписка.Значение].КнопкаОчистки = Истина;
			Элементы[ЭлементСписка.Значение].РежимВыбораИзСписка = Истина;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СписокИменКолонок.Очистить();
	СписокИменКолонок.Вставить(0,"Дата",НСтр("ka='თარიღი';ru='Дата'"));
	СписокИменКолонок.Вставить(1,"ВнеоборотныйАктив",НСтр("ru = 'ОС/Транспортне средство'; ka = 'ძ/ს / სატრანსპორტო საშუალება'"));
	СписокИменКолонок.Вставить(2,"Номенклатура",НСтр("ka='ნომენკლატურა';ru='Номенклатура'"));
	СписокИменКолонок.Вставить(3,"Характеристика",НСтр("ka='მახასიათებელი';ru='Характеристика'"));
	СписокИменКолонок.Вставить(4,"Количество",НСтр("ka='რაოდენობა';ru='Количество'"));
	СписокИменКолонок.Вставить(5,"СтруктурнаяЕдиница",НСтр("ka='საწყობი';ru='Склад'"));
	СписокИменКолонок.Вставить(6,"Подразделение",НСтр("ka='ქვეგანყოფილება';ru='Подразделение'"));
	СписокИменКолонок.Вставить(7,"НаправлениеДеятельности",НСтр("ka='საქმიანობის მიმართულება';ru='Направление деятельности'"));
	СписокИменКолонок.Вставить(8,"СчетУчетаЗатрат",НСтр("ka='ხარჯების ანგარიში (რეგლ)';ru='Счет учета затрат (регл)'"));
	
	Если Параметры.Свойство("ЭтоТопливо") И Параметры.ЭтоТопливо Тогда 
		СписокИменКолонок.Вставить(9,"ПробегНачало",НСтр("ru = 'Пробег начало'; ka = 'ოდომეტრის ჩვენება საწყისი'"));
		СписокИменКолонок.Вставить(10,"ПробегОкончание",НСтр("ru = 'Пробег окончание'; ka = 'ოდომეტრის ჩვენება საბოლოო'"));
		СписокИменКолонок.Вставить(11,"ПробегРазница",НСтр("ru = 'Пробег (км)'; ka = 'გავლილი კილომეტრაჟი'"));
		СписокИменКолонок.Вставить(12,"ПолныйБак",НСтр("ru = 'Полный бак'; ka = 'ავზი გაივსო'"));
	КонецЕсли;
	
	КоличествоКолонок = 0;
	
	Если Параметры.Свойство("СписокКолонок") Тогда 
		
		СписокВходящий = Параметры.СписокКолонок;
		ДабавитьКолонкНаСервере(Параметры.СписокКолонок);
			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КолонкиНачалоВыбора(Элемент)
	
	а=1;
	КолонкиНачалоВыбораНаСервере();
	
	СписокЗагрузки = СписокИменКолонок.Скопировать();
	МассивВыбранныхКолонко = Новый Массив;
	
	Для Сч = 1 По 14 Цикл
		
		Если Элемент.Имя = "Колонка"+Сч Тогда 
			Продолжить;
		КонецЕсли;
		
		Попытка
			ИскомоеЗначение	= ЭтаФорма["Колонка"+Сч];
			НайденныйЭлемент = СписокЗагрузки.НайтиПоЗначению(ИскомоеЗначение);
			Если НайденныйЭлемент <> Неопределено Тогда 
				СписокЗагрузки.Удалить(НайденныйЭлемент);
			КонецЕсли;
		Исключение
			Продолжить;
		КонецПопытки;             
		
	КонецЦикла;
	
	Элемент.СписокВыбора.Очистить();
	
	Для Каждого Элем Из СписокЗагрузки Цикл 
		
		Элемент.СписокВыбора.Добавить(Элем.Значение, Элем.Представление);
		
	КонецЦикла;
	
КонецПроцедуры

