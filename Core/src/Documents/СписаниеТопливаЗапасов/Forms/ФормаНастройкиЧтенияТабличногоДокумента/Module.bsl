&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Для Каждого ЭлементСписка Из СписокВходящий Цикл 
		
		Для Каждого Элем Из СписокИменКолонок Цикл 
			
			Элементы[ЭлементСписка.Значение].СписокВыбора.Добавить(Элем.Значение, Элем.Представление);
			
		КонецЦикла;
		
		Если ЭлементСписка.Представление <> "" Тогда 
			ЭтаФорма[ЭлементСписка.Значение] = Элементы[ЭлементСписка.Значение].СписокВыбора.НайтиПоЗначению(ЭлементСписка.Представление).Значение;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры


&НаСервере
Процедура СохранитьШаблонНаСервере(ТабДок, МассивИменКолонок)
	
	Счетчик = 1;
	Для Каждого Элем Из МассивИменКолонок Цикл 
		
		//ТабДок.ПолучитьОбласть("R1C"+Счетчик+":R1C"+Счетчик+"").ТекущаяОбласть.Текст = Элем;
		ТабДок.Область("R1C"+Формат(Счетчик,"ЧГ=0")).Текст = Элем;
		
		Счетчик = Счетчик + 1;
		
	КонецЦикла;
	
КонецПроцедуры


&НаКлиенте
Процедура СохранитьШаблон(Команда)
	
	ТабДок = Новый ТабличныйДокумент;
	МассивИменКолонок = Новый Массив;
	
	Для Сч = 1 По 14 Цикл
		
		Попытка
			ИскомоеЗначение	= СписокИменКолонок.НайтиПоЗначению(ЭтаФорма["Колонка"+Сч]).Представление;
			МассивИменКолонок.Добавить(ИскомоеЗначение);
		Исключение
			Продолжить;
		КонецПопытки;             
		
	КонецЦикла;
	
	СохранитьШаблонНаСервере(ТабДок, МассивИменКолонок);
	
	ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
    ДиалогВыбораФайла.ПолноеИмяФайла = НСтр("ru = 'Шаблон загрузки'; ka = 'Шаблон загрузки'");
    Фильтр = "Табличный документ (*.xlsx)|*.xlsx|";
    ДиалогВыбораФайла.Фильтр = Фильтр;
    ДиалогВыбораФайла.Заголовок = "Укажите Место";
	
	Если ДиалогВыбораФайла.Выбрать() Тогда
        ПутьКФайлу = ДиалогВыбораФайла.ПолноеИмяФайла;
		ТабДок.Записать(ДиалогВыбораФайла.ПолноеИмяФайла, "XLSX"); 
	КонецЕсли;
	
КонецПроцедуры

