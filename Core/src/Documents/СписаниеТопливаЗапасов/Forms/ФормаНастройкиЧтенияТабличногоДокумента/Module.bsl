&НаКлиенте
Процедура OK(Команда)
	
	СтруктураКолонок = Новый Структура;
	
	Для Сч = 1 По 14 Цикл
		
		Попытка
			ИскомоеЗначение	= ЭтаФорма["Колонка"+Сч];
			СтруктураКолонок.Вставить("Колонка"+Сч, ИскомоеЗначение);
		Исключение
			Продолжить;
		КонецПопытки;             
		
	КонецЦикла;
	
	Оповестить("НастройкаЗагрузкиИзТабличногоДокумента_СпианиеТопливаЗапасов",СтруктураКолонок);
	
	ЭтаФорма.Закрыть();
	
КонецПроцедуры


