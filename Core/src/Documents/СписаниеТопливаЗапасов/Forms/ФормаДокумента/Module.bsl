&НаКлиенте
Процедура РасходыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	СтрокаТабличнойЧасти = Элементы.Расходы.ТекущиеДанные;
	
	Если НоваяСтрока И НЕ Копирование Тогда 
		
		СтрокаТабличнойЧасти.Дата = НачалоДня(ДатаДокумента);
		СтрокаТабличнойЧасти.СтруктурнаяЕдиница = Объект.СтруктурнаяЕдиница;
		СтрокаТабличнойЧасти.Подразделение = Объект.Подразделение;
		СтрокаТабличнойЧасти.НаправлениеДеятельности = Объект.НаправлениеДеятельности;
		СтрокаТабличнойЧасти.СчетУчетаЗатрат = Объект.СчетУчетаЗатрат;      
		
	КонецЕсли;
	
	Если Объект.ВидОперации =ПредопределенноеЗначение("Перечисление.ВидыОперацийСписаниеТопливаЗапасов.СписаниеЗапасовНаВнеоборотныеАктивы") Тогда 
		МассивПринятыхВА = МассивПринятыхВА();
		НовыйПараметрСсылки = Новый ПараметрВыбора("Отбор.Ссылка", МассивПринятыхВА);
		
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НовыйПараметрСсылки);
		НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.РасходыВнеоборотныйАктив.ПараметрыВыбора = НовыеПараметры;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСтруктуруИнвГосНомера(ВнеоборотныйАктив)
	
	СтруктураВозврата = Новый Структура;
	
	Если ТипЗнч(ВнеоборотныйАктив) = Тип("СправочникСсылка.ВнеоборотныеАктивы") 
		ИЛИ ТипЗнч(ВнеоборотныйАктив) = Тип("СправочникСсылка.ТранспортныеСредства") Тогда 
		СтруктураВозврата.Вставить("Номер", ВнеоборотныйАктив.Код);
	Иначе
		СтруктураВозврата.Вставить("Номер", "");
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаКлиенте
Процедура РасходыВнеоборотныйАктивПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Расходы.ТекущиеДанные;
	
	СтруктураНомера = ПолучитьСтруктуруИнвГосНомера(СтрокаТабличнойЧасти.ВнеоборотныйАктив);
	
	СтрокаТабличнойЧасти.НомерВА = СтруктураНомера.Номер;
	
	Если Объект.ВидОперации =ПредопределенноеЗначение("Перечисление.ВидыОперацийСписаниеТопливаЗапасов.СписаниеЗапасовНаВнеоборотныеАктивы") Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(СтрокаТабличнойЧасти.ВнеоборотныйАктив) = Тип("СправочникСсылка.ВнеоборотныеАктивы") Тогда 
		
		МассивПринятыхВА = МассивПринятыхВА();
		НовыйПараметрСсылки = Новый ПараметрВыбора("Отбор.Ссылка", МассивПринятыхВА);
		
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НовыйПараметрСсылки);
		НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.РасходыВнеоборотныйАктив.ПараметрыВыбора = НовыеПараметры;
		
	Иначе
		
		МассивПринятыхВА = МассивПринятыхВА();
		НовыйПараметрСсылки = Новый ПараметрВыбора("Отбор.ПометкаУдаления", ЛОЖЬ);
		
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НовыйПараметрСсылки);
		НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.РасходыВнеоборотныйАктив.ПараметрыВыбора = НовыеПараметры;
		
	КонецЕсли;
	
КонецПроцедуры

