&НаКлиенте
Процедура УстановаитьДоступностьТипаДанныхВА()
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийСписаниеТопливаЗапасов.СписаниеЗапасовНаВнеоборотныеАктивы") Тогда 
		
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(Тип("СправочникСсылка.ВнеоборотныеАктивы"));
		
		ОписаниеТиповКолонка = Новый ОписаниеТипов(МассивТипов);

		Элементы.РасходыВнеоборотныйАктив.ОграничениеТипа = ОписаниеТиповКолонка;
		
	Иначе
		
		МассивТипов = Новый Массив;
		МассивТипов.Добавить(Тип("СправочникСсылка.ВнеоборотныеАктивы"));
		МассивТипов.Добавить(Тип("СправочникСсылка.ТранспортныеСредства"));
		
		ОписаниеТиповКолонка = Новый ОписаниеТипов(МассивТипов);
		
		Элементы.РасходыВнеоборотныйАктив.ОграничениеТипа = ОписаниеТиповКолонка;

	КонецЕсли;	
	
КонецПроцедуры


