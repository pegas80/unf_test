	ТабличныйДокумент.АвтоМасштаб = Истина;
	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
	МакетПечатнойФормы = ПолучитьМакет("Макет_СМ");
	
	ТабличныйДокумент.Очистить();
	//   
	
	//ТабличныйДокумент = Новый ТабличныйДокумент;
	//ТабличныйДокумент.ИмяПараметровПечати	= "ПараметрыПечати_Макет_СТ";
	//ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_СписаниеТопливаЗапасов_Макет_СТ";
	//ТабличныйДокумент.АвтоМасштаб			= Истина;
	//Страница = 1;
	//
