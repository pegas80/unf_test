		//МассивСтрок.Добавить(ОбластьПустаяСтрока);
		//МассивСтрок.Добавить(ОбластьПустаяСтрока);
		//МассивСтрок.Добавить(ОбластьПустаяСтрока);
		
		
		// КолЗапасов = СсылкаНаОбъект.ТаблицаПредложений.Количество();
		
		
		Для Каждого стр из СсылкаНаОбъект.Расходы Цикл
			
			ОбластьТабличнаяЧасть.Параметры.Номенклатура = стр.Номенклатура;
			ОбластьТабличнаяЧасть.Параметры.РасходыДата = Формат(стр.Дата, "ДФ=dd.MM.yyyy");
			ОбластьТабличнаяЧасть.Параметры.ЕдиницаИзмерения = Строка(стр.Количество) + стр.ЕдиницаИзмерения;
			ОбластьТабличнаяЧасть.Параметры.ВнеоборотныйАктив	 = стр.ВнеоборотныйАктив;
			ОбластьТабличнаяЧасть.Параметры.ПробегОкончание = стр.ПробегОкончание;
			ОбластьТабличнаяЧасть.Параметры.НомерВА  = стр.НомерВА;
			ОбластьТабличнаяЧасть.Параметры.ПробегНачало = стр.ПробегНачало;
			ОбластьТабличнаяЧасть.Параметры.ПробегРазница  = стр.ПробегРазница;
			ОбластьТабличнаяЧасть.Параметры.ПолныйБак = стр.ПолныйБак;
			
			ТабличныйДокумент.Вывести(ОбластьТабличнаяЧасть);
			
		КонецЦикла;
		
		//ТабличныйДокумент.Вывести(ОбластьПодвал);
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, СсылкаНаОбъект);
		
		Если ЗначениеЗаполнено(СсылкаНаОбъект.Организация.ФайлПечати) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(СсылкаНаОбъект.Организация.ФайлПечати);
			ОбластьПодвал.Рисунки.Печать.Картинка = Новый Картинка(ДанныеКартинки);
		КонецЕсли;	
		
		
		
		
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
	КонецЦикла;	
	Возврат ТабличныйДокумент;
	
	
	
КонецФункции

