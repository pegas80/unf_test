Процедура СформироватьТаблицаДоходыИРасходы(ДокументСсылкаСписаниеТопливаЗапасов, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
	// Олег Литвиненко 16.11.22 --->
	"ВЫБРАТЬ
	|	ТаблицаЗапасы.НомерСтроки КАК НомерСтроки,
	|	ТаблицаЗапасы.ВидДвижения КАК ВидДвижения,
	|	ТаблицаЗапасы.Сумма КАК Сумма
	|ПОМЕСТИТЬ втТаблицаЗапасы
	|ИЗ
	|	&ВнешняяТаблица КАК ТаблицаЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаЗапасы.НомерСтроки КАК НомерСтроки,
	|	ТаблицаЗапасы.Сумма КАК Сумма
	|ПОМЕСТИТЬ втТаблицаСумм
	|ИЗ
	|	втТаблицаЗапасы КАК ТаблицаЗапасы
	|ГДЕ
	|	ТаблицаЗапасы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ втТаблицаЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Шапка.ПроводитьСДатойДокумента
	|			ТОГДА Шапка.Период
	|		ИНАЧЕ ТаблицаЗапасыНаСкладах.Период
	|	КОНЕЦ КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ТаблицаЗапасыНаСкладах.НомерСтроки КАК НомерСтроки,
	|	Шапка.Организация КАК Организация,
	|	ТаблицаЗапасыНаСкладах.Подразделение КАК СтруктурнаяЕдиница,
	|	ТаблицаЗапасыНаСкладах.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ТаблицаЗапасыНаСкладах.СчетУчетаЗапасов КАК СчетУчета,
	
	//Малышев 2025-02-27 ONESOFT-3896
	//|	Шапка.СчетУчетаЗатрат КАК СчетУчетаРегл,
	|	ТаблицаЗапасыНаСкладах.СчетУчетаЗатратРегл КАК СчетУчетаРегл,
	|	
	|
	|	ТаблицаЗапасыНаСкладах.Характеристика КАК Характеристика,
	|	ЕСТЬNULL(втТаблицаСумм.Сумма, 0) КАК СуммаРасходов,
	//|	NULL КАК Аналитика,
	|   ТаблицаЗапасыНаСкладах.Номенклатура  КАК Аналитика, //ONESOFT-3176
	|	ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СписаниеЗапасов) КАК ХозяйственнаяОперация,
	|	ВЫРАЗИТЬ(&СписаниеЗапасов КАК СТРОКА(100)) КАК СодержаниеПроводки
	|,	ТаблицаЗапасыНаСкладах.Проект КАК Проект //+++ Дмгг, 11.02.24, ONESOFT-2827
	|ИЗ
	|	ВременнаяТаблицаШапка КАК Шапка,
	|	ВременнаяТаблицаРасходы КАК ТаблицаЗапасыНаСкладах
	|	ЛЕВОЕ СОЕДИНЕНИЕ втТаблицаСумм КАК втТаблицаСумм
	|		ПО ТаблицаЗапасыНаСкладах.НомерСтроки = втТаблицаСумм.НомерСтроки
	|ГДЕ  
	//Малышев 2025-02-27  ONESOFT-3896
	|	ТаблицаЗапасыНаСкладах.СчетУчетаЗатратРегл.ТипСчета <> Значение(Перечисление.ТипыСчетов.НезавершенноеПроизводство)
	|	И ТаблицаЗапасыНаСкладах.СчетУчетаЗатратРегл.ТипСчета <> Значение(Перечисление.ТипыСчетов.КосвенныеЗатраты)
	|";
	// Олег Литвиненко <---
	
	
	Запрос.УстановитьПараметр("ВнешняяТаблица", СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЗапасы);
	Запрос.УстановитьПараметр("СписаниеЗапасов", НСтр("ka='მარაგების ჩამოწერა';ru='Списание запасов';en='Write-off stocks'"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	//Нужны колонки, заполнения в процедуре запасов
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДоходыИРасходы", РезультатЗапроса.Выгрузить());
	
