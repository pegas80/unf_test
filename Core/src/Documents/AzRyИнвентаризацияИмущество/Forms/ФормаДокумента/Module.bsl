	ТекШтрихкод = "";
	ВвестиЗначение(ТекШтрихкод, НСтр("ru='Введите штрихкод';ka='შეიყვანეთ შტრიხკოდი'"));
	
	Если НЕ ПустаяСтрока(ТекШтрихкод) Тогда
		ПолученыШтрихкоды(Новый Структура("Штрихкод, Количество", ТекШтрихкод, 1));
	КонецЕсли;
	
КонецПроцедуры

