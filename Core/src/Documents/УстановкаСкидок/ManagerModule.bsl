	//	ЗагрузкаДанныхИзВнешнегоИсточника.ДобавитьПолеОписанияЗагрузки(ТаблицаПолейЗагрузки, "Характеристика",  НСтр("ru = 'Характеристика (наименование)'; ka = 'მახასიათებელი  (დასახელება)'; en = 'Characteristics (name)'"), ОписаниеТиповСтрока150, ОписаниеТиповКолонка);
