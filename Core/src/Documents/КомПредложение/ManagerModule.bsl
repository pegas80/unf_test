					ОбластьТабличнаяЧасть.Параметры.Сумма = Окр(стр.Цена*100/(100+СтавкаНДС)*стр.Количество,2);
					ОбластьТабличнаяЧасть.Параметры.СкидкаСумма = Окр(стр.Цена*100/(100+СтавкаНДС)*стр.Количество*стр.ПроцентСкидкиНаценки/100,2);
	
				КонецЕсли;


					 
				//ТабличныйДокумент.Вывести(ОбластьТабличнаяЧасть);
			Иначе
				//ТабличныйДокумент.Вывести(ОбластьПодвал);
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				Если КолЗапасов > 0 Тогда
				СтавкаНДС = ПолучитьСтавкуНДСЧислом(стр.СтавкаНДС);
				ОбластьТабличнаяЧасть.Параметры.Номенклатура = стр.Номенклатура;
				ОбластьТабличнаяЧасть.Параметры.Количество = стр.Количество;
				ОбластьТабличнаяЧасть.Параметры.ЕдиницаИзмерения = стр.ЕдиницаИзмерения;
				ОбластьТабличнаяЧасть.Параметры.ПроцентСкидки = стр.ПроцентСкидкиНаценки;
				//ОбластьТабличнаяЧасть.Параметры.Цена = стр.Цена;
				ОбластьТабличнаяЧасть.Параметры.СтавкаНДС  = стр.СуммаНДС;
				ОбластьТабличнаяЧасть.Параметры.СуммаВсего = стр.Всего;
								

				Если не  СсылкаНаОбъект.СуммаВключаетНДС Тогда
					ОбластьТабличнаяЧасть.Параметры.Цена = стр.Цена;
					ОбластьТабличнаяЧасть.Параметры.Сумма = стр.Цена*стр.Количество-стр.Цена*стр.Количество*стр.ПроцентСкидки/100;
					ОбластьТабличнаяЧасть.Параметры.СкидкаСумма = стр.Цена*стр.Количество*стр.ПроцентСкидкиНаценки/100;
					
				Иначе
					ОбластьТабличнаяЧасть.Параметры.Цена = стр.Цена*100/(100+СтавкаНДС);
					ОбластьТабличнаяЧасть.Параметры.Сумма = стр.Цена*100/(100+СтавкаНДС)*стр.Количество;
					ОбластьТабличнаяЧасть.Параметры.СкидкаСумма = стр.Цена*100/(100+СтавкаНДС)*стр.Количество*стр.ПроцентСкидкиНаценки/100;
	
				КонецЕсли;


		//ТабличныйДокумент.Вывести(ОбластьТабличнаяЧасть);
				КонецЕсли;
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьТабличнаяЧасть);
			
			КолЗапасов = КолЗапасов - 1;
		КонецЦикла;
		
		//ТабличныйДокумент.Вывести(ОбластьПодвал);
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, СсылкаНаОбъект);
		
		
		
		
		   ТабличныйДокумент.Вывести(ОбластьПодвал);

	КонецЦикла;	
		Возврат ТабличныйДокумент;
		

	
	КонецФункции
	
Функция ПолучитьСтавкуНДСЧислом(СтавкаНДС)
	
		Возврат СтавкаНДС.Ставка;
		
Конецфункции
