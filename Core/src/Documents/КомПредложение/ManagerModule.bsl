		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 			
			
			Если ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				ОбластьШапки.Параметры.НомерТелефонаОрганизации = ВыборкаДетальныеЗаписи.Представление;
			ИначеЕсли ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
				ОбластьШапки.Параметры.АдрОрганизации = ВыборкаДетальныеЗаписи.Представление;
			ИначеЕсли ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
				ОбластьШапки.Параметры.АдресЭПОрганизации = ВыборкаДетальныеЗаписи.Представление
				
			КонецЕсли;		
			
		КонецЦикла;
			// ჩავსვათ შერჩევის დამუშავება ВыборкаДетальныеЗаписи		
		Запрос = Новый Запрос;
		Запрос.Текст =  "ВЫБРАТЬ
		                |	КонтрагентыКонтактнаяИнформация.Тип КАК Тип,
		                |	КонтрагентыКонтактнаяИнформация.Вид КАК Вид,
		                |	КонтрагентыКонтактнаяИнформация.Представление КАК Представление
		                |ИЗ
		                |	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		                |ГДЕ
		                |	КонтрагентыКонтактнаяИнформация.Ссылка = &СсылкаКонтрагента";
		
		Запрос.УстановитьПараметр("СсылкаКонтрагента", СсылкаНаОбъект.Контрагент);
		Результат = Запрос.Выполнить();
		Выборка =Результат.Выбрать();
		
		Пока Выборка.Следующий() Цикл 			
			
			Если Выборка.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				ОбластьШапки.Параметры.НомерТелефонаКонтрагента = Выборка.Представление;
			ИначеЕсли Выборка.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
				ОбластьШапки.Параметры.ПредставлениеКонтрагента = Выборка.Представление;
			ИначеЕсли Выборка.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
				ОбластьШапки.Параметры.АдресЭПКонтрагента = Выборка.Представление
				
			КонецЕсли;		
			
		КонецЦикла;	
		
		
		
		Запрос = Новый Запрос;
		Запрос.Текст =  "ВЫБРАТЬ
		                |	ПользователиКонтактнаяИнформация.Тип КАК Тип,
		                |	ПользователиКонтактнаяИнформация.Вид КАК Вид,
		                |	ПользователиКонтактнаяИнформация.Представление КАК Представление
		                |ИЗ
		                |	Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
		                |ГДЕ
		                |	ПользователиКонтактнаяИнформация.Ссылка.Ссылка = &СсылкаПользовател";
		
		Запрос.УстановитьПараметр("СсылкаПользовател", СсылкаНаОбъект.Ответственный);
		РезультатОт = Запрос.Выполнить();
		ВыборкаОт =РезультатОт.Выбрать();
		
		Пока ВыборкаОт.Следующий() Цикл 			
			
			Если ВыборкаОт.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				ОбластьПодвал.Параметры.НомерТелефонаОтветственный = ВыборкаОт.Представление;
			//ИначеЕсли Выборка.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
			//	ОбластьШапки.Параметры.ПредставлениеКонтрагента = Выборка.Представление;
			//ИначеЕсли Выборка.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
			//	ОбластьШапки.Параметры.АдресЭПКонтрагента = Выборка.Представление
			//	
			КонецЕсли;		
			
		КонецЦикла;	

		
		
		
		
		Если ЗначениеЗаполнено(СсылкаНаОбъект.Организация.ФайлЛоготип) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(СсылкаНаОбъект.Организация.ФайлЛоготип);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка 
					Если ВыводитьХарактеристики Тогда
						 ОбластьШапки.Рисунки.ЛогоХ.Картинка  = Новый Картинка(ДанныеКартинки);
					Иначе
						ОбластьШапки.Рисунки.Лого.Картинка = Новый Картинка(ДанныеКартинки);
					КонецЕсли;
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;

		
		ТабличныйДокумент.Вывести(ОбластьШапки);

		
		
		МассивСтрок = Новый Массив; 
		МассивСтрок.Очистить();		
		МассивСтрок.Добавить(ОбластьПодвал);
		//МассивСтрок.Добавить(ОбластьПустаяСтрока);
		//МассивСтрок.Добавить(ОбластьПустаяСтрока);
		//МассивСтрок.Добавить(ОбластьПустаяСтрока);

		
		 КолЗапасов = СсылкаНаОбъект.ТаблицаПредложений.Количество();

		
		 Для Каждого стр из СсылкаНаОбъект.ТаблицаПредложений Цикл
			 Если ТабличныйДокумент.ПроверитьВывод(МассивСтрок) Тогда
				СтавкаНДС = ПолучитьСтавкуНДСЧислом(стр.СтавкаНДС);
				ОбластьТабличнаяЧасть.Параметры.Номенклатура = стр.Номенклатура;
				ОбластьТабличнаяЧасть.Параметры.Количество = стр.Количество;
				ОбластьТабличнаяЧасть.Параметры.ЕдиницаИзмерения = стр.ЕдиницаИзмерения;
				ОбластьТабличнаяЧасть.Параметры.ПроцентСкидки = стр.ПроцентСкидкиНаценки;
