		ВыводитьХарактеристики = ЗначениеЗаполнено(стр.Характеристика);
		
		Если ВыводитьХарактеристики Тогда
			ОбластьШапки = МакетПечатнойФормы.ПолучитьОбласть("ШапкаХарактеристики");
			ОбластьТабличнаяЧасть = МакетПечатнойФормы.ПолучитьОбласть("ТабличаяЧастьХарактеристики");
		Иначе	
			ОбластьШапки = МакетПечатнойФормы.ПолучитьОбласть("Шапка");
			ОбластьТабличнаяЧасть = МакетПечатнойФормы.ПолучитьОбласть("ТабличаяЧасть");
		КонецЕсли;
		КонецЦИкла;
		ОбластьПодвал= МакетПечатнойФормы.ПолучитьОбласть("Подвал");
	
		//ОбластьШапки.Параметры.Заполнить(ВыборкаДокумент);
		//Попытка
		//	ОбластьШапки.Параметры.Дата	= Формат(ВыборкаДокумент.Дата , "ДФ=dd.MM.yyyy");
		//Исключение
		//КонецПопытки;
		

			
			ОбластьШапки.Параметры.Номер = СсылкаНаОбъект.Номер;
			ОбластьШапки.Параметры.Контрагент = СсылкаНаОбъект.Контрагент;
			ОбластьШапки.Параметры.ИНН = СсылкаНаОбъект.Контрагент.ИНН;
			ОбластьШапки.Параметры.Организация = СсылкаНаОбъект.Организация;
			ОбластьШапки.Параметры.ОрганизацияИНН = СсылкаНаОбъект.Организация.ИНН;
			ОбластьШапки.Параметры.ОрганизацияБанковскийСчетПоУмолчаниюБанк =  СсылкаНаОбъект.Организация.БанковскийСчетПоУмолчанию.Банк;
			ОбластьШапки.Параметры.ОрганизацияБанковскийСчетПоУмолчаниюБанкСВИФТБИК =  СсылкаНаОбъект.Организация.БанковскийСчетПоУмолчанию.Банк.СВИФТБИК;
			ОбластьШапки.Параметры.ОрганизацияБанковскийСчетПоУмолчаниюНомерСчета = СсылкаНаОбъект.Организация.БанковскийСчетПоУмолчанию.НомерСчета;
			
			ОбластьПодвал.Параметры.Дата = Формат(СсылкаНаОбъект.Дата, "ДЛФ=Д");
			ОбластьПодвал.Параметры.Ответственный = СсылкаНаОбъект.Ответственный;
			//Если ЗначениеЗаполнено(КонтактнаяИнформацияКонтрагента.ФактическийАдрес) Тогда
			//	ОбластьШапки.Параметры.АдрКонтрагента = КонтактнаяИнформацияКонтрагента.ФактическийАдрес;
			//КонецЕсли;
			
			
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ОрганизацииКонтактнаяИнформация.Представление КАК Представление,
			|	ОрганизацииКонтактнаяИнформация.Тип,
			|	ОрганизацииКонтактнаяИнформация.Вид
