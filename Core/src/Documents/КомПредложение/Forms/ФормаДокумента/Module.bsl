	ЦеныИВалюта = СформироватьНадписьЦеныИВалюта(СтруктураНадписи);
	
	ИменаТЧ = Новый Массив;
	ИменаТЧ.Добавить(Новый Структура("ИмяПоляПроверки, ИмяПоляОформления", "Объект.ТаблицаПредложений.СтранаПроисхождения", "ТаблицаПредложенийНомерГТД"));
	
	ГрузовыеТаможенныеДекларацииСервер.ПриСозданииНаСервере(ЭтаФорма, ИменаТЧ, КэшЗначений);
		//ПодборНоменклатурыВДокументах.НазначитьФормуПодбора(ПараметрыОткрытияПодбора, Объект.Ссылка.Метаданные().Имя, "ТаблицаПредложений");
	
		
	УстановитьВидимостьИДоступность();
	Если Не ЗначениеЗаполнено(Объект.Контрагент) тогда
		Объект.Действующий = ТекущаяДата();
	КонецЕсли;
