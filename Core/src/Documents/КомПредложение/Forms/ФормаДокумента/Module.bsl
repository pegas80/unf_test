&НаКлиенте
Процедура РасчитатьТабличнойЧасти(Элемент)//////////////////////////////////
	
	ТекущиеДанные = Элементы.ТаблицаПредложений.ТекущиеДанные;
	Для Каждого ТекущиеДанные Из Объект.ТаблицаПредложений Цикл
	Если Не ЗначениеЗаполнено(ТекущиеДанные.Количество) Тогда
		     ТекущиеДанные.Количество =1;

	КонецЕсли ;
	ТекущиеДанные.Артикул =	ПолучитьАртикулНоменклатуры(ТекущиеДанные.Номенклатура);
	ТекущиеДанные.ЕдиницаИзмерения = ПолучитьЕдиницаИзмеренияНоменклатуры(ТекущиеДанные.Номенклатура);
	ТекущиеДанные.Описание = ПолучитьОписаниеНоменклатуры(ТекущиеДанные.Номенклатура);
	
	Если Не Объект.ЦенаВклюЧаетНалоги Тогда
		Если ТекущиеДанные.ПроцентСкидки <> 0 Тогда
				ТекущиеДанные.ЦенаСкидком = ТекущиеДанные.Цена * (1-ТекущиеДанные.ПроцентСкидки/100);
			иначе 
				ТекущиеДанные.ЦенаСкидком = ТекущиеДанные.Цена;
		КонецЕсли;

		ТекущиеДанные.Сумма = ТекущиеДанные.ЦенаСкидком*ТекущиеДанные.Количество;
		ТекущиеДанные.СуммаНДС = ТекущиеДанные.Сумма * ПолучитьСтавкуНДСЧислом(ТекущиеДанные.СтавкаНДС)/100; 
		ТекущиеДанные.СуммаБезНДС = ТекущиеДанные.СуммаНДС + ТекущиеДанные.Сумма;	
	Иначе
		Цена=окр(ТекущиеДанные.Цена/(1+ ПолучитьСтавкуНДСЧислом(ТекущиеДанные.СтавкаНДС)/100),5);
		Если ТекущиеДанные.ПроцентСкидки <> 0 Тогда
		
				ТекущиеДанные.ЦенаСкидком = Цена *(1-ТекущиеДанные.ПроцентСкидки/100);
				ТекущиеДанные.Сумма = ТекущиеДанные.ЦенаСкидком*ТекущиеДанные.Количество;
				ТекущиеДанные.СуммаНДС = ТекущиеДанные.Сумма * ПолучитьСтавкуНДСЧислом(ТекущиеДанные.СтавкаНДС)/100;
				ТекущиеДанные.СуммаБезНДС = ТекущиеДанные.Сумма+ТекущиеДанные.СуммаНДС;
		Иначе 
				ТекущиеДанные.ЦенаСкидком = Цена;
				ТекущиеДанные.Сумма = Цена*ТекущиеДанные.Количество;
				ТекущиеДанные.СуммаНДС = ТекущиеДанные.Сумма * ПолучитьСтавкуНДСЧислом(ТекущиеДанные.СтавкаНДС)/100;
				ТекущиеДанные.СуммаБезНДС = ТекущиеДанные.Цена*ТекущиеДанные.Количество;
		КонецЕсли;
	
		КонецЕсли;	
	
	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтавкуНДСЧислом(СтавкаНДС)///////////////////////
	
		Возврат СтавкаНДС.Ставка;
		
Конецфункции

&НаСервере
Функция  ПолучитьСтавкуНДСНоменклатуры (Организация,Номенклатура)///////////////////////
	Если Константы.ФункциональнаяОпцияИспользоватьИсториюНалогообложенияОрганизации.Получить()=Истина Тогда
		Возврат Организация.СтавкаНДСПоУмолчанию;
	Иначе
		Возврат Номенклатура.СтавкаНДС;
	КонецЕсли;      
КонецФункции

