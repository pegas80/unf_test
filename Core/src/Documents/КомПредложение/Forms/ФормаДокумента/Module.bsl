	Объект.ВидЦен =  Объект.Договор.ВидЦен;
	Объект.Подразделение = ПолучитьПодразделение(Объект.Ответственный);
	Объект.ВалютаДокумента = Объект.Договор.ВалютаРасчетов;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПодразделение(Ответственный)
				
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	НастройкиПользователей.Значение КАК Значение
		|ИЗ
		|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
		|ГДЕ
		|	НастройкиПользователей.Пользователь = &Пользователь
		|	И НастройкиПользователей.Настройка = &Настройка";
	
	Запрос.УстановитьПараметр("Настройка", ПланыВидовХарактеристик.НастройкиПользователей.ОсновноеПодразделение);
	Запрос.УстановитьПараметр("Пользователь",Объект.Ответственный);
		
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Значение;
	
КонецФункции


