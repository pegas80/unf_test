#Область ОбработчикиСобытийЭлементовТаблицыФормыДополнительныеЗатраты

&НаКлиенте
Процедура РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти = Неопределено) Экспорт 
	
	Если СтрокаТабличнойЧасти = Неопределено Тогда
		СтрокаТабличнойЧасти = Элементы.ДополнительныеРасходы.ТекущиеДанные;
	КонецЕсли;
	
	Если УчитыватьДополнительныеЗатратыВПроизводстве Тогда 
		
		СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
		
		РассчитатьСуммуНДС(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
		СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + СтрокаТабличнойЧасти.СуммаНДС;
		
	КонецЕсли;
	
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
	
	УИД_Строки = СтрокаТабличнойЧасти.ПолучитьИдентификатор();
	СтуктураЗаполнения = ПолучитьСтавкиНаСервере(УИД_Строки); 
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидУдержанияНДФЛ) Тогда 
		СтрокаТабличнойЧасти.СуммаНДФЛ = СтуктураЗаполнения.СуммаНДФЛ;  
	Иначе
		СтрокаТабличнойЧасти.СуммаНДФЛ = 0;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидУдержанияПФ) Тогда
		СтрокаТабличнойЧасти.СуммаПФ = СтуктураЗаполнения.СуммаПФ;
	Иначе
		СтрокаТабличнойЧасти.СуммаПФ = 0;
	КонецЕсли;
	
	СтрокаТабличнойЧасти.СуммаНДС = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.СуммаПФ - СтрокаТабличнойЧасти.СуммаНДФЛ)-(СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.СуммаПФ - СтрокаТабличнойЧасти.СуммаНДФЛ)/(1 + (СтавкаНДС/100));
	СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена + СтрокаТабличнойЧасти.СуммаНДФЛ + СтрокаТабличнойЧасти.СуммаПФ;
	СтрокаТабличнойЧасти.СуммаБезНалогов = СтрокаТабличнойЧасти.Всего - СтрокаТабличнойЧасти.СуммаНДФЛ - СтрокаТабличнойЧасти.СуммаПФ - СтрокаТабличнойЧасти.СуммаНДС;
	
КонецПроцедуры // РассчитатьСуммуВСтрокеТабличнойЧасти()

&НаСервере
Процедура РассчитатьСуммуНДС(ИдентификаторСтроки)
	
	СтрокаТабличнойЧасти = Объект.ДополнительныеРасходы.НайтиПоИдентификатору(ИдентификаторСтроки);
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
	
	
	СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
	
	СтрокаТабличнойЧасти.СуммаНДФЛ = 0;
	СтрокаТабличнойЧасти.СуммаПФ = 0;
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидУдержанияНДФЛ) 
		И СтрокаТабличнойЧасти.ВидУдержанияНДФЛ.СтавкаНДФЛ > 0 Тогда
	
		СтрокаТабличнойЧасти.СуммаНДФЛ = СтрокаТабличнойЧасти.Сумма * СтрокаТабличнойЧасти.ВидУдержанияНДФЛ.СтавкаНДФЛ / 100; 				
	
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ВидУдержанияПФ) И СтрокаТабличнойЧасти.ВидУдержанияПФ.СтавкаПФ > 0 Тогда
	
		СтрокаТабличнойЧасти.СуммаПФ = СтрокаТабличнойЧасти.Сумма * СтрокаТабличнойЧасти.ВидУдержанияПФ.СтавкаПФ / 100; 				
	
	
	КонецЕсли;      
	
	СтрокаТабличнойЧасти.СуммаНДС = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.СуммаПФ - СтрокаТабличнойЧасти.СуммаНДФЛ)-(СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.СуммаПФ - СтрокаТабличнойЧасти.СуммаНДФЛ)/(1 + (СтавкаНДС/100));
	СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена + СтрокаТабличнойЧасти.СуммаНДФЛ + СтрокаТабличнойЧасти.СуммаПФ;
	СтрокаТабличнойЧасти.СуммаБезНалогов = СтрокаТабличнойЧасти.Всего - СтрокаТабличнойЧасти.СуммаНДФЛ - СтрокаТабличнойЧасти.СуммаПФ - СтрокаТабличнойЧасти.СуммаНДС;
	
КонецПроцедуры // РассчитатьСуммуНДС()

&НаКлиенте
Процедура ДополнительныеРасходыЦенаПриИзменении(Элемент)
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеРасходыСуммаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ДополнительныеРасходы.ТекущиеДанные;
	СтрокаТабличнойЧасти.Цена = СтрокаТабличнойЧасти.Сумма / СтрокаТабличнойЧасти.Количество;
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеРасходыНоменклатураПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ДополнительныеРасходы.ТекущиеДанные;
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
	//СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
	//СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
	//СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	//СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС;
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеРасходыСтавкаНДСПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ДополнительныеРасходы.ТекущиеДанные;
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеРасходыВидУдержанияНДФЛПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ДополнительныеРасходы.ТекущиеДанные;
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительныеРасходыВидУдержанияПФПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.ДополнительныеРасходы.ТекущиеДанные;
	РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);	
	
КонецПроцедуры

//+++ Дмгг, ONESOFT-2638
&НаКлиенте
Процедура ДополнительныеРасходыКонтрагентПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ДополнительныеРасходы.ТекущиеДанные; 
	УИД_Строки = ТекущаяСтрока.ПолучитьИдентификатор();
	
	Если ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда 
		СтруктураДанные = ПолучитьДанныеКонтрагентПриИзменении(Объект.Дата, ТекущаяСтрока.Контрагент, Объект.Организация);
		
		ТекущаяСтрока.Договор = СтруктураДанные.Договор;
		ТекущаяСтрока.СтавкаНДС = СтруктураДанные.СтавкаНДС;  
		
		ТекущаяСтрока.ВидУдержанияНДФЛ = УправлениеНебольшойФирмойСервер.ЗначениеРеквизитаОбъекта(ТекущаяСтрока.Договор, "ВидУдержанияНДФЛ");
		ТекущаяСтрока.ВидУдержанияПФ = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВидУдержанияПФ(Объект.Дата, ТекущаяСтрока.Контрагент, ТекущаяСтрока.Договор);
		
		СтуктураЗаполнения = ПолучитьСтавкиНаСервере(УИД_Строки);
		ТекущаяСтрока.СуммаНДФЛ = СтуктураЗаполнения.СуммаНДФЛ;
		ТекущаяСтрока.СуммаПФ = СтуктураЗаполнения.СуммаПФ;   
		
	ИначеЕсли ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Сотрудники") Тогда  
		
		ТекущаяСтрока.СтавкаНДС = ПредопределенноеЗначение("Справочник.СтавкиНДС.БезНДС");  
		
		СтруктураСтрудника = ПолучитьСтруктуруСотрудникаНаСервере(УИД_Строки);
		
		ТекущаяСтрока.Валюта 			= Объект.ВалютаДокумента;
		ТекущаяСтрока.ВидУдержанияНДФЛ	= СтруктураСтрудника.ВидУдержанияНДФЛ;
		ТекущаяСтрока.ВидУдержанияПФ	= СтруктураСтрудника.ВидУдержанияПФ; 
		ТекущаяСтрока.Подразделение		= СтруктураСтрудника.Подразделение;
		
		СтуктураЗаполнения = ПолучитьСтавкиНаСервере(УИД_Строки);
		ТекущаяСтрока.СуммаНДФЛ = СтуктураЗаполнения.СуммаНДФЛ;
		ТекущаяСтрока.СуммаПФ = СтуктураЗаполнения.СуммаПФ;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере 
Функция ПолучитьСтруктуруСотрудникаНаСервере(УИД_Строки)
	
	ТекущаяСтрока = Объект.ДополнительныеРасходы.НайтиПоИдентификатору(УИД_Строки);
	
	СтруктураВозврта = Новый Структура("ВидУдержанияНДФЛ, ВидУдержанияПФ, Подразделение");     
	
	тзСтавки = РегистрыСведений.Сотрудники.СрезПоследних(ДатаДокумента, Новый Структура("Сотрудник, Организация", ТекущаяСтрока.Контрагент, Объект.Организация));
	Если тзСтавки.Количество() <> 0 Тогда       
		СтруктураВозврта.ВидУдержанияНДФЛ = тзСтавки[0].ВидУдержанияНДФЛ;
		СтруктураВозврта.ВидУдержанияПФ = тзСтавки[0].ВидУдержанияПФ; 
		СтруктураВозврта.Подразделение = тзСтавки[0].СтруктурнаяЕдиница;
	КонецЕсли;
	
	Возврат СтруктураВозврта;
	
КонецФункции    

&НаСервере
Функция ПолучитьДанныеКонтрагентПриИзменении(Дата, Контрагент, Организация)
	
	ДоговорПоУмолчанию = ПолучитьДоговорПоУмолчанию(Объект.Ссылка, Контрагент, Организация, Объект.ВидОперации);
	
	СтруктураДанные = Новый Структура;
	
	СтруктураДанные.Вставить(
		"КонтактноеЛицоПодписант",
		Контрагент.КонтактноеЛицоПодписант
	);
	
	СтруктураДанные.Вставить(
		"Договор",
		ДоговорПоУмолчанию
	);
		
	СтруктураДанные.Вставить(
		"ВалютаРасчетов",
		ДоговорПоУмолчанию.ВалютаРасчетов
	);
	
	СтруктураДанные.Вставить(
		"ВалютаРасчетовКурсКратность",
		РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата, Новый Структура("Валюта", ДоговорПоУмолчанию.ВалютаРасчетов))
	);
	
	СтруктураДанные.Вставить(
		"ВидЦенКонтрагента",
		ДоговорПоУмолчанию.ВидЦенКонтрагента
	);
	
	СтруктураДанные.Вставить(
		"РасчетыВУсловныхЕдиницах",
		ДоговорПоУмолчанию.РасчетыВУсловныхЕдиницах
	);
	
	СтруктураДанные.Вставить(
		"СуммаВключаетНДС",
		?(ЗначениеЗаполнено(ДоговорПоУмолчанию.ВидЦенКонтрагента), ДоговорПоУмолчанию.ВидЦенКонтрагента.ЦенаВключаетНДС, Неопределено)
	);
	
	СтруктураДанные.Вставить(
		"УчетЦенКонтрагентов",
		ПолучитьФункциональнуюОпцию("УчетЦенКонтрагентов")
	);
	
	СтруктураДанные.Вставить(
		"ВидЦен",
		ДоговорПоУмолчанию.ВидЦен);
		
	Если ТипЗнч(Контрагент) = Тип("СправочникСсылка.Контрагенты") И Контрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда 
		
		СтруктураДанные.Вставить(
			"СтавкаНДС",
			Справочники.СтавкиНДС.НДС18
		); 
		
	Иначе
		
		СтруктураДанные.Вставить(
			"СтавкаНДС",
			Справочники.СтавкиНДС.БезНДС
		); 
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДоговорПоУмолчанию) Тогда 
		СтруктураДанные.Вставить("ПроектИзДоговора", ДоговорПоУмолчанию.Проект);
	Иначе
		СтруктураДанные.Вставить("ПроектИзДоговора", Справочники.Проекты.ПустаяСсылка());
	КонецЕсли;
	
	Возврат СтруктураДанные;
	
КонецФункции // ПолучитьДанныеКонтрагентПриИзменении()

&НаСервереБезКонтекста
Функция ПолучитьДоговорПоУмолчанию(Документ, Контрагент, Организация, ВидОперации)
	
	Если Не Контрагент.ВестиРасчетыПоДоговорам Тогда
		Возврат Контрагент.ДоговорПоУмолчанию;
	КонецЕсли;
	
	МенеджерСправочника = Справочники.ДоговорыКонтрагентов;
	
	СписокВидовДоговоров = МенеджерСправочника.ПолучитьСписокВидовДоговораДляДокумента(Документ, ВидОперации);
	ДоговорПоУмолчанию = МенеджерСправочника.ПолучитьДоговорПоУмолчаниюПоОрганизацииВидуДоговора(Контрагент, Организация, СписокВидовДоговоров);
	// Kuzmich, 19.08.2019, Использовать виды договоров, Доработка
	Если ЗначениеЗаполнено(ДоговорПоУмолчанию) И Константы.ИспользоватьВидыДоговоров.Получить() Тогда
		Если НЕ ДоговорПоУмолчанию.Поставщик Тогда
			ДоговорПоУмолчанию = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	// Kuzmich, 19.08.2019, Использовать виды договоров, Доработка
	
	Возврат ДоговорПоУмолчанию;
	
КонецФункции

&НаСервере
Функция ПолучитьСтавкиНаСервере(УИД_Строки)
	
	ТекущаяСтрока = Объект.ДополнительныеРасходы.НайтиПоИдентификатору(УИД_Строки);
	
	СуммаРасчетов = ТекущаяСтрока.Сумма;
	СтруктураВозврата = Новый Структура;          
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) Тогда 
		СтруктураВозврата.Вставить("СуммаНДФЛ",0);
		СтруктураВозврата.Вставить("СуммаПФ", 0); 
		СтруктураВозврата.Вставить("СтавкаНДС", 0);
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И  ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда     
		
		СтавкаПФ = 0;
		тзСтавкиПФ = РегистрыСведений.УдержанияДляПенсионногоФонда.СрезПоследних(ДатаДокумента, Новый Структура("Контрагент, Договор", ТекущаяСтрока.Контрагент, ТекущаяСтрока.Договор));
		Если тзСтавкиПФ.Количество() <> 0 Тогда 
			СтавкаПФ = тзСтавкиПФ[0].ВидУдержания.СтавкаПФ;
		КонецЕсли;
		
		СтавкаНДС = 0;
		Если НЕ ТекущаяСтрока.Контрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
			
			Если ТекущаяСтрока.Контрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
				СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
			Иначе
				СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
			КонецЕсли;
			
		Иначе
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
		КонецЕсли;  
		
		Если Объект.СуммаВключаетНДС Тогда      
			
			Если ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И  ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда   
				Ставки = РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(0, ТекущаяСтрока.Договор.ВидУдержанияНДФЛ);
				СтавкаНДФЛ = Ставки.СтавкаНДФЛ;  
			КонецЕсли;
			СуммаБезНалогов = СуммаРасчетов;
			СуммаНДФЛ		= Окр(СуммаРасчетов/((100-СтавкаНДФЛ)/100)*(СтавкаНДФЛ/100), 2);
			СуммаПФ			= Окр(((СуммаРасчетов+СуммаНДФЛ)/((100-СтавкаПФ)/100))*(СтавкаПФ/100), 2);
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаПФ;
			
			СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
			СтруктураВозврата.Вставить("СуммаПФ", СуммаПФ);  
			СтруктураВозврата.Вставить("СтавкаНДС", СтавкаНДС);
			
		Иначе

			Если ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И  ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда  
				Ставки = РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(0, ТекущаяСтрока.Договор.ВидУдержанияНДФЛ);
				СтавкаНДФЛ = Ставки.СтавкаНДФЛ;  
			КонецЕсли;
			СуммаБезНалогов = СуммаРасчетов;
			СуммаНДС		= Окр(СуммаРасчетов - СуммаРасчетов*((100-СтавкаНДС)/100), 2);
			СуммаНДФЛ		= Окр((СуммаРасчетов + СуммаНДС)/((100-СтавкаНДФЛ)/100)*(СтавкаНДФЛ/100), 2);
			СуммаПФ			= Окр(((СуммаРасчетов + СуммаНДС + СуммаНДФЛ)/((100-СтавкаПФ)/100)) * (СтавкаПФ / 100), 2);
			
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
			
			СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
			СтруктураВозврата.Вставить("СуммаПФ", СуммаПФ);
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Сотрудники") Тогда 
		
		СтавкаПФ = 0;
		СтавкаНДФЛ = 0;
		
		тзСтавки = РегистрыСведений.Сотрудники.СрезПоследних(ДатаДокумента, Новый Структура("Сотрудник, Организация", ТекущаяСтрока.Контрагент, Объект.Организация));
		Если тзСтавки.Количество() <> 0 Тогда 
			
			СтавкаПФ = ?(ЗначениеЗаполнено(ТекущаяСтрока.ВидУдержанияПФ), ТекущаяСтрока.ВидУдержанияПФ.СтавкаПФ, тзСтавки[0].ВидУдержанияПФ.СтавкаПФ); 
			СтавкаНДФЛ = ?(ЗначениеЗаполнено(ТекущаяСтрока.ВидУдержанияНДФЛ), ТекущаяСтрока.ВидУдержанияНДФЛ.СтавкаНДФЛ, тзСтавки[0].ВидУдержанияНДФЛ.СтавкаНДФЛ);
			
		Иначе
			
			СтавкаПФ = ?(ЗначениеЗаполнено(ТекущаяСтрока.ВидУдержанияПФ), ТекущаяСтрока.ВидУдержанияПФ.СтавкаПФ, 0);
			СтавкаНДФЛ = ?(ЗначениеЗаполнено(ТекущаяСтрока.ВидУдержанияНДФЛ), ТекущаяСтрока.ВидУдержанияНДФЛ.СтавкаНДФЛ, 0);
			
		КонецЕсли;   
		
		СтавкаНДС = Объект.Организация.СтавкаНДСПоУмолчанию; 
		
		СуммаБезНалогов = СуммаРасчетов;
		СуммаНДФЛ		= Окр(СуммаРасчетов/((100-СтавкаНДФЛ)/100)*(СтавкаНДФЛ/100), 2);
		СуммаПФ			= Окр(((СуммаРасчетов+СуммаНДФЛ)/((100-СтавкаПФ)/100))*(СтавкаПФ/100), 2);
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаПФ;
		
		СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
		СтруктураВозврата.Вставить("СуммаПФ", СуммаПФ);  
		СтруктураВозврата.Вставить("СтавкаНДС", СтавкаНДС);
		
	Иначе   
		
		СтруктураВозврата.Вставить("СуммаНДФЛ",0);
		СтруктураВозврата.Вставить("СуммаПФ", 0);  
		СтруктураВозврата.Вставить("СтавкаНДС", СтавкаНДС); 
		
	КонецЕсли;
	
	//Если ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") И ТекущаяСтрока.Договор.УчитыватьНДФЛ Тогда          
	//	
	//	Если Объект.СуммаВключаетНДС Тогда      
	//		
	//		Если ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И  ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда   
	//			Ставки = РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(0, ТекущаяСтрока.Договор.ВидУдержанияНДФЛ);
	//			СтавкаНДФЛ = Ставки.СтавкаНДФЛ;  
	//		КонецЕсли;
	//		СуммаБезНалогов = СуммаРасчетов;
	//		СуммаНДФЛ		= Окр(СуммаРасчетов/((100-СтавкаНДФЛ)/100)*(СтавкаНДФЛ/100), 2);
	//		СуммаПФ			= Окр(((СуммаРасчетов+СуммаНДФЛ)/((100-СтавкаПФ)/100))*(СтавкаПФ/100), 2);
	//		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаПФ;
	//		
	//		СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
	//		СтруктураВозврата.Вставить("СуммаПФ", СуммаПФ);  
	//		СтруктураВозврата.Вставить("СтавкаНДС", СтавкаНДС);
	//		
	//	Иначе

	//		Если ЗначениеЗаполнено(ТекущаяСтрока.Контрагент) И  ТипЗнч(ТекущаяСтрока.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда  
	//			Ставки = РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(0, ТекущаяСтрока.Договор.ВидУдержанияНДФЛ);
	//			СтавкаНДФЛ = Ставки.СтавкаНДФЛ;  
	//		КонецЕсли;
	//		СуммаБезНалогов = СуммаРасчетов;
	//		СуммаНДС		= Окр(СуммаРасчетов - СуммаРасчетов*((100-СтавкаНДС)/100), 2);
	//		СуммаНДФЛ		= Окр((СуммаРасчетов + СуммаНДС)/((100-СтавкаНДФЛ)/100)*(СтавкаНДФЛ/100), 2);
	//		СуммаПФ			= Окр(((СуммаРасчетов + СуммаНДС + СуммаНДФЛ)/((100-СтавкаПФ)/100)) * (СтавкаПФ / 100), 2);
	//		
	//		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
