	Если Объект.Запасы.Количество() <> 0 Тогда
		
		Ответ = Неопределено;
		
		ПоказатьВопрос(Новый ОписаниеОповещения("КомандаЗаполнитьПоСпецификацииЗавершение", ЭтотОбъект), НСтр("ka='ცხრილი ""მასალები"" გადაივსება! გავაგრძელოთ ოპერაციის შესრულება?';ru='Табличная часть ""Материалы"" будет перезаполнена! Продолжить выполнение операции?';en='A table of the ""Materials"" will be refilled! To continue the operation?'"), 
		РежимДиалогаВопрос.ДаНет, 0);
		Возврат;
		
	КонецЕсли;
	
	КомандаЗаполнитьПоСпецификацииФрагмент();
