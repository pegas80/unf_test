&НаСервере
Функция ПоместитьПредоплатаВХранилище()
	
	Возврат ПоместитьВоВременноеХранилище(
		Объект.Запасы.Выгрузить(,
			"НомерСтроки,
			|Номенклатура,
			|Характеристика,
			|Партия,
			|Количество,
			|ЕдиницаИзмерения"),
