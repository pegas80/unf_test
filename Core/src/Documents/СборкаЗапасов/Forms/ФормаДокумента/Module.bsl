&НаКлиенте
Процедура ПеремещениеЗапасы(Команда)
	// Kuzmich, 16.12.2019
	Если Объект.Ссылка.Пустая() ИЛИ ЭтаФорма.Модифицированность Тогда
		Контекст = НЕОПРЕДЕЛЕНО;
		
		ТекстВопроса = НСтр("ka='მონაცემები ჯერ არ არის ჩაწერილი. მოქმედება შესრულება შესაძლებელია მხოლოდ მონაცემთა ჩაწერის შემდეგ. მონაცემები ჩაიწერება.';ru='Данные еще не записаны."
		"Выполнение действия возможно только после записи данных."
		"Данные будут записаны.'");
		
		Обработчик = Новый ОписаниеОповещения("ПродолжитьВыполнениеПеремещениеЗапасы", ЭтотОбъект, Контекст);
		
		ПоказатьВопрос(Обработчик, ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
		
		Возврат;
	КонецЕсли;
	// Kuzmich, 16.12.2019
	МассивВыделеныхСтрок = Элементы.Запасы.ВыделенныеСтроки;
	
	Форма = ПолучитьФорму("Документ.ПеремещениеЗапасов.ФормаОбъекта");
	ДанныеФормы = Форма.Объект; 
	ПеремещениеЗапасыНаСервере(ДанныеФормы, МассивВыделеныхСтрок); 
	КопироватьДанныеФормы(ДанныеФормы, Форма.Объект); 
	Форма.Открыть();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьКнопкиПроизводства()

	ЗначениеВидивости = ПолучитьФункциональнуюОпцию("ФункциональнаяОпцияДополнительныеФункцииПроизводства");
	
	Элементы.ЗапасыПеремещениеЗапасы.Видимость = ЗначениеВидивости;
	Элементы.ПродукцияПеремещениеПродукция.Видимость = ЗначениеВидивости;
	Элементы.ЗапасыЗаполнитьПоОстаткам.Видимость = ЗначениеВидивости;

	Элементы.ПродукцияЗаполнитьПоОстаткамПродукция.Видимость = (ЗначениеВидивости И Объект.ВидОперации = Перечисления.ВидыОперацийСборкаЗапасов.Разборка); // Kuzmich, 18.12.2019
	
