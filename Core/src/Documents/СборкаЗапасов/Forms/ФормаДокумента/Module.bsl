	СтрокаТабличнойЧасти.СрокГодности = ?(СтруктураДанные.КоличествоДни >0,Объект.Дата + СтруктураДанные.КоличествоДни * 86400,Дата(1,1,1));//+Lazare 08.11.2022
	СтрокаТабличнойЧасти.КоличествоНаСкладе = УправлениеНебольшойФирмойСервер.ПолучитьКоличествоЗапасовНаСкладе(Объект.Дата,СтрокаТабличнойЧасти.Номенклатура,СтрокаТабличнойЧасти.Характеристика,СтрокаТабличнойЧасти.Партия,Объект.Организация,Объект.СтруктурнаяЕдиницаЗапасов);//++Lazare 13.12.2022

