		|	Справочник.Спецификации КАК Спецификации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЗ_Номенклатура КАК ТЗ_Номенклатура
		|		ПО Спецификации.Владелец = ТЗ_Номенклатура.Номенклатура
		|ГДЕ
		|	НЕ Спецификации.ПометкаУдаления
		|	И Спецификации.ДатаСоздания <= &ДатаСоздания
		|
		|СГРУППИРОВАТЬ ПО
		|	ТЗ_Номенклатура.Номенклатура,
		|	ТЗ_Номенклатура.НомерСтроки
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Владелец,
		|	ДатаСоздания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Спецификации.Ссылка КАК Спецификация,
		|	СпецификацииОтборПред.НомерСтроки КАК НомерСтроки,
		|	Спецификации.ДатаСоздания КАК ДатаСоздания
		|ИЗ
		|	Справочник.Спецификации КАК Спецификации
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СпецификацииОтборПред КАК СпецификацииОтборПред
		|		ПО Спецификации.ДатаСоздания = СпецификацииОтборПред.ДатаСоздания
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
	
	Запрос.УстановитьПараметр("ТЗ_Номенклатура", ТЗ_Номенклатура);
	Запрос.УстановитьПараметр("ДатаСоздания", ?(ЗначениеЗаполнено(Объект.Дата),Объект.Дата,ТекущаяДатаСеанса()));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ТекущаяСтрока = Объект.Продукция[ВыборкаДетальныеЗаписи.НомерСтроки-1];
		ТекущаяСтрока.Спецификация = ВыборкаДетальныеЗаписи.Спецификация;
		
	КонецЦикла;	
	
КонецПроцедуры
