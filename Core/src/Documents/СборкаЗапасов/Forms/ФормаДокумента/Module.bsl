			//КонецЕсли;
			//// Kuzmich, 16.12.2019
			НоваяСтрока.Резерв = 0;
		КонецЦикла;
		
		РаботаССерийнымиНомерами.ЗаполнитьТЧСерийныеНомераПоКлючуСвязи(ДокПеремещения, Объект.Ссылка);
		
	КонецЕсли;

