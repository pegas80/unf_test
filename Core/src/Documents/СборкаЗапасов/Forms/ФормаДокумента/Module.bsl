Процедура ПеремещениеПродукцияНаСервере(ДанныеФормы, МассивВыделеныхСтрок)
	
	МассивОставляемыхСтрок = Новый Массив;
	
	Для Каждого ИдентефикаторСТроки Из МассивВыделеныхСтрок Цикл 
		МассивОставляемыхСтрок.Добавить(Объект.Продукция.НайтиПоИдентификатору(ИдентефикаторСТроки));
	КонецЦикла;
	
	тзОставляемыхСтрок = Объект.Продукция.Выгрузить(МассивОставляемыхСтрок);
	
	Док = ДанныеФормыВЗначение(ДанныеФормы, Тип("ДокументОбъект.ПеремещениеЗапасов")); // Получаем объект из данных формы ИЛИ
	
	Док = Документы.ПеремещениеЗапасов.СоздатьДокумент();
	
	ЗаполнитьПоСборкеЗапасовСборка(Док);//Док.Заполнить(Объект.Ссылка);
	
	МассивУдаляемыхСтрок = Новый Массив;
	Для Каждого СтрокПроизводства Из Док.Запасы Цикл 
		
		МассивНайденныхСтрок = тзОставляемыхСтрок.НайтиСтроки(Новый Структура("Номенклатура, Характеристика, Количество, ЕдиницаИзмерения", СтрокПроизводства.Номенклатура, СтрокПроизводства.Характеристика, СтрокПроизводства.Количество, СтрокПроизводства.ЕдиницаИзмерения));
		
		Если МассивНайденныхСтрок.Количество() = 0 Тогда 
			МассивУдаляемыхСтрок.Добавить(СтрокПроизводства);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СтрокУдаления Из МассивУдаляемыхСтрок Цикл 
		
		Док.Запасы.Удалить(СтрокУдаления);
		
	КонецЦикла;
	// Kuzmich, 16.12.2019
	ДанныеФормы.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПеремещениеЗапасов.Перемещение");
	НастройкиПользователейОтбор = Новый Структура("Пользователь,Настройка", Объект.Автор,ПланыВидовХарактеристик.НастройкиПользователей.ОсновнойСклад);
	ДанныеФормы.СтруктурнаяЕдиница = РегистрыСведений.НастройкиПользователей.Получить(НастройкиПользователейОтбор);
	// Kuzmich, 16.12.2019
	ЗначениеВДанныеФормы(Док,ДанныеФормы);
	
КонецПроцедуры

&НаКлиенте
Процедура ПеремещениеПродукция(Команда)
	
	МассивВыделеныхСтрок = Элементы.Продукция.ВыделенныеСтроки;
	
	Форма = ПолучитьФорму("Документ.ПеремещениеЗапасов.ФормаОбъекта");
	ДанныеФормы = Форма.Объект; 
	ПеремещениеПродукцияНаСервере(ДанныеФормы, МассивВыделеныхСтрок); 
	КопироватьДанныеФормы(ДанныеФормы, Форма.Объект); 
	Форма.Открыть();
	
КонецПроцедуры

