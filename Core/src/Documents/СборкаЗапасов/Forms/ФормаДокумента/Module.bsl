	);
	
КонецФункции

&НаКлиенте
Процедура ВариантыПродукцииЗавершение(Результат, ДополнительныеПараметры) Экспорт
    
    АдресВариантовПродукцииВХранилище = ДополнительныеПараметры.АдресВариантовПродукцииВХранилище;
    
    КодВозврата = Результат;
    
    ВариантыПродукцииФрагмент(АдресВариантовПродукцииВХранилище, КодВозврата);

КонецПроцедуры

&НаКлиенте
Процедура ВариантыПродукцииФрагмент(Знач АдресВариантовПродукцииВХранилище, Знач КодВозврата)
    
	КлючКМатериалам = "";
    Если (КодВозврата = КодВозвратаДиалога.OK) Тогда
        ПолучитьВариантыПродукцииИзХранилища(АдресВариантовПродукцииВХранилище, КлючКМатериалам);
	КонецЕсли;
	
	Если КлючКМатериалам <> "" Тогда 
		Режим = РежимДиалогаВопрос.ДаНет;
		Ответ = Вопрос(НСтр("ru = 'Перезаполнить таблицу материалов согласно выбранному варианту продукции?';"
		+ " ka = 'მასალების ცხრილის გადავსება საწარმოებლად შერჩეული პროდუქციის მიხედვით';"
		+ " en = 'Перезаполнить таблицу материалов согласно выбранному варианту продукции?'"), Режим, 0);
		
		Если Ответ = КодВозвратаДиалога.Да Тогда
			ПерезаполнитьМатериалыПоКлючу(КлючКМатериалам);
		КонецЕсли;
		
	КонецЕсли;
	

КонецПроцедуры

&НаСервере
Процедура ПолучитьВариантыПродукцииИзХранилища(АдресВариантовПродукцииВХранилище, КлючКМатериалам)
	
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресВариантовПродукцииВХранилище);
	Объект.Продукция.Загрузить(ТаблицаДляЗагрузки);
	
	Если ТаблицаДляЗагрузки.Количество() > 0 Тогда 
		КлючКМатериалам = ТаблицаДляЗагрузки[0].КлючСвязи;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьМатериалыПоКлючу(КлючКМатериалам)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВариантыПроизводстваМатериалы.Материал КАК Номенклатура,
		|	ВариантыПроизводстваМатериалы.Характеристика КАК Характеристика,
		|	ВариантыПроизводстваМатериалы.Количество КАК Количество,
		|	ВариантыПроизводстваМатериалы.ЕдиницаИзмерений КАК ЕдиницаИзмерения,
		|	1 КАК ДоляСтоимости
		|ИЗ
		|	РегистрСведений.ВариантыПроизводстваМатериалы КАК ВариантыПроизводстваМатериалы
		|ГДЕ
		|	ВариантыПроизводстваМатериалы.КлючСвязи = &КлючСвязи";
	
	Запрос.УстановитьПараметр("КлючСвязи", КлючКМатериалам);
	
	тзМатериалы = Запрос.Выполнить().Выгрузить();
	
	Объект.Запасы.Загрузить(тзМатериалы);	

КонецПроцедуры

