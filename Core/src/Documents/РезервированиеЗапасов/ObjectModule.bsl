		|		ИНАЧЕ ЗаказПокупателяМатериалы.Ссылка.СтруктурнаяЕдиницаРезерв
		|	КОНЕЦ,
		|	ЕСТЬNULL(ТЗОстаткиРезервов.КоличествоОстаток, 0)
		|ИЗ
		|	Документ.ЗаказПокупателя.Материалы КАК ЗаказПокупателяМатериалы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТЗОстаткиРезервов КАК ТЗОстаткиРезервов
		|		ПО ЗаказПокупателяМатериалы.Ссылка = ТЗОстаткиРезервов.Документ
		|			И ЗаказПокупателяМатериалы.Ссылка.Организация = ТЗОстаткиРезервов.Организация
		|			И (ВЫБОР
		|				КОГДА &УчетСебестоимостиВРазрезеОрганизации = ИСТИНА
		|					ТОГДА ЗаказПокупателяМатериалы.Ссылка
		|				ИНАЧЕ ЗаказПокупателяМатериалы.Ссылка.СтруктурнаяЕдиницаРезерв
		|			КОНЕЦ = ТЗОстаткиРезервов.СтруктурнаяЕдиница)
		|			И ЗаказПокупателяМатериалы.Номенклатура = ТЗОстаткиРезервов.Номенклатура
		|			И ЗаказПокупателяМатериалы.Характеристика = ТЗОстаткиРезервов.Характеристика
		|			И ЗаказПокупателяМатериалы.Партия = ТЗОстаткиРезервов.Партия
		|			И (ВЫБОР
		|				КОГДА &УчетПоПроектам
		|					ТОГДА ВЫБОР
		|							КОГДА ЗаказПокупателяМатериалы.Проект ЕСТЬ NULL
		|									ИЛИ ЗаказПокупателяМатериалы.Проект = НЕОПРЕДЕЛЕНО
		|									ИЛИ ЗаказПокупателяМатериалы.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
		|								ТОГДА ВЫБОР
		|										КОГДА ЗаказПокупателяМатериалы.Ссылка.Проект ЕСТЬ NULL
		|												ИЛИ ЗаказПокупателяМатериалы.Ссылка.Проект = НЕОПРЕДЕЛЕНО
		|												ИЛИ ЗаказПокупателяМатериалы.Ссылка.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
		|											ТОГДА ТЗОстаткиРезервов.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
		|										ИНАЧЕ ЗаказПокупателяМатериалы.Ссылка.Проект = ТЗОстаткиРезервов.Проект
		|									КОНЕЦ
		|							ИНАЧЕ ЗаказПокупателяМатериалы.Проект = ТЗОстаткиРезервов.Проект
		|						КОНЕЦ
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)
		|ГДЕ
		|	ЕСТЬNULL(ТЗОстаткиРезервов.КоличествоОстаток, 0) > 0";
	
	Запрос.УстановитьПараметр("ЗаказПокупателя", ДокументСсылкаЗаказПокупателя);
    Запрос.УстановитьПараметр("ТЗОстаткиРезервов", ТЗОстаткиРезервов);
	Запрос.УстановитьПараметр("УчетПоПроектам", ПолучитьФункциональнуюОпцию("УчетПоПроектам"));
	
	УчетСебестоимостиВРазрезеОрганизации = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(Дата, Новый Структура("Организация", Организация)).УчетСебестоимостиВРазрезеОрганизации;
	Запрос.УстановитьПараметр("УчетСебестоимостиВРазрезеОрганизации", УчетСебестоимостиВРазрезеОрганизации = Истина);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Запасы.Загрузить(РезультатЗапроса.Выгрузить());
	
КонецПроцедуры
