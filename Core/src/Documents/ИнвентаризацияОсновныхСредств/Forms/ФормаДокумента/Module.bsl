	СортироватьТаблицуВнеоборотныеАктивы();
КонецПроцедуры

&НаКлиенте
Процедура СортироватьПоКатегориям(Команда)
	СортироватьТаблицуВнеоборотныеАктивы(Истина);
КонецПроцедуры  

&НаСервере
Процедура СортироватьТаблицуВнеоборотныеАктивы(ПоКатегориям = Ложь)
	
	ТаблицаВнеоборотныеАктивы = Объект.ВнеоборотныеАктивы.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ВнеоборотныеАктивы.Подразделение КАК Подразделение,
	|	ВнеоборотныеАктивы.СостояниеВнеоборотногоАктива КАК СостояниеВнеоборотногоАктива,
	|	ВнеоборотныеАктивы.Отклонение КАК Отклонение,
	|	ВнеоборотныеАктивы.Количество КАК Количество,
	|	ВнеоборотныеАктивы.КоличествоУчет КАК КоличествоУчет,
	|	ВнеоборотныеАктивы.НачальнаяСтоимость КАК НачальнаяСтоимость,
	|	ВнеоборотныеАктивы.НачальнаяСтоимостьУчет КАК НачальнаяСтоимостьУчет,
	|	ВнеоборотныеАктивы.НачисленнаяАмортизация КАК НачисленнаяАмортизация,
	|	ВнеоборотныеАктивы.НачисленнаяАмортизацияУчет КАК НачисленнаяАмортизацияУчет,
	|	ВнеоборотныеАктивы.КонечнаяСтоимость КАК КонечнаяСтоимость,
	|	ВнеоборотныеАктивы.КонечнаяСтоимостьУчет КАК КонечнаяСтоимостьУчет,
	|	ВнеоборотныеАктивы.ЛиквидационнаяСтоимость КАК ЛиквидационнаяСтоимость,
	|	ВнеоборотныеАктивы.ГодовойПроцентАмортизации КАК ГодовойПроцентАмортизации
	|ПОМЕСТИТЬ Вт_ВнеоборотныеАктивы
	|ИЗ
	|	&ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ВнеоборотныйАктив
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Вт_ВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	Вт_ВнеоборотныеАктивы.Подразделение КАК Подразделение,
	|	Вт_ВнеоборотныеАктивы.СостояниеВнеоборотногоАктива КАК СостояниеВнеоборотногоАктива,
	|	Вт_ВнеоборотныеАктивы.Отклонение КАК Отклонение,
	|	Вт_ВнеоборотныеАктивы.Количество КАК Количество,
	|	Вт_ВнеоборотныеАктивы.КоличествоУчет КАК КоличествоУчет,
	|	Вт_ВнеоборотныеАктивы.НачальнаяСтоимость КАК НачальнаяСтоимость,
	|	Вт_ВнеоборотныеАктивы.НачальнаяСтоимостьУчет КАК НачальнаяСтоимостьУчет,
	|	Вт_ВнеоборотныеАктивы.НачисленнаяАмортизация КАК НачисленнаяАмортизация,
	|	Вт_ВнеоборотныеАктивы.НачисленнаяАмортизацияУчет КАК НачисленнаяАмортизацияУчет,
	|	Вт_ВнеоборотныеАктивы.КонечнаяСтоимость КАК КонечнаяСтоимость,
	|	Вт_ВнеоборотныеАктивы.КонечнаяСтоимостьУчет КАК КонечнаяСтоимостьУчет,
	|	Вт_ВнеоборотныеАктивы.ЛиквидационнаяСтоимость КАК ЛиквидационнаяСтоимость,
	|	Вт_ВнеоборотныеАктивы.ГодовойПроцентАмортизации КАК ГодовойПроцентАмортизации
	|ИЗ
	|	Вт_ВнеоборотныеАктивы КАК Вт_ВнеоборотныеАктивы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
	|		ПО Вт_ВнеоборотныеАктивы.ВнеоборотныйАктив = ВнеоборотныеАктивы.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВнеоборотныеАктивы.Наименование
	|ИТОГИ ПО
	|	ВнеоборотныеАктивы.Ссылка ТОЛЬКО ИЕРАРХИЯ";
	
	Если ПоКатегориям Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВнеоборотныеАктивы.Ссылка ТОЛЬКО ИЕРАРХИЯ", "ВнеоборотныеАктивы.ТипВнеоборотныеАктивы ТОЛЬКО ИЕРАРХИЯ");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВнеоборотныеАктивы", ТаблицаВнеоборотныеАктивы);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Объект.ВнеоборотныеАктивы.Очистить();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ТипЗаписи() <> ТипЗаписиЗапроса.ДетальнаяЗапись Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТаблицы = Объект.ВнеоборотныеАктивы.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Выборка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборПоВнеоборотныйАктиве(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидОтбора", "ОтборПоВнеоборотнымАктивам");
	ПараметрыФормы.Вставить("СписокЗначенийОтбора", СписокВнеоборотныхАктивов);
	
	Оповещение = Новый ОписаниеОповещения("УстановитьОтборЗавершение",ЭтотОбъект);
	ОткрытьФорму("Документ.ИнвентаризацияОсновныхСредств.Форма.ФормаВыбораЗначенийОтбора", ПараметрыФормы, ЭтотОбъект,,,,Оповещение);
	
КонецПроцедуры   

&НаКлиенте
Процедура УстановитьОтборПоКатегориямВнеоборотныхАктивов(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидОтбора", "ОтборПоКатегориямВнеоборотныхАктивов");
	ПараметрыФормы.Вставить("СписокЗначенийОтбора", СписокКатегорийВнеоборотныхАктивов);
	
	Оповещение = Новый ОписаниеОповещения("УстановитьОтборЗавершение",ЭтотОбъект);
	ОткрытьФорму("Документ.ИнвентаризацияОсновныхСредств.Форма.ФормаВыбораЗначенийОтбора", ПараметрыФормы, ЭтотОбъект,,,,Оповещение);
	
	
КонецПроцедуры

