	|	ВнеоборотныеАктивыГруп.ГодовойПроцентАмортизации,
	|	ВнеоборотныеАктивыГруп.НачисленнаяАмортизация,
	|	ВнеоборотныеАктивыГруп.НачисленнаяАмортизацияУчет,
	|	ВнеоборотныеАктивыГруп.КонечнаяСтоимость,
	|	ВнеоборотныеАктивыГруп.КонечнаяСтоимостьУчет";
	
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("Организация", Компания);  
	Запрос.УстановитьПараметр("ПринятКУчету", Перечисления.СостоянияВнеоборотныхАктивов.ПринятКУчету); 
	Запрос.УстановитьПараметр("СнятСУчета", Перечисления.СостоянияВнеоборотныхАктивов.СнятСУчета); 
	Запрос.УстановитьПараметр("ВнеоборотныйАктив", ВнеоборотныеАктивы);
	
	Рез = Запрос.Выполнить().Выгрузить();
	
	Если Рез.Количество() > 0 Тогда 
		СтруктураДанные.Вставить("ВнеоборотныйАктив",Рез[0].ВнеоборотныйАктив);  	
		СтруктураДанные.Вставить("ГодовойПроцентАмортизации", Рез[0].ГодовойПроцентАмортизации);
		СтруктураДанные.Вставить("КонечнаяСтоимость", Рез[0].КонечнаяСтоимость);
		СтруктураДанные.Вставить("КонечнаяСтоимостьУчет", Рез[0].КонечнаяСтоимостьУчет);
		СтруктураДанные.Вставить("ЛиквидационнаяСтоимость",Рез[0].ЛиквидационнаяСтоимость);		
		СтруктураДанные.Вставить("НачальнаяСтоимость", Рез[0].НачальнаяСтоимость);
		СтруктураДанные.Вставить("НачальнаяСтоимостьУчет", Рез[0].НачальнаяСтоимостьУчет);
		СтруктураДанные.Вставить("НачисленнаяАмортизация", Рез[0].НачисленнаяАмортизация);
		СтруктураДанные.Вставить("НачисленнаяАмортизацияУчет", Рез[0].НачисленнаяАмортизацияУчет);  		
		СтруктураДанные.Вставить("Подразделение", Рез[0].Подразделение);
		СтруктураДанные.Вставить("СостояниеВнеоборотногоАктива", Рез[0].СостояниеВнеоборотногоАктива);		
	КонецЕсли;
		
	Возврат СтруктураДанные;
	
КонецФункции

