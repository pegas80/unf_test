		Модифицированность = Истина;
	КонецЕсли;	 
	
КонецПроцедуры 

&НаСервере
Процедура ДобавитьПоКатегориямНаСервере(ВыбранныеКатегории)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив
	|ПОМЕСТИТЬ ВнеоборотныеАктивы
	|ИЗ
	|	&ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнеоборотныеАктивы.Ссылка КАК ВнеоборотныйАктив
	|ИЗ
	|	Справочник.ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
	|ГДЕ
	|	НЕ ВнеоборотныеАктивы.ПометкаУдаления
	|	И НЕ ВнеоборотныеАктивы.ЭтоГруппа
	|	И ВнеоборотныеАктивы.ТипВнеоборотныеАктивы В ИЕРАРХИИ(&ТипВнеоборотныеАктивы)
	|	И НЕ ВнеоборотныеАктивы.Ссылка В
	|				(ВЫБРАТЬ
	|					ВнеоборотныеАктивы.ВнеоборотныйАктив
	|				ИЗ
	|					ВнеоборотныеАктивы КАК ВнеоборотныеАктивы)"; 
	
	Запрос.УстановитьПараметр("ТипВнеоборотныеАктивы", ВыбранныеКатегории);
	Запрос.УстановитьПараметр("ВнеоборотныеАктивы", Объект.ВнеоборотныеАктивы.Выгрузить());
	ТаблицаВнеоборотныйАктивов = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЧ ИЗ ТаблицаВнеоборотныйАктивов Цикл
		НовСтрока = Объект.ВнеоборотныеАктивы.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
