			//КонецЕсли;
			//ДанныеШтрихкода.Вставить("СтруктураДанныеНоменклатуры", ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанныеНоменклатуры, ИспользоватьТолькоРегламентированныйПланСчетов));
