&НаКлиенте
Процедура ПолученыШтрихкоды(ДанныеШтрикодов) Экспорт
	
	Модифицированность = Истина;
	
	НедобавленныеШтрихкоды		= ЗаполнитьПоДаннымШтрихкодов(ДанныеШтрикодов);
	НеизвестныеШтрихкоды		= НедобавленныеШтрихкоды.НеизвестныеШтрихкоды;
	ШтрихкодыНекорректногоТипа	= НедобавленныеШтрихкоды.ШтрихкодыНекорректногоТипа;
	
	ПолученыШтрихкодыНекорректногоТипа(ШтрихкодыНекорректногоТипа);
	
	Если НеизвестныеШтрихкоды.Количество() > 0 Тогда
		
		Оповещение = Новый ОписаниеОповещения("ПолученыШтрихкодыЗавершение", ЭтотОбъект, НеизвестныеШтрихкоды);
		
		ОткрытьФорму(
			"РегистрСведений.ШтрихкодыВА.Форма.РегистрацияШтрихкодовНоменклатуры",
			Новый Структура("НеизвестныеШтрихкоды", НеизвестныеШтрихкоды), ЭтотОбъект,,,,Оповещение
		);
		
		Возврат;
		
	КонецЕсли;
	
	ПолученыШтрихкодыФрагмент(НеизвестныеШтрихкоды);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолученыШтрихкодыЗавершение(ВозвращаемыеПараметры, Параметры) Экспорт
	
	НеизвестныеШтрихкоды = Параметры;
	
	Если ВозвращаемыеПараметры <> Неопределено Тогда
		
		МассивШтрихкодов = Новый Массив;
		
		Для каждого ЭлементМассива Из ВозвращаемыеПараметры.ЗарегистрированныеШтрихкоды Цикл
			МассивШтрихкодов.Добавить(ЭлементМассива);
		КонецЦикла;
		
		Для каждого ЭлементМассива Из ВозвращаемыеПараметры.ПолученыНовыеШтрихкоды Цикл
			МассивШтрихкодов.Добавить(ЭлементМассива);
		КонецЦикла;
		
		НедобавленныеШтрихкоды		= ЗаполнитьПоДаннымШтрихкодов(МассивШтрихкодов);
		НеизвестныеШтрихкоды		= НедобавленныеШтрихкоды.НеизвестныеШтрихкоды;
		ШтрихкодыНекорректногоТипа	= НедобавленныеШтрихкоды.ШтрихкодыНекорректногоТипа;
		ПолученыШтрихкодыНекорректногоТипа(ШтрихкодыНекорректногоТипа);
	КонецЕсли;
	
	ПолученыШтрихкодыФрагмент(НеизвестныеШтрихкоды);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолученыШтрихкодыФрагмент(НеизвестныеШтрихкоды) Экспорт
	
	Для каждого ТекНеизвестныйШтрихкод Из НеизвестныеШтрихкоды Цикл
		
		СтрокаСообщения = НСтр("ka='მონაცემები შტრიხკოდის მიხედვით ნაპოვნი არ არის: %1%; რაოდენობა: %2%';ru='Данные по штрихкоду не найдены: %1%; количество: %2%';en='Data on the barcode is not found:% 1%; amount% 2%'");
		СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%1%", ТекНеизвестныйШтрихкод.Штрихкод);
		СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%2%", ТекНеизвестныйШтрихкод.Количество);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаСообщения);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ЗаполнитьПоДаннымШтрихкодов(ДанныеШтрикодов)
	
	НеизвестныеШтрихкоды = Новый Массив;
	ШтрихкодыНекорректногоТипа = Новый Массив;
	ДобавленныеСтроки = Новый Массив;
	
	Если ТипЗнч(ДанныеШтрикодов) = Тип("Массив") Тогда
		МассивШтрихкодов = ДанныеШтрикодов;
	Иначе
		МассивШтрихкодов = Новый Массив;
		МассивШтрихкодов.Добавить(ДанныеШтрикодов);
	КонецЕсли;
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("МассивШтрихкодов", МассивШтрихкодов);
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	ПолучитьДанныеПоШтрихКодам(СтруктураДанные);
	
	Для каждого ТекШтрихкод Из СтруктураДанные.МассивШтрихкодов Цикл
		ДанныеШтрихкода = СтруктураДанные.ДанныеПоШтрихкодам[ТекШтрихкод.Штрихкод];
		Если ДанныеШтрихкода <> Неопределено
		   И ДанныеШтрихкода.Количество() = 0 Тогда
			НеизвестныеШтрихкоды.Добавить(ТекШтрихкод);
		//ИначеЕсли СтруктураДанные.ОтборТипНоменклатуры.Найти(ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ТипНоменклатуры) = Неопределено Тогда
		//	ШтрихкодыНекорректногоТипа.Добавить(Новый Структура("Штрихкод,Номенклатура,ТипНоменклатуры", ТекШтрихкод.Штрихкод, ДанныеШтрихкода.Номенклатура, ДанныеШтрихкода.СтруктураДанныеНоменклатуры.ТипНоменклатуры));
		Иначе
			МассивСтрокТЧ = Объект.ВнеоборотныеАктивы.НайтиСтроки(Новый Структура("ВнеоборотныйАктив",ДанныеШтрихкода.ВнеоборотныйАктив));
			
			Если МассивСтрокТЧ.Количество() = 0 Тогда   
				
				НоваяСтрока = Объект.ВнеоборотныеАктивы.Добавить();
				НоваяСтрока.ВнеоборотныйАктив = ДанныеШтрихкода.ВнеоборотныйАктив;   
				
				СтруктураДанные = ПолучитьДанныеВА(НоваяСтрока.ВнеоборотныйАктив);

				НоваяСтрока.Подразделение = СтруктураДанные.Подразделение;
				НоваяСтрока.Отклонение = 0;
				НоваяСтрока.Количество = 1; 
				НоваяСтрока.КоличествоУчет = СостоянияВнеоборотныхАктивов(НоваяСтрока.ВнеоборотныйАктив); 	
				НоваяСтрока.НачальнаяСтоимость = СтруктураДанные.НачальнаяСтоимость;
				НоваяСтрока.НачальнаяСтоимостьУчет = СтруктураДанные.НачальнаяСтоимостьУчет; 				
				НоваяСтрока.НачисленнаяАмортизация = СтруктураДанные.НачисленнаяАмортизация; 
				НоваяСтрока.НачисленнаяАмортизацияУчет = СтруктураДанные.НачисленнаяАмортизацияУчет;
				НоваяСтрока.КонечнаяСтоимость = СтруктураДанные.КонечнаяСтоимость;
				НоваяСтрока.КонечнаяСтоимостьУчет = СтруктураДанные.КонечнаяСтоимостьУчет; 				
				НоваяСтрока.ЛиквидационнаяСтоимость = СтруктураДанные.ЛиквидационнаяСтоимость; 
				НоваяСтрока.ГодовойПроцентАмортизации = СтруктураДанные.ГодовойПроцентАмортизации;  
				НоваяСтрока.СостояниеВнеоборотногоАктива = СтруктураДанные.СостояниеВнеоборотногоАктива;								
		
			Иначе
				НоваяСтрока = МассивСтрокТЧ[0];
				НоваяСтрока.Количество = НоваяСтрока.Количество + ТекШтрихкод.Количество;  
				НоваяСтрока.Отклонение = НоваяСтрока.Количество - НоваяСтрока.КоличествоУчет;
				Элементы.ВнеоборотныеАктивы.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
			
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат Новый Структура("НеизвестныеШтрихкоды, ШтрихкодыНекорректногоТипа, ДобавленныеСтроки",НеизвестныеШтрихкоды, ШтрихкодыНекорректногоТипа, ДобавленныеСтроки);

КонецФункции   

&НаСервере
Функция СостоянияВнеоборотныхАктивов(ВнеоборотныйАктив)   
	
	Отбор = Новый Структура();
	Отбор.Вставить("Организация",Объект.Организация); 
	Отбор.Вставить("ВнеоборотныйАктив",ВнеоборотныйАктив);
	
	СостоянияВнеоборотныхАктивов = РегистрыСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(Объект.Дата,Отбор); 
	
	Если СостоянияВнеоборотныхАктивов.Количество() > 0 Тогда 
		Если СостоянияВнеоборотныхАктивов[0].Состояние = Перечисления.СостоянияВнеоборотныхАктивов.ПринятКУчету Тогда 
			Возврат 1;
		Иначе 
			Возврат 0;
		КонецЕсли;
	Иначе 
		Возврат 0;	
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеВА(ВнеоборотныеАктивы)
	
	СтруктураДанные = Новый Структура("ВнеоборотныйАктив,ГодовойПроцентАмортизации,КонечнаяСтоимость,КонечнаяСтоимостьУчет,ЛиквидационнаяСтоимость,НачальнаяСтоимость,НачальнаяСтоимостьУчет,НачисленнаяАмортизация,НачисленнаяАмортизацияУчет,Подразделение,СостояниеВнеоборотногоАктива");
	
	//МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	//Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	СостоянияВнеоборотныхАктивов.Состояние КАК Состояние,
	|	ВЫБОР
	|		КОГДА СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.СпособАмортизации = ЗНАЧЕНИЕ(перечисление.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка)
	|			ТОГДА СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.НачальнаяСтоимостьДляУменьшенногоОстатка
	|		ИНАЧЕ СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.НачальнаяСтоимость
	|	КОНЕЦ КАК НачальнаяСтоимость,
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка КАК ЛиквидационнаяСтоимость,
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.ГодовойПроцентАмортизацииДляУменьшенногоОстатка КАК ГодовойПроцентАмортизации
	|ПОМЕСТИТЬ ВтПринятКУчету
	|ИЗ
	|	РегистрСведений.СостоянияВнеоборотныхАктивов КАК СостоянияВнеоборотныхАктивов
	|ГДЕ
	|	СостоянияВнеоборотныхАктивов.Период <= &Период
	|	И СостоянияВнеоборотныхАктивов.Состояние = &ПринятКУчету
	|	И СостоянияВнеоборотныхАктивов.Организация = &Организация
	|	И СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив = &ВнеоборотныйАктив
	|
	|СГРУППИРОВАТЬ ПО
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив,
	|	СостоянияВнеоборотныхАктивов.Состояние,
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка,
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
	|	ВЫБОР
	|		КОГДА СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.СпособАмортизации = ЗНАЧЕНИЕ(перечисление.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка)
	|			ТОГДА СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.НачальнаяСтоимостьДляУменьшенногоОстатка
	|		ИНАЧЕ СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.НачальнаяСтоимость
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив КАК ВнеоборотныйАктив
	|ПОМЕСТИТЬ ВтНеПринятКУчету
	|ИЗ
	|	РегистрСведений.СостоянияВнеоборотныхАктивов КАК СостоянияВнеоборотныхАктивов
	|ГДЕ
	|	СостоянияВнеоборотныхАктивов.Период <= &Период
	|	И СостоянияВнеоборотныхАктивов.Состояние = &СнятСУчета
	|	И СостоянияВнеоборотныхАктивов.Организация = &Организация
	|	И СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив = &ВнеоборотныйАктив
	|
	|СГРУППИРОВАТЬ ПО
	|	СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтПринятКУчету.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ВтПринятКУчету.Состояние КАК СостояниеВнеоборотногоАктива,
	|	1 КАК Количество,
	|	1 КАК КоличествоУчет,
	|	ВтПринятКУчету.НачальнаяСтоимость КАК НачальнаяСтоимость,
	|	ВтПринятКУчету.НачальнаяСтоимость КАК НачальнаяСтоимостьУчет,
	|	ВтПринятКУчету.ЛиквидационнаяСтоимость КАК ЛиквидационнаяСтоимость,
	|	ВтПринятКУчету.ГодовойПроцентАмортизации КАК ГодовойПроцентАмортизации,
	|	ВнеоборотныеАктивыОстаткиИОбороты.АмортизацияКонечныйОстаток КАК НачисленнаяАмортизация,
	|	ВнеоборотныеАктивыОстаткиИОбороты.АмортизацияКонечныйОстаток КАК НачисленнаяАмортизацияУчет,
	|	0 КАК Отклонение,
	|	ВтПринятКУчету.НачальнаяСтоимость - ВнеоборотныеАктивыОстаткиИОбороты.АмортизацияКонечныйОстаток КАК КонечнаяСтоимость,
	|	ВтПринятКУчету.НачальнаяСтоимость - ВнеоборотныеАктивыОстаткиИОбороты.АмортизацияКонечныйОстаток КАК КонечнаяСтоимостьУчет
	|ПОМЕСТИТЬ ВнеоборотныеАктивыПред
	|ИЗ
	|	ВтПринятКУчету КАК ВтПринятКУчету
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВтНеПринятКУчету КАК ВтНеПринятКУчету
	|		ПО ВтПринятКУчету.ВнеоборотныйАктив = ВтНеПринятКУчету.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты(, &Период, , , ) КАК ВнеоборотныеАктивыОстаткиИОбороты
	|		ПО ВтПринятКУчету.ВнеоборотныйАктив = ВнеоборотныеАктивыОстаткиИОбороты.ВнеоборотныйАктив
	|ГДЕ
	|	ВтНеПринятКУчету.ВнеоборотныйАктив ЕСТЬ NULL
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнеоборотныеАктивыПред.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ВнеоборотныеАктивыПред.СостояниеВнеоборотногоАктива КАК СостояниеВнеоборотногоАктива,
	|	ВнеоборотныеАктивыПред.Количество КАК Количество,
	|	ВнеоборотныеАктивыПред.КоличествоУчет КАК КоличествоУчет,
	|	ВнеоборотныеАктивыПред.НачальнаяСтоимость КАК НачальнаяСтоимость,
	|	ВнеоборотныеАктивыПред.НачальнаяСтоимостьУчет КАК НачальнаяСтоимостьУчет,
	|	ВнеоборотныеАктивыПред.ЛиквидационнаяСтоимость КАК ЛиквидационнаяСтоимость,
