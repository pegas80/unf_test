	|	ВнеоборотныеАктивыГруп.Количество,
	|	ВнеоборотныеАктивыГруп.КоличествоУчет,
	|	ВнеоборотныеАктивыГруп.НачальнаяСтоимость,
	|	ВнеоборотныеАктивыГруп.НачальнаяСтоимостьУчет,
	|	ВнеоборотныеАктивыГруп.ЛиквидационнаяСтоимость,
	|	ВнеоборотныеАктивыГруп.ГодовойПроцентАмортизации,
	|	ВнеоборотныеАктивыГруп.НачисленнаяАмортизация,
	|	ВнеоборотныеАктивыГруп.НачисленнаяАмортизацияУчет,
	|	ВнеоборотныеАктивыГруп.КонечнаяСтоимость,
	|	ВнеоборотныеАктивыГруп.КонечнаяСтоимостьУчет";
	
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("Организация", Компания);  
	Запрос.УстановитьПараметр("ПринятКУчету", Перечисления.СостоянияВнеоборотныхАктивов.ПринятКУчету); 
	Запрос.УстановитьПараметр("СнятСУчета", Перечисления.СостоянияВнеоборотныхАктивов.СнятСУчета); 
	Запрос.УстановитьПараметр("Подразделении", Объект.Подразделении.Выгрузить()); 	
	
	
	Если ЕстьОтборПоВнеоборотнымАктивам Тогда
		Запрос.УстановитьПараметр("СписокВнеоборотныхАктивов", СписокВнеоборотныхАктивов);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив В(&СписокВнеоборотныхАктивов)", "");
	КонецЕсли;
	
	Если ЕстьОтборПоГруппамВнеоборотныхАктивов Тогда
		Запрос.УстановитьПараметр("СписокГруппВнеоборотныхАктивов", СписокГруппВнеоборотныхАктивов);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив В ИЕРАРХИИ(&СписокГруппВнеоборотныхАктивов)", "");
	КонецЕсли;
	
	Если ЕстьОтборПоКатегориямВнеоборотныхАктивов Тогда
		Запрос.УстановитьПараметр("ТипВнеоборотныеАктивы", СписокКатегорийВнеоборотныхАктивов);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.ТипВнеоборотныеАктивы В(&ТипВнеоборотныеАктивы)", "");
	КонецЕсли;
	
	Если ЕстьОтборПоСчетамУчета Тогда
		Запрос.УстановитьПараметр("СписокСчетУчет", СписокСчетУчет);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И СостоянияВнеоборотныхАктивов.ВнеоборотныйАктив.СчетУчетаРегл В(&СписокСчетУчет)", "");
	КонецЕсли;
	
	
	Объект.ВнеоборотныеАктивы.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнитьПоДаннымExcel(Команда)
	
	Оповещение	= Новый ОписаниеОповещения("ВариантЗагрузкиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.ИнвентаризацияОсновныхСредств.Форма.ФормаВыбораПути", ,ЭтотОбъект, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры  

&НаКлиенте
Процедура ВариантЗагрузкиЗавершение(СтруктураВыбора, Параметры) Экспорт
	
	Если СтруктураВыбора = КодВозвратаДиалога.Отмена Тогда 
		Возврат;
	КонецЕсли;
	
	ПутьКФайлу = СтруктураВыбора.ПутьКФайлу;
	
	Если НЕ ЗначениеЗаполнено(ПутьКФайлу) Тогда 
		Возврат;
	КонецЕсли;
	
	ТабДок = Новый ТабличныйДокумент; 
	
	//++Lazare ONESOFT-4150
	БинДанные = Новый ДвоичныеДанные(ПутьКФайлу);		
	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(БинДанные, ЭтаФорма.УникальныйИдентификатор);
	//--Lazare ONESOFT-4150
		
	ЗаполнитьПоДаннымExcelНаСервере(ТабДок, ПутьКФайлу,АдресВременногоХранилища);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДаннымExcelНаСервере(ТабДок, ПутьКФайлу, Адрес)  
	
	//++ ONESOFT-4150
	// Получение данных из временного хранилища
	Данные = ПолучитьИзВременногоХранилища(Адрес);
	
	// Получение имени временного файла	
	//ИмяВременногоФайла = ПолучитьИмяВременногоФайла("*.xls, *.xlsx, *.mxl)|*.xls;*.xlsx;*.mxl|");
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xlsx");
	
	ПутьКФайлуНаСервере = ИмяВременногоФайла;
	// Сохранение данных во временный файл
	Данные.Записать(ИмяВременногоФайла);
	
    ТабДок.Прочитать(ИмяВременногоФайла);		
	//ТабДок.Прочитать(ПутьКФайлу); 
	
	//-- ONESOFT-4150
	
	ТаблицаЗагрузки = Новый ТаблицаЗначений;
	
	ТаблицаЗагрузки.Колонки.Добавить("НомерСтроки");
	ТаблицаЗагрузки.Колонки.Добавить("Количество");
	
	НомерКолонкиКоличество = 8;
	
	Для Сч = 2 По ТабДок.ВысотаТаблицы Цикл
		
		СтрокаТаблицы = ТаблицаЗагрузки.Добавить();
		СтрокаТаблицы.НомерСтроки = СокрЛП(ТабДок.Область(Сч, 1, Сч, 1).Текст);
		СтрокаТаблицы.Количество = СокрЛП(ТабДок.Область(Сч, НомерКолонкиКоличество, Сч, НомерКолонкиКоличество).Текст);
		
	КонецЦикла;
	
	Для Каждого Строк Из ТаблицаЗагрузки Цикл 		
		Объект.ВнеоборотныеАктивы[Строк.НомерСтроки - 1].Количество = Строк.Количество;	
		Объект.ВнеоборотныеАктивы[Строк.НомерСтроки - 1].Отклонение = Объект.ВнеоборотныеАктивы[Строк.НомерСтроки - 1].Количество - Объект.ВнеоборотныеАктивы[Строк.НомерСтроки - 1].КоличествоУчет;
	КонецЦикла;
	
	//Объект.ИтогКоличество = Объект.Запасы.Итог("Количество");
	//Объект.ИтогКоличествоУчет = Объект.Запасы.Итог("КоличествоУчет");
	//Объект.ИтогОтклонение = Объект.Запасы.Итог("Отклонение");
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПоГруппе(Команда)
	
	СтруктураВыбора = Новый Структура("МножественныйВыбор", Истина);
	ВыбранныеГруппы = ПолучитьФорму("Справочник.ВнеоборотныеАктивы.Форма.ФормаВыбораГруппы", СтруктураВыбора);
	Результат = ВыбранныеГруппы.ОткрытьМодально();
	Если НЕ Результат = Неопределено Тогда
		ДобавитьПоГруппеНаСервере(Результат);
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры     

&НаСервере
Процедура ДобавитьПоГруппеНаСервере(ВыбранныеГруппы)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив
	|ПОМЕСТИТЬ ВнеоборотныеАктивы
	|ИЗ
	|	&ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнеоборотныеАктивы.Ссылка КАК ВнеоборотныйАктив
	|ИЗ
	|	Справочник.ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
	|ГДЕ
	|	НЕ ВнеоборотныеАктивы.ПометкаУдаления
	|	И НЕ ВнеоборотныеАктивы.ЭтоГруппа
	|	И ВнеоборотныеАктивы.Ссылка В ИЕРАРХИИ(&ВыбранныеГруппы)
	|	И НЕ ВнеоборотныеАктивы.Ссылка В
	|				(ВЫБРАТЬ
	|					ВнеоборотныеАктивы.ВнеоборотныйАктив
	|				ИЗ
	|					ВнеоборотныеАктивы КАК ВнеоборотныеАктивы)";
	Запрос.УстановитьПараметр("ВыбранныеГруппы",	ВыбранныеГруппы);
	Запрос.УстановитьПараметр("ВнеоборотныеАктивы", Объект.ВнеоборотныеАктивы.Выгрузить());
	ТаблицаВнеоборотныйАктивов = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТЧ ИЗ ТаблицаВнеоборотныйАктивов Цикл
		НовСтрока = Объект.ВнеоборотныеАктивы.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьПоКатегориям(Команда) 
	
	СтруктураВыбора = Новый Структура("МножественныйВыбор", Истина);
	ВыбранныеКатегории = ПолучитьФорму("Справочник.ТипОсновныхСредств.Форма.ФормаВыбора", СтруктураВыбора);
	Результат = ВыбранныеКатегории.ОткрытьМодально();
