	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаАмортизации = РезультатЗапроса[4].Выгрузить();
	
	ПоместитьВоВременноеХранилище(ТаблицаАмортизации, АдресВнеоборотныеАктивыВХранилище);
	
КонецПроцедуры   

&НаСервере
Процедура ПолучитьВнеоборотныеАктивыИзХранилища(АдресВнеоборотныеАктивыВХранилище,ДокументОбъект)
	
	ТаблицаВнеоборотныеАктивы = ПолучитьИзВременногоХранилища(АдресВнеоборотныеАктивыВХранилище);
	
	Если ТаблицаВнеоборотныеАктивы.Количество() <> 0 Тогда 
		СтрокаЗаполнения = ТаблицаВнеоборотныеАктивы[0];
		
		ДокументОбъект.Стоимость 			= СтрокаЗаполнения.Стоимость;
		ДокументОбъект.ОстаточнаяСтоимость 	= СтрокаЗаполнения.ОстаточнаяСтоимость;
		ДокументОбъект.Амортизация 			= СтрокаЗаполнения.Амортизация;
		ДокументОбъект.АмортизацияЗаМесяц 	= СтрокаЗаполнения.АмортизацияЗаМесяц;
		ДокументОбъект.КоличествоМесяцеВЭксплуатации 	= СтрокаЗаполнения.КоличествоМесяцеВЭксплуатации;		
	Иначе 		
		ДокументОбъект.Стоимость 			= 0;
		ДокументОбъект.ОстаточнаяСтоимость 	= 0;
		ДокументОбъект.Амортизация 			= 0;
		ДокументОбъект.АмортизацияЗаМесяц 	= 0;
		ДокументОбъект.КоличествоМесяцеВЭксплуатации 	= 0;
		
	КонецЕсли;
	
КонецПроцедуры 

