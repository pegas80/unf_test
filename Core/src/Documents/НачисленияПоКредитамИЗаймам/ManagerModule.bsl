#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыПоКредитамИЗаймам(ДокументСсылкаНачисленияПоКредитамИЗаймам, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("НачисленыПроцентыПоКредиту", НСтр("ka='კრედიტის (მიღებული) თაობაზე დარიცხულია პროცენტები';ru='Начислены проценты по кредиту (полученному)'"));
	Запрос.УстановитьПараметр("НачисленаКомиссияПоКредиту", НСтр("ka='(მიღებული) კრედიტის მიხედვით დარიცხულია კომისია';ru='Начислена комиссия по кредиту (полученному))'"));
	Запрос.УстановитьПараметр("НачисленыПроцентыПоЗайму", НСтр("ka='(გაცემულ) სესხზე დარიცხულია პროცენტები';ru='Начислены проценты по займу (выданному)'"));
	Запрос.УстановитьПараметр("НачисленаКомиссияПоЗайму", НСтр("ka='(გაცემულ) სესხზე დარიცხულია კომისია';ru='Начислена комиссия по займу (выданному))'"));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаНачисленияПоКредитамИЗаймам);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийНачисленияПоКредитамИЗаймам.НачисленияПоКредитам)
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|	КОНЕЦ КАК ВидДвижения,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийНачисленияПоКредитамИЗаймам.НачисленияПоКредитам)
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.Контрагент
	|		ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.Сотрудник
	|	КОНЕЦ КАК Контрагент,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийНачисленияПоКредитамИЗаймам.НачисленияПоКредитам)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитПолученный)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.ДоговорЗаймаСотруднику)
	|	КОНЕЦ КАК ВидДоговора,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма КАК ДоговорКредитаЗайма,
	|	НачисленияПоКредитамИЗаймамНачисления.Дата КАК Период,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Проценты)
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.Сумма
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПроцентыВал,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Комиссия)
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.Сумма
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КомиссияВал,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Проценты)
	|			ТОГДА ВЫРАЗИТЬ(НачисленияПоКредитамИЗаймамНачисления.Сумма * КурсыВалютУчета.Кратность * КурсыВалютРасчетов.Курс / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2))
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Проценты,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Комиссия)
	|			ТОГДА ВЫРАЗИТЬ(НачисленияПоКредитамИЗаймамНачисления.Сумма * КурсыВалютУчета.Кратность * КурсыВалютРасчетов.Курс / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2))
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Комиссия,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийНачисленияПоКредитамИЗаймам.НачисленияПоКредитам)
	|			ТОГДА ВЫБОР
	|					КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Комиссия)
	|						ТОГДА &НачисленаКомиссияПоКредиту
	|					ИНАЧЕ &НачисленыПроцентыПоКредиту
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Комиссия)
	|					ТОГДА &НачисленаКомиссияПоЗайму
	|				ИНАЧЕ &НачисленыПроцентыПоЗайму
	|			КОНЕЦ
	|	КОНЕЦ КАК СодержаниеПроводки
	|ИЗ
	|	Документ.НачисленияПоКредитамИЗаймам.Начисления КАК НачисленияПоКредитамИЗаймамНачисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, ) КАК КурсыВалютРасчетов
	|		ПО НачисленияПоКредитамИЗаймамНачисления.ВалютаРасчетов = КурсыВалютРасчетов.Валюта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта = &ВалютаУчета) КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|ГДЕ
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка = &Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоКредитамИЗаймам", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаРасчетыСПокупателями()

//T
Процедура СформироватьТаблицаРасчетыНДФЛ(ДокументСсылкаНачисленияПоКредитамИЗаймам, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	//Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	//Запрос.УстановитьПараметр("НачисленыПроцентыПоКредиту", НСтр("ka='კრედიტის (მიღებული) თაობაზე დარიცხულია პროცენტები';ru='Начислены проценты по кредиту (полученному)'"));
	//Запрос.УстановитьПараметр("НачисленаКомиссияПоКредиту", НСтр("ka='(მიღებული) კრედიტის მიხედვით დარიცხულია კომისია';ru='Начислена комиссия по кредиту (полученному))'"));
	//Запрос.УстановитьПараметр("НачисленыПроцентыПоЗайму", НСтр("ka='(გაცემულ) სესხზე დარიცხულია პროცენტები';ru='Начислены проценты по займу (выданному)'"));
	//Запрос.УстановитьПараметр("НачисленаКомиссияПоЗайму", НСтр("ka='(გაცემულ) სესხზე დარიცხულია კომისია';ru='Начислена комиссия по займу (выданному))'"));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаНачисленияПоКредитамИЗаймам);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	//
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	Запрос.УстановитьПараметр("ВалютаНациональная", Константы.НациональнаяВалюта.Получить());
	Запрос.УстановитьПараметр("НачислениеНалога",	НСтр("ka='გადასახადის დარიცხვა';ru='Начисление налога'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка.ДатаОкончания КАК Период,
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка.Организация,
	|	НачисленияПоКредитамИЗаймамНачисления.ВидНачисленияУдержанияНДФЛ КАК ВидНачисленияУдержания,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийНачисленияПоКредитамИЗаймам.НачисленияПоЗаймамСотрудникам)
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.Сотрудник
	|		ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.Контрагент
	|	КОНЕЦ КАК Сотрудник,
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка.ДатаНачала КАК ПериодРегистрации,
	|	НачисленияПоКредитамИЗаймамНачисления.ВалютаРасчетов КАК Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.Начисленный) КАК Операция,
	|	&НачислениеНалога КАК СодержаниеПроводки,
	|	ВЫРАЗИТЬ(НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ * КурсыВалютУчета.Кратность * КурсыВалютРасчетов.Курс / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ КАК СуммаВал
	|ИЗ
	|	Документ.НачисленияПоКредитамИЗаймам.Начисления КАК НачисленияПоКредитамИЗаймамНачисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, ) КАК КурсыВалютРасчетов
	|		ПО НачисленияПоКредитамИЗаймамНачисления.ВалютаРасчетов = КурсыВалютРасчетов.Валюта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта = &ВалютаУчета) КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|ГДЕ
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка = &Ссылка
	|	И НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ <> 0";
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыНДФЛ", РезультатЗапроса.Выгрузить());
	
	
	
КонецПроцедуры // СформироватьТаблицаРасчетыСПокупателями()


Процедура СформироватьТаблицаРасчетыПоНалогам(ДокументСсылкаНачисленияПоКредитамИЗаймам, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	//Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	//Запрос.УстановитьПараметр("НачисленыПроцентыПоКредиту", НСтр("ka='კრედიტის (მიღებული) თაობაზე დარიცხულია პროცენტები';ru='Начислены проценты по кредиту (полученному)'"));
	//Запрос.УстановитьПараметр("НачисленаКомиссияПоКредиту", НСтр("ka='(მიღებული) კრედიტის მიხედვით დარიცხულია კომისია';ru='Начислена комиссия по кредиту (полученному))'"));
	//Запрос.УстановитьПараметр("НачисленыПроцентыПоЗайму", НСтр("ka='(გაცემულ) სესხზე დარიცხულია პროცენტები';ru='Начислены проценты по займу (выданному)'"));
	//Запрос.УстановитьПараметр("НачисленаКомиссияПоЗайму", НСтр("ka='(გაცემულ) სესხზე დარიცხულია კომისია';ru='Начислена комиссия по займу (выданному))'"));
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаНачисленияПоКредитамИЗаймам);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	//
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	Запрос.УстановитьПараметр("ВалютаНациональная", Константы.НациональнаяВалюта.Получить());
	Запрос.УстановитьПараметр("НачислениеНалога",	НСтр("ka='გადასახადის დარიცხვა';ru='Начисление налога'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка.ДатаОкончания КАК Период,
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка.Организация КАК Организация,
	|	&НачислениеНалога КАК СодержаниеПроводки,
	|	ВЫРАЗИТЬ(НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ * КурсыВалютУчета.Кратность * КурсыВалютРасчетов.Курс / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	НачисленияПоКредитамИЗаймамНачисления.ВидНачисленияУдержанияНДФЛ.ВидНалога КАК ВидНалога
	|ИЗ
	|	Документ.НачисленияПоКредитамИЗаймам.Начисления КАК НачисленияПоКредитамИЗаймамНачисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, ) КАК КурсыВалютРасчетов
	|		ПО НачисленияПоКредитамИЗаймамНачисления.ВалютаРасчетов = КурсыВалютРасчетов.Валюта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта = &ВалютаУчета) КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|ГДЕ
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка = &Ссылка
	|	И НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ <> 0";
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоНалогам", РезультатЗапроса.Выгрузить());
	
	
	
КонецПроцедуры // СформироватьТаблицаРасчетыСПокупателями()




// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаНачисленияПоКредитамИЗаймам, СтруктураДополнительныеСвойства) Экспорт

	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка,
	|	НачисленияПоКредитамИЗаймамНачисления.НомерСтроки,
	|	НачисленияПоКредитамИЗаймамНачисления.ТипСуммы,
	|	НачисленияПоКредитамИЗаймамНачисления.Дата,
	|	НачисленияПоКредитамИЗаймамНачисления.Сотрудник,
	|	НачисленияПоКредитамИЗаймамНачисления.Контрагент,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма,
	|	НачисленияПоКредитамИЗаймамНачисления.ВалютаРасчетов,
	|	НачисленияПоКредитамИЗаймамНачисления.Сумма КАК СуммаВал,
	|	ВЫРАЗИТЬ(НачисленияПоКредитамИЗаймамНачисления.Сумма * КурсыВалютУчета.Кратность * КурсыВалютРасчетов.Курс / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = &НачисленияПоКредитам
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетЗатрат
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Проценты)
	|					ТОГДА НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаПроцентов
	|				ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаКомиссии
	|			КОНЕЦ
	|	КОНЕЦ КАК СчетЗатрат,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = &НачисленияПоКредитам
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетЗатратРегл
	|		ИНАЧЕ ВЫБОР
	|				КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Проценты)
	|					ТОГДА НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаПроцентовРегл
	|				ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаКомиссииРегл
	|			КОНЕЦ
	|	КОНЕЦ КАК СчетЗатратРегл,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетЗатратРегл КАК СчетУчетаДоходовИРасходовРегл,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетЗатрат КАК СчетУчетаДоходовИРасходов,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.Заказ КАК ЗаказПокупателя,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = &НачисленияПоКредитам
	|			ТОГДА ВЫБОР
	|					КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Проценты)
	|						ТОГДА НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаПроцентов
	|					ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаКомиссии
	|				КОНЕЦ
	|		ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетЗатрат
	|	КОНЕЦ КАК Корреспонденция,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.Ссылка.ВидОперации = &НачисленияПоКредитам
	|			ТОГДА ВЫБОР
	|					КОГДА НачисленияПоКредитамИЗаймамНачисления.ТипСуммы = ЗНАЧЕНИЕ(Перечисление.ТипыСуммГрафикаКредитовИЗаймов.Проценты)
	|						ТОГДА НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаПроцентовРегл
	|					ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаКомиссииРегл
	|				КОНЕЦ
	|		ИНАЧЕ НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетЗатратРегл
	|	КОНЕЦ КАК КорреспонденцияРегл,
	|	НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ КАК СуммаНДФЛВалюта,
	|	ВЫРАЗИТЬ(НачисленияПоКредитамИЗаймамНачисления.СуммаНДФЛ * КурсыВалютУчета.Кратность * КурсыВалютРасчетов.Курс / (КурсыВалютУчета.Курс * КурсыВалютРасчетов.Кратность) КАК ЧИСЛО(15, 2)) КАК СуммаНДФЛ,
	|	ВЫБОР
	|		КОГДА НачисленияПоКредитамИЗаймамНачисления.ВидНачисленияУдержанияНДФЛ.ВидНалога.СчетУчетаРегл <> ЗНАЧЕНИЕ(ПланСчетов.хозрасчетный.пустаяссылка)
	|			ТОГДА НачисленияПоКредитамИЗаймамНачисления.ВидНачисленияУдержанияНДФЛ.ВидНалога.СчетУчетаРегл
	|	КОНЕЦ КАК СчетУчетаРегла,
	|	НачисленияПоКредитамИЗаймамНачисления.ДоговорКредитаЗайма.СчетУчетаПроцентовРегл КАК СчетУчетаПроцентовРегл
	|ПОМЕСТИТЬ Начисления
	|ИЗ
	|	Документ.НачисленияПоКредитамИЗаймам.Начисления КАК НачисленияПоКредитамИЗаймамНачисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, ) КАК КурсыВалютРасчетов
	|		ПО НачисленияПоКредитамИЗаймамНачисления.ВалютаРасчетов = КурсыВалютРасчетов.Валюта
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта = &ВалютаУчета) КАК КурсыВалютУчета
	|		ПО (КурсыВалютУчета.Валюта = &ВалютаУчета)
	|ГДЕ
	|	НачисленияПоКредитамИЗаймамНачисления.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Начисления.НомерСтроки КАК НомерСтроки,
	|	Начисления.Ссылка.Дата КАК Период,
	|	&Организация КАК Организация,
	//+++ Дмгг
	//|	ВЫБОР
	//|		КОГДА Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	//|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам)
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее)
	//|		ИНАЧЕ Начисления.ДоговорКредитаЗайма.НаправлениеДеятельности
	//|	КОНЕЦ КАК НаправлениеДеятельности,
	//|	ВЫБОР
	//|		КОГДА Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	//|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам)
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	//|		ИНАЧЕ Начисления.СтруктурнаяЕдиница
	//|	КОНЕЦ КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользованиеТолькоРеглПланаСчетов 
	|				И (Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее)
	|		КОГДА &ИспользованиеТолькоРеглПланаСчетов 
	|				И (Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|				ИЛИ Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее)
	|		ИНАЧЕ Начисления.ДоговорКредитаЗайма.НаправлениеДеятельности
	|	КОНЕЦ КАК НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользованиеТолькоРеглПланаСчетов
	|					И (Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|					ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|		КОГДА &ИспользованиеТолькоРеглПланаСчетов
	|					И (Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|					ИЛИ Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|		ИНАЧЕ Начисления.СтруктурнаяЕдиница
	|	КОНЕЦ КАК СтруктурнаяЕдиница,
	//--- Дмгг
	|	Начисления.СчетУчетаДоходовИРасходов КАК СчетУчета,
	|	Начисления.СчетУчетаДоходовИРасходовРегл КАК СчетУчетаРегл,
	|	ВЫБОР
	|		КОГДА Начисления.Ссылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийНачисленияПоКредитамИЗаймам.НачисленияПоЗаймамСотрудникам)
	|			ТОГДА Начисления.Сотрудник
	|		ИНАЧЕ Начисления.Контрагент
	|	КОНЕЦ КАК Аналитика,
	//+++ Дмгг
	//|	ВЫБОР
	//|		КОГДА Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	//|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам)
	//|			ТОГДА НЕОПРЕДЕЛЕНО
	//|		ИНАЧЕ Начисления.ЗаказПокупателя
	//|	КОНЕЦ КАК ЗаказПокупателя,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользованиеТолькоРеглПланаСчетов
	|				И (Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		КОГДА &ИспользованиеТолькоРеглПланаСчетов
	|				И (Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|				ИЛИ Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ Начисления.ЗаказПокупателя
	|	КОНЕЦ КАК ЗаказПокупателя,
	//--- Дмгг
	|	0 КАК СуммаДоходов,
	|	Начисления.Сумма + Начисления.СуммаНДФЛ КАК СуммаРасходов,
	|	Начисления.Сумма КАК Сумма,
	|	&СодержаниеПроводкиПрочихДоходовИРасходов КАК СодержаниеПроводки,
	|	Начисления.СуммаНДФЛ КАК СуммаНДФЛ,
	|	Начисления.СуммаНДФЛВалюта КАК СуммаНДФЛВалюта,
	|	Начисления.СчетУчетаРегла КАК СчетУчетаРегла
	|ИЗ
	|	Начисления КАК Начисления
	|ГДЕ
	|	Начисления.Ссылка.ВидОперации = &НачисленияПоКредитам
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Начисления.НомерСтроки КАК НомерСтроки,
	|	Начисления.Ссылка.Дата КАК Период,
	|	&Организация КАК Организация,
	//+++ Дмгг
	//|	ВЫБОР
	//|		КОГДА Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	//|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам)
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее)
	//|		ИНАЧЕ Начисления.ДоговорКредитаЗайма.НаправлениеДеятельности
	//|	КОНЕЦ КАК НаправлениеДеятельности,
	//|	ВЫБОР
	//|		КОГДА Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	//|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам)
	//|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	//|		ИНАЧЕ Начисления.СтруктурнаяЕдиница
	//|	КОНЕЦ КАК СтруктурнаяЕдиница,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользованиеТолькоРеглПланаСчетов 
	|				И (Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|				ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее)
	|		КОГДА &ИспользованиеТолькоРеглПланаСчетов 
	|				И (Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|				ИЛИ Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее)
	|		ИНАЧЕ Начисления.ДоговорКредитаЗайма.НаправлениеДеятельности
	|	КОНЕЦ КАК НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА НЕ &ИспользованиеТолькоРеглПланаСчетов
	|					И (Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|					ИЛИ Начисления.СчетЗатрат.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|		КОГДА &ИспользованиеТолькоРеглПланаСчетов
	|					И (Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПрочиеРасходы)
	|					ИЛИ Начисления.СчетЗатратРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.ПроцентыПоКредитам))
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	|		ИНАЧЕ Начисления.СтруктурнаяЕдиница
	|	КОНЕЦ КАК СтруктурнаяЕдиница,
	//--- Дмгг
	|	Начисления.СчетУчетаДоходовИРасходов КАК СчетУчета,
	|	Начисления.СчетУчетаДоходовИРасходовРегл КАК СчетУчетаРегл,
	|	ВЫБОР
