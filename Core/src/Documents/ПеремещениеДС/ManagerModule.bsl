// Функция формирует печатную форму документа по указанному макету.
//
// Параметры:
//	ТабличныйДокумент - ТабличныйДокумент в который будет выводится печатная
//				   форма.
//  ИмяМакета    - Строка, имя макета печатной формы.
//
Функция ПечатнаяФорма(МассивОбъектов, ОбъектыПечати)
	Перем ПервыйДокумент, НомерСтрокиНачало, Ошибки;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПоступлениеВКассу_ПоступлениеВКассу";
	
	Для каждого ТекущийДокумент Из МассивОбъектов Цикл
		
		ПечатьДокументовУНФ.ПередНачаломФормированияДокумента(ТабличныйДокумент, ПервыйДокумент, НомерСтрокиНачало);
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Основа", НСтр("ka='სალაროებს შორის გადაადგილება / შემოსავალი სალაროდან';ru='Движение между кассами / Доход от кассы';en='Движение между кассами / Доход от кассы'"));
		Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоступлениеВКассу.Ссылка КАК Ссылка,
		|	ПоступлениеВКассу.Номер КАК Номер,
		|	ПоступлениеВКассу.Дата КАК ДатаДокумента,
		|	ПоступлениеВКассу.Организация КАК Организация,
		|	ПоступлениеВКассу.Организация.ЮридическоеФизическоеЛицо КАК ЮрФизЛицо,
		|	ПоступлениеВКассу.Организация.Префикс КАК Префикс,
		|	ПоступлениеВКассу.Организация.КодПоОКПО КАК ОрганизацияПоОКПО,
		|	ПоступлениеВКассу.Организация.НаименованиеПолное КАК ПредставлениеОрганизации,
		|	ПоступлениеВКассу.Касса.СчетУчетаРегл.Код КАК КодДебета,
		|	ПоступлениеВКассу.ВалютаДенежныхСредств КАК ВалютаДенежныхСредств,
		|	ПРЕДСТАВЛЕНИЕ(ПоступлениеВКассу.ВалютаДенежныхСредств) КАК ВалютаПредставление,
		|	ПоступлениеВКассу.НазначениеПлатежа КАК Основание,
		|	"""" КАК Приложение,
		|	"""" КАК РасшифровкаПодписиГлавногоБухгалтера1,
		|	"""" КАК РасшифровкаПодписиКассира,
		|	ПоступлениеВКассу.СуммаДокумента КАК СуммаДокумента,
		|	ПоступлениеВКассу.Касса.СчетУчетаРегл.Код + "", "" + ПоступлениеВКассу.КассаПолучатель.СчетУчетаРегл.Код КАК КорСчет,
		|	"""" КАК КорСчетАвансов,
		|	"""" КАК СчетУчетаАвансовПокупателяРегл,
		|	"""" КАК СчетУчетаАвансовПоставщикуРегл,
		|	"""" КАК СчетУчетаРасчетовСПокупателемРегл,
		|	"""" КАК СчетУчетаРасчетовСПоставщикомРегл,
		|	ПоступлениеВКассу.Касса.Наименование КАК ПринятоОт,
		|	ПоступлениеВКассу.КассаПолучатель.Наименование КАК ПринятоКуда,
		|	"""" КАК РасшифровкаПодписиГлавногоБухгалтера,
		|	"""" КАК ВидОперации,
		|	"""" КАК ПринятоОт1,
		|	ПоступлениеВКассу.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
		|	ПоступлениеВКассу.Касса.СчетУчета.Наименование КАК СубСчет,
		|	&Основа КАК Основа
		|ИЗ
		|	Документ.ПеремещениеДС КАК ПоступлениеВКассу
		|ГДЕ
		|	ПоступлениеВКассу.Ссылка = &ТекущийДокумент";
		
		ВыборкаДляПечати = Запрос.Выполнить().Выбрать();
		ВыборкаДляПечати.Следующий();
		
		Валютный = ВыборкаДляПечати.ВалютаДенежныхСредств <> Константы.НациональнаяВалюта.Получить();
		
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПеремещениеДС.ПФ_MXL_ПКО");
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(ВыборкаДляПечати);
		ОбластьМакета.Параметры.Сумма = Формат(ВыборкаДляПечати.СуммаДокумента, "ЧЦ=15; ЧДЦ=2") + ?(Валютный, " " + СокрЛП(ВыборкаДляПечати.ВалютаДенежныхСредств), "");
		
		
		//Если ЗначениеЗаполнено(ТекущийДокумент.ПринятоОт) Тогда 
		//	
		//	ОбластьМакета.Параметры.ПринятоОт = ТекущийДокумент.ПринятоОт;
		//КонецЕсли;
		
		
		//ОбластьМакета.Параметры.СубСчет = СокрЛП(ВыборкаДляПечати.КорСчет) + ?(ЗначениеЗаполнено(ВыборкаДляПечати.КорСчетАвансов), "," + СокрЛП(ВыборкаДляПечати.КорСчетАвансов), "");
		
		//ОбластьМакета.Параметры.СубСчет = СокрЛП(ВыборкаДляПечати.СчетУчетаАвансовПокупателяРегл) +","+ СокрЛП(ВыборкаДляПечати.СчетУчетаАвансовПоставщикуРегл)+"," +СокрЛП(ВыборкаДляПечати.СчетУчетаРасчетовСПокупателемРегл)+"," +СокрЛП(ВыборкаДляПечати.СчетУчетаРасчетовСПоставщикомРегл)+"," + ?(ЗначениеЗаполнено(ВыборкаДляПечати.КорСчетАвансов), "," + СокрЛП(ВыборкаДляПечати.КорСчетАвансов), "");
		//ОбластьМакета.Параметры.СубСчет =СокрЛП(ВыборкаДляПечати.СчетУчетаРасчетовСПокупателемРегл) +"," +СокрЛП(ВыборкаДляПечати.СчетУчетаАвансовПокупателяРегл); 
		
		
		ОбластьМакета.Параметры.СуммаРубКоп = ?(Валютный, Формат(ВыборкаДляПечати.СуммаДокумента, "Л=ka; ЧЦ=15; ЧДЦ=2") + " " + СокрЛП(ВыборкаДляПечати.ВалютаДенежныхСредств), РубКоп(ВыборкаДляПечати.СуммаДокумента));
		ОбластьМакета.Параметры.НомерДокумента = ПечатьДокументовУНФ.ПолучитьНомерНаПечатьСУчетомДатыДокумента(ВыборкаДляПечати.ДатаДокумента, ВыборкаДляПечати.Номер, ВыборкаДляПечати.Префикс);
		
		ОбластьМакета.Параметры.СуммаПрописью = УправлениеНебольшойФирмойСервер.ФорматироватьСуммуПрописьюПлатежногоДокумента(
			ВыборкаДляПечати.СуммаДокумента,
			ВыборкаДляПечати.ВалютаДенежныхСредств,
			Ложь
		);
		
		
		//Если ВыборкаДляПечати.ВидОперации =Перечисления.ВидыОперацийПоступлениеВКассу.ОтПокупателя Тогда
		//	 ОбластьМакета.Параметры.Основа = НСтр("ka='შემოსავალი რეალიზაციიდან';ru='შემოსаვаლი რეალიზაციიდან'")
		//КонецЕсли;
			
		//ОбластьМакета.Параметры.ВТомЧисле = ПолучитьТекстВТомЧисле(ВыборкаДляПечати, ТекущийДокумент.РасшифровкаПлатежа);
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаДляПечати.Ссылка);
	КонецЦикла;
	
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПКО") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПКО", НСтр("ka='КО-1 (შემოსვლის სალაროს ორდერი)';ru='КО-1 (Приходный кассовый ордер)';en='KO-1 (cash order)'"), ПечатнаяФорма(МассивОбъектов, ОбъектыПечати));
		
	КонецЕсли;
	
	// параметры отправки печатных форм по электронной почте
	УправлениеНебольшойФирмойСервер.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
	
КонецПроцедуры


#КонецОбласти

