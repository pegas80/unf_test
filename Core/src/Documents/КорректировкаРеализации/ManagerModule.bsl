	ТЗСтрок = МассивРезультатов[1].Выгрузить();
	Для Каждого ТекущаяСтрока Из ДанныеДокументовТОРГ12 Цикл
		
		НайденныеСтроки = ТЗСтрок.НайтиСтроки(Новый Структура("Ссылка", ТекущаяСтрока.Ссылка));
		Если НайденныеСтроки.Количество() > 0 Тогда
			ТекущаяСтрока.ТаблицаЗапасы = ТЗСтрок.Скопировать(НайденныеСтроки);
		КонецЕсли;
		
	КонецЦикла;
	
	ОснованиеПечатиИзРасходнойНакладной(ДанныеДокументовТОРГ12, "ПредставлениеОснования");
	ДоставкаСервер.ДобавитьСтрокуДоставкиТОРГ12(ДанныеДокументовТОРГ12);
	
	Возврат ДанныеДокументовТОРГ12;
	
КонецФункции

Функция УниверсальныйЗапросПоДаннымДокумента(МассивОбъектов)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КорректировкаРеализации.Ссылка КАК Ссылка
