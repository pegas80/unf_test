	Запрос.УстановитьПараметр("НалогообложениеНДС", ДокументСсылкаКорректировкаРеализации.НалогообложениеНДС);
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоНалогам", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаКорректировкаРеализации, СтруктураДополнительныеСвойства) Экспорт
	
	//+++ Дмгг, 20.02.24, ONESOFT-2901
	ВалютаУчета = УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета();
	СтруктураОтбора = Новый Структура("Валюта", ВалютаУчета);
	тзКурсаВалУчета = РегистрыСведений.КурсыВалют.СрезПоследних(ДокументСсылкаКорректировкаРеализации.Дата, СтруктураОтбора);
	
	КурсУчета = 1;
	КратностьУчета = 1;
	Если тзКурсаВалУчета.Количество() > 0 Тогда 
		КурсУчета = тзКурсаВалУчета[0].Курс;
		КратностьУчета = тзКурсаВалУчета[0].Кратность;
	КонецЕсли;
	//--- Дмгг, 20.02.24, ONESOFT-2901
	
	тзЗапасы = ДокументСсылкаКорректировкаРеализации.Запасы.Выгрузить();
	тзЗапасы.Колонки.Добавить("СуммаРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаДоИзмененияРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаДоКорректировкиРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаНДСРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаНДСДоИзмененияРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаНДСДоКорректировкиРегл", Новый ОписаниеТипов("Число"));
	
	Для Каждого Строк Из тзЗапасы Цикл 
		//Строк.СуммаРегл = Формат(Строк.Сумма * ДокументСсылкаКорректировкаРеализации.Курс * ДокументСсылкаКорректировкаРеализации.Кратность, "ЧЦ=15; ЧДЦ=2");
		//Строк.СуммаДоИзмененияРегл = Формат(Строк.СуммаДоИзменения * ДокументСсылкаКорректировкаРеализации.Курс * ДокументСсылкаКорректировкаРеализации.Кратность, "ЧЦ=15; ЧДЦ=2");
		//Строк.СуммаДоКорректировкиРегл = Формат(Строк.СуммаДоКорректировки * ДокументСсылкаКорректировкаРеализации.Курс * ДокументСсылкаКорректировкаРеализации.Кратность, "ЧЦ=15; ЧДЦ=2");
		//Строк.СуммаНДСРегл = Формат(Строк.СуммаНДС * ДокументСсылкаКорректировкаРеализации.Курс * ДокументСсылкаКорректировкаРеализации.Кратность, "ЧЦ=15; ЧДЦ=2");
		//Строк.СуммаНДСДоИзмененияРегл = Формат(Строк.СуммаНДСДоИзменения * ДокументСсылкаКорректировкаРеализации.Курс * ДокументСсылкаКорректировкаРеализации.Кратность, "ЧЦ=15; ЧДЦ=2");
		//Строк.СуммаНДСДоКорректировкиРегл = Формат(Строк.СуммаНДСДоКорректировки * ДокументСсылкаКорректировкаРеализации.Курс * ДокументСсылкаКорректировкаРеализации.Кратность, "ЧЦ=15; ЧДЦ=2");
		Строк.СуммаРегл = Строк.Сумма * ДокументСсылкаКорректировкаРеализации.Курс * КратностьУчета / (КурсУчета * ДокументСсылкаКорректировкаРеализации.Кратность);
		Строк.СуммаДоИзмененияРегл = Строк.СуммаДоИзменения * ДокументСсылкаКорректировкаРеализации.Курс * КратностьУчета / (КурсУчета * ДокументСсылкаКорректировкаРеализации.Кратность);
		Строк.СуммаДоКорректировкиРегл = Строк.СуммаДоКорректировки * ДокументСсылкаКорректировкаРеализации.Курс * КратностьУчета / (КурсУчета * ДокументСсылкаКорректировкаРеализации.Кратность);
		Строк.СуммаНДСРегл = Строк.СуммаНДС * ДокументСсылкаКорректировкаРеализации.Курс * КратностьУчета / (КурсУчета * ДокументСсылкаКорректировкаРеализации.Кратность);
		Строк.СуммаНДСДоИзмененияРегл = Строк.СуммаНДСДоИзменения *ДокументСсылкаКорректировкаРеализации.Курс * КратностьУчета / (КурсУчета * ДокументСсылкаКорректировкаРеализации.Кратность);
		Строк.СуммаНДСДоКорректировкиРегл = Строк.СуммаНДСДоКорректировки * ДокументСсылкаКорректировкаРеализации.Курс * КратностьУчета / (КурсУчета * ДокументСсылкаКорректировкаРеализации.Кратность);
	КонецЦикла;
	
	Если ДокументСсылкаКорректировкаРеализации.ВалютаДокумента <> Константы.ВалютаУчета.Получить()
		И ДокументСсылкаКорректировкаРеализации.Предоплата.Количество() > 0 Тогда 
		
		ПересчитатьСуммыРегл(тзЗапасы, ДокументСсылкаКорректировкаРеализации);
		ПересчитатьСуммыДоКорРегл(тзЗапасы, ДокументСсылкаКорректировкаРеализации);
		ПересчитатьСуммыДоИзмРегл(тзЗапасы, ДокументСсылкаКорректировкаРеализации);
		
	КонецЕсли;
	
	тзЗапасы.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.КорректировкаРеализации"));
	тзЗапасы.ЗаполнитьЗначения(ДокументСсылкаКорректировкаРеализации, "Ссылка");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	тзЗапасы.Ссылка КАК Ссылка,
	|	тзЗапасы.НомерСтроки КАК НомерСтроки,
	|	тзЗапасы.Номенклатура КАК Номенклатура,
	|	тзЗапасы.ТипНоменклатурыЗапас КАК ТипНоменклатурыЗапас,
	|	тзЗапасы.Характеристика КАК Характеристика,
	|	тзЗапасы.Партия КАК Партия,
	//Малышев 2024-08-24 ONESOFT-3415  (--
	|   ВЫБОР 
	|		КОГДА &УчетПоПроектам = ЛОЖЬ Тогда Значение(Справочник.Проекты.ПустаяСсылка)
	|		КОГДА &СебестоимостьЗапасовПоПроектам = ЛОЖЬ Тогда Значение(Справочник.Проекты.БезПроекта)
	|		КОГДА тзЗапасы.Проект = Значение(Справочник.Проекты.ПустаяСсылка) Тогда Значение(Справочник.Проекты.БезПроекта)
	|		ИНАЧЕ тзЗапасы.Проект 
	|	КОНЕЦ КАК Проект, 
	//Малышев 2024-08-24 ONESOFT-3415  --)
	|	тзЗапасы.Количество КАК Количество,
	|	тзЗапасы.Спецификация КАК Спецификация,
	|	тзЗапасы.Резерв КАК Резерв,
	|	тзЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	тзЗапасы.Цена КАК Цена,
	|	тзЗапасы.Сумма КАК Сумма,
	|	тзЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	тзЗапасы.СуммаНДС КАК СуммаНДС,
	|	тзЗапасы.Всего КАК Всего,
	|	тзЗапасы.Заказ КАК Заказ,
	|	тзЗапасы.Содержание КАК Содержание,
	|	тзЗапасы.КлючСвязи КАК КлючСвязи,
	|	тзЗапасы.КоличествоДоКорректировки КАК КоличествоДоКорректировки,
	|	тзЗапасы.КоличествоДоИзменения КАК КоличествоДоИзменения,
	|	тзЗапасы.ЦенаДоКорректировки КАК ЦенаДоКорректировки,
	|	тзЗапасы.ЦенаДоИзменения КАК ЦенаДоИзменения,
	|	тзЗапасы.СуммаДоКорректировки КАК СуммаДоКорректировки,
	|	тзЗапасы.СуммаДоИзменения КАК СуммаДоИзменения,
	|	тзЗапасы.СтавкаНДСДоИзменения КАК СтавкаНДСДоИзменения,
	|	тзЗапасы.СуммаНДСДоКорректировки КАК СуммаНДСДоКорректировки,
	|	тзЗапасы.СуммаНДСДоИзменения КАК СуммаНДСДоИзменения,
	|	тзЗапасы.ЕстьВДокументеРеализации КАК ЕстьВДокументеРеализации,
	|	тзЗапасы.ВсегоДоКорректировки КАК ВсегоДоКорректировки,
	|	тзЗапасы.ВсегоДоИзменения КАК ВсегоДоИзменения,
	|	тзЗапасы.СодержаниеДоИзменения КАК СодержаниеДоИзменения,
	|	тзЗапасы.СтранаПроисхождения КАК СтранаПроисхождения,
	|	тзЗапасы.НомерГТД КАК НомерГТД,
	|	ВЫРАЗИТЬ(тзЗапасы.СуммаРегл КАК Число(15,2)) КАК СуммаРегл,
	|	ВЫРАЗИТЬ(тзЗапасы.СуммаДоКорректировкиРегл КАК Число(15,2)) КАК СуммаДоКорректировкиРегл,
	|	ВЫРАЗИТЬ(тзЗапасы.СуммаДоИзмененияРегл КАК Число(15,2)) КАК СуммаДоИзмененияРегл,
	|	ВЫРАЗИТЬ(тзЗапасы.СуммаНДСРегл КАК Число(15,2)) КАК СуммаНДСРегл,
	|	ВЫРАЗИТЬ(тзЗапасы.СуммаНДСДоКорректировкиРегл КАК Число(15,2)) КАК СуммаНДСДоКорректировкиРегл,
	|	ВЫРАЗИТЬ(тзЗапасы.СуммаНДСДоИзмененияРегл КАК Число(15,2)) КАК СуммаНДСДоИзмененияРегл
	|	,тзЗапасы.СчетУчетаВыручкиОтПродажРегл КАК СчетУчетаВыручкиОтПродажРегл
	|ПОМЕСТИТЬ ВТ_Запасы
	|ИЗ
	|	&тзЗапасы КАК тзЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА КорректировкаРеализации.Ссылка.Договор.ЭтоДоговорОбслуживания
	|				И КорректировкаРеализации.Договор.ДоговорОбслуживанияНаправлениеДеятельности <> ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВестиУчетРасходовПоДоговорамОбслуживания,
	|	КорректировкаРеализации.Ссылка.Договор.ДоговорОбслуживанияНаправлениеДеятельности КАК НаправлениеДеятельности,
	|	КорректировкаРеализации.Договор.ВалютаРасчетов КАК ДоговорВалютаРасчетов,
	|	КорректировкаРеализации.Договор.РасчетыВУсловныхЕдиницах КАК ДоговорРасчетыВУсловныхЕдиницах,
	|	КорректировкаРеализации.Контрагент,
	|	КорректировкаРеализации.ВалютаДокумента,
	|	КорректировкаРеализации.Кратность,
	|	КорректировкаРеализации.Курс,
	|	КорректировкаРеализации.Договор,
	|	КорректировкаРеализации.Дата
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|	Документ.КорректировкаРеализации КАК КорректировкаРеализации
	|ГДЕ
	|	КорректировкаРеализации.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КурсыВалютСрезПоследних.Валюта КАК Валюта,
	|	КурсыВалютСрезПоследних.Курс КАК Курс,
	|	КурсыВалютСрезПоследних.Кратность КАК Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаНациональная, &ВалютаНакладной)) КАК КурсыВалютСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КорректировкаРеализацииЗапасы.Ссылка,
	|	КорректировкаРеализацииЗапасы.Ссылка.Договор КАК Договор,
	|	КорректировкаРеализацииЗапасы.Номенклатура,
	|	КорректировкаРеализацииЗапасы.Характеристика,
	|	КорректировкаРеализацииЗапасы.Партия,
	|	КорректировкаРеализацииЗапасы.Проект,  //Малышев 2024-08-24 ONESOFT-3415
	|	КорректировкаРеализацииЗапасы.ЕдиницаИзмерения,
	|	КорректировкаРеализацииЗапасы.СтранаПроисхождения,
	|	КорректировкаРеализацииЗапасы.НомерГТД,
	|	ВЫБОР
	|		КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|			ТОГДА КорректировкаРеализацииЗапасы.Количество
	|		ИНАЧЕ КорректировкаРеализацииЗапасы.Количество - КорректировкаРеализацииЗапасы.КоличествоДоИзменения
	|	КОНЕЦ КАК Количество,
	|	КорректировкаРеализацииЗапасы.Цена КАК Цена,
	|	ВЫБОР
	|		КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|			ТОГДА КорректировкаРеализацииЗапасы.СуммаРегл
	|		ИНАЧЕ КорректировкаРеализацииЗапасы.СуммаРегл - КорректировкаРеализацииЗапасы.СуммаДоИзмененияРегл
	|	КОНЕЦ КАК Сумма,
	|	КорректировкаРеализацииЗапасы.СтавкаНДС,
	|	ВЫБОР
	|		КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|			ТОГДА КорректировкаРеализацииЗапасы.СуммаНДСРегл
	|		ИНАЧЕ КорректировкаРеализацииЗапасы.СуммаНДСРегл - КорректировкаРеализацииЗапасы.СуммаНДСДоИзмененияРегл
	|	КОНЕЦ КАК СуммаНДС,
	|	КорректировкаРеализацииЗапасы.Заказ,
	|	ВЫБОР
	|		КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|			ТОГДА КорректировкаРеализацииЗапасы.Всего
	|		ИНАЧЕ КорректировкаРеализацииЗапасы.Всего - КорректировкаРеализацииЗапасы.ВсегоДоИзменения
	|	КОНЕЦ КАК Всего,
	|	КорректировкаРеализацииЗапасы.Содержание,
	|	КорректировкаРеализацииЗапасы.НомерСтроки,
	|	КорректировкаРеализацииЗапасы.Резерв,
	|	КорректировкаРеализацииЗапасы.КлючСвязи,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(&ДокументРеализации) = ТИП(Документ.ЗаказПокупателя)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ОснованиеЗаказНаряд,
	|	КорректировкаРеализацииЗапасы.Спецификация,
	|	КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|	,КорректировкаРеализацииЗапасы.СчетУчетаВыручкиОтПродажРегл КАК СчетУчетаВыручкиОтПродажРегл
	|ПОМЕСТИТЬ ВременнаяТаблицаИзмененияЗапасов
	|ИЗ
	|	ВТ_Запасы КАК КорректировкаРеализацииЗапасы
	|ГДЕ
	|	КорректировкаРеализацииЗапасы.Ссылка = &Ссылка
	|	И (ВЫБОР
	|				КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|					ТОГДА КорректировкаРеализацииЗапасы.Количество
	|				ИНАЧЕ КорректировкаРеализацииЗапасы.Количество - КорректировкаРеализацииЗапасы.КоличествоДоИзменения
	|			КОНЕЦ <> 0
	|			ИЛИ ВЫБОР
	|				КОГДА НЕ КорректировкаРеализацииЗапасы.ЕстьВДокументеРеализации
	|					ТОГДА КорректировкаРеализацииЗапасы.Сумма
	|				ИНАЧЕ КорректировкаРеализацииЗапасы.Сумма - КорректировкаРеализацииЗапасы.СуммаДоИзменения
	|			КОНЕЦ <> 0)
	|	И КорректировкаРеализацииЗапасы.Ссылка.ОтражатьВУчете
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
