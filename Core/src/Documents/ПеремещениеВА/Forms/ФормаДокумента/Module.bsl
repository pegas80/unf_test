
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	//Паганини_
	НайденныйЭлНакладная = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(Объект.Ссылка);
	Элементы.ЭлектроннаяНакладнаяНадпись.Заголовок = РаботаСФормойДокументаКлиентСервер.СформироватьНадписьЭлНакладная(НайденныйЭлНакладная);
	Элементы.ЭлектроннаяНакладнаяНадпись.Доступность= РС_ИнтеграцияСНалоговойСлужбойГрузииПовтИсп.ПодсистемаДоступна_ИнтеграцияСНалоговойСлужбойГрузии();
	//_Паганини
	
	//+++ Дмгг
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
		
		ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ТекущаяДата()); //+++ Дмгг
	Иначе
		ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ДатаДокумента);
	КонецЕсли;
	//--- Дмгг
	
	//ПодольскийАИ #УчетПроектов 08.12.2020 {
	УчетПоПроектам = ПолучитьФункциональнуюОпцию("УчетПоПроектам");
	//ПодольскийАИ #УчетПроектов 08.12.2020 }
	
	// СтандартныеПодсистемы.Печать
	УправлениеПечатью.ПриСозданииНаСервере(ЭтотОбъект, Элементы.ПодменюПечать);
	// Конец СтандартныеПодсистемы.Печать
	УправлениеНебольшойФирмойСервер.УстановитьОтображаниеПодменюПечати(Элементы.ПодменюПечать);
	
КонецПроцедуры

&НаСервере
Процедура ВнеоборотныеАктивыВнеоборотныйАктивПриИзмененииНаСервере(УИДСтроки)
	
	ДатаЗапроса = Дата(1,1,1);
	Если ЗначениеЗаполнено(Объект.Дата) Тогда 
		Если Объект.Дата = НачалоДня(Объект.Дата) Тогда 
			ДатаЗапроса = ТекущаяДата();
		Иначе
			ДатаЗапроса = Объект.Дата-1;
		КонецЕсли;
	Иначе
		ДатаЗапроса = ТекущаяДата();
	КонецЕсли;
	
	СтрокаЗаполнения = Объект.ВнеоборотныеАктивы.НайтиПоИдентификатору(УИДСтроки);
	
	Если СтрокаЗаполнения = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПараметрыАмортизацииСрезПоследних.ВнеоборотныйАктив КАК ВнеоборотныйАктивТек,
	|	ПараметрыАмортизацииСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПараметрыАмортизацииСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиницаПолучатель,
	|	ПараметрыАмортизацииСрезПоследних.ОбъемПродукцииРаботДляВычисленияАмортизации КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	ПараметрыАмортизацииСрезПоследних.СтоимостьДляВычисленияАмортизации КАК СтоимостьДляВычисленияАмортизации,
	|	ПараметрыАмортизацииСрезПоследних.СрокИспользованияДляВычисленияАмортизации КАК СрокИспользованияДляВычисленияАмортизации,
	|	ПараметрыАмортизацииСрезПоследних.СчетЗатрат КАК СчетЗатрат,
	|	ПараметрыАмортизацииСрезПоследних.СчетЗатратРегл КАК СчетЗатратРегл,
	|	ПараметрыАмортизацииСрезПоследних.Адрес КАК Адрес,
	|	ПараметрыАмортизацииСрезПоследних.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ПараметрыАмортизацииСрезПоследних.ГодовойПроцентАмортизацииДляУменьшенногоОстатка КАК ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
	|	ПараметрыАмортизацииСрезПоследних.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка КАК ЛиквидационнаяСтоимостьДляУменьшенногоОстатка,
	//Paganini_
	|	ЕСТЬNULL(СостоянияВнеоборотныхАктивовСрезПоследних.НачислятьАмортизацию, ЛОЖЬ) КАК Амортизация,
	|	ЕСТЬNULL(СостоянияВнеоборотныхАктивовСрезПоследних.НачислятьАмортизациюВТекущемМесяце, ЛОЖЬ) КАК НачислятьАмортизациюВТекущемМесяце,
	//_Paganini
	|	ЕСТЬNULL(РыночныеЦеныВАСрезПоследних.Цена, 0) КАК РыночнаяЦена
	|ИЗ
	|	РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних(
	|			&ДатаДокумента,
	|			Организация = &Организация
	|				И ВнеоборотныйАктив = &ВнеоборотныйАктив
	//Paganini_
	|				И НЕ Регистратор = &Ссылка
	//_Paganini
	|) КАК ПараметрыАмортизацииСрезПоследних
	//Paganini_
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(
	|				&ДатаДокумента,
	|				Организация = &Организация
	|					И ВнеоборотныйАктив = &ВнеоборотныйАктив
	|					И НЕ Регистратор = &Ссылка) КАК СостоянияВнеоборотныхАктивовСрезПоследних
	|		ПО ПараметрыАмортизацииСрезПоследних.ВнеоборотныйАктив = СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
	//_Paganini
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РыночныеЦеныВА.СрезПоследних(&ДатаДокумента, ) КАК РыночныеЦеныВАСрезПоследних
	|		ПО ПараметрыАмортизацииСрезПоследних.ВнеоборотныйАктив = РыночныеЦеныВАСрезПоследних.Имущество";
	
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаЗапроса);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ВнеоборотныйАктив", СтрокаЗаполнения.ВнеоборотныйАктив);
	//Paganini_
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	//_Paganini
	
	ВыборкаРезультат = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаРезультат.Следующий() Цикл 
		ЗаполнитьЗначенияСвойств(СтрокаЗаполнения ,ВыборкаРезультат);
	КонецЦикла;
	
	//ПодольскийАИ #УчетПроектов 08.12.2020 {
	СтрокаЗаполнения.Проект = Справочники.Проекты.ПустаяСсылка();
	СтрокаЗаполнения.ПроектПолучатель = Справочники.Проекты.ПустаяСсылка();
	Если УчетПоПроектам Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив,
		|	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.Проект
		|ИЗ
		|	РегистрСведений.УчетПоПроектамВнеоборотныхАктивов.СрезПоследних(
		|			&ДатаДокумента,
		|			Организация = &Организация
		|				И ВнеоборотныйАктив = &ВнеоборотныйАктив) КАК УчетПоПроектамВнеоборотныхАктивовСрезПоследних";
		
		ВыборкаРезультат = Запрос.Выполнить().Выбрать();
		Пока ВыборкаРезультат.Следующий() Цикл 
			СтрокаЗаполнения.Проект = ВыборкаРезультат.Проект;
			СтрокаЗаполнения.ПроектПолучатель = ВыборкаРезультат.Проект;
		КонецЦикла;
	КонецЕсли;
	//ПодольскийАИ #УчетПроектов 08.12.2020 }
	
КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыВнеоборотныйАктивПриИзменении(Элемент)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	ТекСтрока.СтруктурнаяЕдиница = НайтиСкладВПринятиеКУчету(ТекСтрока.ВнеоборотныйАктив);
	
	УИДСтроки = ТекСтрока.ПолучитьИдентификатор();
	
	ВнеоборотныеАктивыВнеоборотныйАктивПриИзмененииНаСервере(УИДСтроки);
	
	ОбновитьПодвалФормы();
	
КонецПроцедуры

&НаСервере
Функция НайтиСкладВПринятиеКУчету(ВнеоборотныйАктив)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПринятиеКУчетуВА.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница
		|ИЗ
		|	Документ.ПринятиеКУчетуВА КАК ПринятиеКУчетуВА
		|ГДЕ
		|	ПринятиеКУчетуВА.ВнеоборотныеАктивы.ВнеоборотныйАктив = &ВнеоборотныйАктив";
	
	Запрос.УстановитьПараметр("ВнеоборотныйАктив", ВнеоборотныйАктив);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.СтруктурнаяЕдиница;
	КонецЦикла;
	
	Возврат Неопределено;	
КонецФункции

&НаКлиенте
Процедура КомментарийНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияКомментария(Элемент.ТекстРедактирования, ЭтотОбъект, "Объект.Комментарий");
	
КонецПроцедуры


//Паганини_
&НаКлиенте
Процедура ЭлектроннаяНакладнаяНадписьОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ОчиститьСообщения();
	
	Если НЕ ПроверитьВозможностьСозданияЭЛНакладной() Тогда 
		Возврат;	
	КонецЕсли;
	
	
	ПараметрыФормы   = Новый Структура;
	массивДокументов = Новый Массив;
	массивДокументов.Добавить(Объект.Ссылка);
	ПараметрыФормы.Вставить("ДокументыОснования", массивДокументов);
	
	УправлениеНебольшойФирмойКлиент.ОткрытьЭлНакладную(ЭтотОбъект,ПараметрыФормы);
	
	СтатистикаИспользованияФормКлиент.ПриИнтерактивномДействии(ЭтотОбъект, Элемент, "ОбработкаНавигационнойСсылки");
КонецПроцедуры
&НаКлиенте
Функция ПроверитьВозможностьСозданияЭЛНакладной()
	
	Результат = Истина;
	Если Модифицированность Или НЕ ПроверитьЗаполнение() Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ka='დოკუმენტი შეიცვალა. თავდაპირველად, საჭიროა დოკუმენტის ჩაწერა!';ru='Документ был изменен. Сначала следует записать документ!';en='The document has been changed. First, you must write the document!'");	
		Сообщение.Сообщить();
		Результат = Ложь;
	Иначе
		Результат = Истина;
	КонецЕсли;

	Возврат Результат;
	
КонецФункции


&НаСервере
Процедура ВнеоборотныеАктивыСтруктурнаяЕдиницаПолучательПриИзмененииНаСервере(УИД_Строки)
	
	ТекСтрока = Объект.ВнеоборотныеАктивы.НайтиПоИдентификатору(УИД_Строки);
	
	МассивАдресовСтруктурнойЕдиницы = ТекСтрока.СтруктурнаяЕдиницаПолучатель.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Тип, Вид", Перечисления.ТипыКонтактнойИнформации.Адрес, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы));
	
	Если МассивАдресовСтруктурнойЕдиницы.Количество() <> 0 Тогда 
		ТекСтрока.АдресПолучатель = МассивАдресовСтруктурнойЕдиницы[0].Представление;
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ВнеоборотныеАктивыСтруктурнаяЕдиницаПолучательПриИзменении(Элемент)
	ТекСтрока= Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	УИД_Строки = ТекСтрока.ПолучитьИдентификатор();
	ВнеоборотныеАктивыСтруктурнаяЕдиницаПолучательПриИзмененииНаСервере(УИД_Строки);
КонецПроцедуры


