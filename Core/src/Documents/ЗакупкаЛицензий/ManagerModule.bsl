


// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаЗакупкаЛицензии, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗакупкаЛицензийЛицензии.Ссылка КАК Ссылка,
	|	ЗакупкаЛицензийЛицензии.НомерСтроки КАК НомерСтроки,
	|	ЗакупкаЛицензийЛицензии.Номенклатура КАК Номенклатура,
	|	ЗакупкаЛицензийЛицензии.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ЗакупкаЛицензийЛицензии.Цена КАК Цена,
	|	ЗакупкаЛицензийЛицензии.СтавкаНДС КАК СтавкаНДС,
	|	ЗакупкаЛицензийЛицензии.Всего КАК Всего,
	|	1 КАК Количество,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ЗакупкаЛицензийЛицензии.СтавкаНДС.Ставка, 0) = 0
	|			ТОГДА 0
	|		ИНАЧЕ ЗакупкаЛицензийЛицензии.Всего - ЗакупкаЛицензийЛицензии.Всего / (1 + ЗакупкаЛицензийЛицензии.СтавкаНДС.Ставка / 100)
	|	КОНЕЦ КАК СуммаНДС,
	|	ЗакупкаЛицензийЛицензии.Всего - ВЫБОР
	|		КОГДА ЕСТЬNULL(ЗакупкаЛицензийЛицензии.СтавкаНДС.Ставка, 0) = 0
	|			ТОГДА 0
	|		ИНАЧЕ ЗакупкаЛицензийЛицензии.Всего - ЗакупкаЛицензийЛицензии.Всего / (1 + ЗакупкаЛицензийЛицензии.СтавкаНДС.Ставка / 100)
	|	КОНЕЦ КАК Сумма,
	|	ВЫБОР
	|		КОГДА &УчетПоПроектам
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
	|	КОНЕЦ КАК Проект
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасыПерерасчетПред
	|ИЗ
	|	Документ.ЗакупкаЛицензий.Лицензии КАК ЗакупкаЛицензийЛицензии
	|ГДЕ
	|	ЗакупкаЛицензийЛицензии.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаЗапасыПерерасчетПред.СуммаНДС КАК СуммаНДС,
	|	1 КАК КоличествоСтрок,
	|	ВременнаяТаблицаЗапасыПерерасчетПред.Сумма КАК Сумма
	|ПОМЕСТИТЬ вт_ЗапасыГрупп
	|ИЗ
	|	ВременнаяТаблицаЗапасыПерерасчетПред КАК ВременнаяТаблицаЗапасыПерерасчетПред
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаЗапасыПерерасчет.Ссылка КАК Ссылка,
	|	ВременнаяТаблицаЗапасыПерерасчет.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаЗапасыПерерасчет.Номенклатура КАК Номенклатура,
	|	ВременнаяТаблицаЗапасыПерерасчет.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВременнаяТаблицаЗапасыПерерасчет.Цена КАК Цена,
	|	ВременнаяТаблицаЗапасыПерерасчет.СтавкаНДС КАК СтавкаНДС,
	|	ВременнаяТаблицаЗапасыПерерасчет.Всего КАК Всего,
	|	ВременнаяТаблицаЗапасыПерерасчет.Количество КАК Количество,
	|	ВЫРАЗИТЬ(ВременнаяТаблицаЗапасыПерерасчет.СуммаНДС КАК ЧИСЛО(15, 8)) КАК СуммаНДС,
	|	ВЫРАЗИТЬ(ВременнаяТаблицаЗапасыПерерасчет.Сумма КАК ЧИСЛО(15, 8)) КАК Сумма,
	|	ВременнаяТаблицаЗапасыПерерасчет.Проект КАК Проект
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасыПерерасчет
	|ИЗ
	|	ВременнаяТаблицаЗапасыПерерасчетПред КАК ВременнаяТаблицаЗапасыПерерасчет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗакупкаЛицензийПредоплата.Ссылка КАК Ссылка,
	|	СУММА(ЗакупкаЛицензийПредоплата.СуммаРасчетов) КАК СуммаРасчетов,
	|	СУММА(ЗакупкаЛицензийПредоплата.СуммаРасчетов * ЗакупкаЛицензийПредоплата.Курс / ЗакупкаЛицензийПредоплата.Кратность) КАК СуммаРасчетовРеглПоКурсуПредоплаты,
	|	СУММА(ЗакупкаЛицензийПредоплата.СуммаНДФЛ) КАК СуммаНДФЛ,
	|	СУММА(ЗакупкаЛицензийПредоплата.СуммаНДФЛ * ЗакупкаЛицензийПредоплата.Курс / ЗакупкаЛицензийПредоплата.Кратность) КАК СуммаНДФЛРеглПоКурсуПредоплаты,
	|	СУММА(ЗакупкаЛицензийПредоплата.СуммаПФ) КАК СуммаПФ,
	|	СУММА(ЗакупкаЛицензийПредоплата.СуммаПФ * ЗакупкаЛицензийПредоплата.Курс / ЗакупкаЛицензийПредоплата.Кратность) КАК СуммаПФРеглПоКурсуПредоплаты
	|ПОМЕСТИТЬ ВременнаяТаблицаСуммаПредоплатыГрупп
	|ИЗ
	|	Документ.ЗакупкаЛицензий.Предоплата КАК ЗакупкаЛицензийПредоплата
	|ГДЕ
	|	ЗакупкаЛицензийПредоплата.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗакупкаЛицензийПредоплата.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗакупкаЛицензий.Ссылка КАК Ссылка,
	|	ЗакупкаЛицензий.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаНДФЛ, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаПФ, 0) КАК СуммаНеОплаченаВал,
	|	(ЗакупкаЛицензий.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаНДФЛ, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаПФ, 0)) * ЗакупкаЛицензий.Курс / ЗакупкаЛицензий.Кратность КАК СуммаНеОплаченаРегл,
	|	ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаРасчетовВал,
	|	ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаНДФЛ, 0) КАК СуммаРасчетовРегл,
	|	(ЗакупкаЛицензий.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаНДФЛ, 0)) * ЗакупкаЛицензий.Курс / ЗакупкаЛицензий.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) КАК СуммаДокументаРеглПоВсемКурсам,
	|	ВЫБОР
	|		КОГДА ЗакупкаЛицензий.СуммаДокумента = 0
	|			ТОГДА 1
	|		ИНАЧЕ ((ЗакупкаЛицензий.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаНДФЛ, 0) - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаПФ, 0)) * ЗакупкаЛицензий.Курс / ЗакупкаЛицензий.Кратность + (ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаНДФЛРеглПоКурсуПредоплаты, 0) + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаПФРеглПоКурсуПредоплаты, 0))) / ЗакупкаЛицензий.СуммаДокумента
	|	КОНЕЦ КАК СреднийКурсДокумента,
	|	1 КАК Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаСреднегоКурсаПредоплаты
	|ИЗ
	|	Документ.ЗакупкаЛицензий КАК ЗакупкаЛицензий
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаСуммаПредоплатыГрупп КАК ВременнаяТаблицаСуммаПредоплатыГрупп
	|		ПО ЗакупкаЛицензий.Ссылка = ВременнаяТаблицаСуммаПредоплатыГрупп.Ссылка
	|ГДЕ
	|	ЗакупкаЛицензий.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаСреднегоКурсаПредоплаты.Ссылка КАК Ссылка,
	|	ВременнаяТаблицаСреднегоКурсаПредоплаты.Кратность КАК Кратность,
	|	ВременнаяТаблицаСреднегоКурсаПредоплаты.СреднийКурсДокумента КАК Курс
	|ПОМЕСТИТЬ ВременнаяТаблицаСреднегоКурсаПоДокументу
	|ИЗ
	|	ВременнаяТаблицаСреднегоКурсаПредоплаты КАК ВременнаяТаблицаСреднегоКурсаПредоплаты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КурсыВалютСрезПоследних.Валюта КАК Валюта,
	|	КурсыВалютСрезПоследних.Курс КАК Курс,
	|	КурсыВалютСрезПоследних.Кратность КАК Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаКурсыВалютСрезПоследних
	|ИЗ
	|	РегистрСведений.КурсыВалют.СрезПоследних(&МоментВремени, Валюта В (&ВалютаУчета, &ВалютаНациональная)) КАК КурсыВалютСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ТаблицаДокумента.НомерСтроки) КАК НомерСтроки,
	|	ТаблицаДокумента.Ссылка.Дата КАК Период,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.Ссылка.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоДоговорам КАК ВестиРасчетыПоДоговорам,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоДокументам КАК ВестиРасчетыПоДокументам,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоЗаказам КАК ВестиРасчетыПоЗаказам,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиУчетОплатыПоСчетам КАК ВестиУчетОплатыПоСчетам,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаРасчетовСПокупателем КАК СчетУчетаРасчетовСПокупателем,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаАвансовПокупателя КАК СчетУчетаАвансовПокупателя,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаРасчетовСПоставщиком КАК СчетУчетаРасчетовСПоставщиком,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаАвансовПоставщику КАК СчетУчетаАвансовПоставщику,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаРасчетовСПокупателемРегл КАК СчетУчетаРасчетовСПокупателемРегл,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаАвансовПокупателяРегл КАК СчетУчетаАвансовПокупателяРегл,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаРасчетовСПоставщикомРегл КАК СчетУчетаРасчетовСПоставщикомРегл,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаАвансовПоставщикуРегл КАК СчетУчетаАвансовПоставщикуРегл,
	|	ТаблицаДокумента.Ссылка.Организация КАК ОрганизацияВНУ,
	|	ТаблицаДокумента.Ссылка.НалогообложениеНДС КАК НалогообложениеНДС,
	|	ТаблицаДокумента.Ссылка.Договор КАК Договор,
	|	ТаблицаДокумента.Ссылка.Договор.ВалютаРасчетов КАК ВалютаРасчетов,
	|	ТаблицаДокумента.Заказ КАК Заказ,
	|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее) КАК НаправлениеДеятельностиПродажи,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс) КАК ТипРасчетов,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг) КАК ТипРасчетовКуда,
	|	&Ссылка КАК ДокументКуда,
	|	ТаблицаДокумента.Документ КАК Документ,
	|	ВЫБОР
	|		КОГДА НЕ ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоДокументам
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТаблицаДокумента.Документ) = ТИП(Документ.АвансовыйОтчет)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТаблицаДокумента.Документ) = ТИП(Документ.Взаимозачет)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтатьиДвиженияДенежныхСредств.ОплатаПоставщикам)
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.РасходСоСчета
	|					ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.РасходСоСчета).Статья
	|				КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.ПоступлениеНаСчет
	|					ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.ПоступлениеНаСчет).Статья
	|				КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.ПоступлениеВКассу
	|					ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.ПоступлениеВКассу).Статья
	|				КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.РасходИзКассы
	|					ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.РасходИзКассы).Статья
	|				ИНАЧЕ ЗНАЧЕНИЕ(Справочник.СтатьиДвиженияДенежныхСредств.ОплатаПоставщикам)
	|			КОНЕЦ
	|	КОНЕЦ КАК Статья,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоДокументам
	|			ТОГДА ВЫБОР
	|					КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.РасходСоСчета
	|						ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.РасходСоСчета).Дата
	|					КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.ПоступлениеНаСчет
	|						ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.ПоступлениеНаСчет).Дата
	|					КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.ПоступлениеВКассу
	|						ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.ПоступлениеВКассу).Дата
	|					КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.РасходИзКассы
	|						ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.РасходИзКассы).Дата
	|					КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.АвансовыйОтчет
	|						ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.АвансовыйОтчет).Дата
	|					КОГДА ТаблицаДокумента.Документ ССЫЛКА Документ.Взаимозачет
	|						ТОГДА ВЫРАЗИТЬ(ТаблицаДокумента.Документ КАК Документ.Взаимозачет).Дата
	|				КОНЕЦ
	|		ИНАЧЕ ТаблицаДокумента.Ссылка.Дата
	|	КОНЕЦ КАК ДокументДата,
	|	СУММА(ВЫРАЗИТЬ(ТаблицаДокумента.СуммаРасчетов * ТаблицаДокумента.Курс * КурсыВалютУчетаСрезПоследних.Кратность / (КурсыВалютУчетаСрезПоследних.Курс * ТаблицаДокумента.Кратность) КАК ЧИСЛО(15, 8))) КАК Сумма,
	|	СУММА(ТаблицаДокумента.СуммаРасчетов) КАК СуммаВал,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.Договор.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
