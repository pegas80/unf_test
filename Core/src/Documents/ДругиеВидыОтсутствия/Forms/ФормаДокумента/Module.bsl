&НаКлиенте
Процедура ПроверитьНаличиеСотрудникаТаблицеСотрудники(ИмяТабЧасти, ТекущаяСтрока)
	
	МассивНайденныхСтрок = Объект.Сотрудники.НайтиСтроки(Новый Структура("Сотрудник", ТекущаяСтрока.Сотрудник));
	
	Если МассивНайденныхСтрок.Количество() = 0 Тогда 
		УправлениеНебольшойФирмойКлиент.СообщитьОбОшибке(ЭтотОбъект, 
														НСтр("ru = 'В Таблице ""Сотрудники"" отсутствует выбранный сотрудник'; ka = 'В Таблице ""თანამშრომლები"" отсутствует выбранный сотрудник'; en = 'В Таблице ""Staff"" отсутствует выбранный сотрудник'"),
														ИмяТабЧасти,
														ТекущаяСтрока.НомерСтроки,
														"Сотрудник");
														
		Сотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

