КонецПроцедуры

&НаКлиенте
Процедура загрузить(Команда)
	
	ОчиститьСообщения();
	ЕстьОшибки = ЛОЖЬ;	
	ТаблицаХозрасчетный = загрузитьНаСервере(ЕстьОшибки) ;
		
	Если ЕстьОшибки Тогда
		Сообщить("ცხრილში მოიძებნა არაკორექტული მნიშვნელობები!");
	Иначе
		Закрыть(Новый Структура("АдресТаблицы", ТаблицаХозрасчетный))
	КонецЕсли;

	
КонецПроцедуры

&НаСервере
Функция  загрузитьНаСервере(ЕстьОшибки)
	
	//ТЗЗапасыИЗатраты.Очистить();
	КолСтрок = ТабличнийДокумент.ВысотаТаблицы;	
	Хозрасчетный.Очистить();		
	
	ЕстьОшибки = ЛОЖЬ;
	Для Стр = 2 По КолСтрок Цикл
		
		//НомерСтр =Стр -1 ;
		ИС1 = Формат(Стр, "ЧГ=0");
		
		//Дебет
		СчетДтТекст 	=  ТабличнийДокумент.Область("R"+ИС1+"C1").Текст;
		ВалютаДтТекст   =  ТабличнийДокумент.Область("R"+ИС1+"C2").Текст;
		ВалютнаяСуммаДтТекст = ТабличнийДокумент.Область("R"+ИС1+"C3").Текст;
		КоличествоДтТекст    = ТабличнийДокумент.Область("R"+ИС1+"C4").Текст;
		
		МассивСубконтоДт = Новый Массив();
		МассивСубконтоДт.Добавить(ТабличнийДокумент.Область("R"+ИС1+"C5").Текст);
		МассивСубконтоДт.Добавить(ТабличнийДокумент.Область("R"+ИС1+"C6").Текст);
		МассивСубконтоДт.Добавить(ТабличнийДокумент.Область("R"+ИС1+"C7").Текст);
		
		//Кредит
		СчетКтТекст          = ТабличнийДокумент.Область("R"+ИС1+"C8").Текст;
		ВалютаКтТекст        = ТабличнийДокумент.Область("R"+ИС1+"C9").Текст;
		ВалютнаяСуммаКтТекст = ТабличнийДокумент.Область("R"+ИС1+"C10").Текст;
		КоличествоКтТекст    = ТабличнийДокумент.Область("R"+ИС1+"C11").Текст;
		
		МассивСубконтоКт = Новый Массив();
		МассивСубконтоКт.Добавить(ТабличнийДокумент.Область("R"+ИС1+"C12").Текст);
		МассивСубконтоКт.Добавить(ТабличнийДокумент.Область("R"+ИС1+"C13").Текст);
		МассивСубконтоКт.Добавить(ТабличнийДокумент.Область("R"+ИС1+"C14").Текст);
		
		Сумма = ТабличнийДокумент.Область("R"+ИС1+"C15").Текст;
		
		Если ПустаяСтрока(Сумма) Тогда 
			Сообщить("თანხის ველის შევსება სავალდებულოა" +" " + "სტრ " + Стр);	
			ЕстьОшибки = Истина;		
		КонецЕсли;
		
		СчетДт = ПланыСчетов.Хозрасчетный.НайтиПоКоду(СчетДтТекст);	
		Если ПустаяСтрока(СчетДт) Тогда 	
			СчетДт = ПланыСчетов.Хозрасчетный.НайтиПоНаименованию(СчетДтТекст);							
			Если ПустаяСтрока(СчетДт) Тогда 
				Сообщить("დებეტის ანგარიში ვერ მოიძებნა" +" " + "სტრ " + Стр);	
				ЕстьОшибки = Истина;
			КонецЕсли;
		КонецЕсли;
		
		СчетКт = ПланыСчетов.Хозрасчетный.НайтиПоКоду(СчетКтТекст);	
		Если ПустаяСтрока(СчетКт) Тогда 		
			СчетДт = ПланыСчетов.Хозрасчетный.НайтиПоНаименованию(СчетКтТекст);	
			Если ПустаяСтрока(СчетКт) Тогда 
				Сообщить("კრედიტის ანგარიში ვერ მოიძებნა" +" " + "სტრ " + Стр);
				ЕстьОшибки = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если  ЕстьОшибки Тогда 		
			Продолжить;			
		Иначе 
			
			//Дебет
			НовСтрока	= Хозрасчетный.Добавить();	
			НовСтрока.СчетДт  = СчетДт;
			СтруктураПоискаДт =	НайтиСправочникДокументПоТексте(СчетДт,"Дт",МассивСубконтоДт,НовСтрока);
			
			Если  СтруктураПоискаДт.Свойство("СубконтоДт1") Тогда 
				НовСтрока.ЗначениеСубконтоДт1 = СтруктураПоискаДт.СубконтоДт1;
			КонецЕсли;	
			Если  СтруктураПоискаДт.Свойство("СубконтоДт2") Тогда 
				НовСтрока.ЗначениеСубконтоДт2 = СтруктураПоискаДт.СубконтоДт2;
			КонецЕсли;		
			Если  СтруктураПоискаДт.Свойство("СубконтоДт3") Тогда 
				НовСтрока.ЗначениеСубконтоДт3 = СтруктураПоискаДт.СубконтоДт3;
			КонецЕсли;
			
			Если  СтруктураПоискаДт.Свойство("ВидСубконтоДт1") Тогда 
				НовСтрока.ВидСубконтоДт1 = СтруктураПоискаДт.ВидСубконтоДт1;
			КонецЕсли;		
			Если  СтруктураПоискаДт.Свойство("ВидСубконтоДт2") Тогда 
				НовСтрока.ВидСубконтоДт2 = СтруктураПоискаДт.ВидСубконтоДт2;
			КонецЕсли;		
			Если  СтруктураПоискаДт.Свойство("ВидСубконтоДт3") Тогда 
				НовСтрока.ВидСубконтоДт3 = СтруктураПоискаДт.ВидСубконтоДт3;
			КонецЕсли;
			
			
			Если СчетДт.Валютный Тогда 
				НовСтрока.ВалютаДт      = Справочники.Валюты.НайтиПоНаименованию(ВРег(ВалютаДтТекст));
				НовСтрока.ВалютнаяСуммаДт = ВалютнаяСуммаДтТекст;
			КонецЕсли;
			
			Если СчетДт.Количественный Тогда 
				НовСтрока.КоличествоДт  = КоличествоДтТекст; 
			КонецЕсли;
			
			//НовСтрока.СубконтоДт1   = СубконтоДт1Текст;
			//НовСтрока.СубконтоДт2   = СубконтоДт2Текст;
			//НовСтрока.СубконтоДт3   = СубконтоДт3Текст;
			//                                                    
			
			//Кредит 
			НовСтрока.СчетКт  = СчетКт;
			СтруктураПоискаКт = НайтиСправочникДокументПоТексте(СчетКт,"Кт",МассивСубконтоКт,НовСтрока);
			
			Если СтруктураПоискаКт.Свойство("СубконтоКт1") Тогда 			
				НовСтрока.ЗначениеСубконтоКт1 = СтруктураПоискаКт.СубконтоКт1;
			КонецЕсли;	
			Если СтруктураПоискаКт.Свойство("СубконтоКт2") Тогда 
				НовСтрока.ЗначениеСубконтоКт2 = СтруктураПоискаКт.СубконтоКт2;
			КонецЕсли;	
			Если СтруктураПоискаКт.Свойство("СубконтоКт3") Тогда 
				НовСтрока.ЗначениеСубконтоКт3 = СтруктураПоискаКт.СубконтоКт3;
			КонецЕсли;
			
			Если СтруктураПоискаКт.Свойство("ВидСубконтоКт1") Тогда 
				НовСтрока.ВидСубконтоКт1 = СтруктураПоискаКт.ВидСубконтоКт1;
			КонецЕсли;	
			Если СтруктураПоискаКт.Свойство("ВидСубконтоКт2") Тогда 
				НовСтрока.ВидСубконтоКт2 = СтруктураПоискаКт.ВидСубконтоКт2;
			КонецЕсли;
			Если СтруктураПоискаКт.Свойство("ВидСубконтоКт3") Тогда 
				НовСтрока.ВидСубконтоКт3 = СтруктураПоискаКт.ВидСубконтоКт3;
			КонецЕсли;
			
			
			Если СчетКт.Валютный Тогда 	
				НовСтрока.ВалютаКт      = Справочники.Валюты.НайтиПоНаименованию(ВРег(ВалютаКтТекст));
				НовСтрока.ВалютнаяСуммаКт = ВалютнаяСуммаКтТекст; 		
			КонецЕсли;
			
			Если СчетКт.Количественный Тогда 
				НовСтрока.КоличествоКт  = КоличествоКтТекст; 
			КонецЕсли;
			
			НовСтрока.Сумма  = Сумма;
		КонецЕсли	
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(Хозрасчетный.Выгрузить());
	
	
КонецФункции

&НаСервере
Функция НайтиСправочникДокументПоТексте(СчетДтКт,ДтКт,МассивСубконтоДтКт,НовСтрока)
	
	
	СтруктураВозврата = Новый Структура;
	
	ДанныеСчета = БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(СчетДтКт);
	
	Если ЗначениеЗаполнено(ДанныеСчета) Тогда   
		
		Если ЗначениеЗаполнено(ДанныеСчета.ВидСубконто1) Тогда 				
			СтруктураВозврата.Вставить("ВидСубконто"+ДтКт+1 ,ДанныеСчета.ВидСубконто1);	 
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеСчета.ВидСубконто2) Тогда
			СтруктураВозврата.Вставить("ВидСубконто"+ДтКт+2 ,ДанныеСчета.ВидСубконто2);
			//НовСтрока.ВидСубконтоДт1 =ДанныеСчета.ВидСубконто1 ;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеСчета.ВидСубконто3) Тогда			
			СтруктураВозврата.Вставить("ВидСубконто"+ДтКт+3 ,ДанныеСчета.ВидСубконто3);
			//НовСтрока.ВидСубконтоДт1 = ДанныеСчета.ВидСубконто3 ;
		КонецЕсли;
		
	КонецЕсли;
	
	
	Для Индекс = 1 по 3 Цикл 
		
		ТипЗначенияСубконто = ДанныеСчета["ВидСубконто" + Индекс + "ТипЗначения"];	
		
		Если ТипЗначенияСубконто <> Неопределено Тогда 
			ОбъектПоиска = "";	
			
			//++ 21.08.2025 ONESOFT-4308	
			МассивТипов = ТипЗначенияСубконто.Типы();					
			ОбъектМетаданных = Метаданные.НайтиПоТипу(МассивТипов[0]);  
			//ОбъектМетаданных = Метаданные.НайтиПоТипу(ТипЗначенияСубконто.Типы()[0]);
			//-- 21.08.2025 ONESOFT-4308	
	
			Если Метаданные.Справочники.Содержит(ОбъектМетаданных) Тогда		
				Если ОбъектМетаданных.Имя = "Номенклатура" Тогда 
					
					СтрокаПоиска = МассивСубконтоДтКт[Индекс-1];// ONESOFT-4310
					Если СтрокаПоиска <> "" Тогда 
						ОбъектПоиска = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул",МассивСубконтоДтКт[Индекс-1]);
						Если не ЗначениеЗаполнено(ОбъектПоиска) Тогда 
							ОбъектПоиска = Справочники[ОбъектМетаданных.Имя].НайтиПоКоду(МассивСубконтоДтКт[Индекс-1]);
						КонецЕсли;  
					КонецЕсли;
				Иначе 	
					ОбъектПоиска = Справочники[ОбъектМетаданных.Имя].НайтиПоКоду(МассивСубконтоДтКт[Индекс-1]);	
				КонецЕсли;		
			ИначеЕсли Метаданные.Документы.Содержит(ОбъектМетаданных) Тогда        
				//+++ Дмгг, 15.09.2025, ONESOFT-4320
				//ОбъектПоиска = Документы[ОбъектМетаданных.Имя].НайтиПоНомеру(МассивСубконтоДтКт[Индекс-1]);
				Если ЗначениеЗаполнено(Период) Тогда 
					ОбъектПоиска = Документы[ОбъектМетаданных.Имя].НайтиПоНомеру(МассивСубконтоДтКт[Индекс-1], Период);  
				Иначе   
					ОбъектПоиска = Документы[ОбъектМетаданных.Имя].НайтиПоНомеру(МассивСубконтоДтКт[Индекс-1]);
				КонецЕсли;      
				//--- Дмгг, 15.09.2025, ONESOFT-4320 
			ИначеЕсли Метаданные.Перечисления.Содержит(ОбъектМетаданных) Тогда
				ОбъектПоиска = Перечисления[ОбъектМетаданных.Имя].НайтиПоНомеру(МассивСубконтоДтКт[Индекс-1]);	
			КонецЕсли;
			
			//+++ 21.08.2025 ONESOFT-4308
			Если не ЗначениеЗаполнено(ОбъектПоиска) И МассивТипов.количество() = 2 Тогда 
				ОбъектМетаданных = Метаданные.НайтиПоТипу(МассивТипов[1]);
				Если Метаданные.Справочники.Содержит(ОбъектМетаданных) Тогда		
					Если ОбъектМетаданных.Имя = "Номенклатура" Тогда 
						ОбъектПоиска = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул",МассивСубконтоДтКт[Индекс-1], НачалоГода(ТекущаяДата()));
						Если не ЗначениеЗаполнено(ОбъектПоиска) Тогда 
							ОбъектПоиска = Справочники[ОбъектМетаданных.Имя].НайтиПоКоду(МассивСубконтоДтКт[Индекс-1]);
						КонецЕсли;
					Иначе 	
						ОбъектПоиска = Справочники[ОбъектМетаданных.Имя].НайтиПоКоду(МассивСубконтоДтКт[Индекс-1]);	
					КонецЕсли;		
					
				КонецЕсли;	
			КонецЕсли;
			//-- 21.08.2025 ONESOFT-4308	
			СтруктураВозврата.Вставить("Субконто" + ДтКт + Индекс,ОбъектПоиска);	
			
		КонецЕсли;	
		
	КонецЦикла;
	
	Возврат  СтруктураВозврата ;
	
КонецФункции


