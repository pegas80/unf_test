
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ПараметрыФормы = Новый Структура("Основание", ПараметрКоманды);
	Если ТипЗнч(ПараметрКоманды) = Тип("ДокументСсылка.ПриемИПередачаВРемонт") 
		И ПараметрыВыполненияКоманды.Источник.Объект.ВариантРемонта = ПредопределенноеЗначение("Перечисление.ВариантыРемонта.НашаМастерскаяМногоэтапныйРемонт") 
		Тогда
			ПоказатьПредупреждение(, НСтр("ka='Для выбранного варианта ремонта указывайте оплаты в подчиненных документах - Заказ-наряд, Расходная накладная, Акт';ru='Для выбранного варианта ремонта указывайте оплаты в подчиненных документах - Заказ-наряд, Расходная накладная, Акт';en='To repair the selected option specify payment in subordinate documents - Work Order, Sales Invoice, Act'"));
			Возврат;
	КонецЕсли;
	ОткрытьФорму("Документ.ПоступлениеВКассу.ФормаОбъекта", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно, ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
	СтатистикаИспользованияФормКлиент.ПроверитьЗаписатьСтатистикуКоманды(
		"СоздатьНаОсновании.ПоступлениеВКассу",
		ПараметрыВыполненияКоманды.Источник
	);
	
КонецПроцедуры
