
&НаКлиенте
Процедура ДатаДоставкиПриИзменении(Элемент)
	// Вставить содержимое обработчика.	
	Если Объект.Запасы.Количество() > 0 Тогда 
		
		Для Каждого стр Из Объект.Запасы Цикл 
			
			стр.ДатаДоставки = Объект.ДатаДоставки;
			
		КонецЦикла;
		
		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	// Вставить содержимое обработчика.
	
	Если ЗначениеЗаполнено(Объект.ДатаДоставки) Тогда 
		
		ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.ДатаДоставки = Объект.ДатаДоставки;		
	КонецЕсли;
	
	
	Если ЗначениеЗаполнено(Объект.Проект) Тогда 
		
		ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.Проект = Объект.Проект;		
	КонецЕсли;
	
	ЕдИзи = ПолучитьЕдИзм(ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.Номенклатура);			
	ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.ЕдиницаИзмерения = ЕдИзи;
	//ЭтаФорма.ТекущийЭлемент.ТекущиеДанные.ПередатьВЗаказ = Истина;
КонецПроцедуры


Функция ПолучитьЕдИзм(Номенклатура)
	
	
	Возврат Номенклатура.ЕдиницаИзмерения;	
	
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекущийПользователь = ПользователиКлиентСервер.ТекущийПользователь(); 	
	Объект.Статус = Справочники.СостоянияДокументЗапроса.ВРаботе;
	//Объект.СтруктурнаяЕдиница = ТекущийПользователь;
	Склад = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройки("ОсновнойСклад");
	Подразделение = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройки("ОсновноеПодразделение");
	
	Объект.СтруктурнаяЕдиница = Склад;
	Объект.ДепартаментИспольнитель = Подразделение;		
	
КонецПроцедуры

&НаКлиенте
Процедура ПроектПриИзменении(Элемент)
	Если Объект.Запасы.Количество() > 0 Тогда 
		
		Для Каждого стр Из Объект.Запасы Цикл 
			
			стр.Проект = Объект.Проект;
			
		КонецЦикла;
		
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВиделитьВсе(Команда)
	
	Если Не Объект.Пометка Тогда    
		Для Каждого Строка Из Объект.Запасы Цикл
			Строка.ПередатьВЗаказ = Истина;
			Объект.Пометка = Истина;  
		КонецЦикла;
	Иначе
		Для Каждого Строка Из Объект.Запасы Цикл
			Строка.ПередатьВЗаказ = Ложь;
			Объект.Пометка = Ложь;			
		КонецЦикла;
		
	КонецЕсли; 
КонецПроцедуры
