

Функция  ПечататьДокументЗапрос(МассивОбъектов, ОбъектыПечати, ИмяМакета) Экспорт
	//{{_КОНСТРУКТОР_ПЕЧАТИ(Печать)
	
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ДокументЗапроса";
	Макет = Документы.ДокументЗапроса.ПолучитьМакет("ПечатьДокументЗапрос");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	Шапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьЗапасыШапка = Макет.ПолучитьОбласть("ЗапасыШапка");
	ОбластьЗапасы = Макет.ПолучитьОбласть("Запасы");
	Подвал = Макет.ПолучитьОбласть("Подвал");
	ТабДок.Очистить();
	
	
	
	Для Каждого ДокументЗапроса Из МассивОбъектов Цикл 
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ДокументЗапроса.Дата,
		|	ДокументЗапроса.ДепартаментИспольнитель,
		|	ДокументЗапроса.Заказшик,
		|	ДокументЗапроса.Номер,
		|	ДокументЗапроса.Организация,
		|	ДокументЗапроса.Проект,
		|	ДокументЗапроса.СтруктурнаяЕдиница,
		|	ДокументЗапроса.Запасы.(
		|		Номенклатура,
		|		ЕдиницаИзмерения,
		|		Количество,
		|		ДатаДоставки
		|	)
		|ИЗ
		|	Документ.ДокументЗапроса КАК ДокументЗапроса
		|ГДЕ
		|	ДокументЗапроса.Ссылка В (&Ссылка)";
		Запрос.Параметры.Вставить("Ссылка", ДокументЗапроса
		);
		Выборка = Запрос.Выполнить().Выбрать();
		
		
		
		
		
		ВставлятьРазделительСтраниц = Ложь;
		Пока Выборка.Следующий() Цикл
			Если ВставлятьРазделительСтраниц Тогда
				ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			
			ТабДок.Вывести(ОбластьЗаголовок);
			
			Шапка.Параметры.Заполнить(Выборка);
			
			
			ЛоготипЗаполнен = ЗначениеЗаполнено(Выборка.Организация.ФайлЛоготип);
			Если ЛоготипЗаполнен Тогда
				ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(Выборка.Организация.ФайлЛоготип);
				Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
					Шапка.Рисунки.Логотип.Картинка = Новый Картинка(ДанныеКартинки);
				КонецЕсли;
			КонецЕсли;
			
			
			
			ТабДок.Вывести(Шапка, Выборка.Уровень());
			
			ТабДок.Вывести(ОбластьЗапасыШапка);
			ВыборкаЗапасы = Выборка.Запасы.Выбрать();
			Пока ВыборкаЗапасы.Следующий() Цикл
				ОбластьЗапасы.Параметры.Заполнить(ВыборкаЗапасы);
				ТабДок.Вывести(ОбластьЗапасы, ВыборкаЗапасы.Уровень());
			КонецЦикла;
			
			Подвал.Параметры.Заполнить(Выборка);
			Подвал.Параметры.ПодписьМОЛ = Выборка.ДепартаментИспольнитель.ПодписьМОЛ.РасшифровкаПодписи;
			ТабДок.Вывести(Подвал);
			
			ВставлятьРазделительСтраниц = Истина;
		КонецЦикла;
		
	КонецЦикла;	
	Возврат ТабДок;

	//}}
КонецФункции



// Процедура печати документа.
//
Функция Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода, ИзРМК = Ложь) Экспорт

	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьДокументЗапрос") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ПечатьДокументЗапрос", "Печать Документ Запрос", ПечататьДокументЗапрос(МассивОбъектов, ОбъектыПечати, "Печать Документ Запрос"));
		
	КонецЕсли;
	// параметры отправки печатных форм по электронной почте
	УправлениеНебольшойФирмойСервер.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
	
КонецФункции // Печать()

// Заполняет список команд печати Заказа покупателя
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ПечатьДокументЗапрос";
	КомандаПечати.Представление = НСтр("ka='მოთხოვნის დოკუმენტი';ru='Документ Запрос';en='Requested document'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Ложь;
	КомандаПечати.Порядок = 1;
	
КонецПроцедуры
