&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)

	// Обработка события изменения организации.
	Объект.Номер = "";
	СтруктураДанные = ПолучитьДанныеОрганизацияПриИзменении(Объект.Организация);
	Компания = СтруктураДанные.Компания;
	// Kuzmich, 15.09.2019, Добавление бух проводок в счет фактурах
	УстановитьСчетНДСИзУчетнойПолитики();
	// Kuzmich, 15.09.2019, Добавление бух проводок в счет фактурах
КонецПроцедуры // ОрганизацияПриИзменении()

&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	
	Объект.ДокументыОснования.Очистить();
	
	ОбновитьТоварыИзДокументовОснованияСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьТоварыИзДокументовОснования(Команда)
	
	ОбновитьТоварыИзДокументовОснованияСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьНадписьЦеныИВалюта()
	
	// Сформируем надпись цены и валюты.
	// Валюта.
	Если ЗначениеЗаполнено(Объект.ВалютаДокумента) Тогда
		ЦеныИВалюта = НСтр("ka='ვალუტა: %Валюта%, კურსი: %Курс%';ru='Валюта: %Валюта%, курс: %Курс%';en='Currency: Currency%% Rate:% Rate%'");
		ЦеныИВалюта = СтрЗаменить(ЦеныИВалюта, "%Валюта%", СокрЛП(Строка(Объект.ВалютаДокумента)));
		ЦеныИВалюта = СтрЗаменить(ЦеныИВалюта, "%Курс%", СокрЛП(Строка(Объект.Курс)));
	Иначе 	
		ЦеныИВалюта = НСтр("ka='ვალუტა: <არა>';ru='Валюта: <нет>';en='Currency: <none>'");	
	КонецЕсли;
		
КонецПроцедуры // УстановитьВидимостьИДоступность()	

&НаКлиенте
Процедура ДокументыОснованияПриИзменении(Элемент)
	
	ОбновитьТоварыИзДокументовОснованияСервер();
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыОснованияПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	
	Если Копирование Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыОснованияДокументОснованиеПриИзменении(Элемент, ТекущиеДанные = Неопределено)
	
	Если ТекущиеДанные = Неопределено Тогда
		ТекущиеДанные = Элементы.ДокументыОснования.ТекущиеДанные;
	КонецЕсли;
	
	СтруктураСумм = РС_ОбщегоНазначения.ПолучитьСуммуИНДСДокументаВВалютеРасчета(ТекущиеДанные.ДокументОснование);
	
	ТекущиеДанные.СуммаДокумента = СтруктураСумм.Сумма;
	ТекущиеДанные.СуммаНДС = СтруктураСумм.СуммаНДС;
	ТекущиеДанные.Всего = СтруктураСумм.СуммаВсего;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаВходящегоДокументаПриИзменении(Элемент)
	
	ПриИзмененииПериодаРегистрации(ЭтаФорма, "ДатаВходящегоДокумента", "ОтображениеПериода");
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаВходящегоДокументаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтруктураПараметров = Новый Структура("ДатаКалендаря", ?(Объект.ДатаВходящегоДокумента = Дата('00010101'), ТекущаяДата(), Объект.ДатаВходящегоДокумента));
	ДатаКалендаряНачало = ОткрытьФормуМодально("ОбщаяФорма.ФормаКалендаря", СтруктураПараметров);
	
	Если ДатаКалендаряНачало = Неопределено Тогда
		Объект.ДатаВходящегоДокумента = КонецДня(Объект.ДатаВходящегоДокумента);
	Иначе
		Объект.ДатаВходящегоДокумента = КонецДня(ДатаКалендаряНачало);
	КонецЕсли;
	
	ДатаВходящегоДокументаПриИзменении(Элемент);

КонецПроцедуры

&НаКлиенте
Процедура ДатаВходящегоДокументаРегулирование(Элемент, Направление, СтандартнаяОбработка)
	
	ПриРегулированииПериодаРегистрации(ЭтаФорма, Направление, "ДатаВходящегоДокумента");
	ДатаВходящегоДокументаПриИзменении(Элемент);
	
КонецПроцедуры

&НаКлиенте
Процедура ДокументыОснованияДокументОснованиеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СЗ = Новый СписокЗначений;
	СЗ.Добавить(0, НСтр("ka='გასავლის ზედდებული';ru='Расходная накладная';en='Sales Invoice'"));
	СЗ.Добавить(1, НСтр("ka='შემოსავლის ზედდებული';ru='Приходная накладная';en='Purchase Invoice'"));
	СЗ.Добавить(2, НСтр("ka='დამატებითი ხარჯები';ru='Дополнительные расходы';en='Additional expenses'"));
	СЗ.Добавить(3, НСтр("ka='ვალის კორექტირება';ru='Корректировка долга';en='adjustment of duty'"));
	
	
	ВыбранныйЭлемент = СЗ.ВыбратьЭлемент(НСтр("ka='Выберите тип документа';ru='Выберите тип документа';en='Select the type of document'"));
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ВыбранныйЭлемент.Значение = 0 Тогда
		ИмяДокумента = "РасходнаяНакладная";
	ИначеЕсли ВыбранныйЭлемент.Значение = 1 Тогда
		ИмяДокумента = "ПриходнаяНакладная";
	ИначеЕсли ВыбранныйЭлемент.Значение = 2 Тогда
		ИмяДокумента = "ДополнительныеРасходы";
	ИначеЕсли ВыбранныйЭлемент.Значение = 3 Тогда
		ИмяДокумента = "Взаимозачет";	
	КонецЕсли;
	
	ФормаВыбора = ПолучитьФорму("Документ." + ИмяДокумента + ".ФормаВыбора", , ЭтаФорма);
	ФормаВыбора.Элементы.Список.МножественныйВыбор = Истина;	
	УправлениеНебольшойФирмойКлиентСервер.УстановитьЭлементОтбораСписка(ФормаВыбора.Список, "Контрагент", Объект.Контрагент, ЗначениеЗаполнено(Объект.Контрагент),ВидСравненияКомпоновкиДанных.Равно);
	
	СписокДокументов = ПолучитьСписокДокументов();
	
	УправлениеНебольшойФирмойКлиентСервер.УстановитьЭлементОтбораСписка(ФормаВыбора.Список,"Ссылка",СписокДокументов,,ВидСравненияКомпоновкиДанных.НеВСписке);
	
	ВыбранныеДокументы = ФормаВыбора.ОткрытьМодально();
	
	Если ВыбранныеДокументы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПервыйВыбранныйДокумент = Истина;
	Для Каждого ВыбранныйДокумент Из ВыбранныеДокументы Цикл
		Если Не ПервыйВыбранныйДокумент Тогда
			НоваяСтрокаТЧ = Объект.ДокументыОснования.Добавить();
		Иначе
			НоваяСтрокаТЧ = Элементы.ДокументыОснования.ТекущиеДанные;
		КонецЕсли;
		НоваяСтрокаТЧ.ДокументОснование = ВыбранныйДокумент;
		
		ДокументыОснованияДокументОснованиеПриИзменении(Неопределено, НоваяСтрокаТЧ);
		ПервыйВыбранныйДокумент = Ложь;
	КонецЦикла;
			
	ОбновитьТоварыИзДокументовОснованияСервер();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокДокументов()
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	СчетФактураПолученныйГрузияДокументыОснования.ДокументОснование
	               |ИЗ
	               |	Документ.СчетФактураПолученныйГрузия.ДокументыОснования КАК СчетФактураПолученныйГрузияДокументыОснования
	               |ГДЕ
	               |	СчетФактураПолученныйГрузияДокументыОснования.Ссылка.Проведен = ИСТИНА";
	
	
	МассивДокументов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументОснование");
	
	
	Для Каждого Стр Из Объект.ДокументыОснования Цикл
		Если МассивДокументов.Найти(Стр.ДокументОснование) = Неопределено Тогда
			МассивДокументов.Добавить(Стр.ДокументОснование);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивДокументов;
	
КонецФункции	




