&НаКлиенте
Процедура ДокументыПлатежаДокументНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СписокВыбора = Новый СписокЗначений; 
	СписокВыбора.Добавить(Тип("ДокументСсылка.РасходИзКассы")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.РасходСоСчета")); 
	СписокВыбора.Добавить(Тип("ДокументСсылка.АвансовыйОтчет"));  
	
	ВыбранноеЗначение = ВыбратьИзСписка(СписокВыбора);
	
	Если ВыбранноеЗначение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗначениеОтбора  = Новый Структура;
	Если ВыбранноеЗначение.Значение = Тип("ДокументСсылка.РасходИзКассы") Тогда 
		
		ИмяДокумента = "РасходИзКассы";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходИзКассы.Поставщику"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.РасходСоСчета") Тогда 
		
		ИмяДокумента = "РасходСоСчета";
		ЗначениеОтбора.Вставить("ВидОперации",	ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Поставщику"));
		ЗначениеОтбора.Вставить("Контрагент",	Объект.Контрагент);
		
	ИначеЕсли ВыбранноеЗначение.Значение = Тип("ДокументСсылка.АвансовыйОтчет") Тогда 
		 
		ИмяДокумента = "АвансовыйОтчет";
		ЗначениеОтбора.Вставить("Ссылка",		СписокДокументаВыданногоАванса());
		
	КонецЕсли;

	ЗначениеОтбора.Вставить("Проведен", Истина);
	пПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);   
	Форма = ОткрытьФорму("Документ." +ИмяДокумента+".ФормаВыбора",пПараметрыВыбора,Элемент);
	
КонецПроцедуры

Функция СписокДокументаВыданногоАванса();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АвансовыйОтчетОплаты.Ссылка
		|ИЗ
		|	Документ.АвансовыйОтчет.Оплаты КАК АвансовыйОтчетОплаты
		|ГДЕ
		|	АвансовыйОтчетОплаты.Ссылка.Проведен
		|	И АвансовыйОтчетОплаты.Контрагент = &Контрагент";
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	СписокКонтрагентов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Возврат Новый ФиксированныйМассив(СписокКонтрагентов);
	
КонецФункции

