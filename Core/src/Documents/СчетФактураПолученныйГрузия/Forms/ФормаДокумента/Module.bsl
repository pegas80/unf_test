// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаСервере
Процедура ОбновитьПодвал(ТолькоТоварыДокументовОснования = Ложь)
	
	Если Не ТолькоТоварыДокументовОснования Тогда
		ПодвалНоменклатураТоварыНаПортале = Объект.ТоварыНаПортале.Количество();
		ПодвалКоличествоТоварыНаПортале = Объект.ТоварыНаПортале.Итог("Количество");
		ПодвалСуммаТоварыНаПортале = Объект.ТоварыНаПортале.Итог("Сумма");
		ПодвалСуммаНДСТоварыНаПортале = Объект.ТоварыНаПортале.Итог("СуммаНДС");
		ПодвалСуммаАкцизаТоварыНаПортале = Объект.ТоварыНаПортале.Итог("СуммаАкциза");
	КонецЕсли;
	
	ПодвалНоменклатураТоварыДокументовОснования = ТоварыДокументовОснования.Количество();
	ПодвалКоличествоТоварыДокументовОснования = ТоварыДокументовОснования.Итог("Количество");
	ПодвалСуммаТоварыДокументовОснования = ТоварыДокументовОснования.Итог("Всего");
	ПодвалСуммаНДСТоварыДокументовОснования = ТоварыДокументовОснования.Итог("СуммаНДС");
	ПодвалСуммаАкцизаТоварыДокументовОснования = ТоварыДокументовОснования.Итог("СуммаАкциза");
	
	СуммыРавны = (ПодвалСуммаТоварыНаПортале = ПодвалСуммаТоварыДокументовОснования);
	СуммыНДСРавны = (ПодвалСуммаНДСТоварыНаПортале = ПодвалСуммаНДСТоварыДокументовОснования);
	СуммыАкцизаРавны = (ПодвалСуммаАкцизаТоварыНаПортале = ПодвалСуммаАкцизаТоварыДокументовОснования);
	
	Объект.СуммаДокумента = ПодвалСуммаТоварыДокументовОснования;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТоварыИзДокументовОснованияСервер()
	
	ТоварыДокументовОснования.Очистить();
	
	Для Каждого СтрокаДокументыОснования Из Объект.ДокументыОснования Цикл
		Если ЗначениеЗаполнено(СтрокаДокументыОснования.ДокументОснование) Тогда
			Если Не ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.ДополнительныеРасходы") И
				 Не ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная")Тогда
				Для Каждого СтрокаТЧ Из СтрокаДокументыОснования.ДокументОснование.Запасы Цикл
					СтрокаТЗ = ТоварыДокументовОснования.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаТЧ);
					СтрокаТЗ.НоменклатураКод = СтрокаТЧ.Номенклатура.Код;
					
					СтруктураСумм = РС_ОбщегоНазначения.ПолучитьСуммуИНДСДокументаВВалютеРасчета(СтрокаДокументыОснования.ДокументОснование);
					
					КоефДокумента = СтрокаТЧ.Всего/СтрокаДокументыОснования.ДокументОснование.СуммаДокумента;
					
					СтрокаТЗ.Сумма    = СтруктураСумм.Сумма * КоефДокумента;
					СтрокаТЗ.Всего    = СтруктураСумм.СуммаВсего * КоефДокумента;
					СтрокаТЗ.СуммаНДС = СтруктураСумм.СуммаНДС * КоефДокумента;
				КонецЦикла;
			КонецЕсли;
			
			Если Не ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") И Не ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.ОтчетПереработчика") Тогда
				Для Каждого СтрокаТЧ Из СтрокаДокументыОснования.ДокументОснование.Расходы Цикл
					СтрокаТЗ = ТоварыДокументовОснования.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаТЧ);
					СтрокаТЗ.НоменклатураКод = СтрокаТЧ.Номенклатура.Код;
					
					СтруктураСумм = РС_ОбщегоНазначения.ПолучитьСуммуИНДСДокументаВВалютеРасчета(СтрокаДокументыОснования.ДокументОснование);
					
					КоефДокумента = СтрокаТЧ.Всего/СтрокаДокументыОснования.ДокументОснование.СуммаДокумента;
					
					СтрокаТЗ.Сумма    = СтруктураСумм.Сумма * КоефДокумента;
					СтрокаТЗ.Всего    = СтруктураСумм.СуммаВсего * КоефДокумента;
					СтрокаТЗ.СуммаНДС = СтруктураСумм.СуммаНДС * КоефДокумента;					
				КонецЦикла;
			КонецЕсли;
			
			    //++LAZARE
			Если ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
				Для Каждого СтрокаТЧ Из СтрокаДокументыОснования.ДокументОснование.Запасы Цикл
					СтрокаТЗ = ТоварыДокументовОснования.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаТЧ);
					СтрокаТЗ.НоменклатураКод = СтрокаТЧ.Номенклатура.Код;
					СтруктураСумм = РС_ОбщегоНазначения.ПолучитьСуммуИНДСДокументаВВалютеРасчета(СтрокаДокументыОснования.ДокументОснование);
					КоефДокумента = СтрокаТЧ.Всего/СтрокаДокументыОснования.ДокументОснование.СуммаДокумента;
					СтрокаТЗ.Сумма    = СтруктураСумм.Сумма * КоефДокумента;
					СтрокаТЗ.Всего    = СтруктураСумм.СуммаВсего * КоефДокумента;
					СтрокаТЗ.СуммаНДС = СтруктураСумм.СуммаНДС * КоефДокумента;
				КонецЦикла;
			КонецЕсли;
			//--LAZARE			
			
			Если ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.ОтчетПереработчика") Тогда
				Для Каждого СтрокаТЧ Из СтрокаДокументыОснования.ДокументОснование.Продукция Цикл
					СтрокаТЗ = ТоварыДокументовОснования.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТЗ, СтрокаТЧ);
					СтрокаТЗ.НоменклатураКод = СтрокаТЧ.Номенклатура.Код;
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаДокументыОснования.ДокументОснование) Тогда
			СтруктураСумм = РС_ОбщегоНазначения.ПолучитьСуммуИНДСДокументаВВалютеРасчета(СтрокаДокументыОснования.ДокументОснование);
			
			СтрокаДокументыОснования.СуммаДокумента = СтруктураСумм.Сумма;
