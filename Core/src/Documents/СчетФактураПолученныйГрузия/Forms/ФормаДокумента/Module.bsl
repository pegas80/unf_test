&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//Если Параметры.Свойство("СоздаемИзСчетФактурыНаПортале") Тогда
		ОбновитьТоварыИзДокументовОснованияСервер();
	//КонецЕсли;
	Если Объект.Ссылка.Пустая() Тогда
		Объект.ДокументыПлатежа.Очистить();
		Объект.ТоварыНаПортале.Очистить();
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		Объект.ВидНалога = НЕОПРЕДЕЛЕНО;
		Объект.СчетУчетаКВозмещениюРегл = НЕОПРЕДЕЛЕНО;
		// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	КонецЕсли;
	
	УстановитьВидимость();
	ОбновитьПодвал();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ДатаВходящегоДокументаПриИзменении(Неопределено);
	
	// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) И ЗначениеЗаполнено(Объект.Организация) Тогда
		УстановитьСчетНДСИзУчетнойПолитики();
	КонецЕсли;
	// Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
	
КонецПроцедуры





