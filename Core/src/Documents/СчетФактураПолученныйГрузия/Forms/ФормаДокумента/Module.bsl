Функция ПолучитьСуммуИНДСУДокумента(ДокументСсылка)
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОтчетПереработчика") Тогда
		СуммаДокумент    = ДокументСсылка.Сумма * ДокументСсылка.Курс * ДокументСсылка.Кратность;
		СуммаНДСДокумент = ДокументСсылка.СуммаНДС * ДокументСсылка.Курс * ДокументСсылка.Кратность;
		СуммаВсего       = ДокументСсылка.Всего * ДокументСсылка.Курс * ДокументСсылка.Кратность;
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Взаимозачет") Тогда 
		СуммаДокумент	 = ДокументСсылка.СуммаРасчетов * ДокументСсылка.Курс * ДокументСсылка.Кратность;
		СуммаНДСДокумент = 0;
		СуммаВсего       = ДокументСсылка.СуммаРасчетов * ДокументСсылка.Курс * ДокументСсылка.Кратность;
	Иначе	 
		
		СуммаДокумент = ДокументСсылка.СуммаДокумента * ДокументСсылка.Курс * ДокументСсылка.Кратность;
		//Паганини_
		Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
			СуммаНДСДокумент = ДокументСсылка.Расходы.Итог("СуммаНДС") * ДокументСсылка.Курс * ДокументСсылка.Кратность;
		Иначе//_Паганини
			СуммаНДСДокумент = (ДокументСсылка.Запасы.Итог("СуммаНДС") * ДокументСсылка.Курс * ДокументСсылка.Кратность) + ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная"), ДокументСсылка.Расходы.Итог("СуммаНДС") * ДокументСсылка.Курс * ДокументСсылка.Кратность, 0);
		КонецЕсли;//Паганини
		СуммаВсего = ?(ДокументСсылка.НДСВключатьВСтоимость, СуммаДокумент, СуммаДокумент + СуммаНДСДокумент * ДокументСсылка.Курс * ДокументСсылка.Кратность);
	КонецЕсли;
	
	Возврат Новый Структура("Сумма, СуммаНДС, СуммаВсего", СуммаДокумент, СуммаНДСДокумент, СуммаВсего);
	
КонецФункции

