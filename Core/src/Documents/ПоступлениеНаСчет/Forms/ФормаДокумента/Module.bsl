	КонецЕсли;
	
	Элементы.ДоговорКредита.Доступность = НЕ Объект.Контрагент.Пустая();
	Если Элементы.ДоговорКредита.Доступность Тогда
		Элементы.ДоговорКредита.ПодсказкаВвода = "";
	Иначе
		Элементы.ДоговорКредита.ПодсказкаВвода = НСтр("ka='ხელშეკრულების ასარჩევად აირჩიეთ ბანკი';ru='Чтобы выбрать договор, выберите банк';en='To select the contract, select the bank'");
	КонецЕсли;
	
КонецПроцедуры

