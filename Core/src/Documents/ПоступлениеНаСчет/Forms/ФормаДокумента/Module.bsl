&НаСервере
Процедура УстановитьЗагруженИзИнтернетБанка()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УИДДокументовВИнтернетБанке.ДокументСсылка,
		|	УИДДокументовВИнтернетБанке.УИДДокументаВБанке,
		|	УИДДокументовВИнтернетБанке.Выгружен
		|ИЗ
		|	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|ГДЕ
		|	УИДДокументовВИнтернетБанке.ДокументСсылка = &ДокументСсылка";
	
	Запрос.УстановитьПараметр("ДокументСсылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() > 0 Тогда 
		Элементы.ДекорацияЗагруженИзБанка.Видимость = Истина;
		Элементы.ДекорацияЗагруженИзБанка.Заголовок = НСтр("ka='ჩატვირთული ონლაინ საბანკოდან';ru='Загружен из интернет банка';en='Downloaded from the Internet bank'");
		Элементы.ДекорацияЗагруженИзБанка.ЦветТекста = Новый Цвет(0,255,0);
	КонецЕсли;
	
КонецПроцедуры

