Функция ПолучитьБанковскийСчетПоУмолчанию(Организация)

	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Организации.БанковскийСчетПоУмолчанию
	               |ПОМЕСТИТЬ ВТБанковскиеСчета
	               |ИЗ
	               |	Справочник.Организации КАК Организации
	               |ГДЕ
	               |	Организации.Ссылка = &Организация
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	БанковскиеСчета.Ссылка КАК БанковскийСчетПоУмолчанию
	               |ИЗ
	               |	Справочник.БанковскиеСчета КАК БанковскиеСчета
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТБанковскиеСчета КАК ВТБанковскиеСчета
	               |		ПО (ВТБанковскиеСчета.БанковскийСчетПоУмолчанию = БанковскиеСчета.Ссылка)";
	
	Запрос.УстановитьПараметр("Организация",Организация);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.БанковскийСчетПоУмолчанию;
	Иначе
		Возврат Справочники.БанковскиеСчета.ПустаяСсылка();
	КонецЕсли;	
	
КонецФункции	


