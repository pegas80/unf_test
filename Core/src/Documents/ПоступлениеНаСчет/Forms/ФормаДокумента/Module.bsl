&НаСервере
Процедура ОпределитьВидимостьНастроекУчетаВНалогообложении()
	
	Если РегламентированнаяОтчетностьПереопределяемый.ЭтоЮридическоеЛицо(Объект.Организация) Тогда
		Элементы.ГруппаУчетВНУ.Видимость = Ложь;
		
		Возврат;
	Иначе
		Элементы.ГруппаУчетВНУ.Видимость = Истина;
	КонецЕсли;
	
	СистемаНалогообложенияСтруктура = РегистрыСведений.СистемыНалогообложенияОрганизаций.ОпределитьСистемуНалогообложенияОрганизации(Объект.Организация, Объект.Дата);
	ПлательщикУСН =  СистемаНалогообложенияСтруктура.ПлательщикУСН;
	ПрименяетсяПатент = СистемаНалогообложенияСтруктура.ПрименяетсяПатент;
	
	Если Не ПлательщикУСН И Не ПрименяетсяПатент Тогда
		Элементы.ГруппаУчетВНУ.Видимость = Ложь;
	Иначе
		Если Не ПлательщикУСН Тогда
			Элементы.УчитыватьВНУ.Видимость = Ложь;
		Иначе
			Если Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПокупателя
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПоставщика
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Налоги 
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ПоступлениеОплатыПоКартам
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтКурьерскойКомпанииПочты
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ПрочиеРасчеты Тогда
				Элементы.УчитыватьВНУ.Видимость = Истина;
			Иначе
				Элементы.УчитыватьВНУ.Видимость = Ложь;
			КонецЕсли;
		КонецЕсли;
			
		Если Не ПрименяетсяПатент Тогда
			Элементы.Патент.Видимость = Ложь;
		Иначе
			Элементы.Патент.Доступность = Не Объект.УчитыватьВНУ ИЛИ НЕ Элементы.УчитыватьВНУ.Видимость;
			// Определяем теперь видимость патента от вида операций 
			Если (Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПокупателя
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ПоступлениеОплатыПоКартам
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтКурьерскойКомпанииПочты
				ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ПрочиеРасчеты) Тогда
				Элементы.Патент.Видимость = Истина;
			Иначе
				Элементы.Патент.Видимость = Ложь;
			КонецЕсли;
		КонецЕсли;
		
		Если Элементы.Патент.Видимость ИЛИ Элементы.УчитыватьВНУ.Видимость Тогда
			Элементы.ГруппаУчетВНУ.Видимость = Истина;
		Иначе
			Элементы.ГруппаУчетВНУ.Видимость = Ложь;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНастройкиУчетаВНалогообложении()
	
	ОпределитьВидимостьНастроекУчетаВНалогообложении();
	Если ЗначениеЗаполнено(Объект.Статья) Тогда
		Объект.УчитыватьВНУ = СтатьяУчитываетсяВНУ(Объект.Статья, Объект.Организация, Объект.Дата);
	КонецЕсли;
	
КонецПроцедуры

//+++ Дмгг
Процедура УстановитьВидимостьРеквизитовВЗависимостиОтКорреспонденцииРегл(ОчиститьАналитику = Ложь, ЭлементАналитикиНаименование = "")
	
	Если ЭлементАналитикиНаименование = "" Тогда
		ТекЭлементАналитики = Элементы.АналитикаПрочихДоходовИРасходов;
	Иначе
		ТекЭлементАналитики = Элементы[ЭлементАналитикиНаименование];
	КонецЕсли;
	
	ТекЭлементАналитики.Видимость = Ложь;
	
	ЗначенияРеквитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.КорреспонденцияРегл, "ТипСчета, АналитикаДоходовИРасходов");
	
	Если ЗначенияРеквитов.ТипСчета <> Перечисления.ТипыСчетов.Расходы Тогда
		Если Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее Тогда
			
			Если ОчиститьАналитику И ЗначениеЗаполнено(ЗначенияРеквитов.АналитикаДоходовИРасходов) Тогда
				ТекЭлементАналитики.ОграничениеТипа = Новый ОписаниеТипов(ЗначенияРеквитов.АналитикаДоходовИРасходов);
				ТекЭлементАналитики.Заголовок = Строка(ТекЭлементАналитики.ОграничениеТипа);
				Объект.АналитикаПрочихДоходовИРасходов = Новый(ЗначенияРеквитов.АналитикаДоходовИРасходов);
				ТекЭлементАналитики.Доступность = Истина;
				ТекЭлементАналитики.Видимость = Истина;
				ТекЭлементАналитики.ПодсказкаВвода = "";
			ИначеЕсли ЗначениеЗаполнено(ЗначенияРеквитов.АналитикаДоходовИРасходов) Тогда
				ТекЭлементАналитики.ОграничениеТипа = Новый ОписаниеТипов(ЗначенияРеквитов.АналитикаДоходовИРасходов);
				ТекЭлементАналитики.Заголовок = Строка(ТекЭлементАналитики.ОграничениеТипа);
				ТекЭлементАналитики.Доступность = Истина;
				ТекЭлементАналитики.Видимость = Истина;
				ТекЭлементАналитики.ПодсказкаВвода = "";
			Иначе // Очистить и не заполнена аналитика.
				Объект.АналитикаПрочихДоходовИРасходов = Неопределено;
				ТекЭлементАналитики.Заголовок = "Аналитика доходов";
				ТекЭлементАналитики.ПодсказкаВвода = "<Не настроена у этого счета>";
				ТекЭлементАналитики.Доступность = Ложь;
				ТекЭлементАналитики.Видимость = Истина;
			КонецЕсли;
		Иначе
			ТекЭлементАналитики.Видимость = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьВидимостьДокументыПланирования();
	
КонецПроцедуры // УстановитьВидимостьРеквизитовВЗависимостиОтКорреспонденцииРегл()

