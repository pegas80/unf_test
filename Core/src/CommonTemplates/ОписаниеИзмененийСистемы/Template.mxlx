					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Производство </v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>წარმოება</v8:content>
						</v8:item>
