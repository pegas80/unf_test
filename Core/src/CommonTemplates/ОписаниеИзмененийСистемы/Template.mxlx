					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Печать ТТН и ТОРГ-12</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>სატრანსპორტო ზედნადების და ТОРГ-12-ის ბეჭდვა</v8:content>
						</v8:item>
						<v8:item>
