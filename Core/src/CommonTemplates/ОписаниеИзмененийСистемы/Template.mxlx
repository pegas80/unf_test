				<i>1</i>
				<c>
					<f>12</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Загрузка данных из внешних источников</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>მონაცემთა ჩატვირთვა გარე წყაროებიდან</v8:content>
						</v8:item>
						<v8:item>
