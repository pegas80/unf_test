			<c>
				<i>1</i>
				<c>
					<f>44</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Отчет «Платежный календарь»</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ანგარიშგება "საგადახდო კალენდარი"</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
