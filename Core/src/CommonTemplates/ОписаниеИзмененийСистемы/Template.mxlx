					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Сверка взаиморасчетов</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ურთიერთანგარიშსწორებების შედარება</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Reconciliation of settlements</v8:content>
						</v8:item>
