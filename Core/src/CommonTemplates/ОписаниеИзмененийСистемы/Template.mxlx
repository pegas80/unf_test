					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Права доступа</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>დაშვების უფლებები</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Permissions</v8:content>
