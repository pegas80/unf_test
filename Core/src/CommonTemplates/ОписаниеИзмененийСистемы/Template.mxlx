				<i>1</i>
				<c>
					<f>13</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Мобильная телефония</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>მობილური ტელეფონია</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
