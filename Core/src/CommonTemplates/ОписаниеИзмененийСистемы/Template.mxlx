					<f>38</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Развитие обменов c 1C:Розница</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>1C:საცალო ვაჭრობასთან გაცვლების განვითარება</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
