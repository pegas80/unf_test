					<f>39</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Механизмы ввода на основании</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>საფუძველზე შეყვანის მექანიზმები</v8:content>
						</v8:item>
