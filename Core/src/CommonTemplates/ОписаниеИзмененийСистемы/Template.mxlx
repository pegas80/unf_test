							<v8:lang>ka</v8:lang>
							<v8:content>აღმოჩენილი შეცდომები შესწორებულია.</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Fixed errors identified.</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
