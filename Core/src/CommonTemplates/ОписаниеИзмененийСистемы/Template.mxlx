					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Повышение удобства работы</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>მუშაობის მოხერხებულობის დონის ამაღლება</v8:content>
						</v8:item>
