					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Досье контрагента</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>კონტრაგენტის დოსიე</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>counterparty dossier</v8:content>
						</v8:item>
