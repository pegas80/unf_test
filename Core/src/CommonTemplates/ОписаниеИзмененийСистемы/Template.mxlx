					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Файлы в облачном сервисе</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ფაილები ღრუბლოვან სერვისში</v8:content>
						</v8:item>
