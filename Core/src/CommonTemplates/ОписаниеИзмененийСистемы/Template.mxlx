					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Универсальный отчет</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>უნივერსალური ანგარისგება</v8:content>
						</v8:item>
						<v8:item>
