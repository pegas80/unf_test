	<rowsItem>
		<index>940</index>
		<row>
			<formatIndex>8</formatIndex>
			<c>
				<i>1</i>
				<c>
					<f>13</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Использование сканера штрихкодов для подбора услуг и работ в документах</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>შტრიხკოდების სკანერის გამოყენება დოკუმენტებში მომსახურებების და სამუშაოების გადასარჩევად</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Using a bar code scanner for the selection of works and services in the documents</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
	</rowsItem>
