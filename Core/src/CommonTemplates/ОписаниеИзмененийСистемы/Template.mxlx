						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Загрузка контактов из адресной книги Google</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>კონტაქტების ჩატვირთვა Google-ის სამისამართო წიგნიდან</v8:content>
