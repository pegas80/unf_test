	<rowsItem>
		<index>629</index>
		<row>
			<formatIndex>8</formatIndex>
			<c>
				<i>1</i>
				<c>
					<f>26</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>В отчете «Досье контрагента» добавлена возможность получить сведения о бухгалтерской отчетности контрагента по данным Росстата, а также сведения о результатах проверок контрагента контролирующими органами по данным Единого реестра проверок.</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ანგარიშგება "კონტრაგენტის დოსიე"-ში დამატებულია საქსტატის მონაცემთა მიხედვით კონტრაგენტის საბუღალტრო ანგარიშგებულობის შესახებ ინფორმაციის მიღების შესაძლებლობა, აგრეთვე, შემოწმებების ერთიანი რეესტრის მონაცემთა მიხედვით მაკონტროლებელი ორგანოების მიერ კონტრაგენტის შემოწმებების შედეგების შესახებ ინფორმაციის მიღების შესაძლებლობა.</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>The report "Counterparty Dossier" adds the ability to obtain information about the financial statements of the counterparty to the Rosstat data, as well as information on the results of inspections by contracting authorities according to the Unified Register of inspections.</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
	</rowsItem>
