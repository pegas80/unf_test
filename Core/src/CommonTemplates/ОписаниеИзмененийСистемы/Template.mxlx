					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Категории номенклатуры</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ნომენკლატურის კატეგორიები</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>category nomenclature</v8:content>
						</v8:item>
					</tl>
