				<i>1</i>
				<c>
					<f>12</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Регламентированная отчетность для индивидуального предпринимателя</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>რეგლამენტირებული ანგარიშგებულობა ინდივიდუალური მეწარმისთვის</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Regulatory reporting for the individual entrepreneur</v8:content>
						</v8:item>
