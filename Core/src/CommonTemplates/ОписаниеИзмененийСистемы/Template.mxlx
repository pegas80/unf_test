					<f>13</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Заполнение недостающих реквизитов перед печатью счёта на оплату</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>უკმარი რეკვიზიტების შევსება გადასახდელი ანგარიშის ამობეჭდვის წინ</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Filling in the missing details before printing the invoice for payment</v8:content>
						</v8:item>
