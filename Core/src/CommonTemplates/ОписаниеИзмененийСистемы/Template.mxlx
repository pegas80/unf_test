	<rowsItem>
		<index>642</index>
		<row>
			<formatIndex>8</formatIndex>
			<c>
				<i>1</i>
				<c>
					<f>11</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>http://its.1c.ru/updinfo/smallbusiness/1.6.3</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>http://its.1c.ru/updinfo/smallbusiness/1.6.3</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>http://its.1c.ru/updinfo/smallbusiness/1.6.3</v8:content>
						</v8:item>
