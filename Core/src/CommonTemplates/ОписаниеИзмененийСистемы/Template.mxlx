					<f>39</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Изменения в отчетах</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ცვლილებები ანგარიშგებებში</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
