					<f>13</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Использование сканера штрихкодов и терминала сбора данных (ТСД) при вводе начальных остатков</v8:content>
						</v8:item>
						<v8:item>
