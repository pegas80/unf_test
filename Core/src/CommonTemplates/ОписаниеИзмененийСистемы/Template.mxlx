	<rowsItem>
		<index>1396</index>
		<row>
			<formatIndex>8</formatIndex>
			<c>
				<i>1</i>
				<c>
					<f>42</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Заполнение реквизитов контрагента по данным ЕГРЮЛ и ЕГРИП</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>კონტრაგენტის რეკვიზიტების შევსება იპესრ-ის და იმესრ-ის მონაცემთა მიხედვით</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>Filling counterparty details according to EGRUL and EGRIP</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
	</rowsItem>
