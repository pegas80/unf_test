					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Автономное рабочее место</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ავტონომიური სამუშაო ადგილი</v8:content>
