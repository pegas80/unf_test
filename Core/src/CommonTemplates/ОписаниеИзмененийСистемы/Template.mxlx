					<f>39</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Производственный календарь</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>საწარმოო კალენდარი</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
