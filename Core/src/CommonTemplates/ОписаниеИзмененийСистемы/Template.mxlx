					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Денежные средства</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ფულადი სახსრები</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
