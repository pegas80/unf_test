					<f>38</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Дисконтные карты</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>დისკონტური ბარათები</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
