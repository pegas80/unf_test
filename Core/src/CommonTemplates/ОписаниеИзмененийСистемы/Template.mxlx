					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Авансовый отчет</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>საავანსო ანგარიში</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>advance statement</v8:content>
						</v8:item>
					</tl>
