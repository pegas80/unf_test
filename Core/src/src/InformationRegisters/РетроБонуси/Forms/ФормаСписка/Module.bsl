

&НаКлиенте
Процедура ЗагрузкаИзФайла(Команда)
	
	АдресЗарплатыВХранилище = ПоместитьЗарплатыВХранилище();
	ПараметрыЗаполнения = Новый Структура("АдресЗарплатыВХранилище", АдресЗарплатыВХранилище);
	
	ОткрытьФорму("РегистрСведений.РетроБонуси.Форма.ФормаЗагрузкеИзТабличногоДокумента",ПараметрыЗаполнения , ЭтаФорма, , , ,Новый ОписаниеОповещения("ЗаполнениеЗарплатыЗавершение", ЭтотОбъект,Новый Структура("АдресЗарплатыВХранилище", АдресЗарплатыВХранилище)) , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Функция ПоместитьЗарплатыВХранилище()
			 
	Возврат ПоместитьВоВременноеХранилище("", УникальныйИдентификатор );
	
КонецФункции

&НаКлиенте
Процедура ЗаполнениеЗарплатыЗавершение(Результат, ДополнительныеПараметры) Экспорт
    
    АдресЗарплатыВХранилище = ДополнительныеПараметры.АдресЗарплатыВХранилище;
    
    КодВозврата = Результат;
    
	ЗаполнениеЗарплатыФрагмент(АдресЗарплатыВХранилище, КодВозврата);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнениеЗарплатыФрагмент(Знач АдресЗарплатыВХранилище, Знач КодВозврата)
	
	ПолучитьЗарплатыИзХранилища(АдресЗарплатыВХранилище);
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьЗарплатыИзХранилища(АдресЗарплатыВХранилище)
			
	//Объект.НачисленияУдержания.Очистить();
	//Объект.НалогиНаДоходы.Очистить();
	//Объект.Удержания.Очистить();

	
	ТаблицаДляЗагрузки = ПолучитьИзВременногоХранилища(АдресЗарплатыВХранилище);
	
	Если  ТаблицаДляЗагрузки <> ""  Тогда 
		
		НаборЗаписей = РегистрыСведений.РетроБонуси.СоздатьНаборЗаписей();
		//НаборЗаписей.Прочитать();	
		

			
		Для Каждого СтрокаТаблицы Из ТаблицаДляЗагрузки Цикл 
				
			//НаборЗаписей = РегистрыСведений.РетроБонуси.СоздатьНаборЗаписей();
			//
			//НаборЗаписей.Отбор.Объект.Установить(СтрокаТаблицы.Период); 
			
				НаборЗаписей.Отбор.Период.Установить(СтрокаТаблицы.Период);
				//НаборЗаписей.Отбор.Контрагент.Установить(СтрокаТаблицы.Контрагент);
				НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТаблицы.Номенклатура);
				НаборЗаписей.Прочитать();

				НоваяЗапись = НаборЗаписей.Добавить(); 
				
				НоваяЗапись.Период 	   = СтрокаТаблицы.Период; 
				НоваяЗапись.Контрагент = СтрокаТаблицы.Контрагент;  	
				НоваяЗапись.ДоговорКонтрагента = СтрокаТаблицы.Контрагент.ДоговорПоУмолчанию; 				
				НоваяЗапись.Номенклатура	 = СтрокаТаблицы.Номенклатура;	
				
				Если СтрокаТаблицы.Номенклатура.СтавкаНДС = Справочники.СтавкиНДС.НДС18 Тогда 
					НоваяЗапись.НалогообложениеНДС = НСТР("ru = ' НДС 18% '; ka = 'დასაბეგრი'");
				ИначеЕсли  СтрокаТаблицы.Номенклатура.СтавкаНДС = Справочники.СтавкиНДС.ОсвобожденОтНДС Тогда 
					НоваяЗапись.Номенклатура.НалогообложениеНДС = НСТР("ru = 'Освобожден от НДС'; ka = 'დაუბეგრავი'");		
				ИначеЕсли  СтрокаТаблицы.Номенклатура.СтавкаНДС = Справочники.СтавкиНДС.БезНДС Тогда 
					НоваяЗапись.НалогообложениеНДС = НСТР("ru = '(-)'; ka = '(-)'");
				Иначе 
					НоваяЗапись.НалогообложениеНДС = НСТР("ru = '(-)'; ka = '(-)'");
				КонецЕсли;
								
				НоваяЗапись.РозничнаяВесовая = СтрокаТаблицы.РозничнаяВесовая;	
				НоваяЗапись.ПроцентМаркетинговогоБюджета = СтрокаТаблицы.ПроцентМаркетинговогоБюджета;
				НоваяЗапись.Процент = СтрокаТаблицы.ПроцентРетробонуса;
				НоваяЗапись.Активность = Истина ;
				НоваяЗапись.АктивностьРетроБонуса = Истина ;	
				НаборЗаписей.Записать();
			
		КонецЦикла;
		
		//НаборЗаписей.Записать();
		
		
		//РаспределитьНДФЛ();
		//ОбновитьПодвалФормы();
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;

	
КонецПроцедуры
