#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Запись Из ЭтотОбъект Цикл
		Если Запись.Применяется Тогда
			Запись.Представление = 
				СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka='თანხა ხარჯი: %1';ru='Сумма расхода:%1';en='Flow amount: 1%'"), Запись.СуммаРасходов)
				+ ?(ЗначениеЗаполнено(Запись.КодИФНС), СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka=', საგადასახადო სამსახურის ინსპექციის კოდი:%1';ru=', код ИФНС:%1';en=', The IRS code:% 1'"),Запись.КодИФНС),"")
				+ ?(ЗначениеЗаполнено(Запись.НомерУведомления), СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka=', номер уведомления:%1';ru=', номер уведомления:%1';en=', Notification number:% 1'"),Запись.НомерУведомления),"")
				+ ?(ЗначениеЗаполнено(Запись.ДатаУведомления), СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka=', შეტყობინების თარიღი:%1';ru=', дата уведомления:%1';en=', The date of notification:% 1'"),Запись.ДатаУведомления),"");
			Иначе
				Запись.Представление =  НСтр("ka='Социальный вычет не применяется';ru='Социальный вычет не применяется';en='Social deduction does not apply'");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецЕсли