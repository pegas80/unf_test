&НаСервере
// Функция возвращает вид регистра.
//
Функция ОпределитьВидРегистраСиноним(МетаданныеРегистра)
	
	Если Метаданные.РегистрыНакопления.Индекс(МетаданныеРегистра) >= 0 Тогда
		Возврат НСтр("ka='დაგროვებითი';ru='Накопления';en='accumulation'");
		
	ИначеЕсли Метаданные.РегистрыСведений.Индекс(МетаданныеРегистра) >= 0 Тогда
		Возврат НСтр("ka='ინფორმაციული';ru='Сведений';en='information'");	
		
	ИначеЕсли Метаданные.РегистрыБухгалтерии.Индекс(МетаданныеРегистра) >= 0 Тогда
		Возврат НСтр("ka='ბუღალტრული';ru='Бухгалтерии';en='accounting'");
		
	Иначе
		Возврат "";
			
	КонецЕсли;
    	
КонецФункции
