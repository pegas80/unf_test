		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДенежныеСредства.Организация КАК Организация,
	ДенежныеСредства.Статья КАК СтатьяПриход,
	ДенежныеСредства.Проект КАК Проект,
	СУММА(ДенежныеСредства.Сумма) КАК СуммаПриход,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ДЕНЬ) КАК ПериодДень,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, НЕДЕЛЯ) КАК ПериодНеделя,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ДЕКАДА) КАК ПериодДекада,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, МЕСЯЦ) КАК ПериодМесяц,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, КВАРТАЛ) КАК ПериодКвартал,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ГОД) КАК ПериодГод,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, МИНУТА) КАК ПериодЧас,
	НАЧАЛОПЕРИОДА(ДенежныеСредства.Период, ЧАС) КАК ПериодМинута,
	ДенежныеСредства.Период КАК ПериодСекунда
ИЗ
	РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
ГДЕ
	ДенежныеСредства.Сумма &gt; 0
	И ДенежныеСредства.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	И ВЫБОР
			КОГДА &amp;КонецПериода = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА ДенежныеСредства.Период &gt;= &amp;НачалоПериода
			ИНАЧЕ ДенежныеСредства.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
		КОНЕЦ

СГРУППИРОВАТЬ ПО
	ДенежныеСредства.Организация,
	ДенежныеСредства.Статья,
	ДенежныеСредства.Проект,
	ДенежныеСредства.Период</query>
	</dataSet>
