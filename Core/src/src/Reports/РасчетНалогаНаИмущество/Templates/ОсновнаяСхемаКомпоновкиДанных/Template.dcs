	ВТ.ДатаВВодаВЕксплуатацию КАК ДатаВВодаВЕксплуатацию,
	ВТ_1_2.СтоимостьНачальныйОстаток1 КАК СтоимостьНачальныйОстаток1,
	ВТ_1_2.СтоимостьКонечныйОстаток1 КАК СтоимостьКонечныйОстаток1,
	ВТ_1_2.СтоимостьОборот1 КАК СтоимостьОборот1,
	ВТ_1_2.СтоимостьПриход1 КАК СтоимостьПриход1,
	ВТ_1_2.СтоимостьРасход1 КАК СтоимостьРасход1,
	ВТ_1_2.АмортизацияНачальныйОстаток1 КАК АмортизацияНачальныйОстаток1,
	ВТ_1_2.АмортизацияКонечныйОстаток1 КАК АмортизацияКонечныйОстаток1,
	ВТ_1_2.АмортизацияОборот1 КАК АмортизацияОборот1,
	ВТ_1_2.АмортизацияПриход1 КАК АмортизацияПриход1,
	ВТ_1_2.АмортизацияРасход1 КАК АмортизацияРасход1,
	ВТ_1_2.СтоимостьИзменение1 КАК СтоимостьИзменение1,
	ВТ_1_2.СтоимостьОстаточная1 КАК СтоимостьОстаточная1,
	ВТ_1_2.Год1 КАК Год1,
	ВТ_1_2.СтоимостьНачальныйОстаток2 КАК СтоимостьНачальныйОстаток2,
	ВТ_1_2.СтоимостьКонечныйОстаток2 КАК СтоимостьКонечныйОстаток2,
	ВТ_1_2.СтоимостьОборот2 КАК СтоимостьОборот2,
	ВТ_1_2.СтоимостьПриход2 КАК СтоимостьПриход2,
	ВТ_1_2.СтоимостьРасход2 КАК СтоимостьРасход2,
	ВТ_1_2.АмортизацияНачальныйОстаток2 КАК АмортизацияНачальныйОстаток2,
	ВТ_1_2.АмортизацияКонечныйОстаток2 КАК АмортизацияКонечныйОстаток2,
	ВТ_1_2.АмортизацияОборот2 КАК АмортизацияОборот2,
	ВТ_1_2.АмортизацияПриход2 КАК АмортизацияПриход2,
	ВТ_1_2.АмортизацияРасход2 КАК АмортизацияРасход2,
	ВТ_1_2.СтоимостьИзменение2 КАК СтоимостьИзменение2,
	ВТ_1_2.СтоимостьОстаточная2 КАК СтоимостьОстаточная2,
	ВТ_1_2.Год2 КАК Год2,
	ВЫБОР
		КОГДА ВТ_1_2.СтоимостьНачальныйОстаток1 = 0
			ТОГДА ВЫРАЗИТЬ((ВТ_1_2.СтоимостьИзменение1 + ВТ_1_2.СтоимостьОстаточная1) / 2 КАК ЧИСЛО(18, 2))
		ИНАЧЕ ВЫРАЗИТЬ((ВТ_1_2.СтоимостьНачальныйОстаток1 + ВТ_1_2.СтоимостьОстаточная1) / 2 КАК ЧИСЛО(18, 2))
	КОНЕЦ КАК СредняяБалансоваяСтоимость1,
	ВЫБОР
		КОГДА ВТ_1_2.СтоимостьНачальныйОстаток2 = 0
			ТОГДА ВЫРАЗИТЬ((ВТ_1_2.СтоимостьИзменение2 + ВТ_1_2.СтоимостьОстаточная2) / 2 КАК ЧИСЛО(18, 2))
		ИНАЧЕ ВЫРАЗИТЬ((ВТ_1_2.СтоимостьНачальныйОстаток2 + ВТ_1_2.СтоимостьОстаточная2) / 2 КАК ЧИСЛО(18, 2))
	КОНЕЦ КАК СредняяБалансоваяСтоимость2,
	ВТ.ГодовойПроцентАмортизацииДляУменьшенногоОстатка КАК ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
	1 КАК КоличествоКуплено,
	ВЫБОР
		КОГДА СостоянияВнеоборотныхАктивовСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияВнеоборотныхАктивов.СнятСУчета)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК СнятСУчетаКоличество,
	ВЫБОР
		КОГДА СостоянияВнеоборотныхАктивовСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияВнеоборотныхАктивов.СнятСУчета)
			ТОГДА НАЧАЛОПЕРИОДА(СостоянияВнеоборотныхАктивовСрезПоследних.Период, ДЕНЬ)
		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	КОНЕЦ КАК ДатаСнятияСУчета,
	ВЫРАЗИТЬ(ВЫБОР
			КОГДА ВТ_1_2.СтоимостьНачальныйОстаток1 = 0
				ТОГДА ВЫРАЗИТЬ((ВТ_1_2.СтоимостьИзменение1 + ВТ_1_2.СтоимостьОстаточная1) / 2 КАК ЧИСЛО(18, 2))
			ИНАЧЕ ВЫРАЗИТЬ((ВТ_1_2.СтоимостьНачальныйОстаток1 + ВТ_1_2.СтоимостьОстаточная1) / 2 КАК ЧИСЛО(18, 2))
		КОНЕЦ * ВТ_1_2.ВнеоборотныйАктив.ПроцентНалогаИмущества / 100 КАК ЧИСЛО(18, 2)) КАК НалогНаИмущество1,
	ВЫРАЗИТЬ(ВЫБОР
			КОГДА ВТ_1_2.СтоимостьНачальныйОстаток2 = 0
				ТОГДА ВЫРАЗИТЬ((ВТ_1_2.СтоимостьИзменение2 + ВТ_1_2.СтоимостьОстаточная2) / 2 КАК ЧИСЛО(18, 2))
			ИНАЧЕ ВЫРАЗИТЬ((ВТ_1_2.СтоимостьНачальныйОстаток2 + ВТ_1_2.СтоимостьОстаточная2) / 2 КАК ЧИСЛО(18, 2))
		КОНЕЦ * ВТ_1_2.ВнеоборотныйАктив.ПроцентНалогаИмущества / 100 КАК ЧИСЛО(18, 2)) КАК НалогНаИмущество2,
	ВТ_1_2.ВнеоборотныйАктив.СчетУчетаРегл.Код + ", " + ВТ_1_2.ВнеоборотныйАктив.СчетУчетаРегл.Наименование КАК СчетУчета_Код_Наименование,
	ВТ_1_2.АмортизацияПриход1 + ВТ_1_2.АмортизацияПриход2 КАК АмортизацияВсего,
	ВТ_1_2.СтоимостьИзменение1 + ВТ_1_2.СтоимостьИзменение2 КАК ИзменениеВсего,
	ВТ_1_2.СтоимостьОстаточная2 КАК ОстаточнаяТекущий,
	ВЫБОР
		КОГДА СостоянияВнеоборотныхАктивовСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияВнеоборотныхАктивов.СнятСУчета)
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК ТекущийКоличественныйОстаток
ИЗ
	ВТ_1_2 КАК ВТ_1_2
		ЛЕВОЕ СОЕДИНЕНИЕ Вт2 КАК ВТ
		ПО ВТ_1_2.Организация = ВТ.Организация
			И ВТ_1_2.ВнеоборотныйАктив = ВТ.ВнеоборотныйАктив
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(ДАТАВРЕМЯ(2222, 2, 2), ) КАК СостоянияВнеоборотныхАктивовСрезПоследних
		ПО ВТ_1_2.Организация = СостоянияВнеоборотныхАктивовСрезПоследних.Организация
			И ВТ_1_2.ВнеоборотныйАктив = СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив</query>
	</dataSet>
