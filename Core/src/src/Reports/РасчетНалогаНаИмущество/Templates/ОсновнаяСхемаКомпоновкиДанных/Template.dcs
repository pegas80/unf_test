	ЕСТЬNULL(ВТ_Год1.СтоимостьКонечныйОстаток1, 0) КАК СтоимостьКонечныйОстаток1,
	ЕСТЬNULL(ВТ_Год1.СтоимостьОборот1, 0) КАК СтоимостьОборот1,
	ЕСТЬNULL(ВТ_Год1.СтоимостьПриход1, 0) КАК СтоимостьПриход1,
	ЕСТЬNULL(ВТ_Год1.СтоимостьРасход1, 0) КАК СтоимостьРасход1,
	ЕСТЬNULL(ВТ_Год1.АмортизацияНачальныйОстаток1, 0) КАК АмортизацияНачальныйОстаток1,
	ЕСТЬNULL(ВТ_Год1.АмортизацияКонечныйОстаток1, 0) КАК АмортизацияКонечныйОстаток1,
	ЕСТЬNULL(ВТ_Год1.АмортизацияОборот1, 0) КАК АмортизацияОборот1,
	ЕСТЬNULL(ВТ_Год1.АмортизацияПриход1, 0) КАК АмортизацияПриход1,
	ЕСТЬNULL(ВТ_Год1.АмортизацияРасход1, 0) КАК АмортизацияРасход1,
	ЕСТЬNULL(ВТ_Год1.СтоимостьИзменение1, 0) КАК СтоимостьИзменение1,
	ЕСТЬNULL(ВТ_Год1.СтоимостьОстаточная1, 0) КАК СтоимостьОстаточная1,
	&amp;Год1 КАК Год1,
	ЕСТЬNULL(ВТ_Год1.СтоимостьОстаточная1, 0) КАК СтоимостьНачальныйОстаток2,
	ЕСТЬNULL(ВТ_Год2.СтоимостьКонечныйОстаток2, 0) КАК СтоимостьКонечныйОстаток2,
	ЕСТЬNULL(ВТ_Год2.СтоимостьОборот2, 0) КАК СтоимостьОборот2,
	ЕСТЬNULL(ВТ_Год2.СтоимостьПриход2, 0) КАК СтоимостьПриход2,
	ЕСТЬNULL(ВТ_Год2.СтоимостьРасход2, 0) КАК СтоимостьРасход2,
	ЕСТЬNULL(ВТ_Год2.АмортизацияНачальныйОстаток2, 0) КАК АмортизацияНачальныйОстаток2,
	ЕСТЬNULL(ВТ_Год2.АмортизацияКонечныйОстаток2, 0) КАК АмортизацияКонечныйОстаток2,
	ЕСТЬNULL(ВТ_Год2.АмортизацияОборот2, 0) КАК АмортизацияОборот2,
	ЕСТЬNULL(ВТ_Год2.АмортизацияПриход2, 0) КАК АмортизацияПриход2,
	ЕСТЬNULL(ВТ_Год2.АмортизацияРасход2, 0) КАК АмортизацияРасход2,
	ЕСТЬNULL(ВТ_Год2.СтоимостьИзменение2, 0) КАК СтоимостьИзменение2,
	ЕСТЬNULL(ВТ_Год2.СтоимостьОстаточная2, 0) КАК СтоимостьОстаточная2,
	&amp;Год2 КАК Год2
ПОМЕСТИТЬ ВТ_1_2
ИЗ
