	СУММА(ВТ_Год1.СтоимостьПриход) КАК СтоимостьПриход1,
	СУММА(ВТ_Год1.СтоимостьРасход) КАК СтоимостьРасход1,
	СУММА(ВТ_Год1.АмортизацияНачальныйОстаток) КАК АмортизацияНачальныйОстаток1,
	СУММА(ВТ_Год1.АмортизацияКонечныйОстаток) КАК АмортизацияКонечныйОстаток1,
	СУММА(ВТ_Год1.АмортизацияОборот) КАК АмортизацияОборот1,
	СУММА(ВТ_Год1.АмортизацияПриход) КАК АмортизацияПриход1,
	СУММА(ВТ_Год1.АмортизацияРасход) КАК АмортизацияРасход1,
	СУММА(ВТ_Год1.СтоимостьПриход - ВТ_Год1.СтоимостьРасход) КАК СтоимостьИзменение1,
