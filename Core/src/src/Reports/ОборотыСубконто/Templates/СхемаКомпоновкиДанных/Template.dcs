			<field xsi:type="DataSetFieldField">
				<dataPath>Субконто1Представление</dataPath>
				<field>Субконто1Представление</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Субконто1 представление</v8:content>
					</v8:item>
					<v8:item>
