			<field xsi:type="DataSetFieldField">
				<dataPath>ВидСубконто</dataPath>
				<field>ВидСубконто</field>
			</field>
			<dataSource>ИнформационнаяБаза</dataSource>
			<query>ВЫБРАТЬ
	ХозрасчетныйВидыСубконто.Ссылка КАК Счет,
	ХозрасчетныйВидыСубконто.ВидСубконто КАК ВидСубконто
ПОМЕСТИТЬ ВТ_СчетаВидСубконто
ИЗ
	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
ГДЕ
	ХозрасчетныйВидыСубконто.ВидСубконто = &amp;ВидСубконто
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_СчетаВидСубконто.Счет КАК Счет,
	ВТ_СчетаВидСубконто.ВидСубконто КАК ВидСубконто
ПОМЕСТИТЬ ВТ_ВидСубконто
ИЗ
	ВТ_СчетаВидСубконто КАК ВТ_СчетаВидСубконто

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	ХозрасчетныйВидыСубконто.Ссылка,
	ХозрасчетныйВидыСубконто.ВидСубконто
ИЗ
	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
ГДЕ
	ХозрасчетныйВидыСубконто.НомерСтроки = 1
	И НЕ ХозрасчетныйВидыСубконто.Ссылка В
				(ВЫБРАТЬ
					ВТ_СчетаВидСубконто.Счет
				ИЗ
					ВТ_СчетаВидСубконто)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ХозрасчетныйОбороты.Счет КАК Счет,
	ХозрасчетныйОбороты.Субконто1 КАК Субконто1,
	ХозрасчетныйОбороты.Субконто2 КАК Субконто2,
	ХозрасчетныйОбороты.Субконто3 КАК Субконто3,
	ХозрасчетныйОбороты.КорСчет КАК КорСчет,
	ХозрасчетныйОбороты.КорСубконто1 КАК КорСубконто1,
	ХозрасчетныйОбороты.КорСубконто2 КАК КорСубконто2,
	ХозрасчетныйОбороты.КорСубконто3 КАК КорСубконто3,
	ХозрасчетныйОбороты.Организация КАК Организация,
	ХозрасчетныйОбороты.Валюта КАК Валюта,
	ХозрасчетныйОбороты.Подразделение КАК Подразделение,
	ХозрасчетныйОбороты.СуммаОборотДт КАК БУОборотДт,
	ХозрасчетныйОбороты.СуммаОборотКт КАК БУОборотКт,
	ХозрасчетныйОбороты.ВалютнаяСуммаОборотДт КАК ВалютнаяСуммаОборотДт,
	ХозрасчетныйОбороты.ВалютнаяСуммаОборотКт КАК ВалютнаяСуммаОборотКт,
	ХозрасчетныйОбороты.КоличествоОборотДт КАК КоличествоОборотДт,
	ХозрасчетныйОбороты.КоличествоОборотКт КАК КоличествоОборотКт,
	ХозрасчетныйОбороты.Период КАК Период,
	ХозрасчетныйОбороты.Регистратор КАК Регистратор,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.Субконто1) КАК Субконто1Представление,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.Субконто2) КАК Субконто2Представление,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.Субконто3) КАК Субконто3Представление,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.Подразделение) КАК ПодразделениеПредставление,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.КорСубконто1) КАК КорСубконто1Представление,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.КорСубконто2) КАК КорСубконто2Представление,
	ПРЕДСТАВЛЕНИЕССЫЛКИ(ХозрасчетныйОбороты.КорСубконто3) КАК КорСубконто3Представление
	
	,ВТ_ВидСубконто.ВидСубконто КАК ВидСубконто
{ВЫБРАТЬ
	Субконто1Представление,
	Субконто2Представление,
	Субконто3Представление,
	ПодразделениеПредставление,
	КорСубконто1Представление,
	КорСубконто2Представление,
	КорСубконто3Представление}
ИЗ
	РегистрБухгалтерии.Хозрасчетный.Обороты({(&amp;НачалоПериода)}, {(&amp;КонецПериода)}, Регистратор {(&amp;Периодичность)}, Счет В ИЕРАРХИИ(&amp;Счет)
		, //[УсловиеВидСубконто]
		, 
		{
			(Субконто1).* КАК Субконто1, (Субконто2).* КАК Субконто2, (Субконто3).* КАК Субконто3, (ВалютаКор).* КАК КорВалюта, (ПодразделениеКор).* КАК КорПодразделение, (Организация).* КАК Организация, (Подразделение).* КАК Подразделение, (Валюта).* КАК Валюта, (КорСубконто1).* КАК КорСубконто1, (КорСубконто2).* КАК КорСубконто2, (КорСубконто3).* КАК КорСубконто3
		}, , ) КАК ХозрасчетныйОбороты
ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВидСубконто
	ПО ХозрасчетныйОбороты.Счет = ВТ_ВидСубконто.Счет</query>
		</item>
	</dataSet>
	<dataSetLink>
