		<field xsi:type="DataSetFieldField">
			<dataPath>ОсталосьОбеспечитьСобр</dataPath>
			<field>ОсталосьОбеспечитьСобр</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>It remains to ensure</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Осталось обеспечить</v8:content>
				</v8:item>
				<v8:item>
