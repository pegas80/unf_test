		<field xsi:type="DataSetFieldField">
			<dataPath>ЗарезервированоНаСкладе1</dataPath>
			<field>ЗарезервированоНаСкладе1</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Зарезервировано на складе1</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗаказыПокупателейОстаткиИОбороты.Организация КАК Организация,
	ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя КАК ЗаказПокупателя,
	ЗаказыПокупателейОстаткиИОбороты.Номенклатура КАК Номенклатура,
	ЗаказыПокупателейОстаткиИОбороты.Характеристика КАК Характеристика,
	ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя.Контрагент КАК Контрагент,
	ЗаказыПокупателейОстаткиИОбороты.КоличествоПриход КАК Заказано,
	ЗаказыПокупателейОстаткиИОбороты.КоличествоРасход КАК Отгружено,
	ЗаказыПокупателейОстаткиИОбороты.КоличествоКонечныйОстаток КАК ОсталосьОтгрузить,
	ВЫБОР
		КОГДА ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя.ВариантЗавершения = ЗНАЧЕНИЕ(перечисление.ВариантыЗавершенияЗаказа.Успешно)
			ТОГДА ЗаказыПокупателейОстаткиИОбороты.КоличествоКонечныйОстаток = 0
		ИНАЧЕ ЗаказыПокупателейОстаткиИОбороты.КоличествоКонечныйОстаток
	КОНЕЦ КАК ОсталосьОтгрузитьЧастичноВыполнено,
	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) КАК ЗарезервированоНаСкладе1,
	ЕСТЬNULL(РазмещениеЗаказовОстатки.КоличествоОстаток, 0) КАК РазмещеноВЗаказах,
	ЗаказыПокупателейОстаткиИОбороты.КоличествоКонечныйОстаток - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РазмещениеЗаказовОстатки.КоличествоОстаток, 0) КАК ОсталосьОбеспечить,
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) КАК СуммаДокумента,
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) КАК Оплачено,
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) КАК ОсталосьОплатить,
	ВЫБОР
		КОГДА ЗаказыПокупателейОстаткиИОборотыСводно.КоличествоПриход = ЗаказыПокупателейОстаткиИОборотыСводно.КоличествоКонечныйОстаток
			ТОГДА "გადაუტვირთავი"
		КОГДА ЗаказыПокупателейОстаткиИОборотыСводно.КоличествоКонечныйОстаток &lt;= 0
			ТОГДА "სრულად გადატვირთული"
		ИНАЧЕ "ნაწილობრივ გადატვირთული"
	КОНЕЦ КАК СостояниеОтгрузки,
	ВЫБОР
		КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) = 0
			ТОГДА "გადაუხდელი"
		КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) &lt;= 0
			ТОГДА "სრულად გადახდილი"
		ИНАЧЕ "ნაწილობრივ გადახდილი"
	КОНЕЦ КАК СостояниеОплаты,
	0 КАК ЗаказаноNET,
	0 КАК ОтгруженоNET,
	0 КАК ОсталосьОтгрузитьNET,
	0 КАК ОсталосьОтгрузитьЧастичноВыполненоNET,
	0 КАК ОсталосьОбеспечитьNET,
	0 КАК ЗаказаноСобр,
	0 КАК ОтгруженоСобр,
	0 КАК ОсталосьОтгрузитьСобр,
	0 КАК ОсталосьОтгрузитьЧастичноВыполненоСобр,
	0 КАК ОсталосьОбеспечитьСобр
ИЗ
	РегистрНакопления.ЗаказыПокупателей.ОстаткиИОбороты(, , , , ) КАК ЗаказыПокупателейОстаткиИОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(, НЕ ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)) КАК ЗапасыОстатки
		ПО ЗаказыПокупателейОстаткиИОбороты.Номенклатура = ЗапасыОстатки.Номенклатура
			И ЗаказыПокупателейОстаткиИОбороты.Характеристика = ЗапасыОстатки.Характеристика
			И ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя = ЗапасыОстатки.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РазмещениеЗаказов.Остатки(, ) КАК РазмещениеЗаказовОстатки
		ПО ЗаказыПокупателейОстаткиИОбороты.Номенклатура = РазмещениеЗаказовОстатки.Номенклатура
			И ЗаказыПокупателейОстаткиИОбороты.Характеристика = РазмещениеЗаказовОстатки.Характеристика
			И ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя = РазмещениеЗаказовОстатки.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОплатаСчетовИЗаказов.Обороты(, , , СчетНаОплату ССЫЛКА Документ.ЗаказПокупателя) КАК ОплатаСчетовИЗаказовОбороты
		ПО ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя = ОплатаСчетовИЗаказовОбороты.СчетНаОплату
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаказыПокупателей.ОстаткиИОбороты(, , , , ) КАК ЗаказыПокупателейОстаткиИОборотыСводно
		ПО ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя = ЗаказыПокупателейОстаткиИОборотыСводно.ЗаказПокупателя
ГДЕ
	(&amp;СостояниеОтгрузки = "Все заказы"
			ИЛИ &amp;СостояниеОтгрузки = ВЫБОР
				КОГДА ЗаказыПокупателейОстаткиИОборотыСводно.КоличествоПриход = ЗаказыПокупателейОстаткиИОборотыСводно.КоличествоКонечныйОстаток
					ТОГДА "Неотгруженные"
				КОГДА ЗаказыПокупателейОстаткиИОборотыСводно.КоличествоКонечныйОстаток &lt;= 0
					ТОГДА "Отгруженные полностью"
				ИНАЧЕ "Отгруженные частично"
			КОНЕЦ)
	И (&amp;СостояниеОплаты = "Все заказы"
			ИЛИ &amp;СостояниеОплаты = ВЫБОР
				КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) = 0
					ТОГДА "Неоплаченные"
				КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) &lt;= 0
					ТОГДА "Оплаченные полностью"
				ИНАЧЕ "Оплаченные частично"
			КОНЕЦ)

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	Усушкa_СобранныеPаказыОстаткиИОбороты.Организация,
	Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя,
	Усушкa_СобранныеPаказыОстаткиИОбороты.Номенклатура,
	Усушкa_СобранныеPаказыОстаткиИОбороты.Характеристика,
	Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя.Контрагент,
	0,
	0,
	0,
	0,
	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0),
	ЕСТЬNULL(РазмещениеЗаказовОстатки.КоличествоОстаток, 0),
	0,
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0),
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0),
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0),
	ВЫБОР
		КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрNETПриход = Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрNETКонечныйОстаток
			ТОГДА "გადაუტვირთავი"
		КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрNETКонечныйОстаток &lt;= 0
			ТОГДА "სრულად გადატვირთული"
		ИНАЧЕ "ნაწილობრივ გადატვირთული"
	КОНЕЦ,
	ВЫБОР
		КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) = 0
			ТОГДА "გადაუხდელი"
		КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) &lt;= 0
			ТОГДА "სრულად გადახდილი"
		ИНАЧЕ "ნაწილობრივ გადახდილი"
	КОНЕЦ,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрNETПриход,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрNETРасход,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрNETКонечныйОстаток,
	ВЫБОР
		КОГДА Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя.ВариантЗавершения = ЗНАЧЕНИЕ(перечисление.ВариантыЗавершенияЗаказа.Успешно)
			ТОГДА Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрNETКонечныйОстаток = 0
		ИНАЧЕ Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрNETКонечныйОстаток
	КОНЕЦ,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрNETКонечныйОстаток - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РазмещениеЗаказовОстатки.КоличествоОстаток, 0),
	0,
	0,
	0,
	0,
	0
ИЗ
	РегистрНакопления.Усушкa_СобранныеPаказы.ОстаткиИОбороты(, , , , ) КАК Усушкa_СобранныеPаказыОстаткиИОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(, НЕ ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)) КАК ЗапасыОстатки
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.Номенклатура = ЗапасыОстатки.Номенклатура
			И Усушкa_СобранныеPаказыОстаткиИОбороты.Характеристика = ЗапасыОстатки.Характеристика
			И Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = ЗапасыОстатки.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РазмещениеЗаказов.Остатки(, ) КАК РазмещениеЗаказовОстатки
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.Номенклатура = РазмещениеЗаказовОстатки.Номенклатура
			И Усушкa_СобранныеPаказыОстаткиИОбороты.Характеристика = РазмещениеЗаказовОстатки.Характеристика
			И Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = РазмещениеЗаказовОстатки.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОплатаСчетовИЗаказов.Обороты(, , , СчетНаОплату ССЫЛКА Документ.ЗаказПокупателя) КАК ОплатаСчетовИЗаказовОбороты
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = ОплатаСчетовИЗаказовОбороты.СчетНаОплату
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Усушкa_СобранныеPаказы.ОстаткиИОбороты(, , , , ) КАК Усушкa_СобранныеPаказыОстаткиИОборотыСводно
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = Усушкa_СобранныеPаказыОстаткиИОборотыСводно.ЗаказПокупателя
ГДЕ
	(&amp;СостояниеОтгрузки = "Все заказы"
			ИЛИ &amp;СостояниеОтгрузки = ВЫБОР
				КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрNETПриход = Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрNETКонечныйОстаток
					ТОГДА "Неотгруженные"
				КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрNETКонечныйОстаток &lt;= 0
					ТОГДА "Отгруженные полностью"
				ИНАЧЕ "Отгруженные частично"
			КОНЕЦ)
	И (&amp;СостояниеОплаты = "Все заказы"
			ИЛИ &amp;СостояниеОплаты = ВЫБОР
				КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) = 0
					ТОГДА "Неоплаченные"
				КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) &lt;= 0
					ТОГДА "Оплаченные полностью"
				ИНАЧЕ "Оплаченные частично"
			КОНЕЦ)

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	Усушкa_СобранныеPаказыОстаткиИОбороты.Организация,
	Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя,
	Усушкa_СобранныеPаказыОстаткиИОбороты.Номенклатура,
	Усушкa_СобранныеPаказыОстаткиИОбороты.Характеристика,
	Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя.Контрагент,
	0,
	0,
	0,
	0,
	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0),
	ЕСТЬNULL(РазмещениеЗаказовОстатки.КоличествоОстаток, 0),
	0,
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0),
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0),
	ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0),
	ВЫБОР
		КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрПриход = Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрКонечныйОстаток
			ТОГДА "გადაუტვირთავი"
		КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрКонечныйОстаток &lt;= 0
			ТОГДА "სრულად გადატვირთული"
		ИНАЧЕ "ნაწილობრივ გადატვირთული"
	КОНЕЦ,
	ВЫБОР
		КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) = 0
			ТОГДА "გადაუხდელი"
		КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) &lt;= 0
			ТОГДА "სრულად გადახდილი"
		ИНАЧЕ "ნაწილობრივ გადახდილი"
	КОНЕЦ,
	0,
	0,
	0,
	0,
	0,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрПриход,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрРасход,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрКонечныйОстаток,
	ВЫБОР
		КОГДА Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя.ВариантЗавершения = ЗНАЧЕНИЕ(перечисление.ВариантыЗавершенияЗаказа.Успешно)
			ТОГДА Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрКонечныйОстаток = 0
		ИНАЧЕ Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрКонечныйОстаток
	КОНЕЦ,
	Усушкa_СобранныеPаказыОстаткиИОбороты.КоличествоСобрКонечныйОстаток - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РазмещениеЗаказовОстатки.КоличествоОстаток, 0)
ИЗ
	РегистрНакопления.Усушкa_СобранныеPаказы.ОстаткиИОбороты(, , , , ) КАК Усушкa_СобранныеPаказыОстаткиИОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(, НЕ ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)) КАК ЗапасыОстатки
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.Номенклатура = ЗапасыОстатки.Номенклатура
			И Усушкa_СобранныеPаказыОстаткиИОбороты.Характеристика = ЗапасыОстатки.Характеристика
			И Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = ЗапасыОстатки.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РазмещениеЗаказов.Остатки(, ) КАК РазмещениеЗаказовОстатки
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.Номенклатура = РазмещениеЗаказовОстатки.Номенклатура
			И Усушкa_СобранныеPаказыОстаткиИОбороты.Характеристика = РазмещениеЗаказовОстатки.Характеристика
			И Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = РазмещениеЗаказовОстатки.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОплатаСчетовИЗаказов.Обороты(, , , СчетНаОплату ССЫЛКА Документ.ЗаказПокупателя) КАК ОплатаСчетовИЗаказовОбороты
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = ОплатаСчетовИЗаказовОбороты.СчетНаОплату
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Усушкa_СобранныеPаказы.ОстаткиИОбороты(, , , , ) КАК Усушкa_СобранныеPаказыОстаткиИОборотыСводно
		ПО Усушкa_СобранныеPаказыОстаткиИОбороты.ЗаказПокупателя = Усушкa_СобранныеPаказыОстаткиИОборотыСводно.ЗаказПокупателя
ГДЕ
	(&amp;СостояниеОтгрузки = "Все заказы"
			ИЛИ &amp;СостояниеОтгрузки = ВЫБОР
				КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрПриход = Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрКонечныйОстаток
					ТОГДА "Неотгруженные"
				КОГДА Усушкa_СобранныеPаказыОстаткиИОборотыСводно.КоличествоСобрКонечныйОстаток &lt;= 0
					ТОГДА "Отгруженные полностью"
				ИНАЧЕ "Отгруженные частично"
			КОНЕЦ)
	И (&amp;СостояниеОплаты = "Все заказы"
			ИЛИ &amp;СостояниеОплаты = ВЫБОР
				КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) + ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) = 0
					ТОГДА "Неоплаченные"
				КОГДА ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаАвансаОборот, 0) - ЕСТЬNULL(ОплатаСчетовИЗаказовОбороты.СуммаОплатыОборот, 0) &lt;= 0
					ТОГДА "Оплаченные полностью"
				ИНАЧЕ "Оплаченные частично"
			КОНЕЦ)</query>
	</dataSet>
