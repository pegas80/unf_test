#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Процедура - обработчик события ПередЗаписью набора записей.
//
Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка
		ИЛИ НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
		ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [25 октября 2021]  НАЧАЛО
	Если НЕ ОбменДанными.Загрузка И ЭтотОбъект.Количество() Тогда
	
		Регистратор = Отбор.Регистратор.Значение;
		УчетСебестоимостиВРазрезеОрганизации = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(Регистратор.Дата, Новый Структура("Организация", Регистратор.Организация)).УчетСебестоимостиВРазрезеОрганизации;
		Если УчетСебестоимостиВРазрезеОрганизации Тогда
		
			Для каждого ТекЗапись Из ЭтотОбъект Цикл
				
				Если ТипЗнч(ТекЗапись.СтруктурнаяЕдиница) = Тип("СправочникСсылка.СтруктурныеЕдиницы")
					И ТекЗапись.СтруктурнаяЕдиница.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.Склад
					Тогда
					
					ТекЗапись.СтруктурнаяЕдиница = Неопределено;
					
				КонецЕсли; 	
				Если ТипЗнч(ТекЗапись.КоррСтруктурнаяЕдиница) = Тип("СправочникСсылка.СтруктурныеЕдиницы")
					И ТекЗапись.КоррСтруктурнаяЕдиница.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.Склад
					Тогда
					
					ТекЗапись.КоррСтруктурнаяЕдиница = Неопределено;
					
				КонецЕсли; 	
				
			КонецЦикла; 
		
		КонецЕсли; 
	
	КонецЕсли; 	
	// © Шишка В.В. [25 октября 2021]  КОНЕЦ
	//--------------------------------------------------------------------------
	
	
	// Установка исключительной блокировки текущего набора записей регистратора.
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ПроданныеИВозвращенныеТовары.НаборЗаписей");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Регистратор", Отбор.Регистратор.Значение);
	Блокировка.Заблокировать();
	
	Если НЕ СтруктураВременныеТаблицы.Свойство("ДвиженияЗапасыИзменение") ИЛИ
		СтруктураВременныеТаблицы.Свойство("ДвиженияЗапасыИзменение") И НЕ СтруктураВременныеТаблицы.ДвиженияЗапасыИзменение Тогда
		
		// Если временная таблица "ДвиженияИзменение" не существует или не содержит записей
		// об изменении набора, значит набор записывается первый раз или для набора был выполнен контроль остатков.
		// Текущее состояние набора помещается во временную таблицу "ДвиженияПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно текущего.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ПроданныеИВозвращенныеТовары.НомерСтроки КАК НомерСтроки,
		|	ПроданныеИВозвращенныеТовары.Организация КАК Организация,
		|	ПроданныеИВозвращенныеТовары.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ПроданныеИВозвращенныеТовары.Номенклатура КАК Номенклатура,
		|	ПроданныеИВозвращенныеТовары.Характеристика КАК Характеристика,
		|	ВЫБОР
		|		КОГДА ПроданныеИВозвращенныеТовары.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА ПроданныеИВозвращенныеТовары.Количество
		|		ИНАЧЕ -ПроданныеИВозвращенныеТовары.Количество
		|	КОНЕЦ КАК КоличествоПередЗаписью
		|ПОМЕСТИТЬ ДвиженияПередЗаписью
		|ИЗ
		|	РегистрНакопления.ПроданныеИВозвращенныеТовары КАК ПроданныеИВозвращенныеТовары
		|ГДЕ
		|	ПроданныеИВозвращенныеТовары.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	Иначе
		
		// Если временная таблица "ДвиженияИзменение" существует и содержит записи
		// об изменении набора, значит набор записывается не первый раз и для набора не был выполнен контроль остатков.
		// Текущее состояние набора и текущее состояние изменений помещаются во временную таблцу "ДвиженияПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно первоначального.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ДвиженияИзменение.НомерСтроки КАК НомерСтроки,
		|	ДвиженияИзменение.Организация КАК Организация,
		|	ДвиженияИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ДвиженияИзменение.Номенклатура КАК Номенклатура,
		|	ДвиженияИзменение.Характеристика КАК Характеристика,
		|	ДвиженияИзменение.КоличествоПередЗаписью КАК КоличествоПередЗаписью
		|ПОМЕСТИТЬ ДвиженияПередЗаписью
		|ИЗ
		|	ДвиженияИзменение КАК ДвиженияИзменение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПроданныеИВозвращенныеТовары.НомерСтроки,
		|	ПроданныеИВозвращенныеТовары.Организация,
		|	ПроданныеИВозвращенныеТовары.СтруктурнаяЕдиница,
		|	ПроданныеИВозвращенныеТовары.Номенклатура,
		|	ПроданныеИВозвращенныеТовары.Характеристика,
		|	ВЫБОР
		|		КОГДА ПроданныеИВозвращенныеТовары.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА ПроданныеИВозвращенныеТовары.Количество
		|		ИНАЧЕ -ПроданныеИВозвращенныеТовары.Количество
		|	КОНЕЦ
		|ИЗ
		|	РегистрНакопления.ПроданныеИВозвращенныеТовары КАК ПроданныеИВозвращенныеТовары
		|ГДЕ
		|	ПроданныеИВозвращенныеТовары.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	КонецЕсли;
	
	// Временная таблица "ДвиженияИзменение" уничтожается
	// Удаляется информация о ее существовании.
	
	Если СтруктураВременныеТаблицы.Свойство("ДвиженияИзменение") Тогда
		
		Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияИзменение");
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		СтруктураВременныеТаблицы.Удалить("ДвиженияИзменение");
	
	КонецЕсли;
	
КонецПроцедуры // ПередЗаписью()

// Процедура - обработчик события ПриЗаписи набора записей.
//
Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка
		ИЛИ НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
		ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	// Рассчитывается изменение нового набора относительно текущего с учетом накопленных изменений
	// и помещается во временную таблицу "ДвиженияИзменение".
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	МИНИМУМ(ДвиженияИзменение.НомерСтроки) КАК НомерСтроки,
	|	ДвиженияИзменение.Организация КАК Организация,
	|	ДвиженияИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ДвиженияИзменение.Номенклатура КАК Номенклатура,
	|	ДвиженияИзменение.Характеристика КАК Характеристика,
	|	СУММА(ДвиженияИзменение.КоличествоПередЗаписью) КАК КоличествоПередЗаписью,
	|	СУММА(ДвиженияИзменение.КоличествоИзменение) КАК КоличествоИзменение,
	|	СУММА(ДвиженияИзменение.КоличествоПриЗаписи) КАК КоличествоПриЗаписи
	|ПОМЕСТИТЬ ДвиженияИзменение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДвиженияПередЗаписью.НомерСтроки КАК НомерСтроки,
	|		ДвиженияПередЗаписью.Организация КАК Организация,
	|		ДвиженияПередЗаписью.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		ДвиженияПередЗаписью.Номенклатура КАК Номенклатура,
	|		ДвиженияПередЗаписью.Характеристика КАК Характеристика,
	|		ДвиженияПередЗаписью.КоличествоПередЗаписью КАК КоличествоПередЗаписью,
	|		ДвиженияПередЗаписью.КоличествоПередЗаписью КАК КоличествоИзменение,
	|		0 КАК КоличествоПриЗаписи
	|	ИЗ
	|		ДвиженияПередЗаписью КАК ДвиженияПередЗаписью
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДвиженияПриЗаписи.НомерСтроки,
	|		ДвиженияПриЗаписи.Организация,
	|		ДвиженияПриЗаписи.СтруктурнаяЕдиница,
	|		ДвиженияПриЗаписи.Номенклатура,
	|		ДвиженияПриЗаписи.Характеристика,
	|		0,
	|		ВЫБОР
	|			КОГДА ДвиженияПриЗаписи.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА -ДвиженияПриЗаписи.Количество
	|			ИНАЧЕ ДвиженияПриЗаписи.Количество
	|		КОНЕЦ,
	|		ДвиженияПриЗаписи.Количество
	|	ИЗ
	|		РегистрНакопления.Запасы КАК ДвиженияПриЗаписи
	|	ГДЕ
	|		ДвиженияПриЗаписи.Регистратор = &Регистратор) КАК ДвиженияИзменение
	|
	|СГРУППИРОВАТЬ ПО
	|	ДвиженияИзменение.Организация,
	|	ДвиженияИзменение.СтруктурнаяЕдиница,
	|	ДвиженияИзменение.Номенклатура,
	|	ДвиженияИзменение.Характеристика
	|
	|ИМЕЮЩИЕ
	|	СУММА(ДвиженияИзменение.КоличествоИзменение) <> 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СтруктурнаяЕдиница,
	|	Номенклатура,
	|	Характеристика");
	
	Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаИзРезультатаЗапроса = РезультатЗапроса.Выбрать();
	ВыборкаИзРезультатаЗапроса.Следующий();
	
	// Новые изменения были помещены во временную таблицу "ДвиженияИзменение".
	// Добавляется информация о ее существовании и наличии в ней записей об изменении.
	СтруктураВременныеТаблицы.Вставить("ДвиженияИзменение", ВыборкаИзРезультатаЗапроса.Количество > 0);
	
	// Временная таблица "ДвиженияПередЗаписью" уничтожается
	Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияПередЗаписью");
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
КонецПроцедуры // ПриЗаписи()

#КонецОбласти

#КонецЕсли