#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Процедура - обработчик события ПередЗаписью набора записей.
//
Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка
		ИЛИ НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
		ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	// Установка исключительной блокировки текущего набора записей регистратора.
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РезервированиеЗапасов.НаборЗаписей");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Регистратор", Отбор.Регистратор.Значение);
	Блокировка.Заблокировать();
	
	Если НЕ СтруктураВременныеТаблицы.Свойство("ДвиженияРезервированиеЗапасовИзменение") ИЛИ
		СтруктураВременныеТаблицы.Свойство("ДвиженияРезервированиеЗапасовИзменение") И НЕ СтруктураВременныеТаблицы.ДвиженияРезервированиеЗапасовИзменение Тогда
		
		// Если временная таблица "ДвиженияРезервированиеЗапасовИзменение" не существует или не содержит записей
		// об изменении набора, значит набор записывается первый раз или для набора был выполнен контроль остатков.
		// Текущее состояние набора помещается во временную таблицу "ДвиженияЗапасыПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно текущего.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	РезервированиеЗапасов.ВидДвижения КАК ВидДвижения,
		|	РезервированиеЗапасов.НомерСтроки КАК НомерСтроки,
		|	РезервированиеЗапасов.Организация КАК Организация,
		|	РезервированиеЗапасов.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	РезервированиеЗапасов.Документ КАК Документ,
		|	РезервированиеЗапасов.Номенклатура КАК Номенклатура,
		|	РезервированиеЗапасов.Характеристика КАК Характеристика,
		|	РезервированиеЗапасов.Партия КАК Партия,
		|	РезервированиеЗапасов.Проект КАК Проект,
		|	ВЫБОР
		|		КОГДА РезервированиеЗапасов.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА РезервированиеЗапасов.Количество
		|		ИНАЧЕ -РезервированиеЗапасов.Количество
		|	КОНЕЦ КАК КоличествоПередЗаписью
		|ПОМЕСТИТЬ ДвиженияРезервированиеЗапасовПередЗаписью
		|ИЗ
		|	РегистрНакопления.РезервированиеЗапасов КАК РезервированиеЗапасов
		|ГДЕ
		|	РезервированиеЗапасов.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
		
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	Иначе
		
		// Если временная таблица "ДвиженияРезервированиеЗапасовИзменение" существует и содержит записи
		// об изменении набора, значит набор записывается не первый раз и для набора не был выполнен контроль остатков.
		// Текущее состояние набора и текущее состояние изменений помещаются во временную таблцу "ДвиженияЗапасыПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно первоначального.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ДвиженияРезервированиеЗапасовИзменение.ВидДвижения КАК ВидДвижения,
		|	ДвиженияРезервированиеЗапасовИзменение.НомерСтроки КАК НомерСтроки,
		|	ДвиженияРезервированиеЗапасовИзменение.Организация КАК Организация,
		|	ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ДвиженияРезервированиеЗапасовИзменение.Документ КАК Документ,
		|	ДвиженияРезервированиеЗапасовИзменение.Номенклатура КАК Номенклатура,
		|	ДвиженияРезервированиеЗапасовИзменение.Характеристика КАК Характеристика,
		|	ДвиженияРезервированиеЗапасовИзменение.Партия КАК Партия,
		|	ДвиженияРезервированиеЗапасовИзменение.Проект КАК Проект,
		|	ДвиженияРезервированиеЗапасовИзменение.КоличествоПередЗаписью КАК КоличествоПередЗаписью
		|ПОМЕСТИТЬ ДвиженияРезервированиеЗапасовПередЗаписью
		|ИЗ
		|	ДвиженияРезервированиеЗапасовИзменение КАК ДвиженияРезервированиеЗапасовИзменение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РезервированиеЗапасов.ВидДвижения,
		|	РезервированиеЗапасов.НомерСтроки,
		|	РезервированиеЗапасов.Организация,
		|	РезервированиеЗапасов.СтруктурнаяЕдиница,
		|	РезервированиеЗапасов.Документ,
		|	РезервированиеЗапасов.Номенклатура,
		|	РезервированиеЗапасов.Характеристика,
		|	РезервированиеЗапасов.Партия,
		|	РезервированиеЗапасов.Проект,
		|	ВЫБОР
		|		КОГДА РезервированиеЗапасов.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА РезервированиеЗапасов.Количество
		|		ИНАЧЕ -РезервированиеЗапасов.Количество
		|	КОНЕЦ
		|ИЗ
		|	РегистрНакопления.РезервированиеЗапасов КАК РезервированиеЗапасов
		|ГДЕ
		|	РезервированиеЗапасов.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	КонецЕсли;
	
	// Временная таблица "ДвиженияЗапасыИзменение" уничтожается
	// Удаляется информация о ее существовании.
	
	Если СтруктураВременныеТаблицы.Свойство("ДвиженияРезервированиеЗапасовИзменение") Тогда
		
		Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияРезервированиеЗапасовИзменение");
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		СтруктураВременныеТаблицы.Удалить("ДвиженияРезервированиеЗапасовИзменение");
	
	КонецЕсли;
	
	// Хозяйственная операция
	//ХозяйственныеОперацииСервер.ЗаполнитьХозяйственнуюОперациюВНабореЗаписей(ЭтотОбъект);
	// Конец Хозяйственная операция
	
КонецПроцедуры // ПередЗаписью()

// Процедура - обработчик события ПриЗаписи набора записей.
//
Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка
		ИЛИ НЕ ДополнительныеСвойства.Свойство("ДляПроведения")
		ИЛИ НЕ ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ДвиженияРезервированиеЗапасовИзменение.ВидДвижения КАК ВидДвижения,
	|	МИНИМУМ(ДвиженияРезервированиеЗапасовИзменение.НомерСтроки) КАК НомерСтроки,
	|	ДвиженияРезервированиеЗапасовИзменение.Организация КАК Организация,
	|	ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ДвиженияРезервированиеЗапасовИзменение.Документ КАК Документ,
	|	ДвиженияРезервированиеЗапасовИзменение.Номенклатура КАК Номенклатура,
	|	ДвиженияРезервированиеЗапасовИзменение.Характеристика КАК Характеристика,
	|	ДвиженияРезервированиеЗапасовИзменение.Партия КАК Партия,
	|	ДвиженияРезервированиеЗапасовИзменение.Проект КАК Проект,
	|	СУММА(ДвиженияРезервированиеЗапасовИзменение.КоличествоПередЗаписью) КАК КоличествоПередЗаписью,
	|	СУММА(ДвиженияРезервированиеЗапасовИзменение.КоличествоИзменение) КАК КоличествоИзменение,
	|	СУММА(ДвиженияРезервированиеЗапасовИзменение.КоличествоПриЗаписи) КАК КоличествоПриЗаписи
	|ПОМЕСТИТЬ ДвиженияРезервированиеЗапасовИзменение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДвиженияРезервированиеЗапасовПередЗаписью.ВидДвижения КАК ВидДвижения,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.НомерСтроки КАК НомерСтроки,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.Организация КАК Организация,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.Документ КАК Документ,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.Номенклатура КАК Номенклатура,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.Характеристика КАК Характеристика,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.Партия КАК Партия,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.Проект КАК Проект,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.КоличествоПередЗаписью КАК КоличествоПередЗаписью,
	|		ДвиженияРезервированиеЗапасовПередЗаписью.КоличествоПередЗаписью КАК КоличествоИзменение,
	|		0 КАК КоличествоПриЗаписи
	|	ИЗ
	|		ДвиженияРезервированиеЗапасовПередЗаписью КАК ДвиженияРезервированиеЗапасовПередЗаписью
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДвиженияРезервированиеЗапасовПриЗаписи.ВидДвижения,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.НомерСтроки,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Организация,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.СтруктурнаяЕдиница,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Документ,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Номенклатура,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Характеристика,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Партия,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Проект,
	|		0,
	|		ВЫБОР
	|			КОГДА ДвиженияРезервированиеЗапасовПриЗаписи.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА ДвиженияРезервированиеЗапасовПриЗаписи.Количество
	|			ИНАЧЕ -ДвиженияРезервированиеЗапасовПриЗаписи.Количество
	|		КОНЕЦ,
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Количество
	|	ИЗ
	|		РегистрНакопления.РезервированиеЗапасов КАК ДвиженияРезервированиеЗапасовПриЗаписи
	|	ГДЕ
	|		ДвиженияРезервированиеЗапасовПриЗаписи.Регистратор = &Регистратор) КАК ДвиженияРезервированиеЗапасовИзменение
	|
	|СГРУППИРОВАТЬ ПО
	|	ДвиженияРезервированиеЗапасовИзменение.ВидДвижения,
	|	ДвиженияРезервированиеЗапасовИзменение.Организация,
	|	ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница,
	|	ДвиженияРезервированиеЗапасовИзменение.Документ,
	|	ДвиженияРезервированиеЗапасовИзменение.Номенклатура,
	|	ДвиженияРезервированиеЗапасовИзменение.Характеристика,
	|	ДвиженияРезервированиеЗапасовИзменение.Партия,
	|	ДвиженияРезервированиеЗапасовИзменение.Проект
	|
	|ИМЕЮЩИЕ
	|	СУММА(ДвиженияРезервированиеЗапасовИзменение.КоличествоИзменение) <> 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	СтруктурнаяЕдиница,
	|	Документ,
	|	Номенклатура,
	|	Характеристика,
	|	Партия,
	|	Проект");
	
	Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаИзРезультатаЗапроса = РезультатЗапроса.Выбрать();
	ВыборкаИзРезультатаЗапроса.Следующий();
	
	// Новые изменения были помещены во временную таблицу "ДвиженияЗапасыИзменение".
	// Добавляется информация о ее существовании и наличии в ней записей об изменении.
	СтруктураВременныеТаблицы.Вставить("ДвиженияРезервированиеЗапасовИзменение", ВыборкаИзРезультатаЗапроса.Количество > 0);
	
	// Временная таблица "ДвиженияЗапасыПередЗаписью" уничтожается
	Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияРезервированиеЗапасовПередЗаписью");
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
КонецПроцедуры // ПриЗаписи()

#КонецОбласти

#КонецЕсли