				Иначе
					Прервать;
				КонецЕсли;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;     
		
		Если ПроцентПорога <> 0 Тогда  
			Возврат ПроцентПорога;
		КонецЕсли;    
		
	КонецЕсли;
	
	Если Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() > 0 Тогда  
		
		СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[0].НижняяГраница;
		
		Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Цикл 
			
			Если ВсегоПоДокументу >= СуммаПорогаПоКарте Тогда 
				ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ].Скидка;
				Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Тогда 
					СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ+1].НижняяГраница;
				Иначе
					Прервать;
				КонецЕсли;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;  
		
	КонецЕсли;
	
	Возврат ПроцентПорога;

КонецФункции

Функция ПолучитьПроцентСкидкиЛояльности_РасходнаяНакладная_2024_11_06(Объект) Экспорт  //Старая версия
	
	ВсегоПоДокументу = 0;
	ВсегоПоДокументуНакопление = 0;
	
	тзЗапасы = Объект.Запасы.Выгрузить(,"Количество, Цена");
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
		//"ВЫБРАТЬ
		//|	тзЗапасы.Цена КАК Цена,
		//|	тзЗапасы.Количество КАК Количество
		//|ПОМЕСТИТЬ ВТ_Запасы
		//|ИЗ
		//|	&тзЗапасы КАК тзЗапасы
		//|;
		//|
		//|////////////////////////////////////////////////////////////////////////////////
		//|ВЫБРАТЬ
		//|	ЕСТЬNULL(СУММА(ВТ_Запасы.Цена * ВТ_Запасы.Количество), 0) КАК СуммаБезСкидок,
		//|	ЕСТЬNULL(СУММА(БалыЛояльностиОбороты.СуммаОборот), 0) КАК СуммаБезСкидокНакопление
		//|ИЗ
		//|	ВТ_Запасы КАК ВТ_Запасы
		//|		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.БалыЛояльности.Обороты(
		//|				,
		//|				&ДатаДокумента,
		//|				Регистратор,
		//|				Контрагент = &Контрагент
		//|					И КартаЛояльности = &КартаЛояльности) КАК БалыЛояльностиОбороты
		//|		ПО (ИСТИНА)
		//|ГДЕ
		//|	БалыЛояльностиОбороты.Регистратор <> &Ссылка
		//|;
		//|
		//|////////////////////////////////////////////////////////////////////////////////
		//|ВЫБРАТЬ
		//|	ВложенныйЗапрос.СуммаДокБезСкидок + ЕСТЬNULL(ПродажиОбороты.СуммаОборот, 0) КАК ВсегоСДокументов
		//|ИЗ
		//|	(ВЫБРАТЬ
		//|		ВТ_Запасы.Цена * ВТ_Запасы.Количество КАК СуммаДокБезСкидок
		//|	ИЗ
		//|		ВТ_Запасы КАК ВТ_Запасы
		//|	
		//|	СГРУППИРОВАТЬ ПО
		//|		ВТ_Запасы.Цена * ВТ_Запасы.Количество) КАК ВложенныйЗапрос
		//|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи.Обороты(, &ДатаДокумента, Регистратор, Контрагент = &Контрагент) КАК ПродажиОбороты
		//|		ПО (ИСТИНА)
		//|ГДЕ
		//|	ПродажиОбороты.Регистратор <> &Ссылка";
		
		"ВЫБРАТЬ
		|	тзЗапасы.Цена КАК Цена,
		|	тзЗапасы.Количество КАК Количество
		|ПОМЕСТИТЬ ВТ_Запасы2
		|ИЗ
		|	&тзЗапасы КАК тзЗапасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(Т.Цена * Т.Количество) КАК СуммаДокБезСкидок
		|ПОМЕСТИТЬ ВТ_Запасы
		|ИЗ
		|	ВТ_Запасы2 КАК Т
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ЕСТЬNULL(ВТ_Запасы.СуммаДокБезСкидок, 0)),0) КАК СуммаБезСкидок,
		|	ЕСТЬNULL(СУММА(ЕСТЬNULL(БалыЛояльностиОбороты.СуммаОборот, 0)),0) КАК СуммаБезСкидокНакопление
		|ИЗ
		|	ВТ_Запасы КАК ВТ_Запасы
		|		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.БалыЛояльности.Обороты(
		|				,
		|				&ДатаДокумента,
		|				Регистратор,
		|				Контрагент = &Контрагент
		|					И КартаЛояльности = &КартаЛояльности
		|					И (&ДатаДокумента МЕЖДУ КартаЛояльности.ДатаНачала И КартаЛояльности.ДатаОкончания)) КАК БалыЛояльностиОбороты
		|		ПО (ИСТИНА)
		|ГДЕ
		|	БалыЛояльностиОбороты.Регистратор <> &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ВложенныйЗапрос.СуммаДокБезСкидок,0) + ЕСТЬNULL(ВложенныйЗапрос1.СуммаОборот, 0) КАК ВсегоСДокументов
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТ_Запасы.СуммаДокБезСкидок КАК СуммаДокБезСкидок
		|	ИЗ
		|		ВТ_Запасы КАК ВТ_Запасы) КАК ВложенныйЗапрос
		|	ЛЕВОЕ СОЕДИНЕНИЕ 
		|			(ВЫБРАТЬ
		|				СУММА(ПродажиОбороты.СуммаОборот) КАК СуммаОборот
		|			 ИЗ
		|				РегистрНакопления.Продажи.Обороты(&ДатаНачалаПродаж, &ДатаДокумента, Регистратор, Контрагент = &Контрагент) КАК ПродажиОбороты
		|			 ГДЕ
		|				ПродажиОбороты.Регистратор <> &Ссылка) КАК ВложенныйЗапрос1
		|		ПО (ИСТИНА)";
		
		
		
		
	
	Запрос.УстановитьПараметр("тзЗапасы", тзЗапасы);    
	Если ЗначениеЗаполнено(объект.Ссылка) Тогда 
		Запрос.УстановитьПараметр("ДатаДокумента", Объект.Дата);  
	Иначе
		Запрос.УстановитьПараметр("ДатаДокумента", ТекущаяДата());
	КонецЕсли;
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запрос.УстановитьПараметр("КартаЛояльности", Объект.КартаЛояльности);   
	Запрос.УстановитьПараметр("ДатаНачалаПродаж", Объект.КартаЛояльности.ДатаНачала); //Малышев 2024-11-05 ONESOFT-3574  
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	ВыборкаДетальныеЗаписи = МассивРезультатов[2].Выбрать();
	ВыборкаНакопления = МассивРезультатов[3].Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВсегоПоДокументу = ВыборкаДетальныеЗаписи.СуммаБезСкидок;       
		ВсегоПоДокументуНакопление = ВыборкаДетальныеЗаписи.СуммаБезСкидокНакопление + ВыборкаДетальныеЗаписи.СуммаБезСкидок;
	КонецЦикла;
	
	ВсегоНакоплено = 0;
	Пока ВыборкаНакопления.Следующий() Цикл
		ВсегоНакоплено = ВыборкаНакопления.ВсегоСДокументов;       
	КонецЦикла;
	
	СуммаПорогаПоКарте = 0;
	ПроцентПорога = 0;     
	
	Если Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1.Количество() > 0 Тогда   
		
		СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1[0].НижняяГраница;
		
		Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1.Количество() - 1 Цикл 
			
			Если ВсегоНакоплено >= СуммаПорогаПоКарте Тогда 
				ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1[СЧ].Скидка;
				Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1.Количество() - 1 Тогда 
					СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1[СЧ+1].НижняяГраница;
				Иначе
					Прервать;
				КонецЕсли;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;     
		
		Если ПроцентПорога <> 0 Тогда  
			Возврат ПроцентПорога;
		КонецЕсли;    
		
	КонецЕсли;
	
	Если Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() > 0 Тогда  
		
		СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[0].НижняяГраница;
		
		Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Цикл 
			
			Если ВсегоПоДокументу >= СуммаПорогаПоКарте Тогда 
				ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ].Скидка;
				Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Тогда 
					СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ+1].НижняяГраница;
				Иначе
					Прервать;
				КонецЕсли;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;  
		
	КонецЕсли;
	
	Возврат ПроцентПорога;

КонецФункции


Функция ПолучитьКоличествоДоступныхБалов_РасходнаяНакладная(ДокСсылка = Неопределено, КартаЛояльности, Контрагент, ДатаДокумента, КоэффициентЛояльности, МенятьКоэффициентЛояльности = Истина) Экспорт

	ДатаНачалаДействияКарты = КартаЛояльности.ДатаНачала;
	
	Запрос = Новый Запрос;
	//Запрос.Текст = 
	//	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	//	|	БалыЛояльностиОбороты.КартаЛояльности КАК КартаЛояльности,
	//	|	БалыЛояльностиОбороты.Контрагент КАК Контрагент,
	//	|	СУММА(БалыЛояльностиОбороты.КоличествоОборот) КАК КоличествоОборот
	//	|ИЗ
	//	|	РегистрНакопления.БалыЛояльности.Обороты(
	//	|			&ДатаНачала,
	//	|			&ДатаОкончания,
	//	|			Регистратор,
	//	|			КартаЛояльности = &КартаЛояльности
	//	|				И Контрагент = &Контрагент) КАК БалыЛояльностиОбороты
	//	|ГДЕ
	//	|	БалыЛояльностиОбороты.Регистратор <> &Ссылка
	//	|
	//	|СГРУППИРОВАТЬ ПО
	//	|	БалыЛояльностиОбороты.КартаЛояльности,
	//	|	БалыЛояльностиОбороты.Контрагент";
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	БалыЛояльностиОбороты.КартаЛояльности КАК КартаЛояльности,
	|	БалыЛояльностиОбороты.Контрагент КАК Контрагент,
	|	СУММА(БалыЛояльностиОбороты.КоличествоОстаток) КАК КоличествоОборот
	|ИЗ
	|	РегистрНакопления.БалыЛояльности.Остатки(
	|			&ДатаОкончания,
	|			КартаЛояльности = &КартаЛояльности
	|				И Контрагент = &Контрагент) КАК БалыЛояльностиОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	БалыЛояльностиОбороты.КартаЛояльности,
	|	БалыЛояльностиОбороты.Контрагент";
	
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачалаДействияКарты);
	Запрос.УстановитьПараметр("ДатаОкончания", ?(ДатаДокумента = НачалоДня(ТекущаяДата()), ТекущаяДата(), ДатаДокумента));
	Запрос.УстановитьПараметр("ДатаОкончания", Новый Граница(ДатаДокумента, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("КартаЛояльности", КартаЛояльности);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);  
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если  МенятьКоэффициентЛояльности и КоэффициентЛояльности <> КартаЛояльности.Владелец.КоэфициентПересчета Тогда                              
		КоэффициентЛояльности = КартаЛояльности.Владелец.КоэфициентПересчета;
	КонецЕсли;	
	
	КолвоБалов = 0;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		КолвоБалов = ВыборкаДетальныеЗаписи.КоличествоОборот;
	КонецЦикла;
	
	Возврат КолвоБалов;

КонецФункции

Функция ПолучитьПроцентНакопленияБаллов_РасходнаяНакладная(Объект) Экспорт
	
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) и (Объект.Дата> Объект.КартаЛояльности.ДатаОкончания или Объект.Дата< Объект.КартаЛояльности.ДатаНачала) Тогда
		Возврат 0;	
	КонецЕсли;	
	
	ВсегоПоДокументу = 0; 
	ВсегоПоДокументуНакопление = 0;
	
	тзЗапасы = Объект.Запасы.Выгрузить(,"Количество, Цена, Всего");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		//"ВЫБРАТЬ
		//|	тзЗапасы.Цена КАК Цена,
		//|	тзЗапасы.Количество КАК Количество
		//|ПОМЕСТИТЬ ВТ_Запасы
		//|ИЗ
		//|	&тзЗапасы КАК тзЗапасы
		//|;
		//|
		//|////////////////////////////////////////////////////////////////////////////////
		//|ВЫБРАТЬ
		//|	ЕСТЬNULL(СУММА(ВТ_Запасы.Цена * ВТ_Запасы.Количество), 0) КАК СуммаБезСкидок,
		//|	ЕСТЬNULL(СУММА(БалыЛояльностиОбороты.СуммаОборот), 0) КАК СуммаБезСкидокНакопление
		//|ИЗ
		//|	ВТ_Запасы КАК ВТ_Запасы
		//|		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.БалыЛояльности.Обороты(
		//|				,
		//|				&ДатаДокумента,
		//|				,
		//|				Контрагент = &Контрагент
		//|					И КартаЛояльности = &КартаЛояльности) КАК БалыЛояльностиОбороты
		//|		ПО (ИСТИНА)";  
		"ВЫБРАТЬ
		|	тзЗапасы.Всего КАК Всего,
		|	тзЗапасы.Цена КАК Цена,
		|	тзЗапасы.Количество КАК Количество
		|ПОМЕСТИТЬ ВТ_Запасы
		|ИЗ
		|	&тзЗапасы КАК тзЗапасы
		|;
		|
		
		//
		//|////////////////////////////////////////////////////////////////////////////////
		//|ВЫБРАТЬ
		//|	ЕСТЬNULL(СУММА(ВТ_Запасы.Цена * ВТ_Запасы.Количество), 0) КАК СуммаБезСкидок,
		//|	ЕСТЬNULL(СУММА(ВложенныйЗапрос.СуммаОборот), 0) КАК СуммаБезСкидокНакопление
		//|ИЗ
		//|	ВТ_Запасы КАК ВТ_Запасы,
		//|	(ВЫБРАТЬ
		//|		СУММА(БалыЛояльностиОбороты.СуммаОборот) КАК СуммаОборот
		//|	ИЗ
		//|		РегистрНакопления.БалыЛояльности.Обороты(, &ДатаДокумента, Регистратор, Контрагент = &Контрагент) КАК БалыЛояльностиОбороты
		//|	ГДЕ
		//|		БалыЛояльностиОбороты.Регистратор <> &Ссылка
		//|) КАК ВложенныйЗапрос
		
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ВТ_Запасы.Всего), 0) КАК СуммаБезСкидок,
		|	ЕСТЬNULL(СУММА(ВложенныйЗапрос.СуммаОборот), 0) КАК СуммаБезСкидокНакопление
		|ИЗ
		|	ВТ_Запасы КАК ВТ_Запасы,
		|	(ВЫБРАТЬ
		|		СУММА(БалыЛояльностиОбороты.СуммаОборот) КАК СуммаОборот
		|	ИЗ
		|		РегистрНакопления.БалыЛояльности.Обороты(, &ДатаДокумента, Регистратор, Контрагент = &Контрагент) КАК БалыЛояльностиОбороты
		|	ГДЕ
		|		БалыЛояльностиОбороты.Регистратор <> &Ссылка
		|) КАК ВложенныйЗапрос
		
		|";
	
	Запрос.УстановитьПараметр("тзЗапасы", тзЗапасы);     
	Если ЗначениеЗаполнено(объект.Ссылка) Тогда 
		Запрос.УстановитьПараметр("ДатаДокумента", Объект.Дата);  
	Иначе
		Запрос.УстановитьПараметр("ДатаДокумента", ТекущаяДата());
	КонецЕсли;
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запрос.УстановитьПараметр("КартаЛояльности", Объект.КартаЛояльности);  
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВсегоПоДокументу = ВыборкаДетальныеЗаписи.СуммаБезСкидок;       
		ВсегоПоДокументуНакопление = ВыборкаДетальныеЗаписи.СуммаБезСкидокНакопление + ВыборкаДетальныеЗаписи.СуммаБезСкидок;
	КонецЦикла;
	
	СуммаПорогаПоКарте = 0;
	ПроцентПорога = 0;
		
	Если Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1.Количество() > 0 Тогда   
		
		СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1[0].НижняяГраницаЛояльность;
		
		Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1.Количество() - 1 Цикл 
			
			//Если ВсегоПоДокументуНакопление >= СуммаПорогаПоКарте Тогда 
			Если ВсегоПоДокументу >= СуммаПорогаПоКарте Тогда //Малышев 2024-12-26 - по одному документу
				ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1[СЧ].СкидкаЛояльность;
				Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1.Количество() - 1 Тогда 
					СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок1[СЧ+1].НижняяГраницаЛояльность;
				Иначе
					Прервать;
				КонецЕсли;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;     
		
		Если ПроцентПорога <> 0 Тогда  
			Возврат ПроцентПорога;
		КонецЕсли;    
		
	КонецЕсли;
	
	//ВсегоПоДокументу = Объект.Запасы.Итог("Сумма");
	ВсегоПоДокументу = Объект.Запасы.Итог("Всего");
	
	Если Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() > 0 Тогда             
		
		СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[0].НижняяГраницаЛояльность;
		
		Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Цикл 
			
			Если ВсегоПоДокументу >= СуммаПорогаПоКарте Тогда 
				ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ].СкидкаЛояльность;
				Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Тогда 
					СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ+1].НижняяГраницаЛояльность;
				Иначе
					Прервать;
				КонецЕсли;
			Иначе
				Прервать;
			КонецЕсли;
			
		КонецЦикла;        
	КонецЕсли;
	
	Возврат ПроцентПорога;

КонецФункции // ПолучитьПроцентНакопления()


