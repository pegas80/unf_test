
Функция ПолучитьКоэффициентЛояльности(КартаЛояльности, Дата) Экспорт
	
	Результат = 0;
	
	Если КартаДействительна(КартаЛояльности, Дата) Тогда
		Результат = КартаЛояльности.Владелец.КоэфициентПересчета;	
	КонецЕсли;	
	
	Возврат Результат; //КоэффициентЛояльности;
	
КонецФункции

Функция КартаДействительна(КартаЛояльности, Дата) Экспорт
	Результат = Ложь;
	
	Если ЗначениеЗаполнено(КартаЛояльности) 
		и (Дата <= КонецДня(КартаЛояльности.ДатаОкончания) и Дата>= НачалоДня(КартаЛояльности.ДатаНачала)) Тогда
		Результат = Истина;	
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции	


Функция ПолучитьПроцентСкидкиЛояльности_РасходнаяНакладная(Объект) Экспорт
	
	ВсегоПоДокументу = 0;
	ВсегоПоДокументуНакопление = 0;
	ПроцентНакопительнойСкидки = 0;
	
	
	//Малышев 2024-12-06 - проверим на годность карты
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) и (Объект.Дата> Объект.КартаЛояльности.ДатаОкончания или Объект.Дата< Объект.КартаЛояльности.ДатаНачала) Тогда
		Возврат ПроцентНакопительнойСкидки;	
	КонецЕсли;	
	
	
	
	тзЗапасы = Объект.Запасы.Выгрузить(,"Количество, Цена, Всего");
	
	Запрос = Новый Запрос; 
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
			
	//Малышев 2024-11-06	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	тзЗапасы.Цена КАК Цена,
	|	тзЗапасы.Количество КАК Количество,
	|	тзЗапасы.Всего КАК Всего
	|ПОМЕСТИТЬ ВТ_ЗапасыТекущегоДокумента
	|ИЗ
	|	&тзЗапасы КАК тзЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	//|	СУММА(Т.Цена * Т.Количество) КАК СуммаДокБезСкидок
	|	СУММА(Т.Всего) КАК СуммаДокБезСкидок  //Малышев 2024-12-19 меняем базу для рассчета 
	|ПОМЕСТИТЬ ВТ_ПродажиТекущегоДокумента
	|ИЗ
	|	ВТ_ЗапасыТекущегоДокумента КАК Т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Пороги.Скидка КАК Скидка,
	|	Пороги.НижняяГраница КАК НижняяГраница
	|ПОМЕСТИТЬ ВТ_Пороги
	|ИЗ
	|	Справочник.ВидыКартЛояльности.ПорогиНакопительныхСкидок КАК Пороги
	|ГДЕ
	|	Пороги.Ссылка = &ВидДисконтнойКарты
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВидыКартЛояльностиПорогиНакопительныхСкидок1.Скидка,
	|	ВидыКартЛояльностиПорогиНакопительныхСкидок1.НижняяГраница
	|ИЗ
	|	Справочник.ВидыКартЛояльности.ПорогиНакопительныхСкидок1 КАК ВидыКартЛояльностиПорогиНакопительныхСкидок1
	|ГДЕ
	|	ВидыКартЛояльностиПорогиНакопительныхСкидок1.Ссылка = &ВидДисконтнойКарты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Т.СуммаОборот) КАК СуммаОборот
	|ПОМЕСТИТЬ ВременнаяТаблицаПродаж
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(СУММА(РегПродажи.СуммаОборот), 0) КАК СуммаОборот
	|	ИЗ
	|		РегистрНакопления.Продажи.Обороты(&ДатаНачалаПродаж, &ДатаКон, Регистратор, Контрагент = &Контрагент) КАК РегПродажи
	|	ГДЕ
	|		РегПродажи.Регистратор <> &Ссылка
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ПродажиТекущегоДокумента.СуммаДокБезСкидок
	|	ИЗ
	|		ВТ_ПродажиТекущегоДокумента КАК ПродажиТекущегоДокумента) КАК Т
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РегПороги.Скидка КАК Скидка
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(СУММА(РегПродажи.СуммаОборот), 0) КАК СуммаОборот
	|	ИЗ
	|		ВременнаяТаблицаПродаж КАК РегПродажи) КАК РегПродажи
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Пороги.НижняяГраница КАК НижняяГраница,
	|			Пороги.Скидка КАК Скидка
	|		ИЗ
	|			ВТ_Пороги КАК Пороги) КАК РегПороги
	|		ПО (РегПороги.НижняяГраница <= РегПродажи.СуммаОборот)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			МАКСИМУМ(РегПороги.НижняяГраница) КАК НижняяГраница
	|		ИЗ
	|			ВременнаяТаблицаПродаж КАК РегПродажи
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|					Пороги.НижняяГраница КАК НижняяГраница
	|				ИЗ
	|					ВТ_Пороги КАК Пороги) КАК РегПороги
	|				ПО (РегПороги.НижняяГраница <= РегПродажи.СуммаОборот)) КАК РегПорогиМакс
	|		ПО (РегПорогиМакс.НижняяГраница = РегПороги.НижняяГраница)";
	
	
	Запрос.УстановитьПараметр("тзЗапасы", тзЗапасы);    
	Если ЗначениеЗаполнено(объект.Ссылка) Тогда 
		Запрос.УстановитьПараметр("ДатаДокумента", Объект.Дата);  
	Иначе
		Запрос.УстановитьПараметр("ДатаДокумента", ТекущаяДата());
	КонецЕсли;
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запрос.УстановитьПараметр("КартаЛояльности", Объект.КартаЛояльности);   
	Запрос.УстановитьПараметр("ДатаНачалаПродаж", Объект.КартаЛояльности.ДатаНачала); //Малышев 2024-11-05 ONESOFT-3574  
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	
	
	//***************
	ДатаСкидки = Объект.Дата; 
	ПериодНакопления = УправлениеНебольшойФирмойСервер.ПолучитьПериодРасчетаНакопительныхСкидокПоДисконтнойКарте(ДатаСкидки, Объект.КартаЛояльности.Ссылка);
	Запрос.УстановитьПараметр("ДатаНач", ПериодНакопления.НачалоПериода);
	Запрос.УстановитьПараметр("ДатаКон", ДатаСкидки);
 	Запрос.УстановитьПараметр("ВидДисконтнойКарты", Объект.КартаЛояльности.Владелец);   
		
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПроцентНакопительнойСкидки = Выборка.Скидка;
	Иначе
		ПроцентНакопительнойСкидки = 0;
	КонецЕсли;		
	
	Возврат ПроцентНакопительнойСкидки;
	
КонецФункции


