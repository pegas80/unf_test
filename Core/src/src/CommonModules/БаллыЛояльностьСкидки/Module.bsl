	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	ВыборкаДетальныеЗаписи = МассивРезультатов[1].Выбрать();
	ВыборкаНакопления = МассивРезультатов[2].Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВсегоПоДокументу = ВыборкаДетальныеЗаписи.СуммаБезСкидок;       
		ВсегоПоДокументуНакопление = ВыборкаДетальныеЗаписи.СуммаБезСкидокНакопление + ВыборкаДетальныеЗаписи.СуммаБезСкидок;
