#Область УникальныеПрефиксыДокументов

Функция ПолучитьДанныеПрефиксовДокумента(СсылкаНаДокумент) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШаблоныУникальныхПрефиксовДляДокументов.ПрефиксДокумента КАК ПрефиксДокумента,
	|	ШаблоныУникальныхПрефиксовДляДокументов.ГодВПрефиксе КАК ГодВПрефиксе,
	|	ШаблоныУникальныхПрефиксовДляДокументов.МесяцВПрефиксе КАК МесяцВПрефиксе
	|ИЗ
	|	РегистрСведений.ШаблоныУникальныхПрефиксовДляДокументов КАК ШаблоныУникальныхПрефиксовДляДокументов
	|ГДЕ
	|	ШаблоныУникальныхПрефиксовДляДокументов.ДокументСсылка = &ДокументСсылка";
	
	Запрос.УстановитьПараметр("ДокументСсылка", СсылкаНаДокумент);

	ДанныеПрефикса = Новый Структура("ПрефиксДокумента, ГодВПрефиксе, МесяцВПрефиксе", "", Ложь, Ложь);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Если Не РезультатЗапроса.Пустой() Тогда
	
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(ДанныеПрефикса, Выборка);
	
	КонецЕсли; 
	
	Возврат ДанныеПрефикса;

КонецФункции // ПолучитьДанныеПрефиксовДокумента()
 

#КонецОбласти 	
