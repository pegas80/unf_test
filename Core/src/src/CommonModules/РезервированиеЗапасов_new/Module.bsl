Процедура ОтразитьРезервированиеЗапасов(ДополнительныеСвойства, Движения, Отказ) ЭКСПОРТ
	
	Если НЕ ДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаРезервированиеЗапасов") Тогда 
		Возврат;
	КонецЕсли;
	
	ТаблицаРезервированиеЗапасов = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаРезервированиеЗапасов;
	
	Если Отказ
	 ИЛИ ТаблицаРезервированиеЗапасов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДвиженияРезервированиеЗапасов = Движения.РезервированиеЗапасов;
	ДвиженияРезервированиеЗапасов.Записывать = Истина;
	ДвиженияРезервированиеЗапасов.Загрузить(ТаблицаРезервированиеЗапасов);
	
КонецПроцедуры

Процедура ОбработатьВременнуюТаблицуДвиженияРезервированиеЗапасовИзменение(ДополнительныеСвойства) ЭКСПОРТ
	ПЕРЕМ ПересоздатьДвиженияРезервированиеЗапасовИзменение;
	
	ПересоздатьДвиженияРезервированиеЗапасовИзменение = ЛОЖЬ;

	МенеджерВременныхТаблиц = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	ВременныеТаблицыЗапроса = МенеджерВременныхТаблиц.Таблицы;
	
	ДвиженияРезервированиеЗапасовИзменение = ВременныеТаблицыЗапроса.Получить("ДвиженияРезервированиеЗапасовИзменение");
	
	Если ДвиженияРезервированиеЗапасовИзменение = НЕОПРЕДЕЛЕНО Тогда
	
		Если ВременныеТаблицыЗапроса.Найти("ДвиженияЗапасыИзменение") = НЕОПРЕДЕЛЕНО Тогда
			
			РегистрыНакопления.РезервированиеЗапасов.ВыполнитьПустуюВременнуюТаблицуИзменение(ДополнительныеСвойства);
			
		Иначе
			
			ПересоздатьДвиженияРезервированиеЗапасовИзменение = ИСТИНА;
			
		КонецЕсли;
		
	Иначе
		
		РезультатЗапроса = ДвиженияРезервированиеЗапасовИзменение.ПолучитьДанные();
		Если РезультатЗапроса.Пустой() Тогда
			
			Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияРезервированиеЗапасовИзменение");
			
			Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
			РезультатЗапроса = Запрос.Выполнить();
			
			Если ВременныеТаблицыЗапроса.Найти("ДвиженияЗапасыИзменение") = НЕОПРЕДЕЛЕНО Тогда
				
				РегистрыНакопления.РезервированиеЗапасов.ВыполнитьПустуюВременнуюТаблицуИзменение(ДополнительныеСвойства);
				
			Иначе
				
				ПересоздатьДвиженияРезервированиеЗапасовИзменение = ИСТИНА;
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЕсли; 
	
	Если ПересоздатьДвиженияРезервированиеЗапасовИзменение Тогда
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		|	ДвиженияЗапасыИзменение.НомерСтроки КАК НомерСтроки,
		|	ДвиженияЗапасыИзменение.Организация КАК Организация,
		|	ДвиженияЗапасыИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ДвиженияЗапасыИзменение.ЗаказПокупателя КАК Документ,
		|	ДвиженияЗапасыИзменение.Номенклатура КАК Номенклатура,
		|	ДвиженияЗапасыИзменение.Характеристика КАК Характеристика,
		|	ДвиженияЗапасыИзменение.Партия КАК Партия,
		|	ДвиженияЗапасыИзменение.Проект КАК Проект,
		|	0 КАК КоличествоПередЗаписью,
		|	0 КАК КоличествоИзменение,
		|	0 КАК КоличествоПриЗаписи
		|ПОМЕСТИТЬ ДвиженияРезервированиеЗапасовИзменение
		|ИЗ
		|	ДвиженияЗапасыИзменение КАК ДвиженияЗапасыИзменение");
		
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
		РезультатЗапроса = Запрос.Выполнить();		
		
	КонецЕсли;

КонецПроцедуры

