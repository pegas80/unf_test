Процедура СообщитьОбОшибкахПроведенияПоРегиструЗапасы(ДокОбъект, ВыборкаЗаписей, Отказ, МассивСообщений = Неопределено, ПоИтогамРегистра = ЛОЖЬ, ВидОшибкиПоОстакам = 0) ЭКСПОРТ
	
	ЗаголовокОшибки = ?(ПоИтогамРегистра, НСтр("ka='შეცდომა, რეესტრის შედეგების საფუძველზე:';ru='Ошибка, по итогам регистра:'"
	+ ";en='Error based on the register:'"	
	), НСтр("ka='შეცდომა:';ru='Ошибка:';en='Mistake:'"));
	ШаблонЗаголовкаСообщения = ЗаголовокОшибки + НСтр("ka='მარაგების და დანახარჯების აღრიცხვის მიხედვით ნაშთი საკმარისი არ არის %СтруктурнаяЕдиницаПредставление%';ru='Не хватает остатка по учету запасов и затрат %СтруктурнаяЕдиницаПредставление%'"
	+ ";en='There is not enough balance to account for inventory and costs %СтруктурнаяЕдиницаПредставление%'"	
	);

	Если ВидОшибкиПоОстакам = 2 Тогда
		СтрокаОстаток = НСтр("ru='свободный остаток ';ka='თავისუფალი ნაშთი ';en='free balance '");
	ИначеЕсли ВидОшибкиПоОстакам = 1 Тогда
		СтрокаОстаток = НСтр("ru='резерв ';ka='რეზერვი ';en='reserved '");
	Иначе
		СтрокаОстаток = НСтр("ru='остаток ';ka='ნაშთი ';en='remainder '"); 
	КонецЕсли;
	
	ШаблонСообщения = НСтр("ru='Номенклатура: %НоменклатураХарактеристикаПартия%,
	|"+СтрокаОстаток+"%КоличествоОстаток% %ЕдиницаИзмерения%,"
	"недостаточно %КоличествоИРезерв% %ЕдиницаИзмерения%';ka='ნომენკლატურა: %НоменклатураХарактеристикаПартия%,
	|"+СтрокаОстаток+"%КоличествоОстаток% %ЕдиницаИзмерения%,"
	"არ არის საკმარისი %КоличествоИРезерв% %ЕдиницаИзмерения%'"
	+ ";en='Nomenclature: %НоменклатураХарактеристикаПартия%,
	|"+СтрокаОстаток+"%КоличествоОстаток% %ЕдиницаИзмерения%,"
	"not enough %КоличествоИРезерв% %ЕдиницаИзмерения%'"	
	);    
	
	
	ВыводитьВЗаголовокРасшифровку = Истина;
	УчетПоНесколькимСкладам = Константы.ФункциональнаяОпцияУчетПоНесколькимСкладам.Получить();
	УчетПоНесколькимПодразделениям = Константы.ФункциональнаяОпцияУчетПоНесколькимПодразделениям.Получить();
	Пока ВыборкаЗаписей.Следующий() Цикл
		
		Если ВыводитьВЗаголовокРасшифровку Тогда
			
			ПредставлениеСтруктурнойЕдиницы = СокрЛП(ВыборкаЗаписей.СтруктурнаяЕдиницаПредставление);
			
			ТекстЗаголовкаСообщения = СтрЗаменить(ШаблонЗаголовкаСообщения, "%СтруктурнаяЕдиницаПредставление%", ПредставлениеСтруктурнойЕдиницы);
			УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ДокОбъект, ТекстЗаголовкаСообщения, , , , Отказ, МассивСообщений);
			ВыводитьВЗаголовокРасшифровку = Ложь;
			
		КонецЕсли;
		
		ПредставлениеНоменклатуры = УправлениеНебольшойФирмойСервер.ПредставлениеНоменклатуры(ВыборкаЗаписей.НоменклатураПредставление, ВыборкаЗаписей.ХарактеристикаПредставление, ВыборкаЗаписей.ПартияПредставление);
		
		СписокДопПолей = "СчетУчетаРеглПредставление,ПроектПредставление";
		СтруктураДопПолей = Новый Структура(СписокДопПолей);
		ЗаполнитьЗначенияСвойств(СтруктураДопПолей,ВыборкаЗаписей);
		СписокДопПолейНоменклатуры = СтрРазделить(СписокДопПолей,",");
		Для Каждого СтрПоля из СписокДопПолейНоменклатуры Цикл
			ЗначениеПоля = "";
			Если СтруктураДопПолей.Свойство(СтрПоля, ЗначениеПоля) Тогда
				ПредставлениеНоменклатуры = ПредставлениеНоменклатуры + " / " + ЗначениеПоля;
			КонецЕсли;	
		КонецЦикла;
		
		ТекстСообщения = СтрЗаменить(ШаблонСообщения, "%НоменклатураХарактеристикаПартия%", ПредставлениеНоменклатуры);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%КоличествоОстаток%", Строка(ВыборкаЗаписей.ОстатокЗапасы));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%КоличествоИРезерв%", Строка(-ВыборкаЗаписей.КоличествоОстатокЗапасы));
		
		// Заказы покупателей в Рознице
		Если ЗначениеЗаполнено(ВыборкаЗаписей.ЗаказПокупателяПредставление) Тогда
			ТекстСообщения = ТекстСообщения + ". " + ВыборкаЗаписей.ЗаказПокупателяПредставление;
		КонецЕсли;
		// Конец Заказы покупателей в Рознице
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ЕдиницаИзмерения%", СокрЛП(ВыборкаЗаписей.ЕдиницаИзмеренияПредставление));
		
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ДокОбъект, ТекстСообщения, , , , Отказ, МассивСообщений);
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТаблицуСвободныхОстатков(МенеджерВременныхТаблиц, ДатаПроверки) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	КонтролироватьОстаткиПриПроведенииПоПроектам = Константы.ФункциональнаяОпцияУчетПоПроектам.Получить() И Константы.КонтролироватьОстаткиПриПроведенииПоПроектам.Получить();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаДанных.НомерСтроки КАК НомерСтроки,
		//|	ТаблицаДанных.Организация КАК Организация,
		//|	ТаблицаДанных.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		//|	ТаблицаДанных.Номенклатура КАК Номенклатура,
		//|	ТаблицаДанных.Характеристика КАК Характеристика,
		//|	ТаблицаДанных.Партия КАК Партия,
		//|	ТаблицаДанных.Проект КАК Проект,
		|	ТаблицаДанных.Количество КАК Количество,
		|	ТаблицаДанных.Резерв КАК Резерв,
		|	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервированиеЗапасовОстатки.КоличествоОстаток, 0) КАК СвободныйОстаток,
		|	ЕСТЬNULL(ЗаказыПоставщикамОстатки.КоличествоОстаток, 0) КАК ОжидаемыеПоставки,
		|	ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(РезервированиеЗапасовОстатки.КоличествоОстаток, 0) + ЕСТЬNULL(ЗаказыПоставщикамОстатки.КоличествоОстаток, 0) КАК ОжидаемыеСвободныеОстатки
		|ИЗ
