				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ РезервированиеЗапасовОстаткиДляРезервирования
				   |;
				   |
				   |////////////////////////////////////////////////////////////////////////////////
				   |УНИЧТОЖИТЬ РезервированиеЗапасовОстаткиСДокументомДляРезервирования
				   // Kuzmich, 08.12.2024, (ONESOFT-3540) Karcher - заполнить по партиям - добавить логику по новом финкционале резервирование, исправления и доделки
				   |";
	
	Если ДобавитьРзделитель Тогда
		ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов()
	КонецЕсли;
	
	Возврат ТекстЗапроса;
			
КонецФункции

Функция ПолучитьТекстЗапросаКонтроля_СвободныеОстатки(ДополнительныеСвойства, ДобавитьРзделитель = ЛОЖЬ) ЭКСПОРТ
	
	ОбработатьВременнуюТаблицуДвиженияРезервированиеЗапасовИзменение(ДополнительныеСвойства);
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	МИНИМУМ(ДвиженияЗапасыИзменение.НомерСтроки) КАК НомерСтроки,
	               |	ДвиженияЗапасыИзменение.Организация КАК Организация,
	               |	ДвиженияЗапасыИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	ДвиженияЗапасыИзменение.СчетУчетаРегл КАК СчетУчетаРегл,
	               |	ДвиженияЗапасыИзменение.Номенклатура КАК Номенклатура,
	               |	ДвиженияЗапасыИзменение.Характеристика КАК Характеристика,
	               |	ДвиженияЗапасыИзменение.Партия КАК Партия,
	               |	ДвиженияЗапасыИзменение.Проект КАК Проект,
	               |	ДвиженияЗапасыИзменение.ЗаказПокупателя КАК ЗаказПокупателя,
	               |	ДвиженияЗапасыИзменение.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	               |	СУММА(ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0)) КАК ОстатокЗапасы,
	               |	СУММА(ЕСТЬNULL(ДвиженияЗапасыИзменение.КоличествоПриЗаписи, 0)) КАК КоличествоДвижение
	               |ПОМЕСТИТЬ ТЗ_Запасы
	               |ИЗ
	               |	ДвиженияЗапасыИзменение КАК ДвиженияЗапасыИзменение
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(
	               |				&МоментКонтроляРезерва,
	               |				(Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия) В
	               |					(ВЫБРАТЬ
	               |						ДвиженияЗапасыИзменение.Организация КАК Организация,
	               |						ДвиженияЗапасыИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |						ДвиженияЗапасыИзменение.Номенклатура КАК Номенклатура,
	               |						ДвиженияЗапасыИзменение.Характеристика КАК Характеристика,
	               |						ДвиженияЗапасыИзменение.Партия КАК Партия
	               |					ИЗ
	               |						ДвиженияЗапасыИзменение КАК ДвиженияЗапасыИзменение)) КАК ЗапасыОстатки
	               |		ПО ДвиженияЗапасыИзменение.Организация = ЗапасыОстатки.Организация
	               |			И ДвиженияЗапасыИзменение.СтруктурнаяЕдиница = ЗапасыОстатки.СтруктурнаяЕдиница
	               |			И ДвиженияЗапасыИзменение.СчетУчетаРегл = ЗапасыОстатки.СчетУчетаРегл
	               |			И ДвиженияЗапасыИзменение.Номенклатура = ЗапасыОстатки.Номенклатура
	               |			И ДвиженияЗапасыИзменение.Характеристика = ЗапасыОстатки.Характеристика
	               |			И ДвиженияЗапасыИзменение.Партия = ЗапасыОстатки.Партия
	               |			И (ВЫБОР
	               |				КОГДА &КонтролироватьОстаткиПриПроведенииПоПроектам
	               |					ТОГДА ДвиженияЗапасыИзменение.Проект = ЗапасыОстатки.Проект
	               |				ИНАЧЕ ИСТИНА
	               |			КОНЕЦ),
	               |	Константы КАК Константы
	               |ГДЕ
	               |	Константы.ФункциональнаяОпцияРезервированиеЗапасов_new
	               |	И НЕ ДвиженияЗапасыИзменение.СтруктурнаяЕдиница.КонтролироватьОстатки
				   |	И ДвиженияЗапасыИзменение.КоличествоИзменение > 0
	               |	И (ДвиженияЗапасыИзменение.ЗаказПокупателя ЕСТЬ NULL
	               |			ИЛИ ДвиженияЗапасыИзменение.ЗаказПокупателя = НЕОПРЕДЕЛЕНО
	               |			ИЛИ ДвиженияЗапасыИзменение.ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка))
				   |
				   |СГРУППИРОВАТЬ ПО
				   |	ДвиженияЗапасыИзменение.Организация,
				   |	ДвиженияЗапасыИзменение.СтруктурнаяЕдиница,
				   |	ДвиженияЗапасыИзменение.СчетУчетаРегл,
				   |	ДвиженияЗапасыИзменение.Номенклатура,
				   |	ДвиженияЗапасыИзменение.Характеристика,
				   |	ДвиженияЗапасыИзменение.Партия,
				   |	ДвиженияЗапасыИзменение.Проект,
				   |	ДвиженияЗапасыИзменение.ЗаказПокупателя,
				   |	ДвиженияЗапасыИзменение.Номенклатура.ЕдиницаИзмерения
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	МИНИМУМ(ДвиженияРезервированиеЗапасовИзменение.НомерСтроки) КАК НомерСтроки,
	               |	ДвиженияРезервированиеЗапасовИзменение.Организация КАК Организация,
	               |	ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	ДвиженияРезервированиеЗапасовИзменение.Номенклатура КАК Номенклатура,
	               |	ДвиженияРезервированиеЗапасовИзменение.Характеристика КАК Характеристика,
	               |	ДвиженияРезервированиеЗапасовИзменение.Партия КАК Партия,
	               |	ДвиженияРезервированиеЗапасовИзменение.Проект КАК Проект,
	               |	СУММА(ЕСТЬNULL(РезервированиеЗапасовОстатки.КоличествоОстаток, 0)) КАК ОстатокЗапасы,
	               |	СУММА(ЕСТЬNULL(ДвиженияРезервированиеЗапасовИзменение.КоличествоПриЗаписи, 0)) КАК КоличествоДвижение
	               |ПОМЕСТИТЬ ТЗ_Резервы
	               |ИЗ
	               |	ДвиженияРезервированиеЗапасовИзменение КАК ДвиженияРезервированиеЗапасовИзменение
	               |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |			ДвиженияРезервированиеЗапасовИзменение.Организация КАК Организация,
	               |			ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |			ДвиженияРезервированиеЗапасовИзменение.Документ КАК Документ,
	               |			ДвиженияРезервированиеЗапасовИзменение.Номенклатура КАК Номенклатура,
	               |			ДвиженияРезервированиеЗапасовИзменение.Характеристика КАК Характеристика,
	               |			ДвиженияРезервированиеЗапасовИзменение.Партия КАК Партия,
	               |			ДвиженияРезервированиеЗапасовИзменение.Проект КАК Проект,
	               |			СУММА(ВЫБОР
	               |					КОГДА ДвиженияРезервированиеЗапасовИзменение.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	               |						ТОГДА ДвиженияРезервированиеЗапасовИзменение.КоличествоПриЗаписи
	               |					ИНАЧЕ -ДвиженияРезервированиеЗапасовИзменение.КоличествоПриЗаписи
	               |				КОНЕЦ) КАК КоличествоПриЗаписи
	               |		ИЗ
	               |			ДвиженияРезервированиеЗапасовИзменение КАК ДвиженияРезервированиеЗапасовИзменение
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			ДвиженияРезервированиеЗапасовИзменение.Организация,
	               |			ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница,
	               |			ДвиженияРезервированиеЗапасовИзменение.Документ,
	               |			ДвиженияРезервированиеЗапасовИзменение.Номенклатура,
	               |			ДвиженияРезервированиеЗапасовИзменение.Характеристика,
	               |			ДвиженияРезервированиеЗапасовИзменение.Партия,
	               |			ДвиженияРезервированиеЗапасовИзменение.Проект) КАК ДвиженияРезервированиеЗапасовИзменениеСвернутое
	               |		ПО (ДвиженияРезервированиеЗапасовИзменениеСвернутое.Организация = ДвиженияРезервированиеЗапасовИзменение.Организация)
	               |			И (ДвиженияРезервированиеЗапасовИзменениеСвернутое.СтруктурнаяЕдиница = ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница)
	               |			И (ДвиженияРезервированиеЗапасовИзменениеСвернутое.Номенклатура = ДвиженияРезервированиеЗапасовИзменение.Номенклатура)
	               |			И (ДвиженияРезервированиеЗапасовИзменениеСвернутое.Характеристика = ДвиженияРезервированиеЗапасовИзменение.Характеристика)
	               |			И (ДвиженияРезервированиеЗапасовИзменениеСвернутое.Партия = ДвиженияРезервированиеЗапасовИзменение.Партия)
	               |			И (ВЫБОР
	               |				КОГДА &КонтролироватьОстаткиПриПроведенииПоПроектам
	               |					ТОГДА ДвиженияРезервированиеЗапасовИзменениеСвернутое.Проект = ДвиженияРезервированиеЗапасовИзменение.Проект
	               |				ИНАЧЕ ИСТИНА
	               |			КОНЕЦ)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РезервированиеЗапасов.Остатки(
	               |				&МоментКонтроляРезерва,
	               |				(Организация, СтруктурнаяЕдиница, Номенклатура, Характеристика, Партия) В
	               |					(ВЫБРАТЬ
	               |						ДвиженияРезервированиеЗапасовИзменение.Организация КАК Организация,
	               |						ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |						ДвиженияРезервированиеЗапасовИзменение.Номенклатура КАК Номенклатура,
	               |						ДвиженияРезервированиеЗапасовИзменение.Характеристика КАК Характеристика,
	               |						ДвиженияРезервированиеЗапасовИзменение.Партия КАК Партия
	               |					ИЗ
	               |						ДвиженияРезервированиеЗапасовИзменение КАК ДвиженияРезервированиеЗапасовИзменение)) КАК РезервированиеЗапасовОстатки
	               |		ПО ДвиженияРезервированиеЗапасовИзменение.Организация = РезервированиеЗапасовОстатки.Организация
	               |			И ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница = РезервированиеЗапасовОстатки.СтруктурнаяЕдиница
	               |			И ДвиженияРезервированиеЗапасовИзменение.Номенклатура = РезервированиеЗапасовОстатки.Номенклатура
	               |			И ДвиженияРезервированиеЗапасовИзменение.Характеристика = РезервированиеЗапасовОстатки.Характеристика
	               |			И ДвиженияРезервированиеЗапасовИзменение.Партия = РезервированиеЗапасовОстатки.Партия
	               |			И (ВЫБОР
	               |				КОГДА &КонтролироватьОстаткиПриПроведенииПоПроектам
	               |					ТОГДА ДвиженияРезервированиеЗапасовИзменение.Проект = РезервированиеЗапасовОстатки.Проект
	               |				ИНАЧЕ ИСТИНА
	               |			КОНЕЦ),
	               |	Константы КАК Константы
	               |ГДЕ
	               |	ДвиженияРезервированиеЗапасовИзменение.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	               |	И Константы.ФункциональнаяОпцияРезервированиеЗапасов_new
	               |	И НЕ ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница.КонтролироватьОстатки
				   |
				   |СГРУППИРОВАТЬ ПО
				   |	ДвиженияРезервированиеЗапасовИзменение.Организация,
				   |	ДвиженияРезервированиеЗапасовИзменение.СтруктурнаяЕдиница,
				   |	ДвиженияРезервированиеЗапасовИзменение.Номенклатура,
				   |	ДвиженияРезервированиеЗапасовИзменение.Характеристика,
				   |	ДвиженияРезервированиеЗапасовИзменение.Партия,
				   |	ДвиженияРезервированиеЗапасовИзменение.Проект
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ_Запасы.НомерСтроки КАК НомерСтроки,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.Организация) КАК ОрганизацияПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиницаПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.СчетУчетаРегл) КАК СчетУчетаРеглПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.Номенклатура) КАК НоменклатураПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.Характеристика) КАК ХарактеристикаПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.Партия) КАК ПартияПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.Проект) КАК ПроектПредставление,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.ЗаказПокупателя) КАК ЗаказПокупателяПредставление,
	               |	ЕСТЬNULL(ВЫРАЗИТЬ(ТЗ_Запасы.СтруктурнаяЕдиница КАК Справочник.СтруктурныеЕдиницы).ТипСтруктурнойЕдиницы, """""""") КАК ТипСтруктурнойЕдиницы,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ТЗ_Запасы.ЕдиницаИзмерения) КАК ЕдиницаИзмеренияПредставление,
	               |	ЕСТЬNULL(ТЗ_Запасы.ОстатокЗапасы, 0) - ЕСТЬNULL(ТЗ_Резервы.ОстатокЗапасы, 0) КАК ОстатокЗапасы,
	               |	ЕСТЬNULL(ТЗ_Запасы.ОстатокЗапасы, 0) - ЕСТЬNULL(ТЗ_Резервы.ОстатокЗапасы, 0) - (ТЗ_Запасы.КоличествоДвижение - ТЗ_Резервы.КоличествоДвижение) КАК КоличествоОстатокЗапасы
	               |ИЗ
	               |	ТЗ_Запасы КАК ТЗ_Запасы
	               //|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЗ_Резервы КАК ТЗ_Резервы
				   |		ЛЕВОЕ СОЕДИНЕНИЕ ТЗ_Резервы КАК ТЗ_Резервы
	               |		ПО ТЗ_Запасы.Организация = ТЗ_Резервы.Организация
	               |			И ТЗ_Запасы.СтруктурнаяЕдиница = ТЗ_Резервы.СтруктурнаяЕдиница
	               |			И ТЗ_Запасы.Номенклатура = ТЗ_Резервы.Номенклатура
	               |			И ТЗ_Запасы.Характеристика = ТЗ_Резервы.Характеристика
	               |			И ТЗ_Запасы.Партия = ТЗ_Резервы.Партия
	               |			И (ВЫБОР
	               |				КОГДА &КонтролироватьОстаткиПриПроведенииПоПроектам
	               |					ТОГДА ТЗ_Запасы.Проект = ТЗ_Резервы.Проект
	               |				ИНАЧЕ ИСТИНА
	               |			КОНЕЦ)
	               |ГДЕ
	               |	ЕСТЬNULL(ТЗ_Запасы.ОстатокЗапасы, 0) - ЕСТЬNULL(ТЗ_Резервы.ОстатокЗапасы, 0) - (ТЗ_Запасы.КоличествоДвижение - ТЗ_Резервы.КоличествоДвижение) < 0
				   //+++ Дмгг, Исключение по реквизиту справочника
	               |	И НЕ ВЫРАЗИТЬ(ТЗ_Запасы.СтруктурнаяЕдиница КАК Справочник.СтруктурныеЕдиницы).КонтролироватьОстатки
				   //--- Дмгг
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	НомерСтроки";	
	
	Если ДобавитьРзделитель Тогда
		ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов()
	КонецЕсли;
	
	Возврат ТекстЗапроса;
			
КонецФункции

Функция ТекстЗапросаПоВременнойТаблицеЗапасов() ЭКСПОРТ
    ПЕРЕМ РЕЗ;
	
	РЕЗ = "ВЫБРАТЬ
	      |	РезервированиеЗапасовОстатки.Организация КАК Организация,
	      |	РезервированиеЗапасовОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	      |	РезервированиеЗапасовОстатки.Номенклатура.СчетУчетаЗапасов КАК СчетУчета,
	      |	РезервированиеЗапасовОстатки.Номенклатура.СчетУчетаЗапасовРегл КАК СчетУчетаРегл,
	      |	РезервированиеЗапасовОстатки.Документ КАК ЗаказПокупателя,
	      |	РезервированиеЗапасовОстатки.Номенклатура КАК Номенклатура,
	      |	РезервированиеЗапасовОстатки.Характеристика КАК Характеристика,
	      |	РезервированиеЗапасовОстатки.Партия КАК Партия,
	      |	РезервированиеЗапасовОстатки.Проект КАК Проект,
	      |	СУММА(РезервированиеЗапасовОстатки.КоличествоОстаток) КАК КоличествоОстаток
	      |ИЗ
	      |	РегистрНакопления.РезервированиеЗапасов.Остатки(
	      |			&Период,
	      |			(Номенклатура, Характеристика, Партия, Документ) В
	      |				(ВЫБРАТЬ
	      |					ТаблицаЗапасы.Номенклатура,
	      |					ТаблицаЗапасы.Характеристика,
	      |					ТаблицаЗапасы.Партия,
	      |					ТаблицаЗапасы.ЗаказПокупателя
	      |				ИЗ
	      |					ВременнаяТаблицаЗапасы КАК ТаблицаЗапасы)) КАК РезервированиеЗапасовОстатки
	      |ГДЕ
	      |	ВЫБОР
	      |			КОГДА &Организация ЕСТЬ NULL
	      |					ИЛИ &Организация = НЕОПРЕДЕЛЕНО
	      |					ИЛИ &Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	      |				ТОГДА ИСТИНА
	      |			ИНАЧЕ &Организация = РезервированиеЗапасовОстатки.Организация
	      |		КОНЕЦ
	      |	И ВЫБОР
	      |			КОГДА &СтруктурнаяЕдиница ЕСТЬ NULL
	      |					ИЛИ &СтруктурнаяЕдиница = НЕОПРЕДЕЛЕНО
	      |					ИЛИ &СтруктурнаяЕдиница = ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)
	      |				ТОГДА ИСТИНА
	      |			ИНАЧЕ &СтруктурнаяЕдиница = РезервированиеЗапасовОстатки.СтруктурнаяЕдиница
	      |		КОНЕЦ
	      |
	      |СГРУППИРОВАТЬ ПО
	      |	РезервированиеЗапасовОстатки.Организация,
	      |	РезервированиеЗапасовОстатки.СтруктурнаяЕдиница,
	      |	РезервированиеЗапасовОстатки.Номенклатура.СчетУчетаЗапасов,
	      |	РезервированиеЗапасовОстатки.Номенклатура.СчетУчетаЗапасовРегл,
	      |	РезервированиеЗапасовОстатки.Документ,
	      |	РезервированиеЗапасовОстатки.Номенклатура,
	      |	РезервированиеЗапасовОстатки.Характеристика,
	      |	РезервированиеЗапасовОстатки.Партия,
	      |	РезервированиеЗапасовОстатки.Проект";
	
	Возврат РЕЗ;

КонецФункции // ТекстЗапросаПоВременнойТаблицеЗапасов()

Функция ПолучитьОборотыРезервовПоДокументу(ДокументОснование,ДатаПроверки=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	МассивТиповСтруктурнаяЕдиница = Новый Массив();
	МассивТиповСтруктурнаяЕдиница.Добавить(Тип("СправочникСсылка.СтруктурныеЕдиницы"));
	МассивТиповСтруктурнаяЕдиница.Добавить(Тип("СправочникСсылка.Контрагенты"));
	ОписаниеТиповСтруктурнаяЕдиница = Новый ОписаниеТипов(МассивТиповСтруктурнаяЕдиница);
	
	РЕЗ = Новый ТаблицаЗначений();
	РЕЗ.Колонки.Добавить("Организация",Новый ОписаниеТипов("СправочникСсылка.Организации"));
	РЕЗ.Колонки.Добавить("СтруктурнаяЕдиница",ОписаниеТиповСтруктурнаяЕдиница);
	РЕЗ.Колонки.Добавить("Документ",Документы.ТипВсеСсылки());
	РЕЗ.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	РЕЗ.Колонки.Добавить("Характеристика",Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	РЕЗ.Колонки.Добавить("Партия",Новый ОписаниеТипов("СправочникСсылка.ПартииНоменклатуры"));
	РЕЗ.Колонки.Добавить("Проект",Новый ОписаниеТипов("СправочникСсылка.Проекты"));
	РЕЗ.Колонки.Добавить("КоличествоПриход",ОбщегоНазначения.ОписаниеТипаЧисло(15,3));
	РЕЗ.Колонки.Добавить("КоличествоРасход",ОбщегоНазначения.ОписаниеТипаЧисло(15,3));
	РЕЗ.Колонки.Добавить("КоличествоОборот",ОбщегоНазначения.ОписаниеТипаЧисло(15,3));
	
	Если НЕ Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(ДокументОснование)) Тогда
	
		Возврат РЕЗ;
		
	Иначе
		
		Если НЕ ЗначениеЗаполнено(ДокументОснование) Тогда
		
			Возврат РЕЗ;
		
		КонецЕсли;
	
	КонецЕсли;
	
	Если ДатаПроверки=НЕОПРЕДЕЛЕНО
		ИЛИ (НЕ ((ТипЗНЧ(ДатаПроверки) = Тип("Дата")) И (ТипЗНЧ(ДатаПроверки) = Тип("МоментВремени")) И (ТипЗНЧ(ДатаПроверки) = Тип("Граница"))))
		Тогда
	
		ДатаПроверки = ТекущаяДата();
	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РезервированиеЗапасовОстаткиИОбороты.Организация КАК Организация,
		|	РезервированиеЗапасовОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	РезервированиеЗапасовОстаткиИОбороты.Документ КАК Документ,
		|	РезервированиеЗапасовОстаткиИОбороты.Номенклатура КАК Номенклатура,
		|	РезервированиеЗапасовОстаткиИОбороты.Характеристика КАК Характеристика,
		|	РезервированиеЗапасовОстаткиИОбороты.Партия КАК Партия,
		|	РезервированиеЗапасовОстаткиИОбороты.Проект КАК Проект,
		|	РезервированиеЗапасовОстаткиИОбороты.КоличествоПриход КАК КоличествоПриход,
		|	РезервированиеЗапасовОстаткиИОбороты.КоличествоРасход КАК КоличествоРасход,
		|	РезервированиеЗапасовОстаткиИОбороты.КоличествоОборот КАК КоличествоОборот
		|ИЗ
		|	РегистрНакопления.РезервированиеЗапасов.ОстаткиИОбороты(, &ДатаПроверки, , , Документ = &ДокументОснование) КАК РезервированиеЗапасовОстаткиИОбороты";
	
	Запрос.УстановитьПараметр("ДатаПроверки", ДатаПроверки);
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	РЕЗ = РезультатЗапроса.Выгрузить();
	
	Возврат РЕЗ;
КонецФункции

