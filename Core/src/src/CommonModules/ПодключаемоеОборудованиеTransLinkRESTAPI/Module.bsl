Процедура НачатьЗавершениеОперации_ПодготовитьВыходныеДанные(РезультатЗавершения, ДополнительныеПараметры)
	
	РезультатСобытия = TransLinkRESTAPI.КомандаТерминалу_LOCKDEVICE(ДополнительныеПараметры.Параметры);
	КодАвторизации = ДополнительныеПараметры.СписокСтрокСлипЧека.КодАвторизации;
	
	Если ДополнительныеПараметры.СписокСтрокСлипЧека.Результат Тогда
			
		//ВыходныеПараметры.Добавить("****************");
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.НомерКарты); //0
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.СсылочныйНомер);  //1
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.НомерЧекаЭТ); //2
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(Новый Массив()); //3
		ДополнительныеПараметры.ВыходныеПараметры[3].Добавить("СлипЧек");
		ДополнительныеПараметры.ВыходныеПараметры[3].Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.СлипОтХоста);
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(КодАвторизации);  //4
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека);
	Иначе
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.НомерКарты);
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены);
		
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(Новый Массив());
		ДополнительныеПараметры.ВыходныеПараметры[3].Добавить("СлипЧек");
		ДополнительныеПараметры.ВыходныеПараметры[3].Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.СлипОтХоста);
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(КодАвторизации);
		ДополнительныеПараметры.ВыходныеПараметры.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека);
		
	КонецЕсли;
	
	
	Если ДополнительныеПараметры.ОповещениеПриЗавершении <> Неопределено Тогда
		Результат = Новый Структура("Результат, ВыходныеПараметры", ДополнительныеПараметры.СписокСтрокСлипЧека.Результат, ДополнительныеПараметры.ВыходныеПараметры);
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеПриЗавершении, Результат);
	КонецЕсли;
		
КонецПроцедуры	

Функция ТестУстройства(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры)
//Функция ТестУстройства(Объект, TerminalID, COMПортФР, мRequest, мМассив, TerminalAlias, ИспользоватьTranslinkДляТерминала)

	Результат = Ложь; 
	
	ДополнительноеОписание = "Результат подключения:";
	
	Если НЕ TransLinkRESTAPI.ПолученТокен(Параметры) Тогда
		СтруктураПодключение = TransLinkRESTAPI.КомандаТерминалу_OPENPOS(Параметры); 
	КонецЕсли;	
	
	СтруктураОтвета = TransLinkRESTAPI.КомандаТерминалу_GETPOSSTATUS(Параметры);
	
	ДополнительноеОписание = ДополнительноеОписание + "
	|Code   : " + СтруктураОтвета.TypeResult.resultCode + "
	|Message: " + СтруктураОтвета.TypeResult.resultMessage + "
	|Time   : " + СтруктураОтвета.TypeResult.resultTime;
	
	Если СтруктураОтвета.TypeResult.resultCode = TransLinkRESTAPI.TypeResult_OK() Тогда
		Результат = истина;
	КонецЕсли;	
	
	ВыходныеПараметры.Добавить("Начали подключение"); //0
    ВыходныеПараметры.Добавить(ДополнительноеОписание); //

	Возврат Результат;

КонецФункции
