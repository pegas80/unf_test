//Оплата платежной картой - Начало

Процедура НачатьОплатуПлатежнойКартой(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения,
	                                        ДанныеДокумента, ВыходныеПараметры, ВходныеПараметры);
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("ОбъектДрайвера"         , ОбъектДрайвера);
	ДополнительныеПараметры.Вставить("ДанныеДокумента"        , ДанныеДокумента);
	ДополнительныеПараметры.Вставить("Параметры"              , Параметры);
	ДополнительныеПараметры.Вставить("ПараметрыПодключения"   , ПараметрыПодключения);
	ДополнительныеПараметры.Вставить("ВыходныеПараметры"      , ВыходныеПараметры);
	ДополнительныеПараметры.Вставить("ВходныеПараметры"       , Входныепараметры);
	ДополнительныеПараметры.Вставить("ОповещениеПриЗавершении", ОповещениеПриЗавершении);
	ДополнительныеПараметры.Вставить("СписокСтрокСлипЧека"	  , TransLinkRESTAPI.СоздатьСтрокиСлипЧека());
	ДополнительныеПараметры.Вставить("СписокСобытийТерминала" , новый Соответствие); //Список событий от терминала
	
	
	//ОповещениеПриПолученииВсехСобытий = Новый ОписаниеОповещения("ПолучениеСобытийОтТерминала_ОбработаемСобытияОтТерминала", ЭтотОбъект, ДополнительныеПараметры);
	//ДополнительныеПараметры.Вставить("Оповещение_ОбработатьВсеСобытия", ОповещениеПриПолученииВсехСобытий);
	
	ОповещениеПриПолученииВсехСобытий2 = Новый ОписаниеОповещения("НачатьВызовОплатитьПлатежнойКартой_ТранзакцияСБанком", ЭтотОбъект, ДополнительныеПараметры);
	ДополнительныеПараметры.Вставить("Оповещение_ТранзакцияСБанком", ОповещениеПриПолученииВсехСобытий2);
	
	
	ОповещениеНачатьЗавершениеОперации = Новый ОписаниеОповещения("НачатьЗавершениеОперации", ЭтотОбъект, ДополнительныеПараметры);
	ДополнительныеПараметры.Вставить("Оповещение_НачатьЗавершениеОперации", ОповещениеНачатьЗавершениеОперации);
	
	
	//анлок
	//получить все события
	//обработать все события
	// если карта представлена и действительна 
	// транзакция с банком
	// получить все события
	// обработать все события
	//отправка результат
	
	
	Сумма = ДанныеДокумента.Сумма;
	
	Если НЕ (Сумма > 0) Тогда
		ПараметрыПодключения.ТипТранзакции = НСтр("ru = 'Отказ';
													|en = 'Cancel'");
		ВыходныеПараметры.Очистить();
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить(НСтр("ru = 'Не корректная сумма операции.';
