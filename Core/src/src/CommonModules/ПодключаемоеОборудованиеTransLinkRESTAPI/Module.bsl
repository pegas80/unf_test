Процедура ПолучениеСобытийОтТерминала_Ожидаем(РезультатОповещения, ДополнительныеПараметры) Экспорт 
	//Параметры, СтрокаСообщения="", БесконечныйЦикл = Истина, ПрерватьсяНаПустомСобытии = Ложь)
	//СтрокаСообщения = "Ожидаем";
	ПрерватьсяНаПустомСобытии = Ложь;
	
	БесконечныйЦикл = Ложь;
	
	Параметры = ДополнительныеПараметры.Параметры;
	
	Результат = Неопределено;
	РезультатПолучен = Ложь;

	Задержка = 6;
	
	ДатаОкончания = ТекущаяДата() + Задержка;
	ВремяЗакончилось = Ложь;
	ПолученыВсеСобытия = Ложь;
	
	
	
	ТекстСообщения = 
	"" + Параметры.TerminalAlias + "
	|" + РезультатОповещения.ТекстОжидания + "
	|";  
	
	//ПрерватьсяНаПустомСобытии = (ДополнительныеПараметры.СписокСобытийТерминала.Количество()>0);
		
	СтруктураПараметров = Новый Структура("ИдентификаторЗадания, ТекстСообщения", Неопределено, ТекстСообщения);
	ФормаЗаставка = ОткрытьФорму("ОбщаяФорма.ДлительнаяОперация", СтруктураПараметров, Неопределено);
	
	ДополнительныеПараметры.Вставить("ФормаЗаставка", ФормаЗаставка);
	
	ТекДата = ТекущаяДата(); 
	eventName = "";
	
	Пока Истина Цикл
		
		Если ДополнительныеПараметры.СписокСобытийТерминала.Количество()>0 
		 и
		 (ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONCARD")<>Неопределено 
			или ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONCARDREMOVE")<>Неопределено 
			или ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONPRINT")<>Неопределено 
			или ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONTRNSTATUS")<>Неопределено 
			или ДополнительныеПараметры.СписокСобытийТерминала.Получить("CANCEL")<>Неопределено //Если нажали отмену
		 ) Тогда
		
	        ПрерватьсяНаПустомСобытии = Истина;
			РезультатПолучен = Истина;
		КонецЕсли;	
		
		МенеджерОборудованияКлиент.Пауза(1);
		
		РезультатСобытия = TransLinkRESTAPI.ПолучитьСобытиеОтТерминала_RestX(Параметры);
		
		Если Ложь Тогда //Отладка       
			РезультатСобытия.eventType = TransLinkRESTAPI.eventType_QueueEmpty();
		КонецЕсли;
		
		eventType = РезультатСобытия.eventType;
		eventName = eventType.eventName; 
		
		Если ЗначениеЗаполнено(eventName) Тогда                                                       
			//РезультатПолучен = Истина; 
			Результат = РезультатСобытия;         
			ДополнительныеПараметры.СписокСобытийТерминала.Вставить(eventName, eventType);
			//Прервать;
			ДатаОкончания = ДатаОкончания + 2;
			Продолжить;
		
		Иначе
			Если ПрерватьсяНаПустомСобытии тогда
				
				РезультатПолучен = Истина; 
				Результат = РезультатСобытия;
				ПолученыВсеСобытия = Истина;
				прервать;
				//Возврат Результат;
			Иначе         
				
			КонецЕсли;
			
		КонецЕсли;	
		
				
		ТекДата = ТекущаяДата();
		Если ТекДата > ДатаОкончания Тогда
			//Сообщить("Закончилось время ожидания");
			ВремяЗакончилось = Истина;
			Прервать;
		КонецЕсли;
		
		
		Если РезультатПолучен Тогда
			Прервать;
		КонецЕсли;	
		
	КонецЦикла;
	
	ФормаЗаставка.Закрыть();
		
	Если ПолученыВсеСобытия Тогда //ключевые события и в конце пустая очередь
		
		РезультатОповещения = Новый Структура("ПоследнееСобытие",eventType);
		ОповещениеПриПолученииВсехСобытий = Новый ОписаниеОповещения("ПолучениеСобытийОтТерминала_ОбработаемСобытияОтТерминала", ЭтотОбъект, ДополнительныеПараметры);
		ВыполнитьОбработкуОповещения(ОповещениеПриПолученииВсехСобытий, РезультатОповещения);
		
	ИначеЕсли ВремяЗакончилось Тогда              

		ТекстВопроса = НСтр("ru = 'Повторить ожидание?';ka = 'ლოდინის გამეორება?';en = 'Repeat wait?'");;
		КнопкаПоУмолчанию = КодВозвратаДиалога.Да;			
		ВопросОЗавершение_Завершение = Новый ОписаниеОповещения("ПолучениеСобытийОтТерминала_ОтветилиНаВопросОПродолжении", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопрос(ВопросОЗавершение_Завершение, ТекстВопроса, РежимДиалогаВопрос.ДаНет,10, КнопкаПоУмолчанию, ДополнительныеПараметры.Параметры.TerminalAlias, КнопкаПоУмолчанию);
		
	ИначеЕсли ложь и РезультатПолучен Тогда
		
		//ДополнительныеПараметры.СписокСобытийТерминала.Вставить(eventName, eventType);
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.Оповещение_ОбработатьСобытияОтТерминала, Результат);
		
	КонецЕсли;	
	
КонецПроцедуры

Процедура ПолучениеСобытийОтТерминала_ОтветилиНаВопросОПродолжении(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		//Запускаем процедуру ОжидаемСобытияОтТерминала с темиже параметрами
		РезультатОповещения = Новый Структура();
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.Оповещение_ОжидаемСобытияОтТерминала, ДополнительныеПараметры);
		
	Иначе                                                                   
		//формируем событие CANCEL и идем по пути успешного получения события
		
		
		//Результат = Результат;
		
		eventType = TransLinkRESTAPI.eventType();
		eventType.eventName = "CANCEL";
		ДополнительныеПараметры.СписокСобытийТерминала.Вставить(eventType.eventName, eventType);
		
		ОповещениеПриПолученииВсехСобытий = Новый ОписаниеОповещения("ПолучениеСобытийОтТерминала_ОбработаемСобытияОтТерминала", ЭтотОбъект, ДополнительныеПараметры);
		РезультатОповещения = Новый Структура("ПоследнееСобытие",eventType);
		ВыполнитьОбработкуОповещения(ОповещениеПриПолученииВсехСобытий, РезультатОповещения);
		
	КонецЕсли;	
		
КонецПроцедуры	

Процедура ПолучениеСобытийОтТерминала_ОбработаемСобытияОтТерминала(РезультатОбработки, ДополнительныеПараметры) Экспорт
	
	//Обрабатываем результат
	eventType = ДополнительныеПараметры.СписокСобытийТерминала.Получить("CANCEL");
	Если eventType<>Неопределено Тогда 
		ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены = "Операция отменена оператором";
		//Возврат;
	КонецЕсли;
	
	eventType = ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONCARD");
	Если eventType<>Неопределено Тогда 
		ДополнительныеПараметры.СписокСтрокСлипЧека.КартаПредоставлена = Истина;
		ДополнительныеПараметры.СписокСтрокСлипЧека.КартаДействительна = eventType.properties.allowAuthorize;
		ДополнительныеПараметры.СписокСтрокСлипЧека.НомерКарты = eventType.properties.PAN;
		Если ДополнительныеПараметры.СписокСтрокСлипЧека.КартаДействительна = Ложь Тогда
	    	ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены = "Карта не действительна.";
		КонецЕсли;	
	КонецЕсли;					
			
	
	eventType = ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONCARDREMOVE");
	Если eventType<>Неопределено Тогда    
		ДополнительныеПараметры.СписокСтрокСлипЧека.КартаПредоставлена = Ложь;
		ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены = "Карта не представлена.";
	КонецЕсли;
	
	
	
	//получена печатная форма чека
	eventType = ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONPRINT");	
	Если eventType<>Неопределено Тогда
		ДополнительныеПараметры.СписокСтрокСлипЧека.СлипОтХоста = eventType.properties.receiptText; 
	КонецЕсли;
	
	//Получено состояние транзакции
	eventType = ДополнительныеПараметры.СписокСобытийТерминала.Получить("ONTRNSTATUS");	
	Если eventType<>Неопределено Тогда
		ДополнительныеПараметры.СписокСтрокСлипЧека.state  = eventType.properties.state;
		
		TransLinkRESTAPI.ЗаполнитьСписокСтрокСлипЧекаПоСтатусуТерминала(ДополнительныеПараметры.СписокСтрокСлипЧека, eventType, ДополнительныеПараметры.Параметры);
		
			
		//ВходныеПараметры.Вставить("параметрыКоманды", ПараметрыКомандыТерминала);
		
			
		ДополнительныеПараметры.СписокСтрокСлипЧека.Результат = (ДополнительныеПараметры.СписокСтрокСлипЧека.state = "Approved");
		Если не ДополнительныеПараметры.СписокСтрокСлипЧека.Результат Тогда
			ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены = "статус транзакции " + ДополнительныеПараметры.СписокСтрокСлипЧека.state;
		ИначеЕсли ЗначениеЗаполнено(eventType.properties.documentNr) Тогда 
			
			МассивОпераций = Новый Массив;
			МассивОпераций.Добавить(ДополнительныеПараметры.СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
			
			ПараметрыКомандыТерминала = Новый Структура;
			ПараметрыКомандыТерминала.Вставить("operations", МассивОпераций); 
			ПараметрыКомандыТерминала.Вставить("documentNr", eventType.properties.documentNr); 
			//Закроем документ на POS
			РезультатОбработкиCLOSEDOC = TransLinkRESTAPI.КомандаТерминалу_CLOSEDOC(ПараметрыКомандыТерминала, ДополнительныеПараметры.Параметры);	
			
		КонецЕсли;	
		
	КонецЕсли;
	
	Если ДополнительныеПараметры.Параметры.Отладка Тогда
		Сообщить(ДополнительныеПараметры.СтрокаСообщенияОжидания);
		Сообщить("Получено событий "+ ДополнительныеПараметры.СписокСобытийТерминала.Количество());	
		Для каждого ЭлементСобытия из ДополнительныеПараметры.СписокСобытийТерминала Цикл
			Сообщить("  " + ЭлементСобытия.Ключ);	
		КонецЦикла;	
	КонецЕсли;	
	
	
	РезультатОповещения = Новый Структура("ТекстОжидания","Идет транзакция с банком");
	ВыполнитьОбработкуОповещения(ДополнительныеПараметры.Оповещение_ПослеОбработкиСобытийТерминала, РезультатОповещения);
	
КонецПроцедуры

