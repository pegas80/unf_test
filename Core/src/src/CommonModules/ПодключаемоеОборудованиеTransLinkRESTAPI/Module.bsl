// Функция возвращает возможность работы модуля в асинхронном режиме.
// Стандартные команды модуля:
// - ПодключитьУстройство
// - ОтключитьУстройство
// - ВыполнитьКоманду
// Команды модуля для работы асинхронном режиме (должны быть определены):
// - НачатьПодключениеУстройства
// - НачатьОтключениеУстройства
// - НачатьВыполнениеКоманды.
//
Функция ПоддержкаАсинхронногоРежима() Экспорт
	
	Возврат Истина;
	
КонецФункции

// Функция осуществляет подключение устройства.
//
Функция ПодключитьУстройство(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт
	
	РезультатПодключения = TransLinkRESTAPI.КомандаТерминалу_OPENPOS(Параметры);
    
	ВыходныеПараметры = Новый Массив;                                           
		
	ВыходныеПараметры.Добавить("");
	ВыходныеПараметры.Добавить(РезультатПодключения);
	
 	Возврат РезультатПодключения;
	
КонецФункции


// Функция осуществляет отключение устройства.
//
// Параметры:
//  ОбъектДрайвера - <*>
//         - ОбъектДрайвера драйвера торгового оборудования.
//
// Возвращаемое значение:
//  <Булево> - Результат работы функции.
//
Функция ОтключитьУстройство(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт
	
	Результат = Ложь;
	
	ВыходныеПараметры = Новый Массив();
	
	СтруктураОтвета = СтруктураОтветаДляСинхронногоРежима();
	
	ВыходныеПараметры.Добавить("");
	ВыходныеПараметры.Добавить(СтруктураОтвета);
	
	Возврат Результат;
	
КонецФункции

// Функция получает, обрабатывает и перенаправляет на исполнение команду к драйверу.
//
Функция ВыполнитьКоманду(Команда, ВходныеПараметры = Неопределено, ВыходныеПараметры = Неопределено,
                         ОбъектДрайвера, Параметры, ПараметрыПодключения) Экспорт
	
	Результат = Ложь;
	
	ВыходныеПараметры = Новый Массив();
	
	//Для асинхронного обработчика вызывается другая процедура

	// Получение версии драйвера
	Если Команда = "GetVersion"  ИЛИ Команда = "ПолучитьВерсиюДрайвера" Тогда
		
		Результат = ПолучитьВерсиюДрайвера(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	// Тестирование устройства
	ИначеЕсли Команда = "ТестУстройства" ИЛИ Команда = "CheckHealth" Тогда
		
		Результат = ТестУстройства(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);

	
    Иначе

		СтруктураОтвета = СтруктураОтветаДляСинхронногоРежима();
		
		ВыходныеПараметры.Добавить("");
		ВыходныеПараметры.Добавить(СтруктураОтвета);
	
	КонецЕсли;

	Возврат Результат;

КонецФункции

// Функция начинает подключение устройства.
//
Процедура НачатьПодключениеУстройства(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения, ДополнительныеПараметры) Экспорт
	
	ПараметрыПодключения.Вставить("ИДУстройства", "");
	ВыходныеПараметры = Новый Массив();
	
	ДополнительныеПараметры.Вставить("ОбъектДрайвера"         , ОбъектДрайвера);
	ДополнительныеПараметры.Вставить("Параметры"              , Параметры);
	ДополнительныеПараметры.Вставить("ПараметрыПодключения"   , ПараметрыПодключения);
	ДополнительныеПараметры.Вставить("ВыходныеПараметры"      , ВыходныеПараметры);
	ДополнительныеПараметры.Вставить("ОповещениеПриЗавершении", ОповещениеПриЗавершении);
	
	ОповещениеПриУстановкеПараметров = Новый ОписаниеОповещения("НачатьПодключениеУстройства_УстановкаПараметровЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	НачатьУстановкуПараметров(ОповещениеПриУстановкеПараметров, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура НачатьУстановкуПараметров(ОповещениеПриУстановкеПараметров, ДополнительныеПараметры)
	
		
	//ДополнительныеПараметры.Параметры = Параметры; 
	
	ВыполнитьОбработкуОповещения(ОповещениеПриУстановкеПараметров, Неопределено);
	
Конецпроцедуры	

Процедура НачатьПодключениеУстройства_УстановкаПараметровЗавершение(РезультатПодключения, ДополнительныеПараметры) Экспорт
	
	РезультатПодключения = TransLinkRESTAPI.КомандаТерминалу_OPENPOS(ДополнительныеПараметры.Параметры);

	ДополнительныеПараметры.ВыходныеПараметры = Новый Массив;                                           
		
	ДополнительныеПараметры.ВыходныеПараметры.Добавить("");
	ДополнительныеПараметры.ВыходныеПараметры.Добавить(РезультатПодключения);
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("Результат", TransLinkRESTAPI.ПолученТокен(ДополнительныеПараметры.Параметры));
	СтруктураОтвета.Вставить("ВыходныеПараметры", ДополнительныеПараметры.ВыходныеПараметры);
	
	ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеПриЗавершении, СтруктураОтвета);
	
КонецПроцедуры	


// Функция начинает отключение устройства.
//
Процедура НачатьОтключениеУстройства(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт
	
	ПараметрыКоманды = Новый Структура();
	ПараметрыКоманды.Вставить("ОповещениеПриЗавершении", ОповещениеПриЗавершении);
	ПараметрыКоманды.Вставить("ОбъектДрайвера"         , ОбъектДрайвера);
	ПараметрыКоманды.Вставить("Параметры"              , Параметры);
	ПараметрыКоманды.Вставить("ПараметрыПодключения"   , ПараметрыПодключения);
	ПараметрыКоманды.Вставить("ВыходныеПараметры"      , ВыходныеПараметры);
	
	ОповещениеМетода = Новый ОписаниеОповещения("НачатьОтключениеУстройства_Завершение", ЭтотОбъект, ПараметрыКоманды);
	
	Попытка
		//ОбъектДрайвера.НачатьВызовОтключить(ОповещениеМетода, ПараметрыПодключения.ИДУстройства);
		
		Результат = Новый Структура("Результат, ВыходныеПараметры", Ложь, ВыходныеПараметры);
		ВыполнитьОбработкуОповещения(ОповещениеМетода, Результат);
		
	Исключение
		Если ВыходныеПараметры = Неопределено ТОгда
			ВыходныеПараметры = Новый Массив;
		КонецЕсли;	
		ПричинаОтмены = НСтр("ka='მეთოდ <დრაივერისობიექტი.გამორთვა>-ს მოხმობის შეცდომა.';ru='Ошибка вызова метода <ОбъектДрайвера.Отключить>.';en='The call to the <ObektDrayvera.Otklyuchit>.'");
		ТекстОшибки = ОписаниеОшибки();
		
		ВыходныеПараметры.Очистить();
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить(ПричинаОтмены + " " + ТекстОшибки);
		Если ОповещениеПриЗавершении <> Неопределено Тогда
			Результат = Новый Структура("Результат, ВыходныеПараметры", Ложь, ВыходныеПараметры);
			ВыполнитьОбработкуОповещения(ОповещениеПриЗавершении, Результат);
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

Процедура НачатьОтключениеУстройства_Завершение(Результат, ПараметрыКоманды) Экспорт
	
	СтруктураОтвета = TransLinkRESTAPI.КомандаТерминалу_CLOSEPOS(ПараметрыКоманды.Параметры);
	
	Если ПараметрыКоманды.ВыходныеПараметры = Неопределено Тогда
		ПараметрыКоманды.ВыходныеПараметры = Новый Массив;	
	КонецЕсли;	
	
	ПараметрыКоманды.ВыходныеПараметры.Очистить();
	ПараметрыКоманды.ВыходныеПараметры.Добавить(999);
	ПараметрыКоманды.ВыходныеПараметры.Добавить(НСтр("ka='.';ru='Отключен.';en='.'"));
	
	Результат = Новый Структура("Результат, ВыходныеПараметры", Истина, ПараметрыКоманды.ВыходныеПараметры);
	ВыполнитьОбработкуОповещения(ПараметрыКоманды.ОповещениеПриЗавершении, Результат);
	
КонецПроцедуры

// Процедура начинает выполнение команды, обрабатывает и перенаправляет на исполнение команду к драйверу.
//
Процедура НачатьВыполнениеКоманды(ОповещениеПриЗавершении, Команда, ВходныеПараметры = Неопределено, ОбъектДрайвера, Параметры, ПараметрыПодключения) Экспорт
	
	ВыходныеПараметры = Новый Массив();
	
	// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩИЕ ДЛЯ ВСЕХ ТИПОВ ДРАЙВЕРОВ
	
	// Тестирование устройства
	Если Команда = "ТестУстройства" ИЛИ Команда = "CheckHealth" Тогда
		///НачатьТестУстройства(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "ВыполнитьДополнительноеДействие" ИЛИ Команда = "DoAdditionalAction" Тогда
		ИмяДействия = ВходныеПараметры[0];
		//НачатьВыполнитьДополнительноеДействие(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения, ИмяДействия, ВыходныеПараметры);
		
	// Получение версии драйвера
	ИначеЕсли Команда = "ПолучитьВерсиюДрайвера" ИЛИ Команда = "GetVersion" Тогда
		НачатьПолучениеВерсииДрайвера(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	// Получение описание драйвера.
	ИначеЕсли Команда = "ПолучитьОписаниеДрайвера" ИЛИ Команда = "GetDescription" Тогда
		//НачатьПолучениеОписаниеДрайвера(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩИЕ ДЛЯ РАБОТЫ С УСТРОЙСТВАМИ ВВОДА ДАННЫХ
	
	// Обработка события от устройства.
	ИначеЕсли Команда = "ОбработатьСобытие" Тогда
		Событие = ВходныеПараметры[0];
		Данные  = ВходныеПараметры[1];
		//Результат = ОбработатьСобытие(ОбъектДрайвера, Параметры, ПараметрыПодключения, Событие, Данные, ВыходныеПараметры);
		
	// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩИЕ ДЛЯ РАБОТЫ С ЭКВАЙРИНГОВЫМ ТЕРМИНАЛОМ
		
	ИначеЕсли Команда = "PrintSlipOnTerminal" ИЛИ Команда = "ПечатьКвитанцийНаТерминале" Тогда
		
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить(НСтр("ru = 'Ок.'"));
		Результат = Новый Структура("Результат, ВыходныеПараметры", Истина, ВыходныеПараметры);
		ВыполнитьОбработкуОповещения(ОповещениеПриЗавершении, Результат);
		
	// Оплата платежной картой	
	ИначеЕсли Команда = "AuthorizeSales" ИЛИ Команда = "ОплатитьПлатежнойКартой" Тогда
		ДанныеДокумента = Новый Структура;
		ДанныеДокумента.Вставить("Сумма", ВходныеПараметры[0]);
		ДанныеДокумента.Вставить("НомерКарты", ВходныеПараметры[1]);
		ДанныеДокумента.Вставить("НомерЧека", ?(ВходныеПараметры.Количество() > 2, ВходныеПараметры[2], "")); 
		ДанныеДокумента.Вставить("documentNr", TransLinkRESTAPI.ПолучитьПроизвольныйНомерДокументаСтрокой());
		
		ДанныеДокумента.Вставить("posOperation", TransLinkRESTAPI.posOperation_AUTHORIZE());

		НачатьОплатуПлатежнойКартой(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения,
	                                        ДанныеДокумента, ВыходныеПараметры, ВходныеПараметры);
	
	// Отмена платежа
	ИначеЕсли Команда = "AuthorizeVoid" ИЛИ Команда = "ОтменитьПлатежПоПлатежнойКарте" Тогда
		//Сумма          = ВходныеПараметры[0];
		СсылочныйНомер = ВходныеПараметры[1];
		//НомерЧека      = ?(ВходныеПараметры.Количество() > 2, ВходныеПараметры[2], "");
		
		ДанныеДокумента = Новый Структура;
		ДанныеДокумента.Вставить("Сумма", ВходныеПараметры[0]);
		
		Если Лев(СсылочныйНомер,1)="{" ТОгда
			СтруктураВозврата = TransLinkRESTAPI.ИзJSON_в_Данные1с(СсылочныйНомер);
			СуммаДокументаОснования = СтруктураВозврата.ИзначальнаяСумма;
			СсылочныйНомер = СтруктураВозврата.СсылочныйНомер;
			ДанныеДокумента.Вставить("СуммаПервоначальная", СуммаДокументаОснования);
		
		КонецЕсли;
		
		ДанныеДокумента.Вставить("operationId", СсылочныйНомер);
		ДанныеДокумента.Вставить("posOperation", TransLinkRESTAPI.posOperation_NOOPERATION());
		
		НачатьОтменуПлатежаПоПлатежнойКарте(ОповещениеПриЗавершении, ОбъектДрайвера, Параметры, ПараметрыПодключения,
		                                    ДанныеДокумента, ВыходныеПараметры);
	
	ИначеЕсли Команда = "Settlement" или Команда = "ИтогиДняПоКартам" Тогда
		
		НачатьформированиеИтогиДняПоКартам(ОповещениеПриЗавершении, ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);

	
	Иначе 
		ТекстОшибки = НСтр("ru = 'Команда ""%Команда%"" не поддерживается данным драйвером.';
										|en = 'The ""%Команда%"" command is not supported by the driver.'");
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Команда%", Команда);
		
		СообщитьОбОшибкеОперации(ОповещениеПриЗавершении, ВыходныеПараметры, ТекстОшибки);
	
	КонецЕсли;
	
КонецПроцедуры
	

#КонецОбласти //ПрограммныйИнтерфейс   

