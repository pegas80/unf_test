	ТекстОшибки = "";
	
	Если ДополнительныеПараметры.СписокСтрокСлипЧека.КартаПредоставлена Тогда
		Если ДополнительныеПараметры.СписокСтрокСлипЧека.КартаДействительна Тогда               
			
			//Отправляем запрос в банк на подтверждение
			РезультатКомандыОперации = TransLinkRESTAPI.КомандаТерминалуНачатьДействие(ДополнительныеПараметры.ДанныеДокумента, ДополнительныеПараметры.ВходныеПараметры, ДополнительныеПараметры.Параметры);	
			
            ЗапуститьПолучениеСобытийОтТерминала(ДополнительныеПараметры,"Ожидаем окончания транзакции с банком");
			
		Иначе
			ТекстОшибки = ТекстОшибки + "Карта не действительна";
		КонецЕсли;
	Иначе
		ТекстОшибки = ТекстОшибки + "Карта не предоставлена";
	КонецЕсли;
	
	Если ТекстОшибки<>"" ТОгда
		//Вызвать команду завершения с описанием ошибки 
		Если не ЗначениеЗаполнено(ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены) Тогда
			ДополнительныеПараметры.СписокСтрокСлипЧека.ПричинаОтмены = ТекстОшибки;
		КонецЕсли;	
		СообщитьОбОшибкеОперации(ДополнительныеПараметры.ОповещениеПриЗавершении, ДополнительныеПараметры.Выходныепараметры, ТекстОшибки);
	КонецЕсли;	

	
КонецПроцедуры	

