Процедура ЗавершениеВводаПароляOTP(Результат, ДополнительныеПараметры) ЭКСПОРТ
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		ПараметрыСоединенияProCredit = ДополнительныеПараметры.ПараметрыСоединенияProCredit;
		СтруктураПарметровЗапросаВБанк = ДополнительныеПараметры.СтруктураПарметровЗапросаВБанк;
		
		ПараметрыСоединенияProCredit.OTP = СокрЛП(Результат);
		ИнтеграцияСБанкомProCredit_КлиентСервер.ВыполнитьЗапросВБанк(ПараметрыСоединенияProCredit, СтруктураПарметровЗапросаВБанк);
		
		Оповестить("ИнтеграцияСБанком_ВыгрузкаЗавершена",  Новый Структура("ВыгруженныеСсылки", СтруктураПарметровЗапросаВБанк.МассивДокументов));
		
	ИначеЕсли СокрЛП(Результат) = "" Тогда   
		
		ТекстСообщения = НСтр("ru = 'Операция отменена. не указан OTP код'; ka = ოპერაცია გაუქმებულია. არ არის მითითებული OTP კოდი'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
КонецПроцедуры

