		|	МАКСИМУМ(ВТ_ВсехЗапрашиваемыхСсылок.Сотрудник) КАК Сотрудник,
		|	ВТ_ВсехЗапрашиваемыхСсылок.ЭтоПакет КАК ЭтоПакет,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИДДокументаВБанке,
		|	СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке КАК Статус_ИЗРегистра
		|ИЗ
		|	ВТ_ВсехЗапрашиваемыхСсылок КАК ВТ_ВсехЗапрашиваемыхСсылок
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|		ПО ВТ_ВсехЗапрашиваемыхСсылок.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
		|			И (
		|				ВЫБОР КОГДА ВТ_ВсехЗапрашиваемыхСсылок.Ссылка ССЫЛКА Документ.ВыплатаЗарплаты ТОГДА
		|					ВЫБОР
		|						КОГДА ВТ_ВсехЗапрашиваемыхСсылок.ЭтоПакет ТОГДА ИСТИНА
		|					ИНАЧЕ
		|						ВТ_ВсехЗапрашиваемыхСсылок.НомерСтроки = УИДДокументовВИнтернетБанке.Position
		|					КОНЕЦ
		|				ИНАЧЕ ИСТИНА
		|				КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанке
		|		ПО ВТ_ВсехЗапрашиваемыхСсылок.Ссылка = СтатусыДокументовВИнтернетБанке.ДокументСсылка
		|			И (
		|				ВЫБОР КОГДА ВТ_ВсехЗапрашиваемыхСсылок.Ссылка ССЫЛКА Документ.ВыплатаЗарплаты ТОГДА
		|					ВЫБОР
		|						КОГДА ВТ_ВсехЗапрашиваемыхСсылок.ЭтоПакет ТОГДА ИСТИНА
		|					ИНАЧЕ
		|						ВТ_ВсехЗапрашиваемыхСсылок.НомерСтроки = СтатусыДокументовВИнтернетБанке.Position
		|					КОНЕЦ
		|				ИНАЧЕ ИСТИНА
		|				КОНЕЦ)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ВсехЗапрашиваемыхСсылок.ЭтоПакет,
		|	ВТ_ВсехЗапрашиваемыхСсылок.Ссылка,
		|	ВТ_ВсехЗапрашиваемыхСсылок.НомерСтроки,
		|	СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """")";
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.УИДДокументаВБанке = "" Тогда 
			ТекстСообщения = НСтр("ru = 'Документ "+ВыборкаДетальныеЗаписи.Ссылка+" не был выгружен ранее'; ka = 'დოკუმენტი "+ВыборкаДетальныеЗаписи.Ссылка+" არ ყოფილია ატვირთული. სტატუსი  განახლდება შეუძლებელია!'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Продолжить;
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.ЭтоПакет Тогда 
			ИмяМетода = "api/documents/bulk/status/";
		Иначе
			ИмяМетода = "api/documents/status/";
		КонецЕсли;
		
		ПараметрыЗапроса = Новый Структура("Key", ВыборкаДетальныеЗаписи.УИДДокументаВБанке);
		Статусы = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, ПараметрыЗапроса, , Токен, НЕ ТестовыйРежим);
		
		Если Статусы <> Неопределено Тогда 
			Если ТипЗнч(Статусы) = Тип("ТаблицаЗначений") Тогда 
				
				Для Каждого Строк ИЗ Статусы Цикл
					
					Если Строк.УникальныйИД = "" И ЗначениеЗаполнено(Строк.Статус) И Не Строк.Статус = "" Тогда 
						
						ПолученыйСтатус = Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке[Строк.Статус];
						
						Если ПолученыйСтатус <> ВыборкаДетальныеЗаписи.Статус_ИЗРегистра Тогда
							ВнестиНовыйСтатусДокумента(ВыборкаДетальныеЗаписи.Ссылка,ПолученыйСтатус,ВыборкаДетальныеЗаписи.Сотрудник,Истина,,,ВыборкаДетальныеЗаписи.НомерСтроки);
							КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1;
						КонецЕсли;
						
						Прервать;
					КонецЕсли;
					
				КонецЦикла;
				
			Иначе 
				
				ПолученыйСтатус = Перечисления.СтатусыДокументовВИнтернетБанке[Статусы];
				
				Если ПолученыйСтатус <> ВыборкаДетальныеЗаписи.Статус_ИЗРегистра Тогда 
					ВнестиНовыйСтатусДокумента(ВыборкаДетальныеЗаписи.Ссылка,ПолученыйСтатус,ВыборкаДетальныеЗаписи.Сотрудник,Истина,,,ВыборкаДетальныеЗаписи.НомерСтроки);
					КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоОбновленныхСтатусов > 0 Тогда 
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Статусы "+КоличествоОбновленныхСтатусов+" документов обновлены.'; ka = 'განახლებულია "+КоличествоОбновленныхСтатусов+" დოკუმენტის სტატუსები.'");
		Сообщение.Сообщить();	
	КонецЕсли;
	
КонецПроцедуры

Процедура ВнестиНовыйСтатусДокумента(ДокументСсылка, СтатусСсылка,  Сотрудник = Неопределено, ТолькоСтатус = Ложь, УИД_Документа = Неопределено, Банк = Неопределено, Position = НЕОПРЕДЕЛЕНО) Экспорт
	
	ДатаЗаполнения = ТекущаяДата();
	
	Если ЗначениеЗаполнено(Position) Тогда
		ТекPosition = ЧИСЛО(Position);
	Иначе	
		ТекPosition = НЕОПРЕДЕЛЕНО;
	КонецЕсли;
	
	Если НЕ (ТипЗНЧ(Банк)=Тип("СправочникСсылка.Банки")) ИЛИ НЕ(ЗначениеЗаполнено(Банк)) Тогда
		
		Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда 
			Банк = ДокументСсылка.Отправитель.Банк;
		Иначе
			Банк = ДокументСсылка.БанковскийСчет.Банк;
		КонецЕсли;		
		
	КонецЕсли;
	
	Если НЕ ТолькоСтатус Тогда		
		НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанкеНовый.СоздатьНаборЗаписей();
		НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
		НаборЗаписейУИДДокумента.Отбор.Банк.Установить(Банк);
		НаборЗаписейУИДДокумента.Отбор.Position.Установить(ТекPosition);
		
		НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
		НовыйУИД.ДокументСсылка 	= ДокументСсылка;
		НовыйУИД.Банк 				= Банк;
		НовыйУИД.Position	 		= ТекPosition;
		НовыйУИД.УИДДокументаВБанке = УИД_Документа;
		НовыйУИД.Выгружен 			= Истина;
		НовыйУИД.Сотрудник 			= Сотрудник;
		
		НаборЗаписейУИДДокумента.Записать();
	КонецЕсли;
	
	НоборЗаписейСтатусыДокументовBOG = РегистрыСведений.СтатусыДокументовВИнтернетБанкеНовый.СоздатьНаборЗаписей();
	НоборЗаписейСтатусыДокументовBOG.Отбор.Период			.Установить(ДатаЗаполнения);
	НоборЗаписейСтатусыДокументовBOG.Отбор.ДокументСсылка	.Установить(ДокументСсылка);
	НоборЗаписейСтатусыДокументовBOG.Отбор.Банк				.Установить(Банк);
	НоборЗаписейСтатусыДокументовBOG.Отбор.Position			.Установить(ТекPosition);
	
	НоваяЗапись = НоборЗаписейСтатусыДокументовBOG.Добавить();
	НоваяЗапись.Период 							= ДатаЗаполнения;
	НоваяЗапись.ДокументСсылка 					= ДокументСсылка;
	НоваяЗапись.Банк 							= Банк;
	НоваяЗапись.Position						= ТекPosition;
	НоваяЗапись.СтатусДокументаВИнтернетБанке 	= СтатусСсылка;
	НоваяЗапись.Сотрудник 						= Сотрудник;
	
	НоборЗаписейСтатусыДокументовBOG.Записать();	
	
КонецПроцедуры

// Функция возвращает структуру с информацией о статусе документа в банке
Функция ПолучитьСтруктуруСтатусаДокумента(ДокументСсылка) Экспорт

	СтруктураВозврата = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.ДокументСсылка КАК ДокументСсылка,
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке КАК СтатусДокументаВИнтернетБанке,
		|	УИДДокументовВИнтернетБанке.Выгружен КАК Выгружен,
		|	УИДДокументовВИнтернетБанке.УИДДокументаВБанке КАК УИДДокументаВБанке
		|ИЗ
		|	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
		|		ПО УИДДокументовВИнтернетБанке.ДокументСсылка = СтатусыДокументовВИнтернетБанкеСрезПоследних.ДокументСсылка
		|ГДЕ
		|	УИДДокументовВИнтернетБанке.ДокументСсылка = &ДокументСсылка";
	
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл   
		
		СтруктураВозврата = Новый Структура;
		СтруктураВозврата.Вставить("ДокументСсылка", 				ВыборкаДетальныеЗаписи.ДокументСсылка);
		СтруктураВозврата.Вставить("СтатусДокументаВИнтернетБанке", ВыборкаДетальныеЗаписи.СтатусДокументаВИнтернетБанке);
		СтруктураВозврата.Вставить("Выгружен", 						ВыборкаДетальныеЗаписи.Выгружен);
		СтруктураВозврата.Вставить("УИДДокументаВБанке", 			ВыборкаДетальныеЗаписи.УИДДокументаВБанке);    
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;	
	
КонецФункции

#КонецОбласти

#Область ПолучениеКурсовВалют

Функция ОбработатьЗапросВБанкДляЗагрузкиКурсов(ИмяМетода, СтруктураПараметров, Токен, ТестовыйРежим)
	ПЕРЕМ СтруктураОтвета;
	
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;
	СтруктураОтвета = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, СтруктураПараметров, , Токен, НЕ ТестовыйРежим);

	Возврат СтруктураОтвета;
КонецФункции

Процедура ЗагрузкаКоммерческихКурсовВалютBoG() ЭКСПОРТ
	
	УстановитьПривилегированныйРежим(ИСТИНА);

	ТекПользователь = ИнтеграцияСБанком_НаСервере.АвторизованныйПользователь();
	
	ТипАутентификацииBOG = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ТипАутентификацииBOG");
	Если НЕ ТипАутентификацииBOG = ПредопределенноеЗначение("Перечисление.ТипыАутентификацииBOG.AuthentificationUsingToken") Тогда
		
		ИмяСобытия = НСтр("ru = 'Получение коммерческих курсов валют'; ka = 'Получение коммерческих курсов валют'");
		ТекстОшибки = НСтр("ru = 'Автоматическая загрузка курсов требует, чтобы вариант аутентификации на сайте банка BoG был установлен в значение ""Authentification using token""'; ka = 'Автоматическая загрузка курсов требует, чтобы вариант аутентификации на сайте банка BoG был установлен в значение ""Authentification using token""'");
		ЗаписатьОшибкуВЖурналРегистрации(ИмяСобытия,ТекстОшибки);
		
		УстановитьПривилегированныйРежим(ЛОЖЬ);
	
		Возврат;
		
	КонецЕсли;
	
	ТестовыйРежим = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ИспользоватьТестовыйРежимBOG");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КлассификаторБанков.Ссылка КАК Банк
		|ИЗ
		|	Справочник.КлассификаторБанков КАК КлассификаторБанков
		|ГДЕ
		|	НЕ КлассификаторБанков.ПометкаУдаления
		|	И КлассификаторБанков.СВИФТБИК = ""BAGAGE22""
		|";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		ИмяСобытия = НСтр("ru = 'Получение коммерческих курсов валют'; ka = 'Получение коммерческих курсов валют'");
		ТекстОшибки = НСтр("ru = 'Не найден элемент справочника банков BoG для загрузки курсов'; ka = 'Не найден элемент справочника банков BoG для загрузки курсов'");
		ЗаписатьОшибкуВЖурналРегистрации(ИмяСобытия,ТекстОшибки);
	
	Иначе
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ПолучитьКоммерческиеКурсы(ВыборкаДетальныеЗаписи.Банк,ТестовыйРежим);
			ПолучитьКроссКурсы(ВыборкаДетальныеЗаписи.Банк,ТестовыйРежим);
			
		КонецЦикла;
	
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(ЛОЖЬ);

КонецПроцедуры

Процедура ПолучитьКоммерческиеКурсы(Банк, ТестовыйРежим) ЭКСПОРТ
	
	ИмяМетода = "api/rates/commercial/";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Валюты.Ссылка КАК Валюта
		|ИЗ
		|	Справочник.Валюты КАК Валюты
		|ГДЕ
		|	НЕ Валюты.ПометкаУдаления
		|";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтруктураПараметров = Новый Структура("currency", ВыборкаДетальныеЗаписи.Валюта.Наименование);
		
		СтруктураОтвета = НЕОПРЕДЕЛЕНО;
		
		Токен = ИнтеграцияСБанком_НаСервере.ПолучитьТокенИзБазы(Банк.СВИФТБИК);
		
		Если ЗначениеЗаполнено(Токен) Тогда
			
			СтруктураОтвета = ОбработатьЗапросВБанкДляЗагрузкиКурсов(ИмяМетода, СтруктураПараметров, Токен, ТестовыйРежим);
			
		Иначе
			
			Токен = ИнтеграцияСБанком_НаСервере.АвторизацияЧерезЛогинИПароль();   
			
			ИнтеграцияСБанком_НаСервере.УстановитьТокенДоступа(Токен, Банк.СВИФТБИК);
			
			Если ЗначениеЗаполнено(Токен) Тогда
				
				СтруктураОтвета = ОбработатьЗапросВБанкДляЗагрузкиКурсов(ИмяМетода, СтруктураПараметров, Токен, ТестовыйРежим);
				
			Иначе
				
				ИмяСобытия = НСтр("ru = 'Получение коммерческих курсов валют'; ka = 'კომერციული კურსების მიღება'");
				ТекстОшибки = НСтр("ru = 'Ошибка при получении токена'; ka = 'შეცდომა ტოკენის მიღების დროს'");
				ЗаписатьОшибкуВЖурналРегистрации(ИмяСобытия,ТекстОшибки);
				
				Продолжить;
				
			Конецесли;
			
		КонецЕсли;
		
		Если ТипЗНЧ(СтруктураОтвета) = Тип("Структура") Тогда
		
			КурсПокупки = НЕОПРЕДЕЛЕНО;
			КурсПродажи = НЕОПРЕДЕЛЕНО;
			
			СтруктураОтвета.Свойство("КурсПокупки",КурсПокупки);
			СтруктураОтвета.Свойство("КурсПродажи",КурсПродажи);
			
			Если (ТипЗНЧ(КурсПокупки) = Тип("Число")) И (ТипЗНЧ(КурсПродажи) = Тип("Число")) Тогда
				
				ТекущийПериод = ТекущаяДатаСеанса();
			
				НаборЗаписей = РегистрыСведений.КурсыВалютБанков.СоздатьНаборЗаписей();
				
				НаборЗаписей.Отбор.Период.Установить(ТекущийПериод);
				НаборЗаписей.Отбор.ВидКурса.Установить(Перечисления.ВидыКурсовВалютБанка.Коммерческий);
				НаборЗаписей.Отбор.Банк.Установить(Банк);
				НаборЗаписей.Отбор.Валюта.Установить(ВыборкаДетальныеЗаписи.Валюта);
				
				НовЗапись = НаборЗаписей.Добавить();
				
				НовЗапись.Период  = ТекущийПериод;
				НовЗапись.ВидКурса = Перечисления.ВидыКурсовВалютБанка.Коммерческий;
				НовЗапись.Банк = Банк;
				НовЗапись.Валюта = ВыборкаДетальныеЗаписи.Валюта;
				НовЗапись.КурсПокупки = КурсПокупки;
				НовЗапись.КратностьПокупки = 1;
				НовЗапись.КурсПродажи = КурсПродажи;
				НовЗапись.КратностьПродажи = 1;
				
				НаборЗаписей.Записать(Истина);
			
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Процедура ПолучитьКроссКурсы(Банк, ТестовыйРежим) ЭКСПОРТ
	
	ИмяМетода = "api/rates/commercial//";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВалютаПродажи.Ссылка КАК ВалютаПродажи,
		|	ВалютаПокупки.Ссылка КАК ВалютаПокупки
		|ИЗ
		|	Справочник.Валюты КАК ВалютаПокупки,
		|	Справочник.Валюты КАК ВалютаПродажи
		|ГДЕ
		|	НЕ ВалютаПокупки.ПометкаУдаления
		|	И НЕ ВалютаПродажи.ПометкаУдаления
		|	И НЕ ВалютаПродажи.Ссылка = ВалютаПокупки.Ссылка
		|";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтруктураПараметров = Новый Структура("buyCurrency,sellCurrency", ВыборкаДетальныеЗаписи.ВалютаПокупки.Наименование, ВыборкаДетальныеЗаписи.ВалютаПродажи.Наименование);
		
		СтруктураОтвета = НЕОПРЕДЕЛЕНО;
		
		Токен = ИнтеграцияСБанком_НаСервере.ПолучитьТокенИзБазы(Банк.СВИФТБИК);
		
		Если ЗначениеЗаполнено(Токен) Тогда
			
			СтруктураОтвета = ОбработатьЗапросВБанкДляЗагрузкиКурсов(ИмяМетода, СтруктураПараметров, Токен, ТестовыйРежим);
			
		Иначе
			
			Токен = ИнтеграцияСБанком_НаСервере.АвторизацияЧерезЛогинИПароль();   
			
			ИнтеграцияСБанком_НаСервере.УстановитьТокенДоступа(Токен, Банк.СВИФТБИК);
			
			Если ЗначениеЗаполнено(Токен) Тогда
				
				СтруктураОтвета = ОбработатьЗапросВБанкДляЗагрузкиКурсов(ИмяМетода, СтруктураПараметров, Токен, ТестовыйРежим);
				
			Иначе
				
				ИмяСобытия = НСтр("ru = 'Получение кросс-курсов валют'; ka = 'კროს კურსების მიღება'");
				ТекстОшибки = НСтр("ru = 'Ошибка при получении токена'; ka = 'შეცდომა ტოკენის მიღების დროს'");
				ЗаписатьОшибкуВЖурналРегистрации(ИмяСобытия,ТекстОшибки);
				
				Продолжить;
				
			Конецесли;
			
		КонецЕсли;
		
		Если ТипЗНЧ(СтруктураОтвета) = Тип("Структура") Тогда
		
			КроссКурс = НЕОПРЕДЕЛЕНО;
			
			СтруктураОтвета.Свойство("КроссКурс",КроссКурс);
			
			Если (ТипЗНЧ(КроссКурс) = Тип("Число")) Тогда
				
				ТекущийПериод = ТекущаяДатаСеанса();
			
				НаборЗаписей = РегистрыСведений.КурсыВалютБанков.СоздатьНаборЗаписей();
				
				НаборЗаписей.Отбор.Период.Установить(ТекущийПериод);
				НаборЗаписей.Отбор.ВидКурса.Установить(Перечисления.ВидыКурсовВалютБанка.Кросс);
				НаборЗаписей.Отбор.Банк.Установить(Банк);
				НаборЗаписей.Отбор.ВалютаПокупки.Установить(ВыборкаДетальныеЗаписи.ВалютаПокупки);
				НаборЗаписей.Отбор.ВалютаПродажи.Установить(ВыборкаДетальныеЗаписи.ВалютаПродажи);
				
				НовЗапись = НаборЗаписей.Добавить();
				
				НовЗапись.Период  = ТекущийПериод;
				НовЗапись.ВидКурса = Перечисления.ВидыКурсовВалютБанка.Кросс;
				НовЗапись.Банк = Банк;
				НовЗапись.ВалютаПокупки = ВыборкаДетальныеЗаписи.ВалютаПокупки;
				НовЗапись.ВалютаПродажи = ВыборкаДетальныеЗаписи.ВалютаПродажи;
				НовЗапись.КурсКросс = КроссКурс;
				НовЗапись.КратностьКросс = 1;
				
				НаборЗаписей.Записать(Истина);
			
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Процедура ПолучитьИсториюКурсовНациональнойВалюты(Токен, ТестовыйРежим, НачалоПериода, ОкончаниеПериода, Валюта=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	
	ИмяМетода = "api/rates/nbg///";
	
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;
	
	startDate = МенеджерИнтеграцииСБанком.ДатаВСтроку(НачалоПериода);
	endDate = МенеджерИнтеграцииСБанком.ДатаВСтроку(ОкончаниеПериода);
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Валюты.Ссылка КАК Валюта
		|ИЗ
		|	Справочник.Валюты КАК Валюты
		|ГДЕ
		|	НЕ Валюты.ПометкаУдаления";
	
	Если ЗначениеЗаполнено(Валюта) Тогда
		
		ТекстЗапроса = ТекстЗапроса +"
		|	И Валюты.Ссылка = &Валюта";
		Запрос.УстановитьПараметр("Валюта", Валюта);
		
	КонецЕсли;
	
	Запрос.Текст = ТекстЗапроса;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтруктураПараметров = Новый Структура("currency,startDate,endDate", ВыборкаДетальныеЗаписи.Валюта.Наименование, startDate,endDate);
		
		СтруктураОтвета = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, СтруктураПараметров, , Токен, НЕ ТестовыйРежим);
		
		Если ТипЗНЧ(СтруктураОтвета)=Тип("Массив") Тогда
			
			Для каждого ЭлементСтруктурыОтвета Из СтруктураОтвета Цикл
				
				Currency = Справочники.Валюты.НайтиПоНаименованию(ЭлементСтруктурыОтвета.Получить("Currency"));
				Если НЕ Currency = НЕОПРЕДЕЛЕНО Тогда
					
					Date = ПрочитатьДатуJSON(ЭлементСтруктурыОтвета.Получить("Date"),ФорматДатыJSON.ISO);
					Rate = Число(ЭлементСтруктурыОтвета.Получить("Rate"));
					
					НаборЗаписей = РегистрыСведений.КурсыВалют.СоздатьНаборЗаписей();
					
					НаборЗаписей.Отбор.Период.Установить(Date);
					НаборЗаписей.Отбор.Валюта.Установить(Currency);
					
					НовЗапись = НаборЗаписей.Добавить();
					
					НовЗапись.Период  = Date;
					НовЗапись.Валюта = Currency;
					НовЗапись.Курс = Rate;
					НовЗапись.Кратность = 1;
					
					НаборЗаписей.Записать(Истина);
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры

Функция СтруктураБаланса(НомерСчетаБанковскогоСчета, Валюта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	ТекПользователь = ИнтеграцияСБанком_НаСервере.АвторизованныйПользователь();
	ТестовыйРежим = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ИспользоватьТестовыйРежимBOG");
	
	Токен = ИнтеграцияСБанком_НаСервере.ПолучитьТокенИзБазы();
	
	Если ЗначениеЗаполнено(Токен) Тогда
		
		РЕЗ = ОбработатьЗапросПолученияБалансаСчета(НомерСчетаБанковскогоСчета, Валюта, Токен, ТестовыйРежим);
		Если ТипЗНЧ(РЕЗ)=Тип("Структура") Тогда
			РЕЗ.Вставить("ОписаниеОшибки");
		Иначе
			РЕЗ = Новый Структура("ДоступныйОстатокНаСчете,ТекущийОстатокНаСчете,ОписаниеОшибки");
		КонецЕсли;
		
	Иначе
		
		Токен = ИнтеграцияСБанком_НаСервере.АвторизацияЧерезЛогинИПароль();   
		
		ИнтеграцияСБанком_НаСервере.УстановитьТокенДоступа(Токен);
		
		Если ЗначениеЗаполнено(Токен) Тогда
			
			РЕЗ = ОбработатьЗапросПолученияБалансаСчета(НомерСчетаБанковскогоСчета, Валюта, Токен, ТестовыйРежим);
			Если ТипЗНЧ(РЕЗ)=Тип("Структура") Тогда
				РЕЗ.Вставить("ОписаниеОшибки");
			Иначе
				РЕЗ = Новый Структура("ДоступныйОстатокНаСчете,ТекущийОстатокНаСчете,ОписаниеОшибки");
			КонецЕсли;
			
		Иначе
			
			ОписаниеОшибки = НСтр("ru = 'Ошибка при получении данных'; ka = 'შეცდომა მონაცემთა მიღების დროს'");
			РЕЗ.Вставить("ОписаниеОшибки",ОписаниеОшибки);
			
		Конецесли;
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбработатьЗапросПолученияБалансаСчета(НомерСчетаБанковскогоСчета, Валюта, Токен, ТестовыйРежим);

	ИмяМетода = "api/accounts/";
	
	СтруктураПараметров = Новый Структура("accountNumber,currency", ЛЕВ(НомерСчетаБанковскогоСчета,22),Валюта.Наименование);
	
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;
	Возврат МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, СтруктураПараметров, , Токен, НЕ ТестовыйРежим);	

КонецФункции // ()


