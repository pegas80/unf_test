Процедура ЗаписатьОшибкуВЖурналРегистрации(ИмяСобытия,ТекстОшибки)

	ЗаписьЖурналаРегистрации(ИмяСобытия,УровеньЖурналаРегистрации.Ошибка,,,ТекстОшибки,РежимТранзакцииЗаписиЖурналаРегистрации.Независимая);

КонецПроцедуры

Процедура УстановитьТокенДоступа(ТокенДоступа, swift) Экспорт
	
	ТекПользователь = ПользователиСлужебный.АвторизованныйПользователь();
	
	НаборЗаписейТокена = РегистрыСведений.ТокеныПользователейBOG.СоздатьНаборЗаписей();
	НаборЗаписейТокена.Отбор.Пользователь.Установить(ТекПользователь); 
	НаборЗаписейТокена.Отбор.swift.Установить(swift);
	
	НоваяЗапись = НаборЗаписейТокена.Добавить();
	НоваяЗапись.Пользователь 		= ТекПользователь; 
	НоваяЗапись.swift 				= swift;
	НоваяЗапись.Токен 				= ТокенДоступа;
	НоваяЗапись.ДатаВремяПолучения 	= ТекущаяДата();
	
	НаборЗаписейТокена.Записать();
	
КонецПроцедуры

Функция АдресСтраницыАутентификации() Экспорт
	
	ИспользоватьТестовыйРежимРаботы = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ИспользоватьТестовыйРежимBOG");
	Если ИспользоватьТестовыйРежимРаботы Тогда 
		
		ID_Пользователя = ПолучитьIDПользователя(ИспользоватьТестовыйРежимРаботы);
		АдресСтраницыАутентификации = "https://cib-staging.bog.ge/auth/realms/bog-test/protocol/openid-connect/auth?client_id="+ID_Пользователя+"&response_type=token&scope=corp&redirect_uri=https%3A%2F%2Fexample.com%3A44312%2Fcallback&state=e46fcdf4-a4bf-4dc6-8a42-e1b12e27826b&kc_locale=ka";

	Иначе	 
		
		ID_Пользователя = ПолучитьIDПользователя(ИспользоватьТестовыйРежимРаботы);
		АдресСтраницыАутентификации = "https://account.bog.ge/auth/realms/bog/protocol/openid-connect/auth?client_id="+ID_Пользователя+"&response_type=token&scope=corp&redirect_uri=https://account.bog.ge/auth/realms/bog/protocol/openid-connect/token&state=e46fcdf4-a4bf-4dc6-8a42-e1b12e27826b";
		
	КонецЕсли;
	
	Возврат АдресСтраницыАутентификации;
	
КонецФункции

Функция ПолучитьIDПользователя(ИспользоватьТестовыйРежимРаботы = ЛОЖЬ) Экспорт
	
	clientIdBOG = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "clientIdBOG");  
	
	Возврат clientIdBOG;	
	
КонецФункции

Функция ПолучитьТокенИзБазы(swift) Экспорт
	
	ТекПользователь = Пользователи.АвторизованныйПользователь();
	СтруктураОтветаТокена = РегистрыСведений.ТокеныПользователейBOG.Получить(Новый Структура("Пользователь, swift", ТекПользователь, swift));
	
	Токен = СтруктураОтветаТокена.Токен;
	
	МинутСПоследнейЗаписи = Цел((ТекущаяДата() - СтруктураОтветаТокена.ДатаВремяПолучения)/60);
	Если МинутСПоследнейЗаписи > 14 Тогда 
		Возврат "";
	КонецЕсли;
	
	Возврат Токен;
	
КонецФункции

Функция ТаблицаДокументов(МассивСсылок) Экспорт
	
	МассивДокументов_BAGAGE22		= Новый Массив;
	МассивДокументов_TBCBGE22		= Новый Массив;
	МассивДокументов_TBCBGE22_Batch = Новый Массив;  
	МассивДокументов_MIBGGE22		= Новый Массив; 
	МассивДокументов_MIBGGE22_Batch	= Новый Массив;
	МассивНекорректныхДокументов 	= Новый Массив;
	
	
	МассивТиповКолонки = Новый Массив;
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.Конвертация"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.ПеремещениеДенежныхСредств"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.РасходДенежныхСредств"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.ВозвратДенежныхСредствПокупателю"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.ВыплатаДенежныхСредств"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.ОплатаНалогов"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.ОплатаВПенсионныйФонд"));
	МассивТиповКолонки.Добавить(Тип("ДокументСсылка.ВыплатаЗарплаты"));
	
	ТаблицаСсылок = Новый ТаблицаЗначений;
	ТаблицаСсылок.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов(МассивТиповКолонки));
	Для Каждого ДокументСсылка ИЗ МассивСсылок Цикл
		НовСтрока = ТаблицаСсылок.Добавить();
		НовСтрока.ДокументСсылка = ДокументСсылка;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСсылок.ДокументСсылка КАК ДокументСсылка
		|ПОМЕСТИТЬ ТаблицаСсылок
		|ИЗ
		|	&ТаблицаСсылок КАК ТаблицаСсылок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаСсылок.ДокументСсылка КАК ДокументСсылка,
		|	ВЫБОР
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.Конвертация
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.Конвертация).Отправитель ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.Конвертация).Отправитель КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.ПеремещениеДенежныхСредств
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ПеремещениеДенежныхСредств).БанковскийСчетКассаОтправитель ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ПеремещениеДенежныхСредств).БанковскийСчетКассаОтправитель КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.РасходДенежныхСредств
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.РасходДенежныхСредств).БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.РасходДенежныхСредств).БанковскийСчетКасса КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.ВозвратДенежныхСредствПокупателю
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ВозвратДенежныхСредствПокупателю).БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ВозвратДенежныхСредствПокупателю).БанковскийСчетКасса КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.ВыплатаДенежныхСредств
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ВыплатаДенежныхСредств).БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ВыплатаДенежныхСредств).БанковскийСчетКасса КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.ОплатаНалогов
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ОплатаНалогов).БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ОплатаНалогов).БанковскийСчетКасса КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.ОплатаВПенсионныйФонд
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ОплатаВПенсионныйФонд).БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ОплатаВПенсионныйФонд).БанковскийСчетКасса КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		КОГДА ТаблицаСсылок.ДокументСсылка ССЫЛКА Документ.ВыплатаЗарплаты
		|				И ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ВыплатаЗарплаты).БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТаблицаСсылок.ДокументСсылка КАК Документ.ВыплатаЗарплаты).БанковскийСчетКасса КАК Справочник.БанковскиеСчета).Банк.СВИФТБИК
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК SWIFT
		|ИЗ
		|	ТаблицаСсылок КАК ТаблицаСсылок";
	Запрос.УстановитьПараметр("ТаблицаСсылок", ТаблицаСсылок);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.SWIFT = "BAGAGE22" Тогда
			МассивДокументов_BAGAGE22.Добавить(Выборка.ДокументСсылка);
		ИначеЕсли Выборка.SWIFT = "TBCBGE22" Тогда                    
			Если ТипЗНЧ(Выборка.ДокументСсылка) = Тип("ДокументСсылка.ВыплатаЗарплаты") Тогда
				Если Выборка.ДокументСсылка.НеВыгружатьВБанкПакетом Тогда
					МассивДокументов_TBCBGE22.Добавить(Выборка.ДокументСсылка);
				Иначе	
					МассивДокументов_TBCBGE22_Batch.Добавить(Выборка.ДокументСсылка);
				КонецЕсли;
			Иначе	
				МассивДокументов_TBCBGE22.Добавить(Выборка.ДокументСсылка);
			КонецЕсли; 
		ИначеЕсли Выборка.SWIFT = "MIBGGE22" Тогда 
			Если ТипЗНЧ(Выборка.ДокументСсылка) = Тип("ДокументСсылка.ВыплатаЗарплаты") Тогда
				МассивДокументов_MIBGGE22_Batch.Добавить(Выборка.ДокументСсылка);
			Иначе	
				МассивДокументов_MIBGGE22.Добавить(Выборка.ДокументСсылка);
			КонецЕсли;
			//МассивДокументов_MIBGGE22.Добавить(Выборка.ДокументСсылка);
		Иначе
			МассивНекорректныхДокументов.Добавить(Выборка.ДокументСсылка);
		КонецЕсли;
	КонецЦикла;
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("МассивДокументов_BAGAGE22",			МассивДокументов_BAGAGE22);
	СтруктураВозврата.Вставить("МассивДокументов_TBCBGE22",			МассивДокументов_TBCBGE22);
	СтруктураВозврата.Вставить("МассивДокументов_TBCBGE22_Batch",	МассивДокументов_TBCBGE22_Batch);  
	СтруктураВозврата.Вставить("МассивДокументов_MIBGGE22",			МассивДокументов_MIBGGE22); 
	СтруктураВозврата.Вставить("МассивДокументов_MIBGGE22_Batch",	МассивДокументов_MIBGGE22_Batch);
	СтруктураВозврата.Вставить("МассивНекорректныхДокументов",		МассивНекорректныхДокументов);
	
	Возврат СтруктураВозврата;
	
КонецФункции

