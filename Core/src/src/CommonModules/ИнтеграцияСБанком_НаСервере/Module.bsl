Функция АвторизацияЧерезЛогинИПароль() Экспорт
	
	clientId = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "clientIdBOG");
	secretId = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "secretIdBOG");
	
	Если НЕ ЗначениеЗаполнено(clientId) ИЛИ НЕ ЗначениеЗаполнено(secretId) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В настройках пользователя не указан Login или Password");
		Возврат "";
	КонецЕсли;
	
	ТестовыйРежим = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ИспользоватьТестовыйРежимBOG");
	
	ssl = Новый ЗащищенноеСоединениеOpenSSL;
	
	Если ТестовыйРежим Тогда
		HTTPСоединение = Новый HTTPСоединение("account-test.bog.ge", 443, clientId, secretId,,,ssl);
	Иначе
		HTTPСоединение = Новый HTTPСоединение("account.bog.ge", 443, clientId, secretId,,,ssl);
	КонецЕсли;
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/x-www-form-urlencoded");
	ТелоЗапроса = "grant_type=client_credentials";
	
	Если ТестовыйРежим Тогда
		HTTPЗапрос = Новый HTTPЗапрос("/auth/realms/bog-test/protocol/openid-connect/token", Заголовки);
	Иначе
		HTTPЗапрос = Новый HTTPЗапрос("/auth/realms/bog/protocol/openid-connect/token", Заголовки);
	КонецЕсли;
	HTTPЗапрос.УстановитьТелоИзСтроки(ТелоЗапроса);
	
	Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	Если Ответ.КодСостояния <> 200 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка авторизации. Проверьте пользователя и пароль. Код состояния " + Ответ.КодСостояния);
		ЗаписьЖурналаРегистрации("BOG", УровеньЖурналаРегистрации.Ошибка,,,"Код состояния " + ответ.КодСостояния + ", " + Ответ.ПолучитьТелоКакСтроку());
		Возврат "";
	КонецЕсли; 
	
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
	ДанныеОтвета = ПрочитатьJSON(ЧтениеJSON, Истина);
	ЧтениеJSON.Закрыть();
	
	access_token = ДанныеОтвета["access_token"];
	Возврат access_token;
	
КонецФункции

Процедура ВыполнитьПроверкуДанныхНаСервере(ДокументСсылка, НацВалюта, Отказ, СтруктураВсехПараметров, ТекстСообщения, Токен) Экспорт
	   
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;  
	
	ТестовыйРежим = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ИспользоватьТестовыйРежимBOG");
	
	ТаблицаДанных = Новый ТаблицаЗначений;
	ТаблицаДанных.Колонки.Добавить("КлючОтправки"				, Новый ОписаниеТипов("Строка"));
	
	Для Каждого ЭлемСтруктуры ИЗ СтруктураВсехПараметров Цикл 
		Для Каждого ЭлемМассива ИЗ ЭлемСтруктуры.Значение Цикл 
			СтрокаТЗ = ТаблицаДанных.Добавить();
			СтрокаТЗ.КлючОтправки = ЭлемМассива;
		КонецЦикла;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НацВалюта", НацВалюта);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("тзПараметров", ТаблицаДанных);
	
	ТекстЗапросаПараметров = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзПараметров.КлючОтправки КАК Строка(50)) КАК КлючОтправки
		|ПОМЕСТИТЬ ВременнаяТаблицаПараметров
		|ИЗ
		|	&тзПараметров КАК тзПараметров
		|;
		|//////////////////////////////////////
		|";
	
	ТестЗапросаОсновнойТаблицы = ПолучитьТекстЗапросаОсновнойТаблиц();		
	
	//////////////////////////////////	
	Запрос.Текст = ТекстЗапросаПараметров + ТестЗапросаОсновнойТаблицы;
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаПоСсылке = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	КоличествоВыгруженныхДокументов = 0;
	
	Пока ВыборкаПоСсылке.Следующий() Цикл
		
		//ВыборкаДетальныеЗаписи = ВЫборкаПоСсылке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВыборкаПоСтрокам = ВЫборкаПоСсылке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПоСтрокам.Следующий() Цикл
			
			ВыборкаДетальныеЗаписи = ВыборкаПоСтрокам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			РазрешинаВыгрузка = Истина;
			ТекстСообщения = НСтр(("ru = 'Документ: "+ВыборкаПоСсылке.Ссылка+", не выгружен. Причина:'; ka = 'Документ: "+ВыборкаПоСсылке.Ссылка+", не выгружен. Причина:'")) + Символы.ПС;
			СтруктураПараметров = Новый Структура;
			ЗначениеСтруктурыПараметров = Неопределено;
			
			ЗначениеСотрудника = НЕОПРЕДЕЛЕНО;
					
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				Если НЕ ВыборкаДетальныеЗаписи.ВыгрузкаРазрешена Тогда
					ТекстРУ = СтрЗаменить(СтрЗаменить(ВыборкаДетальныеЗаписи.ТекстОшибкиRU, "ПармДокументСсылка", ВыборкаДетальныеЗаписи.Ссылка), "ПарамВидОперации", ВыборкаДетальныеЗаписи.ВидОперации);
					ТекстКА = СтрЗаменить(СтрЗаменить(ВыборкаДетальныеЗаписи.ТекстОшибкиKA, "ПармДокументСсылка", ВыборкаДетальныеЗаписи.Ссылка), "ПарамВидОперации", ВыборкаДетальныеЗаписи.ВидОперации);
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = '"+ТекстРУ+"'; ka = '"+ТекстКА+"'"));
					ТекстСообщения = "";
					РазрешинаВыгрузка = Ложь;
					Прервать;
				ИначеЕсли НЕ ВыборкаДетальныеЗаписи.Проведен Тогда 
					
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ "+ВыборкаПоСсылке.Ссылка+" не будет выгружен так как не проведен'; ka = 'Документ "+ВыборкаПоСсылке.Ссылка+" не будет выгружен так как не проведен'"));
					ТекстСообщения = "";
					РазрешинаВыгрузка = Ложь;
					
				КонецЕсли;
				
				ИмяРеквизита = НСтр("ru = '"+ВыборкаДетальныеЗаписи.СинонимРеквизитаRU+"'; ka = '"+ВыборкаДетальныеЗаписи.СинонимРеквизитаKA+"'");
				
				КлючСтруктурыПараметров = СокрЛП(ВыборкаДетальныеЗаписи.КлючОтправки);
				ЗначениеСтруктурыПараметров = ?(ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ЗначениеЗаполнения), ВыборкаДетальныеЗаписи.ЗначениеЗаполнения, "");
				
				Если НЕ ВыборкаДетальныеЗаписи.ТребуетсяПроверка = NULL И НЕ ВыборкаДетальныеЗаписи.ТребуетсяПроверка = "" И ВыборкаДетальныеЗаписи.ТребуетсяПроверка  Тогда 
					Если ИмяРеквизита <> "" Тогда //От другого запроса
						Если СокрЛП(ЗначениеСтруктурыПараметров) = "" Тогда 
							ДополнитьСообщениеОшибки(ТекстСообщения, ИмяРеквизита);
							РазрешинаВыгрузка = ЛОЖЬ;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
				Если СтруктураПараметров.Свойство(КлючСтруктурыПараметров) Тогда 
					СтруктураПараметров[КлючСтруктурыПараметров] = ЗначениеСтруктурыПараметров;
				Иначе
					Если КлючСтруктурыПараметров = "Документ" Тогда
						СтруктураПараметров.Вставить(КлючСтруктурыПараметров, ВыборкаДетальныеЗаписи.Ссылка);
					Иначе
						СтруктураПараметров.Вставить(КлючСтруктурыПараметров, ЗначениеСтруктурыПараметров);
					КонецЕсли;
				КонецЕсли;
				
				СтруктураПараметров.Вставить("НомерСтроки", ВыборкаДетальныеЗаписи.НомерСтроки);
				
				Если КлючСтруктурыПараметров = "AdditionalInformation" Тогда
					СтруктураПараметров[КлючСтруктурыПараметров] = СокрЛП(ЗначениеСтруктурыПараметров)+"##"+XMLСтрока(ВыборкаДетальныеЗаписи.Ссылка)+"##";
				КонецЕсли;
				
				ЗначениеСотрудника = ВыборкаДетальныеЗаписи.Сотрудник;
			КонецЦикла;
			
			Если НЕ РазрешинаВыгрузка Тогда 
				Если ТекстСообщения <> "" Тогда 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				КонецЕсли;
			Иначе
				ИмяМетода = ПолучитьИмяМетода(ВыборкаПоСсылке.Ссылка, НацВалюта);
				СтруктураОтвета = Неопределено;
				Если ИмяМетода <> "" Тогда 
					СтруктураОтвета = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, СтруктураПараметров, , Токен, НЕ ТестовыйРежим);
				Иначе
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ "+ВыборкаПоСсылке.Ссылка+" не выгружен'; ka = 'Документ "+ВыборкаПоСсылке.Ссылка+" не выгружен'"));
				КонецЕсли;
				
				Если Не СтруктураОтвета = Неопределено Тогда
					Если СтруктураОтвета.Результат = 0 
						ИЛИ СтруктураОтвета.Результат = 444
						Тогда
						
						Если ТипЗнч(ВыборкаПоСсылке.Ссылка) = Тип("ДокументСсылка.Конвертация") Тогда 
							Банк = ВыборкаПоСсылке.Ссылка.Отправитель.Банк;
						ИначеЕсли ТипЗнч(ВыборкаПоСсылке.Ссылка) = Тип("ДокументСсылка.ПеремещениеДенежныхСредств") Тогда 
							Банк = ВыборкаПоСсылке.Ссылка.БанковскийСчетКассаОтправитель.Банк;
						Иначе
							Банк = ВыборкаПоСсылке.Ссылка.БанковскийСчетКасса.Банк;
						КонецЕсли;
						
						ДатаЗаполнения = ТекущаяДата();
						УИДДокументаВБанке = СтрЗаменить(СтрЗаменить(СтрЗаменить(СтруктураОтвета.УникальныйКлюч," ",""),",",""),Символы.НПП,"");
						
						НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
						НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(ВыборкаПоСсылке.Ссылка);
						НаборЗаписейУИДДокумента.Отбор.Банк.Установить(Банк);
						НаборЗаписейУИДДокумента.Отбор.Position.Установить(ВыборкаПоСтрокам.НомерСтроки);
						
						НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
						НовыйУИД.ДокументСсылка = ВыборкаПоСсылке.Ссылка;
						НовыйУИД.Банк = Банк;
						НовыйУИД.Position = ВыборкаПоСтрокам.НомерСтроки;
						НовыйУИД.УИДДокументаВБанке = УИДДокументаВБанке;
						НовыйУИД.Выгружен = Истина;
						НовыйУИД.Сотрудник = ЗначениеСотрудника;
						
						НаборЗаписейУИДДокумента.Записать();
						
						///////////////////////
						НоборЗаписейСтатусыДокументовBOG = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
						НоборЗаписейСтатусыДокументовBOG.Отбор.Период.Установить(ДатаЗаполнения);
						НоборЗаписейСтатусыДокументовBOG.Отбор.ДокументСсылка.Установить(ВыборкаПоСсылке.Ссылка);
						НоборЗаписейСтатусыДокументовBOG.Отбор.Банк.Установить(Банк);
						НоборЗаписейСтатусыДокументовBOG.Отбор.Position.Установить(ВыборкаПоСтрокам.НомерСтроки);
						
						НоваяЗапись = НоборЗаписейСтатусыДокументовBOG.Добавить();
						НоваяЗапись.Период = ДатаЗаполнения;
						НоваяЗапись.ДокументСсылка = ВыборкаПоСсылке.Ссылка;
						НоваяЗапись.Банк = Банк;
						НоваяЗапись.Position = ВыборкаПоСтрокам.НомерСтроки;
						НоваяЗапись.СтатусДокументаВИнтернетБанке = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
						НоваяЗапись.Сотрудник = ЗначениеСотрудника;
						
						НоборЗаписейСтатусыДокументовBOG.Записать();
						
						КоличествоВыгруженныхДокументов = КоличествоВыгруженныхДокументов + 1;
						
						ТекстСообщения = НСтр("ru = 'Документ "+ВыборкаПоСсылке.Ссылка+" выгружен'; ka = 'დოკუმენტი "+ВыборкаПоСсылке.Ссылка+" ატვირთულია.'");
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = НСтр("ru = 'Выгружен/о " + КоличествоВыгруженныхДокументов + " документ/ов.'; ka = 'ატვირთულია " + КоличествоВыгруженныхДокументов + " დოკუმენტი.'");
	Сообщение.Сообщить();
	
КонецПроцедуры

Функция ПолучитьИмяМетода(ДокументСсылка, НацВалюта)
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда
		Возврат "api/documents/conversion";
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходДенежныхСредств") ИЛИ
			  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ВозвратДенежныхСредствПокупателю") ИЛИ
			  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ВыплатаДенежныхСредств") ИЛИ 
			  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОплатаНалогов") ИЛИ
			  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОплатаВПенсионныйФонд") ИЛИ
			  ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПеремещениеДенежныхСредств")
			  Тогда
		Если ДокументСсылка.ВалютаДокумента = НацВалюта Тогда
			Возврат "api/documents/domestic";
		Иначе 
			Возврат "api/documents/foreign";			
		КонецЕсли;
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ВыплатаЗарплаты") Тогда
		
		Если ДокументСсылка.НеВыгружатьВБанкПакетом Тогда
		
			Если ДокументСсылка.ВалютаДокумента = НацВалюта Тогда
				Возврат "api/documents/domestic";
			Иначе 
				Возврат "api/documents/foreign";			
			КонецЕсли;
			
		Иначе
			
			Если ДокументСсылка.ВалютаДокумента = НацВалюта Тогда
				Возврат "api/documents/bulk/domestic";
			Иначе
				Возврат "api/documents/bulk/foreign";
			КонецЕсли;
		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Процедура ДополнитьСообщениеОшибки(ТекстСообщения, ИмяРеквизита);
	
	Если СокрЛп(ИмяРеквизита) = "" Тогда 
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = ТекстСообщения + НСтр(("ru = '"+ИмяРеквизита+" должен быть заполненным'; ka = '"+ИмяРеквизита+" უნდა იყოს სავსე'")) + Символы.ПС;
	
КонецПроцедуры

Функция ПолучитьТекстЗапросаОсновнойТаблиц()
	
	ТекстЗапроса = "";
	
	ТекстЗапроса_Конвертация 						= ТекстЗапроса_Конвертация();
	ТекстЗапроса_ПеремещениеДенежныхСредств 		= ТекстЗапроса_ПеремещениеДенежныхСредств();
	ТекстЗапроса_РасходДенежныхСредств 				= ТекстЗапроса_РасходДенежныхСредств();
	ТекстЗапроса_ВозвратДенежныхСредствПокупателю 	= ТекстЗапроса_ВозвратДенежныхСредствПокупателю();
	ТекстЗапроса_ВыплатаДенежныхСредств				= ТекстЗапроса_ВыплатаДенежныхСредств();
	ТекстЗапроса_ОплатаНалогов                      = ТекстЗапроса_ОплатаНалогов();
	ТекстЗапроса_ОплатаВПенсионныйФонд              = ТекстЗапроса_ОплатаВПенсионныйФонд();
	ТекстЗапроса_ВыплатаЗарплаты					= ТекстЗапроса_ВыплатаЗарплаты();
	ТекстЗапросаОкончания = ПолучитьТекстЗапросаОкончания();
	
	ТекстЗапроса =
		ТекстЗапроса_Конвертация + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_ПеремещениеДенежныхСредств +"
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_РасходДенежныхСредств + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_ВозвратДенежныхСредствПокупателю + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_ВыплатаДенежныхСредств + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_ОплатаНалогов + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_ОплатаВПенсионныйФонд + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ТекстЗапроса_ВыплатаЗарплаты +
	
	
		 ТекстЗапросаОкончания;
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапроса_Конвертация()
	
	ТекстВозврата = 
	"ВЫБРАТЬ
	|	0 КАК Порядок,
	|	0 КАК НомерСтроки,
	|	NULL КАК Сотрудник,
	|	Конвертация.Ссылка КАК ВидОперации,
	|	ТаблицаПараметров.КлючОтправки,
	|	ВЫБОР
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""UniqueId""
	|			ТОГДА ""1""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DocumentNo""
	|			ТОГДА ВЫРАЗИТЬ(Конвертация.Номер КАК СТРОКА(100))
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""SourceAccountNumber""
	|			ТОГДА ВЫРАЗИТЬ(Конвертация.Отправитель.НомерСчета КАК СТРОКА(100))
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""SourceCurrency""
	|			ТОГДА ВЫРАЗИТЬ(Конвертация.Отправитель.ВалютаДенежныхСредств.Наименование КАК СТРОКА(100))
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DestinationAccountNumber""
	|			ТОГДА ВЫРАЗИТЬ(Конвертация.Получатель.НомерСчета КАК СТРОКА(100))
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DestinationCurrency""
	|			ТОГДА ВЫРАЗИТЬ(Конвертация.Получатель.ВалютаДенежныхСредств.Наименование КАК СТРОКА(100))
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Amount""
	|			ТОГДА Конвертация.СуммаКонвертации
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Rate""
	|			ТОГДА ВЫБОР
	|					КОГДА Конвертация.Отправитель.ВалютаДенежныхСредств = &НацВалюта
	|							ИЛИ Конвертация.Получатель.ВалютаДенежныхСредств = &НацВалюта
	|						ТОГДА ПРЕДСТАВЛЕНИЕ(Конвертация.КоммерческийКурс)
	|					ИНАЧЕ ПРЕДСТАВЛЕНИЕ(Конвертация.КроссКурс)
	|				КОНЕЦ
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""AdditionalInfo""
	|			ТОГДА ВЫРАЗИТЬ(Конвертация.Комментарий КАК СТРОКА(100))
	|	КОНЕЦ КАК ЗначениеЗаполнения,
	|	ВЫБОР
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""AdditionalInfo""
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ТребуетсяПроверка,
	|	Конвертация.Ссылка,
	|	ВЫБОР
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DocumentNo""
	|			ТОГДА ""Номер документа""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""SourceAccountNumber""
	|			ТОГДА ""Номер счета отправителя""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""SourceCurrency""
	|			ТОГДА ""Валюта счета отправителя""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DestinationAccountNumber""
	|			ТОГДА ""Номер счета получателя""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DestinationCurrency""
	|			ТОГДА ""Валюта счета получателя""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Amount""
	|			ТОГДА ""Конвертируеммая сумма""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Rate""
	|			ТОГДА ВЫБОР
	|					КОГДА Конвертация.Отправитель.ВалютаДенежныхСредств = &НацВалюта
	|							ИЛИ Конвертация.Получатель.ВалютаДенежныхСредств = &НацВалюта
	|						ТОГДА ""Коммерческий курс""
	|					ИНАЧЕ ""Кросс курс""
	|				КОНЕЦ
