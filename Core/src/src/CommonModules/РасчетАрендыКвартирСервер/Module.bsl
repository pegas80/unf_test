Процедура ЗаполнитьПриходПоРасходнойНакладной(РасходнаяНакладная) ЭКСПОРТ
	
	УстановитьПривилегированныйРежим(ИСТИНА);
	
	ЛогикаДляПроверки = (
		ПолучитьФункциональнуюОпцию("РасчетАрендыКвартир") 
		И ЗначениеЗаполнено(РасходнаяНакладная.Договор) И РасходнаяНакладная.Договор.РасчетАрендыКвартир 
		И ЗначениеЗаполнено(РасходнаяНакладная.ВладелецКвартиры) 
		И ЗначениеЗаполнено(РасходнаяНакладная.ДоговорВладельцаКвартиры)
		И (РасходнаяНакладная.ПроцентАрендыКвартиры>0)
		И ЗначениеЗаполнено(РасходнаяНакладная.НоменклатураАрендыКвартиры) 
		И (РасходнаяНакладная.СуммаАрендыЗаКвартиру>0)
		);
	
	Если НЕ ЛогикаДляПроверки Тогда
	
		Возврат;
	
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		ПриходнаяНакладная = ПолучитьПриходнуюНакладнуюИзРегистраРасчетАрендыКвартир(РасходнаяНакладная);
		
		Если ЗначениеЗаполнено(ПриходнаяНакладная)Тогда
			ПриходнаяНакладнаяОбъект = ПриходнаяНакладная.ПолучитьОбъект();
		Иначе	
			ПриходнаяНакладнаяОбъект = Документы.ПриходнаяНакладная.СоздатьДокумент();
		КонецЕсли;
		
		СтратегияЗаполнения = Новый Соответствие;
		ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ПриходнаяНакладнаяОбъект, РасходнаяНакладная.Ссылка, СтратегияЗаполнения);
		
		ПриходнаяНакладнаяОбъект.Дата = РасходнаяНакладная.Дата + 1;
		ПриходнаяНакладнаяОбъект.ДокументОснование = НЕОПРЕДЕЛЕНО;
		
		ПриходнаяНакладнаяОбъект.ДокументАрендыКвартиры = РасходнаяНакладная.Ссылка;
		
		Комментарий = НСТР("ru='# Сформирован автоматически документом: %1';ka='# ფორმირებულია ავტომატურად დოკუმენტით: %1 -ის';en='Automatically generated by document: %1'");
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Комментарий, Строка(РасходнаяНакладная.Ссылка));
		ПриходнаяНакладнаяОбъект.Комментарий = Комментарий;
		
		ПриходнаяНакладнаяОбъект.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
		
		Если РасходнаяНакладная.ПоложениеЗаказаПокупателя = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке 
			И УправлениеНебольшойФирмойПовтИсп.РеквизитВШапке("ПоложениеЗаказаПоставщикуВДокументахПоступления") Тогда
			ПриходнаяНакладнаяОбъект.Заказ = РасходнаяНакладная.Заказ;
		Иначе
			ПриходнаяНакладнаяОбъект.Заказ = Неопределено;
		КонецЕсли;
				
		ПриходнаяНакладнаяОбъект.Организация = РасходнаяНакладная.Организация;
		ПриходнаяНакладнаяОбъект.Контрагент = РасходнаяНакладная.ВладелецКвартиры;
		ПриходнаяНакладнаяОбъект.Договор = РасходнаяНакладная.ДоговорВладельцаКвартиры;
		//ПриходнаяНакладнаяОбъект.СтруктурнаяЕдиница = ДанныеЗаполнения.СтруктурнаяЕдиница;
		//ПриходнаяНакладнаяОбъект.Ячейка = ДанныеЗаполнения.Ячейка;
		
		ПриходнаяНакладнаяОбъект.ВалютаДокумента = РасходнаяНакладная.ВалютаАрендыКвартир;
		Если НЕ ЗначениеЗаполнено(ПриходнаяНакладнаяОбъект.ВалютаДокумента) Тогда
		
			ПриходнаяНакладнаяОбъект.ВалютаДокумента = РасходнаяНакладная.ДоговорВладельцаКвартиры.ВалютаРасчетов;
			
			Если НЕ ЗначениеЗаполнено(ПриходнаяНакладнаяОбъект.ВалютаДокумента) Тогда
				
				ПриходнаяНакладнаяОбъект.ВалютаДокумента = УправлениеНебольшойФирмойПовтИсп.ПолучитьНациональнуюВалюту();
				
			КонецЕсли;
		
		КонецЕсли;
		
		СтруктураКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ПриходнаяНакладнаяОбъект.Дата, Новый Структура("Валюта", ПриходнаяНакладнаяОбъект.ВалютаДокумента));
		ПриходнаяНакладнаяОбъект.Курс = СтруктураКурсКратность.Курс;
		ПриходнаяНакладнаяОбъект.Кратность = СтруктураКурсКратность.Кратность;
		
		ПриходнаяНакладнаяОбъект.НДСВключатьВСтоимость = Истина;
		ПриходнаяНакладнаяОбъект.НалогообложениеНДС = РасходнаяНакладная.ВладелецКвартиры.НалогообложениеНДС;
		Если ЗначениеЗаполнено(РасходнаяНакладная.ДоговорВладельцаКвартиры.ВидЦен) Тогда
			
			ПриходнаяНакладнаяОбъект.ВидЦен = РасходнаяНакладная.ДоговорВладельцаКвартиры.ВидЦен;
			ПриходнаяНакладнаяОбъект.СуммаВключаетНДС = ПриходнаяНакладнаяОбъект.ВидЦен.ЦенаВключаетНДС;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(РасходнаяНакладная.ДоговорВладельцаКвартиры.ВидЦенКонтрагента) Тогда
			
			ПриходнаяНакладнаяОбъект.ВидЦенКонтрагента = РасходнаяНакладная.ДоговорВладельцаКвартиры.ВидЦенКонтрагента;
			
		КонецЕсли;
		
		ПриходнаяНакладнаяОбъект.Подразделение = РасходнаяНакладная.Подразделение;
		
		// Заполнение табличной части документа.
		ПриходнаяНакладнаяОбъект.Запасы.Очистить();
		ПриходнаяНакладнаяОбъект.Расходы.Очистить();
		ПриходнаяНакладнаяОбъект.Предоплата.Очистить();
		
		УчитыватьНДФЛ = ПриходнаяНакладнаяОбъект.Договор.УчитыватьНДФЛ;
		
		// Заполняем данные по аренде
		СтрокаТабличнойЧасти = ПриходнаяНакладнаяОбъект.Расходы.Добавить();
		СтрокаТабличнойЧасти.Номенклатура = РасходнаяНакладная.НоменклатураАрендыКвартиры;
		Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
			
			СтрокаТабличнойЧасти.СтруктурнаяЕдиница = ПриходнаяНакладнаяОбъект.Подразделение;
			
			СтрокаТабличнойЧасти.ВидУдержанияНДФЛ = УправлениеНебольшойФирмойСервер.ЗначениеРеквизитаОбъекта(ПриходнаяНакладнаяОбъект.Договор, "ВидУдержанияНДФЛ");
			СтрокаТабличнойЧасти.ВидУдержанияПФ = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВидУдержанияПФ(ПриходнаяНакладнаяОбъект.Дата, ПриходнаяНакладнаяОбъект.Контрагент, ПриходнаяНакладнаяОбъект.Договор);
			
			Если ЗначениеЗаполнено(ПриходнаяНакладнаяОбъект.НалогообложениеНДС) 
				И НЕ ПриходнаяНакладнаяОбъект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
				
				Если ПриходнаяНакладнаяОбъект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
					СтрокаТабличнойЧасти.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
				Иначе
					СтрокаТабличнойЧасти.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
				КонецЕсли;
				
			ИначеЕсли ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура.СтавкаНДС) Тогда
				СтрокаТабличнойЧасти.СтавкаНДС = СтрокаТабличнойЧасти.Номенклатура.СтавкаНДС;
			Иначе
				СтрокаТабличнойЧасти.СтавкаНДС = ПриходнаяНакладнаяОбъект.Организация.СтавкаНДСПоУмолчанию;
			КонецЕсли;
			
			СтрокаТабличнойЧасти.НаправлениеДеятельности = СтрокаТабличнойЧасти.Номенклатура.НаправлениеДеятельности;
			
			СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
			
			СтрокаТабличнойЧасти.Количество = 1;
			СтрокаТабличнойЧасти.Цена = РасходнаяНакладная.СуммаАрендыЗаКвартиру;
			Если СтрокаТабличнойЧасти.Цена > 0 Тогда
				
				СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
				
				КонтрагентЯвляетсяНеРезидентом = ЛОЖЬ;
				Если ЗначениеЗаполнено(ПриходнаяНакладнаяОбъект.Контрагент) Тогда
					КонтрагентЯвляетсяНеРезидентом = ПриходнаяНакладнаяОбъект.Контрагент.ЯвляетсяНеРезидентом;
				КонецЕсли;
				РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная("Цена", СтрокаТабличнойЧасти, ПриходнаяНакладнаяОбъект.СуммаВключаетНДС, КонтрагентЯвляетсяНеРезидентом);
				
			КонецЕсли;		
			
			СтрокаТабличнойЧасти.Проект = РасходнаяНакладная.Проект;
			
		КонецЕсли;
		
		ПриходнаяНакладнаяОбъект.СуммаДокумента = ПриходнаяНакладнаяОбъект.Запасы.Итог("Всего") + ПриходнаяНакладнаяОбъект.Расходы.Итог("Всего") + ПриходнаяНакладнаяОбъект.ЗатратыНаИмущество.Итог("Всего");
		
		//Заполнение таблицы "Предоплаты"
		//ТЗ_Предоплаты = ПолучитьТаблицуПредоплатДляПриходнойНакладной(ПриходнаяНакладнаяОбъект,РасходнаяНакладная.Дата);
		//Если ТипЗНЧ(ТЗ_Предоплаты) = Тип("ТаблицаЗначений") Тогда
		//
		//	Для каждого Строка_ТЗ_Предоплаты Из ТЗ_Предоплаты Цикл
		//	
		//		СтрокаТЧ_Предоплаты = ПриходнаяНакладнаяОбъект.Предоплата.Добавить();
		//		ЗаполнитьЗначенияСвойств(СтрокаТЧ_Предоплаты,Строка_ТЗ_Предоплаты);
		//	
		//	КонецЦикла;
		//
		//КонецЕсли;
		
		// Проводим
		ПриходнаяНакладнаяОбъект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		
		// Записываем в регистр сведений РасчетАрендыКвартир
		НаборЗаписей = РегистрыСведений.РасчетАрендыКвартир.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.РасходнаяНакладная.Установить(РасходнаяНакладная.Ссылка);
		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Период = РасходнаяНакладная.Дата;
		НоваяЗапись.РасходнаяНакладная = РасходнаяНакладная.Ссылка;
		НоваяЗапись.ПриходнаяНакладная = ПриходнаяНакладнаяОбъект.Ссылка;
		НоваяЗапись.СуммаДокумента = РасходнаяНакладная.СуммаДокумента;
		НоваяЗапись.СуммаНДС = РасходнаяНакладная.Запасы.Итог("СуммаНДС") + РасходнаяНакладная.СуммаНДСДоставки;
		НоваяЗапись.ПроцентАрендыКвартиры = РасходнаяНакладная.ПроцентАрендыКвартиры;
		НоваяЗапись.СуммаАрендыЗаКвартиру = ПриходнаяНакладнаяОбъект.СуммаДокумента;
		НаборЗаписей.Записать();
		
		ЗафиксироватьТранзакцию();
	Исключение
		
		ОтменитьТранзакцию();
		
		СобытиеЖурналаРегистрации = НСТР("ru = 'Расчет аренды квартир. Ошибка создания Приходной накладной.';ka = 'Расчет аренды квартир. Ошибка создания Приходной накладной.';en = 'Расчет аренды квартир. Ошибка создания Приходной накладной.'");
		ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации,УровеньЖурналаРегистрации.Ошибка,Метаданные.ОбщиеМодули.РасчетАрендыКвартирСервер,РасходнаяНакладная,ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(ЛОЖЬ);
	
КонецПроцедуры

Процедура РасчетАрендыКвартирОчисткаПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		
		НачатьТранзакцию();
		
		Попытка
					
			ПриходнаяНакладная = ПолучитьПриходнуюНакладнуюИзРегистраРасчетАрендыКвартир(Источник.Ссылка);
			Если ЗначениеЗаполнено(ПриходнаяНакладная)Тогда
				
				ПриходнаяНакладнаяОбъект = ПриходнаяНакладная.ПолучитьОбъект();
				ПриходнаяНакладнаяОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				
			КонецЕсли;
			
			НаборЗаписей = РегистрыСведений.РасчетАрендыКвартир.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.РасходнаяНакладная.Установить(Источник.Ссылка);
			НаборЗаписей.Записать();
			
			ЗафиксироватьТранзакцию();
		Исключение
			
			ОтменитьТранзакцию();
			
			СобытиеЖурналаРегистрации = НСТР("ru = 'Расчет аренды квартир. Ошибка отмены проведения Приходной накладной.';ka = 'Расчет аренды квартир. Ошибка отмены проведения Приходной накладной.';en = 'Расчет аренды квартир. Ошибка отмены проведения Приходной накладной.'");
			ЗаписьЖурналаРегистрации(СобытиеЖурналаРегистрации,УровеньЖурналаРегистрации.Ошибка,Метаданные.ОбщиеМодули.РасчетАрендыКвартирСервер,Источник,ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
		КонецПопытки;
		
	КонецЕсли;
	
	Если Источник.ПометкаУдаления Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходнаяНакладная.Ссылка КАК ПриходнаяНакладная
		|ИЗ
		|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
		|ГДЕ
		|	ПриходнаяНакладная.ДокументАрендыКвартиры = &Источник";
		
		Запрос.УстановитьПараметр("Источник", Источник.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ПриходнаяНакладнаяОбъект = ВыборкаДетальныеЗаписи.ПриходнаяНакладная.ПолучитьОбъект();
			ПриходнаяНакладнаяОбъект.УстановитьПометкуУдаления(ИСТИНА);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры
