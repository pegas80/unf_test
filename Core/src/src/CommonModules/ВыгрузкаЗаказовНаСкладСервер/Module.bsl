Функция ПолучитьМассивОбъектов(Соединение,Заголовки,АдресРесурса,МетодЗапроса="GET", ТекстОтправки, ПутьКФайлу) ЭКСПОРТ
	ПЕРЕМ РЕЗ,Данные;
	
	РЕЗ = Новый Структура("КодСостояния,КоличествоСтраниц,Данные");
	                                                                                        
	Запрос = Новый HTTPЗапрос("/api/interfacing/orders/", Заголовки);
	//Запрос.АдресРесурса = АдресРесурса;
	//Запрос.АдресРесурса = Запрос.АдресРесурса+"&page="+НомерСтраницы;
	//Запрос.Заголовки = Заголовки;
	Запрос.УстановитьТелоИзСтроки(ТекстОтправки, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.Использовать);
	//Запрос.УстановитьИмяФайлаТела(ПутьКФайлу); 
	
	Результат = Соединение.Получить(Запрос);
	Результат = Соединение.ОтправитьДляОбработки(Запрос); //ВызватьHTTPМетод(МетодЗапроса, Запрос);
	
	РЕЗ.КодСостояния = Результат.КодСостояния;
	
	Если Результат.КодСостояния = 200 Тогда
		
		РЕЗ.Данные = Данные;
		
	Иначе
		
		Сообщить(Результат.ПолучитьТелоКакСтроку());
		
	КонецЕсли;
	
	Возврат РЕЗ;
	
КонецФункции

Процедура ЗаполнитьДанные(МассивOrders, тзOrders, тзCustomer, тзAddress, тзCarrier, тзOrderLines, тзУслуги, ДокЗаказ)
	
	СтрокиOrders 		= тзOrders.НайтиСтроки(Новый Структура("Ссылка", ДокЗаказ));
	СтрокиCustomer 		= тзCustomer.НайтиСтроки(Новый Структура("Ссылка", ДокЗаказ));
	СтрокиAddress 		= тзAddress.НайтиСтроки(Новый Структура("Ссылка", ДокЗаказ));
	СтрокиCarrier 		= тзCarrier.НайтиСтроки(Новый Структура("Ссылка", ДокЗаказ));
	СтрокиOrderLines 	= тзOrderLines.НайтиСтроки(Новый Структура("Ссылка", ДокЗаказ));
	СтрокиУслуг 		= тзУслуги.НайтиСтроки(Новый Структура("Ссылка", ДокЗаказ));
	
	СтруктураOrders = Новый Структура;
	
	Для Каждого Колонка Из тзOrders.Колонки Цикл 
		
		Если Колонка.Имя = "Ссылка" Тогда 
			Продолжить;
		КонецЕсли;
		
		Если СтрокиOrders.Количество() = 0 Тогда 
			Продолжить;
		КонецЕсли;
		
		СтрOrders = СтрокиOrders[0];
		
		Если Колонка.Имя = "OrderId" Тогда 
			СтруктураOrders.Вставить(Колонка.Имя, СтрЗаменить(СтрЗаменить(Строка(СтрOrders[Колонка.Имя]), " ", ""), Символы.НПП, ""));
		Иначе 
			СтруктураOrders.Вставить(Колонка.Имя, СтрOrders[Колонка.Имя]);
		КонецЕсли;
		
		Если Колонка.Имя = "OutboundDock" Тогда
			
			СтруктураCustomer = ЗаполнитьДанныеCustomer(тзCustomer.Колонки, тзAddress.Колонки, СтрокиCustomer, СтрокиAddress);
			СтруктураOrders.Вставить("Customer", СтруктураCustomer);
			
			//СтруктураCarrier = ЗаполнитьДанныеCarrier(тзCarrier.Колонки, СтрокиCarrier);
			//СтруктураOrders.Вставить("Carrier", СтруктураCarrier);
			///
			МассивOrderLines = ЗаполнитьДанныеOrderLines(тзOrderLines.Колонки, СтрокиOrderLines, СтрокиУслуг);
			СтруктураOrders.Вставить("OrderLines", МассивOrderLines);
			
		КонецЕсли; 
		
		Если Колонка.Имя = "Notes" Тогда 
			ТекстNotes = "";
			ИтогСумма = 0;
			Для Каждого СтрУслуги Из СтрокиУслуг Цикл 
				
				Если ЗначениеЗаполнено(СтрУслуги.МетодОплаты) Тогда 
					ТекстNotes = "ტრანსპორტირება";//ТекстNotes + СтрУслуги.МетодОплаты;
					//Прервать;
				КонецЕсли;
				
				ИтогСумма = ИтогСумма + СтрУслуги.Сумма;
			КонецЦикла;
			
			ТекстNotes = ТекстNotes + ", " + ИтогСумма;
			Если ТекстNotes <> "" Тогда
				СтруктураOrders.Вставить("Notes", ТекстNotes);
			КонецЕсли;	
		КонецЕсли;
		
	КонецЦикла;
	
	МассивOrders.Добавить(СтруктураOrders);

КонецПроцедуры

Функция ЗаполнитьДанныеOrderLines(КолонкиOrderLines, СтрокиOrderLines, СтрокиУслуг)

	Если СтрокиOrderLines.Количество() = 0 Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	МассивВозврата = Новый Массив;
	
	Для Каждого СтрокрЗапасы Из СтрокиOrderLines Цикл 
		
		СтруктураЛинии = Новый Структура;
		
		Для Каждого Колонка Из КолонкиOrderLines Цикл 
			
			Если Колонка.Имя = "Ссылка" ИЛИ Колонка.Имя = "ItemUnitOfMeasure" ИЛИ Колонка.Имя = "Amount" Тогда 
				Продолжить;
			КонецЕсли;
			
			
			Если Колонка.Имя = "Reference" Тогда 
				СтруктураЛинии.Вставить(Колонка.Имя, Строка(СтрокрЗапасы[Колонка.Имя]));
			Иначе 
				СтруктураЛинии.Вставить(Колонка.Имя, СтрокрЗапасы[Колонка.Имя]);
			КонецЕсли;
			
			Если Колонка.Имя = "Specifications" Тогда 
				СтруктураQuantityOrdered = Новый Структура("ItemUnitOfMeasure, Amount", СтрокрЗапасы.ItemUnitOfMeasure, СтрокрЗапасы.Amount);
				СтруктураЛинии.Вставить("QuantityOrdered", СтруктураQuantityOrdered);
			КонецЕсли;
			
