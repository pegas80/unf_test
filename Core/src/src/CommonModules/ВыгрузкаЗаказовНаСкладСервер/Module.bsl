Процедура ВыгрузитьЗаказ(МассивСсылок = Неопределено) ЭКСПОРТ
	
	Если МассивСсылок = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураСоединения = ПолучитьСтруктуруСоединения();
	
	МассивРезультатов = ПолучитьДанныеДокуента(МассивСсылок);
	
	тзOrders 		= МассивРезультатов[0].Выгрузить();
	тзCustomer 		= МассивРезультатов[1].Выгрузить();
	тзAddress 		= МассивРезультатов[2].Выгрузить();
	тзCarrier 		= МассивРезультатов[3].Выгрузить(); 
	тзOrderLines 	= МассивРезультатов[4].Выгрузить();
	тзУслуги 		= МассивРезультатов[5].Выгрузить();
	
	МассивOrders = Новый Массив;
	                                                                                  
	Для Каждого ДокЗаказ Из МассивСсылок Цикл 
		
		ЗаполнитьДанные(МассивOrders, тзOrders, тзCustomer, тзAddress, тзCarrier, тзOrderLines, тзУслуги, ДокЗаказ);
		
	КонецЦикла;
	//OrderLines = Новый Структура;
	
	MessageIdentification = Неопределено;
	ЗаполнитьСтруктуруMessageIdentification(MessageIdentification, СтруктураСоединения.СтруктураШапки);
	СтруктураОтправки = Новый Структура("MessageIdentification, Orders", MessageIdentification, МассивOrders);

	
	
	КаталогВременныъхфайлов = КаталогВременныхФайлов(); 
	ПутьКФайлу = КаталогВременныъхфайлов + "PostOrders.json";
	тЗапись = Новый ЗаписьJSON;
	//тЗапись.ПроверятьСтруктуру = ЛОЖЬ;
	тЗапись.ОткрытьФайл(ПутьКФайлу);
	
	ЗаписатьJSON(тЗапись, СтруктураОтправки, Новый НастройкиСериализацииJSON, "ФункцияПреобразования", ВыгрузкаЗаказовНаСкладСервер);
	тЗапись.Закрыть();
	
	ЧтениеJson = Новый ЧтениеТекста;
	ЧтениеJson.Открыть(ПутьКФайлу, КодировкаТекста.UTF8);
	
	ТекстJson = ЧтениеJson.Прочитать();
	ТекстОтправки = СтрЗаменить(ТекстJson, """_null""", "null");
	ТекстОтправки = СокрЛП(СтрЗаменить(ТекстОтправки, Символы.НПП, ""));
	ТекстОтправки = СтрЗаменить(ТекстОтправки, " ", "");
	ЧтениеJson.Закрыть();
	
	
	АдресРесурса = "/api/interfacing/orders";//"/swagger/docs/v1"+"/api/interfacing/orders";
	
	Результат = ПолучитьМассивОбъектов2(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,АдресРесурса,"POST", ТекстОтправки, ПутьКФайлу);

	Если НЕ Результат = Неопределено Тогда 
		
		ЗаказОбъект = ДокЗаказ.ПолучитьОбъект();
		ЗаказОбъект.УИДСоСклада = Результат;
		
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Запись, РежимПроведенияДокумента.Неоперативный);
		
	КонецЕсли;
	
	УдалитьФайлы(ПутьКФайлу);
	
КонецПроцедуры

