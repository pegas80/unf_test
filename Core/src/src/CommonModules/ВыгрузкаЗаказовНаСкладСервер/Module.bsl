Процедура ЗаполнитьСтруктуруMessageIdentification(MessageIdentification, СтруктураШапки)
	
	MessageIdentification = Новый Структура;
	
	MessageIdentification.Вставить("Tenant"					, СтруктураШапки.Tenant);	
	MessageIdentification.Вставить("DateTimeCreated"		, ТекущаяДата());
	MessageIdentification.Вставить("Sender"					, СтруктураШапки.Sender);
	MessageIdentification.Вставить("Receiver"				, НЕОПРЕДЕЛЕНО);
	MessageIdentification.Вставить("MessageType"			, СтруктураШапки.MessageType);
	MessageIdentification.Вставить("Version"				, СтруктураШапки.Version);
	MessageIdentification.Вставить("TestIndicator"			, СтруктураШапки.TestIndicator);
	MessageIdentification.Вставить("HandlingInterfaces"		, СтруктураШапки.HandlingInterfaces);
	MessageIdentification.Вставить("OutputFormatInterfaces"	, СтруктураШапки.OutputFormatInterfaces);
	MessageIdentification.Вставить("SenderRef4erence"		, НЕОПРЕДЕЛЕНО);
	
КонецПроцедуры

