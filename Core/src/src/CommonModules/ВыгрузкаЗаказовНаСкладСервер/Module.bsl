Функция ЗаполнитьДанныеCarrier(КолонкиCarrier, СтрокиCarrier)

	СтруктураВозврата = Новый Структура;
	
	Если СтрокиCarrier.Количество() = 0 Тогда 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтрCarrier = СтрокиCarrier[0];
	
	Для Каждого Колонка ИЗ КолонкиCarrier Цикл 
		
		Если Колонка.Имя = "Ссылка" Тогда 
			Продолжить;
		КонецЕсли;
		
		СтруктураВозврата.Вставить(Колонка.Имя, СтрCarrier[Колонка.Имя]);
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;

КонецФункции // СтруктураCarrier = ЗаполнитьДанныеCarrier(тзCarrier.Колонки, СтрокиCarrier)()


Функция ЗаполнитьДанныеCustomer(КолонкиCustomer, КолонкиAddress, СтрокиCustomer, СтрокиAddress)
	
	СтруктураВозврата = Новый Структура;
	
	Если СтрокиCustomer.Количество() = 0 Тогда 
		Возврат СтруктураВозврата;
	КонецЕсли;
	
	СтрCustomer = СтрокиCustomer[0];
	
	Для Каждого Колонка ИЗ КолонкиCustomer Цикл 
		
		Если Колонка.Имя = "Ссылка" Тогда 
			Продолжить;
		КонецЕсли;
		
		СтруктураВозврата.Вставить(Колонка.Имя, СтрCustomer[Колонка.Имя]);
		
		Если Колонка.Имя = "MinRemainingShelfLife" Тогда 
			СтруктураAddress = ЗаполнитьДанныеAddress(КолонкиAddress, СтрокиAddress);
			СтруктураВозврата.Вставить("Address", СтруктураAddress);
			//СтруктураBillingAddress = ЗаполнитьДанныеBillingAddress();
			//СтруктураВозврата.Вставить("BillingAddress", СтруктураAddress);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции // ЗаполнитьДанныеПокупателя(СтрокиCustomer, СтрокиAddress)()

