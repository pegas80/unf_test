Функция ЗаполнитьСтруктуру(ТаблицаЗначений)

	Если ТаблицаЗначений.Количество() = 0 Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	СтрокаТаблицы = ТаблицаЗначений[0];
		
	СтруктураВозврата = Новый Структура;
	
	Для Каждого Колонка Из ТаблицаЗначений.Колонки Цикл 
		СтруктураВозврата.Вставить(Колонка.Имя, "");
	КонецЦикла;
	
	Для Каждого Элем Из СтруктураВозврата Цикл 
		СтруктураВозврата[Элем.Ключ] = СтрокаТаблицы[Элем.Ключ];
	КонецЦикла;
	
	Возврат СтруктураВозврата;
	
КонецФункции // ЗаполнитьСтруктуру()
