		 ТекстОщибки = "სტატუსი არ იძლევა შესაძლებლობას ზედნადების RS.GE - სთან სინქრონიზაციას. ზედნადები განახლდა მხოლოდ ლოკალურად. ზედნადების სტატუსია: " + СокрЛП(ДокументСсылка.AzRy_STATUS);
		 УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ДокументСсылка, ТекстОщибки, , , , );
		 Возврат;
	 КонецЕсли;	 
	 
	 Если ДокументСсылка.AzRySynch_RS_GE Тогда 
		 Если Не Отказ Тогда 
