Функция ТекстОшибкиПоКоду(ID)
	
	ТекстОшибки = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	AzRyWayBilll_ERRORS.Ссылка,
		|	AzRyWayBilll_ERRORS.ВерсияДанных,
		|	AzRyWayBilll_ERRORS.ПометкаУдаления,
		|	AzRyWayBilll_ERRORS.Предопределенный,
		|	AzRyWayBilll_ERRORS.Код,
		|	AzRyWayBilll_ERRORS.Наименование,
		|	AzRyWayBilll_ERRORS.ID,
		|	AzRyWayBilll_ERRORS.TYPE
		|ИЗ
		|	Справочник.AzRyWayBilll_ERRORS КАК AzRyWayBilll_ERRORS
		|ГДЕ
		|	AzRyWayBilll_ERRORS.ID = &ID";

	Запрос.УстановитьПараметр("ID", СокрЛП(ID));

	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТекстОшибки = ВыборкаДетальныеЗаписи.Наименование;
	КонецЦикла;	
	
	Возврат ТекстОшибки;
	
КонецФункции	

