Процедура ОПТИМУС_ПроведениеНДСНаСервере_ОтрозитьДоходыИРасходы(ДокументСсылка, Движения, Отказ) Экспорт
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		
		Если ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика 
			И ДокументСсылка.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
			
			Если Не ДокументСсылка.ВключатьРасходыВСебестоимость = Истина Тогда
				
				Движения.ДоходыИРасходы.Записывать = Истина;
				Для каждого ТекСтрока Из ДокументСсылка.Расходы Цикл
					
					Если ТекСтрока.Номенклатура.СчетУчетаЗатрат.ТипСчета = Перечисления.ТипыСчетов.ПрочиеРасходы 
						Или ТекСтрока.Номенклатура.СчетУчетаЗатрат.ТипСчета = Перечисления.ТипыСчетов.Расходы Тогда
						
						Движение = Движения.ДоходыИРасходы.Добавить();
						Движение.Период = ДокументСсылка.Дата;
						Движение.Организация = ДокументСсылка.Организация;
						Движение.СтруктурнаяЕдиница = ДокументСсылка.Подразделение;
						Движение.НаправлениеДеятельности = ТекСтрока.НаправлениеДеятельности;
						Движение.ЗаказПокупателя = ДокументСсылка.Расходы[0].Заказ;
						Движение.СчетУчета = ТекСтрока.Номенклатура.СчетУчетаЗатрат;
						Движение.СуммаРасходов = - 1 * ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.ВалютаДокумента, ДокументСсылка.Дата, ТекСтрока.СуммаНДС, ДокументСсылка);
						Движение.СодержаниеПроводки = "Корректировка начисленного НДС";
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
		ИначеЕсли ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя Тогда
			ЗапросПоТабличнойЧасти = Новый Запрос;
			ЗапросПоТабличнойЧасти.Текст = "ВЫБРАТЬ
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Дата КАК Период,
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Организация КАК Организация,
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Подразделение КАК СтруктурнаяЕдиница,
			                               |	ПриходнаяНакладнаяЗапасы.Номенклатура.НаправлениеДеятельности КАК НаправлениеДеятельности,
			                               |	ВЫБОР
			                               |		КОГДА ПриходнаяНакладнаяЗапасы.Заказ ССЫЛКА Документ.ЗаказПокупателя
			                               |				И ПриходнаяНакладнаяЗапасы.Заказ <> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
			                               |			ТОГДА ПриходнаяНакладнаяЗапасы.Заказ
			                               |		КОГДА ПриходнаяНакладнаяЗапасы.Заказ ССЫЛКА Документ.ЗаказПоставщику
			                               |				И ПриходнаяНакладнаяЗапасы.Заказ <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
			                               |			ТОГДА ПриходнаяНакладнаяЗапасы.Заказ
			                               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
			                               |	КОНЕЦ КАК ЗаказПокупателя,
			                               |	ПриходнаяНакладнаяЗапасы.Номенклатура.НаправлениеДеятельности.СчетУчетаВыручкиОтПродаж КАК СчетУчета,
			                               |	СУММА(ПриходнаяНакладнаяЗапасы.СуммаНДС * ПриходнаяНакладнаяЗапасы.Ссылка.Курс / ПриходнаяНакладнаяЗапасы.Ссылка.Кратность) КАК СуммаДоходов,
			                               |	""Отражение доходов"" КАК СодержаниеПроводки
			                               |ИЗ
			                               |	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
			                               |ГДЕ
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Ссылка = &Ссылка
			                               |
			                               |СГРУППИРОВАТЬ ПО
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Организация,
			                               |	ПриходнаяНакладнаяЗапасы.Номенклатура.НаправлениеДеятельности,
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Подразделение,
			                               |	ПриходнаяНакладнаяЗапасы.Ссылка.Дата,
			                               |	ПриходнаяНакладнаяЗапасы.Номенклатура.НаправлениеДеятельности.СчетУчетаВыручкиОтПродаж,
			                               |	ВЫБОР
			                               |		КОГДА ПриходнаяНакладнаяЗапасы.Заказ ССЫЛКА Документ.ЗаказПокупателя
			                               |				И ПриходнаяНакладнаяЗапасы.Заказ <> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
			                               |			ТОГДА ПриходнаяНакладнаяЗапасы.Заказ
			                               |		КОГДА ПриходнаяНакладнаяЗапасы.Заказ ССЫЛКА Документ.ЗаказПоставщику
			                               |				И ПриходнаяНакладнаяЗапасы.Заказ <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
			                               |			ТОГДА ПриходнаяНакладнаяЗапасы.Заказ
			                               |		ИНАЧЕ НЕОПРЕДЕЛЕНО
			                               |	КОНЕЦ";
			ЗапросПоТабличнойЧасти.УстановитьПараметр("Ссылка", ДокументСсылка);
			ВыборкаИзТабличнойЧасти = ЗапросПоТабличнойЧасти.Выполнить().Выбрать();
			Пока ВыборкаИзТабличнойЧасти.Следующий() Цикл
				Движение = Движения.ДоходыИРасходы.Добавить();
				ЗаполнитьЗначенияСвойств(Движение, ВыборкаИзТабличнойЧасти);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		Сумм = 0;
		Для каждого ТС Из ДокументСсылка.Запасы Цикл
			Если ЗначениеЗаполнено(ТС.Номенклатура.АкцизныйКод) Тогда
				Сумм = Сумм + ТС.Номенклатура.АкцизныйКод.Ставка;
			КонецЕсли;
		КонецЦикла;
		Если Сумм > 0 Тогда
			Движения.ДоходыИРасходы.Записывать = Истина;
			Для каждого ТС Из ДокументСсылка.Запасы Цикл
				Если ЗначениеЗаполнено(ТС.Номенклатура.АкцизныйКод) Тогда
					Движение = Движения.ДоходыИРасходы.Добавить();
					Движение.Период = ДокументСсылка.Дата;
					Движение.Организация = ДокументСсылка.Организация;
					Движение.СтруктурнаяЕдиница = ДокументСсылка.СтруктурнаяЕдиница;
					Движение.НаправлениеДеятельности = ТС.Номенклатура.Подразделение;
					Заказ = Неопределено;
					Если ЗначениеЗаполнено(ДокументСсылка.Заказ) Тогда 
						Если ТипЗнч(ДокументСсылка.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
							Заказ = ДокументСсылка.Заказ;
						Иначе 
							Заказ = ДокументСсылка.Заказ.ЗаказПокупателя;
						КонецЕсли;	
					Иначе 	
						Если ТипЗнч(ТС.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
							Заказ = ТС.Заказ;
						Иначе 
							Заказ = ТС.Заказ.ЗаказПокупателя;
						КонецЕсли;
					КонецЕсли;
					Движение.СчетУчета = ТС.Номенклатура.НаправлениеДеятельности.СчетУчетаВыручкиОтПродаж;
					Движение.СуммаДоходов = - 1 * ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.ВалютаДокумента, ДокументСсылка.Дата, ТС.Номенклатура.АкцизныйКод.Ставка, ДокументСсылка);
					Движение.СодержаниеПроводки = "Отражение доходов";
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю И ДокументСсылка.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
			Движения.ДоходыИРасходы.Записывать = Истина;
			Для каждого ТС Из ДокументСсылка.Запасы Цикл
				Движение = Движения.ДоходыИРасходы.Добавить();
				Движение.Период = ДокументСсылка.Дата;
				Движение.Организация = ДокументСсылка.Организация;
				Движение.СтруктурнаяЕдиница = ДокументСсылка.Подразделение;
				Движение.НаправлениеДеятельности = ТС.Номенклатура.НаправлениеДеятельности;
				Движение.ЗаказПокупателя = ДокументСсылка.Заказ;
				
				Заказ = Неопределено;
				Если ЗначениеЗаполнено(ДокументСсылка.Заказ) Тогда 
					Если ТипЗнч(ДокументСсылка.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
						Заказ = ДокументСсылка.Заказ;
					Иначе 
						Заказ = ДокументСсылка.Заказ.ЗаказПокупателя;
					КонецЕсли;	
				ИначеЕсли ЗначениеЗаполнено(ТС.Заказ) Тогда 	
					Если ТипЗнч(ТС.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
						Заказ = ТС.Заказ;
					Иначе 
						Заказ = ТС.Заказ.ЗаказПокупателя;
					КонецЕсли;
				КонецЕсли;	
				
				Движение.ЗаказПокупателя = Заказ;		
				Движение.СчетУчета = ТС.Номенклатура.НаправлениеДеятельности.СчетУчетаВыручкиОтПродаж;
				Движение.СуммаДоходов = - 1 * ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.ВалютаДокумента, ДокументСсылка.Дата, ТС.СуммаНДС, ДокументСсылка);
				Движение.СодержаниеПроводки = "Отражение доходов";
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;



	
КонецПроцедуры	

Процедура ОПТИМУС_ПроведениеНДСНаСервере_ОтразитьЗапасы(ДокументСсылка, Движения, Отказ) Экспорт
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда		
		Если ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика И ДокументСсылка.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
			Если ДокументСсылка.ВключатьРасходыВСебестоимость = Ложь Тогда
				Движения.Запасы.Записывать = Истина;
				Для каждого ТС Из ДокументСсылка.Запасы Цикл
					Движение = Движения.Запасы.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = ДокументСсылка.Дата;
					Движение.Организация = ДокументСсылка.Организация;
					Движение.СтруктурнаяЕдиница = ДокументСсылка.СтруктурнаяЕдиница;
					Движение.СчетУчета = ТС.Номенклатура.СчетУчетаЗапасов;
					Движение.Номенклатура = ТС.Номенклатура;
					Движение.Характеристика = ТС.Характеристика;
					Движение.Партия = ТС.Партия;
					Если ТипЗнч(ТС.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") 
						И Не ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя
						И Не (ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПриемВПереработку
						И Не Константы.ФункциональнаяОпцияРезервированиеЗапасов.Получить()) Тогда
						
						Движение.ЗаказПокупателя = ТС.Заказ;
						//Иначе
						//	Движение.ЗаказПокупателя = ТС.Заказ.ЗаказПокупателя;
					КонецЕсли;
					Движение.AzRyНаименованияПоставщиков = ТС.AzRyНаименованияПоставщиков;
					Движение.Количество = 0;
					Движение.Сумма = - 1 * ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.Договор.ВалютаРасчетов, ДокументСсылка.Дата, ТС.СуммаНДС, ДокументСсылка);
					Движение.ФиксированнаяСтоимость = Истина;
					Движение.ЗатратыНаВыпуск = Ложь;
					Движение.Возврат = Ложь;
					Движение.СодержаниеПроводки = "Оприходование запасов";
					Движение.ПеремещениеВРозницуСуммовойУчет = Ложь;
				КонецЦикла;
				Для каждого ТС Из ДокументСсылка.Расходы Цикл
					Если ТС.Номенклатура.СчетУчетаЗатрат.ТипСчета <> Перечисления.ТипыСчетов.НезавершенноеПроизводство И ТС.Номенклатура.СчетУчетаЗатрат.ТипСчета <> Перечисления.ТипыСчетов.КосвенныеЗатраты Тогда
						Продолжить;
					КонецЕсли;
					Движение = Движения.Запасы.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = ДокументСсылка.Дата;
					Движение.Организация = ДокументСсылка.Организация;
					Движение.СтруктурнаяЕдиница = ?(ТС.СтруктурнаяЕдиница.Пустая(), ДокументСсылка.Подразделение, ТС.СтруктурнаяЕдиница);
					Движение.СчетУчета = ТС.Номенклатура.СчетУчетаЗатрат;
					Если ТипЗнч(ТС.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") 
						И Не ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя
						И Не (ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПриемВПереработку
						И Не Константы.ФункциональнаяОпцияРезервированиеЗапасов.Получить()) Тогда
						
						Движение.ЗаказПокупателя = ТС.Заказ;
						//Иначе
						//	Движение.ЗаказПокупателя = ТС.Заказ.ЗаказПокупателя;
					КонецЕсли;
					Движение.AzRyНаименованияПоставщиков = ТС.AzRyНаименованияПоставщиков;
					Движение.Количество = 0;
					Движение.Сумма = - 1 * ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.Договор.ВалютаРасчетов, ДокументСсылка.Дата, ТС.СуммаНДС, ДокументСсылка);
					Движение.ФиксированнаяСтоимость = Истина;
					Движение.ЗатратыНаВыпуск = Ложь;
					Движение.Возврат = Ложь;
					Движение.СодержаниеПроводки = "Отражение затрат";
					Движение.ПеремещениеВРозницуСуммовойУчет = Ложь;
				КонецЦикла;
			Иначе
				Движения.Запасы.Записывать = Истина;
				Для каждого ТС Из ДокументСсылка.Запасы Цикл
					Движение = Движения.Запасы.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = ДокументСсылка.Дата;
					Движение.Организация = ДокументСсылка.Организация;
					Движение.СтруктурнаяЕдиница = ДокументСсылка.СтруктурнаяЕдиница;
					Движение.СчетУчета = ТС.Номенклатура.СчетУчетаЗапасов;
					Движение.Номенклатура = ТС.Номенклатура;
					Движение.Характеристика = ТС.Характеристика;
					Движение.Партия = ТС.Партия;					
					Если ТипЗнч(ТС.Заказ) = Тип("ДокументСсылка.ЗаказПокупателя") 
						И Не ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя
						И Не (ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПриемВПереработку
						И Не Константы.ФункциональнаяОпцияРезервированиеЗапасов.Получить()) Тогда
						
						Движение.ЗаказПокупателя = ТС.Заказ;
						//Иначе
						//	Движение.ЗаказПокупателя = ТС.Заказ.ЗаказПокупателя;
					КонецЕсли;
					Движение.AzRyНаименованияПоставщиков = ТС.AzRyНаименованияПоставщиков;
					Движение.Количество = 0;
					Движение.Сумма = - 1 * ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.Договор.ВалютаРасчетов, ДокументСсылка.Дата, ТС.СуммаНДС, ДокументСсылка);
					Движение.ФиксированнаяСтоимость = Истина;
					Движение.ЗатратыНаВыпуск = Ложь;
					Движение.Возврат = Ложь;
					Движение.СодержаниеПроводки = "Оприходование запасов";
					Движение.ПеремещениеВРозницуСуммовойУчет = Ложь;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

Функция ПолучитьСуммуВУчетнойВВалюте(ВалютаОпераций, Период, Сумма, ДокументСсылка = Неопределено, Курс = Неопределено, Кратность = Неопределено)
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КурсыВалютСрезПоследних.Курс,
	               |	КурсыВалютСрезПоследних.Кратность
	               |ИЗ
	               |	РегистрСведений.КурсыВалют.СрезПоследних(&Период, ) КАК КурсыВалютСрезПоследних
	               |ГДЕ
	               |	КурсыВалютСрезПоследних.Валюта = &ВалютаУчета";
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	Запрос.УстановитьПараметр("Период", Период);
	Резултат = Запрос.Выполнить();
	Выборка = Резултат.Выбрать();
	КурсУчета = 0;
	КратностьУчета = 0;
	Если Выборка.Следующий() Тогда
		КурсУчета = Выборка.Курс;
		КратностьУчета = Выборка.Кратность;
	КонецЕсли;

	Если ДокументСсылка = Неопределено Тогда
		Если Курс = Неопределено И Кратность = Неопределено Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			|	КурсыВалютСрезПоследних.Курс,
			|	КурсыВалютСрезПоследних.Кратность
			|ИЗ
			|	РегистрСведений.КурсыВалют.СрезПоследних(&Период, ) КАК КурсыВалютСрезПоследних
			|ГДЕ
			|	КурсыВалютСрезПоследних.Валюта = &ВалютаОп";
			Запрос.УстановитьПараметр("ВалютаОп", ВалютаОпераций);
			Запрос.УстановитьПараметр("Период", Период);
			Резултат = Запрос.Выполнить();
			Выборка = Резултат.Выбрать();
			КурсНац = 1;
			КратностьНац = 1;
			Если Выборка.Следующий() Тогда
				КурсО      = Выборка.Курс;
				КратностьО = Выборка.Кратность;
			КонецЕсли;
		Иначе 	
			КурсО      = Курс;
			КратностьО = Кратность;			
		КонецЕсли; 
	Иначе		
		Если Курс = Неопределено И Кратность = Неопределено Тогда
			КурсО      = ДокументСсылка.Курс;
			КратностьО = ДокументСсылка.Кратность;	
		Иначе 	
			КурсО      = Курс;
			КратностьО = Кратность;			
		КонецЕсли;
	КонецЕсли;

	Возврат Сумма * КурсО / КратностьО * КратностьУчета / КурсУчета;
КонецФункции

