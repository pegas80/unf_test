Функция ТЗКурсыВалют(МоментВремени) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КурсыРегВалюты.Период КАК РегВалюты_Период,
		|	КурсыРегВалюты.Валюта КАК РегВалюты_Валюта,
		|	КурсыРегВалюты.Курс КАК РегВалюты_Курс,
		|	КурсыРегВалюты.Кратность КАК РегВалюты_Кратность,
		|	КурсыУпрВалюты.Период КАК УпрВалюты_Период,
		|	КурсыУпрВалюты.Валюта КАК УпрВалюты_Валюта,
		|	КурсыУпрВалюты.Курс КАК УпрВалюты_Курс,
		|	КурсыУпрВалюты.Кратность КАК УпрВалюты_Кратность
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(
		|			&МоментВремени,
		|			Валюта В
		|				(ВЫБРАТЬ
		|					КонстантаВалютаУчета.Значение
		|				ИЗ
		|					Константа.ВалютаУчета КАК КонстантаВалютаУчета)) КАК КурсыУпрВалюты,
		|	РегистрСведений.КурсыВалют.СрезПоследних(
		|			&МоментВремени,
		|			Валюта В
		|				(ВЫБРАТЬ
		|					КонстантаНациональнаяВалюта.Значение
		|				ИЗ
		|					Константа.НациональнаяВалюта КАК КонстантаНациональнаяВалюта)) КАК КурсыРегВалюты";
	
	Запрос.УстановитьПараметр("МоментВремени", МоментВремени);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса;
	
КонецФункции


Функция СуммаВНацВалютеДля_RS_GE(ДокументСсылка, ТекСтрока, ТЗ) Экспорт

	Стр = Новый Структура;
	Стр.Вставить("Сумма", ТекСтрока.Всего * ДокументСсылка.Курс * ТЗ[0].УпрВалюты_Кратность / (ТЗ[0].УпрВалюты_Курс * ДокументСсылка.Кратность));
	Стр.Вставить("Цена", Стр.Сумма / ТекСтрока.Количество);
		
	Возврат Стр;
	
КонецФункции
 

