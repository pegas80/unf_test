Процедура ЧекККМ_ОтрозитьУправленческий(ДополнительныеСвойства, Движения) Экспорт 
	
	ДокументСсылка = ДополнительныеСвойства.ДляПроведения.Ссылка;
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") Тогда
		
		Движения.Управленческий.Записывать = Истина;
		Для каждого ТС Из ДополнительныеСвойства.ДляПроведения.Ссылка.Запасы Цикл
			Если Не ТС.AzRyВидыОперацийЧекККМ = Перечисления.AzRyВидыОперацийЧекККМ.Терминалом И Не ТС.AzRyВидыОперацийЧекККМ = Перечисления.AzRyВидыОперацийЧекККМ.РасходнаяНакладнаяПлатежнаяКарта Тогда
				Движение = Движения.Управленческий.Добавить();
				Движение.Период = ДокументСсылка.Дата;
				Движение.Организация = ДокументСсылка.Организация;
				Движение.ПериодПланирования = Справочники.ПериодыПланирования.Фактический;
				Движение.СчетКт = ТС.Контрагент.СчетУчетаРасчетовСПокупателем;
				Движение.ВалютаДт = ДокументСсылка.ВалютаДокумента;
				Движение.СуммаВалДт = ТС.Сумма;
				Движение.СчетДт = ДокументСсылка.КассаККМ.СчетУчета;
				Движение.Сумма = ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.ВалютаДокумента, ДокументСсылка.Дата, ТС.Сумма, Неопределено);
				Движение.Содержание = "ფულის შეტანა სალაროში";			
			КонецЕсли; 	
		КонецЦикла;		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПоступлениеНаСчет_ОтразитьРасчетыПоНалогам(ДокументСсылка, Движения, Отказ) Экспорт
		
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда
		Для каждого ТекСтрока Из ДокументСсылка.РасшифровкаПлатежа Цикл
			Если ЗначениеЗаполнено(ДокументСсылка.ДокументОснование) И ТипЗнч(ДокументСсылка.ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя")
				И ДокументСсылка.ДокументОснование.AzRyАванс И ТекСтрока.ПризнакАванса Тогда
				Движения.РасчетыПоНалогам.Записывать = Истина;
				Движение = Движения.РасчетыПоНалогам.Добавить();
				Движение.Период = ДокументСсылка.Дата;
				Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
				Движение.Организация = ДокументСсылка.Организация;
				Движение.ВидНалога = ДокументСсылка.Организация.ВидНалогаНДС;
				//СуммаНДС = ТекСтрока.СуммаРасчетов - ТекСтрока.СуммаРасчетов / ((ТекСтрока.СтавкаНДС.Ставка + 100) / 100);
				//Движение.Сумма = ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.ВалютаДенежныхСредств, ДокументСсылка.Дата, ТекСтрока.СуммаНДС, ДокументСсылка);
				Движение.Сумма = ТекСтрока.СуммаНДС;
			КонецЕсли; 
		КонецЦикла;
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета") Тогда
		Для каждого ТекСтрока Из ДокументСсылка.РасшифровкаПлатежа Цикл   
			Если (ТипЗнч(ТекСтрока.Заказ) = Тип("ДокументСсылка.ЗаказПоставщику") И ТекСтрока.Заказ.AzRyАванс) И ТекСтрока.ПризнакАванса Тогда
				Движения.РасчетыПоНалогам.Записывать = Истина;
				Движение = Движения.РасчетыПоНалогам.Добавить();
				Движение.Период = ДокументСсылка.Дата;
				Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
				Движение.Организация = ДокументСсылка.Организация;
				Движение.ВидНалога = ДокументСсылка.Организация.ВидНалогаНДС;
				//Движение.Сумма = ТекСтрока.СуммаНДС;
				Движение.Сумма = ТекСтрока.СуммаПлатежа - (ТекСтрока.СуммаПлатежа) / ((ДокументСсылка.Организация.СтавкаНДСПоУмолчанию.Ставка + 100) / 100);
				Движение.Сумма = ПолучитьСуммуВУчетнойВВалюте(ДокументСсылка.ВалютаДенежныхСредств, ДокументСсылка.Дата, Движение.Сумма, , , );
			КонецЕсли; 
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриходнаяНакладная_ОтразитьРасчетыПоНалогам(ДокументСсылка, Движения, Отказ) Экспорт
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Или ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда 
		
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Сумма");
		ТЗ.Колонки.Добавить("СодержаниеПроводки");
		ТЗ.Колонки.Добавить("ВидНалога");
		
		ИтогСуммаУВ   = 0;
		СуммаУВ       = 0;
		ПризнакАванса = Ложь;
		
		Об = ДокументСсылка;	
		ИтогВсего      = Об.Запасы.Итог("Всего") + Об.Расходы.Итог("Всего");
		ИтогСуммаНДС   = Об.Запасы.Итог("СуммаНДС") + Об.Расходы.Итог("СуммаНДС");
		ИтогСуммаНДСУВ = ПолучитьСуммуВУчетнойВВалюте(Об.ВалютаДокумента, Об.Дата, ИтогСуммаНДС, , Об.Курс, Об.Кратность);
		
		Для каждого ТекСтрока Из ДокументСсылка.Предоплата Цикл
			Если ТипЗнч(ДокументСсылка) <> Тип("ДокументСсылка.ДополнительныеРасходы") И ТипЗнч(ТекСтрока.Заказ) = Тип("ДокументСсылка.ЗаказПоставщику") И ТекСтрока.Заказ.AzRyАванс Тогда
				
				ПризнакАванса = Истина;
				СуммаУВ = ПолучитьСуммуВУчетнойВВалюте(ТекСтрока.Документ.ВалютаДенежныхСредств, ТекСтрока.Документ.Дата, ТекСтрока.СуммаПлатежа, , , );
				СуммаУВ = СуммаУВ - СуммаУВ / ((ТекСтрока.Документ.Организация.СтавкаНДСПоУмолчанию.Ставка + 100) / 100);
				ИтогСуммаУВ = ИтогСуммаУВ + СуммаУВ;								
				
				НоваяСтрока = ТЗ.Добавить();
				НоваяСтрока.Сумма = -?(СуммаУВ > ИтогСуммаНДСУВ, ИтогСуммаНДСУВ, СуммаУВ);
			КонецЕсли; 
		КонецЦикла; 
		
		Для каждого ТекСтрока Из ДокументСсылка.Расходы Цикл
			Если ДокументСсылка.Договор.AzRyУдерживатьПенсионныйНалог Тогда
				НоваяСтрока = ТЗ.Добавить();
				НоваяСтрока.Сумма = ТекСтрока.Сумма * Константы.AzRyПенсионныйНалогПроцент.Получить(); 
				НоваяСтрока.СодержаниеПроводки = НСтр("ru = 'Накопительная пенсия - Процент'; ka = 'დაგროვებითი საპენსიოს პროცენტი'");
				НоваяСтрока.ВидНалога = ДокументСсылка.Договор.AzRyСчетПенсионногоНалога; 
			КонецЕсли; 
		КонецЦикла;
		
		//Если (ДокументСсылка.Предоплата.Количество() > 0 И ПризнакАванса) Тогда
		Для каждого ТекСтрока Из ТЗ Цикл		
			Движения.РасчетыПоНалогам.Записывать = Истина;
			Движение = Движения.РасчетыПоНалогам.Добавить();
			Движение.Период      = ДокументСсылка.Дата;
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.Организация = ДокументСсылка.Организация;
			Движение.ВидНалога   = ?(ЗначениеЗаполнено(ТекСтрока.ВидНалога), ТекСтрока.ВидНалога, ДокументСсылка.Организация.ВидНалогаНДС);
			Движение.Сумма       = ТекСтрока.Сумма;
			Движение.СодержаниеПроводки = ТекСтрока.СодержаниеПроводки;
		КонецЦикла;
		//КонецЕсли; 
			
	КонецЕсли;
	
КонецПроцедуры
 
