Функция АктивныеСотрудники(ДатаОбновления, Организация, СтруктурнаяЕдиница, МассивСотрудники = Неопределено) Экспорт
	
	Парам = ?(МассивСотрудники = Неопределено, "", " И СотрудникиСрезПоследних.Сотрудник В(&Сотрудники) ");
	
	// 1) ТЗ Активных сотрудников
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СотрудникиСрезПоследних.Период,
	               |	СотрудникиСрезПоследних.Регистратор,
	               |	СотрудникиСрезПоследних.НомерСтроки,
	               |	СотрудникиСрезПоследних.Активность,
	               |	СотрудникиСрезПоследних.Организация,
	               |	СотрудникиСрезПоследних.Сотрудник,
	               |	СотрудникиСрезПоследних.СтруктурнаяЕдиница,
				   |	СотрудникиСрезПоследних.AzRyDivision,
	               |	СотрудникиСрезПоследних.Должность,
	               |	СотрудникиСрезПоследних.ЗанимаемыхСтавок,
	               |	СотрудникиСрезПоследних.ГрафикРаботы
	               |ИЗ
	               |	РегистрСведений.Сотрудники.СрезПоследних(&Дата, ) КАК СотрудникиСрезПоследних
	               |ГДЕ
	               |	СотрудникиСрезПоследних.Организация = &Организация
				   |	И НЕ СотрудникиСрезПоследних.Регистратор ССЫЛКА Документ.Увольнение
	               |	И СотрудникиСрезПоследних.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница) " + Парам;
				   
				   
	Запрос.Текст = Запрос.Текст +               
	               "ОБЪЕДИНИТЬ ВСЕ
	               |ВЫБРАТЬ
	               |	СотрудникиСрезПоследних.Период,
	               |	СотрудникиСрезПоследних.Регистратор,
	               |	СотрудникиСрезПоследних.НомерСтроки,
	               |	СотрудникиСрезПоследних.Активность,
	               |	СотрудникиСрезПоследних.Организация,
	               |	СотрудникиСрезПоследних.Сотрудник,
	               |	СотрудникиСрезПоследних.СтруктурнаяЕдиница,
				   |	СотрудникиСрезПоследних.AzRyDivision,
	               |	СотрудникиСрезПоследних.Должность,
	               |	СотрудникиСрезПоследних.ЗанимаемыхСтавок,
	               |	СотрудникиСрезПоследних.ГрафикРаботы
	               |ИЗ
	               |	РегистрСведений.Сотрудники.СрезПоследних(&Период2, НЕ Регистратор ССЫЛКА Документ.Увольнение) КАК СотрудникиСрезПоследних
	               |ГДЕ
	               |	СотрудникиСрезПоследних.Организация = &Организация
	               |	И СотрудникиСрезПоследних.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница)
	               //|	И СотрудникиСрезПоследних.Период МЕЖДУ &Период1 И &Период2
	               |	И СотрудникиСрезПоследних.Сотрудник В
	               |			(ВЫБРАТЬ
	               |				СотрудникиСрезПоследних.Сотрудник
	               |			ИЗ
	               |				РегистрСведений.Сотрудники КАК СотрудникиСрезПоследних
	               |			ГДЕ
	               |				СотрудникиСрезПоследних.Регистратор ССЫЛКА Документ.Увольнение
	               |				И СотрудникиСрезПоследних.Организация = &Организация
	               |				И СотрудникиСрезПоследних.Период МЕЖДУ &Период1 И &Период2)" + Парам;
	
	Запрос.УстановитьПараметр("Дата", ДатаОбновления);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудники", МассивСотрудники);
	Запрос.УстановитьПараметр("Период1", НачалоМесяца(ДатаОбновления));
	Запрос.УстановитьПараметр("Период2", КонецМесяца(ДатаОбновления));
	
	Возврат Запрос.Выполнить().Выгрузить();
 
 КонецФункции 
  
Функция ВсеАктивныеСотрудники(ДатаОбновления, ВидНачисленияУдержания=Неопределено) Экспорт
	
	Если ВидНачисленияУдержания = Неопределено Тогда 
		ДопЗапрос = "";	
	Иначе 
		ДопЗапрос = "		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПлановыеНачисленияИУдержания.СрезПоследних(&Дата, ВидНачисленияУдержания = &ВидНачисленияУдержания) КАК ПлановыеНачисленияИУдержанияСрезПоследних
	                 |		ПО СотрудникиСрезПоследних.Сотрудник = ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник
	                 |			И СотрудникиСрезПоследних.Организация = ПлановыеНачисленияИУдержанияСрезПоследних.Организация";
	КонецЕсли;
	
	 // 1) ТЗ Активных сотрудников
	 Запрос = Новый Запрос;
	 Запрос.Текст = "ВЫБРАТЬ
	                |	СотрудникиСрезПоследних.Период,
	                |	СотрудникиСрезПоследних.Регистратор,
	                |	СотрудникиСрезПоследних.НомерСтроки,
	                |	СотрудникиСрезПоследних.Активность,
	                |	СотрудникиСрезПоследних.Организация,
	                |	СотрудникиСрезПоследних.Сотрудник,
	                |	СотрудникиСрезПоследних.СтруктурнаяЕдиница,
	                |	СотрудникиСрезПоследних.Должность,
	                |	СотрудникиСрезПоследних.ЗанимаемыхСтавок,
	                |	СотрудникиСрезПоследних.ГрафикРаботы
	                |	" + ?(ВидНачисленияУдержания = Неопределено, "", ", ЕСТЬNULL(ПлановыеНачисленияИУдержанияСрезПоследних.Сумма, 0) КАК Сумма") +  
	                " ИЗ
	                  |	РегистрСведений.Сотрудники.СрезПоследних(&Дата, ) КАК СотрудникиСрезПоследних " + ДопЗапрос;   
	 
	 Запрос.УстановитьПараметр("Дата", ДатаОбновления);
	 Запрос.УстановитьПараметр("ВидНачисленияУдержания", ВидНачисленияУдержания);
	 
	 РезультатТЗ = Запрос.Выполнить().Выгрузить();
	 
	 МассивУ = Новый Массив;
	 
	 Для каждого ТекСтрока Из РезультатТЗ Цикл	    
		 Если ТипЗнч(ТекСтрока.Регистратор) =  Тип("ДокументСсылка.Увольнение") Тогда 
			 МассивУ.Добавить(ТекСтрока);
		 КонецЕсли;		
	 КонецЦикла;
	 
	 Для каждого ТекМассив Из МассивУ Цикл	
		 РезультатТЗ.Удалить(ТекМассив);	
	 КонецЦикла;

	 Возврат РезультатТЗ;
 
 КонецФункции

