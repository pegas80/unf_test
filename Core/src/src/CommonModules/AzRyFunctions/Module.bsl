// НачислениеЗарплаты -

&НаСервере
Функция НаправленияДеятельностиНоменклатура(НаправлениеДеятельностыНоменклатура) Экспорт
	
	Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(НаправлениеДеятельностыНоменклатура, Истина);  
	Если Номенклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда
		Номенклатура = Справочники.Номенклатура.СоздатьЭлемент();
		Номенклатура.УстановитьНовыйКод();
		Номенклатура.Наименование            = НаправлениеДеятельностыНоменклатура;
		Номенклатура.НаименованиеПолное      = НаправлениеДеятельностыНоменклатура;
		//Номенклатура.Артикул                 = СтрокаАртикул;
		Номенклатура.ТипНоменклатуры         = Перечисления.ТипыНоменклатуры.Запас;
		//Номенклатура.НоменклатурнаяГруппа    = Справочники.НоменклатурныеГруппы.ОсновнаяГруппа;
		Номенклатура.ЕдиницаИзмерения        = Справочники.КлассификаторЕдиницИзмерения.шт;
		Номенклатура.СтавкаНДС               = Справочники.СтавкиНДС.НайтиПоНаименованию("18%");
		Номенклатура.Комментарий             = "გამოიყენება ხელფასების დარიცხვაში რეგისტრში 'შესყიდვები'";
		Номенклатура.Записать();		
	КонецЕсли;	
	Возврат Номенклатура.Ссылка;	
	
КонецФункции


//////////////////////////////////////////////////////////////////////////////// 
// AzRy - Подписки на события

Процедура ПодпискаНаСобытиеОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	СтруктураВременныеТаблицы = Источник.ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;	
	Если Не СтруктураВременныеТаблицы.Свойство("AzRyДвиженияЗапасыИзменение") Или Отказ Или Не СтруктураВременныеТаблицы.AzRyДвиженияЗапасыИзменение Или СтруктураВременныеТаблицы.AzRyАвторДокумента = СтруктураВременныеТаблицы.AzRyОтветственныйЗаСклад Тогда
		Возврат;	
	КонецЕсли; 
	
	// ვიძახებთ დამუშავებას და ვაგზავნით მეილს	                     
	ОтправитьПисьмоОтветственногоЗаСкладом(СтруктураВременныеТаблицы.AzRyРегистратор, Пользователи.ТекущийПользователь());
	
КонецПроцедуры

