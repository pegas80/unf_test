Процедура ИзменениеПроводкиНачислениеЗарплаты(ТЗ) Экспорт
	
	Для каждого ТекСтрока Из ТЗ Цикл
		Если ТекСтрока.ВидНачисленияУдержания = Справочники.AzRyНастройки.НачислениеПенсия.Значение Тогда
			ТекСтрока.СчетКт = Справочники.AzRyНастройки.НачислениеЗарплаты_3320_04.Значение;
			ТекСтрока.ВалютаКт   = ?(Справочники.AzRyНастройки.НачислениеЗарплаты_3320_04.Значение.Валютный, ТекСтрока.ВалютаКт, Неопределено);
			ТекСтрока.СуммаВалКт = ?(Справочники.AzRyНастройки.НачислениеЗарплаты_3320_04.Значение.Валютный, ТекСтрока.СуммаВалКт, Неопределено);
		КонецЕсли; 
	КонецЦикла;	

КонецПроцедуры

Функция РассчитатьКоефициент(СуммаВходящая,ВсегоСуммаВходящая,СуммаРаспределения) 
   ПроцентОтОбщей=СуммаВходящая /(ВсегоСуммаВходящая/100); 
   Дельта=Окр(СуммаРаспределения/100*ПроцентОтОбщей,2,РежимОкругления.Окр15как20); 
   Возврат Дельта; 
КонецФункции

Процедура ОтправитьПисьмоОтветственногоЗаСкладом(Регистратор, АвторДокумента) Экспорт

	О = Обработки.AzRyПриИзмененийОстатковЗапасаУведомитьВладельцаСклада.Создать();
	О.КомандаОтправитьПисьмо(ПолучитьНавигационнуюСсылку(Регистратор), АвторДокумента);			

КонецПроцедуры

Функция СписокПользователейДляКонтроляОстатковНаСкладе() Экспорт 
	
	С = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПользователиAzRyСкладыДляКонтроляОстатков.Склад КАК Склад,
		|	ПользователиAzRyСкладыДляКонтроляОстатков.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Пользователи.AzRyСкладыДляКонтроляОстатков КАК ПользователиAzRyСкладыДляКонтроляОстатков
		|ГДЕ
		|	ПользователиAzRyСкладыДляКонтроляОстатков.Ссылка В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				Пользователи.Ссылка КАК Ссылка
		|			ИЗ
		|				Справочник.Пользователи КАК Пользователи
		|			ГДЕ
		|				НЕ Пользователи.Ссылка.ПометкаУдаления
		|				И Пользователи.Ссылка.AzRyСкладскойКонтроль)
		|	И ПользователиAzRyСкладыДляКонтроляОстатков.Актуальность
		|	И НЕ ПользователиAzRyСкладыДляКонтроляОстатков.Ссылка.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		С = Новый Структура("Пользователь, Склад", ВыборкаДетальныеЗаписи.Ссылка, ВыборкаДетальныеЗаписи.Склад); 		
	КонецЦикла;
	
	Возврат С;
	
КонецФункции
 



