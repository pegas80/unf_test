	Запрос.УстановитьПараметр("РасходДенежныхСредств", НСтр("ru='Расход денежных средств';ka='ფულადი სახსრების დანახარჯი'"));
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ru='Курсовая разница';ka='სხვაობა კურსებს შორის'"));

