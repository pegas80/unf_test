Функция AzRyСоздатьThumbnailФайлНаСервере(Док) Экспорт
	
	ХранимыйФайл = Обработки.AzRyEcommerceConsole.Создать().ПолучитьХранимыеФайлыВерсий(Док);
	
	ИМФ = ПолучитьИмяВременногоФайла(Док.ТекущаяВерсияРасширение);
	ИМФ2 = ПолучитьИмяВременногоФайла(Док.ТекущаяВерсияРасширение);
	
	Картинка = Новый Картинка(ХранимыйФайл.Получить());
	Картинка.Записать(ИМФ);
	Картинка.Записать(ИМФ2);
	
	Файл = Новый Файл(ИМФ2);
	
	ИмяФайла = ИМФ;
	GFLAx = Новый COMОбъект("GFLAx.GFLAx");
	GFLAx.LoadBitmap(ИмяФайла);
	ШиринаИзо = GFLAx.Width;
	ВысотаИзо = GFLAx.Height;
	Если ШиринаИзо>ВысотаИзо Тогда
		Делитель=ШиринаИзо/192;
	Иначе
		Делитель=ВысотаИзо/192;    
	КонецЕсли;
	Делитель = ?(0,1,Делитель);
	ШиринаИзо = ШиринаИзо/Делитель;
	ВысотаИзо = ВысотаИзо/Делитель;
	GFLAx.Resize(Цел(ШиринаИзо),Цел(ВысотаИзо));
	
	НовИмя = Файл.Путь + Док.Наименование + "_ThumbNail." + Док.ТекущаяВерсияРасширение;
	
	GFLAx.SaveBitmap(НовИмя);   
	
	Двоичное = Новый ДвоичныеДанные(НовИмя);
	Адрес = ПоместитьВоВременноеХранилище(Двоичное);
	
	Стр = Новый Структура;
	Стр.Вставить("Адрес", Адрес);
	Стр.Вставить("ТекущаяВерсияРасширение", Док.ТекущаяВерсияРасширение);
	Стр.Вставить("ИмяФайла", Док.Наименование + "_ThumbNail." + Док.ТекущаяВерсияРасширение);
	Стр.Вставить("Путь", Файл.Путь);
	
	Возврат Стр;
	
КонецФункции

