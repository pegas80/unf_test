Процедура ОтразитьЗапасы(ДокументСсылка, Движения, Отказ)  Экспорт
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
		
		Если ДокументСсылка.Контрагент.Нерезидент Тогда
						
			Курс      = 0;
			Кратность = 0;			
			ПолучитьКурсДокумента(ДокументСсылка, Курс, Кратность);
			
			Движения.Запасы.Записывать = Истина;
			Для Каждого ТекСтрока Из ДокументСсылка.Запасы Цикл
				Движение = Движения.Запасы.Добавить();
				Движение.ВидДвижения             = ВидДвиженияНакопления.Приход;
				Движение.Период                  = ДокументСсылка.Дата;
				Движение.Организация             = ДокументСсылка.Организация;
				Движение.СтруктурнаяЕдиница      = ДокументСсылка.СтруктурнаяЕдиница;
				Движение.СчетУчета               = ТекСтрока.Номенклатура.СчетУчетаЗапасов;
				Движение.Номенклатура            = ТекСтрока.Номенклатура;
				Движение.Характеристика          = ТекСтрока.Характеристика;
				Движение.Партия                  = ТекСтрока.Партия;
				Движение.ЗаказПокупателя         = ?(ДокументСсылка.Договор.УдерживатьПодоходныйНалог, Неопределено, ТекСтрока.ЗаказПокупателя);
				Движение.Количество              = 0;
				Движение.Сумма                   = ТекСтрока.СуммаРасходов * (Курс / Кратность) / 90*10;
				Движение.ФиксированнаяСтоимость  = Истина;
				Движение.ЗатратыНаВыпуск         = Ложь;
				Движение.Возврат                 = Ложь;
				Движение.СодержаниеПроводки      = "Оприходование запасов";
				Движение.ПеремещениеВРозницуСуммовойУчет = Ложь;					
			КонецЦикла;						
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры	

