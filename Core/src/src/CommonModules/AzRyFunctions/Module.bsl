 // ПроверкаКонтрагентаПоИНН
Функция ПроверкаКонтрагентаПоИНН(ИНН, Объект) Экспорт 

	ИННПР = СтрЗаменить(ИНН, " ", "");
	НайденКонтрагент = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	                |	Контрагенты.ИНН,
	                |	Контрагенты.Ссылка
	                |ИЗ
	                |	Справочник.Контрагенты КАК Контрагенты
	                |ГДЕ
	                |	Контрагенты.ИНН = &ИНН";
	
	Запрос.УстановитьПараметр("ИНН", ИННПР);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НайденКонтрагент = Истина;			
		Сообщение = Новый СообщениеПользователю();
		Текст = "კონტრაგენტი ინნ-ით " + "(" + ИННПР + ")" + " უკვე არსებობს სისტემაში! ნაპოვნი კონტრაგენტი: (" + Выборка.Ссылка.Наименование + ")";
		Сообщение.Текст = Текст;
		Сообщение.Поле = "Объект.ИНН"; 
		Сообщение.УстановитьДанные(Объект);
		Сообщение.Сообщить();		
	КонецЦикла;

	Возврат НайденКонтрагент;

КонецФункции // ПроверкаКонтрагентаПоИНН()

