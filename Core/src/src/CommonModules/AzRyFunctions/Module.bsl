Процедура ЗапретСозданиеДокументаКопированием(Источник, ОбъектКопирования) Экспорт
	
	//Обнулит реквизиты при копирований -------------------------
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РасходнаяНакладная") Тогда  
		Источник.AzRySynch_RS_GE = Ложь;
		Источник.AzRyWayBill_ID  = "";
		Источник.AzRyWayBill_NUMBER = "";
		Источник.AzRy_STATUS = "";
		//Источник.AzRyWayBill_TRANSPORT_COAST = "";
		//Источник.AzRyWayBill_TRAN_COST_PAYER = "";
		//Источник.AzRyWayBilll_TRANSPORT_TYPES = Неопределено;
		//Источник.AzRyWayBilll_TRANSPORT_TYPES_TXT = "";
		//Источник.AzRyWayBilll_TYPES = "";
		//Источник.AzRyWayBilll_АдресДоставки = "";
		//Источник.AzRyWayBilll_АдресОтправки = "";
		//Источник.AzRyWayBilll_Водителы = Неопределено;
		Источник.AzRy_s_user_id = "";
		Источник.AzRy_su = "";
		Источник.AzRy_un_id = "";
		
		Для каждого ТекСтрока Из Источник.Запасы Цикл
			ТекСтрока.AzRyWayBill_ID = "";
			ТекСтрока.AzRyWayBillERROR = "";
		КонецЦикла;		
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.АктВыполненныхРабот") Тогда  
		
		Источник.Предоплата.Очистить();
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.РасходнаяНакладная") Тогда  
		
		Источник.Предоплата.Очистить();	
		
	ИначеЕсли ТипЗнч(Источник) = Тип("ДокументОбъект.ДополнительныеРасходы") Тогда  
		
		Источник.Предоплата.Очистить();	
		
	КонецЕсли;
	
	// Запрет копирование документа для бугалтера
	Если РольДоступна("Бугалтер") Тогда  
		ВызватьИсключение НСтр("ru = 'Копирование документа запрешено!'; ka = 'დოკუმენტის შექმნა კოპირებით აკრძალულია'");
	КонецЕсли;
	 
 КонецПроцедуры
 
