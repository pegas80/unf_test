//////////////////////////////////////////////////////////////////////////////// 
// АмортизацияВА - 

Процедура АмортизацияВА(Запрос, СтруктураДополнительныеСвойства, Объект) Экспорт 
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.АмортизацияВА") Тогда
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	*
		|ИЗ
		|	ТаблицаРасчетаАмортизации КАК ТаблицаДокумента";
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		Для каждого ТекСтрока Из РезультатЗапроса Цикл
			Если ТекСтрока.СпособНачисленияАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка Тогда
				Если ТекСтрока.Амортизация_old = 0 Тогда		
					ТекСтрока.Продолжить = Ложь;
				Иначе 	
					ГодАморт = Год(ТекСтрока.Период) - Год(ТекСтрока.ДатаПринятия2);
					БалансоваяСтоимостьГодовая = 0;
					БалансоваяСтоимостьГодоваяСумма = 0;
					ВсегоОсталосьСписать = ТекСтрока.СтоимостьДляВычисленияАмортизации;
					Ств = Новый Соответствие;
					Для Ч = 1 По ГодАморт+1 Цикл
						ДатаФормулы = ?(Ч = 1, ТекСтрока.ДатаПринятия2, ТекСтрока.Период);
						КолДнейВГодуСначалоПриема = ?(Ч = 1, (НачалоДня(КонецГода((ДатаФормулы))+1) - НачалоДня(ДатаФормулы)) / (60 * 60 * 24), 365);
						БалансоваяСтоимостьГодовая = (ВсегоОсталосьСписать / 100 * ТекСтрока.ПроцентАмортизацииДляВычисленияАмортизации) / 365 * КолДнейВГодуСначалоПриема;
						БалансоваяСтоимостьГодоваяСумма = БалансоваяСтоимостьГодоваяСумма + БалансоваяСтоимостьГодовая; 
						ВсегоОсталосьСписатьДо = ВсегоОсталосьСписать;
						ВсегоОсталосьСписать = (ВсегоОсталосьСписать - БалансоваяСтоимостьГодовая);
						Стр = Новый Структура;
						Стр.Вставить("БалансоваяСтоимостьГодовая", БалансоваяСтоимостьГодовая);
						Стр.Вставить("БалансоваяСтоимостьГодоваяСумма", БалансоваяСтоимостьГодоваяСумма);
						Стр.Вставить("ВсегоОсталосьСписать", ВсегоОсталосьСписатьДо);
						Ств.Вставить(Ч, Стр);
					КонецЦикла;
					
					Если ТекСтрока.ПоследныйМесяц Тогда
						ТекСтрока.Амортизация = ТекСтрока.БалансоваяСтоимость - ТекСтрока.АмортизацияКонечныйОстаток;	
					Иначе			
						//Если Месяц(ТекСтрока.Период) = 12 Тогда // 12 - ე თვე
						//	ТекСтрока.Амортизация = БалансоваяСтоимостьГодовая - (ТекСтрока.АмортизацияКонечныйОстаток - ?(Ств[ГодАморт] = Неопределено, 0, Ств[ГодАморт].БалансоваяСтоимостьГодовая));
						//Иначе
						Если НачалоМесяца(ТекСтрока.ДатаПринятия2) = НачалоМесяца(ТекСтрока.Период) Тогда
							КоличествоДнейВМесяц = Число(Сред(КонецМесяца(ТекСтрока.ДатаПринятия2), 1, 2));
							ТекДень              = День(ТекСтрока.ДатаПринятия2)-1;
							КолДны               = КоличествоДнейВМесяц - ТекДень;
							//ТекСтрока.Амортизация = Окр((БалансоваяСтоимостьГодовая / 12) / КоличествоДнейВМесяц, 2) * КолДны;
							ТекСтрока.Амортизация = (ТекСтрока.БалансоваяСтоимость / 100 * ТекСтрока.ПроцентАмортизацииДляВычисленияАмортизации) / 365 * КолДны;
						Иначе
							КоличествоДнейВМесяц = Число(Сред(КонецМесяца(ТекСтрока.Период), 1, 2));
							ТекСтрока.Амортизация = (Ств[ГодАморт+1].ВсегоОсталосьСписать / 100 * ТекСтрока.ПроцентАмортизацииДляВычисленияАмортизации) / 365 * КоличествоДнейВМесяц;
						КонецЕсли;
						//КонецЕсли;
					КонецЕсли;			
				КонецЕсли; 			 
			ИначеЕсли ТекСтрока.СпособНачисленияАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.Линейный Тогда
				Если ТекСтрока.Амортизация_old = 0 Тогда		
					ТекСтрока.Продолжить = Ложь;
				Иначе 	
					Амортизация = 1 / ТекСтрока.СрокИспользованияДляВычисленияАмортизации * ТекСтрока.СтоимостьДляВычисленияАмортизации;
					Если НачалоМесяца(ТекСтрока.ДатаПринятия2) = НачалоМесяца(ТекСтрока.Период) Тогда
						КоличествоДнейВМесяц = Число(Сред(КонецМесяца(ТекСтрока.ДатаПринятия2), 1, 2));
						ТекДень              = День(ТекСтрока.ДатаПринятия2)-1;
						КолДны               = КоличествоДнейВМесяц - ТекДень;
						
						ТекСтрока.Амортизация = Амортизация / КоличествоДнейВМесяц * КолДны;
					ИначеЕсли ТекСтрока.ПоследныйМесяц Тогда 
						ТекСтрока.Амортизация = ТекСтрока.ВсегоОсталосьСписать;
					Иначе 	
						ТекСтрока.Амортизация = Амортизация;	
					КонецЕсли;					
				КонецЕсли;	 	
			КонецЕсли; 
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		
		Запрос.Текст =
		"
		| УНИЧТОЖИТЬ ТаблицаРасчетаАмортизации;
		|
		|//////////////////////////////////////////////
		|
		|ВЫБРАТЬ  *
		|ПОМЕСТИТЬ ТаблицаРасчетаАмортизации
		|ИЗ
		|&Таблица КАК Таблица";
		
		Запрос.УстановитьПараметр("Таблица", РезультатЗапроса);	
		Запрос.Выполнить();
		
	ИначеЕсли ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ПередачаВА") Или ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.СписаниеВА") Тогда
		
		// 1
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.AzRyСпособАмортизации,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив,
		|	ПараметрыВнеоборотныхАктивовСрезПоследних.ПроцентАмортизации
		|ИЗ
		|	РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(&Дата, ВнеоборотныйАктив В (&СписокЗначений)) КАК СостоянияВнеоборотныхАктивовСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних КАК ПараметрыВнеоборотныхАктивовСрезПоследних
		|		ПО СостоянияВнеоборотныхАктивовСрезПоследних.Организация = ПараметрыВнеоборотныхАктивовСрезПоследних.Организация
		|			И СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив = ПараметрыВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
		|ГДЕ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.Организация = &Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СостоянияВнеоборотныхАктивовСрезПервых.AzRyСпособАмортизации,
		|	СостоянияВнеоборотныхАктивовСрезПервых.ВнеоборотныйАктив,
		|	СостоянияВнеоборотныхАктивовСрезПервых.Период
		|ИЗ
		|	РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПервых(, ВнеоборотныйАктив В (&СписокЗначений)) КАК СостоянияВнеоборотныхАктивовСрезПервых";
		
		Запрос.УстановитьПараметр("Дата", Объект.Дата);
		Запрос.УстановитьПараметр("СписокЗначений", СтруктураДополнительныеСвойства.ВыгрузитьКолонку("ВнеоборотныйАктив"));
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
		
		МассивРезультатов = Запрос.ВыполнитьПакет();		
		РезультатЗапроса1 = МассивРезультатов[0].Выгрузить();
		РезультатЗапроса2 = МассивРезультатов[1].Выгрузить();
				
		// 2
		Для каждого ТекСтрока Из СтруктураДополнительныеСвойства Цикл		
			НайденнаяСтрока = РезультатЗапроса1.Найти(ТекСтрока.ВнеоборотныйАктив, "ВнеоборотныйАктив");
			Если НайденнаяСтрока <> Неопределено И НайденнаяСтрока.AzRyСпособАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка Тогда
				
				НайденнаяСтрока2 = РезультатЗапроса2.Найти(ТекСтрока.ВнеоборотныйАктив, "ВнеоборотныйАктив");
				
				ГодАморт = Год(Объект.Дата) - Год(НайденнаяСтрока2.Период);
				БалансоваяСтоимостьГодовая = 0;
				БалансоваяСтоимостьГодоваяСумма = 0;
				ВсегоОсталосьСписать = ТекСтрока.Стоимость;
				Ств = Новый Соответствие;
				Для Ч = 1 По ГодАморт+1 Цикл
					ДатаФормулы = ?(Ч = 1, НайденнаяСтрока2.Период, Объект.Дата);
					КолДнейВГодуСначалоПриема = ?(Ч = 1, (НачалоДня(КонецГода((ДатаФормулы))+1) - НачалоДня(ДатаФормулы)) / (60 * 60 * 24), 365);
					БалансоваяСтоимостьГодовая = (ВсегоОсталосьСписать / 100 * НайденнаяСтрока.ПроцентАмортизации) / 365 * КолДнейВГодуСначалоПриема;
					БалансоваяСтоимостьГодоваяСумма = БалансоваяСтоимостьГодоваяСумма + БалансоваяСтоимостьГодовая; 
					ВсегоОсталосьСписатьДо = ВсегоОсталосьСписать;
					ВсегоОсталосьСписать = (ВсегоОсталосьСписать - БалансоваяСтоимостьГодовая);
					Стр = Новый Структура;
					Стр.Вставить("БалансоваяСтоимостьГодовая", БалансоваяСтоимостьГодовая);
					Стр.Вставить("БалансоваяСтоимостьГодоваяСумма", БалансоваяСтоимостьГодоваяСумма);
					Стр.Вставить("ВсегоОсталосьСписать", ВсегоОсталосьСписатьДо);
					Ств.Вставить(Ч, Стр);
				КонецЦикла;
				
				
				КоличествоДнейВМесяц = Число(Сред(КонецМесяца(Объект.Дата), 1, 2));
				ТекДень              = День(Объект.Дата)-1;
				//КолДны               = КоличествоДнейВМесяц - ТекДень;
				ТекСтрока.АмортизацияЗаМесяц = (Ств[ГодАморт+1].ВсегоОсталосьСписать / 100 * НайденнаяСтрока.ПроцентАмортизации) / 365 * ТекДень;	
			КонецЕсли;  			
		КонецЦикла;				
	КонецЕсли;	
	
КонецПроцедуры

Процедура АмортизацияВА_КолДней(Запрос, СтруктураДополнительныеСвойства) Экспорт

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	*
	|ИЗ
	|	ВременнаяТаблицаДляРасчетаКоличествоМесяцев КАК ТаблицаДокумента";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("ВнеоборотныйАктив", Новый ОписаниеТипов("СправочникСсылка.ВнеоборотныеАктивы"));
	ТЗ.Колонки.Добавить("Кол", Новый ОписаниеТипов("Число")); 
	ТЗ.Колонки.Добавить("ПериодДляВичисленияКолДней", Новый ОписаниеТипов("Число")); 
	ТЗ.Колонки.Добавить("ДатаПринятия", Новый ОписаниеТипов("Дата"));

	
	Для каждого ТекСтрока Из РезультатЗапроса Цикл
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(*) КАК Кол
		|ИЗ
		|	РегистрНакопления.ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
		|ГДЕ
		|	(ВнеоборотныеАктивы.Регистратор ССЫЛКА Документ.АмортизацияВА
		//|			ИЛИ ВнеоборотныеАктивы.Регистратор ССЫЛКА Документ.ПринятиеКУчетуВА
		//| 			ИЛИ ВнеоборотныеАктивы.Регистратор ССЫЛКА Документ.ИзменениеПараметровВА
		|)
		|	И ВнеоборотныеАктивы.Период МЕЖДУ &ПериодНачало И &ПериодКонец
		|	И ВнеоборотныеАктивы.Организация = &Организация
		|	И ВнеоборотныеАктивы.ВнеоборотныйАктив = &ВнеоборотныйАктив";
		
		Запрос.УстановитьПараметр("ПериодНачало", ТекСтрока.Начало);
		Запрос.УстановитьПараметр("ПериодКонец", КонецМесяца(ТекСтрока.Конец));
		Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
		Запрос.УстановитьПараметр("ВнеоборотныйАктив", ТекСтрока.ВнеоборотныйАктив);
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();						
		Для каждого ТекИм Из РезультатЗапроса Цикл
			НоаяСтрока = ТЗ.Добавить();
			НоаяСтрока.ВнеоборотныйАктив = ТекСтрока.ВнеоборотныйАктив; 
			НоаяСтрока.ДатаПринятия = ТекСтрока.Начало;
			НоаяСтрока.Кол = (ТекИм.Кол+1);
			НоаяСтрока.ПериодДляВичисленияКолДней = ТекСтрока.ПериодДляВичисленияКолДней;
		КонецЦикла;
		
	КонецЦикла;

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст =
	" ВЫБРАТЬ  *
	|ПОМЕСТИТЬ ВременнаяТаблицаКолМесяцев
	|ИЗ
	|&Таблица КАК Таблица";
	
	Запрос.УстановитьПараметр("Таблица", ТЗ);	
	Запрос.Выполнить();
	
КонецПроцедуры
 

//////////////////////////////////////////////////////////////////////////////// 
// ИзменениеПараметровВА - 

Процедура ИзменениеПараметровВА(ДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.AzRyИзменениеСпособаМетодаАмортизаций,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.AzRyСпособАмортизации
		|ИЗ
		|	РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(&Дата, ВнеоборотныйАктив В (&ВнеоборотныйАктив)) КАК СостоянияВнеоборотныхАктивовСрезПоследних
		|ГДЕ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.Организация = &Организация";
	
	Запрос.УстановитьПараметр("ВнеоборотныйАктив", ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаСостоянияВнеоборотныхАктивов.ВыгрузитьКолонку("ВнеоборотныйАктив"));
	Запрос.УстановитьПараметр("Дата", ДополнительныеСвойства.ДляПроведения.Дата-1);
	Запрос.УстановитьПараметр("Организация", ДополнительныеСвойства.ДляПроведения.Организация);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
	Для каждого ТекСтрока Из ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаСостоянияВнеоборотныхАктивов Цикл
		НайденнаяСтрока = РезультатЗапроса.Найти(ТекСтрока.ВнеоборотныйАктив, "ВнеоборотныйАктив");
		ТекСтрока.AzRyИзменениеСпособаМетодаАмортизаций = НайденнаяСтрока.AzRyСпособАмортизации <> ТекСтрока.AzRyСпособАмортизации;	
	КонецЦикла;			

КонецПроцедуры

