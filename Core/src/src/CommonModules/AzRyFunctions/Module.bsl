Процедура ПолучитьКурсДокумента(ДокументСсылка, Курс, Кратность)
	
	Если ДокументСсылка.Предоплата.Количество() = 0 Тогда
		Курс      = ДокументСсылка.Курс;
		Кратность = ДокументСсылка.Кратность;
	Иначе 
		Курс      = ДокументСсылка.Предоплата[0].Курс;
		Кратность = ДокументСсылка.Предоплата[0].Кратность;
	КонецЕсли;	
		
КонецПроцедуры	
	
Функция АмортизацияДатаПредДокумента(ДатаДокумента) Экспорт

	ДатаДляВозврата = Дата(1,1,1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АмортизацияВА.Дата КАК Дата,
		|	АмортизацияВА.Ссылка
		|ИЗ
		|	Документ.АмортизацияВА КАК АмортизацияВА
		|ГДЕ
		|	АмортизацияВА.Проведен = ИСТИНА
		|	И АмортизацияВА.Дата < &Дата
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
		
	Запрос.УстановитьПараметр("Дата", ДатаДокумента);	

	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл		
		Возврат Запрос.Выполнить().Выгрузить()[0].Дата;
	КонецЦикла;
	
	Возврат ДатаДляВозврата;

КонецФункции
	

