				ПараметрыВалютаУчета.Вставить("Курс",      ДополнительныеСвойства.ДляПроведения.Ссылка.Курс);
				ПараметрыВалютаУчета.Вставить("Кратность", ДополнительныеСвойства.ДляПроведения.Ссылка.Кратность);
				
