Функция Ping(IPАдрес)
	
	objShell = Новый COMОбъект("WScript.Shell") ;
    objScriptExec = objShell.Exec("ping.exe -n 1 " + IPАдрес) ;
    strPingResults = НРег(objScriptExec.StdOut.ReadAll());
	
	Возврат   Найти(strPingResults, "ttl=");
	
КонецФункции

