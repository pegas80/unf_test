
Функция СписокИспользуемыхВесов()
	
	ДрайверОборудования = Новый Массив;
	ДрайверОборудования.Добавить(Справочники.ДрайверыОборудования.ДрайверDigiВесыСПечатьюЭтикеток);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	ПодключаемоеОборудование.Ссылка
	                      |ИЗ
	                      |	Справочник.ПодключаемоеОборудование КАК ПодключаемоеОборудование
	                      |ГДЕ
	                      |	ПодключаемоеОборудование.УстройствоИспользуется
	                      |	И ПодключаемоеОборудование.ТипОборудования = &ТипОборудования
	                      |	И ПодключаемоеОборудование.ДрайверОборудования В(&ДрайверОборудования)
	                      |	И НЕ ПодключаемоеОборудование.ПометкаУдаления");
						  
	Запрос.УстановитьПараметр("ТипОборудования",	 Перечисления.ТипыПодключаемогоОборудования.ВесыСПечатьюЭтикеток);
	Запрос.УстановитьПараметр("ДрайверОборудования", ДрайверОборудования);
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	МассивВесов = Новый Массив;
	
	Пока Выборка.Следующий() Цикл 
		МассивВесов.Добавить(Выборка.Ссылка);		
	КонецЦикла;
	
	Возврат МассивВесов;
	
КонецФункции

Функция ТипОборудования(ПодключаемоеОборудование) Экспорт
	
	Возврат ПодключаемоеОборудование.ДрайверОборудования.ОбработчикДрайвера;

КонецФункции

Функция ПараметрыОборудования(ПодключаемоеОборудование) Экспорт
	
	ПараметрыПодключения = Новый Массив;
	ПараметрыПодключения.Добавить(ПодключаемоеОборудование.Параметры.Получить());
	
	Возврат ПараметрыПодключения;
	  
КонецФункции

Функция ТаблицаВыгрузкиТоваров(ВидЦены, ОтборПоТоварам = Неопределено) Экспорт     	
	
	ТаблицаВыгрузкиТоваров = Новый Массив;                
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод,
		|	ШтрихкодыНоменклатуры.Номенклатура,
		|	&ВидЦены КАК ВидЦены,
		|	ВЫРАЗИТЬ(ШтрихкодыНоменклатуры.Номенклатура.НаименованиеПолное КАК СТРОКА(256)) КАК НаименованиеНоменклатуры,
		|	ШтрихкодыНоменклатуры.PLU КАК PLU,
		|	ШтрихкодыНоменклатуры.PLU КАК Код,
		|	ШтрихкодыНоменклатуры.Номенклатура.СрокГодности КАК СрокГодности,
		|	ВЫБОР
		|		КОГДА ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 2, 1) = ""2""
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Весовая,
		|	ВЫБОР
		|		КОГДА ШтрихкодыНоменклатуры.ЕдиницаИзмерения = NULL
		|				ИЛИ ШтрихкодыНоменклатуры.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.ЕдиницыИзмерения.ПустаяСсылка)
		|				ИЛИ ШтрихкодыНоменклатуры.ЕдиницаИзмерения = ЗНАЧЕНИЕ(Справочник.КлассификаторЕдиницИзмерения.ПустаяСсылка)
		|			ТОГДА ШтрихкодыНоменклатуры.Номенклатура.ЕдиницаИзмерения
		|		ИНАЧЕ ШтрихкодыНоменклатуры.ЕдиницаИзмерения
		|	КОНЕЦ КАК ЕдиницаИзмерения,
		|	ШтрихкодыНоменклатуры.ЕдиницаИзмерения.Наименование КАК ПредставлениеВесовойЕдиницы,
		|	0 КАК Цена,
		|	ШтрихкодыНоменклатуры.Номенклатура.Родитель.Код КАК КодРодитель
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура.ВыгружатьВВесы = ИСТИНА
		|	И ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 1, 1) = ""2"""  + 
		
		?(ОтборПоТоварам = Неопределено,"","
		|И Номенклатура В (&ОтборПоТоварам)");
	
	Запрос.Текст = Запрос.Текст + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	PLU";
	
	
	Запрос.УстановитьПараметр("ВидЦены",		ВидЦены);
	Запрос.УстановитьПараметр("ОтборПоТоварам",	ОтборПоТоварам);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
	Для Каждого СтрокаТЧ Из РезультатЗапроса Цикл
		
		СтрокаТЧ.Цена = ЦенообразованиеСервер.ПолучитьЦенуНоменклатуры(СтрокаТЧ.Номенклатура, ТекущаяДата(), ВидЦены, СтрокаТЧ.Номенклатура.ЕдиницаИзмерения);
		
		Если СтрокаТЧ.PLU = 0 Тогда
			//сгенерируем новый PLU
			СтрокаТЧ.PLU = СгенерироватьНовыйPLU(СтрокаТЧ.Штрихкод);
			СтрокаТЧ.Код = СтрокаТЧ.PLU;			
		КонецЕсли;
	
		СтруктураСтроки = Новый Структура("Штрихкод,НаименованиеНоменклатуры,Весовая,ЕдиницаИзмерения,ПредставлениеВесовойЕдиницы,Номенклатура,PLU,Код,КодРодитель,Цена,СрокГодности");
		ЗаполнитьЗначенияСвойств(СтруктураСтроки,СтрокаТЧ);
		 
		ТаблицаВыгрузкиТоваров.Добавить(СтруктураСтроки);
		
	КонецЦикла;		
		
	Возврат ТаблицаВыгрузкиТоваров;
	
КонецФункции

Функция ДиапазоныВесовыхШтрихкодов() Экспорт
	
