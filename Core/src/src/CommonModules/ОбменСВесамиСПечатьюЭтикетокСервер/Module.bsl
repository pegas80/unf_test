	СоответствиеКодировки.Вставить("ც","Э");
	СоответствиеКодировки.Вставить("ძ","Ю");
	СоответствиеКодировки.Вставить("წ","Я");
	СоответствиеКодировки.Вставить("ჭ","а");
	СоответствиеКодировки.Вставить("ხ","б");
	СоответствиеКодировки.Вставить("ჯ","г");
	СоответствиеКодировки.Вставить("ჰ","д");
	
	НаименованиеДляВесевогоТовара = "";
	Символ = "";
	
	Для Счт = 1 По СтрДлина(Наименование) Цикл
		
		ГрузинскийСимвол = Сред(Наименование, Счт, 1);
		
		Если СтрЧислоВхождений("აბგდევზთიკლმნოპჟრსტუფქღყშჩცძწჭხჯჰ",ГрузинскийСимвол) > 0 Тогда 
			
			СоответствиеКодировки.Свойство(ГрузинскийСимвол, Символ);
			
		Иначе 
			
			Символ = ГрузинскийСимвол;
			
		КонецЕсли;
		
		НаименованиеДляВесевогоТовара = НаименованиеДляВесевогоТовара + Символ; 
		
	КонецЦикла;
	
	Возврат НаименованиеДляВесевогоТовара;
	
	
КонецФункции

Процедура ВыгрузитьТоварыВВесы() Экспорт
	
	МассивIP = Новый Массив;
	ЗапросАдресов = Новый Запрос;
	ЗапросАдресов.Текст = "ВЫБРАТЬ
	                      |	АдресаВесов.IPAdress
	                      |ИЗ
	                      |	РегистрСведений.АдресаВесов КАК АдресаВесов
	                      |ГДЕ
	                      |	АдресаВесов.Выгружать = ИСТИНА
	                      |	И НЕ АдресаВесов.IPAdress = """"";
	РезЗапросаАдресов = ЗапросАдресов.Выполнить();
	Если НЕ РезЗапросаАдресов.Пустой() Тогда
		ВыборкаАдресов = РезЗапросаАдресов.Выбрать();
		Пока ВыборкаАдресов.Следующий() Цикл
			МассивIP.Добавить(СокрЛП(ВыборкаАдресов.IPAdress));	
		КонецЦикла; 	
	КонецЕсли;
		
	ТабНоменклатуры = ПолучитьТаблицуНоменклатуры();
	
	Для Каждого ЭлВесов Из МассивIP Цикл
		Попытка
			ПрогИД = "DigiSM.Scale";
			Драйвер = Новый COMОбъект(ПрогИД);
			Драйвер.Registered = "Developer License, RS Line LLC, ID 404395463";
			Драйвер.Copyright  = "Scale-Soft Site: http://scale-soft.com Email: support@scale-soft.com";
			Драйвер.ScaleIP = ЭлВесов; //автоматически задается значение ScalePort
			Драйвер.ScaleTimeOut = 1000;
			Ошиб = Драйвер.OpenConnect();
			Если Не Ошиб = 0 Тогда
				Если Ошиб = -1 Тогда
					Ошиб = Драйвер.CloseConnect();
					Драйвер = "";
					Продолжить;
				КонецЕсли;	
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = Ошиб;
				Сообщение.Сообщить();
			КонецЕсли;
                                         
			Для Каждого СтрТов Из ТабНоменклатуры Цикл
								
				//Задаем параметры товара
				Драйвер.ScaleTimeOut  = 1000;
				Драйвер.PLUType	  	  = СтрТов.Весовой; //0,1(весовой, штучный)
				Драйвер.PLUNo	  	  = СтрТов.PLU; //от 0 до 7500
				Драйвер.PLUName   	  = ПолучитьНаименование_GE_RU(СтрТов.Наименование); //макс. 412 символов
				Драйвер.GroupCode 	  = 0; //код основной группы
				Драйвер.ItemCode   	  = СтрТов.ШтрихКод; //префикс штрихкода + код товара макс. 12 цифр
				Драйвер.BarCodeFormat = 5; //Формат штрихкода - F1F2 CCCCC XXXXX CD (23 04567 вес CD)
				Драйвер.LabelFormat	  = "F1"; //1 свободный формат этикетки  (две строчки - 30 символов)
				Драйвер.LabelFont	  = "S5"; //Шрифт этикетки по умолчанию 5 × 7 (IngredientName)
				Драйвер.UnitPrice 	  = СтрТов.Цена*100;//цена товара (коп) от 0 до 999999 
				Драйвер.ShelfLife	  = СтрТов.СрокГодности;//срок годности (сут) от 0 до 999
				
				//Загружаем в весы параметры товара
				Ошиб = Драйвер.SendPLU();
				Если Не Ошиб = 0 Тогда
					Драйвер.CloseConnect();
					Сообщение = Новый СообщениеПользователю();
					Сообщение.Текст = Ошиб;
					Сообщение.Сообщить();
				КонецЕсли;	
					
			КонецЦикла;	
			
			Драйвер.CloseConnect();
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = ЭлВесов;
			Сообщение.Сообщить();
			Драйвер = "";
			 
		Исключение
			Сообщить(ОписаниеОшибки());		
			тОписаниеОшибки = "Невозможно подключить OLE драйвер.
			| Проверьте, что OLE драйвер корректно установлен.";
			Сообщить(тОписаниеОшибки);
			пОшибка = Истина;
			
		КонецПопытки;	
	КонецЦикла;	
	
КонецПроцедуры	

Функция ПолучитьIPАдресВесов() Экспорт

	ЗапросАдресов = Новый Запрос;
	ЗапросАдресов.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	АдресаВесов.IPAdress
	                      |ИЗ
	                      |	РегистрСведений.АдресаВесов КАК АдресаВесов
	                      |ГДЕ
	                      |	АдресаВесов.Выгружать = ИСТИНА";
	РезЗапросаАдресов = ЗапросАдресов.Выполнить();
	Если РезЗапросаАдресов.Пустой() Тогда
		ТекущийIP = "";
	Иначе	
		ВыборкаАдресов = РезЗапросаАдресов.Выбрать();
		ВыборкаАдресов.Следующий();
		ТекущийIP = СокрЛП(ВыборкаАдресов.IPAdress);	
	КонецЕсли;
	
КонецФункции	
