//digi
Функция ВыгрузитьТоварыDIGI(ПараметрыПодключения, Товары, УзелОбменаДляВесы = Неопределено) Экспорт
	
	АдресПрограмы = ПараметрыПодключения.АдресПрограмы;
	IPАдрес = ПараметрыПодключения.IPАдрес;
	
	Текст = Новый ТекстовыйДокумент;                                            
	Текст.УстановитьТипФайла(КодировкаТекста.ANSI); 
	
	ВременнаяСтрокаЗаписи = "";
	СтрокаГорячихКнопок = "";
		
	//МенеджерЗаписи = РегистрыСведений.ВыгрузкаВВесах.СоздатьНаборЗаписей();
	//МенеджерЗаписи.Отбор.Весы.Установить(УзелОбменаДляВесы);
	
	Для Каждого ТекСтр Из Товары Цикл	
		
		НаименованиеНоменклатуры = ТекСтр.НаименованиеНоменклатуры;
		
		HEXДлинаНаим =  DecToHex(СтрДлина(НаименованиеНоменклатуры));     				
		Шрифт = ПолучитьРазмерДляШрифта(СтрДлина(НаименованиеНоменклатуры));   				
		НеХватаетРазмера = 2 - СтрДлина(HEXДлинаНаим);   
		
		НехватающаяЧасть = "";
		
		Пока   НеХватаетРазмера<> 0 Цикл    				  
			НехватающаяЧасть = НехватающаяЧасть + "0"; 
			НеХватаетРазмера = НеХватаетРазмера - 1; 					
		КонецЦикла;	
		
		HEXДлинаНаим = НехватающаяЧасть + HEXДлинаНаим;       			
		
		НаимНомен = ?(СтрДлина(НаименованиеНоменклатуры)>52,Сред(НаименованиеНоменклатуры,1,52),НаименованиеНоменклатуры);
		НаименованиеТовараКод =   ПолучитьНаименование_GE_RU_DIGI_ДляПрямогоЭкспорта(НаимНомен);
		
		ItemPLU = Формат(Число(ТекСтр.PLU),"ЧЦ=8; ЧВН=; ЧГ=0");  			  
		
		Если ТекСтр.Весовая Тогда
			PLUSTATUS = "7C00";
		Иначе
			PLUSTATUS = "7D00";                                                                                                                                                             
		КонецЕсли;    			  
		
		ЦенаКопеек   = Формат(Цел(Текстр.Цена*100) ,  "ЧЦ=8; ЧДЦ=0; ЧН=; ЧВН=; ЧГ=0" );   					  
		ЦенаКонечная = Строка(ЦенаКопеек);//8   
		
		ПолеШтрихКод = Сред(Текстр.Штрихкод,1,12);   				
		Срок = "0000";
		
		Срок = ТекСтр.СрокГодности; 
		Срок = Строка(Срок);
		Срок = СокрЛП(Срок);
		Срок = СтрЗаменить(Срок, Символ(160), "");
		Срок = Лев("0000", 4-СтрДлина(Срок)) + Срок;  				
		
		СтрокаПередРазмером = PLUSTATUS + "DD215F" + ЦенаКонечная + "1105" + ПолеШтрихКод + "00" + Срок + "00000000000000000000000000010000000000000000000000" + Шрифт + HEXДлинаНаим + НаименованиеТовараКод ; 
		
		//Формат არ იმუშავებს, რადგან ასოებიც შედის !!! ფორმატი თექვსმეტობით რიცხვებს ვერ აღიქვამს,  PluRecordSize სტრიქონია !!!!
		PluRecordSize =  DecToHex( (СтрДлина(СтрокаПередРазмером) + 16) /2 )  ; 
		
		НеХватаетРазмера = 4 - СтрДлина(PluRecordSize);    			  
		НехватающаяЧасть = "";    
		
		Пока   НеХватаетРазмера <> 0 Цикл  				  
			НехватающаяЧасть = НехватающаяЧасть + "0"; 
			НеХватаетРазмера = НеХватаетРазмера - 1; 				  
		КонецЦикла;		
		
		PluRecordSize = НехватающаяЧасть + PluRecordSize;   			  
		
		//წონითი FE01, არაწონითი FF01 , ცალ-ცალკე სტრიქონებად არ ვწერთ !!!! 
		ВременнаяСтрокаЗаписи = ВременнаяСтрокаЗаписи + ItemPLU + PluRecordSize + PLUSTATUS + "DD211F" + ЦенаКонечная + "1105" + ПолеШтрихКод +
		"00000000000000" + Срок + "000000000000000100"+Шрифт +HEXДлинаНаим+НаименованиеТовараКод+"0C00"+"DA000000000000000000"; 
			
		//"ცხელი ღილაკები"   - HOTKEYS
		ВыгрузитьКнопки = Ложь;
		
		//СтрТаблица = МенеджерЗаписи.Добавить();
		//СтрТаблица.Весы 		= УзелОбменаДляВесы;	
		//СтрТаблица.Номенклатура = ТекСтр.Номенклатура;
		//СтрТаблица.PLU 			= ТекСтр.PLU;
		//СтрТаблица.Цена 		= ТекСтр.Цена;
		//СтрТаблица.Период 		= ТекущаяДата();
		
	КонецЦикла;	  
	
	СтрокаДляЗадачи = "";
	СтрокаДляЗадачиКнопок = "";
	
	Если Не ВременнаяСтрокаЗаписи = "" Тогда
		
		Текст.ДобавитьСтроку(ВременнаяСтрокаЗаписи);				
				
		Если Не Найти ( IPАдрес,"." ) = 0 Тогда	
			
			ФорматIP   =  СтрЗаменить(СтрЗаменить(IPАдрес," ",""),Символы.Таб,""); 							
			ПослБайтIP =  Домейн(ФорматIP,Истина);		
			
			Если  ПослБайтIP = -1 Тогда	
				Сообщить("სასწორის მისამართი"+ IPАдрес + "არასწორია !");
				Возврат Ложь;
			КонецЕсли;
			
			ИмяФайлаВыгрузки = АдресПрограмы + "\SM" + ПослБайтIP + "F25.DAT";  					
			СтрокаДляЗадачи = СтрокаДляЗадачи + Домейн(ФорматIP,Истина)+" ";     				
			
			Попытка
				Текст.Записать(ИмяФайлаВыгрузки, КодировкаТекста.ANSI);       					
			Исключение
				Сообщить("ვერ მოხერხდა მონაცემების გადატვირთვა. გადაამოწმეთ სასწორის მისამართი");
				Возврат Ложь;
			КонецПопытки;   
		Иначе
			Сообщить("სასწორის მისამართი" + IPАдрес + "არასწორია !");					
		КонецЕсли;	
					  				
		
		АдресДрайвера = АдресПрограмы+"\twswtcp.exe";
		Драйвер = Новый Файл(АдресДрайвера);
		
