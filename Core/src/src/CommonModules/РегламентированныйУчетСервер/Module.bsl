Функция ЗапросВыполнитьВыгрузить(ТекстЗапроса, ПараметрыЗапроса = Неопределено, МенеджерВременныхТаблиц = Неопределено) Экспорт 
	Запрос = Новый Запрос(ТекстЗапроса); 
	Если МенеджерВременныхТаблиц <> Неопределено Тогда
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
	КонецЕсли;
	Если ЗначениеЗаполнено(ПараметрыЗапроса) Тогда 
		Для Каждого Параметр Из ПараметрыЗапроса Цикл
			Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
		КонецЦикла; 
	КонецЕсли;
	Возврат Запрос.Выполнить().Выгрузить(); 
КонецФункции

Функция ПоказатьВременнуюТаблицу(МенеджерВременныхТаблицИлиЗапрос, ИмяВременнойТаблицы) Экспорт 
	ЗакрытьМенеджерВременныхТаблиц = Ложь; Если ТипЗнч(МенеджерВременныхТаблицИлиЗапрос) = Тип("Запрос") Тогда 
		Если МенеджерВременныхТаблицИлиЗапрос.МенеджерВременныхТаблиц = Неопределено Тогда 
			МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц; 
			ЗакрытьМенеджерВременныхТаблиц = Истина; 
			МенеджерВременныхТаблицИлиЗапрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц; 
		Иначе МенеджерВременныхТаблиц = МенеджерВременныхТаблицИлиЗапрос.МенеджерВременныхТаблиц; 
		КонецЕсли; 
		МенеджерВременныхТаблицИлиЗапрос.Выполнить();
	Иначе МенеджерВременныхТаблиц = МенеджерВременныхТаблицИлиЗапрос; 
	КонецЕсли; 
	ДанныеТаблицы = ЗапросВыполнитьВыгрузить("ВЫБРАТЬ * ИЗ " + ИмяВременнойТаблицы,, МенеджерВременныхТаблиц); 
	Если ЗакрытьМенеджерВременныхТаблиц Тогда 
		МенеджерВременныхТаблиц.Закрыть(); 
		МенеджерВременныхТаблицИлиЗапрос.МенеджерВременныхТаблиц = Неопределено;
	КонецЕсли; 
	
	Возврат ДанныеТаблицы; 
КонецФункции

Процедура ДобавитьПроводкиПоЗапасам(Движения, СтруктураПараметров)
	
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = СтруктураПараметров.ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Запасы.Номенклатура,
		|	Запасы.Количество,
		|	Запасы.СтруктурнаяЕдиница,
		|	Запасы.Номенклатура.СчетУчетаЗапасовРегл КАК СчетУчетаЗапасовРегл,
		|	Запасы.ВалютаРасчетов,
		|	Запасы.СуммаВал,
		|	Запасы.СуммаНДСВал,
		|	Запасы.Сумма,
		|	Запасы.СуммаРасходов,
		|	Запасы.СуммаРасходовНДФЛ,
		|	Запасы.СуммаНДС
		|ИЗ
		|	ВременнаяТаблицаЗапасы КАК Запасы";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Если НЕ ЗначениеЗаполнено(Выборка.СчетУчетаЗапасовРегл) Тогда
				
				СтрокаСообщения = НСтр("ka='Не заполнен счет учета запасов для номенклатуры %1';ru='Не заполнен счет учета запасов для номенклатуры %1';en='Not filled by inventory for the range of 1%'");
				СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%1", Выборка.Номенклатура);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаСообщения);
				Отказ = Истина;
				Продолжить;
				
			КонецЕсли; 
			
			Движение = Движения.Хозрасчетный.Добавить();
			Движение.Период = СтруктураПараметров.Период;
			Движение.Организация = СтруктураПараметров.Организация;
			Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ОприходованиеЗапасов);
			
			Движение.КоличествоДт = Выборка.Количество;
			
			Движение.СчетДт = Выборка.СчетУчетаЗапасовРегл;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Номенклатура", Выборка.Номенклатура);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Склады", Выборка.СтруктурнаяЕдиница);
			
			Движение.СчетКт = СтруктураПараметров.СчетУчетаРасчетовСПоставщиком;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", СтруктураПараметров.Контрагент);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", СтруктураПараметров.Договор);
			
			Если Движение.СчетКТ.Валютный Тогда
				
				Движение.ВалютаКт = Выборка.ВалютаРасчетов;
				Движение.ВалютнаяСуммаКт = Выборка.СуммаВал  + Выборка.СуммаРасходов - Выборка.СуммаРасходовНДФЛ - Выборка.СуммаНДСВал;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаРасчетов);
				
			КонецЕсли; 
			
			Движение.Сумма  = Выборка.Сумма + Выборка.СуммаРасходов - Выборка.СуммаРасходовНДФЛ - Выборка.СуммаНДС;
			
			Если Выборка.СуммаНДС <> 0 Тогда
				
				
				Движение = Движения.Хозрасчетный.Добавить();
				Движение.Период = СтруктураПараметров.Период;
				Движение.Организация = СтруктураПараметров.Организация;
				Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.НачислениеНДС);
				
				Движение.СчетДт = СтруктураПараметров.СчетУчетаНДС;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СчетФактураПоставщика", СтруктураПараметров.НайденныйСчетФактура);
				
				Движение.СчетКт = СтруктураПараметров.СчетУчетаРасчетовСПоставщиком;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", СтруктураПараметров.Контрагент);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", СтруктураПараметров.Договор);
				
				
				Движение.Сумма  = Выборка.СуммаНДС;
				
			Если Движение.СчетКТ.Валютный Тогда
				
					Движение.ВалютаКт = Выборка.ВалютаРасчетов;
					Движение.ВалютнаяСуммаКт = Выборка.СуммаНДСВал;
					БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаРасчетов);
					
				КонецЕсли; 
				
			КонецЕсли; 
			
		КонецЦикла; 

	
КонецПроцедуры

Процедура ДобавитьПроводкиЗачетПредоплаты(Движения, СтруктураПараметров)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураПараметров.ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Взаиморасчеты.Контрагент,
	|	Взаиморасчеты.Договор,
	|	Взаиморасчеты.Валюта,
	|	Взаиморасчеты.СуммаВал,
	|	Взаиморасчеты.Сумма
	|ИЗ
	|	ВременнаяТаблицаРасчетыСПоставщиками КАК Взаиморасчеты
	|ГДЕ
	|	Взаиморасчеты.ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Движение = Движения.Хозрасчетный.Добавить();
		Движение.Период = СтруктураПараметров.Период;
		Движение.Организация = СтруктураПараметров.Организация;
		Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ЗачетПредоплаты);
		
		Движение.СчетДт = СтруктураПараметров.СчетУчетаРасчетовСПоставщиком;
		БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Контрагенты", Выборка.Контрагент);
		БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Договоры", Выборка.Договор);
		
		Если Движение.СчетДт.Валютный Тогда
			
			Движение.ВалютаДт = Выборка.Валюта;
			Движение.ВалютнаяСуммаДт = Выборка.СуммаВал;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Валюты", Выборка.Валюта);
			
		КонецЕсли; 
		
		Движение.СчетКт = СтруктураПараметров.СчетУчетаАвансовПоставщику;
		БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", Выборка.Контрагент);
		БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", Выборка.Договор);
		
		Если Движение.СчетКт.Валютный Тогда
			
			Движение.ВалютаКт = Выборка.Валюта;
			Движение.ВалютнаяСуммаКт = Выборка.СуммаВал;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.Валюта);
			
		КонецЕсли; 
		
		Движение.Сумма  = Выборка.Сумма;
		
	КонецЦикла; 
	
КонецПроцедуры

