//+++
Процедура ПересчитатьСуммыВалютыПредоплатыВСуммыРеглУчета(ТЗДанныеРасчета, ДокументСсылка) Экспорт

	Если ТЗДанныеРасчета.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	КурсДок = ДокументСсылка.Курс;
	КратностьДок = ДокументСсылка.Кратность;
	тчПредоплат = ДокументСсылка.Предоплата;
	Сч = 0;
	ОстатокПерсчета = 0;
	СуммаРегл = 0;
	СуммаНДСРегл = 0;
	
	Для Каждого СтрокаПредоплаты Из тчПредоплат Цикл
		
		СуммаПредоплатыВал = СтрокаПредоплаты.СуммаРасчетов;
		КурсПредоплаты = СтрокаПредоплаты.Курс;
		КратностьПредоплаты = СтрокаПредоплаты.Кратность;
		
		СтрокаТоваров = ТЗДанныеРасчета[Сч];
		СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТоваров.СтавкаНДС);
		
		Пока СуммаПредоплатыВал <> 0 Цикл
			
			
			Если Сч > ТЗДанныеРасчета.Количество() - 1 Тогда 
				СуммаРегл = СуммаРегл + ОстатокПерсчета * КурсДок * КратностьДок;
				СуммаНДСРегл = СуммаНДСРегл + ?(ДокументСсылка.СуммаВключаетНДС, 
									  СуммаРегл - (СуммаРегл) / ((СтавкаНДС + 100) / 100),
									  СуммаРегл * СтавкаНДС / 100);
				СуммаПредоплатыВал = СуммаПредоплатыВал - СтрокаТоваров.Сумма;
				СтрокаТоваров.СуммаРегл = СуммаРегл;
				СтрокаТоваров.СуммаНДСРегл = СуммаНДСРегл;
				ОстатокПерсчета = 0;
				Прервать;
			КонецЕсли;
			
			СтрокаТоваров = ТЗДанныеРасчета[Сч];
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТоваров.СтавкаНДС);
			
			Если СуммаПредоплатыВал >= СтрокаТоваров.Сумма И ОстатокПерсчета = 0 Тогда 
				СуммаРегл = СуммаРегл + СтрокаТоваров.Сумма * КурсПредоплаты * КратностьПредоплаты;
				СуммаНДСРегл = СуммаНДСРегл + ?(ДокументСсылка.СуммаВключаетНДС, 
									  СуммаРегл - (СуммаРегл) / ((СтавкаНДС + 100) / 100),
									  СуммаРегл * СтавкаНДС / 100);
				СуммаПредоплатыВал = СуммаПредоплатыВал - СтрокаТоваров.Сумма;
				СтрокаТоваров.СуммаРегл = СуммаРегл;
				СтрокаТоваров.СуммаНДСРегл = СуммаНДСРегл;
				Сч = Сч + 1;
			ИначеЕсли СуммаПредоплатыВал >= ОстатокПерсчета И ОстатокПерсчета <> 0 Тогда 
				СуммаРегл = СуммаРегл + (ОстатокПерсчета * КурсПредоплаты * КратностьПредоплаты);
				СуммаНДСРегл = СуммаНДСРегл + ?(ДокументСсылка.СуммаВключаетНДС, 
									  СуммаРегл - (СуммаРегл) / ((СтавкаНДС + 100) / 100),
									  СуммаРегл * СтавкаНДС / 100);
				СуммаПредоплатыВал = СуммаПредоплатыВал - ОстатокПерсчета;
				СтрокаТоваров.СуммаРегл = СуммаРегл;
				СтрокаТоваров.СуммаНДСРегл = СуммаНДСРегл;
				ОстатокПерсчета = 0;
				Сч = Сч + 1;
			ИначеЕсли СуммаПредоплатыВал < ОстатокПерсчета И ОстатокПерсчета <> 0 Тогда 
				СуммаРегл = СуммаРегл + (СуммаПредоплатыВал * КурсПредоплаты * КратностьПредоплаты);
				СуммаНДСРегл = ?(ДокументСсылка.СуммаВключаетНДС, 
									  СуммаРегл - (СуммаРегл) / ((СтавкаНДС + 100) / 100),
									  СуммаРегл * СтавкаНДС / 100);
				ОстатокПерсчета = ОстатокПерсчета - СуммаПредоплатыВал;
				СуммаПредоплатыВал = 0;
			Иначе
				СуммаРегл = СуммаПредоплатыВал * КурсПредоплаты * КратностьПредоплаты;
				СуммаНДСРегл = ?(ДокументСсылка.СуммаВключаетНДС, 
									  СуммаРегл - (СуммаРегл) / ((СтавкаНДС + 100) / 100),
									  СуммаРегл * СтавкаНДС / 100);
				ОстатокПерсчета = СтрокаТоваров.Сумма - СуммаПредоплатыВал;
				СуммаПредоплатыВал = 0;
			КонецЕсли;
			
							
		КонецЦикла;
		
		
	КонецЦикла;
	
	Если ОстатокПерсчета <> 0 Тогда 
		СуммаРегл = СуммаРегл + (ОстатокПерсчета * КурсДок * КратностьДок);
		СуммаНДСРегл = СуммаНДСРегл + ?(ДокументСсылка.СуммаВключаетНДС, 
									  СуммаРегл - (СуммаРегл) / ((СтавкаНДС + 100) / 100),
									  СуммаРегл * СтавкаНДС / 100);
		СтрокаТоваров.СуммаРегл = СуммаРегл;
		СтрокаТоваров.СуммаНДСРегл = СуммаНДСРегл;
	КонецЕсли;

КонецПроцедуры
