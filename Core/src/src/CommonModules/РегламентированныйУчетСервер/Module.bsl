Функция ПолучитьСчетаКосвенныхПроизводственныхЗатрат() Экспорт

	НаборДвижений = РегистрыСведений.СчетаКосвенныхПроизводственныхЗатрат.СоздатьНаборЗаписей();
	НаборДвижений.Прочитать();
	Возврат НаборДвижений.ВыгрузитьКолонку("СчетУчетаРегл");

КонецФункции

Функция СчетЯвляетсяКосвенныйПоПроизводственнымЗатратам(Счет) Экспорт

	МассивСчетов = РегламентированныйУчетСервер.ПолучитьСчетаКосвенныхПроизводственныхЗатрат();
	
	Коственный = Ложь;
	
	Для Каждого СтрМас Из МассивСчетов Цикл
		Если СтрМас = Счет Тогда
			Коственный = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Коственный;

КонецФункции // СчетЯвляетсяРасходным()

Функция ПолучитьСтруктуруОтраженияКурсовыхРазниц() Экспорт
	
	СчетаКурсовыхРазниц = Новый Структура;
	СчетаКурсовыхРазниц.Вставить("СчетПоложительнаяКурсоваяРазницаДеньги", );
	СчетаКурсовыхРазниц.Вставить("СчетОтрицательнаяКурсоваяРазницаДеньги", );
	СчетаКурсовыхРазниц.Вставить("СчетПоложительнаяКурсоваяРазницаЗадолженность", );
	СчетаКурсовыхРазниц.Вставить("СчетОтрицательнаяКурсоваяРазницаЗадолженность", );
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УчетнаяПолитикаРеглСрезПоследних.СчетПоложительнаяКурсоваяРазницаДеньги,
		|	УчетнаяПолитикаРеглСрезПоследних.СчетОтрицательнаяКурсоваяРазницаДеньги,
		|	УчетнаяПолитикаРеглСрезПоследних.СчетПоложительнаяКурсоваяРазницаЗадолженность,
		|	УчетнаяПолитикаРеглСрезПоследних.СчетОтрицательнаяКурсоваяРазницаЗадолженность
		|ИЗ
		|	РегистрСведений.УчетнаяПолитикаРегл.СрезПоследних КАК УчетнаяПолитикаРеглСрезПоследних";
	                                                                      
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		СчетаКурсовыхРазниц.СчетПоложительнаяКурсоваяРазницаДеньги = ВыборкаДетальныеЗаписи.СчетПоложительнаяКурсоваяРазницаДеньги;
		СчетаКурсовыхРазниц.СчетОтрицательнаяКурсоваяРазницаДеньги = ВыборкаДетальныеЗаписи.СчетОтрицательнаяКурсоваяРазницаДеньги;
		СчетаКурсовыхРазниц.СчетПоложительнаяКурсоваяРазницаЗадолженность = ВыборкаДетальныеЗаписи.СчетПоложительнаяКурсоваяРазницаЗадолженность;
		СчетаКурсовыхРазниц.СчетОтрицательнаяКурсоваяРазницаЗадолженность = ВыборкаДетальныеЗаписи.СчетОтрицательнаяКурсоваяРазницаЗадолженность;
		
	КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	НеПереоцениватьСчета.СчетУчета
	               |ИЗ
	               |	РегистрСведений.НеПереоцениватьСчета КАК НеПереоцениватьСчета";
	
	МассивСчетов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("СчетУчета");
	
	Результат = Новый Структура;
	Результат.Вставить("СчетаКурсовыхРазниц", СчетаКурсовыхРазниц);
	Результат.Вставить("НеПереоцениватьСчета", МассивСчетов);

	Возврат Результат;
	
КонецФункции // ()

