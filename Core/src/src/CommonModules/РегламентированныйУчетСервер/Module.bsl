				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаРасчетов);
				
			КонецЕсли; 
			
			Движение.Сумма  = (Выборка.Сумма - Выборка.СуммаНДС) * (-1);
			
						
			////////////////////////
			//Сторнирование НДС
			Если Выборка.СуммаНДС <> 0 Тогда
				
				
				Движение = Движения.Хозрасчетный.Добавить();
				Движение.Период = Период;
				Движение.Организация = Организация;
				Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.СторнированиеПоставки);
				
				Движение.СчетДт = СчетУчетаНДСРегл;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СчетФактураПоставщика", НайденныйСчетФактура);
				

				Движение.СчетКт = СчетУчетаРасчетовСПоставщикамиРегл;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", Контрагент);	
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", Договор);
				
				Если Движение.СчетКт.Валютный Тогда
				
					Движение.ВалютаКт = Выборка.ВалютаРасчетов;
					Движение.ВалютнаяСуммаКт = Выборка.СуммаНДСВал;
					БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаРасчетов);
					
				КонецЕсли;
				
				Движение.Сумма  = Выборка.СуммаНДС * (-1); 
				
			КонецЕсли; 
			
		КонецЦикла;
		
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратИзПереработки Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратКомитенту Тогда		
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратСОтветхранения Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаВПереработку Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаНаКомиссию Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПередачаНаОтветхранение Тогда
	КонецЕсли;

	
КонецПроцедуры

Процедура ОтразитьДвиженияДокументаПоступлениеНаСчет(ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	Если Отказ Тогда
		
		Возврат;
		
	КонецЕсли; 
	
	Движения.Хозрасчетный.Записывать = Истина;
	
	СчетУчетаРасчетовСПокупателемРегл 	= ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент.СчетУчетаРасчетовСПокупателемРегл;
	СчетУчетаБанковскогоСчетаРегл	 	= ДополнительныеСвойства.ДляПроведения.Ссылка.БанковскийСчет.СчетУчетаРегл;
	//СчетУчетаРасчетовСПоставщикамиРегл= ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент.СчетУчетаРасчетовСПоставщикомРегл;
	СчетУчетаАвансовПокупателяРегл    	= ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент.СчетУчетаАвансовПокупателяРегл;
	//СчетУчетаНДСВозмещенияРегл        = ?(ЗначениеЗаполнено(ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС), ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС.СчетУчетаКВозмещениюРегл, ПланыСчетов.Хозрасчетный.НалоговыеОбязательства);
	//СчетУчетаНДСРегл                  = ?(ЗначениеЗаполнено(ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС), ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС.СчетУчетаРегл, ПланыСчетов.Хозрасчетный.НДС);
	
	Если Не ЗначениеЗаполнено(СчетУчетаБанковскогоСчетаРегл) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Не указан счет учета банковского счета (регл). Документ проведен не будет!';ru='Не указан счет учета банковского счета (регл). Документ проведен не будет!';en='Unknown by taking into account a bank account (Regla). The document will not be held!'"));
		
	КонецЕсли;
	
		
	Период               = ДополнительныеСвойства.ДляПроведения.Дата;
	Организация          = ДополнительныеСвойства.ДляПроведения.Организация;
	Контрагент           = ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент;
	СтатьяДДС            = ДополнительныеСвойства.ДляПроведения.Ссылка.Статья;
	ВидОперации          = ДополнительныеСвойства.ДляПроведения.Ссылка.ВидОперации;
	КорреспонденцияРегл  = ДополнительныеСвойства.ДляПроведения.Ссылка.КорреспонденцияРегл;
	
	НайденныйСчетФактура = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйСчетФактуру(ДополнительныеСвойства.ДляПроведения.Ссылка, Истина);
	
	Если ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПокупателя Тогда 
		
		Если Не ЗначениеЗаполнено(СчетУчетаРасчетовСПокупателемРегл) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Не указан счет учета расчетов с покупателем. Документ проведен не будет!';ru='Не указан счет учета расчетов с покупателем. Документ проведен не будет!';en='Unknown by the account of calculations with the buyer. The document will not be held!'"));
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СчетУчетаАвансовПокупателяРегл) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Не указан счет учета авансов с покупателем. Документ проведен не будет!';ru='Не указан счет учета авансов с покупателем. Документ проведен не будет!';en='Unknown by taking into account advances to the buyer. The document will not be held!'"));
			
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасчетыСПокупателями.БанковскийСчет,
		|	РасчетыСПокупателями.Валюта,
		|	РасчетыСПокупателями.ВалютаДенежныхСредств,
		|	РасчетыСПокупателями.Договор,
		|	РасчетыСПокупателями.ТипРасчетов,
		|	РасчетыСПокупателями.СуммаВал,
		|	РасчетыСПокупателями.Сумма
		|ИЗ
		|	ВременнаяТаблицаРасчетыСПокупателями КАК РасчетыСПокупателями";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.ТипРасчетов = Перечисления.ТипыРасчетов.Аванс Тогда  		
				///////////////////
				// Возникновение аванса покупателя
				Движение = Движения.Хозрасчетный.Добавить();
				Движение.Период = Период;
				Движение.Организация = Организация;
				Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ВозникновениеАвансаПокупателя);
								
				Движение.СчетДт = СчетУчетаБанковскогоСчетаРегл;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "БанковскиеСчета", Выборка.БанковскийСчет);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СтатьиДвиженияДенежныхСредств", СтатьяДДС);
				
				Если Движение.СчетДт.Валютный Тогда
					
					Движение.ВалютаДт = Выборка.Валюта;
					Движение.ВалютнаяСуммаДт = Выборка.СуммаВал;
					БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Валюты", Выборка.ВалютаДенежныхСредств);
					
				КонецЕсли;
				
				
				Движение.СчетКт = СчетУчетаАвансовПокупателяРегл;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", Контрагент);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", Выборка.Договор);
				
				Если Движение.СчетКт.Валютный Тогда
					
					Движение.ВалютаКт = Выборка.Валюта;
					Движение.ВалютнаяСуммаКт = Выборка.СуммаВал;
					БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаДенежныхСредств);
					
				КонецЕсли;
				
				Движение.Сумма  = Выборка.Сумма;
				
			ИначеЕсли Выборка.ТипРасчетов = Перечисления.ТипыРасчетов.Долг Тогда
				///////////////////
				// Погашение обязательств покупателя
				Движение = Движения.Хозрасчетный.Добавить();
				Движение.Период = Период;
				Движение.Организация = Организация;
				Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ПогашениеОбязательствПокупателя);
								
				Движение.СчетДт = СчетУчетаБанковскогоСчетаРегл;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "БанковскиеСчета", Выборка.БанковскийСчет);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СтатьиДвиженияДенежныхСредств", СтатьяДДС);
				
				Если Движение.СчетДт.Валютный Тогда
					
					Движение.ВалютаДт = Выборка.Валюта;
					Движение.ВалютнаяСуммаДт = Выборка.СуммаВал;
					БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Валюты", Выборка.ВалютаДенежныхСредств);
					
				КонецЕсли;
				
				
				Движение.СчетКт = СчетУчетаРасчетовСПокупателемРегл;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", Контрагент);
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", Выборка.Договор);
				
				Если Движение.СчетКт.Валютный Тогда
					
					Движение.ВалютаКт = Выборка.Валюта;
					Движение.ВалютнаяСуммаКт = Выборка.СуммаВал;
					БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаДенежныхСредств);
					
				КонецЕсли;
				
				Движение.Сумма  = Выборка.Сумма;
				
			КонецЕсли;
			
		КонецЦикла;
					
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ВзносНаличными Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником Тогда
		
		СчетУчетаАвансовПокупателяРегл  = ДополнительныеСвойства.ДляПроведения.Ссылка.ДоговорКредитаЗайма.СчетУчетаРегл;
		Договор  = ДополнительныеСвойства.ДляПроведения.Ссылка.ДоговорДляЗачетаАвансаСПомощником;
		
		Если Не ЗначениеЗаполнено(СчетУчетаБанковскогоСчетаРегл) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Не указан счет учета основного долга (регл) в договоре кредита. Документ проведен не будет!';ru='Не указан счет учета основного долга (регл) в договоре кредита. Документ проведен не будет!';en='Unknown by taking into account the principal debt (Regla) in the agreement the loan. The document will not be held!'"));
			
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасчетыПоКредитамИЗаймам.БанковскийСчет,
		|	РасчетыПоКредитамИЗаймам.Валюта,
		|	РасчетыПоКредитамИЗаймам.ВалютаДенежныхСредств,
		|	РасчетыПоКредитамИЗаймам.Сумма,
		|	РасчетыПоКредитамИЗаймам.СуммаПлатежа
		|ИЗ
		|	ВременнаяТаблицаРасчетыПоКредитамИЗаймам КАК РасчетыПоКредитамИЗаймам";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			
			///////////////////
			// Оплата основного долга по займу
			Движение = Движения.Хозрасчетный.Добавить();
			Движение.Период = Период;
			Движение.Организация = Организация;
			Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ОплатаОсновногоДолгаПоЗайму);
			
			Движение.СчетДт = СчетУчетаБанковскогоСчетаРегл;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "БанковскиеСчета", Выборка.БанковскийСчет);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СтатьиДвиженияДенежныхСредств", СтатьяДДС);
			
			Если Движение.СчетДт.Валютный Тогда
				
				Движение.ВалютаДт = Выборка.ВалютаДенежныхСредств;
				Движение.ВалютнаяСуммаДт = Выборка.СуммаПлатежа;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Валюты", Выборка.ВалютаДенежныхСредств);
				
			КонецЕсли;
			
			
			Движение.СчетКт = СчетУчетаАвансовПокупателяРегл;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Контрагенты", Контрагент);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Договоры", Договор);
			
			Если Движение.СчетКт.Валютный Тогда
				
				Движение.ВалютаКт = Выборка.ВалютаДенежныхСредств;
				Движение.ВалютнаяСуммаКт = Выборка.СуммаПлатежа;
				БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Валюты", Выборка.ВалютаДенежныхСредств);
				
			КонецЕсли;
			
			Движение.Сумма  = Выборка.Сумма;
			
			
		КонецЦикла;
		
		
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Налоги Тогда
		
		КоррСчет = ПланыСчетов.Хозрасчетный.НДС;
		 
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасшифровкаПлатежа.БанковскийСчет,
		|	РасшифровкаПлатежа.ВалютаДенежныхСредств,
		|	РасшифровкаПлатежа.СуммаПлатежа,
		|	РасшифровкаПлатежа.СуммаРасчетов
		|ИЗ
		|	ВременнаяТаблицаРасшифровкаПлатежа КАК РасшифровкаПлатежа";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			
			
			///////////////////
			// Возврат налога
			Движение = Движения.Хозрасчетный.Добавить();
			Движение.Период = Период;
			Движение.Организация = Организация;
			Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ВозвратНалога);
			
			Движение.СчетДт = СчетУчетаБанковскогоСчетаРегл;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "БанковскиеСчета", Выборка.БанковскийСчет);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "СтатьиДвиженияДенежныхСредств", СтатьяДДС);
			
			Если Движение.СчетДт.Валютный Тогда
				
