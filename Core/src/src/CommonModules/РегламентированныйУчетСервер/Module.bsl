Процедура ОтразитьДвиженияДокументаРасходнаяНакладная(ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	Если Отказ Тогда
		
		Возврат;
		
	КонецЕсли; 
	
	Движения.Хозрасчетный.Записывать = Истина;
	
	СчетУчетаРасчетовСПокупателемРегл = ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент.СчетУчетаРасчетовСПокупателемРегл;
	СчетУчетаРасчетовСПоставщикамиРегл= ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент.СчетУчетаРасчетовСПоставщикомРегл;
	СчетУчетаАвансовПокупателяРегл    = ДополнительныеСвойства.ДляПроведения.Ссылка.Контрагент.СчетУчетаАвансовПокупателяРегл;
	СчетУчетаНДСВозмещенияРегл        = ?(ЗначениеЗаполнено(ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС), ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС.СчетУчетаКВозмещениюРегл, ПланыСчетов.Хозрасчетный.НалоговыеОбязательства);
	СчетУчетаНДСРегл                  = ?(ЗначениеЗаполнено(ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС), ДополнительныеСвойства.ДляПроведения.Ссылка.ВидНалогаНДС.СчетУчетаРегл, ПланыСчетов.Хозрасчетный.НДС);
	
	Если Не ЗначениеЗаполнено(СчетУчетаРасчетовСПокупателемРегл) Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Не указан счет учета расчетов с покупателем. Документ проведен не будет!';ru='Не указан счет учета расчетов с покупателем. Документ проведен не будет!';en='Unknown by the account of calculations with the buyer. The document will not be held!'"));
		
