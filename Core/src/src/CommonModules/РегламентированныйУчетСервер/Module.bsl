		//|	Запасы.Номенклатура КАК НоменклатураОтправитель,
		//|	Запасы.КоррНоменклатура КАК НоменклатураПолучатель,
		//|	Запасы.Номенклатура.СчетУчетаЗапасовРегл КАК СчетУчетаЗапасовОтправитель,
		//|	Запасы.КоррНоменклатура.СчетУчетаЗапасовРегл КАК СчетУчетаЗапасовПолучатель,
		//|	Запасы.Количество,
		//|	Запасы.Сумма
		//|ИЗ
		//|	ВременнаяТаблицаЗапасы КАК Запасы
		//|;
		//|
		//|////////////////////////////////////////////////////////////////////////////////
		//|ВЫБРАТЬ
		//|	ТаблЗапасы.Номенклатура,
		//|	ТаблЗапасы.КоррНоменклатура,
		//|	ТаблЗапасы.СтруктурнаяЕдиница,
		//|	ТаблЗапасы.КоррСтруктурнаяЕдиница,
		//|	СУММА(ТаблЗапасы.Количество) КАК Количество,
		//|	СУММА(ТаблЗапасы.Сумма) КАК Сумма
		//|ИЗ
		//|	&ТаблЗапасы КАК ТаблЗапасы
		//|
		//|СГРУППИРОВАТЬ ПО
		//|	ТаблЗапасы.КоррСтруктурнаяЕдиница,
		//|	ТаблЗапасы.Номенклатура,
		//|	ТаблЗапасы.КоррНоменклатура,
		//|	ТаблЗапасы.СтруктурнаяЕдиница";
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл 
			
			Если НЕ ЗначениеЗаполнено(Выборка.НоменклатураОтправитель.СчетУчетаЗапасовРегл) Тогда
				СтрокаСообщения = НСтр("ka='Не заполнен счет учета запасов для номенклатуры %1';ru='Не заполнен счет учета запасов для номенклатуры %1';en='Not filled by inventory for the range of 1%'");
				СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%1", Выборка.НоменклатураОтправитель);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаСообщения);
				Отказ = Истина;
				Продолжить;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Выборка.НоменклатураПолучатель.СчетУчетаЗапасовРегл) Тогда
				СтрокаСообщения = НСтр("ka='Не заполнен счет учета запасов для номенклатуры %1';ru='Не заполнен счет учета запасов для номенклатуры %1';en='Not filled by inventory for the range of 1%'");
				СтрокаСообщения = СтрЗаменить(СтрокаСообщения, "%1", Выборка.НоменклатураПолучатель);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрокаСообщения);
				Отказ = Истина;
				Продолжить;
			КонецЕсли;
			
			
			Движение = Движения.Хозрасчетный.Добавить();
			Движение.Период = Период;
			Движение.Организация = Организация;
			Движение.Содержание  = Строка(Перечисления.СодержанияРеглОпераций.ПеремещениеЗапасов);
			
			Движение.КоличествоДт = Выборка.Количество;
			
			Движение.СчетДт = Выборка.НоменклатураПолучатель.СчетУчетаЗапасовРегл;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Склады", Выборка.СЕ_Получатель);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетДт, Движение.СубконтоДт, "Номенклатура", Выборка.НоменклатураПолучатель);
			
					
			Движение.КоличествоКт = Выборка.Количество;
			
			Движение.СчетКт = Выборка.НоменклатураОтправитель.СчетУчетаЗапасовРегл;
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Склады", Выборка.СЕ_Отправитель);
			БухгалтерскийУчет.УстановитьСубконто(Движение.СчетКт, Движение.СубконтоКт, "Номенклатура", Выборка.НоменклатураОтправитель);
			
			Движение.Сумма  = Выборка.Сумма;
			
		КонецЦикла;
				
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.ВозвратИзЭксплуатации Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.ПередачаВЭксплуатацию Тогда
	ИначеЕсли ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.СписаниеНаРасходы Тогда
	КонецЕсли;
	
КонецПроцедуры

