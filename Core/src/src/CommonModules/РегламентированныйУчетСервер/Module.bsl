Процедура ПерезаполнитьСчетаРегУчетаЗапасов(ДополнительныеСвойства, Движения, Отказ) Экспорт

	ТаблицаЗапасы = ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЗапасы;
	
	Если Отказ
	 ИЛИ ТаблицаЗапасы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	НаборДвижений = РегистрыСведений.СчетаКосвенныхПроизводственныхЗатрат.СоздатьНаборЗаписей();
	НаборДвижений.Прочитать();
	ТзСчетов = НаборДвижений.Выгрузить();//Колонку("СчетУчетаРегл");
	
	Для Каждого Строк Из ТаблицаЗапасы Цикл 
		СтруктураПоиска = Новый Структура("СчетУчетаРегл", Строк.СчетУчетаРегл);
		МассСтрок = ТзСчетов.НайтиСтроки(СтруктураПоиска);
		Если МассСтрок.Количество() = 0 Тогда 
			Строк.СчетУчетаРегл = ПланыСчетов.Хозрасчетный.ПустаяСсылка();
		Иначе
			Продолжить;
		КонецЕсли;
	КонецЦикла;
	
	ДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаЗапасы = ТаблицаЗапасы;	

