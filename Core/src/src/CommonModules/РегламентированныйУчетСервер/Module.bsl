Функция ПолучитьЭлементНаФорме(Форма, ПутьКДаннымЭлемнта)

	ВозвращаемыЭлемент = Форма;
	
	СтркаРазбора = ПутьКДаннымЭлемнта;
	ПоискТочки = СтрНайти(СтркаРазбора, ".");
	
	ПодстркаПути = "";
	Пока ПоискТочки <> 0 Цикл 
		
		ПодстркаПути = Сред(СтркаРазбора, 1, ПоискТочки - 1);
		СтркаРазбора = Сред(СтркаРазбора, ПоискТочки + 1);
		
		ПоискТочки = СтрНайти(СтркаРазбора, ".");
		Попытка
			ВозвращаемыЭлемент = ВозвращаемыЭлемент[ПодстркаПути];
		Исключение
			ВозвращаемыЭлемент = Неопределено;
			Прервать;
		КонецПопытки;
	КонецЦикла;
	
	Если ВозвращаемыЭлемент <> Неопределено Тогда 
		Если ТипЗнч(ВозвращаемыЭлемент) = Тип("ДанныеФормыКоллекция") Тогда
			Если ВозвращаемыЭлемент.Количество() > 0 Тогда
				тзКоллекции = ВозвращаемыЭлемент.Выгрузить();
				Если ВозвращаемыЭлемент.Выгрузить().Колонки.Найти(СтркаРазбора) <> Неопределено Тогда 
					ВозвращаемыЭлемент = ВозвращаемыЭлемент.Выгрузить().Колонки[СтркаРазбора].ТипЗначения.Типы()
				Иначе 
					ВозвращаемыЭлемент = Неопределено;
				КонецЕсли;
			КонецЕсли;
		Иначе
			Попытка
				ВозвращаемыЭлемент = ВозвращаемыЭлемент[СтркаРазбора];
			Исключение
				ВозвращаемыЭлемент = Неопределено;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВозвращаемыЭлемент;

КонецФункции // ПолучитьЭлементНаФорме(Форма, ПутьКДаннымЭлемнта)()

