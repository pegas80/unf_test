			Если СтрНайти(Элемент.Имя, "НачисленияУдержания") <> 0 Тогда 
				а=1;
			КонецЕсли;
			
			ПутьКДаннымЭлемнта = Элемент.ПутьКДанным;
			ЭлементФормы = ПолучитьЭлементНаФорме(Форма, ПутьКДаннымЭлемнта);
