Функция GetJiraProjects() Экспорт
	
	Ответ = ВыполнитьHTTPЗапрос8();
	Если Ответ.ОщибкаСоединения Или Ответ.ОщибкаКодСостояния Тогда
		Ответ.Вставить("ДопИнфо", Неопределено);
		Возврат Ответ;
	КонецЕсли;
	 
	JsonDataJiraProjects = JSON2Текст2(Ответ.Текст);
	ArrayOfResults = JsonDataJiraProjects["values"];
	
	Пока Не JsonDataJiraProjects["isLast"] Цикл
		next = JsonDataJiraProjects["nextPage"];
		next = СтрЗаменить(next, "https://azrystudio.jira.com", "");
		Ответ = ВыполнитьHTTPЗапрос8(next);
		JsonDataJiraProjects = JSON2Текст2(Ответ.Текст);
		ArrayOfResults = ДобавитьЭлементыМассиваВМассив(ArrayOfResults, JsonDataJiraProjects["values"]);
	КонецЦикла;
	
	Ответ2 = ЗаполнитьТаблицуJiraProjects(ArrayOfResults);	
	Ответ.Вставить("ДопИнфо", Ответ2.ДопИнфо);            
	
	Возврат Ответ;
	
КонецФункции

