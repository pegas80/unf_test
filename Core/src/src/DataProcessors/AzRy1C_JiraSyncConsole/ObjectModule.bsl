Функция ДопИнфоWorklogs(ТЗ)

	Парам = Новый Структура("КоличествоНовыеСотрудники, КоличествоНовыеЗаданиеНаРаботу, WorklogsКолИзмененыеДлительностьВЧасах, UniqueAccountsList", 0, 0, 0, Новый СписокЗначений);
	
	Список = Новый СписокЗначений;
	Для каждого ТекСтрока Из ТЗ Цикл
		Если ТекСтрока.НовыйСотрудник И Список.НайтиПоЗначению(ТекСтрока.wr_user_account_id) = Неопределено Тогда
			Список.Добавить(ТекСтрока.wr_user_account_id);
			Парам.КоличествоНовыеСотрудники = Парам.КоличествоНовыеСотрудники  + 1;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекСтрока.ЗаданиеНаРаботу) Тогда
			Парам.КоличествоНовыеЗаданиеНаРаботу = Парам.КоличествоНовыеЗаданиеНаРаботу  + 1;
		КонецЕсли;
		
		Если ТекСтрока.wr_hours <> ТекСтрока.ДлительностьВЧасах Тогда
			Парам.WorklogsКолИзмененыеДлительностьВЧасах = Парам.WorklogsКолИзмененыеДлительностьВЧасах  + 1;	
		КонецЕсли;
		
		Если Парам.UniqueAccountsList.НайтиПоЗначению(ТекСтрока.wr_account) = Неопределено Тогда
			Парам.UniqueAccountsList.Добавить(ТекСтрока.wr_account);	
		КонецЕсли;		
	КонецЦикла;
	
	Возврат Парам;

КонецФункции

Функция ЗаданияНаРаботу() Экспорт 

	Парам = Новый Структура("Дата, Сотрудник, Проект, AzRyJiraSelectVersion");
	Для каждого ТекСтрока Из Worklogs Цикл
		Парам.Дата = Дата(СтрЗаменить(ТекСтрока.wr_date, "-", ""));
		Если ЗначениеЗаполнено(Сотрудник) Тогда			
			Если Сотрудник = ТекСтрока.Сотрудник Тогда
				СоздатьЗаданияНаРаботу(ТекСтрока); 			
			КонецЕсли;
		Иначе 
			СоздатьЗаданияНаРаботу(ТекСтрока); 
		КонецЕсли; 		
	КонецЦикла;

