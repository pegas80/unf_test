Функция ОбновитьТаблицуWorklogs() Экспорт 

	ПроектыСПустымиЗаказ.Очистить();
	Worklogs.Очистить();
	
	мЗаданияНаРаботу = Новый ТаблицаЗначений;
	
	Ответ = ВыполнитьHTTPЗапрос3();
	Если Ответ.ОщибкаСоединения Или Ответ.ОщибкаКодСостояния Тогда
		Ответ.Вставить("ДопИнфо", Неопределено);
		Возврат Ответ;
	КонецЕсли;
	 
	JsonDataWorklogs = JSON2Текст(Ответ.Текст);
	ArrayOfResults = JsonDataWorklogs.results;
	
	Пока JsonDataWorklogs.metadata.Свойство("next") Цикл
		next = JsonDataWorklogs.metadata.next;
		next = СтрЗаменить(next, "https://api.tempo.io", "");
		Ответ = ВыполнитьHTTPЗапрос3(next);
		JsonDataWorklogs = JSON2Текст(Ответ.Текст);
		ArrayOfResults = ДобавитьЭлементыМассиваВМассив(ArrayOfResults, JsonDataWorklogs.results);
	КонецЦикла;
	
	Если ArrayOfResults.Количество() > 0 Тогда
		ОбновитьТЗСотрудники(ArrayOfResults);
		ОбновитьТЗПроекты(ArrayOfResults);
		ОбновитьТЗJiraProjects();
	КонецЕсли; 
	
	// პირველი შევსება
	Н = 0;
	Для каждого ТекСтрока Из ArrayOfResults Цикл
		Н = Н + 1;	
		// Debug
		//Если Не ТекСтрока.wr_user_name = "George Mamulashvili" Тогда
		//	Продолжить;	
		//КонецЕсли; 
		
		//Если Н = 10 Тогда		
		//	Прервать;	
		//КонецЕсли; 
		
		НоваяСтрока = Worklogs.Добавить();
		НоваяСтрока.wr_account = ТекСтрока.attributes.values[0].value;
		НоваяСтрока.wr_date    = ТекСтрока.startDate;
		НоваяСтрока.wr_hours   = ТекСтрока.billableSeconds / 60 / 60;
		НоваяСтрока.wr_last_update_time = ТекСтрока.updatedAt;
		НоваяСтрока.wr_user_account_id  = ТекСтрока.author.accountId;
		НоваяСтрока.tempoWorklogId      = ТекСтрока.tempoWorklogId;
		НоваяСтрока.wr_issue_id         = СтрЗаменить(ТекСтрока.issue.id, " ", "");
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		
		// თანამშრომლის მოძიება
		НайдСтрока = мТЗСотрудники.Найти(СокрЛП(ТекСтрока.author.accountId), "UserAccountId");
		Если НайдСтрока = Неопределено Тогда
			НоваяСтрока.НовыйСотрудник = Истина;
			Ответ2 = ВыполнитьHTTPЗапрос6(СокрЛП(ТекСтрока.author.accountId));
			authorДанные = JSON2ТекстВСтруктуру(Ответ2.Текст);
			НоваяСтрока.wr_user_name = authorДанные.displayName;
		Иначе 
			НоваяСтрока.НовыйСотрудник = Ложь;
			НоваяСтрока.Сотрудник      = НайдСтрока.Ссылка; 
		КонецЕсли;
		
		// პროექტის მოძიება
		НайдСтрока = мТЗПроекты.Найти(СокрЛП(ТекСтрока.attributes.values[0].value), "AzRyTempoObjectKey");
		Если НайдСтрока = Неопределено Тогда
			НоваяСтрока.НовыйПроект = Истина;
		Иначе 
			НоваяСтрока.НовыйПроект = Ложь;
			НоваяСтрока.Проект      = НайдСтрока.Ссылка; 
		КонецЕсли;		
		
	КонецЦикла;
	
	Если Worklogs.Количество() > 0 Тогда
		ОбновитьЗаданияНаРаботу2(Worklogs.ВыгрузитьКолонку("tempoWorklogId"));
		//ОбновитьТЗJiraProjects(Worklogs.ВыгрузитьКолонку("wr_issue_id"));
	КонецЕсли;  
			
	// მეორე შევსება
	Если мЗаданияНаРаботу.Количество() > 0 Тогда
		Для каждого ТекСтрока Из Worklogs Цикл
			
			Отбор = Новый Структура();
			Отбор.Вставить("tempoWorklogId", ТекСтрока.tempoWorklogId);
			
			Строки = мЗаданияНаРаботу.НайтиСтроки(Отбор);
			Если Строки.Количество() > 0 Тогда
				ТекСтрока.ЗаданиеНаРаботу    = Строки[0].ЗаданиеНаРаботу;
				ТекСтрока.ДлительностьВЧасах = Строки[0].ЗаданиеНаРаботу.Работы[0].Трудоемкость;
				ТекСтрока.JiraProject        = Строки[0].JiraProject;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	//СоотJiraProjects = Новый Соответствие;
	// Temp	
	Для каждого ТекСтрока Из Worklogs Цикл
		
		Если ЗначениеЗаполнено(ТекСтрока.JiraProject) Тогда
			Продолжить;				
		КонецЕсли;
		
		Ответ3 = ВыполнитьHTTPЗапрос7(ТекСтрока.wr_issue_id);
		Если Ответ3.ОщибкаСоединения Тогда
			Ответ.Вставить("ДопИнфо", Неопределено);
			Возврат Ответ;
		КонецЕсли;
		Если Ответ3.ОщибкаКодСостояния Тогда
			Продолжить;
		КонецЕсли;		
		JsonDataWorklogs = JSON2Текст2(Ответ3.Текст);
		JiraProjectСоот   = JsonDataWorklogs.Получить("fields").Получить("project");
		ТекСтрока.wr_jiraproject_id = JiraProjectСоот.Получить("id");
		
		// ჯირა პროექტის მოძიება
		НайдСтрока = мJiraProjects.Найти(ТекСтрока.wr_jiraproject_id, "id");
		Если Не НайдСтрока = Неопределено Тогда 
			ТекСтрока.JiraProject = НайдСтрока.Ссылка;	 
		КонецЕсли;
		
		//СоотJiraProjects.Вставить(ТекСтрока.wr_jiraproject_id, JiraProjectСоот);
		
	КонецЦикла;	
	// Temp
	
	
	// ცარიელი შეკვეთების მქონე პროექტების ცხრილის შევსება
	ПроектыСПустымиЗаказ.Очистить();
	Для каждого ТекСтрока Из мТЗПроектыПустые Цикл	
		НоваяСтрока = ПроектыСПустымиЗаказ.Добавить();
		НоваяСтрока.Проект = ТекСтрока.Ссылка;	
	КонецЦикла;
	
	//Worklogs.Сортировать("Сотрудник Возр");
	Ответ.Вставить("ДопИнфо", ДопИнфоWorklogs(Worklogs));
	
	Возврат Ответ;
	
КонецФункции

