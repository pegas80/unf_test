Процедура СоздатьЗаданияНаРаботу(ТекСтрока)
	
	Парам.Сотрудник             = ТекСтрока.Сотрудник;
	Парам.Проект                = ТекСтрока.Проект;
	Парам.AzRyJiraSelectVersion = Число(ТекСтрока.wr_version);
	Если ЗначениеЗаполнено(ТекСтрока.Проект) И Не ЗначениеЗаполнено(ТекСтрока.ЗаданиеНаРаботу) Тогда
		СоздатьДокументЗаданиеНаРаботу(ТекСтрока, Парам);		
	КонецЕсли;	
	
КонецПроцедуры
 
Процедура СоздатьДокументЗаданиеНаРаботу(ТекСтрока, Парам)
	
	// Документ Задание На Работу
	НовыйДокумент = Документы.ЗаданиеНаРаботу.СоздатьДокумент();
	НовыйДокумент.Дата = Парам.Дата;		
	УправлениеНебольшойФирмойСервер.ЗаполнитьШапкуДокумента(НовыйДокумент, Перечисления.ВидыОперацийЗаданиеНаРаботу.Внешнее,Документы.ЗаданиеНаРаботу.ПустаяСсылка(), Неопределено, 0, Новый Структура);
	НовыйДокумент.Организация    = Справочники.Организации.ОсновнаяОрганизация;
	НовыйДокумент.ВидРабот       = Справочники.AzRyНастройки.ЗаданиеНаРаботуВидРабот.Значение;  
	НовыйДокумент.Состояние      = Справочники.СостоянияСобытий.Завершено;
	НовыйДокумент.Сотрудник      = Парам.Сотрудник;
	НовыйДокумент.AzRyПроекты    = Парам.Проект;
	НовыйДокумент.AzRyJiraSelectVersion = Парам.AzRyJiraSelectVersion;
	НовыйДокумент.AzRytempoWorklogId    = ТекСтрока.tempoWorklogId;
	НовыйДокумент.AzRyJiraProject       = ТекСтрока.JiraProject;
	
	// Табличная часть документа
	СгенерироватьТЗДокументаЗаданиеНаРаботу(ТекСтрока, НовыйДокумент, Парам.Проект);
	  
	НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение); 
	
КонецПроцедуры

Процедура СгенерироватьТЗДокументаЗаданиеНаРаботу(ТекСтрока, НовыйДокумент, Проект)
	
	ДТ = Дата(НовыйДокумент.Дата);
	
	НовыйДокумент.Работы.Очистить();
	НоваяСтрока = НовыйДокумент.Работы.Добавить(); 
	
	Если Не Проект.AzRy_ЗаказПокупателя = Документы.ЗаказПокупателя.ПустаяСсылка() Тогда
		НоваяСтрока.Заказчик = Проект.AzRy_ЗаказПокупателя;
		НоваяСтрока.AzRyПроект = Проект;
	Иначе 
		Сообщить("პროექტს: " + Проект + " - ს არ აქვს მითითებული შეკვეთის დოკუმენტი");
		ВызватьИсключение "პროექტს: " + Проект + " - ს არ აქვს მითითებული შეკვეთის დოკუმენტი";
	КонецЕсли;
	
	НоваяСтрока.ВидРабот       = Справочники.AzRyНастройки.ЗаданиеНаРаботуВидРабот.Значение;
	НоваяСтрока.Номенклатура   = НоменклатураIssue; 
	НоваяСтрока.ДатаНачала    = Дата(Год(ДТ),Месяц(ДТ),День(ДТ),10,00,00);
	НоваяСтрока.ДатаОкончания = НоваяСтрока.ДатаНачала + ТекСтрока.wr_hours * 3600;
	//НоваяСтрока.Длительность   = СвормироватьДлительностьВЧасах(ТекСтрока.wr_hours);
	НоваяСтрока.Трудоемкость   = ТекСтрока.wr_hours;	
	//НоваяСтрока.Цена = 0;					
	//НоваяСтрока.Сумма = НоваяСтрока.Трудоемкость * НоваяСтрока.Цена;
				
КонецПроцедуры

