Процедура ОбновитьТЗПроекты(JsonDataWorklogs) Экспорт

	Список_wr_account = Новый Массив;
	Для каждого ТекСтрока Из JsonDataWorklogs Цикл
		Если Список_wr_account.Найти(СокрЛП(ТекСтрока.attributes.values[0].value)) = Неопределено Тогда
			Список_wr_account.Добавить(СокрЛП(ТекСтрока.attributes.values[0].value));
		КонецЕсли; 
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Проекты.AzRyTempoObjectID КАК AzRyTempoObjectID,
		|	Проекты.AzRyTempoObjectType КАК AzRyTempoObjectType,
		|	Проекты.AzRyTempoObjectKey КАК AzRyTempoObjectKey,
		|	Проекты.AzRyTempoObjectName КАК AzRyTempoObjectName,
		|	Проекты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Проекты КАК Проекты
		|ГДЕ
		|	Проекты.ПометкаУдаления = ЛОЖЬ
		|	И Проекты.AzRyTempoObjectKey В(&TempoObjectKey)
		|	И Проекты.AzRyTempoObjectType = &AzRyTempoObjectType
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Проекты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Проекты КАК Проекты
		|ГДЕ
		|	НЕ Проекты.ПометкаУдаления
		|	И Проекты.AzRyTempoObjectKey В(&TempoObjectKey)
		|	И Проекты.AzRyTempoObjectType = &AzRyTempoObjectType
		|	И Проекты.AzRy_ЗаказПокупателя = &AzRy_ЗаказПокупателя";
	
