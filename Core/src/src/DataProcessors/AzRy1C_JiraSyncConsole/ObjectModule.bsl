Функция ЗапросПроекты(TempoObjectTypes)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Проекты.Ссылка,
		|	Проекты.AzRyTempoObjectID,
		|	Проекты.AzRyTempoObjectType
		|ИЗ
		|	Справочник.Проекты КАК Проекты
		|ГДЕ
		|	Проекты.AzRyTempoObjectType В(&AzRyTempoObjectTypes)
		|	И Проекты.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("AzRyTempoObjectTypes", TempoObjectTypes);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ОтборТЗПроекты(ТЗПроектов, TempoObjectID, TempoObjectType)

	Отбор = Новый Структура();
	Отбор.Вставить("AzRyTempoObjectID", TempoObjectID);
	Отбор.Вставить("AzRyTempoObjectType", TempoObjectType);
	
	Строки = ТЗПроектов.НайтиСтроки(Отбор);	
	Если Строки.Количество() > 0 Тогда
		Возврат Строки[0].Ссылка;
	КонецЕсли;	
	
	Возврат Справочники.Проекты.ПустаяСсылка();

КонецФункции

Функция СозданиеСправочникаПроекты(TempoObjectType, TempoObjectID, TempoObjectKey, TempoObjectName, Контрагент, Владелец = Неопределено)
	
	TypeСтрока = ?(TempoObjectType = Перечисления.AzRyTempoObjects.Account_categories, "AC", "A");
	
	Парам = Новый Структура("Ошибка, Текст", Ложь, "");
	Ответ = ПроверкаПередСозданиемСправочникаПроекты2(TempoObjectID, TempoObjectType);
	
	НачатьТранзакцию();
	Попытка
		
		Если ЗначениеЗаполнено(Ответ) Тогда	
				
		Иначе 		
			НовыйПроект = Справочники.Проекты.СоздатьЭлемент();
			НовыйПроект.УстановитьНовыйКод();
			//НовыйПроект.Наименование = TempoObjectKey + " - " + TypeСтрока + " - " + TempoObjectName;
			НовыйПроект.Наименование = НаименованиеПроекта(TempoObjectKey, TempoObjectName);
			НовыйПроект.Контрагент   = Контрагент;
			НовыйПроект.AzRyTempoObjectType = TempoObjectType;
			НовыйПроект.AzRyTempoObjectID   = TempoObjectID;
			НовыйПроект.AzRyTempoObjectKey  = TempoObjectKey;
			НовыйПроект.AzRyTempoObjectName = TempoObjectName;
			НовыйПроект.Родитель = Владелец;
			НовыйПроект.Записать();
		КонецЕсли;	
		
	Исключение
		Парам.Вставить("Ошибка", Истина);
		Парам.Вставить("Текст", "შეცდომა ახალი პროექტის შექმნისას, შეცდომის ტექსტი:" + ОписаниеОшибки());
		ОтменитьТранзакцию();
		
		Возврат Парам;
	КонецПопытки;
	ЗафиксироватьТранзакцию();
			
	Возврат Парам;
	
КонецФункции

