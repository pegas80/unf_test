Процедура ОбновитьЗаданияНаРаботу(JsonDataWorklogs) Экспорт

	СписокДат         = Новый Массив;
	СписокСотрудников = Новый Массив;
	СписокПроекты     = Новый Массив;
	
	Для каждого ТекСтрока Из JsonDataWorklogs Цикл
		Дата = Дата(СтрЗаменить(ТекСтрока.wr_date, "-", ""));
		Если ЗначениеЗаполнено(Дата) И СписокДат.Найти(Дата) = Неопределено Тогда
			СписокДат.Добавить(Дата);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекСтрока.Сотрудник) И СписокСотрудников.Найти(ТекСтрока.Сотрудник) = Неопределено Тогда
			СписокСотрудников.Добавить(ТекСтрока.Сотрудник);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекСтрока.Проект) И СписокПроекты.Найти(ТекСтрока.Проект) = Неопределено Тогда
			СписокПроекты.Добавить(ТекСтрока.Проект);
		КонецЕсли;		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.Ссылка КАК ЗаданиеНаРаботу,
		|	ВложенныйЗапрос.Дата,
		|	ВложенныйЗапрос.Сотрудник,
		|	ВложенныйЗапрос.AzRyПроекты,
		|	ВложенныйЗапрос.AzRyJiraSelectVersion
		|ИЗ
		|	(ВЫБРАТЬ
		|		ЗаданиеНаРаботу.Ссылка КАК Ссылка,
		|		НАЧАЛОПЕРИОДА(ЗаданиеНаРаботу.Дата, ДЕНЬ) КАК Дата,
		|		ЗаданиеНаРаботу.Сотрудник КАК Сотрудник,
		|		ЗаданиеНаРаботу.AzRyПроекты КАК AzRyПроекты,
		|		ЗаданиеНаРаботу.AzRyJiraSelectVersion КАК AzRyJiraSelectVersion
		|	ИЗ
		|		Документ.ЗаданиеНаРаботу КАК ЗаданиеНаРаботу
		|	ГДЕ
		|		ЗаданиеНаРаботу.ПометкаУдаления = ЛОЖЬ
		|		И ЗаданиеНаРаботу.Проведен = ИСТИНА) КАК ВложенныйЗапрос
		|ГДЕ
		|	ВложенныйЗапрос.Дата В(&Дата)
		|	И ВложенныйЗапрос.Сотрудник В(&Сотрудник)
		|	И ВложенныйЗапрос.AzRyПроекты В(&AzRyПроекты)
		|	И ВложенныйЗапрос.AzRyJiraSelectVersion >= &AzRyJiraSelectVersion";
	
	Запрос.УстановитьПараметр("Дата", СписокДат);
	Запрос.УстановитьПараметр("Сотрудник", СписокСотрудников);
	Запрос.УстановитьПараметр("AzRyПроекты", СписокПроекты);
	Запрос.УстановитьПараметр("AzRyJiraSelectVersion", Число(WorklogResource));
	
	мЗаданияНаРаботу = Запрос.Выполнить().Выгрузить();
	
КонецПроцедуры

