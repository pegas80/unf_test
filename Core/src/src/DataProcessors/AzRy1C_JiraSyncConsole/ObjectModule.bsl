Функция getMaxSelectVersion() Экспорт
	
	Ответ = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ЗаданиеНаРаботу.AzRyJiraSelectVersion) КАК JiraSelectVersion
		|ИЗ
		|	Документ.ЗаданиеНаРаботу КАК ЗаданиеНаРаботу
		|ГДЕ
		|	ЗаданиеНаРаботу.Проведен = ИСТИНА
		|	И ЗаданиеНаРаботу.Дата >= &Дата";
	
	Запрос.УстановитьПараметр("Дата", Дата(2021, 1, 1));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ?(ВыборкаДетальныеЗаписи.JiraSelectVersion = Null, 0, ВыборкаДетальныеЗаписи.JiraSelectVersion); 	
	КонецЦикла;
	
	Возврат 0;
	
