Функция ЗаполнитьТаблицуJiraProjects(МассивJiraProjects)
	
	Парам = Новый Структура("КоличествоНовыеJiraProjects, КоличествоИзмененныйJiraProjects", 0, 0);
	
	Ответ = Новый Структура;
	
	JiraProjects.Очистить();
	Для каждого ТекСтрока Из МассивJiraProjects Цикл	
		НоваяСтрока = JiraProjects.Добавить();
		НоваяСтрока.id             = ТекСтрока["id"];
		НоваяСтрока.projectTypeKey = ТекСтрока["projectTypeKey"];	
		НоваяСтрока.name 		   = ТекСтрока["name"];
		НоваяСтрока.key  		   = ТекСтрока["key"];
		НоваяСтрока._description   = ТекСтрока["description"];
		НоваяСтрока.leadId         = ТекСтрока["lead"]["accountId"];
		
		//ТекСтрока.isPrivate = ТекСтрока["isPrivate"];
		//ТекСтрока.style = ТекСтрока["style"];
		//ТекСтрока.id = ТекСтрока["projectCategory"];		
		//"expand"	"description,lead,issueTypes,url,projectKeys,permissions,insight"					
	КонецЦикла;
	
	ОбновитьТЗJiraProjects(JiraProjects.ВыгрузитьКолонку("id"));
	ТЗСотрудникиДляJiraProjects = ТЗСотрудникиДляJiraProjects(JiraProjects.ВыгрузитьКолонку("leadId"));
	
	Для каждого ТекСтрока Из JiraProjects Цикл
		// ჯირა პროექტის მოძიება
		НайдСтрока = мJiraProjects.Найти(ТекСтрока.id, "id");
		Если НайдСтрока = Неопределено Тогда
			ТекСтрока.Новый = Истина;
			Парам.КоличествоНовыеJiraProjects = Парам.КоличествоНовыеJiraProjects + 1;
		Иначе 
			ТекСтрока.Новый = Ложь;
			ТекСтрока.AzRyJiraProject = НайдСтрока.Ссылка;
			Если СокрЛП(ТекСтрока.name) <> СокрЛП(НайдСтрока.Ссылка.Наименование) Тогда
				ТекСтрока.Измененный = Истина;
				Парам.КоличествоИзмененныйJiraProjects = Парам.КоличествоИзмененныйJiraProjects + 1;
			КонецЕсли; 
		КонецЕсли;
		
		// თანამშრომლების მოძიება
		НайдСтрока = ТЗСотрудникиДляJiraProjects.Найти(ТекСтрока.leadId, "UserAccountId");
		Если Не НайдСтрока = Неопределено Тогда
			ТекСтрока.lead = НайдСтрока.Ссылка;	
		КонецЕсли;
		
	КонецЦикла;
	
	Ответ.Вставить("ДопИнфо", Парам);
	Возврат Ответ;
	
КонецФункции

