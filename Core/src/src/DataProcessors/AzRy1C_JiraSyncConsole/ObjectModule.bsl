Функция GetAccountLinks(JsonDataAccounts) Экспорт
	
	Для каждого ТекАкаунт Из JsonDataAccounts.results Цикл
		Ответ = ВыполнитьHTTPЗапрос("accounts/" + ТекАкаунт.key + "/" + "links");
		AccountLinks = JSON2Текст(Ответ.Текст);
		Если AccountLinks.metadata.count > 0 Тогда
			ТекАкаунт.links.Вставить("data", AccountLinks);
		КонецЕсли; 
	КонецЦикла;
	
КонецФункции

// ЭКСПОРТНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

Функция GetAccountsAndAccountCategories() Экспорт
	
	ТЗПроектов = ЗапросТЗПроектов();
	
	Ответ = GetAccountCategories();
	Если Ответ.ОщибкаСоединения Или Ответ.ОщибкаКодСостояния Тогда
		Возврат Ответ;
	КонецЕсли; 		
	JsonDataAccountCategories = JSON2Текст(Ответ.Текст);
	
	Ответ = GetAccounts();
	Если Ответ.ОщибкаСоединения Или Ответ.ОщибкаКодСостояния Тогда
		Возврат Ответ;
	КонецЕсли;
	JsonDataAccounts = JSON2Текст(Ответ.Текст);

	СоотвКонтрагенты = СоответствиеКонтрагентыCustomers(JsonDataAccounts);
	Если AccountsWithNoProjects Тогда
		GetAccountLinks(JsonDataAccounts); 		
	КонецЕсли;
	
	ЗаполнитьТаблицуAccountCategories(JsonDataAccountCategories, JsonDataAccounts, СоотвКонтрагенты);
	
	Worklogs.Очистить();
	
	Ответ.Вставить("ДопИнфо", ДопИнфо(AccountCategoriesAndAccounts));
	Возврат Ответ;
	
КонецФункции

Функция СозданиеНовыхПроектов() Экспорт
	
	ТЗПроектов = ЗапросТЗПроектов();	
	
	Для каждого ТекСтрока Из AccountCategoriesAndAccounts Цикл	
		Если Не ТекСтрока.Вибор Тогда Продолжить; КонецЕсли; 
		СоздатьНовыйПроект(ТекСтрока, "");
	КонецЦикла;	

	GetAccountsAndAccountCategories();
	
КонецФункции

Процедура ЗаполнитьТаблицуAccountCategories(JsonDataAccountCategories, JsonDataAccounts, СП) Экспорт
	
	СписокAccounts = ОбновитьТаблицуWorklogs().ДопИнфо.UniqueAccountsList;
	
	AccountCategoriesAndAccounts.Очистить();		
	Для каждого ТекСтрока Из JsonDataAccountCategories.results Цикл
		
		////Debug
		//Если НЕ ТекСтрока.key = "CDSPSL" Тогда
		//	Продолжить;	
		//КонецЕсли; 
		////Debug
		
		НоваяСтрока = AccountCategoriesAndAccounts.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		НоваяСтрока.Type    = Перечисления.AzRyTempoObjects.Account_categories;
		НоваяСтрока.Проекты = ОтборТЗПроекты(ТЗПроектов, ТекСтрока.id, НоваяСтрока.Type);
		Если ЗначениеЗаполнено(НоваяСтрока.Проекты) Тогда
			НоваяСтрока.ИзмененName = НоваяСтрока.Проекты.Наименование <> НаименованиеПроекта(НоваяСтрока.Key, НоваяСтрока.Name);
		Иначе
			Если НЕ НоваяСтрока.Status = "CLOSED" Тогда
				НоваяСтрока.Вибор = Истина;			
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла;
	
	Для каждого ТекСтрока Из JsonDataAccounts.results Цикл
		
		////Debug
		//Если НЕ ТекСтрока.key = "CDSPSL" Тогда
		//	Продолжить;	
		//КонецЕсли; 
		////Debug
		
		Если AccountsWithNoProjects И СписокИсключений.НайтиПоЗначению(СокрЛП(ТекСтрока.name)) = Неопределено Тогда
			Если ТекСтрока.links.Свойство("data") И ТекСтрока.links.data.metadata.count > 0 Тогда
				Продолжить;			
			КонецЕсли; 		
		КонецЕсли; 
		
		НоваяСтрока = AccountCategoriesAndAccounts.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		НоваяСтрока.Type    = Перечисления.AzRyTempoObjects.Accounts;
		НоваяСтрока.Проекты = ОтборТЗПроекты(ТЗПроектов, ТекСтрока.id, НоваяСтрока.Type);
		НоваяСтрока.CategoryID = ТекСтрока.category.id;
		Если ТекСтрока.Свойство("customer") Тогда		
			НоваяСтрока.Контрагент = СП[ТекСтрока.customer.key];
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НоваяСтрока.Проекты) Тогда
			НоваяСтрока.ИзмененName = НоваяСтрока.Проекты.Наименование <> НаименованиеПроекта(НоваяСтрока.Key, НоваяСтрока.Name);
		Иначе
			Если Не СписокAccounts.НайтиПоЗначению(НоваяСтрока.Key) = Неопределено Или НЕ НоваяСтрока.Status = "CLOSED" Тогда 
				НоваяСтрока.Вибор = Истина;			
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НоваяСтрока.Проекты.Родитель) 
			И НоваяСтрока.Проекты.Родитель.AzRyTempoObjectType = Перечисления.AzRyTempoObjects.Account_categories
			И НоваяСтрока.Проекты.Родитель.AzRyTempoObjectID <> ТекСтрока.category.id Тогда
			НоваяСтрока.ИзмененCategoryID = Истина;		
		КонецЕсли; 
		
	КонецЦикла;		
	AccountCategoriesAndAccounts.Сортировать("Type, ID Возр");
	
КонецПроцедуры

Функция СоздатьНовыйПроект(ТекСтрока, Комментарий) Экспорт
	
	TempoObjectType = ТекСтрока.Type;
	TempoObjectID   = ТекСтрока.ID;
	TempoObjectKey  = ТекСтрока.Key;
	TempoObjectName = ТекСтрока.Name;
	CategoryID      = ТекСтрока.CategoryID;
	Контрагент      = ТекСтрока.Контрагент;
	
	Парам = Новый Структура("Ошибка, Текст", Ложь, "");
		
	НачатьТранзакцию();
	Попытка
		Если TempoObjectType = Перечисления.AzRyTempoObjects.Account_categories Тогда
			Ответ = СозданиеСправочникаПроекты(TempoObjectType, TempoObjectID, TempoObjectKey, TempoObjectName, Контрагент);
		ИначеЕсли TempoObjectType = Перечисления.AzRyTempoObjects.Accounts Тогда	
			ТЗПроектов = ЗапросТЗПроектов();
			Проект = ОтборТЗПроекты(ТЗПроектов, CategoryID, Перечисления.AzRyTempoObjects.Account_categories);
			Если Не Проект = Справочники.Проекты.ПустаяСсылка() Тогда
				Ответ = СозданиеСправочникаПроекты(TempoObjectType, TempoObjectID, TempoObjectKey, TempoObjectName, Контрагент, Проект);
			КонецЕсли; 
		КонецЕсли; 
	Исключение		
		Парам.Вставить("Ошибка", Истина);
		Парам.Вставить("Текст", "შეცდომა ახალი პროექტის შექმნისას, შეცდომის ტექსტი:" + ОписаниеОшибки());
		ОтменитьТранзакцию();
		
		Возврат Парам;
	КонецПопытки;
	ЗафиксироватьТранзакцию();
	
	Возврат Парам;
	
КонецФункции

Функция ОбновлениеПроектов() Экспорт 

	ТЗПроектов = ЗапросТЗПроектов();
	
	Парам = Новый Структура("Ошибка, Текст", Ложь, "");
	
	Попытка
		НачатьТранзакцию();
		Для каждого ТекСтрока Из AccountCategoriesAndAccounts Цикл
			Если ЗначениеЗаполнено(ТекСтрока.Проекты) И ТекСтрока.ИзмененName Тогда
				Объ = ТекСтрока.Проекты.ПолучитьОбъект();
				Объ.Наименование = НаименованиеПроекта(ТекСтрока.Key, ТекСтрока.Name);
				Объ.Записать();
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ТекСтрока.Проекты.Родитель) И ТекСтрока.ИзмененCategoryID Тогда
				НовыйПроект = ОтборТЗПроекты(ТЗПроектов, ТекСтрока.CategoryID, Перечисления.AzRyTempoObjects.Account_categories);
				Если ЗначениеЗаполнено(НовыйПроект) Тогда
					Объ = ТекСтрока.Проекты.ПолучитьОбъект();
					Объ.Родитель = НовыйПроект;
					Объ.Записать();
				КонецЕсли; 
			КонецЕсли;
		КонецЦикла;				
	Исключение
		Парам.Вставить("Ошибка", Истина);
		Парам.Вставить("Текст", "შეცდომა პროექტის დასახელების განახლებისას, შეცდომის ტექსტი:" + ОписаниеОшибки());
		ОтменитьТранзакцию();
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	
	Возврат Парам;
		
КонецФункции

// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

Функция ДопИнфо(ТЗ)

	Парам = Новый Структура("КоличествоНовых, КоличествоИзмененые", 0, 0);
	
	Для каждого ТекСтрока Из ТЗ Цикл
		Если ТекСтрока.Вибор Тогда
			Парам.КоличествоНовых = Парам.КоличествоНовых  + 1;
		КонецЕсли;
		
		Если ТекСтрока.ИзмененName Или ТекСтрока.ИзмененCategoryID Тогда
			Парам.КоличествоИзмененые = Парам.КоличествоИзмененые  + 1;
		КонецЕсли;		
		
	КонецЦикла;
	
	Возврат Парам;

КонецФункции
 
Функция ВыполнитьHTTPЗапрос(ResourcePlus)
	
	Ответ = Новый Структура;
	Парам = RESTServices.ПарамертыHTTPЗапрос();
	
	// Headers
	Парам.Headers.Вставить("authorization", Authorization);
	
	// Соединение 
	Парам.Соединение.Сервер               = Сервер;
	Парам.Соединение.ЗащищенноеСоединение = ЗащищенноеСоединение;
	
	// Resource
	Парам.Resource        = Resource + "/" + ResourcePlus;
	Парам.ИмяФайлаЗапроса = ИмяФайлаЗапроса;
	
	Попытка
		HTTPЗапрос = RESTServices.GET(Парам);
	Исключение
		Ответ.Вставить("ОщибкаСоединения", Истина);
		Ответ.Вставить("ОщибкаКодСостояния", Ложь);
		Ответ.Вставить("HTTPЗапрос", Неопределено);
		Ответ.Вставить("Текст", ОписаниеОшибки());
		Возврат Ответ;
	КонецПопытки;
	
	Если HTTPЗапрос.КодСостояния <> 200 Тогда
		Ответ.Вставить("ОщибкаСоединения", Ложь);
		Ответ.Вставить("ОщибкаКодСостояния", Истина);
		Ответ.Вставить("HTTPЗапрос", HTTPЗапрос);
		Ответ.Вставить("Текст", HTTPЗапрос.ПолучитьТелоКакСтроку());
		Возврат Ответ;
	Иначе 	
		Ответ.Вставить("ОщибкаСоединения", Ложь);
		Ответ.Вставить("ОщибкаКодСостояния", Ложь);
		Ответ.Вставить("HTTPЗапрос", HTTPЗапрос);
		Ответ.Вставить("Текст", HTTPЗапрос.ПолучитьТелоКакСтроку());		
		Возврат Ответ;
	КонецЕсли;
	
	Возврат Ответ;	

КонецФункции

