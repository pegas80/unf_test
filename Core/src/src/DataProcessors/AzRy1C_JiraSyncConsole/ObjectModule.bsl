Процедура ОбновитьТЗСотрудники(JsonDataWorklogs) Экспорт

	СписокUserAccountId = Новый Массив;
	Для каждого ТекСтрока Из JsonDataWorklogs Цикл
		Если СписокUserAccountId.Найти(СокрЛП(ТекСтрока.author.accountId)) = Неопределено Тогда
			СписокUserAccountId.Добавить(СокрЛП(ТекСтрока.author.accountId));		
		КонецЕсли; 
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиAzRyJiraUserIDs.Ссылка,
		|	СотрудникиAzRyJiraUserIDs.id КАК UserAccountId
		|ИЗ
		|	Справочник.Сотрудники.AzRyJiraUserIDs КАК СотрудникиAzRyJiraUserIDs
