Функция GetMaxVertionByDate(Дата) Экспорт
	
	ТЗ = Worklogs.Выгрузить();
	ТЗ.Колонки.Добавить("wr_date2");
	Для каждого ТекСтрока Из ТЗ Цикл	
		ТекСтрока.wr_date2 = Дата(СтрЗаменить(ТекСтрока.wr_date, "-", "")); 
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Worklogs.wr_date,
		|	Worklogs.wr_version
		|ПОМЕСТИТЬ MaxVertion
		|ИЗ
		|	&ТЗ КАК Worklogs
		|ГДЕ
		|	Worklogs.wr_date2 МЕЖДУ &wr_date1 И &wr_date2
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(MaxVertion.wr_version) КАК wr_version1
		|ИЗ
		|	MaxVertion КАК MaxVertion";
	
	
	Запрос.Параметры.Вставить("ТЗ", ТЗ);
	Запрос.Параметры.Вставить("wr_date1", НачалоМесяца(Дата));
	Запрос.Параметры.Вставить("wr_date2", КонецМесяца(Дата));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.wr_version1;		
	КонецЦикла;
	
	Возврат 0;
	
