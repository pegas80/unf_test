КонецПроцедуры

&НаСервере
Процедура WorklogsОбновлениеВременыНаСервере()
	
	ОбменДаннымиСервер.ПропуститьПроверкуЗапретаИзменения();
	// არსებული დოკუმენტების განახლება
	Объ = РеквизитФормыВЗначение("Объект");
	Объ.WorklogsОбновлениеВременыНаСервере();
	ЗначениеВРеквизитФормы(Объ, "Объект");
	
	// წასაშლელია ლოკალურად შექმნილი დოკუმენტები
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаРаботу.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаданиеНаРаботу КАК ЗаданиеНаРаботу
		|ГДЕ
		|	ЗаданиеНаРаботу.Дата МЕЖДУ &Дата1 И &Дата2
		|	И ЗаданиеНаРаботу.Комментарий ПОДОБНО ""%Local%""";
	
	Запрос.УстановитьПараметр("Дата1", НачалоМесяца(Объ.ЗадНаРаботуМесацЗагрузки));
	Запрос.УстановитьПараметр("Дата2", КонецМесяца(Объ.ЗадНаРаботуМесацЗагрузки));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ДокОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		//ДокОбъект.ОбменДанными.ЗагрузкаДанных = Истина;
		ДокОбъект.Удалить();	
	КонецЦикла;
	
	// ყველა დოკუმენტს უნდა დაუბრუნდეს დეფაულტ ორგანიზაცია - ცხრილის განახლებულ ჩანაწერებში
	Н = 0;
	Для каждого ТекСтрока Из Объект.Worklogs Цикл
		Н = Н + 1;	
		Если ЗначениеЗаполнено(ТекСтрока.ЗаданиеНаРаботу) И ((Не ТекСтрока.ЗаданиеНаРаботу.Организация = Справочники.Организации.ОсновнаяОрганизация) Или (Не ТекСтрока.ЗаданиеНаРаботу.AzRyПроекты = ТекСтрока.Проект)) Тогда
			О = ТекСтрока.ЗаданиеНаРаботу.ПолучитьОбъект();
			О.Организация = Справочники.Организации.ОсновнаяОрганизация;
			О.AzRyПроекты = ТекСтрока.Проект;
			О.Записать(РежимЗаписиДокумента.Проведение); 
		КонецЕсли; 	
	КонецЦикла;
	
	// ყველა დოკუმენტს უნდა დაუბრუნდეს დეფაულტ ორგანიზაცია - თუ დარჩა კიდევ დოკუმენტები იმ თვეში
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаРаботу.Ссылка КАК ЗаданиеНаРаботу
		|ИЗ
		|	Документ.ЗаданиеНаРаботу КАК ЗаданиеНаРаботу
		|ГДЕ
		|	ЗаданиеНаРаботу.Дата МЕЖДУ &Дата1 И &Дата2
		|	И ЗаданиеНаРаботу.Организация <> &Организация";
	
	Запрос.УстановитьПараметр("Дата1", НачалоМесяца(Объ.ЗадНаРаботуМесацЗагрузки));
	Запрос.УстановитьПараметр("Дата2", КонецМесяца(Объ.ЗадНаРаботуМесацЗагрузки));
	Запрос.УстановитьПараметр("Организация", Справочники.Организации.ОсновнаяОрганизация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
	Н = 0;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Н = Н + 1;	
		
		О = ВыборкаДетальныеЗаписи.ЗаданиеНаРаботу.ПолучитьОбъект();
		О.Организация = Справочники.Организации.ОсновнаяОрганизация;
		О.Записать(РежимЗаписиДокумента.Проведение); 
	КонецЦикла;
		
	// ფორმაზე ცხრილის თავიდან განახლება
	СинхронизацияСWorklogsНаСервере();
	ОбменДаннымиСервер.ПропуститьПроверкуЗапретаИзменения(Ложь);
	
КонецПроцедуры

