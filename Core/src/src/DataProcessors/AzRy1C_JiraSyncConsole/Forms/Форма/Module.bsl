#Область Worklogs

&НаКлиенте
Процедура СинхронизацияСWorklogs(Команда)
	СинхронизацияСWorklogsНаСервере();
КонецПроцедуры

&НаСервере
Процедура СинхронизацияСWorklogsНаСервере()
	
	Объ = РеквизитФормыВЗначение("Объект");
	Если Не ЗначениеЗаполнено(Объ.ЗадНаРаботуМесацЗагрузки) Тогда
		Возврат;	
	КонецЕсли; 
	
	Ответ = Объ.ОбновитьТаблицуWorklogs();
	Если Ответ.ОщибкаСоединения Тогда // შეცდომა სერვერთან დაკავშირებისას
		Сообщить("შეცდომა სერვერთან დაკავშირებისას, მიზეზი: " + Ответ.Текст);
		Возврат;
	ИначеЕсли Ответ.ОщибкаКодСостояния Тогда // შეცდომა სერვერიდან დაბრუნებული კოდის პასუხის მიხედვით	
		Сообщить("შეცდომა სერვერიდან დაბრუნებული კოდის (" + Ответ.HTTPЗапрос.КодСостояния + ") პასუხის მიხედვით, მიზეზი: " + Ответ.Текст);
		Возврат;
	КонецЕсли; 
	
	Объ.ДопИнфоКоличествоНовыеСотрудники      = Ответ.ДопИнфо.КоличествоНовыеСотрудники;
	Объ.ДопИнфоКоличествоНовыеЗаданиеНаРаботу = Ответ.ДопИнфо.КоличествоНовыеЗаданиеНаРаботу;
	Объ.ДопИнфоWorklogsКолИзмененыеДлительностьВЧасах = Ответ.ДопИнфо.WorklogsКолИзмененыеДлительностьВЧасах;
	
	ЗначениеВРеквизитФормы(Объ, "Объект");
	
КонецПроцедуры

