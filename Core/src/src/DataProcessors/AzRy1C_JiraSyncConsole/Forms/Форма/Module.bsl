КонецПроцедуры

&НаСервере
Процедура JiraProjectsСинхронизацияССерверомНаСервере()
	
	Объ = РеквизитФормыВЗначение("Объект");
	
	Ответ = Объ.GetJiraProjects();
	Если Ответ.ОщибкаСоединения Тогда // შეცდომა სერვერთან დაკავშირებისას
		Сообщить("შეცდომა სერვერთან დაკავშირებისას, მიზეზი: " + Ответ.Текст);
		Возврат;
	ИначеЕсли Ответ.ОщибкаКодСостояния Тогда // შეცდომა სერვერიდან დაბრუნებული კოდის პასუხის მიხედვით	
	    Сообщить("შეცდომა სერვერიდან დაბრუნებული კოდის (" + Ответ.HTTPЗапрос.КодСостояния + ") პასუხის მიხედვით, მიზეზი: " + Ответ.Текст);
		Возврат;
	КонецЕсли;
		
	Объ.ДопИнфоКоличествоНовыхJiraProjects = Ответ.ДопИнфо.КоличествоНовыеJiraProjects;
	
	Грп = ПодчиненныеЭлементы.ГруппаСтраницы.ПодчиненныеЭлементы.ГруппаJiraProjects.ПодчиненныеЭлементы.Группа1;
	Грп.ПодчиненныеЭлементы.JiraProjectsЗагрузитьНовые.Доступность = Ответ.ДопИнфо.КоличествоНовыеJiraProjects > 0;
	Грп.ПодчиненныеЭлементы.JiraProjectsОбновитьТекушие.Доступность = Ответ.ДопИнфо.КоличествоИзмененныйJiraProjects > 0;
		
	ЗначениеВРеквизитФормы(Объ, "Объект");	
	
КонецПроцедуры

