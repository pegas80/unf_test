&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.СерверWorklogs = "pas.azrycloud.com";	
	Объ = РеквизитФормыВЗначение("Объект");
	Объ.WorklogResource = Объ.getMaxSelectVersion();
	ЗначениеВРеквизитФормы(Объ, "Объект");
	
КонецПроцедуры

#Область Accounts_and_AccountCategories

&НаКлиенте
Процедура ОбновитьТаблицуCategories(Команда)
	ОбновитьТаблицуCategoriesНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблицуCategoriesНаСервере()
	
	Объ = РеквизитФормыВЗначение("Объект");
	
	Ответ = Объ.GetAccountsAndAccountCategories();
	Если Ответ.ОщибкаСоединения Тогда // შეცდომა სერვერთან დაკავშირებისას
		Сообщить("შეცდომა სერვერთან დაკავშირებისას, მიზეზი: " + Ответ.Текст);
		Возврат;
	ИначеЕсли Ответ.ОщибкаКодСостояния Тогда // შეცდომა სერვერიდან დაბრუნებული კოდის პასუხის მიხედვით	
	    Сообщить("შეცდომა სერვერიდან დაბრუნებული კოდის (" + Ответ.HTTPЗапрос.КодСостояния + ") პასუხის მიხედვით, მიზეზი: " + Ответ.Текст);
		Возврат;
	КонецЕсли; 
		
	Объ.ДопИнфоКоличествоНовыхAccounts     = Ответ.ДопИнфо.КоличествоНовых;
	Объ.ДопИнфоКоличествоИзмененыхAccounts = Ответ.ДопИнфо.КоличествоИзмененые;
	
	ЗначениеВРеквизитФормы(Объ, "Объект");
	
КонецПроцедуры 

&НаКлиенте
Процедура СозданиеНовыхПроектов(Команда)
	СозданиеНовыхПроектовНаСервере();
	ОбновитьТаблицуCategoriesНаСервере();
КонецПроцедуры

&НаСервере
Процедура СозданиеНовыхПроектовНаСервере()
	
	Объ = РеквизитФормыВЗначение("Объект");
	Объ.СозданиеНовыхПроектов(); 
	ЗначениеВРеквизитФормы(Объ, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновлениеНаименованийПроектов(Команда)
	ОбновлениеПроектовНаСервере();
	ОбновитьТаблицуCategoriesНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбновлениеПроектовНаСервере()
	
	Объ = РеквизитФормыВЗначение("Объект");
	Ответ = Объ.ОбновлениеПроектов();
	
	Если Ответ.Ошибка Тогда
		Сообщить(Ответ.Текст);
		Возврат;
	КонецЕсли;
	ЗначениеВРеквизитФормы(Объ, "Объект");
		
КонецПроцедуры

#КонецОбласти

