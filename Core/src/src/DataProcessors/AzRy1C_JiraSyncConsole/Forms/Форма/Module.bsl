КонецПроцедуры

&НаСервере
Процедура СинхронизацияСJiraUsersНаСервере()
	
	Для каждого ТекСтрока Из Объект.JiraUsers Цикл
		Если ЗначениеЗаполнено(ТекСтрока.Сотрудник) Тогда
			Если ТекСтрока.Сотрудник.AzRyJiraUserIDs.Количество() > 0 Тогда
				Сообщить("თანამშრომელს " + ТекСтрока.Сотрудник.Наименование + " უკვე მინიჭებული აქვს გუიდი.");
				Продолжить;
			КонецЕсли; 
			
			О = ТекСтрока.Сотрудник.ПолучитьОбъект();
			НоваяСтрока = О.AzRyJiraUserIDs.Добавить();
			НоваяСтрока.id = СокрЛП(ТекСтрока.ID);
			О.Записать();
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("wr_user_account_id", ТекСтрока.ID);
			НайденныеСтроки = Объект.Worklogs.НайтиСтроки(ПараметрыОтбора);
			
			Для каждого ТекIssue Из НайденныеСтроки Цикл
				ТекIssue.Сотрудник      = О.Ссылка;
				ТекIssue.НовыйСотрудник = Ложь;
			КонецЦикла;
		КонецЕсли;	
	КонецЦикла;                                
	
	// ცხრილის განახლება
	Объ = РеквизитФормыВЗначение("Объект");
	Объ.ДжираПользователи(Объект.Worklogs.Выгрузить());

	// ცხრილის განახლება
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("НовыйСотрудник", Истина);
	НайденныеСтроки = Объект.Worklogs.НайтиСтроки(ПараметрыОтбора);
	
	Объ.ДопИнфоКоличествоНовыеСотрудники = НайденныеСтроки.Количество();
	
	Элементы.ГруппаJiraUsers.Видимость = НайденныеСтроки.Количество() > 0;
	Элементы.ГруппаJiraUsers.Доступность = НайденныеСтроки.Количество() > 0;
	
	//Ответ = Объ.ОбновитьТаблицаДжираПользователи();
	//Если Ответ.ОщибкаСоединения Тогда // შეცდომა სერვერთან დაკავშირებისას
	//	Сообщить("შეცდომა სერვერთან დაკავშირებისას, მიზეზი: " + Ответ.Текст);
	//	Возврат;
	//ИначеЕсли Ответ.ОщибкаКодСостояния Тогда // შეცდომა სერვერიდან დაბრუნებული კოდის პასუხის მიხედვით	
	//    Сообщить("შეცდომა სერვერიდან დაბრუნებული კოდის (" + Ответ.HTTPЗапрос.КодСостояния + ") პასუხის მიხედვით, მიზეზი: " + Ответ.Текст);
	//	Возврат;
	//КонецЕсли; 
		
	ЗначениеВРеквизитФормы(Объ, "Объект");	
	
КонецПроцедуры

