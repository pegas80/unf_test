Функция ПолучитьЗначениеСвойства(НаименованиеЗначения, СвойствоОбъекта)
	Результат = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(НаименованиеЗначения, , ,СвойствоОбъекта);
	Если Результат = Справочники.ЗначенияСвойствОбъектов.ПустаяСсылка() Тогда
		Результат = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
		Результат.Наименование = НаименованиеЗначения;
		Результат.Владелец = СвойствоОбъекта;
		Результат.Записать();				
	КонецЕсли;
Возврат Результат.Ссылка;
КонецФункции

Функция СоздатьНоменклатуру(ВыборкаЗапроса, ТаблицаНоменклатуры)
	
	Элемент = Справочники.Номенклатура.СоздатьЭлемент();
	
	//+++ Дмгг
	ПоискНоменклатурыПоАртикулу = ТаблицаНоменклатуры.НайтиСтроки(Новый Структура("Артикул", ВыборкаЗапроса.Артикул));
	Если ПоискНоменклатурыПоАртикулу.Количество() <> 0 Тогда 
		Сообщить(НСтр("ru = 'Номенклатура с артикулом: " + ВыборкаЗапроса.Артикул + ", уже существует'; ka = 'ნომეკლატურა არტიკულით" + ВыборкаЗапроса.Артикул + ",უკვე არსებობს'"));
		Возврат ПоискНоменклатурыПоАртикулу[0].Ссылка;
	КонецЕсли;
	//--- Дмгг
	
	ПоискРодителяПоНаименованию = Справочники.Номенклатура.НайтиПоНаименованию(ВыборкаЗапроса.Родитель,Истина);
	Если ПоискРодителяПоНаименованию = Неопределено ИЛИ ПоискРодителяПоНаименованию = Справочники.Номенклатура.ПустаяСсылка() Тогда 
		Элемент.Родитель			= ЭтотОбъект.ГруппаДляЗагрузкиНоменклатуры;
	Иначе
		Элемент.Родитель 			= ПоискРодителяПоНаименованию;
	КонецЕсли;
	
	//Паганини_
	//Элемент.НоменклатурнаяГруппа= ЭтотОбъект.НоменклатурнаяГруппа;
	Элемент.Артикул					= ВыборкаЗапроса.Артикул;
	Элемент.КатегорияНоменклатуры = Справочники.КатегорииНоменклатуры.БезКатегории;//ЭтотОбъект.НоменклатурнаяГруппа;
	//_Паганини
	Элемент.СчетУчетаЗапасов	= ЭтотОбъект.СчетУчетаЗапасов;
	Элемент.СчетУчетаЗатрат		= ЭтотОбъект.СчетУчетаЗатрат;
	//Паганини_
	Элемент.СчетУчетаЗапасовРегл	= ЭтотОбъект.СчетУчетаЗапасовРегл;
	Элемент.СчетУчетаЗатратРегл		= ЭтотОбъект.СчетУчетаЗатратРегл;
	//_Паганини
	Элемент.ЕдиницаИзмерения	= ЭтотОбъект.ЕдиницаИзмерения;
	Элемент.СтавкаНДС			= ЭтотОбъект.СтавкаНДС;
	
	
	Элемент.НаправлениеДеятельности = Справочники.НаправленияДеятельности.ОсновноеНаправление;
	Элемент.СпособПополнения		= Перечисления.СпособыПополненияЗапасов.Закупка;
	Элемент.МетодОценки             = ЭтотОбъект.МетодОценки;
	Элемент.ТипНоменклатуры			= Перечисления.ТипыНоменклатуры.Запас;
	
	Элемент.Наименование		= ВыборкаЗапроса.Наименование;
	Элемент.НаименованиеПолное	= ВыборкаЗапроса.Наименование;
	Элемент.Поставщик           = ЭтотОбъект.Поставщик;
	
	Элемент.ИспользоватьХарактеристики = ЛОЖЬ;
	//+++ Дмгг
	Попытка
		Сообщить(НСтр("ru = 'Была создана номенклатура: " + ВыборкаЗапроса.Наименование +"/"+ ВыборкаЗапроса.Артикул +"'; ka = 'შეიქმნა ნომენკლატურა: " + ВыборкаЗапроса.Наименование +"/"+ ВыборкаЗапроса.Артикул +"'"));
		Элемент.Записать();
	Исключение
		Сообщить(НСтр("ru = 'Не удалось создать номенклатуру: " + ВыборкаЗапроса.Наименование +"/"+ ВыборкаЗапроса.Артикул +"'; ka = 'ვერ შეიქმნა ნომეკლატურა: " + ВыборкаЗапроса.Наименование +"/"+ ВыборкаЗапроса.Артикул +""));
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецПопытки;
	
	//+++ Дмгг
	НовСтрока = ТаблицаНоменклатуры.Добавить();
	НовСтрока.Ссылка = Элемент.Ссылка;
	НовСтрока.Артикул = Элемент.Ссылка.Артикул;
	//--- Дмгг
	
	Возврат Элемент.Ссылка;
	
КонецФункции

