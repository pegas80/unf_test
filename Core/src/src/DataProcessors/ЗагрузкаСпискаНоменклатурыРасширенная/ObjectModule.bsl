// Запись на диск файла из временного хранилища
Функция ВыполнитьЗагрузкуДанныхИзВременногоХранилища(АдресВременногоХранилища) Экспорт
	
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
		
		// получаем имя временного файла в локальной ФС на сервере
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xls");
		
		//Паганини_
		ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке();
		ПараметрыРегистрации.Вставить("БезопасныйРежим", Ложь);
		//_Паганини
		// получаем файл для считывания
		ДвоичныеДанные.Записать(ИмяВременногоФайла);
	Исключение
		Сообщить(НСтр("ka='Не удалось создать файл на диске из временного хранилища!';ru='Не удалось создать файл на диске из временного хранилища!';en='Unable to create file on disk from the temporary storage!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Возврат Ложь;
	КонецПопытки;
Возврат Истина;			
КонецФункции

// Удаление временного файла
Процедура УдалитьВременныйФайл()
	
	Попытка		
		Если Не ПустаяСтрока(ИмяВременногоФайла) Тогда
			УдалитьФайлы(ИмяВременногоФайла);
		КонецЕсли;
	Исключение
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
	КонецПопытки;
КонецПроцедуры

// Получить список страниц из файлов
Функция ПолучитьПереченьСтраниц(СтраницыИзФайла, АдресХранилища = Неопределено) Экспорт
	Если АдресХранилища = Неопределено Тогда 
		АдресХранилища = АдресВременногоХранилища;
	КонецЕсли;
	Если ПустаяСтрока(АдресХранилища) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	Если Не ВыполнитьЗагрузкуДанныхИзВременногоХранилища(АдресХранилища) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	//ვუერთდებით ექსელს
	Попытка
		Excel = новый COMОбъект("Excel.Application");
	Исключение
		Сообщить(НСтр("ka='როგორც ჩანს სერვერზე არ არის დაყენებული Microsoft Excel, გთხოვთ სცადოთ დაინსტალირების შემდეგ';ru='По всей видимости на сервере не установлен Microsoft Excel, повторите попытку после установки.';en='Apparently the server is not installed Microsoft Excel, try again after installation.'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Возврат Неопределено;
	КонецПопытки; 
	
	//მიერთებამ წარმატებით ჩაიარა, ვხსნით დროებითი ფაილს
	Попытка
		Excel.Workbooks.Open(ИмяВременногоФайла);
	Исключение
		Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის გახსნა!';ru='Не удалось открыть файл!';en='Could not open file!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Excel.Quit();
		Возврат Неопределено;
	КонецПопытки;	

	
	//Получим количество строк и колонок.
	//В разных версиях Excel получаются по-разному, поэтому сначала определим версию Excel
	Версия = Число(Лев(Excel.Version,Найти(Excel.Version,".")-1));
	
	Попытка
		ВсегоСтраниц = Excel.Worksheets.Count;
		Для ИндексСтраницы = 1 По ВсегоСтраниц Цикл 		
			Если Версия = 8 тогда
				ФайлСтрок   = Excel.Cells.CurrentRegion.Rows.Count;
				ФайлКолонок = Макс(Excel.Cells.CurrentRegion.Columns.Count, 13);
			Иначе
				ФайлСтрок   = Excel.WorkSheets(ИндексСтраницы).Cells(1,1).SpecialCells(11).Row;
				ФайлКолонок = Excel.WorkSheets(ИндексСтраницы).Cells(1,1).SpecialCells(11).Column;   
			Конецесли;
			СтрокаТаблицы = СтраницыИзФайла.Добавить();
			СтрокаТаблицы.Номер			= ИндексСтраницы;
			СтрокаТаблицы.Наименование	= Excel.WorkSheets(ИндексСтраницы).Name;
			СтрокаТаблицы.Строк			= ФайлСтрок;
			СтрокаТаблицы.Столбцов		= ФайлКолонок;
			СтрокаТаблицы.Используеться	= Ложь;			
		КонецЦикла;
	Исключение
		Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის შიგთავსის დამუშავება!';ru='Не удалось обработать содержимое файла!';en='Unable to process the contents of the file!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Excel.Quit();
		Возврат Неопределено;		
	КонецПопытки;
	
	//ექსელის გამორთვა
	Excel.ActiveWorkbook.Close();
	Excel.Quit();
	
	//დროებითი ფაილის წაშლა
	УдалитьВременныйФайл();	
КонецФункции

