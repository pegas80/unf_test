// Функции и процедуры для обработки данных из файла 
//

// Обновление данных планов счетов
Функция ОбработкаДанныхИзФайла(СтраницыИзФайла, АдресХранилища = Неопределено) Экспорт
	Если АдресХранилища = Неопределено Тогда 
		АдресХранилища = АдресВременногоХранилища;
	КонецЕсли;
	Если ПустаяСтрока(АдресХранилища) ИЛИ (Не ВыполнитьЗагрузкуДанныхИзВременногоХранилища(АдресХранилища))	Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	// Запустим приложение EXCEL
	Попытка
		Excel = новый COMОбъект("Excel.Application");
	Исключение
		Сообщить(НСтр("ka='როგორც ჩანს სერვერზე არ არის დაყენებული Microsoft Excel, გთხოვთ სცადოთ დაინსტალირების შემდეგ';ru='По всей видимости на сервере не установлен Microsoft Excel, повторите попытку после установки.';en='Apparently the server is not installed Microsoft Excel, try again after installation.'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Возврат Неопределено;
	КонецПопытки; 
	
	// Откроем файл EXCEL-а 
	Попытка
		Excel.Workbooks.Open(ИмяВременногоФайла);
	Исключение
		Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის გახსნა!';ru='Не удалось открыть файл!';en='Could not open file!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Excel.Quit();
		Возврат Неопределено;
	КонецПопытки;	

	
	//Получим количество строк и колонок.
	//В разных версиях Excel получаются по-разному, поэтому сначала определим версию Excel
	Версия = Лев(Excel.Version,Найти(Excel.Version,".")-1);

	// Создание таблицы значений 
	ТаблицаЗначений = Новый ТаблицаЗначений;
	
	Массив = Новый Массив;
	Массив.Добавить(Тип("Строка"));
	КС = Новый КвалификаторыСтроки(256, ДопустимаяДлина.Переменная);
	ОписаниеТипа = Новый ОписаниеТипов(Массив,,КС);
	
	МассивОТ = Новый Массив;
	МассивОТ.Добавить(Тип("Число"));
	Знак = ДопустимыйЗнак.Неотрицательный;
	КЧ = Новый КвалификаторыЧисла(10,0,Знак);
	ОписаниеТипаЧисло = Новый ОписаниеТипов(МассивОТ,,КЧ);
	
	// добавим в таблицу значений три колонки
	ТаблицаЗначений.Колонки.Добавить("НомерСтроки", ОписаниеТипаЧисло,"Номер строки");
	ТаблицаЗначений.Колонки.Добавить("Наименование", ОписаниеТипа,"Наименование");
	ТаблицаЗначений.Колонки.Добавить("НаименованиеПолное", ОписаниеТипа,"НаименованиеПолное");
	ТаблицаЗначений.Колонки.Добавить("Артикул", ОписаниеТипа,"Артикул");
	ТаблицаЗначений.Колонки.Добавить("Штрихкод", ОписаниеТипа,"Штрихкод");
	ТаблицаЗначений.Колонки.Добавить("Родитель", ОписаниеТипа,"Родитель");
	ТаблицаЗначений.Колонки.Добавить("ЦенаЗакупки", ОписаниеТипа,"Цена закупки");
	ТаблицаЗначений.Колонки.Добавить("ЦенаПродажи", ОписаниеТипа,"Цена продажи");
	
	//+++ Дмгг	
	// Для поиска номенклатуры по артикулу
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка,
		|	Номенклатура.Артикул
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ЭтоГруппа
		|	И НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.Артикул <> """"";
	
	ТаблицаНоменклатуры = Запрос.Выполнить().Выгрузить();
	//--- Дмгг
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	 			   |	ВТДанныеИЗФайла.НомерСтроки,
	               |	ВТДанныеИЗФайла.Наименование,
	               |	ВТДанныеИЗФайла.НаименованиеПолное,
	               |	ВТДанныеИЗФайла.Артикул,
	               |	ВТДанныеИЗФайла.Штрихкод,
	               |	ВТДанныеИЗФайла.Родитель,
	               |	ВТДанныеИЗФайла.ЦенаЗакупки,
	               |	ВТДанныеИЗФайла.ЦенаПродажи
	               |ПОМЕСТИТЬ ВТТаблица
	               |ИЗ
	               |	&ВТДанныеИЗФайла КАК ВТДанныеИЗФайла
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
				   |	ВТТаблица.НомерСтроки,
	               |	ВТТаблица.Наименование КАК Наименование,
	               |	ВТТаблица.НаименованиеПолное КАК НаименованиеПолное,
	               |	ВТТаблица.Артикул КАК Артикул,
	               |	ВТТаблица.Штрихкод КАК Штрихкод,
	               |	ВТТаблица.Родитель КАК Родитель,
	               |	ВТТаблица.ЦенаЗакупки КАК ЦенаЗакупки,
	               |	ВТТаблица.ЦенаПродажи КАК ЦенаПродажи
	               |ИЗ
	               |	ВТТаблица КАК ВТТаблица
				   |УПОРЯДОЧИТЬ ПО
				   |	НомерСтроки";
				   //|ИТОГИ
				   //|	МАКСИМУМ(ЦенаЗакупки),
				   //|	МАКСИМУМ(ЦенаПродажи)
				   //|ПО
				   //|	Наименование,
				   //|	НаименованиеПолное,
				   //|	Артикул,
				   //|	Родитель,
				   //|	Штрихкод";
	
	Попытка
		НачатьТранзакцию();					   
		ДатаЗагрузки = ТекущаяДата();					   
		Для Каждого Эл Из СтраницыИзФайла Цикл
			
			// Проверка по страницам
			Если Эл.Используеться = Ложь
				// Или Эл.Наименование <> "ОбновлениеПлановСчетов"
					Тогда 
				Продолжить;
			КонецЕсли;
			
			Сообщить(НСтр("ru = 'Чтение данных страницы: " + Эл.Наименование + "'; ka = 'მონაცემების დამუშავება: " + Эл.Наименование + "'"));
			
			ТаблицаЗначений.Очистить();
			// Обход страницы в файле и генерируем таблицу значений
			Для ИндексСтроки = 2 По Эл.Строк Цикл
	        	СтрокаТЗ = ТаблицаЗначений.Добавить();
				СтрокаТЗ["НомерСтроки"]			= ИндексСтроки;
				СтрокаТЗ["Наименование"]		= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,1).Value);
				СтрокаТЗ["НаименованиеПолное"]	= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,2).Value);
				СтрокаТЗ["Артикул"]				= СтрЗаменить(СтрЗаменить(СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,3).Value)," ", ""),Символы.НПП,"");
				СтрокаТЗ["Штрихкод"]			= СтрЗаменить(СтрЗаменить(СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,4).Value)," ", ""),Символы.НПП,"");
				СтрокаТЗ["Родитель"]			= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,5).Value);
				СтрокаТЗ["ЦенаПродажи"]			= СтрЗаменить(СтрЗаменить(СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,6).Value)," ", ""),Символы.НПП,"");
				СтрокаТЗ["ЦенаЗакупки"]			= СтрЗаменить(СтрЗаменить(СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,7).Value)," ", ""),Символы.НПП,"");
			КонецЦикла;
			
			Запрос.УстановитьПараметр("ВТДанныеИЗФайла", ТаблицаЗначений);
			ВыборкаПоНоменклатуре = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаПоНоменклатуре.Следующий() Цикл 
				Если ВыборкаПоНоменклатуре.Наименование = Неопределено ИЛИ ПустаяСтрока(ВыборкаПоНоменклатуре.Наименование) Тогда 
					Продолжить;	
				КонецЕсли;

				Сообщить(НСтр("ru = 'Загрузка данных строки: " + ВыборкаПоНоменклатуре.НомерСтроки + "'; ka = 'მონაცემის ჩატვირთვა სტრიქონი: " + ВыборкаПоНоменклатуре.НомерСтроки + "'"));
				Номенклатура = СоздатьНоменклатуру(ВыборкаПоНоменклатуре, ТаблицаНоменклатуры);
				
				//ВыборкаПоХарактеристикам = ВыборкаПоНоменклатуре.Выбрать();
				//
				//Пока ВыборкаПоХарактеристикам.Следующий() Цикл 
				//	
				//	Характеристика = СоздатьХарактеристику(Номенклатура, ВыборкаПоХарактеристикам);
				
					ЗарегистрироватьШтрихКод(Номенклатура, ВыборкаПоНоменклатуре);
					
					ЗарегистрироватьЦенуКонтрагента(Номенклатура, ВыборкаПоНоменклатуре);
					
                    ЗарегистрироватьЦенуРеализации(Номенклатура, ВыборкаПоНоменклатуре);
					
				//КонецЦикла; // Конец обработки характеристик
			КонецЦикла; // Конец обработки номенклатуры
		КонецЦикла; // Конец обработки страницы из файла
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის შიგთავსის დამუშავება!';ru='Не удалось обработать содержимое файла!';en='Unable to process the contents of the file!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Excel.Quit();
		Возврат Неопределено;		
	КонецПопытки;
	
	// Закроем приложение EXCEL
	Excel.ActiveWorkbook.Close();
	Excel.Quit();
	
	// удалим временный файл созданный на сервере
	УдалитьВременныйФайл();	
КонецФункции


