// Функции и процедуры для генерации шаблонов файлов 
//

// Генерация шаблона для обновления данных планов счетов
Функция СгенерироватьШаблонДляФайлаИмпорта(УникальныйИдентификаторФормы) Экспорт 
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		
		Попытка
			Excel = новый COMОбъект("Excel.Application");
		Исключение
			Сообщить(НСтр("ka='როგორც ჩანს სერვერზე არ არის დაყენებული Microsoft Excel, გთხოვთ სცადოთ დაინსტალირების შემდეგ';ru='По всей видимости на сервере не установлен Microsoft Excel, повторите попытку после установки.';en='Apparently the server is not installed Microsoft Excel, try again after installation.'"));
			Ошибка = ОписаниеОшибки();
			Сообщить(Ошибка);
			Возврат Неопределено;
		КонецПопытки;
		
		Попытка
						
			Версия = Число(Лев(Excel.Version,Найти(Excel.Version,".")-1));
			
			Если Версия < 13 Тогда // если установлен 2003 и более ранний ексель то используем старый формат
				// получаем имя временного файла в локальной ФС на сервере
				ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xls");
			Иначе //иначе испорльзуем новый формат
				// получаем имя временного файла в локальной ФС на сервере
				ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xlsx");				
			КонецЕсли;
			
			КнигаExcel = Excel.WorkBooks.Add();
			Страница1 = КнигаExcel.WorkSheets.Add();
			ИмяСтраници =  НСтр("ka='ნომენკლატურის მონაცემები';ru='ДанныеПоНоменклатуре';en='Product info'");
			Страница1.Name = ИмяСтраници;
			//Страница1.Cells(1,1).Value = "'Артикул / наименование";
			//Страница1.Cells(1,2).Value = "'Штрихкод";
			//Страница1.Cells(1,3).Value = "'Размер";
			//Страница1.Cells(1,4).Value = "'Цена закупки";
			//Страница1.Cells(1,5).Value = "'Цена продажи";
			
			Наименование =   НСтр("ka='დასახელება';ru='Наименование';en='Name'");
			ПолноеНаименование =   НСтр("ka='სრული დასახელება';ru='Полное наименование';en='Full name'");
			Артикул =   НСтр("ka='არტიკული';ru='Артикул';en='Code'");
			Штрихкод =   НСтр("ka='შტრიხკოდი';ru='Штрихкод';en='Barcode'");
			Родитель =   НСтр("ka='მშობელი';ru='Родитель';en='Parent'");
			ЦенаПродажи =   НСтр("ka='გაყიდვის ფასი';ru='Цена продажи';en='Sale price'");
			ЦенаЗакупки =   НСтр("ka='შესყიდვის ფასი';ru='Цена закупки';en='Buying price'");
			
			Страница1.Cells(1,1).Value = Наименование;
			Страница1.Cells(1,2).Value = ПолноеНаименование;
			Страница1.Cells(1,3).Value = Артикул;
			Страница1.Cells(1,4).Value = Штрихкод;
			Страница1.Cells(1,5).Value = Родитель;
			Страница1.Cells(1,6).Value = ЦенаПродажи;
			Страница1.Cells(1,7).Value = ЦенаЗакупки;
			КнигаExcel.SaveAs(ИмяВременногоФайла);
			
			// Закроем приложение EXCEL
			Excel.ActiveWorkbook.Close();
			Excel.Quit();			
			
			Адрес = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяВременногоФайла), УникальныйИдентификаторФормы);
			
			// удалим временный файл созданный на сервере 
			УдалитьВременныйФайл();			
		Исключение
			Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის გახსნა!';ru='Не удалось создать файл!';en='Could not create file!'"));
			Ошибка = ОписаниеОшибки();
			Сообщить(Ошибка);
			Excel.Quit();
			Возврат Неопределено;
		КонецПопытки;
		
	Возврат Версия;	
	
	Исключение
		Сообщить(НСтр("ka='Не удалось создать файл на диске из временного хранилища!';ru='Не удалось создать файл на диске из временного хранилища!';en='Unable to create file on disk from the temporary storage!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции
