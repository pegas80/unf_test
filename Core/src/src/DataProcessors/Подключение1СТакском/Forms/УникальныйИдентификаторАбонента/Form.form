              <horizontalAlign>Left</horizontalAlign>
            </extInfo>
          </extendedTooltip>
          <contextMenu>
            <name>Декорация2КонтекстноеМеню</name>
            <id>14</id>
            <autoFill>true</autoFill>
          </contextMenu>
          <type>Label</type>
