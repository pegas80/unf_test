&НаСервере
Функция СуммаИДокументыЗадНаРаботу2(СПЗначений1)
	
	СуммаВремени      = 0;
	КоличествоЗаписей = 0;
	Массив = Новый Массив;
	Структура = Новый Структура;
	Мап = Новый Соответствие;
	Для каждого ТекЗначение Из СПЗначений1 Цикл
		П = Новый Структура;
		ЗагрузкаПлан          = ТекЗначение.Значение.ЗагрузкаПлан;
		ЗагрузкаПланТребуется = ТекЗначение.Значение.ЗагрузкаПланТребуется;
		СуммаВ = (ЗагрузкаПлан - ЗагрузкаПланТребуется);
	
		Для каждого ТекДерего Из ТекЗначение.Значение.Строки Цикл
			Для каждого ТекДерего1 Из ТекДерего.Строки Цикл				
				
				Если СуммаВ <= 0 Тогда Прервать; КонецЕсли;
				
				Если ТекДерего1.ЗагрузкаПлан <= СуммаВ Тогда
					СуммаВ = СуммаВ - ТекДерего1.ЗагрузкаПлан;
					Массив.Добавить(ТекДерего1);
				Иначе
					СуммаВ = СуммаВ - ТекДерего1.ЗагрузкаПлан;
					Массив.Добавить(ТекДерего1);
					Прервать;
				КонецЕсли;	
				
			КонецЦикла;	
		КонецЦикла;
		
		П.Вставить("СуммаВремени", (ЗагрузкаПлан - ЗагрузкаПланТребуется));
		П.Вставить("Массив", Массив);
		Мап.Вставить(ТекЗначение.Значение.ОрганизацияЗаданияНаРаботу, П);
	КонецЦикла;
		
	Возврат Мап;
	
КонецФункции
 
&НаСервере
Функция КешДляОбработки(СПЗначений, Парам)

	Кеш   = Новый Соответствие;
	Для каждого ТекСтрока Из СПЗначений Цикл
		П = Новый Структура;
		П.Вставить("ТарифПоОрг", ТекСтрока.Значение.ТарифПоОрг);
		П.Вставить("ЗаказПокупателя", ТекСтрока.Значение.ЗаказПокупателя);
		Кеш.Вставить(ТекСтрока.Значение.Организация, П);
	КонецЦикла;	
	
	Зарплата = 0;
	Для каждого ТекСтрока Из Кеш Цикл
		Зарплата = Зарплата + ТекСтрока.Значение.ТарифПоОрг;	
	КонецЦикла;
	
	СТРП = Новый Структура;
	Если Цел(Парам.КоличествоЗаписей / Кеш.Количество()) = 0 Тогда
		
		КО = Кеш.Количество();	
		Для Х=0 По Кеш.Количество()-1 Цикл
			Ц = ?(КО = 0, 0, Цел(Парам.КоличествоЗаписей / КО));
			СТРП.Вставить("П"+Х, ?(Ц=0, 0, 1));	
			КО = КО - 1;
		КонецЦикла;
	Иначе 
		
		КО   = Кеш.Количество();
		КОЛЗ = Парам.КоличествоЗаписей;
		Цел  = Цел(Парам.КоличествоЗаписей / КО);
		Для Х=0 По Кеш.Количество()-1 Цикл
			СТРП.Вставить("П"+Х, ?(Х=(Кеш.Количество()-1), КОЛЗ, Цел));
			КОЛЗ = КОЛЗ - Цел;
		КонецЦикла;	
	КонецЕсли;			
	
	К = Зарплата / 100;
	Н1 = 0;
	Н2 = 0;
	//Стр = Новый Структура;
	Для каждого ТекСтрока Из Кеш Цикл
		ТекСтрока.Значение.Вставить("Процент", ТекСтрока.Значение.ТарифПоОрг / К); 
		ТекСтрока.Значение.Вставить("СуммаВремени", Окр((Парам.СуммаВремени / 100) * (ТекСтрока.Значение.ТарифПоОрг / К), 4));
		
		НовМассив = Новый Массив;
		Для Ч=0 По СТРП["П"+Н1]-1 Цикл		
			НовМассив.Добавить(Парам.Массив.Получить(Ч+Н2));	
		КонецЦикла;
		//Стр.Вставить("П"+Н1, НовМассив);
		ТекСтрока.Значение.Вставить("МассивДок", НовМассив);
		Н2 = Н2 + Ч;
		Н1 = Н1 + 1;
	КонецЦикла;
	
	
	Возврат Кеш;

КонецФункции

&НаСервере
Процедура ОбработкаТаблицы(ТЗ)

	// 1)
	Для каждого ТекСтрока Из ТЗ Цикл
		Если ТекСтрока.Сотрудник = Null Тогда
			ТекСтрока.Сотрудник       		= ТекСтрока.Сотрудник1;
			//ТекСтрока.Организация     		= ТекСтрока.Организация1;
			ТекСтрока.ОрганизацияЗаданияНаРаботу = ТекСтрока.Организация1;
			ТекСтрока.ЗаказПокупателя 		= Документы.ЗаказПокупателя.ПустаяСсылка();
			ТекСтрока.ЗагрузкаПлан    		= 0;
			ТекСтрока.ЗагрузкаПланВСумме    = 0;
			ТекСтрока.ЗаказПокупателяПроект = Справочники.Проекты.ПустаяСсылка();
			ТекСтрока.Налог                 = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
			ТекСтрока.РазницаВСумме         = 0;
			ТекСтрока.Статус                = Ложь;
			ТекСтрока.Тариф                 = 0;
			ТекСтрока.ТарифЗаЧас            = 0;
			ТекСтрока.ТарифПоОрг            = ТекСтрока.Сумма1;
			ТекСтрока.Строка                = "Строка";
		КонецЕсли; 	
	КонецЦикла;
	
	// 2)
	
	ТЗ2 = ТЗ.Скопировать();
	ТЗ2.Свернуть("Сотрудник, ОрганизацияЗаданияНаРаботу, ТарифПоОрг", "ЗагрузкаПлан");
	ТЗ2.Свернуть("Сотрудник", "ТарифПоОрг, ЗагрузкаПлан");
	
	// 3) 
	ТЗ.Колонки.Добавить("НМ", Новый ОписаниеТипов("Строка", Новый КвалификаторыЧисла(15, 0, ДопустимыйЗнак.Неотрицательный)));
	Для Ч=0 По ТЗ.Количество()-1 Цикл
		НайденнаяСтрока = ТЗ2.Найти(ТЗ[Ч].Сотрудник, "Сотрудник");
		
		ТЗ[Ч].НМ = Ч;
		О = Окр(НайденнаяСтрока.ТарифПоОрг / НайденнаяСтрока.ЗагрузкаПлан, 4);
		ТЗ[Ч].ТарифЗаЧас            = О;
		ТЗ[Ч].ЗагрузкаПланВСумме    = Окр(ТЗ[Ч].ЗагрузкаПлан * О, 4);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция РаспределитьВремяВМассив(КолЗаписей, Время)

	К = Окр(Время / КолЗаписей, 2);
	Сумма = 0;
	Массив = Новый Массив;
	Для Ч = 0 По КолЗаписей - 1 Цикл
		Если Ч = (КолЗаписей - 1) Тогда 
			С = Время - Сумма;
			Массив.Добавить(С);
		Иначе 
			Массив.Добавить(К);
			Сумма = Сумма + К;			
		КонецЕсли;			
	КонецЦикла;
	
	Возврат Массив;

КонецФункции

