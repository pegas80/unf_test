&НаСервере
Процедура СоздатьДокументыСервер()
	
	КРЧ  = Справочники.AzRyНастройки.КоличествоРабочихЧасов.Значение;
	
	ТаблицаWorklogs = ТаблицаWorklogs();
	ТаблицаWorklogs.Колонки.Добавить("КоличествоСтрок");
	ТаблицаWorklogs.ЗаполнитьЗначения(1, "КоличествоСтрок"); 
	
	// Изменяем формат даты
	Для каждого ТекД Из ТаблицаWorklogs Цикл
		ТекД.ЗаданияНаРаботуДата = Дата(Год(ТекД.ЗаданияНаРаботуДата), Месяц(ТекД.ЗаданияНаРаботуДата), День(ТекД.ЗаданияНаРаботуДата));	
	КонецЦикла;
	
	ТаблицаWorklogsКопия = ТаблицаWorklogs.Скопировать();
	ТаблицаWorklogsКопия.Свернуть("Сотрудник, ЗаданияНаРаботуДата", "ЗагрузкаПлан, КоличествоСтрок");
	
	НачатьТранзакцию();
	Дерево = РеквизитФормыВЗначение("ДеревоЗначений");
	Для каждого ТекСТрока Из Дерево.Строки Цикл
		
		СуммаКомпенсаций = Объект.КоличествоРабочихЧасов - ТекСТрока.ЗагрузкаПлан;
		
		Если СуммаКомпенсаций <= 0 Тогда Продолжить; КонецЕсли;
		
		Отбор = Новый Структура();
		Отбор.Вставить("Сотрудник", ТекСТрока.Сотрудник);
		Строки = ТаблицаWorklogsКопия.НайтиСтроки(Отбор);
		Если Строки.Количество() > 0 Тогда
			
			МассивСоответствие = КоефициентВремени(Строки, СуммаКомпенсаций);
			
			Индекс = 0;
			ИндексСумма = СуммаКомпенсаций;
			Для каждого ТекМассив Из Строки Цикл
				Индекс = Индекс + 1;
				ОтборПоДням = Новый Структура();
				ОтборПоДням.Вставить("ЗаданияНаРаботуДата", ТекМассив.ЗаданияНаРаботуДата);
				ОтборПоДням.Вставить("Сотрудник", ТекМассив.Сотрудник);
				НаидСтроки = ТаблицаWorklogs.НайтиСтроки(ОтборПоДням);
				
				Если НаидСтроки.Количество() > 0 Тогда
					
					Попытка
						ДокументОбъект = НаидСтроки[0].Регистратор.ПолучитьОбъект();
						
						СтрПарам = МассивСоответствие.Получить(НаидСтроки[0].ЗаданияНаРаботуДата);
						
						ИндексСумма = ИндексСумма - СтрПарам.Сумма;
						
						Если Строки.Количество() = Индекс Тогда 
							ДокументОбъект.Работы[0].ДлительностьВЧасах = ДокументОбъект.Работы[0].ДлительностьВЧасах + СтрПарам.Сумма + ИндексСумма;
						Иначе 
							ДокументОбъект.Работы[0].ДлительностьВЧасах = ДокументОбъект.Работы[0].ДлительностьВЧасах + СтрПарам.Сумма;
						КонецЕсли;	
						
						ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);					
					Исключение
						ОтменитьТранзакцию();
						Сообщить(ОписаниеОшибки());
						Возврат;
					КонецПопытки;				
					
				КонецЕсли;	
				
			КонецЦикла;	
			
		КонецЕсли;					
	
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

&НаСервере
Функция ТаблицаWorklogs()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданияНаРаботу.Сотрудник КАК Сотрудник,
		|	ЗаданияНаРаботу.Регистратор.Дата КАК ЗаданияНаРаботуДата,
		|	ЗаданияНаРаботу.Организация КАК Организация,
		|	ЗаданияНаРаботу.ЗагрузкаПлан КАК ЗагрузкаПлан,
		|	ЗаданияНаРаботу.Регистратор
		|ИЗ
		|	РегистрНакопления.ЗаданияНаРаботу КАК ЗаданияНаРаботу
		|ГДЕ
		|	ЗаданияНаРаботу.Период МЕЖДУ &Период1 И &Период2
		|	И ЗаданияНаРаботу.Регистратор.Проведен = ИСТИНА
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудник,
		|	ЗаданияНаРаботуДата";

	Запрос.УстановитьПараметр("Период1", НачалоМесяца(Объект.ДатаОтбора));
	Запрос.УстановитьПараметр("Период2", КонецМесяца(Объект.ДатаОтбора));

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();

	Возврат РезультатЗапроса;

КонецФункции

&НаСервере
Функция КоефициентВремени(МассивПарам, СуммаКомпенсаций)
	
	СуммаКоеф = 0;
	
	Соответствие = Новый Соответствие;
	
	СтруктураПарам = Новый Структура;
	СтруктураПарам.Вставить("Сотрудник", "");
	СтруктураПарам.Вставить("ЗагрузкаПлан", "");
	СтруктураПарам.Вставить("ЗаданияНаРаботуДата", "");
	СтруктураПарам.Вставить("КоличествоСтрок", "");
	СтруктураПарам.Вставить("Сумма", "");
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Сотрудник");
	ТЗ.Колонки.Добавить("ЗагрузкаПлан");
	ТЗ.Колонки.Добавить("ЗаданияНаРаботуДата");
	ТЗ.Колонки.Добавить("КоличествоСтрок");
	ТЗ.Колонки.Добавить("Сумма");
	
	Сумма = 0;
	Для каждого ТекМ Из МассивПарам Цикл
		Сумма = Сумма + ТекМ.ЗагрузкаПлан;
	КонецЦикла;
	
	ПарамСоответствие = Новый Соответствие;
	Для каждого ТекМассив Из МассивПарам Цикл
	
		СтруктураПарам = Новый Структура;
		СтруктураПарам.Вставить("Сотрудник", ТекМассив.Сотрудник);
		СтруктураПарам.Вставить("ЗагрузкаПлан", ТекМассив.ЗагрузкаПлан);
		СтруктураПарам.Вставить("ЗаданияНаРаботуДата", ТекМассив.ЗаданияНаРаботуДата);
		СтруктураПарам.Вставить("КоличествоСтрок", ТекМассив.КоличествоСтрок);
		СтруктураПарам.Вставить("Сумма", 0);
		
		Соответствие.Вставить(ТекМассив.ЗаданияНаРаботуДата, СтруктураПарам); 
		
		НовСтрока = ТЗ.Добавить();
		НовСтрока.Сотрудник           = ТекМассив.Сотрудник;
		НовСтрока.ЗагрузкаПлан        = ТекМассив.ЗагрузкаПлан;
		НовСтрока.ЗаданияНаРаботуДата = ТекМассив.ЗаданияНаРаботуДата;
		НовСтрока.КоличествоСтрок     = ТекМассив.КоличествоСтрок;
	
	КонецЦикла;
	
	СуммаКоеф = ТЗ.Итог("ЗагрузкаПлан");
	
	Для каждого ТекТЗ Из ТЗ Цикл
		
		ТекТЗ.Сумма = ТекТЗ.ЗагрузкаПлан / СуммаКоеф * СуммаКомпенсаций;
		
	КонецЦикла;
	
	Для каждого ТекТЗ Из Соответствие Цикл
		
		ТекТЗ.Значение.Сумма = Окр(ТекТЗ.Значение.ЗагрузкаПлан / СуммаКоеф * СуммаКомпенсаций, 4);  
		
	КонецЦикла;	
	
	Возврат Соответствие;
	
КонецФункции

&НаСервере
Процедура СохранениеДанныхWorklogsРазница()
	
	Если ПроверкаJiraWorklogsРазличия() Тогда
		
		НачатьТранзакцию();
		Попытка
			
			Для каждого ТекСтрока Из Объект.ТабличнаяЧастьРазница Цикл
				
				НаборЗаписей = РегистрыСведений.JiraWorklogsРазличия.СоздатьНаборЗаписей(); 
				
				НаборЗаписей.Отбор.Период.Установить(Объект.ДатаОтбора);
				НаборЗаписей.Отбор.Сотрудник.Установить(ТекСтрока.Сотрудники); 
				
				НоваяЗапись = НаборЗаписей.Добавить(); 
				НоваяЗапись.Период       = Объект.ДатаОтбора;
				НоваяЗапись.Сотрудник    = ТекСтрока.Сотрудники;
				
				НоваяЗапись.Зарплата               = ТекСтрока.Тариф;
				НоваяЗапись.ТарифЗаЧас             = ТекСтрока.ТарифЗаЧас;
				НоваяЗапись.КоличествоРабочихЧасов = Объект.КоличествоРабочихЧасов;
				НоваяЗапись.КоличествоРабочихДней  = Объект.КоличествоРабочихДнейВМесяце;
				НоваяЗапись.РазницаВЧасах          = ТекСтрока.Worklogs - Объект.КоличествоРабочихЧасов;
				НоваяЗапись.РазницаЗарплата        = (ТекСтрока.Worklogs - Объект.КоличествоРабочихЧасов) * ТекСтрока.ТарифЗаЧас;
				НоваяЗапись.РазницаВПроцентах      = 100 * (ТекСтрока.Worklogs - Объект.КоличествоРабочихЧасов) / Объект.КоличествоРабочихЧасов;
				
				НаборЗаписей.Записать(); 
				
			КонецЦикла;
			
		Исключение
			ОтменитьТранзакцию();
			Сообщить(ОписаниеОшибки());
			Возврат;
		КонецПопытки;
		
		ЗафиксироватьТранзакцию();
		
	КонецЕсли;
	
КонецПроцедуры 	

&НаСервере
Функция ПроверкаJiraWorklogsРазличия()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	JiraWorklogsРазличия.Период,
		|	JiraWorklogsРазличия.Сотрудник,
		|	JiraWorklogsРазличия.Зарплата,
		|	JiraWorklogsРазличия.ТарифЗаЧас,
		|	JiraWorklogsРазличия.КоличествоРабочихЧасов,
		|	JiraWorklogsРазличия.КоличествоРабочихДней,
		|	JiraWorklogsРазличия.РазницаВЧасах,
		|	JiraWorklogsРазличия.РазницаЗарплата,
		|	JiraWorklogsРазличия.РазницаВПроцентах
		|ИЗ
		|	РегистрСведений.JiraWorklogsРазличия КАК JiraWorklogsРазличия
		|ГДЕ
		|	JiraWorklogsРазличия.Период МЕЖДУ &Период1 И &Период2";

	Запрос.УстановитьПараметр("Период1", НачалоМесяца(Объект.ДатаОтбора));
	Запрос.УстановитьПараметр("Период2", КонецМесяца(Объект.ДатаОтбора));

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();

	Возврат ?(РезультатЗапроса.Количество() = 0, Истина, Ложь);

