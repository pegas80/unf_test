&НаКлиенте
Процедура ЗаменаЗначенияНаДругого(СтрокаТабличнойЧасти, ТекущиеДанные)
	
	Для каждого ТекСтрока Из ТекущиеДанные Цикл
		ТекСтрока.Сотрудник             = СтрокаТабличнойЧасти.Сотрудник;
		
		Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.ЗаказПокупателя) Тогда 
			ТекСтрока.ЗаказПокупателя = СтрокаТабличнойЧасти.ЗаказПокупателя;
		КонецЕсли;
		
		ПРКТ = ПроекИзДокументаЗаказа(СтрокаТабличнойЧасти.ЗаказПокупателя);
		Если ЗначениеЗаполнено(ПРКТ) Тогда 
			ТекСтрока.ЗаказПокупателяПроект = ПРКТ;
		КонецЕсли;

		ТекСтрока.Статус = Истина;
		Если ТекСтрока.ПолучитьЭлементы().Количество() <> 0 Тогда
			ЗаменаЗначенияНаДругого(СтрокаТабличнойЧасти, ТекСтрока.ПолучитьЭлементы());	
		КонецЕсли;	
	КонецЦикла;	
	
