Процедура ДеревоЗначенийЗаказПокупателяНовыйОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Если Не ЗначениеЗаполнено(Элементы.ДеревоЗначений.ТекущиеДанные.ОрганизацияЗаданияНаРаботу) Тогда
		СтандартнаяОбработка = Ложь;
	Иначе 	
		Если ЗначениеЗаполнено(Элементы.ДеревоЗначений.ТекущиеДанные.ЗаказПокупателя) Тогда
			СтандартнаяОбработка = Ложь;
		КонецЕсли; 	
	КонецЕсли; 
КонецПроцедуры


Функция УННомер(Н)

	НС = "AR00-JR99999";
	Ч = 0;
	Для Х = 1 По 99999 Цикл
		
		НомерД = Лев(Н, 7) + Формат(Х, "ЧЦ=5; ЧВН=; ЧГ=");
		
		Если ЗапросУнНомер(НомерД) Тогда 
			Возврат НомерД;
		КонецЕсли;	
	
	КонецЦикла;

	Возврат НС;
	
КонецФункции

Функция ЗапросУнНомер(НомерД)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаРаботу.Номер,
		|	ЗаданиеНаРаботу.Ссылка
		|ИЗ
		|	Документ.ЗаданиеНаРаботу КАК ЗаданиеНаРаботу
		|ГДЕ
		|	ЗаданиеНаРаботу.Номер = &Номер";

	Запрос.УстановитьПараметр("Номер", НомерД);

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() = 0 Тогда 
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;

КонецФункции 
 
 

