Перем КРДВ;

&НаСервере
Перем КРЧ;


////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

&НаСервере
Процедура СформироватьНаСервер()
	
	СформироватьСервер();
	
КонецПроцедуры	

&НаСервере
Процедура СформироватьСервер(Результат = Неопределено)
	
	КРДВ = AzRyFunctions.КоличествоРабочихДнейВМесяце(Год(Объект.ДатаОтбора), НачалоМесяца(Объект.ДатаОтбора), КонецМесяца(Объект.ДатаОтбора));
	КРЧ  = Справочники.AzRyНастройки.КоличествоРабочихЧасов.Значение;
	Объект.КоличествоРабочихДнейВМесяце = КРДВ;
	Объект.КоличествоРабочихЧасов       = КРДВ * КРЧ;
	
	Если Результат = Неопределено Тогда 
		
		РезультатТЗ = AzRyFunctions.ВсеАктивныеСотрудники(Объект.ДатаОтбора, Справочники.AzRyНастройки.НачислениеТарифнаяСтавка.Значение);
		
		СотрудникиИзДжира = РеквизитФормыВЗначение("Объект").СотрудникиИзДжира(Объект.ДатаОтбора);		
		
		//// FOR DEBUG --
		//СотрудникиИзДжира = Новый СписокЗначений;
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("0000000147"));  //თეო
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000109"));
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000075")); // ზურაბ ჯანიაშვილი
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000045")); //მიხეილ აბულაშვილი  
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000025")); //mamulashvili 
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000049")); // Ника 
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000406")); // akaki 
		//СотрудникиИзДжира.Добавить(Справочники.Сотрудники.НайтиПоКоду("000000471")); // akaki 
		РеквизитФормыВЗначение("Объект").ФилтрТЗ(РезультатТЗ, "Сотрудник", СотрудникиИзДжира);
		//// FOR DEBUG --
		
		НДФЛ = Справочники.AzRyНастройки.УдержаниеНДФЛ.Значение.СтавкаНДФЛ/100;
		
		// 2) 
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		Запрос.Текст = "ВЫБРАТЬ
		               |	АктивныеСотрудники.Сотрудник КАК Сотрудник,
		               |	АктивныеСотрудники.Организация КАК Организация,
		               |	АктивныеСотрудники.Сумма КАК Сумма
		               |ПОМЕСТИТЬ ВременнаяТаблицаАктивныеСотрудники
		               |ИЗ
		               |	&АктивныеСотрудники КАК АктивныеСотрудники
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ЗаданияНаРаботу.Сотрудник КАК Сотрудник,
		               |	ЗаданияНаРаботу.ЗаказПокупателя.Организация КАК Организация,
		               |	ЗаданияНаРаботу.AzRyПроект КАК ЗаказПокупателяПроект,
		               |	ЗаданияНаРаботу.ЗагрузкаПлан КАК ЗагрузкаПлан,
		               |	0 КАК РазницаВСумме,
		               |	ЗаданияНаРаботу.Организация КАК ОрганизацияЗаданияНаРаботу,
		               |	ЗаданияНаРаботу.Регистратор КАК Регистратор,
		               |	ЗаданияНаРаботу.ЗаказПокупателя КАК ЗаказПокупателя,
		               |	ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка) КАК ЗаказПокупателяНовый,
		               |	&Налог КАК Налог,
		               |	ЛОЖЬ КАК Статус,
		               |	ВЫРАЗИТЬ(ЗаданияНаРаботу.ЗагрузкаПлан * (ВЫРАЗИТЬ(ПлановыеНачисленияИУдержанияСрезПоследних_ТарифОрг.Сумма / &КРДВ / &КЧР КАК ЧИСЛО(15, 4))) КАК ЧИСЛО(15, 4)) КАК ЗагрузкаПланВСумме,
		               |	ЕСТЬNULL(ВЫРАЗИТЬ(ПлановыеНачисленияИУдержанияСрезПоследних_ТарифОрг.Сумма / ЗаданияНаРаботу.ЗагрузкаПлан КАК ЧИСЛО(15, 4)), 0) КАК ТарифЗаЧас,
		               |	ЕСТЬNULL(ПлановыеНачисленияИУдержанияСрезПоследних.Сумма, 0) КАК Тариф,
		               |	ЕСТЬNULL(ПлановыеНачисленияИУдержанияСрезПоследних_ТарифОрг.Сумма, 0) КАК ТарифПоОрг,
		               |	0 КАК ЗагрузкаПланТребуется,
		               |	0 КАК ЗагрузкаПланТребуетсяДобавить,
		               |	""Строка"" КАК Строка
		               |ПОМЕСТИТЬ ТЗ1
		               |ИЗ
		               |	РегистрНакопления.ЗаданияНаРаботу КАК ЗаданияНаРаботу
		               |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		               |			ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник КАК Сотрудник,
		               |			СУММА(ЕСТЬNULL(ПлановыеНачисленияИУдержанияСрезПоследних.Сумма, 0)) КАК Сумма
		               |		ИЗ
		               |			РегистрСведений.ПлановыеНачисленияИУдержания.СрезПоследних(&Дата, ВидНачисленияУдержания = &ВидНачисленияУдержания) КАК ПлановыеНачисленияИУдержанияСрезПоследних
		               |		ГДЕ
		               |			ПлановыеНачисленияИУдержанияСрезПоследних.Актуальность
		               |		
		               |		СГРУППИРОВАТЬ ПО
		               |			ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник) КАК ПлановыеНачисленияИУдержанияСрезПоследних
		               |		ПО ЗаданияНаРаботу.Сотрудник = ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПлановыеНачисленияИУдержания.СрезПоследних(
		               |				&Дата,
		               |				ВидНачисленияУдержания = &ВидНачисленияУдержания
		               |					И ТИПЗНАЧЕНИЯ(Регистратор) <> ТИП(Документ.Увольнение)) КАК ПлановыеНачисленияИУдержанияСрезПоследних_ТарифОрг
		               |		ПО ЗаданияНаРаботу.Сотрудник = ПлановыеНачисленияИУдержанияСрезПоследних_ТарифОрг.Сотрудник
		               |			И ЗаданияНаРаботу.Организация = ПлановыеНачисленияИУдержанияСрезПоследних_ТарифОрг.Организация
		               |ГДЕ
		               |	ЗаданияНаРаботу.Период МЕЖДУ &Период1 И &Период2
		               |	И ЗаданияНаРаботу.Сотрудник В
		               |			(ВЫБРАТЬ
		               |				ВременнаяТаблицаАктивныеСотрудники.Сотрудник
		               |			ИЗ
		               |				ВременнаяТаблицаАктивныеСотрудники)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТЗ2.Сотрудник КАК Сотрудник,
		               |	ТЗ2.Организация КАК Организация,
		               |	ТЗ2.ОрганизацияЗаданияНаРаботу КАК ОрганизацияЗаданияНаРаботу,
		               |	ТЗ2.ЗаказПокупателяПроект КАК ЗаказПокупателяПроект,
		               |	ТЗ2.ЗагрузкаПлан КАК ЗагрузкаПлан,
		               |	ТЗ2.РазницаВСумме КАК РазницаВСумме,
		               |	ТЗ2.Налог КАК Налог,
		               |	ТЗ2.Регистратор КАК Регистратор,
		               |	ТЗ2.ЗаказПокупателя КАК ЗаказПокупателя,
		               |	ТЗ2.ЗаказПокупателяНовый КАК ЗаказПокупателяНовый,
		               |	ТЗ2.Статус КАК Статус,
		               |	ТЗ2.ЗагрузкаПланВСумме КАК ЗагрузкаПланВСумме,
		               |	ТЗ2.ТарифЗаЧас КАК ТарифЗаЧас,
		               |	ТЗ2.Тариф КАК Тариф,
		               |	ВЫБОР
		               |		КОГДА ТЗ2.ТарифПоОрг = 0
		               |			ТОГДА ЕСТЬNULL(ВременнаяТаблицаАктивныеСотрудники.Сумма, 0)
		               |		ИНАЧЕ ТЗ2.ТарифПоОрг
		               |	КОНЕЦ КАК ТарифПоОрг,
		               |	ТЗ2.ЗагрузкаПланТребуется КАК ЗагрузкаПланТребуется,
		               |	ТЗ2.ЗагрузкаПланТребуетсяДобавить КАК ЗагрузкаПланТребуетсяДобавить,
		               |	ВременнаяТаблицаАктивныеСотрудники.Сотрудник КАК Сотрудник1,
		               |	ВременнаяТаблицаАктивныеСотрудники.Организация КАК Организация1,
		               |	ВременнаяТаблицаАктивныеСотрудники.Сумма КАК Сумма1,
		               |	ТЗ2.Строка КАК Строка
		               |ИЗ
		               |	ТЗ1 КАК ТЗ2
		               |		ПОЛНОЕ СОЕДИНЕНИЕ ВременнаяТаблицаАктивныеСотрудники КАК ВременнаяТаблицаАктивныеСотрудники
		               |		ПО ТЗ2.Сотрудник = ВременнаяТаблицаАктивныеСотрудники.Сотрудник
		               |			И ТЗ2.ОрганизацияЗаданияНаРаботу = ВременнаяТаблицаАктивныеСотрудники.Организация
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	Сотрудник,
		               |	ТЗ2.Организация";
		
		Запрос.УстановитьПараметр("АктивныеСотрудники", РезультатТЗ);
		Запрос.УстановитьПараметр("Период1", НачалоМесяца(Объект.ДатаОтбора));
		Запрос.УстановитьПараметр("Период2", КонецМесяца(Объект.ДатаОтбора));
		Запрос.УстановитьПараметр("Сотрудник", РезультатТЗ.ВыгрузитьКолонку("Сотрудник"));
		Запрос.УстановитьПараметр("Дата", КонецМесяца(Объект.ДатаОтбора));
		Запрос.УстановитьПараметр("ВидНачисленияУдержания", Справочники.AzRyНастройки.НачислениеТарифнаяСтавка.Значение); 
		Запрос.УстановитьПараметр("Налог", Справочники.AzRyНастройки.УдержаниеНДФЛ.Значение);
		Запрос.УстановитьПараметр("КРДВ", КРДВ);
		Запрос.УстановитьПараметр("КЧР", КРЧ);
		
		Результат = Запрос.Выполнить().Выгрузить();
		ОбработкаТаблицы(Результат);
		
		//// FOR DEBUG --
		РеквизитФормыВЗначение("Объект").ФилтрТЗ(Результат, "Сотрудник", СотрудникиИзДжира);
		//// FOR DEBUG --
			
	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ2.ЗаказПокупателяПроект,
	               |	ТЗ2.Сотрудник КАК Сотрудник,
	               |	ТЗ2.Организация КАК Организация,
	               |	ТЗ2.ОрганизацияЗаданияНаРаботу КАК ОрганизацияЗаданияНаРаботу,
	               |	ТЗ2.ЗагрузкаПлан КАК ЗагрузкаПлан,
	               |	ТЗ2.ЗагрузкаПланВСумме КАК ЗагрузкаПланВСумме,
	               |	ТЗ2.РазницаВСумме КАК РазницаВСумме,
	               |	ТЗ2.Тариф,
	               |	ТЗ2.ТарифПоОрг КАК ТарифПоОрг,
	               |	ТЗ2.Налог,
	               |	ТЗ2.Регистратор,
	               |	ТЗ2.ТарифЗаЧас,
	               |	ТЗ2.ЗаказПокупателя КАК ЗаказПокупателя,
	               |	ТЗ2.ЗаказПокупателяНовый КАК ЗаказПокупателяНовый,
	               |	ТЗ2.Статус,
	               |	ТЗ2.ЗагрузкаПланТребуется,
	               |	ТЗ2.ЗагрузкаПланТребуетсяДобавить,
	               |	ТЗ2.НМ,
	               |	ТЗ2.Строка
	               |ПОМЕСТИТЬ ТЗ2
	               |ИЗ
	               |	&ТЗ КАК ТЗ2
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ3.ЗаказПокупателяПроект,
	               |	ТЗ3.Сотрудник КАК Сотрудник,
	               |	ТЗ3.Организация КАК Организация,
	               |	ТЗ3.ОрганизацияЗаданияНаРаботу КАК ОрганизацияЗаданияНаРаботу,
	               |	ТЗ3.ЗагрузкаПлан КАК ЗагрузкаПлан,
	               |	ТЗ3.ЗагрузкаПланВСумме КАК ЗагрузкаПланВСумме,
	               |	ТЗ3.РазницаВСумме КАК РазницаВСумме,
	               |	ТЗ3.Тариф,
	               |	ТЗ3.ТарифПоОрг КАК ТарифПоОрг,
	               |	ТЗ3.Налог,
	               |	ТЗ3.Регистратор,
	               |	ТЗ3.ТарифЗаЧас,
	               |	ТЗ3.ЗаказПокупателя КАК ЗаказПокупателя,
	               |	ТЗ3.ЗаказПокупателяНовый КАК ЗаказПокупателяНовый,
	               |	ТЗ3.Статус,
	               |	ТЗ3.ЗагрузкаПланТребуется,
	               |	ТЗ3.ЗагрузкаПланТребуетсяДобавить,
	               |	ТЗ3.НМ,
	               |	ТЗ3.Строка,
	               |	ЛОЖЬ КАК Изменен,
				   |	0 КАК Н
	               |ИЗ
	               |	ТЗ2 КАК ТЗ3
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Сотрудник,
	               |	Организация
	               |ИТОГИ
	               |	СУММА(ЗагрузкаПлан),
	               |	СУММА(ЗагрузкаПланВСумме),
	               |	СУММА(РазницаВСумме)
	               |ПО
	               |	Сотрудник,
	               |	ОрганизацияЗаданияНаРаботу,
	               |	ЗаказПокупателя";
	
	Запрос.УстановитьПараметр("ТЗ", Результат);
		
	РезультатСИерархией = Запрос.Выполнить();
	ДеревоТЗ = РезультатСИерархией.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией); 
	
	Дерево = РеквизитФормыВЗначение("ДеревоЗначений");
	Дерево = ДеревоТЗ;
	Элементы.ДеревоЗначений.Обновить();
	
	Объект.ТабличнаяЧастьСотрудники.Очистить();
	Объект.ТабличнаяЧастьРазница.Очистить();
	
	Н = 0;
	Для каждого ТекДерево Из Дерево.Строки Цикл // თანამშრომლის ციკლი
		Н = Н + 1;
		ЗагрузкаПланТребуется = 0;
		КешТариф      = Новый Соответствие;
		КешТарифЗаЧас = Новый Соответствие;
		ТарифЗаЧас    = СуммаТарифаПоОрганизациям(ТекДерево); //ТекДерево.Строки[0].Строки[0].Строки[0].ТарифПоОрг / ТекДерево.ЗагрузкаПлан;  
		
		ТекДерево.Н = Н;
		ТекДерево.РазницаВСумме= Неопределено;
		Для каждого ТекДерево1 Из ТекДерево.Строки Цикл // ორგანიზაციის ციკლი
			// dajameba organizaciis mixedviT
			ТекДерево1.ТарифПоОрг = ТекДерево1.Строки[0].Строки[0].ТарифПоОрг;
			//ТекДерево1.ТарифЗаЧас = ТекДерево1.Строки[0].Строки[0].ТарифЗаЧас;
			ТекДерево1.ТарифЗаЧас = ТарифЗаЧас;
			
			КешТариф.Вставить(ТекДерево1.ОрганизацияЗаданияНаРаботу, ТекДерево1.Строки[0].Строки[0].ТарифПоОрг);
			КешТарифЗаЧас.Вставить(ТекДерево1.ОрганизацияЗаданияНаРаботу, ТекДерево1.Строки[0].Строки[0].ТарифЗаЧас);
			
			Для каждого ТекДерево2 Из ТекДерево1.Строки Цикл
				ТекДерево2.ТарифПоОрг         = ТекДерево2.Строки[0].ТарифПоОрг;
				//ТекДерево2.ТарифЗаЧас         = ТекДерево2.Строки[0].ТарифЗаЧас; 
				//ТекДерево2.Тариф              = ТекДерево2.Строки[0].Тариф;
				ТекДерево2.ТарифЗаЧас         = ТарифЗаЧас; 
				ТекДерево2.ЗагрузкаПланВСумме    = ТарифЗаЧас * ТекДерево2.ЗагрузкаПлан;
				ТекДерево2.ЗаказПокупателяПроект = ТекДерево2.Строки[0].ЗаказПокупателяПроект;
				ТекДерево2.ОрганизацияЗаданияНаРаботу           = ТекДерево2.Строки[0].ОрганизацияЗаданияНаРаботу;
				//ТекДерево2.РазницаВСумме 	     = ТекДерево2.ЗагрузкаПланВСумме - ТекДерево2.ТарифПоОрг; 
			КонецЦикла;
			
			ТекДерево1.ЗагрузкаПланТребуется         = ?(ТекДерево1.ТарифПоОрг=0, 0, Окр(ТекДерево1.ТарифПоОрг / ТекДерево1.ТарифЗаЧас, 4));
			ТекДерево1.ЗагрузкаПланТребуетсяДобавить = ТекДерево1.ЗагрузкаПланТребуется - ТекДерево1.ЗагрузкаПлан;
			ЗагрузкаПланТребуется = ЗагрузкаПланТребуется + ТекДерево1.ЗагрузкаПланТребуется;
		КонецЦикла;
		
		ТекДерево.ТарифПоОрг         	 = ИтогИзКеша(КешТариф);
		//ТекДерево.ТарифЗаЧас         	 = КешТарифЗаЧас[ТекДерево1.ОрганизацияЗаданияНаРаботу];
		ТекДерево.ТарифЗаЧас         	 = ТарифЗаЧас;
		ТекДерево.ЗагрузкаПланТребуется  = ЗагрузкаПланТребуется;
