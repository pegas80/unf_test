		////ТекДерево.Тариф              = ТекДерево.Строки[0].Тариф;
		//ТекДерево1.ЗагрузкаПланВСумме = ТекДерево1.ТарифЗаЧас * ТекДерево1.ЗагрузкаПлан; 
		ТекДерево.ЗагрузкаПланТребуетсяДобавить = Объект.КоличествоРабочихЧасов - ТекДерево.ЗагрузкаПлан;
		ТекДерево.РазницаВСумме 	 = ТекДерево.ЗагрузкаПланВСумме - ТекДерево.ТарифПоОрг;
		Если ТекДерево.ТарифПоОрг = 0 Тогда 
			Сообщить("№ " + Н + " - თანამშრომელს: (" + ТекДерево.Сотрудник.Наименование + ") არ გააჩნია ხელფასი!", СтатусСообщения.ОченьВажное);
