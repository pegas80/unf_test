&НаСервере
Функция Обработка(Кеш)

	Изменен = Ложь;
	КРЧ = Справочники.AzRyНастройки.КоличествоРабочихЧасов.Значение;
	
	Для каждого ТекСтрока Из Кеш Цикл
		// Tu dro romelic unda gadanawildes ar arsebobs mashin gamovdivart
		Если ТекСтрока.Значение.СПЗначений1.Количество() = 0 Тогда 
			Продолжить;
		Иначе
			// Tu gadasanawilebeli dro aris magram sad gadanawildes isini ar arseboben mashin shemdegze gadavdivarT
			Если ТекСтрока.Значение.СПЗначений2.Количество() = 0 Тогда 
				Продолжить;
			КонецЕсли;
			
			СПЗначений1 = ТекСтрока.Значение["СПЗначений1"];
			СПЗначений2 = ТекСтрока.Значение["СПЗначений2"];
			
			Парам = СуммаИДокументыЗадНаРаботу(СПЗначений1);
			
			СуммаВремени = Парам.СуммаВремени;
			ИзбытокСумма = 0;
			Избыток      = 0;
			Для каждого ТекОргПрием Из СПЗначений2 Цикл
				
				// For debug --
				//Если ТекОргПрием.Значение.ОрганизацияЗаданияНаРаботу = Справочники.Организации.НайтиПоКоду("00-000004") Тогда Продолжить; КонецЕсли;	
								
				ЗагрузкаПланТребуетсяДобавитьОстаток = 0;
				
				// Tu Organizacias gegmiuri saatebi gadavsebuli aqvs, mashin gadavdivart shemdeg organizaciaze 
				Если ТекОргПрием.Значение.ЗагрузкаПланТребуетсяДобавить <= 0 Тогда Продолжить; КонецЕсли;
				
				ЗагрузкаПланТребуетсяДобавитьОстаток = ТекОргПрием.Значение.ЗагрузкаПланТребуетсяДобавить;
				
				Для каждого ТекДерегоОтдача Из Парам.Массив Цикл
					
					Если ЗагрузкаПланТребуетсяДобавитьОстаток = 0 Тогда Продолжить; КонецЕсли;
					
					// Tu xelfasi shevsebulia eseigi oranizaciis sheсvla am worklogze ukve ganxorcielda
					Если Не ТекДерегоОтдача.ТарифПоОрг = 0 Тогда Продолжить; КонецЕсли;
					
					Если ТекДерегоОтдача.ЗагрузкаПлан <= ЗагрузкаПланТребуетсяДобавитьОстаток Тогда 
						ТекДерегоОтдача.ОрганизацияЗаданияНаРаботу = ТекОргПрием.Значение.ОрганизацияЗаданияНаРаботу;
						ЗагрузкаПланТребуетсяДобавитьОстаток = ЗагрузкаПланТребуетсяДобавитьОстаток - ТекДерегоОтдача.ЗагрузкаПлан;
						ТекДерегоОтдача.Статус               = Истина; 
						ТекДерегоОтдача.ТарифПоОрг           = ТекОргПрием.Значение.ТарифПоОрг;
						Изменен = Истина;
						Если ИзбытокСумма <> 0 Тогда 
							ПерераспределитьВремя(ИзбытокСумма, ТекДерегоОтдача.ЗагрузкаПлан);
						КонецЕсли;	
					Иначе
						Избыток = (ТекДерегоОтдача.ЗагрузкаПлан - ЗагрузкаПланТребуетсяДобавитьОстаток);
						ИзбытокСумма = ИзбытокСумма + Избыток;
						ТекДерегоОтдача.ОрганизацияЗаданияНаРаботу = ТекОргПрием.Значение.ОрганизацияЗаданияНаРаботу;
						ТекДерегоОтдача.ЗагрузкаПлан 		 = ЗагрузкаПланТребуетсяДобавитьОстаток;
						ЗагрузкаПланТребуетсяДобавитьОстаток = 0;
						ТекДерегоОтдача.Статус               = Истина;
						ТекДерегоОтдача.ТарифПоОрг           = ТекОргПрием.Значение.ТарифПоОрг;
						Изменен = Истина;
					КонецЕсли;	
										
				КонецЦикла;		
			КонецЦикла;		
		КонецЕсли;		
	КонецЦикла;	
	
	Возврат Изменен;
	
КонецФункции

