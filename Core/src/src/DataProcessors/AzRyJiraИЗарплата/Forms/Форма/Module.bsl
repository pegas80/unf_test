КонецФункции

&НаСервере
Функция СоздатьМассивИтерацийИзВремены(Время)

	В = Время;
	К = Время / 24; 
	С = Цел(К)+1;
	Массив = Новый Массив;
	Для Ч = 0 По С-1 Цикл
		Если Ч = (С - 1) Тогда  
			Массив.Добавить(В);
		Иначе 
			Массив.Добавить(24);
			В = В - 24;
		КонецЕсли;		
	КонецЦикла;

	Возврат Массив;
	
КонецФункции

&НаСервере
Процедура СгенерироватьТЗДокументаЗаданиеНаРаботу(ТекСтрока, НовыйДокумент, Времья, ЗакаПокупателя, Проект = Неопределено)
	
	ДТ = НовыйДокумент.Дата;
	ЗПНоменклатура = Справочники.Номенклатура.НайтиПоКоду("11-00001636");
	
	НоваяСтрока = НовыйДокумент.Работы.Добавить(); 	
	НоваяСтрока.Заказчик       = ЗакаПокупателя;
	НоваяСтрока.AzRyПроект     = Проект;
	НоваяСтрока.ВидРабот       = Справочники.AzRyНастройки.ЗаданиеНаРаботуВидРабот.Значение;  
	НоваяСтрока.Номенклатура   = ЗПНоменклатура; 
	НоваяСтрока.ДатаНачала     = Дата(Год(ДТ),Месяц(ДТ),День(ДТ),10,00,00);
	НоваяСтрока.ДатаОкончания  = НоваяСтрока.ДатаНачала + Времья * 3600;
	НоваяСтрока.Трудоемкость   = Времья;		
	
КонецПроцедуры

&НаСервере
Процедура ПерераспределитьВремя(ИзбытокСумма, ЗагрузкаПлан)

	Если (ЗагрузкаПлан + ИзбытокСумма) > 24 Тогда 
		К = ((ЗагрузкаПлан + ИзбытокСумма) - 24);
		ЗагрузкаПлан = ЗагрузкаПлан + К;
		ИзбытокСумма = ИзбытокСумма - К;	
	Иначе 
		ЗагрузкаПлан = ЗагрузкаПлан + ИзбытокСумма;
		ИзбытокСумма = 0;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Функция МассивВремены(Время, ДерегоЗначения)
		
	К = ?(ДерегоЗначения.ЗагрузкаПлан = 0, 1, (ДерегоЗначения.ЗагрузкаПланТребуетсяДобавить / ДерегоЗначения.ЗагрузкаПлан));
	
	Количество = ДерегоЗначения.Строки.Количество();
	
	М = Новый Массив;
	Соот = Новый Соответствие;
	Сумма = 0;	
	Для Ч = 0 По Количество-1 Цикл
		
		Если (Не ЗначениеЗаполнено(ДерегоЗначения.Строки[Ч].ЗаказПокупателя)) Тогда 
			ВызватьИсключение "თანამშრომელს (" + ДерегоЗначения.Строки[Ч].Сотрудник + ") არ აქვს მითითებული მყიდველის შეკვეთა."; 
		КонецЕсли;
		
		Если Ч = Количество-1 Тогда
			Соот.Вставить(ДерегоЗначения.Строки[Ч].ЗаказПокупателя, Окр(Время-Сумма, 2));
		Иначе 	
			Сумма = Сумма + Окр((ДерегоЗначения.Строки[Ч].ЗагрузкаПлан * К), 2);
			Соот.Вставить(ДерегоЗначения.Строки[Ч].ЗаказПокупателя, Окр((ДерегоЗначения.Строки[Ч].ЗагрузкаПлан * К), 2));
		КонецЕсли; 	
	КонецЦикла;
	
	Возврат Соот;

КонецФункции

