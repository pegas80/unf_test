								Изменен = Истина;
								Массив[Ч].Изменен = Истина;
							КонецЕсли; 	
						КонецЦикла;		
					КонецЦикла;						
				КонецЦикла;
				
			КонецЕсли;		
		КонецЦикла;
		
	Исключение
		ОтменитьТранзакцию();
		Сообщить(ОписаниеОшибки());
		ВызватьИсключение;
	КонецПопытки;	
	
	ЗафиксироватьТранзакцию();
	
	Возврат Изменен;
	
