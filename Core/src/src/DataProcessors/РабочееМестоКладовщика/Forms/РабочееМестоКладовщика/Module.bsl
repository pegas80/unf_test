Процедура СоздатьДокументыПередачи(Команда)
	СоздатьДокументыПередачиНаСервере();
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументыПередачиНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Товары.Ячейка,
	               |	Товары.Номенклатура,
	               |	Товары.Заказ,
	               |	Товары.Передать КАК Количество,
	               |	Товары.Характеристика,
	               |	Товары.ОК
	               |ПОМЕСТИТЬ Товары
	               |ИЗ
	               |	&Остатки КАК Товары
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Товары.Ячейка КАК Ячейка,
	               |	Товары.Номенклатура,
	               |	Товары.Заказ КАК ЗаказПокупателя,
	               |	Товары.Количество КАК Количество,
	               |	Товары.Характеристика,
	               |	Товары.Количество КАК Резерв
	               |ИЗ
	               |	Товары КАК Товары
	               |ГДЕ
	               |	Товары.ОК
	               |ИТОГИ
	               |	СУММА(Количество)
	               |ПО
	               |	Ячейка";
	Запрос.УстановитьПараметр("Остатки", Остатки.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	
	НачатьТранзакцию();
	
	обходПоЯчейкам = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Отказ = Ложь;
	
	Пока обходПоЯчейкам.Следующий() Цикл
		
		Если обходПоЯчейкам.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СоздатьИПровестиПеремещение(обходПоЯчейкам, Отказ);
		
		Если Отказ Тогда
			ОтменитьТранзакцию();
			Возврат;
		КонецЕсли;
		
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();
	
	ОбновитьНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьИПровестиПеремещение(обходПоЯчейкам, Отказ)
	
	новыйДокумент = Документы.ПеремещениеЗапасов.СоздатьДокумент();
	
	новыйДокумент.Организация = Справочники.Организации.НайтиПоКоду("00-000001"); ///!!!!!!!!!!!!!!!!
	новыйДокумент.ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.Перемещение;
	новыйДокумент.СтруктурнаяЕдиница = Склад;
	новыйДокумент.Ячейка = обходПоЯчейкам.Ячейка;
	новыйДокумент.СтруктурнаяЕдиницаПолучатель = Получатель;
	//новыйДокумент.ДокументОснование = ;
	//новыйДокумент.ЗаказПокупателя = текущийЗаказ;
	новыйДокумент.Автор = Пользователи.ТекущийПользователь();
	новыйДокумент.Дата = ТекущаяДата();
	новыйДокумент.ПоложениеЗаказаПокупателя = Перечисления.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти;
	
	выборка = обходПоЯчейкам.Выбрать();
	
	Пока выборка.следующий() Цикл
		
		Если выборка.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = новыйДокумент.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, выборка);
		НоваяСтрока.ЕдиницаИзмерения = выборка.Номенклатура.ЕдиницаИзмерения;
			
	КонецЦикла;
	
	Если новыйДокумент.Запасы.Количество() > 0 Тогда
		
		Попытка
			новыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
		    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки(),,,,Отказ);
		КонецПопытки;
		
	КонецЕсли;
		
	ОбновитьНаСервере();
	
КонецПроцедуры

