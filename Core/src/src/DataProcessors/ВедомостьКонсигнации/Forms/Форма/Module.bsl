
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НачалоПериода	= НачалоМесяца(ТекущаяДата());
	КонецПериода	= ТекущаяДата();
	
	ЗагрузитьВодители();
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоПериодаПриИзменении(Элемент)
	ЗагрузитьВодители();
КонецПроцедуры

&НаКлиенте
Процедура КонецПериодаПриИзменении(Элемент)
	ЗагрузитьВодители();
КонецПроцедуры

&НаКлиенте
Процедура Печать(Команда)

	ОчиститьСообщения();
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.Водители.НайтиСтроки(Новый Структура("Пометка", Истина)).Количество() = 0 Тогда
		Предупреждение("არ არის მონიშნული არცერთი მძღოლი!", 60);
		Возврат;
	КонецЕсли;
	
	ТабДок = Новый ТабличныйДокумент;
	
	ТабДок.ОтображатьСетку		= Ложь;
	ТабДок.Защита				= Ложь;
	ТабДок.ТолькоПросмотр		= Ложь;
	ТабДок.ОтображатьЗаголовки	= Ложь;
	ТабДок.АвтоМасштаб			= Истина;
	ТабДок.ПолеСверху			= 5;
	ТабДок.ПолеСлева			= 5;
	ТабДок.ПолеСнизу			= 5;
	ТабДок.ПолеСправа			= 5;
	ТабДок.ОриентацияСтраницы	= ОриентацияСтраницы.Ландшафт;
	ТабДок.АвтоМасштаб = Истина;
	
	ПечатьНаСервере(ТабДок);
	ТабДок.Показать();//"კონსიგნაციის უწყისი"
	
КонецПроцедуры

&НаСервере
Процедура ПечатьНаСервере(ТабДок)

	Макет = Обработки.ВедомостьКонсигнации.ПолучитьМакет("МакетВедомостьКонсигнации");           			
	ОбластьШапка	= Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока	= Макет.ПолучитьОбласть("Строка");
	ОбластьПодвал	= Макет.ПолучитьОбласть("Подвал");
	ТабДок.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = 		
	  "ВЫБРАТЬ
	  |	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.Водитель КАК Водитель,
	  |	РасходнаяНакладная.Ссылка КАК Ссылка,
	  |	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.НомерТН КАК НомерТТН,
	  |	РасходнаяНакладная.Контрагент КАК Контрагент,
	  |	ВЫБОР
	  |		КОГДА РасходнаяНакладная.Договор.Адрес = """"
	  |			ТОГДА РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.АдресДоставки
	  |		ИНАЧЕ РасходнаяНакладная.Договор.Адрес
	  |	КОНЕЦ КАК ФактическийАдрес,
	  |	РасходнаяНакладная.СуммаДокумента КАК СуммаДокумента,
	  |	РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование.Ссылка КАК ДокументОснованиеСсылка,
	  |	ВЫБОР
	  |		КОГДА РасходнаяНакладная.Договор.ВидВзаиморасчетаСКонтрагентом = ЗНАЧЕНИЕ(Перечисление.ВидВзаиморасчетаСКонтрагентом.Наличные)
	  |			ТОГДА РасходнаяНакладная.СуммаДокумента
	  |		ИНАЧЕ 0
	  |	КОНЕЦ КАК СуммаНадоПолучить,
	  |	ВЫБОР
	  |		КОГДА РасходнаяНакладная.Договор.ВидВзаиморасчетаСКонтрагентом = ЗНАЧЕНИЕ(Перечисление.ВидВзаиморасчетаСКонтрагентом.БезНаличные)
	  |			ТОГДА РасходнаяНакладная.СуммаДокумента
	  |		ИНАЧЕ 0
	  |	КОНЕЦ КАК СуммаОставленная
	  |ПОМЕСТИТЬ ВТ_Расходные
	  |ИЗ
	  |	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
	  |		ПО РасходнаяНакладная.Ссылка = РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование.Ссылка
	  |ГДЕ
	  |	РасходнаяНакладная.Дата МЕЖДУ &НачалоПериода И &КонецПериода
	  |	И РасходнаяНакладная.Проведен
	  |	И РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.Водитель В(&Водитель)
	  |;
	  |
	  |////////////////////////////////////////////////////////////////////////////////
	  |ВЫБРАТЬ
	  |	ПриходнаяНакладная.ДокументОснование КАК ДокументОснование,
	  |	ПриходнаяНакладная.СуммаДокумента КАК СуммаДокумента,
	  |	ВЫБОР
	  |		КОГДА ПриходнаяНакладная.Договор.ВидВзаиморасчетаСКонтрагентом = ЗНАЧЕНИЕ(Перечисление.ВидВзаиморасчетаСКонтрагентом.Наличные)
	  |			ТОГДА ПриходнаяНакладная.СуммаДокумента
	  |		ИНАЧЕ 0
	  |	КОНЕЦ КАК СуммаНадоПолучить,
	  |	ВЫБОР
	  |		КОГДА ПриходнаяНакладная.Договор.ВидВзаиморасчетаСКонтрагентом = ЗНАЧЕНИЕ(Перечисление.ВидВзаиморасчетаСКонтрагентом.БезНаличные)
	  |			ТОГДА ПриходнаяНакладная.СуммаДокумента
	  |		ИНАЧЕ 0
	  |	КОНЕЦ КАК СуммаОставленная
	  |ПОМЕСТИТЬ ВТ_Возвраты
	  |ИЗ
	  |	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	  |ГДЕ
	  |	ПриходнаяНакладная.Проведен
	  |	И ПриходнаяНакладная.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя)
	  |	И ПриходнаяНакладная.ДокументОснование ССЫЛКА Документ.РасходнаяНакладная
	  |	И ВЫРАЗИТЬ(ПриходнаяНакладная.ДокументОснование КАК Документ.РасходнаяНакладная) В
	  |			(ВЫБРАТЬ
	  |				ВТ_Расходные.Ссылка
	  |			ИЗ
	  |				ВТ_Расходные КАК ВТ_Расходные)
	  |;
	  |
	  |////////////////////////////////////////////////////////////////////////////////
	  |ВЫБРАТЬ
	  |	ВТ_Расходные.Водитель КАК Водитель,
	  |	ВТ_Расходные.Ссылка КАК Ссылка,
	  |	ВТ_Расходные.НомерТТН КАК НомерТТН,
	  |	ВТ_Расходные.Контрагент КАК Контрагент,
	  |	ВТ_Расходные.ФактическийАдрес КАК ФактическийАдрес,
	  |	ВТ_Расходные.СуммаДокумента КАК СуммаДокумента,
	  |	ЕСТЬNULL(ВТ_Возвраты.СуммаДокумента, 0) КАК СуммаВозврата,
	  |	1 КАК КоличествоНакладных,
	  |	ВТ_Расходные.СуммаНадоПолучить - ЕСТЬNULL(ВТ_Возвраты.СуммаНадоПолучить, 0) КАК СуммаНадоПолучить,
	  |	ВТ_Расходные.СуммаОставленная - ЕСТЬNULL(ВТ_Возвраты.СуммаОставленная, 0) КАК СуммаОставленная
	  |ИЗ
	  |	ВТ_Расходные КАК ВТ_Расходные
	  |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Возвраты КАК ВТ_Возвраты
	  |		ПО ВТ_Расходные.Ссылка = ВТ_Возвраты.ДокументОснование
	  |
	  |УПОРЯДОЧИТЬ ПО
	  |	ВТ_Расходные.Ссылка
	  |ИТОГИ
	  |	СУММА(СуммаДокумента),
	  |	СУММА(СуммаВозврата),
	  |	СУММА(КоличествоНакладных),
	  |	СУММА(СуммаНадоПолучить),
	  |	СУММА(СуммаОставленная)
	  |ПО
	  |	ОБЩИЕ,
	  |	Водитель" ;
	
	Запрос.УстановитьПараметр("НачалоПериода",	НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",	КонецДня(КонецПериода));
	Запрос.УстановитьПараметр("Водитель",		Объект.Водители.Выгрузить(Новый Структура("Пометка", Истина)).ВыгрузитьКолонку("Водитель"));
	
	
	ВыборкаОбщийИтог = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОбщийИтог.Следующий() Цикл 
		//ВсегоСуммаДокумента 	= 0;
		//ВсегоСуммаВозврата		= 0;
		//ВсегоСуммаНадоПолучить	= 0;
		//ВсегоСуммаОставленная	= 0;
		ВыборкаВодитель = ВыборкаОбщийИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВодитель.Следующий() Цикл
			ВсегоСуммаДокумента = ВыборкаВодитель.СуммаДокумента;
			ВсегоСуммаВозврата	= ВыборкаВодитель.СуммаВозврата;
			ВсегоСуммаНадоПолучить	= ВыборкаВодитель.СуммаНадоПолучить;
			ВсегоСуммаОставленная	= ВыборкаВодитель.СуммаОставленная;
			
			ОбластьШапка.Параметры.Дата						= ?(НачалоПериода = КонецПериода, Формат(КонецПериода,"ДФ=dd.MM.yyyy"),
																					  		  Формат(НачалоПериода,"ДФ=dd.MM.yyyy")+ " - "+ Формат(КонецПериода,"ДФ=dd.MM.yyyy"));
			ОбластьШапка.Параметры.Водитель					= ВыборкаВодитель.Водитель;
			ОбластьШапка.Параметры.СуммаНакладных			= ВсегоСуммаДокумента;
			ОбластьШапка.Параметры.КоличествоНакладных 		= ВыборкаВодитель.КоличествоНакладных;
			ОбластьШапка.Параметры.СуммаВозврата			= ВсегоСуммаВозврата;
			ОбластьШапка.Параметры.ВсегоСуммаНадоПолучить	= ВсегоСуммаНадоПолучить;
			ОбластьШапка.Параметры.ВсегоСуммаОставленная	= ВсегоСуммаОставленная;
			ТабДок.Вывести(ОбластьШапка);
			
			Выборка = ВыборкаВодитель.Выбрать();
			Пока Выборка.Следующий() Цикл
				ОбластьСтрока.Параметры.Заполнить(Выборка);
				ТабДок.Вывести(ОбластьСтрока);		
			КонецЦикла;
			
			ОбластьПодвал.Параметры.ВсегоСуммаДокумента		= ВсегоСуммаДокумента;
			ОбластьПодвал.Параметры.ВсегоСуммаВозврата		= ВсегоСуммаВозврата;
			ОбластьПодвал.Параметры.ВсегоСуммаНадоПолучить	= ВсегоСуммаНадоПолучить;
			ОбластьПодвал.Параметры.ВсегоСуммаОставленная	= ВсегоСуммаОставленная;
			//ОбластьПодвал.Параметры.ВсегоХранения	= ВсегоХранения;
			ТабДок.Вывести(ОбластьПодвал);
			
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();			
			
		КонецЦикла;
	КонецЦикла;
	
	
КонецПроцедуры

