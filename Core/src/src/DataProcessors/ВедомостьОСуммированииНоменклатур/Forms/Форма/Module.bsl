	//	|	ОПТИМУС_Дистрибуция.ТранспортноеСредство.НомернойЗнак КАК НомерТС
	//	|ИЗ
	//	|	ПланОбмена.ОПТИМУС_Дистрибуция КАК ОПТИМУС_Дистрибуция
	//	|ГДЕ
	//	|	НЕ ОПТИМУС_Дистрибуция.ПометкаУдаления
	//	|	И ОПТИМУС_Дистрибуция.Ответственный = &Сотрудник";
	//Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	//ВыборкаВодитель = Запрос.Выполнить().Выбрать();
