	//	Водитель				= ВыборкаВодитель.Водитель;
	//	СкладВодителя			= ВыборкаВодитель.СкладВодителя;
	//	ТранспортноеСредство	= ВыборкаВодитель.ТранспортноеСредство;
	//	НомерТС            		= ВыборкаВодитель.НомерТС
	//Иначе
	//	Возврат;
	//КонецЕсли;
	
	Макет = Обработки.ВедомостьОСуммированииНоменклатур.ПолучитьМакет("МакетВедомостьОСуммированииНоменклатур");           			
	ОбластьШапка	= Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока	= Макет.ПолучитьОбласть("Строка");
	ОбластьПодвал	= Макет.ПолучитьОбласть("Подвал");
	ТабДок.Очистить();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходнаяНакладнаяЗапасы.Номенклатура КАК Номенклатура,
		|	РасходнаяНакладнаяЗапасы.Ссылка.СтруктурнаяЕдиница КАК Склад,
		|	РасходнаяНакладнаяЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмеренияТЧ,
