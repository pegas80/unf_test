		|	КОНЕЦ КАК КоличествоХранения,
		|	ВЫБОР
		|		КОГДА РасходнаяНакладнаяЗапасы.ЕдиницаИзмерения ССЫЛКА Справочник.ЕдиницыИзмерения
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕдиницаДополнительная,
		|	РасходнаяНакладнаяЗапасы.Ссылка.Договор.Водитель КАК Водитель
		|ПОМЕСТИТЬ ВТ_ТЧ
		|ИЗ
		|	Документ.РасходнаяНакладная.Запасы КАК РасходнаяНакладнаяЗапасы
		|ГДЕ
		|	РасходнаяНакладнаяЗапасы.Ссылка.Проведен
		|	И РасходнаяНакладнаяЗапасы.Ссылка.Дата МЕЖДУ &НачалоПериода И &КонецПериода
		|	И РасходнаяНакладнаяЗапасы.Ссылка.Договор.Водитель В(&Водители)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Номенклатура,
		|	МАКСИМУМ(ШтрихкодыНоменклатуры.Штрихкод) КАК Штрихкод
		|ПОМЕСТИТЬ ВТ_Штрихкоды
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ВТ_ТЧ.Номенклатура
		|			ИЗ
		|				ВТ_ТЧ КАК ВТ_ТЧ)
		|
		|СГРУППИРОВАТЬ ПО
		|	ШтрихкодыНоменклатуры.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ТЧ.Номенклатура,
		|	ВТ_ТЧ.ЕдиницаИзмеренияТЧ КАК ДопЕдИзм
		|ПОМЕСТИТЬ ВТ_ДопИзмеренияИзТЧ
		|ИЗ
		|	ВТ_ТЧ КАК ВТ_ТЧ
		|ГДЕ
		|	ВТ_ТЧ.ЕдиницаДополнительная
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ДопЕдИзм
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДопИзмеренияИзТЧ.Номенклатура КАК Номенклатура,
		|	МАКСИМУМ(ВЫРАЗИТЬ(ВТ_ДопИзмеренияИзТЧ.ДопЕдИзм КАК Справочник.ЕдиницыИзмерения)) КАК ДопЕдИзм
		|ПОМЕСТИТЬ ВТ_ДопЕдиницы
		|ИЗ
		|	ВТ_ДопИзмеренияИзТЧ КАК ВТ_ДопИзмеренияИзТЧ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ДопИзмеренияИзТЧ.Номенклатура
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ЕдиницыИзмерения.Владелец КАК Справочник.Номенклатура),
		|	МАКСИМУМ(ЕдиницыИзмерения.Ссылка)
		|ИЗ
		|	Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
		|ГДЕ
		|	НЕ ЕдиницыИзмерения.ПометкаУдаления
		|	И ЕдиницыИзмерения.Владелец ССЫЛКА Справочник.Номенклатура
		|	И НЕ ВЫРАЗИТЬ(ЕдиницыИзмерения.Владелец КАК Справочник.Номенклатура) В
		|				(ВЫБРАТЬ
		|					ВТ_ДопИзмеренияИзТЧ.Номенклатура
		|				ИЗ
		|					ВТ_ДопИзмеренияИзТЧ КАК ВТ_ДопИзмеренияИзТЧ)
		|	И ВЫРАЗИТЬ(ЕдиницыИзмерения.Владелец КАК Справочник.Номенклатура) В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ВТ_ТЧ.Номенклатура
		|			ИЗ
		|				ВТ_ТЧ КАК ВТ_ТЧ)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВЫРАЗИТЬ(ЕдиницыИзмерения.Владелец КАК Справочник.Номенклатура)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТЧ.Номенклатура,
		|	ЕСТЬNULL(ВТ_Штрихкоды.Штрихкод, """") КАК Штрихкод,
		|	ВТ_ТЧ.Склад,
		|	СУММА(ВТ_ТЧ.КоличествоХранения) КАК КоличествоХранения,
		|	ВТ_ТЧ.Водитель
		|ПОМЕСТИТЬ ВТ_БезКоэфициента
		|ИЗ
		|	ВТ_ТЧ КАК ВТ_ТЧ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Штрихкоды КАК ВТ_Штрихкоды
		|		ПО ВТ_ТЧ.Номенклатура = ВТ_Штрихкоды.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ТЧ.Номенклатура,
		|	ЕСТЬNULL(ВТ_Штрихкоды.Штрихкод, """"),
		|	ВТ_ТЧ.Склад,
		|	ВТ_ТЧ.Водитель
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_БезКоэфициента.Номенклатура КАК Номенклатура,
		|	ВТ_БезКоэфициента.Штрихкод,
		|	ВТ_БезКоэфициента.Склад,
		|	ВТ_БезКоэфициента.КоличествоХранения,
		|	ЕСТЬNULL(ВТ_ДопЕдиницы.ДопЕдИзм.Коэффициент, 0) КАК Коэффициент,
		|	ЕСТЬNULL(ВТ_ДопЕдиницы.ДопЕдИзм, """") КАК ДопЕдИзм,
		|	ВТ_БезКоэфициента.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмеренияНоменклатуры,
		|	ВТ_БезКоэфициента.Водитель КАК Водитель
		|ИЗ
		|	ВТ_БезКоэфициента КАК ВТ_БезКоэфициента
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДопЕдиницы КАК ВТ_ДопЕдиницы
		|		ПО ВТ_БезКоэфициента.Номенклатура = ВТ_ДопЕдиницы.Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура
		|ИТОГИ ПО
		|	Водитель";
	Запрос.УстановитьПараметр("НачалоПериода",	НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",	КонецДня(КонецПериода));
	Запрос.УстановитьПараметр("Водители",		Объект.Водители.Выгрузить(Новый Структура("Пометка", Истина)).ВыгрузитьКолонку("Водитель"));
	
	Организация = Справочники.Организации.ОсновнаяОрганизация;
	Период = ?(НачалоПериода = КонецПериода, Формат(КонецПериода,"ДФ=dd.MM.yyyy"), Формат(НачалоПериода,"ДФ=dd.MM.yyyy")+ " - "+ Формат(КонецПериода,"ДФ=dd.MM.yyyy"));
	
	ВыборкаВодитель = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаВодитель.Следующий() Цикл
	
		ОбластьШапка.Параметры.Организация			= Организация;
		ОбластьШапка.Параметры.Период				= Период;
		
		НайденныйВодители = Объект.Водители.НайтиСтроки(Новый Структура("Водитель", ВыборкаВодитель.Водитель));
		ОбластьШапка.Параметры.НомерТС				= НайденныйВодители[0].НомерТС;
		ОбластьШапка.Параметры.Водитель				= НайденныйВодители[0].Водитель;
		ОбластьШапка.Параметры.ТранспортноеСредство = НайденныйВодители[0].ТранспортноеСредство;
		ОбластьШапка.Параметры.СкладВодителя		= НайденныйВодители[0].СкладВодителя;
		ТабДок.Вывести(ОбластьШапка);

		Выборка = ВыборкаВодитель.Выбрать();
		НомерСтроки = 1;
		ВсегоШтука		= 0;
		ВсегоКоробка	= 0;
		ВсегоХранения	= 0;
		
		Пока Выборка.Следующий() Цикл
			ОбластьСтрока.Параметры.Заполнить(Выборка);
			ОбластьСтрока.Параметры.НомерСтроки = НомерСтроки;
			ОбластьСтрока.Параметры.Кол1 = ?(Выборка.Коэффициент = 0, "0", 									Строка(Цел(Выборка.КоличествоХранения/Выборка.Коэффициент))) +" "+?(Выборка.ДопЕдИзм = "", "ყუთი", Выборка.ДопЕдИзм);
			ОбластьСтрока.Параметры.Кол2 = ?(Выборка.Коэффициент = 0, Строка(Выборка.КоличествоХранения),	Строка(Цел(Выборка.КоличествоХранения%Выборка.Коэффициент))) +" "+Выборка.ЕдиницаИзмеренияНоменклатуры;
			ТабДок.Вывести(ОбластьСтрока);
			НомерСтроки = НомерСтроки + 1;
			ВсегоШтука		= ВсегоШтука 	+ ?(Выборка.Коэффициент = 0, Выборка.КоличествоХранения, Строка(Цел(Выборка.КоличествоХранения%Выборка.Коэффициент)));
			ВсегоКоробка	= ВсегоКоробка 	+ ?(Выборка.Коэффициент = 0, 0, 						 Строка(Цел(Выборка.КоличествоХранения/Выборка.Коэффициент)));
			ВсегоХранения	= ВсегоХранения + Выборка.КоличествоХранения;
			
		КонецЦикла;
		

		ОбластьПодвал.Параметры.ВсегоШтука		= ВсегоШтука;
		ОбластьПодвал.Параметры.ВсегоКоробка	= ВсегоКоробка;
		ОбластьПодвал.Параметры.ВсегоХранения	= ВсегоХранения;
		ТабДок.Вывести(ОбластьПодвал);
	КонецЦикла;
	
	
КонецПроцедуры


&НаСервере
Процедура ЗагрузитьВодители()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МАКСИМУМ(ОПТИМУС_Дистрибуция.Ссылка) КАК Ссылка,
		|	ОПТИМУС_Дистрибуция.ТранспортноеСредство
		|ПОМЕСТИТЬ ВТ_ТранспортныеСредства
		|ИЗ
		|	ПланОбмена.ОПТИМУС_Дистрибуция КАК ОПТИМУС_Дистрибуция
		|ГДЕ
		|	НЕ ОПТИМУС_Дистрибуция.ПометкаУдаления
		|	И НЕ ОПТИМУС_Дистрибуция.ТранспортноеСредство = ЗНАЧЕНИЕ(Справочник.ТранспортныеСредства.ПустаяСсылка)
		|	И НЕ ОПТИМУС_Дистрибуция.ТранспортноеСредство.ОсновнойВодитель = ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ОПТИМУС_Дистрибуция.ТранспортноеСредство
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ОПТИМУС_Дистрибуция.СтруктурнаяЕдиница КАК СкладВодителя,
		|	ОПТИМУС_Дистрибуция.ТранспортноеСредство,
		|	ОПТИМУС_Дистрибуция.ТранспортноеСредство.ОсновнойВодитель КАК Водитель,
		|	ОПТИМУС_Дистрибуция.Ответственный,
		|	ОПТИМУС_Дистрибуция.ТранспортноеСредство.Код КАК НомерТС,
		|	ИСТИНА КАК Пометка
		|ИЗ
		|	ПланОбмена.ОПТИМУС_Дистрибуция КАК ОПТИМУС_Дистрибуция
		|ГДЕ
		|	ОПТИМУС_Дистрибуция.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТ_ТранспортныеСредства.Ссылка
		|			ИЗ
		|				ВТ_ТранспортныеСредства КАК ВТ_ТранспортныеСредства)";
	Объект.Водители.Загрузить(Запрос.Выполнить().Выгрузить());

КонецПроцедуры


&НаКлиенте
Процедура ПометитьВсе(Команда)
	Для Каждого СтрокаТЧ Из Объект.Водители Цикл 
		СтрокаТЧ.Пометка = Истина;
	КонецЦикла;
КонецПроцедуры
&НаКлиенте
Процедура СнятьПометку(Команда)
	Для Каждого СтрокаТЧ Из Объект.Водители Цикл 
		СтрокаТЧ.Пометка = Ложь;
	КонецЦикла;
КонецПроцедуры


