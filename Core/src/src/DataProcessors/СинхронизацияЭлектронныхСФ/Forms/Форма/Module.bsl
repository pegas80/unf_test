Функция НайтиТТН_Полученной(НомераНакладных)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходнаяНакладная.Ссылка КАК ДокументОснование,
		|	ПриходнаяНакладная.НомерТТН
		|ИЗ
		|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
		|ГДЕ
		|	НЕ ПриходнаяНакладная.НомерТТН = """"
		|	И ПриходнаяНакладная.НомерТТН В(&НомераНакладных)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РасходнаяНакладная.Ссылка,
		|	РасходнаяНакладная.НомерТТН
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|ГДЕ
		|	НЕ РасходнаяНакладная.НомерТТН = """"
		|	И РасходнаяНакладная.НомерТТН В(&НомераНакладных)
		|	И РасходнаяНакладная.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику)";
	Запрос.УстановитьПараметр("НомераНакладных", НомераНакладных);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции
