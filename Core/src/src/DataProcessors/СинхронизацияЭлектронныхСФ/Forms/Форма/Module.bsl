Функция СуммыДокументаДляСчетФактурыПолученного(ДокументСсылка)

	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
		СуммаНДСДокумент = ДокументСсылка.Расходы.Итог("СуммаНДС");
	Иначе
		СуммаНДСДокумент = ДокументСсылка.Запасы.Итог("СуммаНДС") + ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная"), ДокументСсылка.Расходы.Итог("СуммаНДС"), 0);
	КонецЕсли;
	СуммаВсего 			= ДокументСсылка.СуммаДокумента;
	//_lazare
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		СуммаДокумент		= СуммаВсего;
	Иначе
	//lazare_
		СуммаДокумент		= СуммаВсего - СуммаНДСДокумент;
	КонецЕсли;
	
	// Олег Литвиненко 17.11.22 --->
	//Для РасходнаяНакладная суммы должны быть отрицательные
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
		СуммаДокумент = ?(СуммаВсего>0, -СуммаВсего, СуммаВсего);
		СуммаНДСДокумент = ?(СуммаНДСДокумент>0, -СуммаНДСДокумент,СуммаНДСДокумент);
		СуммаВсего = ?(СуммаВсего>0, -СуммаВсего, СуммаВсего);
	КонецЕсли;
	// Олег Литвиненко <---
	
	Возврат Новый Структура("СуммаДокумента, СуммаНДС, Всего", СуммаДокумент, СуммаНДСДокумент, СуммаВсего);
	
КонецФункции

&НаСервереБезКонтекста
Функция СуммыДокументаДляСчетФактурыОтправленного(ДокументСсылка)

	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
		СуммаНДСДокумент = ДокументСсылка.Расходы.Итог("СуммаНДС");
	Иначе
		СуммаНДСДокумент = ДокументСсылка.Запасы.Итог("СуммаНДС")
			+ ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная"), ДокументСсылка.Расходы.Итог("СуммаНДС"), 0);
	КонецЕсли;
	
	СуммаВсего = ДокументСсылка.СуммаДокумента;
	СуммаДокумент = СуммаВсего - СуммаНДСДокумент;
	
	//Для документа-основания вида ПриходнаяНакладная суммы должны быть отрицательные.
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		СуммаДокумент = ?(СуммаВсего > 0, -СуммаВсего, СуммаВсего);
		СуммаНДСДокумент = ?(СуммаНДСДокумент > 0, -СуммаНДСДокумент, СуммаНДСДокумент);
		СуммаВсего = ?(СуммаВсего > 0, -СуммаВсего, СуммаВсего);
	КонецЕсли;
	
	Возврат Новый Структура("СуммаДокумента, СуммаНДС, Всего", СуммаДокумент, СуммаНДСДокумент, СуммаВсего);
	
КонецФункции

