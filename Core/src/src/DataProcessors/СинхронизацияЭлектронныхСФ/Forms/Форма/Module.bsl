
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТекДата		= ТекущаяДата();
	ДатаНач		= НачалоМесяца(ТекДата);
	ДатаКон		= КонецМесяца(ТекДата);
	Полученный	= Истина;
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Организация = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"ОсновнаяОрганизация");
		Если НЕ ЗначениеЗаполнено(Организация) Тогда
			Организация = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.Организации.ОсновнаяОрганизация");
		КонецЕсли;
	КонецЕсли;
	
	//+++ Lazare_19.05.2021
	Если ПолученныеСФ = 1 Тогда 
		Элементы.СоздатьНенайденныеНоменклатури.Видимость  = Истина ;
	Иначе
		Элементы.СоздатьНенайденныеНоменклатури.Видимость = Ложь;
	КонецЕсли;	
	Элементы.ПолученныеСФ.Видимость = Ложь ;	
	//--- Lazare_19.05.2021
	//Паганини#Nexia_
	Объект.ПериодРегистрации = НачалоМесяца(ТекущаяДата());
	ОтображениеПериодаРегистрации = Формат(Объект.ПериодРегистрации, "ДФ='MMMM yyyy'");
	УстановитьВидимостьДат();
	//_Паганини#Nexia
	
КонецПроцедуры

&НаКлиенте
Процедура Выгрузить(Команда)
	ОчиститьСообщения();
	//}Paganini(LTB)_
	//Если НЕ ПроверитьЗаполнение() Тогда
	Если НЕ ФильтрЗаполнен() Тогда
	//}_Paganini(LTB)
		Возврат;
	КонецЕсли;
	ВыгрузитьНаСервере();
	КоличествоОтобранныхСтрок = Объект.СписокСФ.Количество();
	//Элементы.СписокСФ.ОтборСтрок = Неопределено;
	
	//+++ Lazare_19.05.2021	
	Элементы.СписокСФ.ОтборСтрок = Новый ФиксированнаяСтруктура(ПолучитьСтруктуруДялятбораСтрокПринятыхСФ()) ;
	Если КоличествоОтобранныхСтрок >0 Тогда 	
		Элементы.ПолученныеСФ.Видимость = Истина ;
	Иначе 
		Элементы.ПолученныеСФ.Видимость = Ложь ;
	КонецЕсли;
	//--- Lazare_19.05.2021
	
КонецПроцедуры

&НаСервере
Процедура ВыгрузитьНаСервере()
	
	КонтрагентИНН = "";
	Если ЗначениеЗаполнено(Контрагент) Тогда
		КонтрагентИНН = СокрЛП(Контрагент.ИНН);
	КонецЕсли;
	//Паганини#Nexia_
	//Отборы = Новый Структура("S_DT, E_DT, Организация, КонтрагентИНН", ДатаНач, КонецДня(ДатаКон), Организация, КонтрагентИНН);
	Отборы = Новый Структура("Организация, КонтрагентИНН", Организация, КонтрагентИНН);
	Если ВариантФильтраВыгруки = 0 Тогда
		Отборы.Вставить("S_DT", ДатаНач);
		Отборы.Вставить("E_DT", КонецДня(ДатаКон));
	ИначеЕсли ВариантФильтраВыгруки = 1 Тогда
		Отборы.Вставить("op_s_dt", Объект.ПериодРегистрации);
		Отборы.Вставить("op_e_dt", КонецМесяца(Объект.ПериодРегистрации));
	Иначе
		Отборы.Вставить("S_DT", ДатаНач);
		Отборы.Вставить("E_DT", КонецДня(ДатаКон));
		Отборы.Вставить("op_s_dt", Объект.ПериодРегистрации);
		Отборы.Вставить("op_e_dt", КонецМесяца(Объект.ПериодРегистрации));
	КонецЕсли;
	//_Паганини#Nexia
	Объект.СписокСФ.Очистить();
	Объект.ТоварыНаПортале.Очистить();
	Объект.ДокументыФактуры.Очистить();	
	
	МассивФильтровСтатуса = Новый Массив;
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	МассивФильтровСтатуса.Добавить(0);
	
	//Полученные
	Если Полученный Тогда
		СписокПринятыхФактур = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСписокПринятыхФактур(, Отборы);
		Если НЕ ТипЗнч(СписокПринятыхФактур) = Тип("Массив") Тогда
			Возврат;
		КонецЕсли;
		Для Каждого СтрокаТЗ ИЗ СписокПринятыхФактур Цикл
			НоваяЗапись = Объект.СписокСФ.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТЗ);
			//НоваяЗапись.Reg_DT		= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СтрокаВДату(СтрокаТЗ.Reg_DT);
			//НоваяЗапись.OPeration_DT	= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СтрокаВДату(СтрокаТЗ.OPeration_DT);
			НоваяЗапись.Статус      	= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСтатусСФ_ИзЧисла(НоваяЗапись.Status);
			НоваяЗапись.СтатусДляФильтра= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСтатусСФ_ДляФильтра(НоваяЗапись.Status, НоваяЗапись.Was_Ref);
			НоваяЗапись.Состояние       = "მიღებული";
			НоваяЗапись.ФактураАванса	= (Лев(НоваяЗапись.f_series, 2) = "ავ");
			
			//+++ Lazare_19.05.2021
			Если ЗначениеЗаполнено(НоваяЗапись.ПривязанныеТТН) Тогда 
				 НоваяЗапись.ДокументБезТТН = Ложь
				  //Элементы.СписокСФДокументБезТТН = Ложь ;			  
		 	Иначе 	
				  //Элементы.СписокСФДокументБезТТН = Истина ;
				  НоваяЗапись.ДокументБезТТН  = Истина ;
			КонецЕсли;
			//--- Lazare_19.05.2021
			
			ТоварыСФ = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьТабЧастьФактуры(, Организация, НоваяЗапись.ID);
			Если Не ТоварыСФ = Неопределено Тогда
				Для Каждого СтрокаТЧRS Из ТоварыСФ Цикл
					СтрокаТовары = Объект.ТоварыНаПортале.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТовары, СтрокаТЧRS);
					СтрокаТовары.ID = НоваяЗапись.ID;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокФактур("მიღებული", Объект.СписокСФ, Организация);
		ПревязатьНакладныеКФактурам_Полученные();
	КонецЕсли;
	
	//Отправленные
	Если Отправленный Тогда
		СписокОтправленныхФактур = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСписокОтправленныхФактур(, Отборы);
		Если НЕ ТипЗнч(СписокОтправленныхФактур) = Тип("Массив") Тогда
			Возврат;
		КонецЕсли;
		Для Каждого СтрокаТЗ ИЗ СписокОтправленныхФактур Цикл
			НоваяЗапись = Объект.СписокСФ.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаТЗ);
			//НоваяЗапись.Reg_DT		= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СтрокаВДату(СтрокаТЗ.Reg_DT);
			//НоваяЗапись.OPeration_DT	= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СтрокаВДату(СтрокаТЗ.OPeration_DT);
			НоваяЗапись.Статус      	= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСтатусСФ_ИзЧисла(НоваяЗапись.Status);
			НоваяЗапись.СтатусДляФильтра= ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСтатусСФ_ДляФильтра(НоваяЗапись.Status, НоваяЗапись.Was_Ref);
			НоваяЗапись.Состояние       = "გაცემული";
			НоваяЗапись.ФактураАванса	= (Лев(НоваяЗапись.f_series, 2) = "ავ");
			
			// Kuzmich, 01.08.2023, ONESOFT-2450, Синхронизация СФ - создание расходная накладная на основе выданных счет фактуров
			Если ЗначениеЗаполнено(НоваяЗапись.ПривязанныеТТН) Тогда 
				НоваяЗапись.ДокументБезТТН = Ложь			  
			Иначе
				НоваяЗапись.ДокументБезТТН  = Истина ;
			КонецЕсли;
			// Kuzmich, 01.08.2023, ONESOFT-2450, Синхронизация СФ - создание расходная накладная на основе выданных счет фактуров
			
			ТоварыСФ = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьТабЧастьФактуры(, Организация, НоваяЗапись.ID);
			Если Не ТоварыСФ = Неопределено Тогда
				Для Каждого СтрокаТЧRS Из ТоварыСФ Цикл
					СтрокаТовары = Объект.ТоварыНаПортале.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТовары, СтрокаТЧRS);
					СтрокаТовары.ID = НоваяЗапись.ID;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокФактур("გაცემული", Объект.СписокСФ, Организация);
		ПревязатьНакладныеКФактурам_Отправленные();
	КонецЕсли;
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписок_КонтрагентовФактуры(Объект.СписокСФ);
	
КонецПроцедуры

&НаКлиенте
Процедура СписокСФПриАктивизацииСтроки(Элемент)
	
	впТекущаяСтрока = Элементы.СписокСФ.ТекущиеДанные;
	Если впТекущаяСтрока <> Неопределено Тогда
		Элементы.ТоварыНаПортале.ОтборСтрок = Новый ФиксированнаяСтруктура("ID", впТекущаяСтрока.ID);
	Иначе 
		Элементы.ТоварыНаПортале.ОтборСтрок = Новый ФиксированнаяСтруктура("ID", "?????");
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура СоздатьСФ(Команда)
	ОчиститьСообщения();
	ЕстьОшибки = Ложь;
	Создать_Документы(ЕстьОшибки);
	Если НЕ ЕстьОшибки Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.ДокументыФактуры;		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Создать_Документы(ЕстьОшибки)
	
	ДанныеЗаполненияСчетаФактурыПолученного = ДанныеЗаполненияСчетаФактурыПолученного(Организация, ТекущаяДата());
	ДанныеЗаполненияСчетаФактурыВыданного = ДанныеЗаполненияСчетаФактурыВыданного(Организация, ТекущаяДата());
	
	Если Не ПроверитьЗаполнениеУчетнойПолитики(ДанныеЗаполненияСчетаФактурыПолученного, ДанныеЗаполненияСчетаФактурыВыданного) Тогда
		ЕстьОшибки = Истина;
		Возврат;
	КонецЕсли;
	
	ПроверитьПередСозданиемДокументов(ЕстьОшибки);
	
	Созать_Полученныйе(ДанныеЗаполненияСчетаФактурыПолученного);
	Созать_Отправленные(ДанныеЗаполненияСчетаФактурыВыданного);
	
КонецПроцедуры

&НаСервере
Процедура Созать_Полученныйе(ДанныеЗаполнения)
	
	СписокВыбранныхСФ = Объект.СписокСФ.НайтиСтроки(Новый Структура("Флаг, Состояние, ЕстьОшибки", Истина, "მიღებული", Ложь));
	Для Каждого Запись ИЗ СписокВыбранныхСФ Цикл
		
		ДокПриходнаяНакладная = НЕОПРЕДЕЛЕНО;// Kuzmich, 03.08.2023, ONESOFT-2459, Синхронизация електронных СФ - Полученный - БезТТН - Автоматическое заполнение документа
		
		//+++ Lazare_19.05.2021
		Если ПолученныеСФ = 1 Тогда 
			ДокПриходнаяНакладная = Документы.ПриходнаяНакладная.СоздатьДокумент();
			
			//Шапка
			ДокПриходнаяНакладная.Заполнить(Неопределено);
			
			Если НачалоМесяца(Запись.Reg_DT) > НачалоМесяца(Запись.Operation_DT) Тогда 
				ДокПриходнаяНакладная.Дата  = НачалоДня(КонецМесяца(Запись.Operation_DT))  ;
			Иначе 
				ДокПриходнаяНакладная.Дата  = НачалоДня(Запись.Reg_DT)  ;
			КонецЕсли;	
			
			ДокПриходнаяНакладная.Дата         = Запись.Operation_DT ;
			ДокПриходнаяНакладная.Автор	       = ПараметрыСеанса.ТекущийПользователь.Ссылка;
			ДокПриходнаяНакладная.Организация  = Организация;
			ДокПриходнаяНакладная.Контрагент   = Запись.Контрагент;		
			Если ДокПриходнаяНакладная.Контрагент.ВестиРасчетыПоДоговорам Тогда 	
				ДокПриходнаяНакладная.Договор = ДокПриходнаяНакладная.Контрагент.ДоговорПоУмолчанию;
				ДанныеОКонтрагенте  = ДокПриходнаяНакладная.Договор ;
			Иначе 
				ДанныеОКонтрагенте  = ДокПриходнаяНакладная.Контрагент ;
			КонецЕсли;		
			ВалютаРасчетов     = ДанныеОКонтрагенте.ВалютаРасчетов ;
			НациональнаяВалюта = Константы.НациональнаяВалюта.Получить();
			
			СтруктураПоВалюте  = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокПриходнаяНакладная.Дата, Новый Структура("Валюта", НациональнаяВалюта));
			КурсНациональнаяВалюта      = СтруктураПоВалюте.Курс;
			КратностьНациональнаяВалюта = СтруктураПоВалюте.Кратность;
			
			СтруктураДанные      = ПолучитьДанныеДоговора(ДокПриходнаяНакладная.Дата, ВалютаРасчетов, ДанныеОКонтрагенте) ; 	
			СуммаВключаетНДС     = СтруктураДанные.СуммаВключаетНДС; ;
			УчетВалютныхОпераций = Константы.ФункциональнаяУчетВалютныхОпераций.Получить();
			НалогообложениеНДС   = СтруктураДанные.НалогообложениеСтавка.НалогообложениеНДС;
			Курс   = СтруктураДанные.ВалютаРасчетовКурсКратность.Курс ;
			ВидЦен = Неопределено ;
			
			ДокПриходнаяНакладная.ВалютаДокумента    = СтруктураДанные.ВалютаРасчетов ;
			ДокПриходнаяНакладная.Кратность          = СтруктураДанные.ВалютаРасчетовКурсКратность.Кратность ;
			ДокПриходнаяНакладная.Курс               = СтруктураДанные.ВалютаРасчетовКурсКратность.Курс;	
			ДокПриходнаяНакладная.НалогообложениеНДС = НалогообложениеНДС;
			ДокПриходнаяНакладная.ВидЦенКонтрагента  = СтруктураДанные.ВидЦенКонтрагента ;
			ДокПриходнаяНакладная.СуммаВключаетНДС   = СтруктураДанные.СуммаВключаетНДС ;				
			ДокПриходнаяНакладная.Подразделение      = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение ; 	
			ДокПриходнаяНакладная.IDСФ = Запись.ID;
			СерияСФ =  Запись.f_series;
			НомерСФ =  Запись.f_number;
			ДокПриходнаяНакладная.НомерСФ = СерияСФ + " " + НомерСФ ;		
			//Таб Часть Услуги
			УслугиНаПортале = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("ID", Запись.ID));
			Для Каждого СтрокаТЗ Из УслугиНаПортале Цикл		
				НовСтрока =  ДокПриходнаяНакладная.Расходы.Добавить();			
				СоздатьНоменклатуру   			= СоздатьНенайденныеНоменклатури;
				НовСтрока.Номенклатура 			= ПолучитьНоменклатуру(СтрокаТЗ.Номенклатура,СоздатьНоменклатуру);
				НовСтрока.ЕдиницаИзмерения 		= ?(ЗначениеЗаполнено(НовСтрока.Номенклатура),НовСтрока.Номенклатура.ЕдиницаИзмерения,УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("КлассификаторЕдиницИзмерения", "шт"));
				НовСтрока.Количество			= ?(СтрокаТЗ.Количество=0,1,СтрокаТЗ.Количество);
				НовСтрока.Сумма					= Окр((СтрокаТЗ.Сумма/ДокПриходнаяНакладная.Курс)* ДокПриходнаяНакладная.Кратность,2);
				НовСтрока.Цена			 	    = Окр(НовСтрока.Сумма/НовСтрока.Количество,2);
				Если СтрокаТЗ.СуммаНДС > 0 Тогда 
					НовСтрока.СуммаНДС		    = Окр((СтрокаТЗ.СуммаНДС/ДокПриходнаяНакладная.Курс)* ДокПриходнаяНакладная.Кратность,2);
					НовСтрока.СтавкаНДС        = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС18");
				Иначе 
					НовСтрока.СуммаНДС 	    = СтрокаТЗ.СуммаНДС ;
					НовСтрока.СтавкаНДС        = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС0");
				КонецЕсли;
				НовСтрока.ПроцентСкидкиНаценки	= 0;
				НовСтрока.СуммаБезНалогов	    = НовСтрока.Сумма - НовСтрока.СуммаНДС ;
				НовСтрока.Всего					= НовСтрока.Сумма;
				НовСтрока.СтруктурнаяЕдиница    = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение ; 		
			КонецЦикла;	
			Попытка
				ДокПриходнаяНакладная.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ДокПриходнаяНакладная.Записать(РежимЗаписиДокумента.Запись);
			КонецПопытки;
		КонецЕсли;
		//--- Lazare_19.05.2021
		
		ДокументОбъект	= Документы.СчетФактураПолученныйГрузия.СоздатьДокумент();
		ДокументОбъект.Дата						= ТекущаяДата();
		ДокументОбъект.Автор					= ПараметрыСеанса.ТекущийПользователь.Ссылка;
		ДокументОбъект.Идентификатор			= Запись.ID;
		ДокументОбъект.ПериодРегистрации		= Запись.Reg_DT;
		ДокументОбъект.ДатаВходящегоДокумента	= Запись.Operation_DT;
		ДокументОбъект.Серия					= Запись.f_series;
		ДокументОбъект.НомерСчетФактуры			= Запись.f_number;
		ДокументОбъект.НомерВходящегоДокумента	= ДокументОбъект.Серия + " " + ДокументОбъект.НомерСчетФактуры;
		ДокументОбъект.Идентификатор			= Запись.ID;
		ДокументОбъект.Организация				= Организация;
		ДокументОбъект.Контрагент				= Запись.Контрагент;
		ДокументОбъект.Статус					= Запись.Статус;
		ДокументОбъект.Аванс					= Запись.ФактураАванса;
		
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ДанныеЗаполнения);
		
		Если НЕ Запись.ФактураАванса Тогда
			//Документы
			Если ЗначениеЗаполнено(Запись.ПривязанныеТТН) Тогда
				ТаблицаНакладных = НайтиТТН_Полученной(Запись.ПривязанныеТТН);
				Для Каждого СтрокаТЗ ИЗ ТаблицаНакладных Цикл
					СтрокаДО = ДокументОбъект.ДокументыОснования.Добавить();
					СтрокаДО.ДокументОснование = СтрокаТЗ.ДокументОснование;
					СтруктураСумм = СуммыДокументаДляСчетФактурыПолученного(СтрокаДО.ДокументОснование);
					ЗаполнитьЗначенияСвойств(СтрокаДО, СтруктураСумм);		
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		
		//Товары
		ТоварыНаПортале = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("ID", Запись.ID));
		Для Каждого СтрокаТЗ Из ТоварыНаПортале Цикл
			СтрокаТ = ДокументОбъект.ТоварыНаПортале.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТ, СтрокаТЗ);
		КонецЦикла;
		
		// Kuzmich, 03.08.2023, ONESOFT-2459, Синхронизация електронных СФ - Полученный - БезТТН - Автоматическое заполнение документа
		Если (ТипЗНЧ(ДокПриходнаяНакладная) = Тип("ДокументСсылка.ПриходнаяНакладная") ИЛИ ТипЗНЧ(ДокПриходнаяНакладная) = Тип("ДокументОбъект.ПриходнаяНакладная"))
			//И ДокПриходнаяНакладная.Проведен 
			Тогда
			
			НоваяСтрокаДокументыОснования = ДокументОбъект.ДокументыОснования.Добавить();
			
			НоваяСтрокаДокументыОснования.ДокументОснование = ДокПриходнаяНакладная.Ссылка;
			
			Если ДокПриходнаяНакладная.Проведен Тогда
				
				СтруктураСумм = РС_ОбщегоНазначения.ПолучитьСуммуИНДСДокументаВВалютеРасчета(ДокПриходнаяНакладная.Ссылка);
				
				НоваяСтрокаДокументыОснования.СуммаДокумента = СтруктураСумм.Сумма;
				НоваяСтрокаДокументыОснования.СуммаНДС = СтруктураСумм.СуммаНДС;
				НоваяСтрокаДокументыОснования.Всего = СтруктураСумм.СуммаВсего;
				
			КонецЕсли;
			
		КонецЕсли;
		// Kuzmich, 03.08.2023, ONESOFT-2459, Синхронизация електронных СФ - Полученный - БезТТН - Автоматическое заполнение документа
		
		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			СтрокаДокФактуры = Объект.ДокументыФактуры.Добавить();
			СтрокаДокФактуры.Документ	= ДокументОбъект.Ссылка;
			Запись.Документ	= ДокументОбъект.Ссылка;
			Запись.Флаг		= Ложь;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура Созать_Отправленные(ДанныеЗаполнения)
	
	СписокВыбранныхСФ = Объект.СписокСФ.НайтиСтроки(Новый Структура("Флаг, Состояние, ЕстьОшибки", Истина, "გაცემული", Ложь));
	Для Каждого Запись ИЗ СписокВыбранныхСФ Цикл
		
		// Kuzmich, 01.08.2023, ONESOFT-2450, Синхронизация СФ - создание расходная накладная на основе выданных счет фактуров
		ДокРасходнаяНакладная = НЕОПРЕДЕЛЕНО;
		
		Если ПолученныеСФ = 1 Тогда 
			
			ДокРасходнаяНакладная = Документы.РасходнаяНакладная.СоздатьДокумент();
			
			//Шапка
			ДокРасходнаяНакладная.Заполнить(Неопределено);
			
			ДокРасходнаяНакладная.Дата         = Запись.Operation_DT ;
			ДокРасходнаяНакладная.Автор	       = ПараметрыСеанса.ТекущийПользователь.Ссылка;
			ДокРасходнаяНакладная.Организация  = Организация;
			ДокРасходнаяНакладная.Контрагент   = Запись.Контрагент;		
			Если ДокРасходнаяНакладная.Контрагент.ВестиРасчетыПоДоговорам Тогда 	
				ДокРасходнаяНакладная.Договор = ДокРасходнаяНакладная.Контрагент.ДоговорПоУмолчанию;
				ДанныеОКонтрагенте  = ДокРасходнаяНакладная.Договор ;
			Иначе 
				ДанныеОКонтрагенте  = ДокРасходнаяНакладная.Контрагент ;
			КонецЕсли;		
			ВалютаРасчетов     = ДанныеОКонтрагенте.ВалютаРасчетов ;
			НациональнаяВалюта = Константы.НациональнаяВалюта.Получить();
			
			СтруктураПоВалюте  = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокРасходнаяНакладная.Дата, Новый Структура("Валюта", НациональнаяВалюта));
			КурсНациональнаяВалюта      = СтруктураПоВалюте.Курс;
			КратностьНациональнаяВалюта = СтруктураПоВалюте.Кратность;
			
			СтруктураДанные      = ПолучитьДанныеДоговора(ДокРасходнаяНакладная.Дата, ВалютаРасчетов, ДанныеОКонтрагенте) ; 	
			СуммаВключаетНДС     = СтруктураДанные.СуммаВключаетНДС; ;
			УчетВалютныхОпераций = Константы.ФункциональнаяУчетВалютныхОпераций.Получить();
			НалогообложениеНДС   = СтруктураДанные.НалогообложениеСтавка.НалогообложениеНДС;
			Курс   = СтруктураДанные.ВалютаРасчетовКурсКратность.Курс ;
			ВидЦен = Неопределено ;
			
			ДокРасходнаяНакладная.ВалютаДокумента    = СтруктураДанные.ВалютаРасчетов ;
			ДокРасходнаяНакладная.Кратность          = СтруктураДанные.ВалютаРасчетовКурсКратность.Кратность ;
			ДокРасходнаяНакладная.Курс               = СтруктураДанные.ВалютаРасчетовКурсКратность.Курс;	
			ДокРасходнаяНакладная.НалогообложениеНДС = НалогообложениеНДС;
			ДокРасходнаяНакладная.ВидЦен             = СтруктураДанные.ВидЦенКонтрагента ;
			ДокРасходнаяНакладная.СуммаВключаетНДС   = СтруктураДанные.СуммаВключаетНДС ;				
			ДокРасходнаяНакладная.Подразделение      = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение ; 	
			ДокРасходнаяНакладная.IDСФ = Запись.ID;
			СерияСФ =  Запись.f_series;
			НомерСФ =  Запись.f_number;
			ДокРасходнаяНакладная.НомерСФ = СерияСФ + " " + НомерСФ ;		
			//Таб Часть Услуги
			УслугиНаПортале = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("ID", Запись.ID));
			Для Каждого СтрокаТЗ Из УслугиНаПортале Цикл		
				НовСтрока =  ДокРасходнаяНакладная.Запасы.Добавить();			
				СоздатьНоменклатуру   			= СоздатьНенайденныеНоменклатури;
				НовСтрока.Номенклатура 			= ПолучитьНоменклатуру(СтрокаТЗ.Номенклатура,СоздатьНоменклатуру);
				НовСтрока.ЕдиницаИзмерения 		= ?(ЗначениеЗаполнено(НовСтрока.Номенклатура),НовСтрока.Номенклатура.ЕдиницаИзмерения,УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("КлассификаторЕдиницИзмерения", "шт"));
				НовСтрока.Количество			= ?(СтрокаТЗ.Количество=0,1,СтрокаТЗ.Количество);
				НовСтрока.Сумма					= Окр((СтрокаТЗ.Сумма/ДокРасходнаяНакладная.Курс)* ДокРасходнаяНакладная.Кратность,2);
				НовСтрока.Цена			 	    = Окр(НовСтрока.Сумма/НовСтрока.Количество,2);
				Если СтрокаТЗ.СуммаНДС > 0 Тогда 
					НовСтрока.СуммаНДС		    = Окр((СтрокаТЗ.СуммаНДС/ДокРасходнаяНакладная.Курс)* ДокРасходнаяНакладная.Кратность,2);
					НовСтрока.СтавкаНДС        = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС18");
				Иначе 
					НовСтрока.СуммаНДС 	    = СтрокаТЗ.СуммаНДС ;
					НовСтрока.СтавкаНДС        = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС0");
				КонецЕсли;
				НовСтрока.ПроцентСкидкиНаценки	= 0;
				НовСтрока.СуммаБезНалогов	    = НовСтрока.Сумма - НовСтрока.СуммаНДС ;
				НовСтрока.Всего					= НовСтрока.Сумма;
				НовСтрока.СтруктурнаяЕдиница    = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение ; 		
			КонецЦикла;	
			Попытка
				ДокРасходнаяНакладная.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ДокРасходнаяНакладная.Записать(РежимЗаписиДокумента.Запись);
			КонецПопытки;
			
		КонецЕсли;
		// Kuzmich, 01.08.2023, ONESOFT-2450, Синхронизация СФ - создание расходная накладная на основе выданных счет фактуров
		
		ДокументОбъект	= Документы.СчетФактураОтправленныйГрузия.СоздатьДокумент();
		ДокументОбъект.Дата						= ТекущаяДата();
		ДокументОбъект.Автор					= ПараметрыСеанса.ТекущийПользователь.Ссылка;
		ДокументОбъект.Идентификатор			= Запись.ID;
		ДокументОбъект.ПериодРегистрации		= Запись.Reg_DT;
		ДокументОбъект.ДатаВходящегоДокумента	= Запись.Operation_DT;
		ДокументОбъект.Серия					= Запись.f_series;
		ДокументОбъект.НомерСчетФактуры			= Запись.f_number;
		ДокументОбъект.НомерВходящегоДокумента	= ДокументОбъект.Серия + " " + ДокументОбъект.НомерСчетФактуры;
		ДокументОбъект.Идентификатор			= Запись.ID;
		ДокументОбъект.Организация				= Организация;
		ДокументОбъект.Контрагент				= Запись.Контрагент;
		ДокументОбъект.Статус					= Запись.Статус;
		ДокументОбъект.Аванс					= Запись.ФактураАванса;
		
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ДанныеЗаполнения);
		
		Если НЕ Запись.ФактураАванса Тогда
			//Документы
			ТаблицаНакладных = Неопределено;
			Если ЗначениеЗаполнено(Запись.ПривязанныеТТН) Тогда
				ТаблицаНакладных = НайтиТТН_Отправленные(Запись.ПривязанныеТТН);
				Для Каждого СтрокаТЗ ИЗ ТаблицаНакладных Цикл
					СтрокаДО = ДокументОбъект.ДокументыОснования.Добавить();
					СтрокаДО.ДокументОснование = СтрокаТЗ.ДокументОснование;
					СтруктураСумм = СуммыДокументаДляСчетФактурыОтправленного(СтрокаДО.ДокументОснование);
					ЗаполнитьЗначенияСвойств(СтрокаДО, СтруктураСумм);
				КонецЦикла;
			КонецЕсли;
			
			//Запасы
			Если НЕ ТаблицаНакладных = Неопределено Тогда
				ДокументОбъект.ЗаполнитьЗапасы(ТаблицаНакладных.ВыгрузитьКолонку("ДокументОснование"));
			КонецЕсли;
		КонецЕсли;
		
		// Kuzmich, 01.08.2023, ONESOFT-2450, Синхронизация СФ - создание расходная накладная на основе выданных счет фактуров
		Если (ТипЗНЧ(ДокРасходнаяНакладная) = Тип("ДокументСсылка.РасходнаяНакладная") ИЛИ ТипЗНЧ(ДокРасходнаяНакладная) = Тип("ДокументОбъект.РасходнаяНакладная"))
			//И ДокРасходнаяНакладная.Проведен 
			Тогда
			
			НоваяСтрокаДокументыОснования = ДокументОбъект.ДокументыОснования.Добавить();
			
			НоваяСтрокаДокументыОснования.ДокументОснование	= ДокРасходнаяНакладная.Ссылка;
			НоваяСтрокаДокументыОснования.Всего = ДокРасходнаяНакладная.Запасы.Итог("Всего");
			НоваяСтрокаДокументыОснования.СуммаНДС = ДокРасходнаяНакладная.Запасы.Итог("СуммаНДС");
			НоваяСтрокаДокументыОснования.СуммаДокумента = НоваяСтрокаДокументыОснования.Всего - НоваяСтрокаДокументыОснования.СуммаНДС;
			Если ДокРасходнаяНакладная.СтоимостьДоставки > 0 Тогда 
				НоваяСтрокаДокументыОснования.Всего = НоваяСтрокаДокументыОснования.Всего + ДокРасходнаяНакладная.СтоимостьДоставки ;
				НоваяСтрокаДокументыОснования.СуммаНДС = НоваяСтрокаДокументыОснования.СуммаНДС + ДокРасходнаяНакладная.СуммаНДСДоставки ;
				НоваяСтрокаДокументыОснования.СуммаДокумента = НоваяСтрокаДокументыОснования.СуммаДокумента +(ДокРасходнаяНакладная.СтоимостьДоставки - ДокРасходнаяНакладная.СуммаНДСДоставки);
			КонецЕсли;			
			
		КонецЕсли;
		
		// Заполняем товары/услуги
		МассивДокументыОснования = Новый Массив;
		Для Каждого СтрокаТЧ Из ДокументОбъект.ДокументыОснования Цикл
			Если ТипЗнч(СтрокаТЧ.ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
				Продолжить;
			КонецЕсли;
			МассивДокументыОснования.Добавить(СтрокаТЧ.ДокументОснование);	
		КонецЦикла;
		ДокументОбъект.ЗаполнитьЗапасы(МассивДокументыОснования);
		// Kuzmich, 01.08.2023, ONESOFT-2450, Синхронизация СФ - создание расходная накладная на основе выданных счет фактуров
		
		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
			СтрокаДокФактуры = Объект.ДокументыФактуры.Добавить();
			СтрокаДокФактуры.Документ	= ДокументОбъект.Ссылка;
			Запись.Документ	= ДокументОбъект.Ссылка;
			Запись.Флаг		= Ложь;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПревязатьНакладныеКФактурам_Полученные()
	
	УстановитьПривилегированныйРежим(Истина);
	Для Каждого СтрокаСФ ИЗ Объект.СписокСФ Цикл
		Если ЗначениеЗаполнено(СтрокаСФ.Документ) Тогда
            ПерваяСтрока		  = Истина;
			ЕстьИзминении		  = Ложь;
			ЕстьИзминенииВСтатусе = Ложь;
			Если НЕ СтрокаСФ.Статус = СтрокаСФ.Документ.Статус Тогда
				ЕстьИзминенииВСтатусе = Истина;
			КонецЕсли;
			ТаблицаНакладных = НайтиТТН_Полученной(СтрокаСФ.ПривязанныеТТН);
			Для Каждого СтрокаПН ИЗ ТаблицаНакладных Цикл
				НайденныеСтроки = СтрокаСФ.Документ.ДокументыОснования.НайтиСтроки(Новый Структура("ДокументОснование", СтрокаПН.ДокументОснование));
				Если НайденныеСтроки.Количество() = 0 Тогда
					Если ПерваяСтрока Тогда
						ДокументСф = СтрокаСФ.Документ.ПолучитьОбъект();
						ПерваяСтрока	= Ложь;
						ЕстьИзминении	= Истина;
					КонецЕсли;
					СтрокаДО = ДокументСф.ДокументыОснования.Добавить();
					СтрокаДО.ДокументОснование = СтрокаПН.ДокументОснование;
					СтруктураСумм = СуммыДокументаДляСчетФактурыПолученного(СтрокаДО.ДокументОснование);
					ЗаполнитьЗначенияСвойств(СтрокаДО, СтруктураСумм);
				КонецЕсли;
			КонецЦикла;
			Если ЕстьИзминении Тогда
				ДокументСф.ТоварыНаПортале.Очистить();
				ТоварыНаПортале = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("ID", СтрокаСФ.ID));
				Для Каждого СтрокаТЗ Из ТоварыНаПортале Цикл
					СтрокаТ = ДокументСф.ТоварыНаПортале.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаТ, СтрокаТЗ);
				КонецЦикла;
				Если ЕстьИзминенииВСтатусе Тогда
					ДокументСф.Статус = СтрокаСФ.Статус;
				КонецЕсли;
				ДокументСф.Записать();
			ИначеЕсли ЕстьИзминенииВСтатусе Тогда
				ДокументСф = СтрокаСФ.Документ.ПолучитьОбъект();
				ДокументСф.Статус = СтрокаСФ.Статус;
				ДокументСф.Записать();
			КонецЕсли;			
		КонецЕсли;
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры
