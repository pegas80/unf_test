&НаСервере
Функция ПолучитьНоменклатуру(Номенклатура,СоздатьНоменклатуру)

	Если Не СоздатьНоменклатуру Тогда 
		НайденнаяНоменклатура = Справочники.Номенклатура.НайтиПоНаименованию(Номенклатура,Истина);
	Иначе 
		НайденнаяНоменклатура = Справочники.Номенклатура.НайтиПоНаименованию(Номенклатура,Истина);
		Если НайденнаяНоменклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда 
			 НайденнаяНоменклатура =  СоздатНоменклатуру(Номенклатура);
		КонецЕсли;
	КонецЕсли;
			
	Возврат НайденнаяНоменклатура;

КонецФункции 

&НаСервере
Функция  СоздатНоменклатуру(Номенклатура)
	
	ЗначенияЗаполнения = РегистрыСведений.УчетнаяПолитикаРегл.ЗначенияПолейУчетнойПолитики(
		"НаправлениеДеятелности,СчетУчетаЗатратРегл,ЕдиницИзмерения",
		Организация,
		ТекущаяДатаСеанса());
	
	СтруктураПараметров = Новый Структура;
	
	Если ЗначениеЗаполнено(ЗначенияЗаполнения.ЕдиницИзмерения)Тогда
		 СтруктураПараметров.Вставить("ЕдиницИзмерения", ЗначенияЗаполнения.ЕдиницИзмерения);
	Иначе 
		 СтруктураПараметров.Вставить("ЕдиницИзмерения", УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("КлассификаторЕдиницИзмерения", "шт"));
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ЗначенияЗаполнения.СчетУчетаЗатратРегл)Тогда
		 СтруктураПараметров.Вставить("СчетУчетаЗатратРегл", ЗначенияЗаполнения.СчетУчетаЗатратРегл);
	Иначе 
		 СтруктураПараметров.Вставить("СчетУчетаЗатратРегл", ПланыСчетов.Хозрасчетный.НайтиПоКоду("1630"));
	КонецЕсли;	
	СтруктураПараметров.Вставить("Услуга",				Перечисления.ТипыНоменклатуры.Услуга);
	СтруктураПараметров.Вставить("БезКатегории",		УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("КатегорииНоменклатуры", 	"БезКатегории"));	
	Если ЗначениеЗаполнено(ЗначенияЗаполнения.НаправлениеДеятелности)Тогда
		 СтруктураПараметров.Вставить("НаправлениеДеятелности", ЗначенияЗаполнения.НаправлениеДеятелности);
	Иначе 
		 СтруктураПараметров.Вставить("НаправлениеДеятелности",	УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("НаправленияДеятельности", "ОсновноеНаправление"));
	КонецЕсли;	
	СтруктураПараметров.Вставить("Наименование",Номенклатура);
	
	
	НовНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();
	НовНоменклатура.Заполнить(Неопределено);
	НовНоменклатура.СчетУчетаЗатратРегл     = СтруктураПараметров.СчетУчетаЗатратРегл;	
	НовНоменклатура.Наименование 		    = СтруктураПараметров.Наименование;
	НовНоменклатура.НаименованиеПолное      = СтруктураПараметров.Наименование;
	НовНоменклатура.ТипНоменклатуры 	    = СтруктураПараметров.Услуга;
	НовНоменклатура.ЕдиницаИзмерения        = СтруктураПараметров.ЕдиницИзмерения;
	НовНоменклатура.КатегорияНоменклатуры   = СтруктураПараметров.БезКатегории;                                                                       
	НовНоменклатура.НаправлениеДеятельности = СтруктураПараметров.НаправлениеДеятелности;				
	НовНоменклатура.Записать();		
	Ссылка = НовНоменклатура.Ссылка;

	Возврат Ссылка ;
КонецФункции

&НаСервере
Функция ПолучитьДанныеДоговора(Дата, ВалютаДокумента, Договор)
	
	СтруктураДанные = Новый Структура;
	
	СтруктураДанные.Вставить(
		"ВалютаРасчетов",
		Договор.ВалютаРасчетов
	);
	
	СтруктураДанные.Вставить(
		"ВалютаРасчетовКурсКратность",
		РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Дата, Новый Структура("Валюта", Договор.ВалютаРасчетов))
	);
	
	СтруктураДанные.Вставить(
		"РасчетыВУсловныхЕдиницах",
	  	Договор.РасчетыВУсловныхЕдиницах
	);
	
	СтруктураДанные.Вставить(
		"ВидЦенКонтрагента",
		Договор.ВидЦенКонтрагента
	);
	
	СтруктураДанные.Вставить(
		"СуммаВключаетНДС",
		?(ЗначениеЗаполнено(Договор.ВидЦенКонтрагента), Договор.ВидЦенКонтрагента.ЦенаВключаетНДС, Неопределено)
	);
	
	СтруктураДанные.Вставить(
		"УчетЦенКонтрагентов",
		ПолучитьФункциональнуюОпцию("УчетЦенКонтрагентов")
	);
	
	Если ПолучитьФункциональнуюОпцию("ФункциональнаяОпцияИспользоватьИсториюНалогообложенияКонтрагентов") Тогда
		СтруктураДанные.Вставить(
			"НалогообложениеСтавка",
			РегистрыСведений.НалогообложениеКонтрагентов.ПолучитьПоследнее(Дата, Новый Структура("Контрагент,Договор", Договор.Владелец, Договор))
			);
	Иначе
		СтруктураДанные.Вставить(
			"НалогообложениеСтавка", Новый Структура("НалогообложениеНДС",Договор.Владелец.НалогообложениеНДС));
	КонецЕсли;	
	
	СтруктураДанные.Вставить(
		"ВидЦен",
		Договор.ВидЦен);
	
	Возврат СтруктураДанные;
	
КонецФункции 

