
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	ОчиститьСообщения();
	
	МассивДок = Новый Массив;
	
	Если ПараметрыВыполненияКоманды.Источник.Элементы.Найти("Список") <> Неопределено Тогда 
		МассивДок = ПараметрыВыполненияКоманды.Источник.ТекущийЭлемент.ВыделенныеСтроки;
	ИНаче
		МассивДок.Добавить(ПараметрКоманды);
	КонецЕсли;
	
	МассивНаименований = ПолучитьНаСетветеМассивНаименованийИспользуемыхБанков();
	
	СтруктураМассивовДокументов = Новый Структура;
	СтруктураМассивовДокументов.Вставить("МассивНекорректныхДокументов", Новый Массив);
	Для Каждого Банк Из МассивНаименований Цикл
		СтруктураМассивовДокументов.Вставить(Строка("МассивДокументов" + Банк), Новый Массив);
	КонецЦикла;
	
	РасспределитьДокументыПоМассивам(МассивДок, СтруктураМассивовДокументов);
	
	Для Каждого Наименования Из МассивНаименований Цикл 
		
		Если Наименования = "TBCBGE22" Тогда
			
			Сертификат = "";
			ПарольСертификата = "";
			
			Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Наименования) Тогда 
				МассивДокументов = СтруктураМассивовДокументов["МассивДокументов"+Наименования];
			Иначе
				Продолжить;
			КонецЕсли;
			
			Если МассивДокументов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтруктураСертификатИзНастроекПользователя = TBC_СертификатИзНастроекПользователя();
			Если ЗначениеЗаполнено(СтруктураСертификатИзНастроекПользователя.Сертификат) Тогда
				Сертификат = СтруктураСертификатИзНастроекПользователя.Сертификат;
			КонецЕсли;
			Если ЗначениеЗаполнено(СтруктураСертификатИзНастроекПользователя.ПарольСертификата) Тогда
				ПарольСертификата = СтруктураСертификатИзНастроекПользователя.ПарольСертификата;
			КонецЕсли;
			
			Nonce = "";
			Если НЕ (ЗначениеЗаполнено(Сертификат) И ЗначениеЗаполнено(ПарольСертификата)) Тогда
				Подсказка = НСтр("ka='Введите пароль DigiPass';ru='Введите пароль DigiPass!';en='Enter the password of DigiPass!'");
				Если НЕ ВвестиСтроку(Nonce, Подсказка, 0, Истина) Тогда
					// запомнить текст напоминания
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Для Каждого Док Из МассивДокументов Цикл 
				
				Если НЕ (ЗначениеЗаполнено(Сертификат) И ЗначениеЗаполнено(ПарольСертификата)) Тогда
					ФормаОбработки = ПолучитьФорму("Обработка.ИнтеграцияСБанкомTBC.Форма");
					Сертификат = ФормаОбработки.ЭтаФорма.Сертификат;
					ПарольСертификата = ФормаОбработки.ЭтаФорма.ПарольСертификата;
				КонецЕсли;
				
				ОбновитьСтатус(Док, Nonce, Сертификат, ПарольСертификата);
				
			КонецЦикла;
			
		ИначеЕсли Наименования = "BAGAGE22" Тогда
			
			Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Наименования) Тогда 
				МассивДокументов = СтруктураМассивовДокументов["МассивДокументов"+Наименования];
			Иначе
				Продолжить;
			КонецЕсли;
			
			Если МассивДокументов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Токен = ПолучитьТокенИзБазы();
			
			Если Токен = "" Тогда 
				Токен = ОткрытьФормуМодально("Обработка.ИнтеграцияСБанком.Форма.ФормаАвторизации");
			КонецЕсли;
			
			Если Токен <> "" И Токен <> Неопределено Тогда 
				ВыполнитьОбновлениеСтатусовНаСервере(МассивДокументов, Токен);	
			КонецЕсли;
			
			СтруктураОповещения = Новый Структура("ВыгруженныеСсылки", МассивДокументов);
			
			Оповестить("ИнтеграцияСБанком_ВыгрузкаЗавершина", СтруктураОповещения);
			
		ИначеЕсли Наименования = "MIBGGE22" Тогда
			
			Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Наименования) Тогда 
				МассивДокументов = СтруктураМассивовДокументов["МассивДокументов"+Наименования];
			Иначе
				Продолжить;
			КонецЕсли;
			
			Если МассивДокументов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			//Токен = ПолучитьТокенИзБазы();
			//
			//Если Токен = "" Тогда 
			//	Токен = ОткрытьФормуМодально("Обработка.ИнтеграцияСБанком.Форма.ФормаАвторизации");
			//КонецЕсли;
			//
			//Если Токен <> "" И Токен <> Неопределено Тогда 
			//	ВыполнитьОбновлениеСтатусовНаСервере(МассивДокументов, Токен);	
			//КонецЕсли;
			//
			//СтруктураОповещения = Новый Структура("ВыгруженныеСсылки", МассивДокументов);
			//
			//Оповестить("ИнтеграцияСБанком_ВыгрузкаЗавершина", СтруктураОповещения);
			ТекПользователь = ПолучитьПользователяНаСервере();
			Токен = ИнтеграцияСБанком_НаСервере.ПолучитьТокенИзБазы("MIBGGE22");
			ОбновитьСтатусProCredit(ТекПользователь,МассивДокументов,Токен);
			
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Док Из СтруктураМассивовДокументов.МассивНекорректныхДокументов Цикл 
		
		Сообщить(НСтр("ru = 'Выгрузка в банк для документа: """+Док+""" невозможна'; ka = 'Выгрузка в банк для документа: """+Док+""" невозможна'"));

	КонецЦикла;
	//////////////////////
	
	
КонецПроцедуры  

&НаСервере
Функция ПолучитьПользователяНаСервере()

	Возврат Пользователи.ТекущийПользователь();	

КонецФункции // &НаСервере()


&НаКлиенте
Процедура ОбновитьСтатусProCredit(ТекПользователь,МассивДокументов_MIBGGE22,Токен) ЭКСПОРТ
	
	Если МассивДокументов_MIBGGE22.Количество() > 0 Тогда
		
		ПараметрыСоединенияProCredit = ИнтеграцияСБанкомProCredit_КлиентСервер.ПолучитьПараметрыСоединенияProCredit(ТекПользователь);
		
		Если НЕ ЗначениеЗаполнено(Токен) Тогда
			
			СтруктураAuthToken = ИнтеграцияСБанкомProCredit_КлиентСервер.ПолучитьAuthToken(ПараметрыСоединенияProCredit);   
			
			Если НЕ СтруктураAuthToken.Успешно Тогда 
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = НСтр("ru = 'Ошибка авторизации AuthToken: "+СтруктураAuthToken.Описание+"'; ka = 'Ошибка авторизации AuthToken: "+СтруктураAuthToken.Описание+"'");
				Сообщение.Сообщить();
				Возврат;
			КонецЕсли;
			
			ПараметрыСоединенияProCredit.Вставить("AuthToken", СтруктураAuthToken.ВозвращаемоеЗначение);   
			
		Иначе
			
			ПараметрыСоединенияProCredit.Вставить("AccessToken", Токен);
			
		КонецЕсли;
		
		СтруктураПарметровЗапросаВБанк = Новый Структура();
		СтруктураПарметровЗапросаВБанк.Вставить("ИмяМетода","GetTransferStatus");
		СтруктураПарметровЗапросаВБанк.Вставить("МассивДокументов",МассивДокументов_MIBGGE22);
		
		ДополнительныеПараметрыОповещения = Новый Структура();
		ДополнительныеПараметрыОповещения.Вставить("ПараметрыСоединенияProCredit",ПараметрыСоединенияProCredit);
		ДополнительныеПараметрыОповещения.Вставить("СтруктураПарметровЗапросаВБанк",СтруктураПарметровЗапросаВБанк);
		
		Если ЗначениеЗаполнено(Токен) Тогда  
			
			ИнтеграцияСБанкомProCredit_КлиентСервер.ВыполнитьЗапросВБанк(ПараметрыСоединенияProCredit, СтруктураПарметровЗапросаВБанк);
			
			Параметр = Новый Структура("ВыгруженныеСсылки", МассивДокументов_MIBGGE22);
			Оповестить("ИнтеграцияСБанком_ВыгрузкаЗавершена", Параметр);
			
		Иначе
			
			Подсказка = НСтр("ka='ProCredit ინტეგრაცია: შეიყვანეთ OTP –ის პაროლი';ru='Интеграция с ProCredit: Введите пароль OTP'");
			ОповещениеВводаСтроки = Новый ОписаниеОповещения("ЗавершениеВводаПароляOTP", ЭтотОбъект, ДополнительныеПараметрыОповещения);
			ПоказатьВводСтроки(ОповещениеВводаСтроки,,Подсказка,,ИСТИНА);
			
		КонецЕсли;   
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеВводаПароляOTP(Результат, ДополнительныеПараметры) ЭКСПОРТ
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		ПараметрыСоединенияProCredit = ДополнительныеПараметры.ПараметрыСоединенияProCredit;
		СтруктураПарметровЗапросаВБанк = ДополнительныеПараметры.СтруктураПарметровЗапросаВБанк;
		
		ПараметрыСоединенияProCredit.OTP = СокрЛП(Результат);
		ИнтеграцияСБанкомProCredit_КлиентСервер.ВыполнитьЗапросВБанк(ПараметрыСоединенияProCredit, СтруктураПарметровЗапросаВБанк);
		
		Оповестить("ИнтеграцияСБанком_ВыгрузкаЗавершена",  Новый Структура("ВыгруженныеСсылки", СтруктураПарметровЗапросаВБанк.МассивДокументов));
		
	ИначеЕсли СокрЛП(Результат) = "" Тогда   
		
		ТекстСообщения = НСтр("ru = 'Операция отменена. не указан OTP код'; ka = ოპერაცია გაუქმებულია. არ არის მითითებული OTP კოდი'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьТокенИзБазы();
	
	ТекПользователь = Пользователи.АвторизованныйПользователь();
	СтруктураОтветаТокена = РегистрыСведений.ТокеныПользователейBOG.Получить((Новый Структура("Пользователь, swift", ТекПользователь, "BAGAGE22")));
	
	Токен = СтруктураОтветаТокена.Токен;
	
	МинутСПоследнейЗаписи = Цел((ТекущаяДата() - СтруктураОтветаТокена.ДатаВремяПолучения)/60);
	Если МинутСПоследнейЗаписи > 14 Тогда 
		Возврат "";
	КонецЕсли;
	
	Возврат Токен;
	
КонецФункции

&НаСервере
Процедура ВыполнитьОбновлениеСтатусовНаСервере(МассивДокументов, Токен)
	
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;
	
	КоличествоОбновленныхСтатусов = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходСоСчета.Ссылка,
		|	ВЫБОР
		|		КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.ВИДЫОПЕРАЦИЙРасходСоСчета.Зарплата)
		|				ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(ПЕРЕЧИСЛЕНИЕ.ВИДЫОПЕРАЦИЙРасходСоСчета.ЗарплатаВРазрезеСотрудников)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоПакет
		|ПОМЕСТИТЬ ВТ_ВсехЗапрашиваемыхСсылок
		|ИЗ
		|	Документ.РасходСоСчета КАК РасходСоСчета
		|ГДЕ
		|	РасходСоСчета.Ссылка В(&МассивДокументов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Конвертация.Ссылка,
		|	ЛОЖЬ
		|ИЗ
		|	Документ.Конвертация КАК Конвертация
		|ГДЕ
		|	Конвертация.Ссылка В(&МассивДокументов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ВсехЗапрашиваемыхСсылок.Ссылка,
		|	ВТ_ВсехЗапрашиваемыхСсылок.ЭтоПакет,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИДДокументаВБанке,
		|	СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке КАК ТекущийСтатусДокумента
		|ИЗ
		|	ВТ_ВсехЗапрашиваемыхСсылок КАК ВТ_ВсехЗапрашиваемыхСсылок
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|		ПО ВТ_ВсехЗапрашиваемыхСсылок.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанке
		|		ПО ВТ_ВсехЗапрашиваемыхСсылок.Ссылка = СтатусыДокументовВИнтернетБанке.ДокументСсылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ВсехЗапрашиваемыхСсылок.ЭтоПакет,
		|	ВТ_ВсехЗапрашиваемыхСсылок.Ссылка,
		|	СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """")";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.УИДДокументаВБанке = "" Тогда 
			Сообщить(НСтр("ru = 'Документ "+ВыборкаДетальныеЗаписи.Ссылка+" не был выгружен ранее'; ka = 'Документ "+ВыборкаДетальныеЗаписи.Ссылка+" не был выгружен ранее'"));
			Продолжить;
		КонецЕсли;
		
		Если ВыборкаДетальныеЗаписи.ЭтоПакет Тогда 
			ИмяМетода = "api/documents/bulk/status/";
		Иначе
			ИмяМетода = "api/documents/status/";
		КонецЕсли;
		
		ПараметрыЗапроса = Новый Структура("Key", ВыборкаДетальныеЗаписи.УИДДокументаВБанке);
		Статусы = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, ПараметрыЗапроса, , Токен, ИСТИНА);
		//Статусы = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, ПараметрыЗапроса, , Токен, ЛОЖЬ);
		
		Если Статусы <> Неопределено Тогда 
			Если ТипЗнч(Статусы) = Тип("ТаблицаЗначений") Тогда 
				
				Для Каждого Строк ИЗ Статусы Цикл
					
					Если Строк.УникальныйИД = "" И ЗначениеЗаполнено(Строк.Статус) И Не Строк.Статус = "" Тогда 
						
						ПолученыйСтатус = Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке[Строк.Статус];
						
						Если ПолученыйСтатус <> ВыборкаДетальныеЗаписи.ТекущийСтатусДокумента Тогда
							ВнестиНовыйСтатусДокумента(ТекущаяДата(), 
							ВыборкаДетальныеЗаписи.Ссылка,  
							ПолученыйСтатус);
							
							КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1;
						КонецЕсли;
						
						Прервать; 
					КонецЕсли;
					
				КонецЦикла;
				
			Иначе 
				
				ПолученыйСтатус = Перечисления.СтатусыДокументовВИнтернетБанке[Статусы];
				
				Если ПолученыйСтатус <> ВыборкаДетальныеЗаписи.ТекущийСтатусДокумента Тогда 
					ВнестиНовыйСтатусДокумента(ТекущаяДата(), 
					ВыборкаДетальныеЗаписи.Ссылка, 
					ПолученыйСтатус);
				КонецЕсли;
				КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1;
				
			КонецЕсли;
		КонецЕсли;
		Попытка
			ДокОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
			а=1;
		КонецПопытки;
		
	КонецЦикла;
	
	Если КоличествоОбновленныхСтатусов > 0 Тогда 
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru = 'Статусы "+КоличествоОбновленныхСтатусов+" документов обновлены.'; ka = 'განახლებულია "+КоличествоОбновленныхСтатусов+" დოკუმენტის სტატუსები.'");
		Сообщение.Сообщить();	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВнестиНовыйСтатусДокумента(ДатаЗаполнения, ДокументСсылка, СтатусСсылка,  Сотрудник = Неопределено)
	
	Если Сотрудник = Неопределено Тогда 
		Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;
	
	НоборЗаписейСтатусыДокументовBOG = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
	НоборЗаписейСтатусыДокументовBOG.Отбор.Период.Установить(ДатаЗаполнения);
	НоборЗаписейСтатусыДокументовBOG.Отбор.ДокументСсылка.Установить(ДокументСсылка);
	НоборЗаписейСтатусыДокументовBOG.Отбор.Сотрудник.Установить(Сотрудник);
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда 
		НоборЗаписейСтатусыДокументовBOG.Отбор.Банк.Установить(ДокументСсылка.Отправитель.Банк);
	Иначе
		НоборЗаписейСтатусыДокументовBOG.Отбор.Банк.Установить(ДокументСсылка.БанковскийСчет.Банк);
	КонецЕсли;
	
	НоваяЗапись = НоборЗаписейСтатусыДокументовBOG.Добавить();
	НоваяЗапись.ДокументСсылка = ДокументСсылка;
	НоваяЗапись.Период = ДатаЗаполнения;
	//НоваяЗапись.УИДДокументаВБанке = УИДДокуента;
	НоваяЗапись.СтатусДокументаВИнтернетБанке = СтатусСсылка;
	НоваяЗапись.Сотрудник = Сотрудник;
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда 
		НоваяЗапись.Банк = ДокументСсылка.Отправитель.Банк;
	Иначе
		НоваяЗапись.Банк = ДокументСсылка.БанковскийСчет.Банк;
	КонецЕсли;
	
	НоборЗаписейСтатусыДокументовBOG.Записать();	
	
КонецПроцедуры

&НаСервере
Функция ПолучитьНаСетветеМассивНаименованийИспользуемыхБанков()
	
	МассивВозврата = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИнтеграцииСБанками.Наименование
		|ИЗ
		|	Справочник.ИнтеграцииСБанками КАК ИнтеграцииСБанками
		|ГДЕ
		|	ИнтеграцииСБанками.Предопределенный
		|	И ИнтеграцииСБанками.ЗначениеКонстанты";
	
	тзИспользуемыеБанки = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Строк Из тзИспользуемыеБанки Цикл 
		
		МассивВозврата.Добавить(Строк.Наименование);
		
	КонецЦикла;
	
	Возврат МассивВозврата;
	
КонецФункции

&НаСервере
Процедура РасспределитьДокументыПоМассивам(ДокументСсылка, СтруктураМассивовДокументов)
	
	Если ТипЗнч(ДокументСсылка) = Тип("Массив") Тогда 
		
		Для Каждого Элем Из ДокументСсылка Цикл 
			
			Если ТипЗнч(Элем) = Тип("ДокументСсылка.РасходСоСчета") Тогда 
				Свифт = Элем.БанковскийСчет.Банк.СВИФТБИК;
			ИначеЕсли ТипЗнч(Элем) = Тип("ДокументСсылка.Конвертация") Тогда
				Свифт = Элем.Отправитель.Банк.СВИФТБИК;
			КонецЕсли;
			
			ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, Элем);
			
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета") Тогда 
		
		Свифт = ДокументСсылка.БанковскийСчет.Банк.СВИФТБИК;
		ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, ДокументСсылка);
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда
		
		Свифт = ДокументСсылка.Отправитель.Банк.СВИФТБИК;
		ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, ДокументСсылка);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, ДокСсылка)
	
	Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Свифт) Тогда 
		СтруктураМассивовДокументов["МассивДокументов"+Свифт].Добавить(ДокСсылка);
	Иначе
		СтруктураМассивовДокументов.МассивНекорректныхДокументов.Добавить(ДокСсылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатус(Док, Nonce, Сертификат = "", ПарольСертификата = "")

	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Login"));
	СтруктураПараметров.Вставить("PASSWORD",  			УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Password"));
	СтруктураПараметров.Вставить("Nonce",				Nonce);
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	СтруктураПараметров.Вставить("Метод",   			"GetPaymentOrderStatus");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo");
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"">");
	
	//+++ Дмгг
	СтруктураПараметров.Вставить("Сертификат",   		Сертификат);
	СтруктураПараметров.Вставить("ПарольСертификата",   ПарольСертификата);
	//--- Дмгг
	
	МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
	
	КоллекцияОбхода = Неопределено;
	
	СВИФТБИК = "";
	
	Если ТипЗнч(Док) = Тип("ДокументСсылка.РасходСоСчета") Тогда 
		СВИФТБИК = Док.БанковскийСчет.Банк.СВИФТБИК;
	ИначеЕсли ТипЗнч(Док) = Тип("ДокументСсылка.Конвертация") Тогда
		СВИФТБИК = Док.Отправитель.Банк.СВИФТБИК; 
	КонецЕсли;
	
	КоллекцияОбхода = ПолучитьВыборкуУИД(СВИФТБИК, Док, Дата(1,1,1,0,0,0), ТекущаяДата());
	
	Если КоллекцияОбхода.Количество() = 0 Тогда 
		Сообщить(НСтр("ru = 'Документ: """+Док+""" ранее не был выгружен'; ka = 'Документ: """+Док+""" ранее не был выгружен'"));
	КонецЕсли;
	
	ПустойСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	Статусобновления = Неопределено;
	Для каждого Строк из КоллекцияОбхода Цикл 
		
		СтруктураПараметров.Вставить("УИД", Строк.УИД);
		СтруктураПараметров.Вставить("ЭтоПакет", Строк.ЭтоПакет);
		Сотрудник = Строк.Сотрудник;
		ДокументСсылка = Строк.ДокументСсылка;
		Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
		
		Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
		
		Если Структураответа.Свойство("status") Тогда 
			
			Попытка
				
				Если Строк.ЭтоПакет Тогда 
					Статусобновления = Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке[СокрЛП(Структураответа.status)];
				Иначе
					Статусобновления = Перечисления.СтатусыДокументовВИнтернетБанке[СокрЛП(Структураответа.status)];
				КонецЕсли;
				
			Исключение
				Сообщить("Не определен статус: """+СокрЛП(Структураответа.status)+"");
				Продолжить;
			КонецПопытки;
			
			Если Статусобновления <> Строк.СтатусДокументаВИнтернетБанке Тогда 
				ДатаОбновления = ТекущаяДата();
				НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
				НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
				НаборЗаписейСтатусовДокумента.Отбор.Сотрудник.Установить(Сотрудник);
				НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ДатаОбновления);
				НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(Банк);
				
				НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
				НовыйСтатус.ДокументСсылка = ДокументСсылка;
				НовыйСтатус.Период = ДатаОбновления;
				НовыйСтатус.Сотрудник = Сотрудник;
				НовыйСтатус.СтатусДокументаВИнтернетБанке = Статусобновления;
				НовыйСтатус.Банк = Банк;
				
				НаборЗаписейСтатусовДокумента.Записать();
				
				Сообщить(НСтр( "ru = 'Документу: """+ ДокументСсылка + """, присвоен статус: """ + Статусобновления + """'; ka = 'Документу: """+ ДокументСсылка + """, присвоен статус: """ + Статусобновления + """'"));
			Иначе
				Сообщить(НСтр( "ru = 'Для документа: """+ ДокументСсылка + """, не было изменений'; ka = 'Для документа: """+ ДокументСсылка + """, не было изменений'"));
			КонецЕсли;
			
		ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда 
			Сообщить(Структураответа.ТекстОшибки);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.S")
		ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.P")
		ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка")
		ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.F")
		ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.FINISHED") Тогда 
		
		Попытка
			ДокОбъект = Док.ПолучитьОбъект();
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
			Сообщить("ru = 'Не Удалось провести документ: """+ Док + """'; ka = 'Не Удалось провести документ: """+ Док + """'");
		КонецПопытки;
		
	КонецЕсли;
	//ОбновитьСтатусыДокументовНаСервере(СтруктураПараметров, Истина);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьВыборкуУИД(Банк, МассивДокументов = Неопределено, ДатаНачала, ДатаОкончания)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.ДокументСсылка,
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке,
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.Банк,
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.Сотрудник
		|ПОМЕСТИТЬ ТаблицаСрезСтатусов
		|ИЗ
		|	РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(
		|			,
		|			Банк.СВИФТБИК = &Банк
		|				И ВЫБОР
		|					КОГДА &МассивДокументов = НЕОПРЕДЕЛЕНО
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ДокументСсылка В (&МассивДокументов)
		|				КОНЕЦ
		|				И (ДокументСсылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания)) КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаСрезСтатусов.ДокументСсылка,
		|	ТаблицаСрезСтатусов.СтатусДокументаВИнтернетБанке,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД,
		|	ТаблицаСрезСтатусов.Сотрудник
		|ПОМЕСТИТЬ ТаблицаПред
		|ИЗ
		|	ТаблицаСрезСтатусов КАК ТаблицаСрезСтатусов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|		ПО ТаблицаСрезСтатусов.ДокументСсылка = УИДДокументовВИнтернетБанке.ДокументСсылка
		|			И ТаблицаСрезСтатусов.Банк = УИДДокументовВИнтернетБанке.Банк
		|			И ТаблицаСрезСтатусов.Сотрудник = УИДДокументовВИнтернетБанке.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПред.ДокументСсылка,
		|	ТаблицаПред.СтатусДокументаВИнтернетБанке,
		|	ТаблицаПред.УИД,
		|	ВЫБОР
		|		КОГДА ТаблицаПред.ДокументСсылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыоперацийРасходСоСчета.Зарплата)
		|				ИЛИ ТаблицаПред.ДокументСсылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыоперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников)
		|			ТОГДА ВЫБОР
		|					КОГДА ТаблицаПред.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ЛОЖЬ
		|				КОНЕЦ
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоПакет,
		|	ТаблицаПред.Сотрудник
		|ИЗ
		|	ТаблицаПред КАК ТаблицаПред
		|ГДЕ
		|	ТаблицаПред.СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.S)
		|	И ТаблицаПред.СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка)
		|	И ТаблицаПред.УИД <> """"
		|	И (ТаблицаПред.ДокументСсылка ССЫЛКА Документ.РасходСоСчета
		|			ИЛИ ТаблицаПред.ДокументСсылка ССЫЛКА Документ.Конвертация)";
	
	Запрос.УстановитьПараметр("Банк", Банк);
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

&НаСервере
Функция TBC_СертификатИзНастроекПользователя()
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Структура("Сертификат,ПарольСертификата");

	Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ИспользоватьСертификат") Тогда
	
		TBC_Сертификат = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Сертификат");
		Попытка
			
			ПутьКВременномуФайлуСертификата = ПолучитьИмяВременногоФайла("pfx");
			ТекущийУникальныйИдентификатор = Новый УникальныйИдентификатор();
			ПараметрыЭлементаСправочникаФайлы = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляСохранения(TBC_Сертификат, ТекущийУникальныйИдентификатор);			
			СтруктураВозврата = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаИДвоичныеДанные(ПараметрыЭлементаСправочникаФайлы.Версия,,ТекущийУникальныйИдентификатор);
			
			Если ЭтоАдресВременногоХранилища(СтруктураВозврата.ДвоичныеДанные) Тогда
				ДвоичныеДанныеСертификата = ПолучитьИзВременногоХранилища(СтруктураВозврата.ДвоичныеДанные);
			Иначе
				ДвоичныеДанныеСертификата = СтруктураВозврата.ДвоичныеДанные;
			КонецЕсли;
			ДвоичныеДанныеСертификата.Записать(ПутьКВременномуФайлуСертификата);
			
