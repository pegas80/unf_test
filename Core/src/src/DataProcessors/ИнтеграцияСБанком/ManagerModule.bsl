Функция ОбработатьТекстДляXML(ВходящаяСтрока)
	ПЕРЕМ РЕЗ;
	
	РЕЗ=Строка(ВходящаяСтрока);
	
	ТекДлинаСтроки = СтрДлина(ВходящаяСтрока);
	
	РЕЗ=СтрЗаменить(РЕЗ,"&","&amp;");
	РЕЗ=СтрЗаменить(РЕЗ,"<","&lt;");
	РЕЗ=СтрЗаменить(РЕЗ,">","&gt;");
	РЕЗ=СтрЗаменить(РЕЗ,"'","&apos;");
	РЕЗ=СтрЗаменить(РЕЗ,"""","&quot;");
	
	Возврат РЕЗ;	
КонецФункции
// DO-25848

Функция ПолучитьДанныеДокументовПоИнтернетБанку(МассивДокументов, ДатаСреза) Экспорт
	
	СоответствиеВозврата = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатусыДокументовВИнтернетБанке.ДокументСсылка,
	|	СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке,
	|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД
	|ИЗ
	|	РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(, ДокументСсылка В (&МассивДокументов)) КАК СтатусыДокументовВИнтернетБанке
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	|		ПО СтатусыДокументовВИнтернетБанке.ДокументСсылка = УИДДокументовВИнтернетБанке.ДокументСсылка";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("ДатаСреза", ДатаСреза);
	
	ВыборкаРезультат = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаРезультат.Следующий() Цикл 
		
		СтруктураДанных = Новый Структура;
		
		СтруктураДанных.Вставить("УИД", ВыборкаРезультат.УИД);
		СтруктураДанных.Вставить("Статус", ВыборкаРезультат.СтатусДокументаВИнтернетБанке);
		Если ВыборкаРезультат.УИД = "" Тогда 
			СтруктураДанных.Вставить("Выгружено", ЛОЖЬ);
		Иначе
			СтруктураДанных.Вставить("Выгружено", Истина);
		КонецЕсли;
		
		СоответствиеВозврата.Вставить(ВыборкаРезультат.ДокументСсылка, СтруктураДанных);
		
	КонецЦикла;
	
	Возврат СоответствиеВозврата;
	
КонецФункции
