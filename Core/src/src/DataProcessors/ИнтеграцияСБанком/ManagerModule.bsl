Функция ОтправитьЗапросXML(ПараметрыЗапроса, Режим = 1, Token, ИмяМетода, ЗапускатьРеальныйБанк = ЛОЖЬ) Экспорт
	
	Перем mhttp;
	
	Сервер = "https://cib2-web-dev.bog.ge:8090/";
	Если НЕ ЗапускатьРеальныйБанк Тогда 
		Сервер = "https://cib2-web-dev.bog.ge:8090/";
	ИНаче
		Сервер = "https://api.businessonline.ge/";
	КонецЕсли;

	Если mhttp = Неопределено Тогда
		mhttp = Новый COMОбъект("WinHttp.WinHttpRequest.5.1"); 
	Конецесли;
	
	mhttp.SetTimeouts(6000000, 6000000, 6000000, 6000000);
	
	Если ИмяМетода = "api/documents/foreign" ИЛИ ИмяМетода = "api/documents/domestic" ИЛИ ИмяМетода = "api/documents/conversion" ИЛИ ИмяМетода = "api/documents/bulk/domestic" ИЛИ ИмяМетода = "api/documents/bulk/foreign" Тогда  
		mhttp.open("POST", Сервер+ИмяМетода, False);	
	ИначеЕсли ИмяМетода = "api/documents/status/" ИЛИ ИмяМетода = "api/documents/bulk/status/" Тогда 
		Если ЗначениеЗаполнено(ПараметрыЗапроса.param.Key) Тогда 
			mhttp.open("GET", Сервер+ИмяМетода+СтрЗаменить(ПараметрыЗапроса.param.Key,Символы.НПП,"")+"", False);		
		Иначе 	
			Возврат Неопределено;
		КонецЕсли;
	ИначеЕсли ИмяМетода = "api/rates/commercial/" Тогда  
		mhttp.open("GET", Сервер+ИмяМетода+ПараметрыЗапроса.param.currency+"", False);	
	ИначеЕсли ИмяМетода = "api/rates/commercial//" Тогда  
		mhttp.open("GET", Сервер+"api/rates/commercial/"+ПараметрыЗапроса.param.sellCurrency+"/"+ПараметрыЗапроса.param.buyCurrency, False);	
	ИначеЕсли ИмяМетода = "api/accounts/" Тогда 
		mhttp.open("GET", Сервер+ИмяМетода+ПараметрыЗапроса.param.accountNumber+"/"+ПараметрыЗапроса.param.currency+"", False);	
	ИначеЕсли ИмяМетода = "api/statement/" Тогда 	                                            
		mhttp.open("GET", Сервер+ИмяМетода+ПараметрыЗапроса.param.accountNumber+"/"+ПараметрыЗапроса.param.currency+"/"+ПараметрыЗапроса.param.startDate+"/"+ПараметрыЗапроса.param.endDate+"", False);	
	ИначеЕсли ИмяМетода = "api/statement////" Тогда 	                                            
		mhttp.open("GET", Сервер+ИмяМетода+ПараметрыЗапроса.param.accountNumber+"/"+ПараметрыЗапроса.param.currency+"/"+СтрЗаменить(ПараметрыЗапроса.param.id, Символы.НПП,"")+"/"+ПараметрыЗапроса.param.page+"", False);
	ИначеЕсли ИмяМетода = "api/statement/summary/" Тогда  	
		mhttp.open("GET", Сервер+ИмяМетода+ПараметрыЗапроса.param.accountNumber+"/"+ПараметрыЗапроса.param.currency+"/"+СтрЗаменить(ПараметрыЗапроса.param.id, Символы.НПП,"")+"", False);
		//api/statement/summary/{accountNumber}/{currency}/{id}
	КонецЕсли;
	
	//Попытка
	//	mhttp.SetClientCertificate("LOCAL_MACHINE\\Intermediate Certification Authorities\\Certificates\\CIB2-WEB-DEV.bog.ge");
	//Исключение
	//	Сообщение = Новый СообщениеПользователю;
	//	Сообщение.Текст = НСтр("ka='ინფორმაციის გადაცემის შეცდომა! შეამოწმეთ აწყობის პარამეტრების შევსება';ru='Ошибка передачи информации! Проверьте правильность заполнения настроек';en='Information Communication error! Check the correctness of the settings'");
	//	ПриЗагрузкеВозниклиОшибки = Истина
	//КонецПопытки;	
	
	mhttp.setRequestHeader("Content-Type", "text/xml; charset=utf-8");
	mhttp.setRequestHeader("Authorization", "Bearer " + Token + " ");			
	//mhttp.setRequestHeader("Accept", "application/xml");  // если хочу ответ в формате XML	
	
	//+++
	DocumentNo = "b6b20b62-d596-4a5f-bfd5-97cd2869bf6e";
	UniqueId = "b6b20b62-d596-4a5f-bfd5-97cd2869bf6e";
