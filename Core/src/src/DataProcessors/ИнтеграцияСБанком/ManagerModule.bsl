		+"<BeneficiaryBankCode>"+СокрЛП(ПараметрыЗапроса.param.BeneficiaryBankCode)+"</BeneficiaryBankCode>"
		+"<BeneficiaryBankName>"+СокрЛП(ОбработатьТекстДляXML(ПараметрыЗапроса.param.BeneficiaryBankName))+"</BeneficiaryBankName>"
