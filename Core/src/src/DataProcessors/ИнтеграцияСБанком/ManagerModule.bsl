
Функция ВыполнитьМетодСервиса(ИмяМетода, ПараметрыМетода = Неопределено, Режим = 1, Token, ЗапускатьРеальныйБанк = ЛОЖЬ) Экспорт
	
	ПараметрыЗапроса = Новый Структура;     
	
	Если НЕ ПараметрыМетода = Неопределено Тогда
		ПараметрыЗапроса.Вставить("param", ПараметрыМетода);
	КонецЕсли;
	
	//результатом является Массив Соответсвий
	//РезультатЗапроса = ОтправитьЗапросXML(ПараметрыЗапроса, Режим, Token, ИмяМетода, ЗапускатьРеальныйБанк);
	РезультатЗапроса = ОтправитьЗапросXML_1С(ПараметрыЗапроса, Режим, Token, ИмяМетода, ЗапускатьРеальныйБанк);
	
	Если ИмяМетода = "api/documents/status/" Тогда
		//возвращаем статус
		
		Если РезультатЗапроса = Неопределено Тогда 
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ka='ინფორმაციის გადაცემის შეცდომა! დოკუმენტს არ აქვს მინიჭებული უნიკალური გასაღები!';ru='Ошибка передачи информации! Документу не присвоен уникальный ключ!';en='Information Communication error! The document has not been assigned a unique key!'");		
			Сообщение.Сообщить();
		Иначе 
			
			КодОшибки = РезультатЗапроса.Получить("RejectCode");
			
			Если КодОшибки = "22" Тогда 
				ТекстОшибки = "გაუქმებულია, დამატებითი ინფორმაციისთვის დაგვიკავშირდით 2444444"; 
			ИначеЕсли КодОшибки = "21" Тогда 
				ТекстОшибки = "მიმღების ანგარიში და დასახელება არ ედრება"; 
			ИначеЕсли КодОшибки = "20" Тогда 
				ТекстОшибки = "დასააქცეპდებელი ბარათი"; 
			ИначеЕсли КодОшибки = "19" Тогда 
				ТекстОшибки = "ვადაგასული ბარათი"; 
			ИначеЕсли КодОшибки = "18" Тогда 
				ТекстОшибки = "დაბლოკილი ბარათი"; 
			ИначеЕсли КодОшибки = "17" Тогда 
				ТекстОшибки = "არასაკმარისი თანხა"; 
			ИначеЕсли КодОшибки = "16" Тогда 
				ТекстОшибки = "ფონტი არ იკითხება"; 
			ИначеЕсли КодОшибки = "15" Тогда 
				ТекстОшибки = "არასწორი დანიშნულება";
			ИначеЕсли КодОшибки = "14" Тогда 
				ТекстОшибки = "მიმღების ანგარიში არასწორია";
			ИначеЕсли КодОшибки = "13" Тогда 
				ТекстОшибки = "არ არის მითითებული სახაზინო კოდი";
			ИначеЕсли КодОшибки = "12" Тогда 
				ТекстОшибки = "არასწორი IBAN-ის ფორმატი";
			Иначе 
				Возврат РезультатЗапроса.Получить("Status");
			КонецЕсли;
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = НСтр("ka='BoG ის სერვისთან მიმართვის შეცდომა!';ru='Ошибка обращения к сервисам BoG!';en='Error handling services to BoG!'") + Символы.ПС
			+ НСтр("ru = 'Код ошибки: '; ka = 'შეცდომის კოდი: '") + КодОшибки + Символы.ПС 
			+ НСтр("ru = 'Описание: '; ka = 'აღწერა: '") + ТекстОшибки + Символы.ПС;
			
			Сообщение.Сообщить();
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/rates/commercial/" Тогда 
		
		Если РезультатЗапроса = Неопределено Тогда  
			Возврат Неопределено;
		ИначеЕсли ТипЗнч(РезультатЗапроса) = Тип("Строка") Тогда
			Возврат РезультатЗапроса;
		Иначе
			//возвращаем курсы коммерческих валют
			Структура = Новый Структура;
			Структура.Вставить("КурсПродажи", РезультатЗапроса.Получить("Sell"));
			Структура.Вставить("КурсПокупки", РезультатЗапроса.Получить("Buy"));			
			Возврат Структура;
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/rates/commercial//" Тогда 
		
		Если РезультатЗапроса = Неопределено ИЛИ ТипЗнч(РезультатЗапроса) = Тип("Строка") Тогда
			Возврат Неопределено;
		Иначе
			//возвращаем курсы коммерческих валют
			Структура = Новый Структура;
			Структура.Вставить("КроссКурс", РезультатЗапроса);
			
			Возврат Структура;
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/accounts/" Тогда	
		
		Если РезультатЗапроса = Неопределено ИЛИ ТипЗнч(РезультатЗапроса) = Тип("Строка") Тогда
			Возврат Неопределено;
		Иначе 
			//возвращаем остаток на счете
			Структура = Новый Структура;
			Структура.Вставить("ДоступныйОстатокНаСчете", РезультатЗапроса.Получить("AvailableBalance"));
			Структура.Вставить("ТекущийОстатокНаСчете", РезультатЗапроса.Получить("CurrentBalance"));
			
			Возврат Структура;		
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/documents/bulk/domestic" ИЛИ ИмяМетода = "api/documents/bulk/foreign"  Тогда 
		
		Если ТипЗнч(РезультатЗапроса) = Тип("Соответствие") Тогда
			Для Каждого ЭлементМассива Из РезультатЗапроса Цикл 
				Если ЭлементМассива.Значение = "An error has occurred." Тогда 
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = НСтр("ka='BoG ის სერვისთან მიმართვის შეცდომა!';ru='Ошибка обращения к сервисам BoG!';en='Error handling services to BoG!'") + Символы.ПС
					+ НСтр("ru = 'Код ошибки: '; ka = 'შეცდომის კოდი: '") + "500" + Символы.ПС 
					+ НСтр("ru = 'Описание: '; ka = 'აღწერა: '") + ЭлементМассива.Значение + Символы.ПС;
					
					Сообщение.Сообщить();
				КонецЕсли;			
			КонецЦикла;	
		Иначе 	
			Структура = Новый Структура;
			Структура.Вставить("Результат", 0);
			Структура.Вставить("УникальныйКлюч", СтрЗаменить(СтрЗаменить(РезультатЗапроса, ",", ""),Символы.НПП,"")); 
			
			Возврат Структура;			
			
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/documents/bulk/status/" Тогда
		
		ТаблицаСтатусов = Новый ТаблицаЗначений;
		
		ТаблицаСтатусов.Колонки.Добавить("УникальныйИД" , Новый ОписаниеТипов("Строка"));
		ТаблицаСтатусов.Колонки.Добавить("Статус"       , Новый ОписаниеТипов("Строка"));
		
		Если ТипЗнч(РезультатЗапроса) = Тип("Соответствие") Тогда
			Для Каждого ЭлементМассива Из РезультатЗапроса Цикл 
				Если ЭлементМассива.Значение = "An error has occurred." Тогда 
					
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = НСтр("ka='BoG ის სერვისთან მიმართვის შეცდომა!';ru='Ошибка обращения к сервисам BoG!';en='Error handling services to BoG!'") + Символы.ПС
					+ НСтр("ru = 'Код ошибки: '; ka = 'შეცდომის კოდი: '") + "500" + Символы.ПС 
					+ НСтр("ru = 'Описание: '; ka = 'აღწერა: '") + ЭлементМассива.Значение + Символы.ПС;
					
					Сообщение.Сообщить();
				ИначеЕсли ТипЗнч(ЭлементМассива.Значение) = Тип("Массив") Тогда 
					
					Для Каждого СтрМассива Из ЭлементМассива.Значение Цикл											
						НоваяСтрока = ТаблицаСтатусов.Добавить();
						НоваяСтрока.УникальныйИД = СтрЗаменить(СтрМассива.Получить("UniqueId"), "-", "");
						НоваяСтрока.Статус       = СтрМассива.Получить("Status");
					КонецЦикла;
					
					Возврат ТаблицаСтатусов;
				Иначе 
					НоваяСтрока = ТаблицаСтатусов.Добавить();
					НоваяСтрока.УникальныйИД = РезультатЗапроса.Получить("UniqueId");
					НоваяСтрока.Статус       = РезультатЗапроса.Получить("Status");
				КонецЕсли;			
			КонецЦикла;				
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/statement/" Тогда
		
		Если Не РезультатЗапроса = Неопределено Тогда 
			
			Структура = Новый Структура;
			Структура.Вставить("Id", РезультатЗапроса.Получить("Id"));
			Структура.Вставить("Count", РезультатЗапроса.Получить("Count")); 
			
			Возврат Структура;	
			
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "api/statement////" Тогда
		
		Если Не ТипЗнч(РезультатЗапроса) = Тип("Массив") И Не РезультатЗапроса = Неопределено Тогда
			
			Если РезультатЗапроса["Message"] = "An error has occurred." Тогда 
				
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = НСтр("ka='მითითებული პერიოდისთვის მონაცემები ვერ მოიძებნა!';ru='Не найдено данных на указанный период!';en='Found data for this period!'") + Символы.ПС
				+ НСтр("ru = 'Код ошибки: '; ka = 'შეცდომის კოდი: '") + "500" + Символы.ПС;
				
				Сообщение.Сообщить();			
			КонецЕсли;    
		Иначе 
			Возврат РезультатЗапроса;
			
		КонецЕсли;	
	ИначеЕсли ИмяМетода = "api/statement/summary/" Тогда
		
		Если Не РезультатЗапроса = Неопределено Тогда
			Возврат РезультатЗапроса;			
		Иначе 
			Если РезультатЗапроса["Message"] = "An error has occurred." Тогда 
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = НСтр("ka='BoG ის სერვისთან მიმართვის შეცდომა!';ru='Ошибка обращения к сервисам BoG!';en='Error handling services to BoG!'") + Символы.ПС
				+ НСтр("ru = 'Код ошибки: '; ka = 'შეცდომის კოდი: '") + "500" + Символы.ПС 
				+ НСтр("ru = 'Описание: '; ka = 'აღწერა: '") + Символы.ПС;
				
				Сообщение.Сообщить();			
			КонецЕсли; 
			
		КонецЕсли;	
	Иначе 
		
		Если Не РезультатЗапроса = Неопределено Тогда 
			
			Для Каждого ЭлементМассива Из РезультатЗапроса Цикл 				
				Если Не ТипЗнч(ЭлементМассива) = Тип("Соответствие") Тогда            
					Если ЭлементМассива.Значение = "An error has occurred." Тогда 
						
						Сообщение = Новый СообщениеПользователю;
						Сообщение.Текст = НСтр("ka='BoG ის სერვისთან მიმართვის შეცდომა!';ru='Ошибка обращения к сервисам BoG!';en='Error handling services to BoG!'") + Символы.ПС
						+ НСтр("ru = 'Код ошибки: '; ka = 'შეცდომის კოდი: '") + "500" + Символы.ПС 
						+ НСтр("ru = 'Описание: '; ka = 'აღწერა: '") + ЭлементМассива.Значение + Символы.ПС;
						
						Сообщение.Сообщить();
					КонецЕсли;			
				Иначе 
					Результат = ЭлементМассива.Получить("ResultCode");
					// проверки по кодам --
					Если Результат = 0 Тогда
						
						Структура = Новый Структура;
						Структура.Вставить("Результат", ЭлементМассива.Получить("ResultCode"));
						Структура.Вставить("УникальныйКлюч", ЭлементМассива.Получить("UniqueKey")); 
						
						Возврат Структура;
						
					ИначеЕсли Результат = 147 Тогда 
						ТекстСообщения = "არასწორი IBAN-ის ფორმატი";
					ИначеЕсли Результат = 333 Тогда
						ТекстСообщения = "სამუშაო ნაშთი არ არის საკმარისი. გსურთ საბუთის შექმნა?";
					ИначеЕсли Результат = 363 Тогда
						ТекстСообщения = "დოკუმენტი დუბლირებულია. გსურთ საბუთის შექმნა?";
					ИначеЕсли Результат = 112 Тогда
						ТекстСообщения = "გამგზავნის ანგარიში არასწორია";
					ИначеЕсли Результат = 4 Тогда
						ТекстСообщения = "კონვერტაციის კურსი არასწორია";
					ИначеЕсли Результат = 111 Тогда
						ТекстСообщения = "გადარიცხვის ვალუტა არასწორია";
					ИначеЕсли Результат = 110 Тогда
						ТекстСообщения = "თანხის ფორმატი არასწორია";
					ИначеЕсли Результат = 91 Тогда
						ТекстСообщения = "დანიშნულება გრძელია";
					ИначеЕсли Результат = 90 Тогда
						ТекстСообщения = "მიმღების დასახელება გრძელია";
					ИначеЕсли Результат = 444 Тогда
						ТекстСообщения = "თანხა არ არის საკმარისი";
						//+++ Истомин, Костыль. Документ выгружается
						Сообщить("თანხა არ არის საკმარისი. საჭიროა კორექტირება");
						Структура = Новый Структура;
						Структура.Вставить("Результат", ЭлементМассива.Получить("ResultCode"));
						Структура.Вставить("УникальныйКлюч", ЭлементМассива.Получить("UniqueKey")); 
						//---
						
						Возврат Структура;
					ИначеЕсли Результат = 999 Тогда
						ТекстСообщения = "document.result.code.general.exception";
					ИначеЕсли Результат = 123 Тогда
						ТекстСообщения = "document.result.code.general.exception";
					ИначеЕсли Результат = 122 Тогда
						ТекстСообщения = "document.result.code.general.exception";
					ИначеЕсли Результат = 47 Тогда
						ТекстСообщения = "ვალუტირების თარიღი არასწორია";
					ИначеЕсли Результат = 48 Тогда
						ТекстСообщения = "ვალუტირების თარიღი არასწორია";
					ИначеЕсли Результат = 57 Тогда
						ТекстСообщения = "დოკუმენტის ვალიდაციისას დაფიქსირდა შეცდომა";
					ИначеЕсли Результат = 40 Тогда
						ТекстСообщения = "ხაზინაში გადარიცხვის პარამეტრები არასწორია";
					ИначеЕсли Результат = 36 Тогда
						ТекстСообщения = "გამგზავნის საიდენტიფიკაციო კოდი არასწორია";
					ИначеЕсли Результат = 35 Тогда
						ТекстСообщения = "გამგზავნის ანგარიშის ტიპი არასწორია";
					ИначеЕсли Результат = 33 Тогда
						ТекстСообщения = "გამგზავნის ანგარიში არასწორია";
					ИначеЕсли Результат = 34 Тогда
						ТекстСообщения = "გამგზავნის ანგარიშის ვალუტა არასწორია";
					ИначеЕсли Результат = 150 Тогда
						ТекстСообщения = "აუცილებელი ველი";
					ИначеЕсли Результат = 151 Тогда
						ТекстСообщения = "ველის მნიშვნელობა უნდა იყოს რიცვითი";
					ИначеЕсли Результат = 152 Тогда
						ТекстСообщения = "ველის ფორმატი არასწორია";
					ИначеЕсли Результат = 153 Тогда
						ТекстСообщения = "ველის სიგრძე არასწორია";
					ИначеЕсли Результат = 154 Тогда
						ТекстСообщения = "ველის მნიშვნელობა არ მოიძებნა, აირჩიეთ ჩამონათვალიდან";			
					ИначеЕсли Результат = 121 Тогда
						ТекстСообщения = "ოპერაციის ვალუტა არასწორია";
					ИначеЕсли Результат = 120 Тогда
						ТекстСообщения = "ოპერაციის ვალუტისთვის ვერ მოიძებნა კურსი";
					ИначеЕсли Результат = 119 Тогда
						ТекстСообщения = "დანიშნულება დასაშვებზე გრძელია";
					ИначеЕсли Результат = 118 Тогда
						ТекстСообщения = "დოკუმენტში პარამეტრები არასწორია";
					ИначеЕсли Результат = 117 Тогда
						ТекстСообщения = "გამგზავნი და მიმღები ფილიალი სხვადასხვაა";			
					ИначеЕсли Результат = 116 Тогда
						ТекстСообщения = "გამგზავნი და მიმღები სხვადასხვა კლიენტია";			
					ИначеЕсли Результат = 115 Тогда
