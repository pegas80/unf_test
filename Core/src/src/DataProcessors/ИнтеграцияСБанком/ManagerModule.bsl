		+"<PaymentDetail>"+СокрЛП(ОбработатьТекстДляXML(ПараметрыЗапроса.param.PaymentDetail))+"</PaymentDetail>"
		+"<ValueDate>"+СокрЛП(ДельтаНСФ.ДатаВремяВСтроку(ТекущаяДата()))+"</ValueDate>"
