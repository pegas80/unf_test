Функция СоздатьСчетКонтрагента(ВладелецСчета, НомерСчета, тзСозданныСчетов)  
	
	ПоисКонтрагента = тзСозданныСчетов.НайтиСтроки(Новый Структура("НомерСчета", НомерСчета));
	Если ПоисКонтрагента.Количество() > 0 Тогда 
		Возврат ПоисКонтрагента[0].Ссылка;
	КонецЕсли;
	
	КодБанка = Сред(НомерСчета, 5, 2);
	НаименованиеВалюты = Прав(НомерСчета, 3);
	
	Банк = Справочники.Банки.ПустаяСсылка();   
	Валюта = Справочники.Валюты.НайтиПоНаименованию(НаименованиеВалюты);    
	СчетУчета = ПланыСчетов.Управленческий.ПустаяСсылка();
	СчетУчетаРегл = ПланыСчетов.Хозрасчетный.НайтиПоКоду("1200");
	
	Если КодБанка = "TB" Тогда 
		СВИФТБИК = "TBCBGE22";
		Банк = Справочники.Банки.НайтиПоРеквизиту("СВИФТБИК", СВИФТБИК);
	ИначеЕсли КодБанка = "BG" Тогда
		СВИФТБИК = "BAGAGE22";   
		Банк = Справочники.Банки.НайтиПоРеквизиту("СВИФТБИК", СВИФТБИК);
	ИначеЕсли КодБанка = "PC" Тогда
		СВИФТБИК = "MIBGGE22";   
		Банк = Справочники.Банки.НайтиПоРеквизиту("СВИФТБИК", СВИФТБИК);
	КонецЕсли;
	
	НовыйСчет = Справочники.БанковскиеСчета.СоздатьЭлемент();  
	НовыйСчет.Наименование = НомерСчета;
	НовыйСчет.ВидСчета = "Расчетный";
	НовыйСчет.Владелец = ВладелецСчета;
	НовыйСчет.НомерСчета = НомерСчета; 
	НовыйСчет.ВалютаДенежныхСредств = ?(ЗначениеЗаполнено(Валюта), Валюта, БанковскийСчет.ВалютаДенежныхСредств);
	НовыйСчет.Банк = Банк;
	НовыйСчет.СчетУчета = СчетУчета;
	НовыйСчет.СчетУчетаРегл = СчетУчетаРегл;
	
	НовыйСчет.Записать(); 
	
	// Сделаем новый счет, счетом по умолчанию
	Если ТипЗнч(ВладелецСчета) = Тип("СправочникСсылка.Контрагенты") Тогда 
		Контрагентобъект = ВладелецСчета.ПолучитьОбъект();
		Контрагентобъект.БанковскийСчетПоУмолчанию = НовыйСчет.Ссылка;
		Контрагентобъект.Записать();
	КонецЕсли;
	
	СтрокаСчета = тзСозданныСчетов.Добавить();
	СтрокаСчета.НомерСчета = НомерСчета;
	СтрокаСчета.Ссылка = НовыйСчет.Ссылка;
	
	Возврат НовыйСчет.Ссылка;
	
КонецФункции

Функция СоздатьКонтрагента(ИНН, Наименование, СтруктураТипаКонтрагента, тзСозданныеКонтрагенты)
	
	Если ЗначениеЗаполнено(ИНН) Тогда
		ПоисКонтрагента = тзСозданныеКонтрагенты.НайтиСтроки(Новый Структура("ИНН", ИНН));
		Если ПоисКонтрагента.Количество() > 0 Тогда 
			Возврат ПоисКонтрагента[0].Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	ДанныеКонтрагента = Неопределено;
	Если ЗначениеЗаполнено(ИНН) Тогда 
		ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервере(ИНН);
	КонецЕсли;
	
	ДлинаИНН = СтрДлина(СокрЛп(ИНН));
	
	СправочникМенеджер = Справочники.Контрагенты;
	НовыйКонтрагент = СправочникМенеджер.СоздатьЭлемент(); 
	НовыйКонтрагент.Заполнить(Неопределено);
	СтруктураСчетов = РегламентированныйУчетСервер.ПолучитьСчетаКонтрагентаПоУмолчанию(); 
	
	НовыйКонтрагент.СчетУчетаРасчетовСПокупателемРегл = СтруктураСчетов.СчетУчетаРасчетовСПокупателемРегл;
	НовыйКонтрагент.СчетУчетаАвансовПокупателяРегл = СтруктураСчетов.СчетУчетаАвансовПокупателяРегл;
	НовыйКонтрагент.СчетУчетаРасчетовСПоставщикомРегл = СтруктураСчетов.СчетУчетаРасчетовСПоставщикомРегл;
	НовыйКонтрагент.СчетУчетаАвансовПоставщикуРегл = СтруктураСчетов.СчетУчетаАвансовПоставщикуРегл;
	
	НовыйКонтрагент.СчетУчетаРасчетовСПокупателем = ПланыСчетов.Управленческий.РасчетыСПокупателями;
	НовыйКонтрагент.СчетУчетаАвансовПокупателя = ПланыСчетов.Управленческий.РасчетыПоАвансамПолученным;
	НовыйКонтрагент.СчетУчетаРасчетовСПоставщиком = ПланыСчетов.Управленческий.РасчетыСПоставщиками;
	НовыйКонтрагент.СчетУчетаАвансовПоставщику = ПланыСчетов.Управленческий.РасчетыПоАвансамВыданным;
	
	НовыйКонтрагент.ВестиРасчетыПоДоговорам = Истина;
	НовыйКонтрагент.ВестиРасчетыПоДокументам = Истина;
	НовыйКонтрагент.ВестиРасчетыПоЗаказам = Истина;
	НовыйКонтрагент.ВестиУчетОплатыПоСчетам = Истина;
	
	Если ДлинаИНН = 12 Тогда 
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
	ИначеЕсли ДлинаИНН = 9 Тогда
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	Иначе
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель;
	КонецЕсли;
	
	Если ДанныеКонтрагента = Неопределено ИЛИ (ТипЗнч(ДанныеКонтрагента) = Тип("Структура") И ДанныеКонтрагента.Свойство("ИНН") И ДанныеКонтрагента.ИНН = "")  Тогда 
		ЗаполнитьКонтрагентаИмеющимисяДанными(НовыйКонтрагент, ИНН, Наименование, СтруктураСчетов, СтруктураТипаКонтрагента);
	Иначе        
		НовыйКонтрагент.ИНН = ИНН; 
		ЗаполнитьКонтрагентаДаннымиRS(НовыйКонтрагент, ДанныеКонтрагента, СтруктураСчетов, СтруктураТипаКонтрагента);
	КонецЕсли;
	
	НовыйКонтрагент.Записать();     
	
	СтрокаКонтра = тзСозданныеКонтрагенты.Добавить();
	СтрокаКонтра.ИНН = ИНН;
	СтрокаКонтра.Ссылка = НовыйКонтрагент.Ссылка;
	
	Возврат НовыйКонтрагент.Ссылка;
	
КонецФункции

Функция ПолучитьЗаписьНачисления(СтруктураОтбора)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.Период КАК Период,
		|	ПлановыеНачисленияИУдержания.Организация КАК Организация,
		|	ПлановыеНачисленияИУдержания.Подразделение КАК Подразделение,
		|	ПлановыеНачисленияИУдержания.Сотрудник КАК Сотрудник,
		|	ПлановыеНачисленияИУдержания.Должность КАК Должность,
		|	ПлановыеНачисленияИУдержания.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
		|	ПлановыеНачисленияИУдержания.Валюта КАК Валюта,
		|	ПлановыеНачисленияИУдержания.Сумма КАК Сумма,
		|	ПлановыеНачисленияИУдержания.Актуальность КАК Актуальность,
		|	ПлановыеНачисленияИУдержания.СчетЗатрат КАК СчетЗатрат,
		|	ПлановыеНачисленияИУдержания.СтатьяДоходовИРасходов КАК СтатьяДоходовИРасходов
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ВложенныйЗапрос.Период) КАК Период,
		|		ВложенныйЗапрос.ВидНачисленияУдержанияТип КАК ВидНачисленияУдержанияТип
		|	ИЗ
		|		(ВЫБРАТЬ
		|			ПлановыеНачисленияИУдержания.Период КАК Период,
		|			ПлановыеНачисленияИУдержания.ВидНачисленияУдержания.Тип КАК ВидНачисленияУдержанияТип
		|		ИЗ
		|			РегистрСведений.ПлановыеНачисленияИУдержания КАК ПлановыеНачисленияИУдержания
		|		ГДЕ
		|			ПлановыеНачисленияИУдержания.ВидНачисленияУдержания.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыНачисленийИУдержаний."+СтруктураОтбора.ТипНачисленияУдержания+")
		|			И ПлановыеНачисленияИУдержания.Период <= &ДатаДокумента) КАК ВложенныйЗапрос
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВложенныйЗапрос.ВидНачисленияУдержанияТип) КАК ВложенныйЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПлановыеНачисленияИУдержания КАК ПлановыеНачисленияИУдержания
		|		ПО ВложенныйЗапрос.Период = ПлановыеНачисленияИУдержания.Период
		|			И ВложенныйЗапрос.ВидНачисленияУдержанияТип = ПлановыеНачисленияИУдержания.ВидНачисленияУдержания.Тип
		|ГДЕ
		|	ПлановыеНачисленияИУдержания.Организация = &Организация
		|	И ПлановыеНачисленияИУдержания.Сотрудник = &Сотрудник";
	
	Запрос.УстановитьПараметр("ДатаДокумента"	, СтруктураОтбора.Дата);  
	Запрос.УстановитьПараметр("Организация"		, СтруктураОтбора.Организация);
	Запрос.УстановитьПараметр("Сотрудник"		, СтруктураОтбора.Сотрудник);
	
	тзРезультат = Запрос.Выполнить().Выгрузить();
	                                                
	Возврат тзРезультат;

КонецФункции // ПолучитьЗаписьНачисления()

Процедура ЗаполнитьКонтрагентаИмеющимисяДанными(НовыйКонтрагент, ИНН, Наименование, СтруктураСчетов, СтруктураТипаКонтрагента)
	     
	ДлиннаИНН = СтрДлина(СокрЛП(ИНН));
	
	ВидКонтрагента = Перечисления.ВидыКонтрагентов.ПустаяСсылка();  
	ОтметкаНеРезидента = Ложь;
	//по длинне ИНН определяем Физ или Юр Лицо
	Если ДлиннаИНН = 9 Тогда 
		//Юр лицо
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	ИначеЕсли ДлиннаИНН = 11 Тогда
		//физ лицо   
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
	ИначеЕсли ДлиннаИНН = 0 Тогда 
		//скорее всего не резидент 
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	Иначе
		ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо; 
		ОтметкаНеРезидента = Истина;
	КонецЕсли;
	
	НовыйКонтрагент.ВидКонтрагента = ВидКонтрагента; 
	НовыйКонтрагент.Покупатель = СтруктураТипаКонтрагента.Покупатель;
	НовыйКонтрагент.Поставщик = СтруктураТипаКонтрагента.Поставщик;      
	НовыйКонтрагент.ПрочиеОтношения = СтруктураТипаКонтрагента.ПрочиеОтношения;
	НовыйКонтрагент.Наименование = ?(СокрЛП(Наименование) <> "", Наименование, НСтр("ru='Создан помощником загрузки выписки';ka='შექმნილია განცხადების ჩამოტვირთვის ასისტენტის მიერ'"));
	НовыйКонтрагент.НаименованиеПолное = ?(СокрЛП(Наименование) <> "", Наименование, НСтр("ru='Создан помощником загрузки выписки';ka='შექმნილია განცხადების ჩამოტვირთვის ასისტენტის მიერ'")); 
	НовыйКонтрагент.ЯвляетсяНеРезидентом = ОтметкаНеРезидента; 
	НовыйКонтрагент.СчетУчетаАвансовПокупателяРегл = СтруктураСчетов.СчетУчетаАвансовПокупателяРегл;
	НовыйКонтрагент.СчетУчетаАвансовПоставщикуРегл = СтруктураСчетов.СчетУчетаАвансовПоставщикуРегл;
	НовыйКонтрагент.СчетУчетаРасчетовСПокупателемРегл = СтруктураСчетов.СчетУчетаРасчетовСПокупателемРегл;
	НовыйКонтрагент.СчетУчетаРасчетовСПоставщикомРегл = СтруктураСчетов.СчетУчетаРасчетовСПоставщикомРегл;
	НовыйКонтрагент.ИНН = ИНН;	 
	
КонецПроцедуры

Процедура ЗаполнитьКонтрагентаДаннымиRS(НовыйКонтрагент, ДанныеКонтрагента, СтруктураСчетов, СтруктураТипаКонтрагента)

	НовыйКонтрагент.Наименование       	= ДанныеКонтрагента.Имя;
	НовыйКонтрагент.НаименованиеПолное 	= ДанныеКонтрагента.Имя;
	
	Если ДанныеКонтрагента.ТипОрганизаций = "ფიზიკური პირი" Тогда
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
		НовыйКонтрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "შ\პ\ს" ИЛИ ДанныеКонтрагента.ТипОрганизаций = "სააქციო საზოგადოება" ИЛИ ДанныеКонтрагента.ТипОрганизаций = "საჯარო სამართლის იურიდიული პირი" Тогда	
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "სახელმწიფო ორგანოები" Тогда	
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ГосударственныйОрган;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "ინდივიდუალური მეწარმე" Тогда	
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель;
	Иначе
		НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
	КонецЕсли;	
			
	// Юридический адрес
	
	ДобавитьЮрАдресс(НовыйКонтрагент, ДанныеКонтрагента.Адрес);
	
	ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервереНов(НовыйКонтрагент.ИНН);
	
	//ЗаполнитьФизлицПоИНН(НовыйКонтрагент, ДанныеКонтрагента);
	Если ДанныеКонтрагента = Неопределено Или ДанныеКонтрагента.UnID = 0  Тогда
		Возврат;
	КонецЕсли;	
	
	Если ДанныеКонтрагента.IsVatPayer Тогда
		Если НовыйКонтрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
			НовыйКонтрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
		КонецЕсли;			
	Иначе 
		НовыйКонтрагент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	КонецЕсли;      
	
	НовыйКонтрагент.Покупатель = СтруктураТипаКонтрагента.Покупатель;
	НовыйКонтрагент.Поставщик = СтруктураТипаКонтрагента.Поставщик;      
	НовыйКонтрагент.ПрочиеОтношения = СтруктураТипаКонтрагента.ПрочиеОтношения;
	
	НовыйКонтрагент.СчетУчетаАвансовПокупателяРегл = СтруктураСчетов.СчетУчетаАвансовПокупателяРегл;
	НовыйКонтрагент.СчетУчетаАвансовПоставщикуРегл = СтруктураСчетов.СчетУчетаАвансовПоставщикуРегл;
	НовыйКонтрагент.СчетУчетаРасчетовСПокупателемРегл = СтруктураСчетов.СчетУчетаРасчетовСПокупателемРегл;
	НовыйКонтрагент.СчетУчетаРасчетовСПоставщикомРегл = СтруктураСчетов.СчетУчетаРасчетовСПоставщикомРегл;

КонецПроцедуры

Процедура ДобавитьЮрАдресс(НовыйКонтрагент, ЮрАдресс)
	
	ТЗ = НовыйКонтрагент.КонтактнаяИнформация.Выгрузить();	

	СтруктураПараметров = Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента);
	СтрокаКИ = ТЗ.НайтиСтроки(СтруктураПараметров);
	Если СтрокаКИ.Количество() = 0 Тогда
		СтрокаКИ = ТЗ.Добавить();
		СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
		СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
	Иначе
		СтрокаКИ = СтрокаКИ[0];
	КонецЕсли;
	
	СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
	СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента;
	СтрокаКИ.Представление = ЮрАдресс;
	
	НовыйКонтрагент.КонтактнаяИнформация.Загрузить(ТЗ);
	
КонецПроцедуры

Процедура ЗаполнитьФизлицПоИНН(НовыйКонтрагент, ДанныеКонтрагента)

	Если НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо
		ИЛИ НовыйКонтрагент.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель
		И ЗначениеЗаполнено(НовыйКонтрагент.ИНН)
		Тогда
		
		ФИО = СокрЛП(НовыйКонтрагент.Наименование);
		ФИО = СтрЗаменить(ФИО, "  ", " ");
		МассивФИО = СтрРазделить(ФИО, " ", Ложь);
		ПорядокФИО = Константы.ПорядокИмен.Получить();
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ФизическиеЛица.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.ИНН = &ИНН
		|	И НЕ ФизическиеЛица.ПометкаУдаления
		|	И НЕ ФизическиеЛица.ЭтоГруппа";
		
		Запрос.УстановитьПараметр("ИНН", НовыйКонтрагент.ИНН);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() Тогда
		
			НовыйКонтрагент.КонтактноеЛицо = Выборка.Ссылка;	
			НовыйКонтрагент.ФизическоеЛицо = Выборка.Ссылка;	
		
		Иначе
		
			НовоеФЛ = Справочники.ФизическиеЛица.СоздатьЭлемент();
			НовоеФЛ.ИНН = НовыйКонтрагент.ИНН;
			НовоеФЛ.Наименование = НовыйКонтрагент.Наименование;
			НовоеФЛ.Записать();
			НовыйКонтрагент.КонтактноеЛицо = НовоеФЛ.Ссылка;	
			НовыйКонтрагент.ФизическоеЛицо = НовоеФЛ.Ссылка;	
		
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НовыйКонтрагент.ФизическоеЛицо) Тогда
		
			Фамилия = "";
			Имя = "";
			Если МассивФИО.Количество() И ПорядокФИО = Перечисления.ПорядокИмен.ФамилияИмяОтчество Тогда
			
				Фамилия = МассивФИО[0];
				Если МассивФИО.Количество() >= 2 Тогда
				
					Имя = МассивФИО[1];
				
				КонецЕсли; 
			
			ИначеЕсли МассивФИО.Количество() И ПорядокФИО = Перечисления.ПорядокИмен.ИмяОтчествоФамилия Тогда
			
				Имя = МассивФИО[0];
				Если МассивФИО.Количество() >= 3 Тогда
				
					Фамилия = МассивФИО[2];
				
				КонецЕсли; 
			
			ИначеЕсли МассивФИО.Количество() И ПорядокФИО = Перечисления.ПорядокИмен.ИмяФамилияОтчество Тогда
			
				Если МассивФИО.Количество() >= 2 Тогда
				
					Фамилия = МассивФИО[1];
				
				КонецЕсли; 
				Имя = МассивФИО[0];
			
			КонецЕсли; 
			
			Если Не ПустаяСтрока(Фамилия) Или Не ПустаяСтрока(Имя) Тогда
			
				МенеджерЗаписи = РегистрыСведений.ФИОФизЛиц.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Период = ТекущаяДатаСеанса();
				МенеджерЗаписи.ФизЛицо = НовыйКонтрагент.ФизическоеЛицо;
				МенеджерЗаписи.Фамилия = Фамилия;
				МенеджерЗаписи.Имя = Имя;
				МенеджерЗаписи.Записать(Истина);
			
			КонецЕсли; 
		
		КонецЕсли; 
		
	КонецЕсли; 	

КонецПроцедуры // ЗаполнитьФизлицПоИНН()

Процедура ПересчитатьСуммыДокумента(ДокументБанк,СтрокаТабличнойЧасти,Курс, Кратность)
	СтруктураДанные = Новый Структура;
	
	СтруктураДанные.Вставить("ВалютаКурсКратность",РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументБанк.Дата,	Новый Структура("Валюта", БанковскийСчет.ВалютаДенежныхСредств)));
	СтруктураДанные.Вставить("ВалютаДенежныхСредств",БанковскийСчет.ВалютаДенежныхСредств);
	
	естьПоступлениеНаСчет = ТипЗнч(ДокументБанк) = Тип("ДокументОбъект.ПоступлениеНаСчет");
	Если ЗначениеЗаполнено(ДокументБанк.ВалютаДенежныхСредств) И естьПоступлениеНаСчет Тогда
		Курс = ?(
		СтруктураДанные.ВалютаКурсКратность.Курс = 0,
		1,
		СтруктураДанные.ВалютаКурсКратность.Курс
		);
		Кратность = ?(
		СтруктураДанные.ВалютаКурсКратность.Кратность = 0,
		1,
		СтруктураДанные.ВалютаКурсКратность.Кратность
		);
		//Если ДокументБанк.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ПокупкаВалюты") Тогда
		//	ДокументБанк.Курс = Курс;
		//	ДокументБанк.Кратность = Кратность;
		//КонецЕсли;
		
		ДокументБанк.Курс = ?(
		ДокументБанк.Курс = 0,
		1,
		ДокументБанк.Курс
		);
		ДокументБанк.Кратность = ?(
		ДокументБанк.Кратность = 0,
		1,
		ДокументБанк.Кратность
		);
		
		ДокументБанк.СуммаУчета = УправлениеНебольшойФирмойСервер.ПересчитатьИзВалютыВВалюту(
		ДокументБанк.СуммаДокумента,
		ДокументБанк.Курс,
		Курс,
		ДокументБанк.Кратность,
		Кратность
		);

	КонецЕсли;
	
	Если Не СтрокаТабличнойЧасти = Неопределено Тогда  
		СтрокаТабличнойЧасти.Курс = ?(
		СтрокаТабличнойЧасти.Курс = 0,
		1,
		СтрокаТабличнойЧасти.Курс
		);
		СтрокаТабличнойЧасти.Кратность = ?(
		СтрокаТабличнойЧасти.Кратность = 0,
		1,
		СтрокаТабличнойЧасти.Кратность
		);
		СтрокаТабличнойЧасти.СуммаРасчетов = УправлениеНебольшойФирмойСервер.ПересчитатьИзВалютыВВалюту(
		СтрокаТабличнойЧасти.СуммаПлатежа,
		Курс,
		СтрокаТабличнойЧасти.Курс,
		Кратность,
		СтрокаТабличнойЧасти.Кратность
		);
	КонецЕсли;
	
КонецПроцедуры // ПересчитатьСуммыДокумента()

Функция ПолучитьДатуИзСтроки(ДатаСтрока);
	ДатаСтрока = Лев(ДатаСтрока,10);
	
	Год   = прав(ДатаСтрока,4);
	Месяц  = Сред(ДатаСтрока,4,2);
	День = Лев(ДатаСтрока,2);
	
	Возврат Дата(Год,Месяц,День);
	
КонецФункции

Функция НайтиДоговорКонтрагентаПоВалюте(Контрагент,ВалютаДенежныхСредств)
	
	знчВозврата = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДоговорыКонтрагентов.Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Владелец = &Владелец
	|	И ДоговорыКонтрагентов.ВалютаРасчетов = &ВалютаРасчетов
	|	И НЕ ДоговорыКонтрагентов.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ВалютаРасчетов", ВалютаДенежныхСредств);
	Запрос.УстановитьПараметр("Владелец", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
		знчВозврата = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат знчВозврата;
	
КонецФункции

