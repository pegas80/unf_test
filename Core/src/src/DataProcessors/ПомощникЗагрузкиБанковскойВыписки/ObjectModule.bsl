// Kuzmich, 01.12.2025, (ES4001-99) Помощик загрузки банковской выписки - TBC - конвертация
Функция РазборСтрокиНазначениеПлатежа(Данные)
	ПЕРЕМ РЕЗ, НазначениеПлатежа;
	
	РЕЗ = Новый Структура("ЕстьКурсБанка", ЛОЖЬ);
	
	НазначениеПлатежа = СОКРЛП(Данные.НазначениеПлатежа);
	
	Если НЕ ПустаяСтрока(НазначениеПлатежа) Тогда
	
		СтруктураКурсаБанка = Новый Структура("ПерваяВалюта,КурсПервойВалюты,ВтораяВалюта,КурсВторойВалюты",НЕОПРЕДЕЛЕНО,0,НЕОПРЕДЕЛЕНО,0);
		
		ПерваяВалюта = НЕОПРЕДЕЛЕНО;
		КурсПервойВалюты = НЕОПРЕДЕЛЕНО;
		ВтораяВалюта = НЕОПРЕДЕЛЕНО;
		КурсВторойВалюты = НЕОПРЕДЕЛЕНО;
		
		ПрошлыйСимвол = "";
		ТекущийСимвол = "";
		ТекущаяЛексема = "";
		Разделители = " "+Символы.НПП;
		СимволыЧисла = "0123456789";
		СимволыСкобки = "(){}";
		РазделителиЧисла = ",.";
		ЗнакРавно = "=";
		СоставлениеЧисла = ЛОЖЬ;
		ПоискПервогоКурса = ИСТИНА;
		ПоискВторогоКурса = ЛОЖЬ;
		
		НазначениеПлатежаДлина = СтрДлина(НазначениеПлатежа);
		и1=1;
		Пока и1<=НазначениеПлатежаДлина Цикл
			
			ТекущийСимвол = СРЕД(НазначениеПлатежа,и1,1);
			
			Если СтрНайти(Разделители,ТекущийСимвол)=0 Тогда // Собираем лексему
				
				Если СтрНайти(Разделители,ПрошлыйСимвол)>0 И СтрНайти(СимволыЧисла,ТекущийСимвол)>0 Тогда
					
					СоставлениеЧисла = ИСТИНА;
					
				КонецЕсли;
				
				Если СоставлениеЧисла И СтрНайти(СимволыЧисла,ТекущийСимвол)=0 И СтрНайти(РазделителиЧисла,ТекущийСимвол)=0 Тогда // Ожидаем число, но символ не из чисел и не из разделителей - это ошибка 
					
					СоставлениеЧисла = ЛОЖЬ;
					
				КонецЕсли;
				
				Если СоставлениеЧисла И (СтрНайти(РазделителиЧисла,ТекущийСимвол)>0 И СтрНайти(РазделителиЧисла,ПрошлыйСимвол)>0) Тогда // Два раделителя подряд - это ошибка
					
					СоставлениеЧисла = ЛОЖЬ;
					
				КонецЕсли;
				
				Если СтрНайти(СимволыСкобки,ТекущийСимвол)>0 Тогда // Скобки отбрасываем
					
					ПрошлыйСимвол = ТекущийСимвол;
					
					и1 = и1 + 1;
					
					Продолжить;
					
				КонецЕсли;
				
				ТекущаяЛексема = ТекущаяЛексема + ТекущийСимвол;
				
			Иначе // Собрали лексему, начинаем обрабатывать
				
				Если СтрДлина(ТекущаяЛексема)=0 Тогда // Два или более пробела подрад
					
					ПрошлыйСимвол = ТекущийСимвол;
					
					и1 = и1 + 1;
					
					Продолжить;
				
				КонецЕсли;
				
				Если СтрНайти(ЗнакРавно,ТекущаяЛексема)>0 И СтрДлина(ТекущаяЛексема)=1 Тогда // Это знак "=", начинаем искать второй курс
					
					ПоискПервогоКурса = ЛОЖЬ;
					ПоискВторогоКурса = ИСТИНА;
					
				ИначеЕсли СоставлениеЧисла Тогда
					
					ТекущаяЛексема = СтрЗаменить(ТекущаяЛексема,",",".");
					ЧислоТекущейЛексемы = Число(ТекущаяЛексема);
					
					Если ЧислоТекущейЛексемы>0 Тогда
						
						Если ПоискПервогоКурса Тогда
						
							КурсПервойВалюты = ЧислоТекущейЛексемы;
							
						ИначеЕсли ПоискВторогоКурса Тогда
						
							КурсВторойВалюты = ЧислоТекущейЛексемы;
						
						КонецЕсли;
					
					КонецЕсли;
				
				Иначе
					
					ТекущаяВалюта = Справочники.Валюты.НайтиПоНаименованию(ТекущаяЛексема);
					
					Если НЕ(ТекущаяВалюта = НЕОПРЕДЕЛЕНО) И НЕ(ТекущаяВалюта = Справочники.Валюты.ПустаяСсылка()) Тогда
						
						Если ПоискПервогоКурса Тогда
						
							ПерваяВалюта = ТекущаяВалюта;
							
						ИначеЕсли ПоискВторогоКурса Тогда
						
							ВтораяВалюта = ТекущаяВалюта;
						
						КонецЕсли;
						
					КонецЕсли;
				
				КонецЕсли;
				
				ТекущаяЛексема = "";
				
			КонецЕсли;
			
			ПрошлыйСимвол = ТекущийСимвол;
			
			и1 = и1 + 1;
			
		КонецЦикла;
		
		// Завершение обработки после последненго символа
		Если СтрДлина(ТекущаяЛексема)>0 Тогда // Два или более пробела подрад
			
			Если СтрНайти(ЗнакРавно,ТекущаяЛексема)>0 И СтрДлина(ТекущаяЛексема)=1 Тогда // Это знак "=", начинаем искать второй курс
				
				ПоискПервогоКурса = ЛОЖЬ;
				ПоискВторогоКурса = ИСТИНА;
				
			ИначеЕсли СоставлениеЧисла Тогда
				
				ТекущаяЛексема = СтрЗаменить(ТекущаяЛексема,",",".");
				ЧислоТекущейЛексемы = Число(ТекущаяЛексема);
				
				Если ЧислоТекущейЛексемы>0 Тогда
					
					Если ПоискПервогоКурса Тогда
						
						КурсПервойВалюты = ЧислоТекущейЛексемы;
						
					ИначеЕсли ПоискВторогоКурса Тогда
						
						КурсВторойВалюты = ЧислоТекущейЛексемы;
						
					КонецЕсли;
					
				КонецЕсли;
				
			Иначе
				
				ТекущаяВалюта = Справочники.Валюты.НайтиПоНаименованию(ТекущаяЛексема);
				
				Если НЕ(ТекущаяВалюта = НЕОПРЕДЕЛЕНО) И НЕ(ТекущаяВалюта = Справочники.Валюты.ПустаяСсылка()) Тогда
					
					Если ПоискПервогоКурса Тогда
						
						ПерваяВалюта = ТекущаяВалюта;
						
					ИначеЕсли ПоискВторогоКурса Тогда
						
						ВтораяВалюта = ТекущаяВалюта;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если 
			ТипЗНЧ(ПерваяВалюта)=Тип("СправочникСсылка.Валюты")
			И
			КурсПервойВалюты>0
			И
			ТипЗНЧ(ВтораяВалюта)=Тип("СправочникСсылка.Валюты")
			И
			КурсВторойВалюты>0
		Тогда
		
			РЕЗ.ЕстьКурсБанка = ИСТИНА;                                      
			
			СтруктураКурсаБанка.ПерваяВалюта = ПерваяВалюта;
			СтруктураКурсаБанка.КурсПервойВалюты = КурсПервойВалюты;
			СтруктураКурсаБанка.ВтораяВалюта = ВтораяВалюта;
			СтруктураКурсаБанка.КурсВторойВалюты = КурсВторойВалюты;
			РЕЗ.Вставить("СтруктураКурсаБанка",СтруктураКурсаБанка);
		
		КонецЕсли;
		
	КонецЕсли;	
	
	Возврат РЕЗ;
КонецФункции
