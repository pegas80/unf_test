			//новыйДокумент.ВариантЗаполненияРасшифровки = Перечисления.ВариантыЗаполненияРасшифровкиПлатежа.Автоматически;
			// Олег Литвиненко 04.11.22 --->
			новыйДокумент.ВариантЗаполненияРасшифровки = ?(ЗначениеЗаполнено(ВариантЗаполненияРасшифровки), ВариантЗаполненияРасшифровки, Перечисления.ВариантыЗаполненияРасшифровкиПлатежа.Автоматически);
			// Олег Литвиненко <---
			//
			// Олег Литвиненко 14.03.23 --->
			Если ЗначениеЗаполнено(ВариантЗаполненияРасшифровки) 
				И Не ВариантЗаполненияРасшифровки = Перечисления.ВариантыЗаполненияРасшифровкиПлатежа.Автоматически
				И Не ЕстьДолг(новыйДокумент.Контрагент) Тогда
				нстрРасшифровкаПлатежа.ПризнакАванса = Истина;
			КонецЕсли;
			// Олег Литвиненко <---
			
		КонецЕсли;  
		
		//Malyshev 2024-05-24 ONESOFT-3063
		//ТипСуммы расшифровки платежа
		Если ОбъектШаблон.ВидимостьТипаСуммы() 
			и ЗначениеЗаполнено(ОбъектШаблон.ТипСуммы) 
			Тогда     
			Для каждого СтрРасшифровки из новыйДокумент.РасшифровкаПлатежа Цикл
				СтрРасшифровки.ТипСуммы = ОбъектШаблон.ТипСуммы; 	
			КонецЦикла;	
		КонецЕсли;
		
		
		
	КонецЕсли; 

	
	
	
	
	//Если МетаданныеДокумента.Реквизиты.Найти("НазначениеПлатежа") <> Неопределено Тогда
	Если ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia Тогда
		Если этоКонвертация Тогда 
			новыйДокумент.НазначениеПлатежа = Данные.НазначениеПлатежа + " " + Данные.ДополнительноеЗначение;
		Иначе 
			новыйДокумент.НазначениеПлатежа = Данные.НазначениеПлатежа;
		КонецЕсли;
	Иначе
		новыйДокумент.НазначениеПлатежа = Данные.НазначениеПлатежа;
	КонецЕсли;
	//КонецЕсли;
	новыйДокумент.Комментарий		= Данные.Комментарий;
	
	новыйДокумент.ID = Данные.ID;
	новыйДокумент.TransactionID = Данные.TransactionID;
	//+++ Дмгг
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", МетаданныеДокумента)
		И ТипЗнч(новыйДокумент) <> Тип("ДокументОбъект.ПоступлениеНаСчет") И НЕ ЗначениеЗаполнено(новыйДокумент.Подразделение) Тогда
		Пользователь = Пользователи.ТекущийПользователь();
		ЗначениеНастройки = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователь, "ОсновноеПодразделение");
		новыйДокумент.Подразделение = ?(ЗначениеЗаполнено(ЗначениеНастройки), ЗначениеНастройки, Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение);
	КонецЕсли;
	//--- Дмгг
	
	Если ПроводитьСозданныеДокументы Тогда 
		Попытка
			новыйДокумент.записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		Исключение
			новыйДокумент.записать(РежимЗаписиДокумента.Запись);
		КонецПопытки;
	Иначе
		Попытка
			новыйДокумент.записать(РежимЗаписиДокумента.Запись);
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
		новыйДокумент.записать(РежимЗаписиДокумента.Запись);
	КонецЕсли;      
	
	Если этоКонвертация Тогда 
		
		// Убираем суммц, что бы в контр выписке был определено документ
		КлючУИД =                                 
			Лев(Строка(НовыйДокумент.Дата), 10)
			+ "_" + Данные.НомерДокумента //Данные.НомерДокумента 
			+ "_" //+ ?(ЗначениеЗаполнено(НовыйДокумент.СуммаКонвертации), Строка(НовыйДокумент.СуммаКонвертации), Строка(НовыйДокумент.СуммаПолучено)) //Строка(НовыйДокумент.СуммаДокумента)
			//+ "_" + Строка(НовыйДокумент.НазначениеПлатежа);
			+ "_" + Строка(Данные.НазначениеПлатежа);
			
		Если ЗначениеЗаполнено(новыйДокумент.Ссылка) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Создан документ конвертации: ""'; ka = 'შექმნილია დოკუმენტი: ""'; en = 'შექმნილია დოკუმენტი: ""'") + новыйДокумент.Ссылка + НСтр("ru = '"" ; Строка №'; ka = ' ; სტრიქონის:'; en = ' ; სტრიქონის:'") + Данные.НомерСтроки +  НСтр("ru = ', пожалуйста, перепроверте внесенную информацию'; ka = ', გთხოვთ, შეამოწმეთ შესყვანილი ინფორმცაიია'; en = ', გთხოვთ, შეამოწმეთ შესყვანილი ინფორმცაიია'"));	
		КонецЕсли;
		
	Иначе
		
		КлючУИД =                                 
			Лев(Строка(НовыйДокумент.Дата), 10) 
			+ "_" + Данные.НомерДокумента 
			+ "_" + Строка(НовыйДокумент.СуммаДокумента)
			+ "_" + Строка(НовыйДокумент.НазначениеПлатежа);
		
	КонецЕсли;
	
				
	НаборЗаписейКлючДокИБ = РегистрыСведений.КлючДокументаИнтернетБанка.СоздатьНаборЗаписей();
	НаборЗаписейКлючДокИБ.Отбор.Документ.Установить(НовыйДокумент.Ссылка);
		
	НовыйУИД = НаборЗаписейКлючДокИБ.Добавить();
	НовыйУИД.Документ = НовыйДокумент.Ссылка;
	НовыйУИД.Ключ = КлючУИД;   
		
	НаборЗаписейКлючДокИБ.Записать();
	
	ТаблицаВыписки[Данные.НомерСтроки-1]._СсылкаНаДокумент = новыйДокумент.Ссылка;
	ТаблицаВыписки[Данные.НомерСтроки-1].ДокументПроведен = новыйДокумент.Проведен;
	
КонецПроцедуры  //СоздатьДокументПоДанным


Процедура ЗаполнимЭквайринговыеОперацииНовогоДокумента(новыйДокумент, ТекСумма, ТекСуммаКомиссии, ВидПлатежнойКарты, НомерПлатежнойКарты)
	
	новыйДокумент.ЭквайринговыеОперации.Очистить();
	
	ОстатокСумма = ТекСумма;
	ОстатокКомиссия = ТекСуммаКомиссии;
	
	УчетнаяПолитика = УправлениеНебольшойФирмойПовтИсп.УчетнаяПолитикаОрганизации(новыйДокумент.Организация, новыйДокумент.Дата);
			
	Подбирать = УчетнаяПолитика.ЗагрузкаВыписок_ОтчетЭквайера_АвтозаполнениеДокументов;
	Если Подбирать = Истина Тогда 
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Организация", новыйДокумент.Организация);
		Запрос.УстановитьПараметр("Контрагент", новыйДокумент.ЭквайринговыйТерминал.Эквайрер);
		Запрос.УстановитьПараметр("ПериодРасчетовДатаНачала", Дата(1,1,1));
		Запрос.УстановитьПараметр("ПериодРасчетовДатаОкончания", КонецДня(новыйДокумент.Дата));
		Запрос.УстановитьПараметр("ЭквайринговыйТерминал", новыйДокумент.ЭквайринговыйТерминал);
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Т.Организация КАК Организация,
		|	Т.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
		|	Т.ДатаПлатежа КАК ДатаПлатежа,
		|	Т.Документ КАК Документ,
		|	Т.СуммаОстаток КАК СуммаОстаток,
		|	Т.СуммаВалОстаток КАК СуммаВалОстаток,
		|	Т.КомиссияОстаток КАК КомиссияОстаток,
		|	Т.КомиссияВалОстаток КАК КомиссияВалОстаток,
		|	Т.Заказ КАК Заказ,
		|	Т.ВидОперацииЭквайринга КАК ВидОперацииЭквайринга,
		|	Т.ВидПлатежнойКарты КАК ВидПлатежнойКарты,
		|	Т.НомерПлатежнойКарты КАК НомерПлатежнойКарты
		|ИЗ
		|	РегистрНакопления.РасчетыПоЭквайрингу.Остатки(
		|			,
		|			ДатаПлатежа >= &ПериодРасчетовДатаНачала
		|				И ВЫБОР
		|					КОГДА &ПериодРасчетовДатаОкончания <> ДАТАВРЕМЯ(1, 1, 1)
		|						ТОГДА ДатаПлатежа <= &ПериодРасчетовДатаОкончания
		|					ИНАЧЕ ИСТИНА
		|				КОНЕЦ
		|				И Организация = &Организация
		|				И ЭквайринговыйТерминал.Эквайрер = &Контрагент
		|				И ЭквайринговыйТерминал = &ЭквайринговыйТерминал) КАК Т";
		
		ТабОстатков = Запрос.Выполнить().Выгрузить();
		
		НайденныйДокумент = ТабОстатков.Найти(ОстатокСумма,"СуммаОстаток");
		Если НайденныйДокумент<>Неопределено тогда //найдем точное совпадение по сумме
			НоваяСтрокаОперации = новыйДокумент.ЭквайринговыеОперации.Добавить();
			НоваяСтрокаОперации.СуммаРасчетов = ОстатокСумма;
			НоваяСтрокаОперации.СуммаПлатежаИтогоПоСтроке = ОстатокСумма;
			НоваяСтрокаОперации.Документ = НайденныйДокумент.Документ;
			
			
			НоваяСтрокаОперации.ДатаПлатежа = НайденныйДокумент.ДатаПлатежа;
			НоваяСтрокаОперации.ВидПлатежнойКарты = НайденныйДокумент.ВидПлатежнойКарты; 
			НоваяСтрокаОперации.НомерПлатежнойКарты = НайденныйДокумент.НомерПлатежнойКарты;
			НоваяСтрокаОперации.СуммаРасчетовКомиссии = НайденныйДокумент.КомиссияОстаток;
			НоваяСтрокаОперации.СуммаКомиссииИтогоПоСтроке = НайденныйДокумент.КомиссияОстаток;	
			
			ОстатокСумма = 0;
			ОстатокКомиссия = 0; 
			НайденныйДокумент.СуммаОстаток = 0;
		КонецЕсли;
		
		//распределим остатки
		Для каждого стр из ТабОстатков Цикл
			Если стр.СуммаОстаток=0 тогда 
				Продолжить;
			КонецЕсли;	
			
			Если ОстатокСумма = 0 тогда 
				Прервать;
			КонецЕсли;	
			
			Если ОстатокСумма > стр.СуммаОстаток Тогда
				ЗачетСумма = стр.СуммаОстаток; 
				ЗачетКомиссия = Окр(ОстатокКомиссия * стр.СуммаОстаток/ОстатокСумма,2); 
			Иначе
				ЗачетСумма = ОстатокСумма;
				ЗачетКомиссия = ОстатокКомиссия;
			КонецЕсли;	        
			
			ЗачетКомиссия = стр.КомиссияОстаток;
			
			Если ЗачетСумма = 0 тогда 
				Продолжить;
			КонецЕсли;	
		
				
			ОстатокСумма = ОстатокСумма - ЗачетСумма;
			ОстатокКомиссия = ОстатокКомиссия - ЗачетКомиссия;
			
			
			НоваяСтрокаОперации = новыйДокумент.ЭквайринговыеОперации.Добавить();
			НоваяСтрокаОперации.СуммаРасчетов = ЗачетСумма;
			НоваяСтрокаОперации.СуммаПлатежаИтогоПоСтроке = ЗачетСумма;
			НоваяСтрокаОперации.Документ = стр.Документ;
			
			НоваяСтрокаОперации.ДатаПлатежа = Стр.ДатаПлатежа;
			НоваяСтрокаОперации.ВидПлатежнойКарты = стр.ВидПлатежнойКарты; 
			НоваяСтрокаОперации.НомерПлатежнойКарты = стр.НомерПлатежнойКарты;
			НоваяСтрокаОперации.СуммаРасчетовКомиссии = ЗачетКомиссия;
			НоваяСтрокаОперации.СуммаКомиссииИтогоПоСтроке = ЗачетКомиссия;
			
		КонецЦикла;
		
	КонецЕсли;	         
	
	//Если чтото осталось после распределения		
	Если ОстатокСумма>0 Тогда
		
		НоваяСтрокаОперации = новыйДокумент.ЭквайринговыеОперации.Добавить();
		НоваяСтрокаОперации.СуммаРасчетов = ОстатокСумма;
		НоваяСтрокаОперации.СуммаПлатежаИтогоПоСтроке = ОстатокСумма;
		
		НоваяСтрокаОперации.ДатаПлатежа = новыйДокумент.Дата;
		НоваяСтрокаОперации.ВидПлатежнойКарты = ВидПлатежнойКарты; 
		НоваяСтрокаОперации.НомерПлатежнойКарты = НомерПлатежнойКарты;
		НоваяСтрокаОперации.СуммаРасчетовКомиссии = 0; //ОстатокКомиссия;
		НоваяСтрокаОперации.СуммаКомиссииИтогоПоСтроке = 0; //ОстатокКомиссия;
		
	КонецЕсли;		
			

КонецПроцедуры	

Процедура ОбработатьданныеДляКонвертации(новыйДокумент, Данные, НацВалюта, ВалютаУчета)
	
	//Данные
	//новыйДокумент
	
	СтруктураДополнительногоЗначение = Неопределено;
	Если ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia Тогда 
		СтруктураДополнительногоЗначение = BOG_РазобратьСтрокуДополнительногоЗначенияВСтруктуру(Данные.ДополнительноеЗначение);
	ИначеЕсли ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.ProCredit Тогда
		СтруктураДополнительногоЗначение = PC_РазобратьСтрокуДополнительногоЗначенияВСтруктуру(Данные.НазначениеПлатежа);
	ИначеЕсли ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.TBC Тогда
		СтруктураДополнительногоЗначение = новый Структура; 
		СтруктураДополнительногоЗначение.Вставить("Курс", Данные.Курс);
		СтруктураДополнительногоЗначение.Вставить("Кратность", 1);
	КонецЕсли;
	
	новыйДокумент.ВидОперации = Перечисления.ВидыОперацийКонвертация.СоСчета;
	новыйДокумент.Комментарий = Данные.Комментарий;
	
	Если ЗначениеЗаполнено(Данные.СуммаДт) Тогда
		
		новыйДокумент.Отправитель		= БанковскийСчет;
		новыйДокумент.ВалютаОтправитель = БанковскийСчет.ВалютаДенежныхСредств;
		СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(новыйДокумент.Дата, Новый Структура("Валюта", новыйДокумент.ВалютаОтправитель));
		Если ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia Тогда
			//+++ Дмгг, 02.02.24, ONESOFT-2925
			//новыйДокумент.КурсОтправитель = СтруктураДополнительногоЗначение.Курс;
			новыйДокумент.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			//--- Дмгг, 02.02.24, ONESOFT-2925
		Иначе
			//+++ Дмгг, 02.02.24, ONESOFT-3438
			//новыйДокумент.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			Если новыйДокумент.ВалютаОтправитель = НацВалюта Тогда 
				новыйДокумент.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс); 
			Иначе
				новыйДокумент.КурсОтправитель = СтруктураДополнительногоЗначение.Курс;
			КонецЕсли;    
			//--- Дмгг, 02.02.24, ONESOFT-3438
		КонецЕсли;
		//Если ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.TBC Тогда 
		//	новыйДокумент.КурсОтправитель = Данные.Курс;
		//Иначе
		//	новыйДокумент.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
		//КонецЕсли;
		новыйДокумент.КурсОтправительНацБанк = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
		новыйДокумент.КратностьОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
		новыйДокумент.СуммаКонвертации 	= Данные.СуммаДт;
		
		
		
		новыйДокумент.Получатель	 	= Данные.СчетКонтрагента1С;
		новыйДокумент.ВалютаПолучатель	= Данные.СчетКонтрагента1С.ВалютаДенежныхСредств;
		СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(новыйДокумент.Дата, Новый Структура("Валюта", новыйДокумент.ВалютаПолучатель));
		новыйДокумент.КурсПолучательНацБанк= ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
		новыйДокумент.КратностьПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
		
