Процедура УстановитьВалютуПоУмолчанию(ДокументОбъект, ОтправительПолучатель)
	
	Если ОтправительПолучатель = "Отправитель" Тогда 
		Если ТипЗнч(ДокументОбъект.Отправитель) = Тип("СправочникСсылка.БанковскиеСчета")
			И ЗначениеЗаполнено(ДокументОбъект.Отправитель) Тогда 
			ДокументОбъект.ВалютаОтправитель = ДокументОбъект.Отправитель.ВалютаДенежныхСредств;
			СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументОбъект.Дата, Новый Структура("Валюта", ДокументОбъект.ВалютаОтправитель));
			
			ДокументОбъект.КурсОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			ДокументОбъект.КратностьОтправитель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);
		КонецЕсли;
	ИначеЕсли ОтправительПолучатель = "Получатель" Тогда 
		Если ТипЗнч(ДокументОбъект.Получатель) = Тип("СправочникСсылка.БанковскиеСчета")
			И ЗначениеЗаполнено(ДокументОбъект.Получатель)
			Тогда
			ДокументОбъект.ВалютаПолучатель = ДокументОбъект.Получатель.ВалютаДенежныхСредств;
			СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ДокументОбъект.Дата, Новый Структура("Валюта", ДокументОбъект.ВалютаПолучатель));
			
			ДокументОбъект.КурсПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Курс);
			ДокументОбъект.КратностьПолучатель = ?(СтруктураПоВалюте.Курс = 0, 1, СтруктураПоВалюте.Кратность);			
		КонецЕсли;
	КонецЕсли;
	
