&НаСервере
Процедура СоздатьДокументы(СтруктураБанков)Экспорт
	
	ВремяСозданияДокументов = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ВремяДляДокументовПомошникаЗагрузкиИзБанка");
	СтруктураОтбора  = Новый Структура; 
	СтруктураОтбора.Вставить("_Загружать", Истина); 
	ТаблицаСоздаваемыхДокументов = ТаблицаВыписки.Выгрузить().Скопировать(СтруктураОтбора);
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	Контрагенты.ИНН КАК ИНН
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	НЕ Контрагенты.ПометкаУдаления
		|	И НЕ Контрагенты.ЭтоГруппа";
	
	тзКонтрагенты = Запрос.Выполнить().Выгрузить();      
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БанковскиеСчета.Ссылка КАК Ссылка,
		|	БанковскиеСчета.НомерСчета КАК НомерСчета
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	НЕ БанковскиеСчета.ПометкаУдаления";
	
	тзБанковскиеСчета = Запрос.Выполнить().Выгрузить();
	
	//Для Каждого стрДанные Из МассивДанных Цикл 
	//	Если ЗначениеЗаполнено(стрДанные._ШаблонЗаполнения) И Не ЗначениеЗаполнено(стрДанные._СсылкаНаДокумент) Тогда 
	//		СоздатьДокументПоДанным(стрДанные);
	//	ИначеЕсли НЕ ЗначениеЗаполнено(стрДанные._ШаблонЗаполнения)Тогда 
	//		Сообщить(Строка(стрДанные.НомерСтроки) + НСтр("ru = ' სტრიქონზე არ არის შვესებული შევსების წესი'; ka = ' სტრიქონზე არ არის შვესებული ""შევსების წესი""'"));
	//	ИначеЕсли ЗначениеЗаполнено(стрДанные._СсылкаНаДокумент)Тогда 
	//		Сообщить(Строка(стрДанные.НомерСтроки) + НСтр("ru = ' დოკუმენტი უკვე შექმნილია'; ka = ' დოკუმენტი უკვე შექმნილია'"));
	//	КонецЕсли;
	//КонецЦикла;
	
	// Олег Литвиненко 04.11.22 --->
	//++lyskov 19.02.2023 Замена на оптимизированный метод получения учетной политики из кэша.
	ВариантЗаполненияРасшифровки = РегистрыСведений.УчетнаяПолитикаРегл.ЗначениеПоляУчетнойПолитики("ВариантЗаполненияРасшифровки", Организация);
	// Олег Литвиненко <---
	
	Для Каждого стрДанные Из ТаблицаСоздаваемыхДокументов Цикл
		
		ПоисхДулейНомеровдокументов = ТаблицаСоздаваемыхДокументов.НайтиСтроки(Новый Структура("НомерДокумента", стрДанные.НомерДокумента));  
		ЕстьДублиДокументов = ПоисхДулейНомеровдокументов.Количество() > 1;
			
		Если ЗначениеЗаполнено(стрДанные._ШаблонЗаполнения) И Не ЗначениеЗаполнено(стрДанные._СсылкаНаДокумент) Тогда 
			
			СоздатьДокументПоДанным(стрДанные, тзКонтрагенты, СтруктураБанков, ЕстьДублиДокументов, тзБанковскиеСчета);
			
		ИначеЕсли ЗначениеЗаполнено(стрДанные._СсылкаНаДокумент)Тогда 
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(стрДанные.НомерСтроки) + НСтр("ru = ' Документ уже создан'; ka = ' დოკუმენტი უკვე შექმნილია'"));
			
		ИначеЕсли НЕ ЗначениеЗаполнено(стрДанные._ШаблонЗаполнения)Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(стрДанные.НомерСтроки) + НСтр("ru = ' В строке не указано правило заполнения'; ka = ' სტრიქონზე არ არის შვესებული ""შევსების წესი""'"));
			
		КонецЕсли; 
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВыполнитьСозданиеКомиссийИДозаполнениеОсновныхДокументов(СтруктураБанков)
	
	ТаблицаКоммисий = Неопределено;
	
	Если СтруктураБанков.ЭтоBOG Тогда 
		ТаблицаКоммисий = ТаблицаВыписки.Выгрузить(Новый Структура("_Загружать,ТипОперации", Истина, "COM"));
	ИначеЕсли СтруктураБанков.ЭтоTBC Тогда 
		ТаблицаКоммисий = ТаблицаВыписки.Выгрузить(Новый Структура("_Загружать,ТипОперации", Истина, "*TF%*"));
	Иначе
		//Не обрабатываемы банки
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаКомиссии Из ТаблицаКоммисий Цикл 
		
		ПоискОсновногоДокумента = ТаблицаВыписки.НайтиСтроки(Новый Структура("НомерДокумента", СтрокаКомиссии.НомерДокумента));
		
		Для Каждого СтрокаПоиска Из ПоискОсновногоДокумента Цикл 
			
			//Нашли самого семя или нечего обрабатывать
			Если СтруктураБанков.ЭтоBOG И СтрокаПоиска.ТипОперации = "COM" Тогда 
				Продолжить;
			ИначеЕсли СтруктураБанков.ЭтоTBC И СтрокаПоиска.ТипОперации = "*TF%*" Тогда 
				Продолжить;
			ИначеЕсли НЕ ЗначениеЗаполнено(СтрокаПоиска._СсылкаНаДокумент) Тогда 
				Продолжить;
			КонецЕсли; 
			
			//Дополним документ комиссией и добавим документ в строку выписки комиссии
			ДокументОбъект = СтрокаПоиска._СсылкаНаДокумент.ПолучитьОбъект();
			
			ДокументОбъект.СуммаКомиссииБанка = СтрокаКомиссии.СуммаДТ; 
			ДокументОбъект.ВалютаКомисииБанка = ДокументОбъект.ВалютаДокумента;  
			ДокументОбъект.КурсКомиссииБанка = 1;
			ДокументОбъект.КратностьКомиссииБанка = 1;
			ДокументОбъект.СтатьяРасходовКомиссииБанка = СтрокаПоиска._ШаблонЗаполнения.СтатьяРасходовКомиссииБанка;
			ДокументОбъект.СчетРасходовКомиссииБанка = ДокументОбъект.СтатьяРасходовКомиссииБанка.СчетУчета;
			
			Если ДокументОбъект.Проведен Тогда 
				
				Попытка
					ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
					СтрокаКомиссии._СсылкаНаДокумент = СтрокаПоиска._СсылкаНаДокумент;
				Исключение
			        ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось перепровести документ " + СтрокаПоиска._СсылкаНаДокумент);
				КонецПопытки;
				
			Иначе                                                                                                
				
				ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
				СтрокаКомиссии._СсылкаНаДокумент = СтрокаПоиска._СсылкаНаДокумент;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	

КонецПроцедуры

&НаСервере
Процедура СоздатьДокументПоДанным(Данные, тзКонтрагенты, СтруктураБанков, ЕстьДублиДокументов, тзБанковскиеСчета) Экспорт
	
	НацВалюта = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НациональнаяВалюта");

	текШаблонЗаполнения =  Данные._ШаблонЗаполнения;
	ОбъектШаблон = текШаблонЗаполнения.ПолучитьОбъект();	


	
	
	этоПеремещениеДС = текШаблонЗаполнения.СсылкаИсточника = "ПеремещениеДС";
	этоКонвертация	 = текШаблонЗаполнения.СсылкаИсточника = "Конвертация";
	
	ЗаполнитьВидОперации = 	не этоПеремещениеДС И не этоКонвертация;
	
	//Malyshev 2024-05-24 ONESOFT-3063 - перенес в модуль объекта шаблона и дополнил - начало
	//ЗаполнитьКонтрагент = текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПокупателя 
	//ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПоставщика
	//ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ПоступлениеОплатыПоКартам//Паганини
	//ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Покупателю	
	//ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Поставщику
	//; 
	ЗаполнитьКонтрагент = ОбъектШаблон.ВидимостьКонтрагента();                      
	//Malyshev 2024-05-24 ONESOFT-3063 - окончание
	
	ЗаполнитьСчетКонтрагента = текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ПереводНаДругойСчет;
	
	ЗаполнитьПодотчетник=  текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника
	ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику;

	ЗаполнитьВидНалога =  текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Налоги
	ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Налоги;
	
	ЗаполнитьКорреспонденция =  текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее
	ИЛИ текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Прочее;

	СоздаватьКонтрагента = НЕ текШаблонЗаполнения.СсылкаИсточника = "ПеремещениеДС";
	//+++ Дмгг, 11.04.2025, ONESOFT-3973
	ЭтоРасходСоСчетаПереводОднимДокументом = ОбъектШаблон.ЭтоРасходдСосчетаПереводСПометкойПеремещения();
	//--- Дмгг, 11.04.2025, ONESOFT-3973
	// Олег Литвиненко 20.04.23 --->
	КонтрагентИзШаблона = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(текШаблонЗаполнения, "Контрагент");
	СоздаватьКонтрагента = СоздаватьКонтрагента И Не ЗначениеЗаполнено(КонтрагентИзШаблона);
	
	Данные.Контрагент1С = ?(ЗначениеЗаполнено(КонтрагентИзШаблона), КонтрагентИзШаблона, Данные.Контрагент1С);
	// Олег Литвиненко <---
	
	врСсылкаИсточника   =  текШаблонЗаполнения.СсылкаИсточника;
	
	ТекСумма = 0;
	ТекСуммаКомиссии = 0;
	
	Если Данные.СуммаКТ > 0 Тогда 	
		ТекСумма =  Данные.СуммаКТ;
	ИначеЕсли Данные.СуммаДТ > 0 Тогда
		ТекСумма =  Данные.СуммаДТ;
	КонецЕсли;
	
	Пользователь = Пользователи.ТекущийПользователь();  
	ВидДоговора = Перечисления.ВидыДоговоров.ПустаяСсылка();
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Если НЕ ЗначениеЗаполнено(Данные.Контрагент1С) И СоздаватьКонтрагента И СоздаватьНеНайденныхКонтрагентов
		И (ЗначениеЗаполнено(Данные.Наименование) ИЛИ ЗначениеЗаполнено(Данные.ИНН)) Тогда   
		
		СтруктураТипаКонтрагента = Новый Структура("Покупатель,Поставщик,ПрочиеОтношения", Ложь, Ложь, Ложь);
		
		Если текШаблонЗаполнения.СсылкаИсточника = "РасходСоСчета" Тогда  
			
			СтруктураТипаКонтрагента.Поставщик 	= Истина;      
			Данные.Контрагент1С 				= СоздатьКонтрагента(Данные.ИНН, Данные.Наименование, СтруктураТипаКонтрагента, тзКонтрагенты);     
			ВидДоговора = Перечисления.ВидыДоговоров.СПоставщиком; 
			   
		ИначеЕсли текШаблонЗаполнения.СсылкаИсточника = "ПоступлениеНаСчет" Тогда
			
			СтруктураТипаКонтрагента.Покупатель = Истина;      
			Данные.Контрагент1С 				= СоздатьКонтрагента(Данные.ИНН, Данные.Наименование, СтруктураТипаКонтрагента, тзКонтрагенты);  
			ВидДоговора = Перечисления.ВидыДоговоров.СПокупателем;
			
		ИначеЕсли этоКонвертация И не ЗначениеЗаполнено(Данные.СчетКонтрагента1С) Тогда
			
			Если Данные.ИННДт = Данные.ИННКт Тогда 
				ВладелецСчета = Организация;
				Данные.Контрагент1С = Организация;
				Данные.СчетКонтрагента1С = СоздатьСчетКонтрагента(ВладелецСчета, Данные.СчетБанк, тзБанковскиеСчета);
			КонецЕсли;
			
		КонецЕсли; 
		
	ИначеЕсли ЗначениеЗаполнено(Данные.Контрагент1С) Тогда 
		
		Если  текШаблонЗаполнения.СсылкаИсточника = "ПоступлениеНаСчет" Тогда 
			
			ВидДоговора = Перечисления.ВидыДоговоров.СПокупателем;
			
		ИначеЕсли текШаблонЗаполнения.СсылкаИсточника = "РасходСоСчета" Тогда
			
			ВидДоговора = Перечисления.ВидыДоговоров.СПоставщиком;
			
			//Malyshev 2024-05-24 ONESOFT-3063
			Если текШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам Тогда
				ВидДоговора = Перечисления.ВидыДоговоров.Прочее;
			КонецЕсли;	
			
		КонецЕсли;
		
	Иначе
		ВидДоговора = Перечисления.ВидыДоговоров.СПокупателем;
	КонецЕсли;    
	
	Если НЕ ЗначениеЗаполнено(Данные.СчетКонтрагента1С) 
		И (ЗначениеЗаполнено(Данные.Контрагент1С) ИЛИ ЗначениеЗаполнено(Данные.Подотчетник1С))
		И СоздаватьБанковскиеСчета Тогда    
		
		Если НЕ текШаблонЗаполнения.СсылкаИсточника = "ПеремещениеДС" Тогда 
			//ВладелецСчета = ?(ЗначениеЗаполнено(Данные.Контрагент1С), Данные.Контрагент1С, Данные.Подотчетник1С.Физлицо);
			ВладелецСчета = ?(ЗначениеЗаполнено(Данные.Контрагент1С), Данные.Контрагент1С, Данные.Подотчетник1С);
		Иначе
			ВладелецСчета = Организация;
		КонецЕсли;
		
		Данные.СчетКонтрагента1С = СоздатьСчетКонтрагента(ВладелецСчета, Данные.СчетБанк, тзБанковскиеСчета); 
		
	ИначеЕсли  НЕ ЗначениеЗаполнено(Данные.СчетКонтрагента1С) И этоКонвертация И СоздаватьБанковскиеСчета Тогда 
		
		Данные.СчетКонтрагента1С = СоздатьСчетКонтрагента(Организация, Данные.СчетБанк, тзБанковскиеСчета);
		
	ИначеЕсли  НЕ ЗначениеЗаполнено(Данные.СчетКонтрагента1С) И этоКонвертация Тогда 
		
		ПоисСчета = тзБанковскиеСчета.НайтиСтроки(Новый Структура("НомерСчета", Данные.СчетБанк));
		Если ПоисСчета.Количество() > 0 Тогда 
			Данные.СчетКонтрагента1С = ПоисСчета[0].Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	
	новыйДокумент = Документы[врСсылкаИсточника].СоздатьДокумент();
	//+++ Дмгг
	//новыйДокумент.Дата = Данные.Дата;
	МетаданныеДокумента = новыйДокумент.Метаданные();
	ОсновнаяДата = Формат(НачалоДня(Данные.Дата), "ДФ=""ггггММдд""");
	ВремяДляДаты = Формат(ВремяСозданияДокументов, "ДФ=""ЧЧммсс""");
	ДатаДокумента  = Дата(ОсновнаяДата + ВремяДляДаты);
	новыйДокумент.Дата = ДатаДокумента;  
	//--- Дмгг
	новыйДокумент.Организация = Организация;                                 
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("НалогообложениеНДС", МетаданныеДокумента)
		И ЗначениеЗаполнено(Организация) Тогда 
		новыйДокумент.НалогообложениеНДС = Организация.НалогообложениеНДС; 
	КонецЕсли;
	Если ЗаполнитьВидОперации Тогда 
		новыйДокумент.ВидОперации = текШаблонЗаполнения.ВидОперации;
		//+++ Дмгг
		Если новыйДокумент.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее Тогда 
			новыйДокумент.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
		КонецЕсли;
		//--- Дмгг   
		
		//Malyshev 2024-05-30 ONESOFT-3187
		Если (
