Функция НайтиКонтрагента(ИНН, Наименование, СчетБанк = Неопределено)
	
	наидКонтрагент = Неопределено;
	//Если Не (ЗначениеЗаполнено(ИНН) ИЛИ ЗначениеЗаполнено(Наименование)) Тогда 
	Если Не (ЗначениеЗаполнено(ИНН) ИЛИ ЗначениеЗаполнено(СчетБанк)) Тогда
		Возврат наидКонтрагент;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИНН) Тогда
		
		наидКонтрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН",ИНН);
		Если Не ЗначениеЗаполнено(наидКонтрагент) Тогда 
			//наидКонтрагент = Справочники.Контрагенты.НайтиПоНаименованию(Наименование);           
			ПоискСчет = Справочники.БанковскиеСчета.НайтиПоРеквизиту("НомерСчета", СчетБанк);   
			Если ЗначениеЗаполнено(ПоискСчет) Тогда 
				наидКонтрагент = ПоискСчет.Владелец;
			КонецЕсли;
		КонецЕсли;
		
	//ИначеЕсли ЗначениеЗаполнено(Наименование) Тогда  
	ИначеЕсли ЗначениеЗаполнено(СчетБанк) Тогда
		//наидКонтрагент = Справочники.Контрагенты.НайтиПоНаименованию(Наименование);  
		ПоискСчет = Справочники.БанковскиеСчета.НайтиПоРеквизиту("НомерСчета", СчетБанк);   
		Если ЗначениеЗаполнено(ПоискСчет) Тогда  
			Если ТипЗнч(ПоискСчет.Владелец) = Тип("СправочникСсылка.Контрагенты") Тогда 
				наидКонтрагент = ПоискСчет.Владелец;      
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Возврат наидКонтрагент;
	
КонецФункции //   

