&НаСервере
Процедура ProCredit_ЗагрузитьНаСервере(ArrExcel,ТипОбмена,ЧтениеExcel = ЛОЖЬ)
	
	//Проверка Номера Счета. Исходим из того что номер счета всегда в третей строке первой колонке
	Если ЧтениеExcel И ArrExcel[0][2] <> НомерСчета Тогда  
		ТекстСообщения = НСтр("ru = 'В указанном файле нет записей по выбранному счету'; ka = 'ამონაწერი არ ეკუთვნის არჩეულ ანგარიშის ნომერს'; en = 'There are no records for the selected account in the specified file'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,,);
		Возврат;
	КонецЕсли;
	
	Если ЧтениеExcel Тогда 
   		СтруктураКолонок = ПолучитьСтруктуруСоответствииКолонок(ТипОбмена, ArrExcel.Количество(), 1);
	Иначе
		СтруктураКолонок = ПолучитьСтруктуруСоответствииКолонок(ТипОбмена, 0, 0);
	КонецЕсли;
	
    СсылкаПустогоШаблона = Справочники.ШаблоныЗаполнения.ПустаяСсылка();
	
	Объект.ТаблицаВыписки.Очистить();
	врТаблицаВыписки = Объект.ТаблицаВыписки.Выгрузить();
	врТаблицаВыпискиШ =  врТаблицаВыписки.Скопировать();
	Для Каждого стр Из ArrExcel[0] Цикл 
		врТаблицаВыписки.Добавить();
	КонецЦикла;
	
	Для каждого стрСтруктури Из СтруктураКолонок Цикл
		стЗначение = стрСтруктури.Значение;
		стКлюч	   = стрСтруктури.Ключ;
		Попытка
			Если VTB И стКлюч = "Дата" Тогда 
				врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],"ДатаСтрока");
			Иначе 
				врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],стКлюч);
			КонецЕсли;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки() +  " колонка " + " стЗначение ");
		КонецПопытки;
	КонецЦикла;
	
	СтрокаУжеУдалялась = ЛОЖЬ;
	
	МассивУдаления = Новый Массив;
	Для каждого СтрокаВыписки Из врТаблицаВыписки Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки.Дата) 
			Или  СтрокаВыписки.Дата = "" 
			Или СтрокаВыписки.Дата = "ამონაწერი" 
			Или СтрокаВыписки.Дата = "თარიღი"	 
			Или СтрокаВыписки.Дата = "დანიშნულება"	 
			Или СтрокаВыписки.Дата = "Date"	Тогда 
			МассивУдаления.Добавить(СтрокаВыписки);
			СтрокаУжеУдалялась = Истина;
			Продолжить;
		ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.СуммаДт) Тогда 
			СтрокаВыписки.Наименование = СтрокаВыписки.НаименованиеДт;
			СтрокаВыписки.ИНН = СтрокаВыписки.ИННДт;
			СтрокаВыписки.СчетБанк = СтрокаВыписки.СчетБанкДт;
		ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.СуммаКт) Тогда 
			СтрокаВыписки.Наименование = СтрокаВыписки.НаименованиеКт;
			СтрокаВыписки.ИНН = СтрокаВыписки.ИННКт;
			СтрокаВыписки.СчетБанк = СтрокаВыписки.СчетБанкКт;
		КонецЕсли;
		
		// Kuzmich, 09.07.2024, (ONESOFT-3256) Помошник загрузки банковской выписки - Procredit Bank - Тип Операции - соответствие
		ТекущийТипОперации = СокрЛП(СтрокаВыписки.ТипОперации);
		Если ТекущийТипОперации = "DomesticPayment" Тогда
			СтрокаВыписки.ТипОперации = "გადარიცხვა საქართველოში";
		ИначеЕсли ТекущийТипОперации = "CurrencyConversion" Тогда
			СтрокаВыписки.ТипОперации = "ვალუტის კონვერტაცია";
		ИначеЕсли ТекущийТипОперации = "CardTransaction" Тогда
			СтрокаВыписки.ТипОперации = "საბარათე ტრანზაქცია";
		ИначеЕсли ТекущийТипОперации = "PaymentInsideProCredit" Тогда
			СтрокаВыписки.ТипОперации = "გადარიცხვა პროკრედიტ ბანკში";
		ИначеЕсли ТекущийТипОперации = "Commission" Тогда
			СтрокаВыписки.ТипОперации = "საკომისიო";
		ИначеЕсли ТекущийТипОперации = "OnlinePayments" Тогда
			СтрокаВыписки.ТипОперации = "ონლაინ გადახდები";
		ИначеЕсли ТекущийТипОперации = "Other" Тогда
			СтрокаВыписки.ТипОперации = "სხვა";
		КонецЕсли;
		// Kuzmich, 09.07.2024, (ONESOFT-3256) Помошник загрузки банковской выписки - Procredit Bank - Тип Операции - соответствие
		
		врТаблицаВыпискиШ.Очистить();
		СтрокаВыпискиШ = врТаблицаВыпискиШ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаВыпискиШ,СтрокаВыписки);
		СтрокаВыписки._ШаблонЗаполнения = СоответствоватьШаблонЗаполнения(врТаблицаВыпискиШ);
		
		пИНН = СтрЗаменить(СтрокаВыписки.ИНН, " ", "");//Паганини
		СтрокаВыписки.ID = СокрЛП(СтрЗаменить(СтрЗаменить(СтрокаВыписки.ID, " ", ""), Символы.НПП, ""));		
		//СтрокаВыписки.Ключ 
		//+ "_" + Строка(СтрокаВыписки.Дата) 
		//+ "_" + пИНН//СтрокаВыписки.ИНН 
		//+ "_" + СтрокаВыписки.НомерДокумента 
		//+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		//+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_-" + Строка(СтрокаВыписки.СуммаКт), "") 
		//+ "_" + СтрокаВыписки.НазначениеПлатежа
		//+ "_" + СтрокаВыписки.Баланс;
		
		// Поиск ранее обработанного документа
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) И СтрДлина(СтрокаВыписки.Комментарий)>0 Тогда
		
			ПозицияПервогоРазлелителя = СтрНайти(СтрокаВыписки.Комментарий,"##",НаправлениеПоиска.СНачала,,1);
			ПозицияВторогоРазлелителя = СтрНайти(СтрокаВыписки.Комментарий,"##",НаправлениеПоиска.СНачала,,2);
			Если ПозицияПервогоРазлелителя>0 И ПозицияВторогоРазлелителя>0 Тогда
			
				СтрокаУникальныйИдентификатор = СРЕД(СтрокаВыписки.Комментарий,ПозицияПервогоРазлелителя+2,36);
				
				СтрокаВыписки._СсылкаНаДокумент  = ПолучитьСсылкуНаДокументПоУникальномуИдентификатору(СтрокаУникальныйИдентификатор);
			
			КонецЕсли;
		
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда
			
			СтрокаВыписки._СсылкаНаДокумент  = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиДокументПоИД(СтрокаВыписки.ID);
			
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) 
				И (
				ЗначениеЗаполнено(СтрокаВыписки.Дата)
				И 
				ЗначениеЗаполнено(СтрокаВыписки.НомерДокумента)
				)
				Тогда
				
				СтрокаВыписки._СсылкаНаДокумент = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиДокументПоШаблонуДатеИНомеру(СтрокаВыписки._ШаблонЗаполнения,СтрокаВыписки.Дата,СтрокаВыписки.НомерДокумента,СтрокаВыписки.СуммаКт,СтрокаВыписки.СуммаДт);	
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда 
			СтрокаВыписки.ДокументПроведен  = СтрокаВыписки._СсылкаНаДокумент.Проведен; 
		КонецЕсли;
		
		СтрокаВыписки.Контрагент1С      = НайтиКонтрагента(пИНН,СтрокаВыписки.Наименование,СтрокаВыписки.СчетБанк);//СтрокаВыписки.ИНН
		СтрокаВыписки.Подотчетник1С     = НайтиПодотчетника(пИНН, СтрокаВыписки.СчетБанк);							//СтрокаВыписки.ИНН  
		//ВладелецСчета = ?(ЗначениеЗаполнено(СтрокаВыписки.Контрагент1С), СтрокаВыписки.Контрагент1С, СтрокаВыписки.Подотчетник1С.Физлицо);
		ВладелецСчета = ?(ЗначениеЗаполнено(СтрокаВыписки.Контрагент1С), СтрокаВыписки.Контрагент1С, СтрокаВыписки.Подотчетник1С);//++Lazare 05.04.2024
		СтрокаВыписки.СчетКонтрагента1С = НайтиСчет(ВладелецСчета,СтрокаВыписки.СчетБанк);
		                     
		Если СтрокаВыписки._ШаблонЗаполнения = СсылкаПустогоШаблона И НЕ СтрокаУжеУдалялась Тогда 					 
			//МассивУдаления.Добавить(СтрокаВыписки);
		КонецЕсли;
		
		СтрокаУжеУдалялась = ЛОЖЬ;
		
	КонецЦикла;
	
	Для каждого стрМУд Из МассивУдаления Цикл
		врТаблицаВыписки.Удалить(стрМУд);
	КонецЦикла;
	
	Объект.ТаблицаВыписки.Загрузить(врТаблицаВыписки);


