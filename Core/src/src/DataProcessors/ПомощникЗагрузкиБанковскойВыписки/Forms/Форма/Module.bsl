&НаСервере
Процедура ТаблицаВыписки_ШаблонЗаполненияПриИзмененииНаСервере(УИДСтроки)  
	
	ТекущаяСтрокаВыписки = Объект.ТаблицаВыписки.НайтиПоИдентификатору(УИДСтроки);
	
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрокаВыписки._ШаблонЗаполнения) Тогда 
		Возврат;
	КонецЕсли;
	
	ИскатьКонтрагента = Истина;
	ИскатьСотрудника = Ложь; 
	
	Если ЗначениеЗаполнено(ТекущаяСтрокаВыписки._ШаблонЗаполнения) 
		И (ТекущаяСтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "ВыплатаЗарплаты"
		И (ТекущаяСтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийВыплатыЗарплаты.ВыплатаАванса  
		ИЛИ ТекущаяСтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийВыплатыЗарплаты.ВыплатаЗарплаты
		ИЛИ ТекущаяСтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийВыплатыЗарплаты.НачислениеИВыплатаЗарплаты))
		ИЛИ ТекущаяСтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "ПеремещениеДенежныхСредств" Тогда 
		
		ИскатьКонтрагента = Ложь;
		ИскатьСотрудника = Истина;
		
	КонецЕсли;     
	
	Если ИскатьКонтрагента Тогда     
		Если ЗначениеЗаполнено(СокрЛП(ТекущаяСтрокаВыписки.ИНН)) Тогда 
			ТекущаяСтрокаВыписки.Контрагент1С	= НайтиКонтрагента(ТекущаяСтрокаВыписки.ИНН, ТекущаяСтрокаВыписки.Наименование);    
			ТекущаяСтрокаВыписки.Подотчетник1С	= Справочники.Сотрудники.ПустаяСсылка();      
		Иначе              
			ТекущаяСтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(ТекущаяСтрокаВыписки.СчетБанк, "Контрагенты");
			Если ЗначениеЗаполнено(ТекущаяСтрокаВыписки.СчетКонтрагента1С) Тогда       
				ТекущаяСтрокаВыписки.Контрагент1С	= ТекущаяСтрокаВыписки.СчетКонтрагента1С.Владелец;    
				ТекущаяСтрокаВыписки.Подотчетник1С	= Справочники.Сотрудники.ПустаяСсылка();  
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ИскатьСотрудника Тогда  
		Если ЗначениеЗаполнено(СокрЛП(ТекущаяСтрокаВыписки.ИНН)) Тогда 
			ТекущаяСтрокаВыписки.Контрагент1С	=  Справочники.Контрагенты.ПустаяСсылка();
		ТекущаяСтрокаВыписки.Подотчетник1С  = НайтиПодотчетника(ТекущаяСтрокаВыписки.ИНН);      
		Иначе              
			ТекущаяСтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(ТекущаяСтрокаВыписки.СчетБанк, "Сотрудники");
			Если ЗначениеЗаполнено(ТекущаяСтрокаВыписки.СчетКонтрагента1С) Тогда       
				ТекущаяСтрокаВыписки.Контрагент1С	= Справочники.Контрагенты.ПустаяСсылка();    
				ТекущаяСтрокаВыписки.Подотчетник1С	= ТекущаяСтрокаВыписки.СчетКонтрагента1С.Владелец;  
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаВыписки_ШаблонЗаполненияПриИзменении(Элемент)  
	
	ТекущаяСтрокаВыписки = Элементы.ТаблицаВыписки.ТекущиеДанные;
	УИДСтроки = ТекущаяСтрокаВыписки.ПолучитьИдентификатор();
	ТаблицаВыписки_ШаблонЗаполненияПриИзмененииНаСервере(УИДСтроки);    
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСсылкуНаДокументПоУникальномуИдентификатору(СтрокаУникальныйИдентификатор)
	ПЕРЕМ РЕЗ;
	
	Если СтрДлина(СтрокаУникальныйИдентификатор)>0 Тогда
	
		Для Каждого МенеджерДокумента Из Документы Цикл 
			
			РЕЗ = МенеджерДокумента.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаУникальныйИдентификатор));
			Если СтрНайти(Строка(РЕЗ),"Объект не найден")=0 Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
	
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

&НаКлиенте
Процедура ТаблицаВыпискиСчетКонтрагента1СНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	ТекущаяСтрока = Элементы.ТаблицаВыписки.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.Подотчетник1С) Тогда 
		
		ФизЛицо = ПолучитьФизЛицоИзСотрудникаНаСервере(ТекущаяСтрока.Подотчетник1С);   
		
		МассивПараметров = Новый Массив;
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.Владелец", ФизЛицо); 
		
		МассивПараметров.Добавить(НовыйПараметр);
		
		МассивПараметров.Добавить(НовыйПараметр);
		Элементы.ТаблицаВыпискиСчетКонтрагента1С.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров); 
		
	Иначе                  
		
		МассивПараметров = Новый Массив;
		
		НовыйПараметр = Новый ПараметрВыбора("Отбор.Владелец", ТекущаяСтрока.Контрагент1С);
		
		МассивПараметров.Добавить(НовыйПараметр);
		
		МассивПараметров.Добавить(НовыйПараметр);
		Элементы.ТаблицаВыпискиСчетКонтрагента1С.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);  
		
	КонецЕсли;     
	
КонецПроцедуры

Функция ПолучитьФизЛицоИзСотрудникаНаСервере(Сотрудник)
	
	Если НЕ ЗначениеЗаполнено(Сотрудник) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Сотрудник.Физлицо;
	
КонецФункции

&НаКлиенте
Процедура ПутьКФайлуНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДиалогВыбораФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	ДиалогВыбораФайла.Фильтр                      = НСтр("ka='ფაილი Excel 2007 (*.xlsx)|*.xlsx';ru='Книга Excel 2007 (*.xlsx)|*.xlsx';en='Book Excel 2007 (* .xlsx) | * .xlsx'");
	ДиалогВыбораФайла.Заголовок                   = Заголовок;
	ДиалогВыбораФайла.ПредварительныйПросмотр     = Ложь;
	ДиалогВыбораФайла.Расширение                  = "xlsx";
	ДиалогВыбораФайла.ИндексФильтра               = 0;
	//ДиалогВыбораФайла.ПолноеИмяФайла              = ИмяФайла;
	//ДиалогВыбораФайла.ПроверятьСуществованиеФайла = Ложь;
	
	Если ДиалогВыбораФайла.Выбрать() Тогда
		Объект.ПутьКФайлу = ДиалогВыбораФайла.ПолноеИмяФайла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПреобразоватьДату(СтркаПреобразования)
	
	СтрокаДаты = "";
	
	Год 	= Лев(СтркаПреобразования, 4);
	Месяц   = Сред(СтркаПреобразования, 6, 2);
	День    = Сред(СтркаПреобразования, 9, 2);
	Часы    = Сред(СтркаПреобразования, 12, 2);
	Минуты  = Сред(СтркаПреобразования, 15, 2);
	Секунды = Сред(СтркаПреобразования, 18, 2);
	
	СтрокаДаты = СтрокаДаты + День + "." + Месяц + "." + Год; // + " " + Часы + ":" + Минуты + ":" + Секунды;
	
	Возврат СтрокаДаты;
	
КонецФункции

&НаКлиенте
Функция ДатаВСтроку(Дата) 
	
	Если не ЗначениеЗаполнено(Дата) Тогда
		Возврат "";
	Иначе
		ДатаСтрока = Строка(Формат(Дата, "ДФ='yyyy-MM-dd'"));
		Возврат ДатаСтрока;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ЗапольнитьОрганизациюИАвтор()

	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	Объект.Автор = ТекПользователь ;
	ЗначениеНастройки = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ТекПользователь, "ОсновнаяОрганизация");
	Если ЗначениеЗаполнено(ЗначениеНастройки) Тогда
		Если Объект.Организация <> ЗначениеНастройки Тогда
			Объект.Организация = ЗначениеНастройки;
		КонецЕсли;
	Иначе
		Объект.Организация = УправлениеНебольшойФирмойСервер.ПолучитьПредопределеннуюОрганизацию();
	КонецЕсли;

КонецПроцедуры // ()

Функция НайтиДокументПоИД(ID)
	
	НаиденныйДок = Документы.РасходСоСчета.НайтиПоРеквизиту("ID",ID);
	
	Если НЕ ЗначениеЗаполнено(НаиденныйДок) Тогда 
		
		НаиденныйДок = Документы.ПоступлениеНаСчет.НайтиПоРеквизиту("ID",ID);
		
	//ИначеЕсли НЕ ЗначениеЗаполнено(НаиденныйДок) Тогда 
		Если НЕ ЗначениеЗаполнено(НаиденныйДок) Тогда 
			
			НаиденныйДок = Документы.ПеремещениеДС.НайтиПоРеквизиту("ID",ID);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат НаиденныйДок;
	
КонецФункции

&НаСервере
Процедура ДополнитьДокументКонвертацииНаСервере()
	
	воОбъект =  РеквизитФормыВЗначение("Объект");
	воОбъект.ДополнитьДокументыКонвертации();
	ЗначениеВРеквизитФормы(воОбъект, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнитьДокументКонвертации(Команда)
	ДополнитьДокументКонвертацииНаСервере();
КонецПроцедуры
