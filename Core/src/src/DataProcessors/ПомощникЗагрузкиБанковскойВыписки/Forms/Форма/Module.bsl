	CARTU = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.Cartu;
	VTB = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.VTB; 
	ProCredit = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.ProCredit; 
	
	Если ЗначениеЗаполнено(Объект.БанковскийСчет) И ЗначениеЗаполнено(Объект.БанковскийСчет.Банк) Тогда
	
		Если BOG И НЕ(Объект.БанковскийСчет.Банк.СВИФТБИК = "BAGAGE22") Тогда
		
			Объект.БанковскийСчет = НЕОПРЕДЕЛЕНО;
			
		ИначеЕсли TBC И НЕ(Объект.БанковскийСчет.Банк.СВИФТБИК = "TBCBGE22") Тогда
		
			Объект.БанковскийСчет = НЕОПРЕДЕЛЕНО;
			
		ИначеЕсли CARTU И НЕ(Объект.БанковскийСчет.Банк.СВИФТБИК = "CRTUGE22") Тогда
		
			Объект.БанковскийСчет = НЕОПРЕДЕЛЕНО;  
			
		ИначеЕсли ProCredit И НЕ(Объект.БанковскийСчет.Банк.СВИФТБИК = "MIBGGE22") Тогда //ПроКредит
		
			Объект.БанковскийСчет = НЕОПРЕДЕЛЕНО;
		
		КонецЕсли;
	
	КонецЕсли;
	
	УстановитьВидимость();	
	
