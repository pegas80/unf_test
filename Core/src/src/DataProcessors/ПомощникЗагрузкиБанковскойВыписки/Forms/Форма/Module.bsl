&НаСервереБезКонтекста
Функция НайтиНомерБанковскогоСчета(БанковскийСчет, МассивРеквизитовФайла, МассивДляВыписки, ВысотаШапкиСДанными = 1)
	
	НомерСчетаНайден = Ложь;
	НомерСчетаСтрокой = СокрЛП(БанковскийСчет.НомерСчета); 
	
	//Ищем на странце с реквизитами
	Если МассивРеквизитовФайла.Количество()>0 тогда
		
		НомерСчетаНайден = Ложь;		
		Для каждого СтрокаРеквизитов из МассивРеквизитовФайла Цикл
			Для каждого МассивКолонки из СтрокаРеквизитов.Значение Цикл
				Для каждого ЭлементШапки из МассивКолонки Цикл
					Если СтрНайти(СокрЛП(""+ЭлементШапки), НомерСчетаСтрокой)>0 Тогда
						НомерСчетаНайден = Истина;
						//Сообщить("Нашли в шапке на отдельной закладке");
						Возврат НомерСчетаНайден;
					КонецЕсли;	
				КонецЦикла;	
			КонецЦикла;	
		КонецЦикла;	                              
		
	КонецЕсли;
	
	//Ищем на той же странице, где данные
	Если не НомерСчетаНайден Тогда   
		
		Для каждого МассивКолонки из МассивДляВыписки Цикл
			НПП = 0;
			Для каждого ЭлементШапки из МассивКолонки Цикл
				НПП = НПП + 1;
				Если СтрНайти(СокрЛП(""+ЭлементШапки), НомерСчетаСтрокой)>0 Тогда
					НомерСчетаНайден = Истина;
					//Сообщить("Нашли в данных");
					Возврат НомерСчетаНайден;
				КонецЕсли;	  
				Если НПП>ВысотаШапкиСДанными Тогда
					Прервать;
				КонецЕсли;	
			КонецЦикла;	
		КонецЦикла;			
	КонецЕсли;	
	

	Возврат НомерСчетаНайден;		

КонецФункции // НайтиНомерБанковскогоСчета()



&НаСервере
Процедура ЗагрузитьНаСервере(ArrExcel, ВариантЗагрузки)
	
	Если BOG Тогда
		BOG_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia, ВариантЗагрузки);
	КонецЕсли;
	
	Если TBC Тогда
		TBC_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.TBC);
	КонецЕсли;
	
	Если CARTU Тогда
		CARTU_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.Cartu);
	КонецЕсли;
	
	Если VTB Тогда
		VTB_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.VTB);
	КонецЕсли;  
	
	Если ProCredit Тогда  //ПроКредит
		ProCredit_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.ProCredit, Истина);
	КонецЕсли;
	
	ТаблицаВыписки.Загрузить(Объект.ТаблицаВыписки.Выгрузить());
	//Таб.Параметры.УстановитьЗначениеПараметра("Таб", ТаблицаВыписки.Выгрузить());
	
КонецПроцедуры

