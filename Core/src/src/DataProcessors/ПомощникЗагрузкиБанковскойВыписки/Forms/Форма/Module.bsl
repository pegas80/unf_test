&НаСервере
Процедура ЗапольнитьФормуПоУмолчанию()

	ТекПользователь = ПараметрыСеанса.ТекущийПользователь;
	Объект.Автор = ТекПользователь ;
	ЗначениеНастройки = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ТекПользователь, "ОсновнаяОрганизация");
	Если ЗначениеЗаполнено(ЗначениеНастройки) Тогда
		Если Объект.Организация <> ЗначениеНастройки Тогда
			Объект.Организация = ЗначениеНастройки;
		КонецЕсли;
	Иначе
		Объект.Организация = Справочники.Организации.ОсновнаяОрганизация;
	КонецЕсли;
	
	Объект.БанковскийСчет = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ТекПользователь, "ОсновнойБанковскийСчет");
	
	Если ЗначениеЗаполнено(Объект.БанковскийСчет.Банк) Тогда
	
		Если Объект.БанковскийСчет.Банк.СВИФТБИК = "BAGAGE22" Тогда
		
			Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia;
			
		ИначеЕсли Объект.БанковскийСчет.Банк.СВИФТБИК = "TBCBGE22" Тогда
		
			Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.TBC;
			
		ИначеЕсли Объект.БанковскийСчет.Банк.СВИФТБИК = "MIBGGE22" Тогда  //ПроКредит
			
			Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.ProCredit;
			
		КонецЕсли;
	
	КонецЕсли;

