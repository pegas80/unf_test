&НаКлиенте
Процедура БанковскийСчетНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	БанковскийСчетУстановитьПараметрыВыбора();
	
КонецПроцедуры

&НаКлиенте
Процедура БанковскийСчетАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	БанковскийСчетУстановитьПараметрыВыбора();
	
КонецПроцедуры

&НаСервере
Процедура БанковскийСчетУстановитьПараметрыВыбора()

	МассивПараметров = Новый Массив();
	
	Если ЗначениеЗаполнено(Объект.ТипОбменаСИнтернетБанком) Тогда
	
		СВИФТ = НЕОПРЕДЕЛЕНО;
		
		Если BOG Тогда
		
			СВИФТ = "BAGAGE22";
			
		ИначеЕсли TBC Тогда
		
			СВИФТ = "TBCBGE22";
			
		ИначеЕсли CARTU Тогда
		
			СВИФТ = "CRTUGE22";
			
		ИначеЕсли ProCredit Тогда  //ПроКредит
		
			СВИФТ = "MIBGGE22";

		КонецЕсли;
		
		Если НЕ СВИФТ = НЕОПРЕДЕЛЕНО Тогда
		
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	Банки.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Банки КАК Банки
			|ГДЕ
			|	НЕ Банки.ПометкаУдаления
			|	И Банки.СВИФТБИК = &СВИФТ";
			
			Запрос.УстановитьПараметр("СВИФТ", СВИФТ);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			МассивБанков = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
			
			НовыйПараметр = Новый ПараметрВыбора("Отбор.Банк", Новый ФиксированныйМассив(МассивБанков));
			МассивПараметров.Добавить(НовыйПараметр);
		
		КонецЕсли;
	
	КонецЕсли;
	
	Элементы.БанковскийСчет.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);

КонецПроцедуры

#Область ПолучениеБанковскойВыпискиИзTBC

&НаКлиенте
Процедура ЗавершениеВводаПароляDigiPass(Результат, ДополнительныеПараметры) ЭКСПОРТ
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		ПараметрыСоединенияТБС = ДополнительныеПараметры.ПараметрыСоединенияТБС;
		СтруктураПарметровЗапросаВБанк = ДополнительныеПараметры.СтруктураПарметровЗапросаВБанк;
		
		ПараметрыСоединенияТБС.Nonce = Результат;
		ПолучитьБанковскуюВыпискуИзTBC(ПараметрыСоединенияТБС,СтруктураПарметровЗапросаВБанк);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьБанковскуюВыпискуИзTBC(ПараметрыСоединенияТБС, СтруктураПарметровЗапросаВБанк) ЭКСПОРТ

	ИнтеграцияСБанкомTBC_КлиентСервер.ВыполнитьЗапросВБанк(ПараметрыСоединенияТБС, СтруктураПарметровЗапросаВБанк);
	
	ОбработатьРезультатыПолученияБанковскойВыпискиИзTBC(СтруктураПарметровЗапросаВБанк);

КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатыПолученияБанковскойВыпискиИзTBC(СтруктураПарметровЗапросаВБанк)
	
	ТаблицаБанковскойВыписки = Новый ТаблицаЗначений();
	ТаблицаБанковскойВыписки.Колонки.Добавить("Date",ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаБанковскойВыписки.Колонки.Добавить("description", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("additionalInformation", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("PaidOut",Новый ОписаниеТипов("Число"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("PaidIn",Новый ОписаниеТипов("Число"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("Balance",Новый ОписаниеТипов("Число"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("Type", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("DocumentDate",ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаБанковскойВыписки.Колонки.Добавить("documentNumber", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("partnerAccountNumber", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("partnerName", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("partnerTaxCode", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("partnerBankCode", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("partnerBank", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("intermediaryBankCode", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("intermediaryBank", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("chargeDetail", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("taxpayerCode", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("taxpayerName", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("treasuryCode", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("operationCode", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("additionalDescription", Новый ОписаниеТипов("Строка"));
	//ТаблицаБанковскойВыписки.Колонки.Добавить("СсылкаНаДокумент", ОбщегоНазначения.ОписаниеТипаВсеСсылки());
	ТаблицаБанковскойВыписки.Колонки.Добавить("TransactionID", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("currency", Новый ОписаниеТипов("Строка"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("exchangeRate", Новый ОписаниеТипов("Число"));
	ТаблицаБанковскойВыписки.Колонки.Добавить("СсылкаНаДокумент", ОбщегоНазначения.ОписаниеТипаВсеСсылки());
	
	ТаблицаДвиженийПоСчету = ПолучитьИзВременногоХранилища(СтруктураПарметровЗапросаВБанк.ТаблицаДвиженийПоСчету);
	Если ТаблицаДвиженийПоСчету.Количество()>0 Тогда
	
		Для каждого СтрокаТаблицаДвиженийПоСчету Из ТаблицаДвиженийПоСчету Цикл
		
			СтрокаТаблицаБанковскойВыписки = ТаблицаБанковскойВыписки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицаБанковскойВыписки,СтрокаТаблицаДвиженийПоСчету,,"DocumentDate");
			
			Если СтрокаТаблицаДвиженийПоСчету.debitCredit = "1" Тогда //+++ Дмгг поменял местами "0" и "1", ребята писали что не верно
				СтрокаТаблицаБанковскойВыписки.PaidOut = 0;
				СтрокаТаблицаБанковскойВыписки.PaidIn = Число(СтрокаТаблицаДвиженийПоСчету.amount);
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.debitCredit = "0" Тогда
				СтрокаТаблицаБанковскойВыписки.PaidOut = Число(СтрокаТаблицаДвиженийПоСчету.amount);
				СтрокаТаблицаБанковскойВыписки.PaidIn = 0;
			КонецЕсли;
			
			СтрокаТаблицаБанковскойВыписки.Date = ПрочитатьДатуJSON(ЛЕВ(СтрокаТаблицаДвиженийПоСчету.valueDate,19),ФорматДатыJSON.ISO);
			СтрокаТаблицаБанковскойВыписки.DocumentDate = ПрочитатьДатуJSON(ЛЕВ(СтрокаТаблицаДвиженийПоСчету.documentDate,19),ФорматДатыJSON.ISO);
			
			Если СтрокаТаблицаДвиженийПоСчету.transactionType = "1" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "საკუთარ ანგარიშებს შორის გადარიცხვა";
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.transactionType = "5" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "კონვერტაცია";	
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.transactionType = "20" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "შემოსავლები";
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.transactionType = "30" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "გადარიცხვა და თანხის გატანა";
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.transactionType = "31" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "კომუნალური, მობილური, ჯარიმები";
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.transactionType = "32" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "საბიუჯეტო გადარიცხვები";
			ИначеЕсли СтрокаТаблицаДвиженийПоСчету.transactionType = "33" Тогда
				СтрокаТаблицаБанковскойВыписки.Type = "სხვა ხარჯები";
			КонецЕсли;
			
			Если НЕ ТипЗНЧ(СтрокаТаблицаДвиженийПоСчету.partnerTaxCode)=Тип("Строка") Тогда
				СтрокаТаблицаБанковскойВыписки.partnerTaxCode = "";
			КонецЕсли;       
			
			Если СтрокаТаблицаДвиженийПоСчету.exchangeRate = NULL ИЛИ СтрокаТаблицаДвиженийПоСчету.exchangeRate = Неопределено
					ИЛИ СтрокаТаблицаДвиженийПоСчету.exchangeRate = "" Тогда 
				СтрокаТаблицаБанковскойВыписки.exchangeRate = 1
			Иначе        
				Если ТипЗнч(СтрокаТаблицаДвиженийПоСчету.exchangeRate) <> Тип("Структура") Тогда 
					//+++ Дмгг, 14.03.24, ONESOFT-3041
					ЗначениеКурса = Сред(СтрокаТаблицаДвиженийПоСчету.exchangeRate,9);
					СтрокаТаблицаБанковскойВыписки.exchangeRate = Число(Лев(ЗначениеКурса,СтрНайти(ЗначениеКурса," ")-1));					
					//+++ Дмгг, 14.03.24, ONESOFT-3041
					Курс1 = Сред(СтрокаТаблицаДвиженийПоСчету.exchangeRate,3,3);
					Курс2 = Прав(СтрокаТаблицаДвиженийПоСчету.exchangeRate,3);
					Если СтрокаТаблицаБанковскойВыписки.currency = Курс1 Тогда 
						СтрокаТаблицаБанковскойВыписки.currency = Курс2;
					Иначе
						СтрокаТаблицаБанковскойВыписки.currency = Курс1;
					КонецЕсли;       
				КонецЕсли;
				//СтрокаТаблицаБанковскойВыписки.currency = Сред(СтрокаТаблицаДвиженийПоСчету.exchangeRate,3,3);
			КонецЕсли;
			СтрокаТаблицаБанковскойВыписки.TransactionID = СокрЛП(СтрокаТаблицаДвиженийПоСчету.externalPaymentId);
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	УИДДокументовВИнтернетБанке.ДокументСсылка КАК ДокументСсылка
			|ИЗ
			|	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
			|ГДЕ
			|	УИДДокументовВИнтернетБанке.УИДДокументаВБанке = &УИДДокументаВБанке";
			
			Запрос.УстановитьПараметр("УИДДокументаВБанке", СтрокаТаблицаДвиженийПоСчету.paymentId);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Если ВыборкаДетальныеЗаписи.Следующий() Тогда
				СтрокаТаблицаБанковскойВыписки.СсылкаНаДокумент = ВыборкаДетальныеЗаписи.ДокументСсылка;
			КонецЕсли;
			
		КонецЦикла;
	
	КонецЕсли;
	
	//+++ Дмгг
	ТаблицаБанковскойВыписки.Сортировать("Date Возр");
	//--- Дмгг
	
	МассивМассивов = Новый Массив();
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("Date"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("description"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("additionalInformation"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("PaidOut"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("PaidIn"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("Balance"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("Type"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("DocumentDate"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("documentNumber"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("partnerAccountNumber"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("partnerName"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("partnerTaxCode"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("partnerBankCode"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("partnerBank"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("intermediaryBankCode"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("intermediaryBank"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("chargeDetail"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("taxpayerCode"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("taxpayerName"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("treasuryCode"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("operationCode"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("additionalDescription"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("TransactionID")); 
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("currency"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("exchangeRate"));
	МассивМассивов.Добавить(ТаблицаБанковскойВыписки.ВыгрузитьКолонку("СсылкаНаДокумент"));
	
	TBC_ЗагрузитьНаСервере(МассивМассивов,Перечисления.ТипыОбменаСИнтернетБанком.TBC,ИСТИНА);

КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ПолучитьБанковскуюВыпискуИзProcredit(ПараметрыСоединенияProCredit, СтруктураПарметровЗапросаВБанк) ЭКСПОРТ

	ИнтеграцияСБанкомProCredit_КлиентСервер.ВыполнитьЗапросВБанк(ПараметрыСоединенияProCredit, СтруктураПарметровЗапросаВБанк);
	
	ОбработатьРезультатыПолученияБанковскойВыпискиИзProCredit(СтруктураПарметровЗапросаВБанк);

КонецПроцедуры

&НаКлиенте
Процедура ЗавершениеВводаПароляOTP(Результат, ДополнительныеПараметры) ЭКСПОРТ
	
	Если ЗначениеЗаполнено(Результат) Тогда
		
		ПараметрыСоединенияProCredit = ДополнительныеПараметры.ПараметрыСоединенияProCredit;
		СтруктураПарметровЗапросаВБанк = ДополнительныеПараметры.СтруктураПарметровЗапросаВБанк;
		
		ПараметрыСоединенияProCredit.OTP = СокрЛП(Результат);
		ПолучитьБанковскуюВыпискуИзProcredit(ПараметрыСоединенияProCredit,СтруктураПарметровЗапросаВБанк);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьРезультатыПолученияБанковскойВыпискиИзProCredit(СтруктураПарметровЗапросаВБанк)
	
	ТаблицаБанковскойВыписки = Новый ТаблицаЗначений();
	ТаблицаБанковскойВыписки.Колонки.Добавить("DOC_DATE",ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.ДатаВремя));
	ТаблицаБанковскойВыписки.Колонки.Добавить("DOC_NUM", Новый ОписаниеТипов("Строка"));
