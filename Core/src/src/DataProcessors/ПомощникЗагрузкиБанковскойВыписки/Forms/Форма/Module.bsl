			Если ИскатьКонтрагента Тогда     
				Если ЗначениеЗаполнено(СокрЛП(СтрокаВыписки.ИНН)) Тогда 
					СтрокаВыписки.Контрагент1С	= НайтиКонтрагента(СтрокаВыписки.ИНН, СтрокаВыписки.Наименование);    
					СтрокаВыписки.Подотчетник1С	= Справочники.Сотрудники.ПустаяСсылка(); 
					
				Иначе              
					СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк, "Контрагенты");
					Если ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда       
						СтрокаВыписки.Контрагент1С	= СтрокаВыписки.СчетКонтрагента1С.Владелец;    
						СтрокаВыписки.Подотчетник1С	= Справочники.Сотрудники.ПустаяСсылка();  
					КонецЕсли;
				КонецЕсли;
				
				
				
				
				
			ИначеЕсли ИскатьСотрудника Тогда  
				Если ЗначениеЗаполнено(СокрЛП(СтрокаВыписки.ИНН)) Тогда 
					СтрокаВыписки.Контрагент1С	=  Справочники.Контрагенты.ПустаяСсылка();
					СтрокаВыписки.Подотчетник1С  = НайтиПодотчетника(СтрокаВыписки.ИНН);      
				Иначе              
					СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк, "Сотрудники");
					Если ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда       
						СтрокаВыписки.Контрагент1С	= Справочники.Контрагенты.ПустаяСсылка();    
						СтрокаВыписки.Подотчетник1С	= СтрокаВыписки.СчетКонтрагента1С.Владелец;  
					КонецЕсли;
				КонецЕсли;
			//+++ Дмгг, 11.04.2025, ONESOFT-3973	
			ИначеЕсли ИскатьОрганизацию Тогда  
				
				СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк, "", СтрокаВыписки.Валюта);
			//--- Дмгг, 11.04.2025, ONESOFT-3973	
			КонецЕсли; 
			
			//Заполним счет контрагента	
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) и ЗначениеЗаполнено(СтрокаВыписки.СчетБанк) Тогда 
				ВладелецСчета = Неопределено; 
				Если СтрокаВыписки.ИННДт = СтрокаВыписки.ИННКт Тогда
					//Малышев 2024-05-30 ONESOFT-3187  
					ВладелецСчета = объект.Организация;                                                  
				ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.Контрагент1С) Тогда     
					ВладелецСчета = СтрокаВыписки.Контрагент1С;
				ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.Подотчетник1С) Тогда       
					ВладелецСчета = СтрокаВыписки.Подотчетник1С;
				Иначе    
					ВладелецСчета = объект.Организация;
				КонецЕсли;
				
				СтрокаВыписки.СчетКонтрагента1С = НайтиСчет(ВладелецСчета, СтрокаВыписки.СчетБанк);
				
			КонецЕсли;
			
			//Малышев 2024-05-30 ONESOFT-3187 
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда
				СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк);

				Если НЕ ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда
					//Если у счета нет признака валюты на конце, тогда дописываем туда валюту и уже по нему ищем
					РазницаДлинСчетов = СтрДлина(Объект.БанковскийСчет.НомерСчета) - СтрДлина(СтрокаВыписки.СчетБанк);
					Если РазницаДлинСчетов > 0 Тогда
						//допишем признак валюты к счету
						НовыйСчетБанк = СтрокаВыписки.СчетБанк + Прав(Объект.БанковскийСчет.НомерСчета, РазницаДлинСчетов); 
						СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(НовыйСчетБанк,, Объект.БанковскийСчет.ВалютаДенежныхСредств.Наименование);						
					КонецЕсли;	
					
				КонецЕсли;	
						
			КонецЕсли;
			
			//Малышев 2024-05-29 ONESOFT-3186 - попробуем найти сотрудника по ИНН контрагента
			Если ИскатьКонтрагента и ЗначениеЗаполнено(СтрокаВыписки.ИНН) Тогда
				СтрокаВыписки.Подотчетник1С = НайтиПодотчетника(СтрокаВыписки.ИНН);  
			КонецЕсли;	
			
			
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого стрМУд Из МассивУдаления Цикл
		врТаблицаВыписки.Удалить(стрМУд);
	КонецЦикла;
	Объект.ТаблицаВыписки.Загрузить(врТаблицаВыписки);
	

КонецПроцедуры 

&НаСервере
Процедура TBC_ЗагрузитьНаСервере(ArrExcel,ТипОбмена,ЕстьСсылкаНаДокумент=ЛОЖЬ)

    СтруктураКолонок = ПолучитьСтруктуруСоответствииКолонок(ТипОбмена);

	Объект.ТаблицаВыписки.Очистить();
	врТаблицаВыписки = Объект.ТаблицаВыписки.Выгрузить();
	врТаблицаВыпискиШ =  врТаблицаВыписки.Скопировать();
	Для Каждого стр Из ArrExcel[0] Цикл 
		врТаблицаВыписки.Добавить();
	КонецЦикла;
	
	ТребуетьсяПреобразованиеДаты = ЛОЖЬ;
	Если ArrExcel[0].Количество() > 2 И СтрНайти(ArrExcel[0][2],"/") <> 0 Тогда 
		ТребуетьсяПреобразованиеДаты = Истина;
	КонецЕсли;
	МассивКолонкиДат = Новый Массив;
	Для Каждого ЭлемДат Из ArrExcel[0] Цикл 
		ДатаСтрокой = Формат(ЭлемДат,"ДФ=dd.MM.yyyy");
		День 	= Лев(ДатаСтрокой, 2);
		Месяц 	= Сред(ДатаСтрокой, 4,2);
		Год 	= Сред(ДатаСтрокой, 7,4);
		Попытка
			ДатаСтроки = Дата(Год,Месяц,День);
		Исключение
			ДатаСтроки = Дата(1,1,1);
		КонецПопытки;
		МассивКолонкиДат.Добавить(ДатаСтроки);
	КонецЦикла;
	
	Для каждого стрСтруктури Из СтруктураКолонок Цикл
		стЗначение = стрСтруктури.Значение;
		стКлюч	   = стрСтруктури.Ключ;
		//+++ Дмгг, проверка, на то что мы читаем ексель, в екселе на 2 колонки меньше;
		Если ArrExcel.Количество() < стЗначение Тогда 
			//Скоре всего это ексель
			Продолжить;
		КонецЕсли;
		//--- ДМгг
		Если ТребуетьсяПреобразованиеДаты И стКлюч = "Дата" Тогда 
			Попытка
				врТаблицаВыписки.ЗагрузитьКолонку(МассивКолонкиДат,стКлюч);
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки() +  " колонка " + " стЗначение ");
			КонецПопытки;
		Иначе
			Если ArrExcel.Количество() = стЗначение-1   
				И стКлюч = "Курс" Тогда 
				Продолжить;
			КонецЕсли;
			Попытка
				врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],стКлюч);
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки() +  " колонка " + " стЗначение ");
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьСсылкаНаДокумент Тогда
		//врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[22],"_СсылкаНаДокумент");
		врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[25],"_СсылкаНаДокумент");
	КонецЕсли;
	МассивУдаления = Новый Массив;
	Для каждого СтрокаВыписки Из врТаблицаВыписки Цикл
		Если  НЕ ЗначениеЗаполнено(СтрокаВыписки.Дата)
			Или СтрокаВыписки.Дата = "" 
			Или СтрокаВыписки.Дата = "ამონაწერი" 
			Или СтрокаВыписки.Дата = "თარიღი"	 
			Или СтрокаВыписки.Дата = "Date"	Тогда 
			МассивУдаления.Добавить(СтрокаВыписки);
			Продолжить;
		КонецЕсли;
		
		врТаблицаВыпискиШ.Очистить();
		СтрокаВыпискиШ = врТаблицаВыпискиШ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаВыпискиШ,СтрокаВыписки);
		СтрокаВыписки._ШаблонЗаполнения = СоответствоватьШаблонЗаполнения(врТаблицаВыпискиШ);
		
		ИскатьКонтрагента = Истина;
		ИскатьСотрудника = Ложь; 
		ИскатьОрганизацию = Ложь;
		Если ЗначениеЗаполнено(СтрокаВыписки._ШаблонЗаполнения) 
			И (СтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "ВыплатаЗарплаты"
			И (СтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийВыплатыЗарплаты.ВыплатаАванса  
			ИЛИ СтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийВыплатыЗарплаты.ВыплатаЗарплаты
			ИЛИ СтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийВыплатыЗарплаты.НачислениеИВыплатаЗарплаты))
			//+++ Дмгг, 08.05.2025, ONESOFT-4047
			//ИЛИ СтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "ПеремещениеДенежныхСредств" Тогда 
			ИЛИ СтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "ПеремещениеДенежныхСредств" 
			ИЛИ (СтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "РасходСоСчета" 
				И СтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику)
			ИЛИ (СтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "ПостуалениеНаСчет"                            
				 И СтрокаВыписки._ШаблонЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника) Тогда 
			//--- Дмгг, 08.05.2025, ONESOFT-4047
			ИскатьКонтрагента = Ложь;
			ИскатьСотрудника = Истина;
			ИскатьОрганизацию = Ложь;
		ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки._ШаблонЗаполнения) 
			И (СтрокаВыписки._ШаблонЗаполнения.СсылкаИсточника = "Конвертация"
			ИЛИ (СтрокаВыписки.Курс <> 1 И СтрокаВыписки.Курс <> 0)) Тогда
			
			ИскатьКонтрагента = Ложь;
			ИскатьСотрудника = Ложь;
			ИскатьОрганизацию = Истина;
			
		КонецЕсли;
		пИНН = СтрЗаменить(СтрокаВыписки.ИНН, " ", "");
		СтрокаВыписки.ID = 
		СтрокаВыписки.Ключ 
		+ "_" + Строка(СтрокаВыписки.Дата) 
		+ "_" + пИНН//СтрокаВыписки.ИНН 
		+ "_" + СтрокаВыписки.НомерДокумента 
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_-" + Строка(СтрокаВыписки.СуммаКт), "") 
		+ "_" + СтрокаВыписки.НазначениеПлатежа;  
		
		//СтрокаВыписки.ID_Новый = Лев(СтрокаВыписки.Дата, 10) 
		//+ "_" + СтрокаВыписки.НомерДокумента 
		//+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		//+ ?(НЕ ЗначениеЗаполнено(СтрокаВыписки.СуммаДт),?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_" + Строка(СтрокаВыписки.СуммаКт), ""), "")
		//+ "_" + СтрокаВыписки.НазначениеПлатежа;
		
		СтрокаВыписки.TransactionID = СокрЛП(СтрЗаменить(СтрЗаменить(СтрокаВыписки.TransactionID, " ", ""), Символы.НПП, ""));
		СтрокаВыписки.НомерДокумента = СокрЛП(СтрЗаменить(СтрЗаменить(СтрокаВыписки.НомерДокумента, " ", ""), Символы.НПП, ""));
		
		СтрокаВыписки.ID_Новый = Лев(Строка(СтрокаВыписки.Дата), 10) 
		+ "_" + СтрокаВыписки.НомерДокумента
		//+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		+ ?(СтрокаВыписки.ТипТранзакцийБВ = "კონვერტაცია", "_", ?(НЕ ЗначениеЗаполнено(СтрокаВыписки.СуммаДт),?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_" + Строка(СтрокаВыписки.СуммаКт), ""), ""))
		+ "_" + СтрокаВыписки.НазначениеПлатежа;
		
		// Поиск ранее обработанного документа
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) И СтрДлина(СтрокаВыписки.Комментарий)>0 Тогда
			ПозицияПервогоРазлелителя = СтрНайти(СтрокаВыписки.Комментарий,"##",НаправлениеПоиска.СНачала,,1);
			ПозицияВторогоРазлелителя = СтрНайти(СтрокаВыписки.Комментарий,"##",НаправлениеПоиска.СНачала,,2);
			Если ПозицияПервогоРазлелителя>0 И ПозицияВторогоРазлелителя>0 Тогда
				СтрокаУникальныйИдентификатор = СРЕД(СтрокаВыписки.Комментарий,ПозицияПервогоРазлелителя+2,36);
				СтрокаВыписки._СсылкаНаДокумент  = ПолучитьСсылкуНаДокументПоУникальномуИдентификатору(СтрокаУникальныйИдентификатор);
			КонецЕсли;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда
			СтрокаВыписки._СсылкаНаДокумент  = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиДокументПоИД(СтрокаВыписки.ID);
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) 
				И ( 
				ЗначениеЗаполнено(СтрокаВыписки.Дата)
				И 
				ЗначениеЗаполнено(СтрокаВыписки.НомерДокумента)
				)
				Тогда
				СтрокаВыписки._СсылкаНаДокумент = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиДокументПоШаблонуДатеИНомеру(СтрокаВыписки._ШаблонЗаполнения,СтрокаВыписки.Дата,СтрокаВыписки.НомерДокумента,СтрокаВыписки.СуммаКт,СтрокаВыписки.СуммаДт);	
			КонецЕсли;
		КонецЕсли;  
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда
			СтрокаВыписки._СсылкаНаДокумент  = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиВРегистреКлючДокументаИнтернетБанка(СтрокаВыписки.ID_Новый);
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда 
			СтрокаВыписки.ДокументПроведен  = СтрокаВыписки._СсылкаНаДокумент.Проведен; 
		КонецЕсли;  
		Если ЗначениеЗаполнено(СтрокаВыписки.КодКазначейство) Тогда    
			СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.КодКазначейство);
			Если ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда 
				СтрокаВыписки.Контрагент1С = СтрокаВыписки.СчетКонтрагента1С.Владелец;
			КонецЕсли;  
		Иначе			
			Если ИскатьКонтрагента Тогда     
				Если ЗначениеЗаполнено(СокрЛП(СтрокаВыписки.ИНН)) Тогда 
					СтрокаВыписки.Контрагент1С	= НайтиКонтрагента(СтрокаВыписки.ИНН, СтрокаВыписки.Наименование);    
					СтрокаВыписки.Подотчетник1С	= Справочники.Сотрудники.ПустаяСсылка();      
				Иначе              
					СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк, "Контрагенты");
					Если ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда       
						СтрокаВыписки.Контрагент1С	= СтрокаВыписки.СчетКонтрагента1С.Владелец;    
						СтрокаВыписки.Подотчетник1С	= Справочники.Сотрудники.ПустаяСсылка();  
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли ИскатьСотрудника Тогда  
				Если ЗначениеЗаполнено(СокрЛП(СтрокаВыписки.ИНН)) Тогда 
					СтрокаВыписки.Контрагент1С	=  Справочники.Контрагенты.ПустаяСсылка();
					СтрокаВыписки.Подотчетник1С  = НайтиПодотчетника(СтрокаВыписки.ИНН);      
				Иначе              
					СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк, "Сотрудники");
					Если ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда       
						СтрокаВыписки.Контрагент1С	= Справочники.Контрагенты.ПустаяСсылка();    
						СтрокаВыписки.Подотчетник1С	= СтрокаВыписки.СчетКонтрагента1С.Владелец;  
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли ИскатьОрганизацию Тогда  
				СтрокаВыписки.СчетКонтрагента1С = НайтиСчетКазначенийстваПоНомеруСчета(СтрокаВыписки.СчетБанк, "", СтрокаВыписки.Валюта);
				//Если ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда       
				//	СтрокаВыписки.Контрагент1С	= Справочники.Контрагенты.ПустаяСсылка();    
				//	СтрокаВыписки.Подотчетник1С	= СтрокаВыписки.СчетКонтрагента1С.Владелец;  
				//КонецЕсли;
			КонецЕсли;   
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки.СчетКонтрагента1С) Тогда 
				ВладелецСчета = Неопределено;
				Если ЗначениеЗаполнено(СтрокаВыписки.Контрагент1С) Тогда     
					ВладелецСчета = СтрокаВыписки.Контрагент1С;
				ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.Подотчетник1С) Тогда //.Физлицо) Тогда       
					ВладелецСчета = СтрокаВыписки.Подотчетник1С; //.Физлицо;
				Иначе    
					ВладелецСчета = объект.Организация;
				КонецЕсли;   
				СтрокаВыписки.СчетКонтрагента1С = НайтиСчет(ВладелецСчета,СтрокаВыписки.СчетБанк);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого стрМУд Из МассивУдаления Цикл
		врТаблицаВыписки.Удалить(стрМУд);
	КонецЦикла;
	Объект.ТаблицаВыписки.Загрузить(врТаблицаВыписки);


КонецПроцедуры // ()

&НаСервере
Функция НайтиСчетКазначенийстваПоНомеруСчета(НомерСчетаКонтрагента, ТипВладелец = "", ИмяВалюты = "")
	
	СчетВозврата = Неопределено;
	
	Если НомерСчетаКонтрагента = "" ТОгда
		Возврат СчетВозврата;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ЗапросТекст = 
		"ВЫБРАТЬ
		|	БанковскиеСчета.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	ВЫРАЗИТЬ(БанковскиеСчета.НомерСчета КАК Строка(%ЧислоСимволовСчет%)) = &НомерСчета
		|	%УсловияСотрудника%
		|	%УсловияКонтрагента%
		|	%УсловияОрганизации%";
	
	Если ТипВладелец = "Сотрудники" Тогда 
		ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияСотрудника%", "И ТИПЗНАЧЕНИЯ(БанковскиеСчета.Владелец) = ТИП(Справочник.Сотрудники)"); 
	ИначеЕсли ТипВладелец = "Контрагенты" Тогда
		ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияКонтрагента%", "И ТИПЗНАЧЕНИЯ(БанковскиеСчета.Владелец) = ТИП(Справочник.Контрагенты)"); 
	Иначе
		ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияОрганизации%", "И ТИПЗНАЧЕНИЯ(БанковскиеСчета.Владелец) = ТИП(Справочник.Организации) И БанковскиеСчета.ВалютаДенежныхСредств.Наименование = &ИмяВалюты");
		//ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияКонтрагента%", "");  
	КонецЕсли;
	
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияСотрудника%", "");
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияКонтрагента%", ""); 
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "%УсловияОрганизации%", "");
	ЗапросТекст = СтрЗаменить(ЗапросТекст, "%ЧислоСимволовСчет%", СтрДлина(НомерСчетаКонтрагента));
	
	Запрос.Текст = ЗапросТекст;
	
	Запрос.УстановитьПараметр("НомерСчета", НомерСчетаКонтрагента);
	Запрос.УстановитьПараметр("ИмяВалюты", ИмяВалюты);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СчетВозврата = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат СчетВозврата; 
	

КонецФункции

&НаСервере
Процедура CARTU_ЗагрузитьНаСервере(ArrExcel,ТипОбмена)

    СтруктураКолонок = ПолучитьСтруктуруСоответствииКолонок(ТипОбмена);

	Объект.ТаблицаВыписки.Очистить();
	врТаблицаВыписки = Объект.ТаблицаВыписки.Выгрузить();
	врТаблицаВыпискиШ =  врТаблицаВыписки.Скопировать();
	Для Каждого стр Из ArrExcel[0] Цикл 
		врТаблицаВыписки.Добавить();
	КонецЦикла;
	
	Для каждого стрСтруктури Из СтруктураКолонок Цикл
		стЗначение = стрСтруктури.Значение;
		стКлюч	   = стрСтруктури.Ключ;
		Попытка
			врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],стКлюч);
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки() +  " колонка " + " стЗначение ");
		КонецПопытки;
	КонецЦикла;
	
	МассивУдаления = Новый Массив;
	Для каждого СтрокаВыписки Из врТаблицаВыписки Цикл
		Если  НЕ ЗначениеЗаполнено(СтрокаВыписки.Дата)
			Или СтрокаВыписки.Дата = "" 
			Или СтрокаВыписки.Дата = "ამონაწერი" 
			Или СтрокаВыписки.Дата = "თარიღი"	 
			Или СтрокаВыписки.Дата = "Date"	Тогда 
			МассивУдаления.Добавить(СтрокаВыписки);
			Продолжить;
		КонецЕсли;
		
		врТаблицаВыпискиШ.Очистить();
		СтрокаВыпискиШ = врТаблицаВыпискиШ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаВыпискиШ,СтрокаВыписки);
		СтрокаВыписки._ШаблонЗаполнения = СоответствоватьШаблонЗаполнения(врТаблицаВыпискиШ);
		
		пИНН = СтрЗаменить(СтрокаВыписки.ИНН, " ", "");//Паганини
		СтрокаВыписки.ID = 
		СтрокаВыписки.Ключ 
		+ "_" + Строка(СтрокаВыписки.Дата) 
		+ "_" + пИНН//СтрокаВыписки.ИНН 
		+ "_" + СтрокаВыписки.НомерДокумента 
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_-" + Строка(СтрокаВыписки.СуммаКт), "") 
		+ "_" + СтрокаВыписки.НазначениеПлатежа
		+ "_" + СтрокаВыписки.Баланс;
		// Поиск ранее обработанного документа
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) И СтрДлина(СтрокаВыписки.Комментарий)>0 Тогда
		
			ПозицияПервогоРазлелителя = СтрНайти(СтрокаВыписки.Комментарий,"##",НаправлениеПоиска.СНачала,,1);
			ПозицияВторогоРазлелителя = СтрНайти(СтрокаВыписки.Комментарий,"##",НаправлениеПоиска.СНачала,,2);
			Если ПозицияПервогоРазлелителя>0 И ПозицияВторогоРазлелителя>0 Тогда
				СтрокаУникальныйИдентификатор = СРЕД(СтрокаВыписки.Комментарий,ПозицияПервогоРазлелителя+2,36);
				СтрокаВыписки._СсылкаНаДокумент  = ПолучитьСсылкуНаДокументПоУникальномуИдентификатору(СтрокаУникальныйИдентификатор);
			КонецЕсли;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда
			СтрокаВыписки._СсылкаНаДокумент  = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиДокументПоИД(СтрокаВыписки.ID);
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) 
				И (
				ЗначениеЗаполнено(СтрокаВыписки.Дата)
				И 
				ЗначениеЗаполнено(СтрокаВыписки.НомерДокумента)
				)
				Тогда
				СтрокаВыписки._СсылкаНаДокумент = Обработки.ПомощникЗагрузкиБанковскойВыписки.НайтиДокументПоШаблонуДатеИНомеру(СтрокаВыписки._ШаблонЗаполнения,СтрокаВыписки.Дата,СтрокаВыписки.НомерДокумента,СтрокаВыписки.СуммаКт,СтрокаВыписки.СуммаДт);	
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаВыписки._СсылкаНаДокумент) Тогда 
			СтрокаВыписки.ДокументПроведен  = СтрокаВыписки._СсылкаНаДокумент.Проведен; 
		КонецЕсли;
		
		СтрокаВыписки.Контрагент1С      = НайтиКонтрагента(пИНН,СтрокаВыписки.Наименование);//СтрокаВыписки.ИНН
		СтрокаВыписки.Подотчетник1С     = НайтиПодотчетника(пИНН);							//СтрокаВыписки.ИНН
		СтрокаВыписки.СчетКонтрагента1С = НайтиСчет(СтрокаВыписки.Контрагент1С,СтрокаВыписки.СчетБанк);
		
	КонецЦикла;
	
	Для каждого стрМУд Из МассивУдаления Цикл
		врТаблицаВыписки.Удалить(стрМУд);
	КонецЦикла;
	Объект.ТаблицаВыписки.Загрузить(врТаблицаВыписки);


КонецПроцедуры // ()

&НаСервере
