&НаКлиенте
Процедура Загрузить(Команда)
	
	Оповещение	= Новый ОписаниеОповещения("ВариантЗагрузкиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.ПомощникЗагрузкиБанковскойВыписки.Форма.ФормаВариантаЗагрузки", ,ЭтотОбъект, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

&НаКлиенте
Процедура ВариантЗагрузкиЗавершение(СтруктураВыбора, Параметры) Экспорт
	
	Если СтруктураВыбора = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если СтруктураВыбора.Отмена Тогда 
		Возврат;
	КонецЕсли;
	
	ДатаНачала 		= СтруктураВыбора.ДатаНачала;
	ДатаОкончания 	= СтруктураВыбора.ДатаОкончания;     
	
	Если СтруктураВыбора.ВариантЗагрузки = 0 Тогда
		
		ЗагрузитьЧерезПодключениеКБанку();	
		
	Иначе 
		 Объект.ПутьКФайлу = СтруктураВыбора.ПутьКФайлу;
		 ЗагрузитьИзФайлаXLSНаКлиенте(Объект.ПутьКФайлу, 1);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьЧерезПодключениеКБанку()
	
	Если BOG Тогда
		
		Если НЕ ЗначениеЗаполнено(НомерСчета) Тогда 
			ТекстСообщения = НСтр("ru = 'Заполните банковский счет!'; ka = 'შეავსეთ თქვენი საბანკო ანგარიში!'; en = 'Fill out your bank account!'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);    
			Возврат;
		КонецЕсли;
		
		Токен = ИнтеграцияСБанком_НаСервере.ПолучитьТокенИзБазы("BAGAGE22"); 
		
		Если ЗначениеЗаполнено(Токен) Тогда     
			
			ИмяМетода = "api/statement/";   
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("currency", Валюта);
			ПараметрыЗапроса.Вставить("accountNumber", Сред(НомерСчета, 1, 22));
			ПараметрыЗапроса.Вставить("startDate", Строка(Формат(НачалоДня(ДатаНачала),"ДФ='yyyy-MM-dd'")));
			ПараметрыЗапроса.Вставить("endDate", Строка(Формат(КонецДня(ДатаОкончания),"ДФ='yyyy-MM-dd'")));
			
			IDИКоличествоСтрок = ВыполнитьМетодСервисаНаСервере(ИмяМетода, ПараметрыЗапроса, Токен);
			
			IDВыпискиПолучен = ЛОЖЬ;
			Если Не IDИКоличествоСтрок = Неопределено Тогда 
				IDВыписки = СтрЗаменить(IDИКоличествоСтрок.ID, ",", "");
				КоличествоСтрок  = СтрЗаменить(IDИКоличествоСтрок.Count, ",", "");
				IDВыпискиПолучен = Истина;
				НомерСтраницы = ?(Цел(КоличествоСтрок / 1000) < КоличествоСтрок / 1000, Цел(КоличествоСтрок / 1000) + 1, Цел(КоличествоСтрок / 1000));
				ПоследняяСтраница = НомерСтраницы;
			КонецЕсли;
			
			Если НомерСтраницы <> 0 И НомерСтраницы <> Неопределено ИЛИ IDВыпискиПолучен И IDИКоличествоСтрок <> Неопределено Тогда 
				ЗаполнитьТЧВыписки(Токен);		
			КонецЕсли;
			
		Иначе
			Оповещение	= Новый ОписаниеОповещения("ЗагрузкаВыпискиПослеАвторизации", ЭтотОбъект);
			ОткрытьФорму("Обработка.ИнтеграцияСБанком.Форма.ФормаАвторазации2", Новый Структура("ИзДокумента", Истина),	ЭтотОбъект, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
		
	ИначеЕсли TBC Тогда
		
		БанковскийСчетПриИзмененииНаСервере();
		
		ТекущийПользователь	= ИнтеграцияСБанком_НаСервере.АвторизованныйПользователь();
		
		ПараметрыСоединенияТБС = ИнтеграцияСБанкомTBC_КлиентСервер.ПолучитьПараметрыСоединенияТБС(ТекущийПользователь);
		
		СтруктураФильтра = Новый Структура;
		
		СтруктураФильтра.Вставить("accountNumber", Сред(НомерСчета, 1, 22));
		СтруктураФильтра.Вставить("accountCurrencyCode",Валюта);
		СтруктураФильтра.Вставить("periodFrom", НачалоДня(ДатаНачала));
		СтруктураФильтра.Вставить("periodTo", КонецДня(ДатаОкончания));
		
		СтруктураПарметровЗапросаВБанк = Новый Структура();
		СтруктураПарметровЗапросаВБанк.Вставить("ИмяМетода","GetAccountMovements");
		СтруктураПарметровЗапросаВБанк.Вставить("ФильтраЗапроса", СтруктураФильтра);
		
		Если ПараметрыСоединенияТБС.TBC_ИспользоватьСертификат Тогда
			
			ПараметрыСоединенияТБС.Nonce = "1111";
			ПолучитьБанковскуюВыпискуИзTBC(ПараметрыСоединенияТБС,СтруктураПарметровЗапросаВБанк);
			
		Иначе
			
			ДополнительныеПараметрыОповещения = Новый Структура();
			ДополнительныеПараметрыОповещения.Вставить("ПараметрыСоединенияТБС",ПараметрыСоединенияТБС);
			ДополнительныеПараметрыОповещения.Вставить("СтруктураПарметровЗапросаВБанк",СтруктураПарметровЗапросаВБанк);
			
			Подсказка = НСтр("ru = 'Интеграция с TBC: Введите пароль DigiPass'; ka = 'TBC ინტეგრაცია: შეიყვანეთ DigiPass –ის პაროლი'; en = 'TBC Integration: Enter your DigiPass password'");
			ОповещениеВводаСтроки = Новый ОписаниеОповещения("ЗавершениеВводаПароляDigiPass", ЭтотОбъект, ДополнительныеПараметрыОповещения);
			ПоказатьВводСтроки(ОповещениеВводаСтроки,,Подсказка,,ИСТИНА);
			
		КонецЕсли;
		
	ИначеЕсли ProCredit Тогда 
		БанковскийСчетПриИзмененииНаСервере();
		ТекущийПользователь	= ИнтеграцияСБанком_НаСервере.АвторизованныйПользователь();
		ПараметрыСоединенияProCredit = ИнтеграцияСБанкомProCredit_КлиентСервер.ПолучитьПараметрыСоединенияProCredit(ТекущийПользователь);     
		Токен = ИнтеграцияСБанком_НаСервере.ПолучитьТокенИзБазы("MIBGGE22");
		Если НЕ ЗначениеЗаполнено(Токен) Тогда
			СтруктураAuthToken = ИнтеграцияСБанкомProCredit_КлиентСервер.ПолучитьAuthToken(ПараметрыСоединенияProCredit);   
			Если НЕ СтруктураAuthToken.Успешно Тогда 
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = НСтр("ru = 'Ошибка авторизации AuthToken'; ka = 'AuthToken ავტორიზაციის შეცდომა'; en = 'AuthToken authorization error'"+СтруктураAuthToken.Описание+"ru = 'Ошибка авторизации AuthToken'; ka = 'AuthToken ავტორიზაციის შეცდომა'; en = 'AuthToken authorization error'"+СтруктураAuthToken.Описание+"'");
				Сообщение.Сообщить();
				Возврат;
			КонецЕсли;
			ПараметрыСоединенияProCredit.Вставить("AuthToken", СтруктураAuthToken.ВозвращаемоеЗначение);
		Иначе
			ПараметрыСоединенияProCredit.Вставить("AccessToken", Токен);
		КонецЕсли;
		СтруктураФильтра = Новый Структура;
		СтруктураФильтра.Вставить("accountNumber", Сред(НомерСчета, 1, 22));
		СтруктураФильтра.Вставить("accountCurrencyCode",Валюта);
		СтруктураФильтра.Вставить("periodFrom", НачалоДня(ДатаНачала));
		СтруктураФильтра.Вставить("periodTo", КонецДня(ДатаОкончания));
		СтруктураПарметровЗапросаВБанк = Новый Структура();
		СтруктураПарметровЗапросаВБанк.Вставить("ИмяМетода","GetAccountStatment"); 
		СтруктураПарметровЗапросаВБанк.Вставить("ИмяСервиса","/api/Statement/GetStatement");
		СтруктураПарметровЗапросаВБанк.Вставить("ФильтраЗапроса", СтруктураФильтра);
		ДополнительныеПараметрыОповещения = Новый Структура();
		ДополнительныеПараметрыОповещения.Вставить("ПараметрыСоединенияProCredit",ПараметрыСоединенияProCredit);
		ДополнительныеПараметрыОповещения.Вставить("СтруктураПарметровЗапросаВБанк",СтруктураПарметровЗапросаВБанк);
		Если ЗначениеЗаполнено(Токен) Тогда  
			ИнтеграцияСБанкомProCredit_КлиентСервер.ВыполнитьЗапросВБанк(ПараметрыСоединенияProCredit, СтруктураПарметровЗапросаВБанк);
			ОбработатьРезультатыПолученияБанковскойВыпискиИзProCredit(СтруктураПарметровЗапросаВБанк);
		Иначе     
			Подсказка = НСтр("ru = 'Интеграция с ProCredit: Введите пароль OTP'; ka = 'ProCredit ინტეგრაცია: შეიყვანეთ OTP –ის პაროლი'; en = 'Integration with ProCredit: Enter OTP password'");
			ОповещениеВводаСтроки = Новый ОписаниеОповещения("ЗавершениеВводаПароляOTP", ЭтотОбъект, ДополнительныеПараметрыОповещения);
			ПоказатьВводСтроки(ОповещениеВводаСтроки,,Подсказка,,ИСТИНА);
		КонецЕсли;    
		
	КонецЕсли;
	
	
КонецПроцедуры // ЗагрузитьИзТаблицы()


&НаСервере
Функция ВыполнитьМетодСервисаНаСервере(ИмяМетода, ПараметрыЗапроса, Токен)
	
	ТестовыйРежим = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"ИспользоватьТестовыйРежимBOG");
	
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;
	
	Возврат МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, ПараметрыЗапроса, , Токен, НЕ ТестовыйРежим); 
	
КонецФункции

&НаКлиенте
Процедура ЗагрузкаВыпискиПослеАвторизации(Токен, Параметры) Экспорт
	
	Если Токен = КодВозвратаДиалога.Отмена Тогда 
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Токен) Тогда

		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("currency", Валюта);
		ПараметрыЗапроса.Вставить("accountNumber", Сред(НомерСчета, 1, 22));
		ПараметрыЗапроса.Вставить("startDate", Строка(Формат(НачалоДня(ДатаНачала),"ДФ='yyyy-MM-dd'")));
		ПараметрыЗапроса.Вставить("endDate", Строка(Формат(КонецДня(ДатаОкончания),"ДФ='yyyy-MM-dd'")));
		
		IDИКоличествоСтрок = Неопределено;
		ОтправитьНаСервере(ПараметрыЗапроса, Токен, IDИКоличествоСтрок);
		
		IDВыпискиПолучен = ЛОЖЬ;
		Если Не IDИКоличествоСтрок = Неопределено Тогда 
			IDВыписки = СтрЗаменить(IDИКоличествоСтрок.ID, ",", "");
			КоличествоСтрок  = СтрЗаменить(IDИКоличествоСтрок.Count, ",", "");
			IDВыпискиПолучен = Истина;
			НомерСтраницы = ?(Цел(КоличествоСтрок / 1000) < КоличествоСтрок / 1000, Цел(КоличествоСтрок / 1000) + 1, Цел(КоличествоСтрок / 1000));
			ПоследняяСтраница = НомерСтраницы;
		КонецЕсли;
		
		Если НомерСтраницы <> 0 И НомерСтраницы <> Неопределено ИЛИ IDВыпискиПолучен И IDИКоличествоСтрок <> Неопределено Тогда 
			ЗаполнитьТЧВыписки(Токен);		
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьТЧВыписки(Токен)	
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("currency", Валюта);
	ПараметрыЗапроса.Вставить("accountNumber", Сред(НомерСчета, 1, 22));
	ПараметрыЗапроса.Вставить("id", IDВыписки);
	ПараметрыЗапроса.Вставить("page", НомерСтраницы);
	
	МассивЗаписей = МенеджерОбработки.ВыполнитьМетодСервиса("api/statement////", ПараметрыЗапроса, 0, Токен, Истина);
	
	Объект.ТаблицаВыписки.Очистить();
	
	Объект.ТаблицаВыписки.Очистить();
	врТаблицаВыписки = Объект.ТаблицаВыписки.Выгрузить();
	врТаблицаВыпискиШ =  врТаблицаВыписки.Скопировать();
    МассивУдаления = Новый Массив;
	
	Если Не МассивЗаписей = Неопределено Тогда 
		Если МассивЗаписей.Количество() > 0 Тогда 
			
			Для Каждого ЭлементМассива ИЗ МассивЗаписей Цикл
				
				НоваяСтрокаТЧ = Объект.ТаблицаВыписки.Добавить();
				
				Если НЕ ЭлементМассива.Получить("EntryAmountDebit") = 0 Тогда  
					НоваяСтрокаТЧ.Наименование                    	= ЭлементМассива.Получить("BeneficiaryDetails").Получить("Name");
					НоваяСтрокаТЧ.СчетБанк           				= ЭлементМассива.Получить("BeneficiaryDetails").Получить("AccountNumber");
					НоваяСтрокаТЧ.ИНН                     			= ЭлементМассива.Получить("BeneficiaryDetails").Получить("Inn");       
				ИначеЕсли НЕ ЭлементМассива.Получить("EntryAmountCredit") = 0 Тогда
					НоваяСтрокаТЧ.Наименование                    	= ЭлементМассива.Получить("SenderDetails").Получить("Name");
					НоваяСтрокаТЧ.СчетБанк           				= ЭлементМассива.Получить("SenderDetails").Получить("AccountNumber");
					НоваяСтрокаТЧ.ИНН                     			= ЭлементМассива.Получить("SenderDetails").Получить("Inn"); 
				КонецЕсли;
				
				НоваяСтрокаТЧ.Комментарий                		= ЭлементМассива.Получить("DocumentInformation");
				НоваяСтрокаТЧ.НазначениеПлатежа                 = ЭлементМассива.Получить("DocumentNomination"); 
				НоваяСтрокаТЧ.ТипТранзакцийБВ               	= ЭлементМассива.Получить("DocumentProductGroup");
				НоваяСтрокаТЧ.ТипОперации               		= ЭлементМассива.Получить("DocumentProductGroup");
				НоваяСтрокаТЧ.КодКазначейство               	= ЭлементМассива.Получить("DocumentTreasuryCode");
				НоваяСтрокаТЧ.СуммаКт                  			= ЭлементМассива.Получить("EntryAmountCredit");
				НоваяСтрокаТЧ.СуммаДт				     		= ЭлементМассива.Получить("EntryAmountDebit");
				НоваяСтрокаТЧ.Дата                         		= ПереводВДату(ЭлементМассива.Получить("EntryDate"));
				НоваяСтрокаТЧ.НомерДокумента                	= ЭлементМассива.Получить("EntryDocumentNumber");
				НоваяСтрокаТЧ.ID			                 	= ЭлементМассива.Получить("EntryId"); 
				НоваяСтрокаТЧ.ДополнительноеЗначение           	= ЭлементМассива.Получить("EntryComment");
				НоваяСтрокаТЧ.Валюта           					= ЭлементМассива.Получить("DocumentSourceCurrency"); //+++ Дмгг, 11.04.2025, ONESOFT-3973
				
				Если ЗначениеЗаполнено(НоваяСтрокаТЧ.СуммаДт) Тогда 
					НоваяСтрокаТЧ.НаименованиеДт = НоваяСтрокаТЧ.Наименование;
					НоваяСтрокаТЧ.ИННДт = НоваяСтрокаТЧ.ИНН;
					НоваяСтрокаТЧ.СчетБанкДт = НоваяСтрокаТЧ.СчетБанк;
				ИначеЕсли ЗначениеЗаполнено(НоваяСтрокаТЧ.СуммаКт) Тогда 
					НоваяСтрокаТЧ.НаименованиеКт = НоваяСтрокаТЧ.Наименование;
					НоваяСтрокаТЧ.ИННКт = НоваяСтрокаТЧ.ИНН;
					НоваяСтрокаТЧ.СчетБанкКт = НоваяСтрокаТЧ.СчетБанк;
				КонецЕсли; 
				
				Если НоваяСтрокаТЧ.Дата = "" 
					Или Не ЗначениеЗаполнено(НоваяСтрокаТЧ.Дата) 
					Или НоваяСтрокаТЧ.Дата = "ამონაწერი" 
					Или НоваяСтрокаТЧ.Дата = "თარიღი"	Тогда 
