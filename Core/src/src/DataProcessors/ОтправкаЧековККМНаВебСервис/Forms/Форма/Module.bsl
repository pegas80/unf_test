
&НаСервере
Процедура ВыполнитьОтправкуНаСервере(СсылкаНастроекКассыККМ, ЧекККМ)
	     
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Результат = ОбработкаОбъект.ОтправитьPOST;
	
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
	Если Результат.КодСостояния = 200 Тогда 
		Сообщить("Данные отправлены успешно!!!");
	Иначе
		Сообщить("Код ошибки: " + Результат.КодСостояния);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОтправку(Команда)
	
	СсылкаНастроекКассыККМ = ПолучитьСсылкуНастроекДляКассыККМ(ЧекККМ);
	ВыполнитьОтправкуНаСервере(СсылкаНастроекКассыККМ, ЧекККМ);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСсылкуНастроекДляКассыККМ(ЧекККМ)
	
	РезультатВозрата = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастрайкиВебСервисовДляКассККМ.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.НастрайкиВебСервисовДляКассККМ КАК НастрайкиВебСервисовДляКассККМ
		|ГДЕ
		|	НастрайкиВебСервисовДляКассККМ.Владелец = &КассаККМ";
	
	Запрос.УстановитьПараметр("КассаККМ", ЧекККМ.КассаККМ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РезультатВозрата = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат РезультатВозрата;
	
КонецФункции