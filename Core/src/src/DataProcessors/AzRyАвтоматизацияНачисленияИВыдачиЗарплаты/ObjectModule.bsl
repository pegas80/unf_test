Процедура ОчиститьНачисленияСотрудникам(Дата1, Дата2, Организация, СтруктурнаяЕдиница, ВидНачисленияУдержания) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НачислениеЗарплатыНачисленияУдержания.Ссылка,
		|	НачислениеЗарплатыНачисленияУдержания.Сотрудник,
		|	НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания
		|ПОМЕСТИТЬ ТЗ
		|ИЗ
		|	Документ.НачислениеЗарплаты.НачисленияУдержания КАК НачислениеЗарплатыНачисленияУдержания
		|ГДЕ
		|	НачислениеЗарплатыНачисленияУдержания.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
		|	И НачислениеЗарплатыНачисленияУдержания.Ссылка.Организация = &Организация
		|	И НачислениеЗарплатыНачисленияУдержания.Ссылка.СтруктурнаяЕдиница В(&СтруктурнаяЕдиница)
		|	И НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания В(&ВидНачисленияУдержания)
		|	И НачислениеЗарплатыНачисленияУдержания.Сотрудник В(&Сотрудник)
		|	И НачислениеЗарплатыНачисленияУдержания.Ссылка.Проведен
		|	И НачислениеЗарплатыНачисленияУдержания.Ссылка.AzRyТипСозданияДокумента = &AzRyТипСозданияДокумента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлатежнаяВедомость.Ссылка
		|ПОМЕСТИТЬ ПлатежнаяВедомость_Темп
		|ИЗ
		|	Документ.ПлатежнаяВедомость КАК ПлатежнаяВедомость
		|ГДЕ
		|	ПлатежнаяВедомость.Ссылка В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ТЗ.Ссылка
		|			ИЗ
		|				ТЗ КАК ТЗ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗ.Ссылка,
		|	ТЗ.Сотрудник,
		|	ТЗ.ВидНачисленияУдержания
		|ИЗ
		|	ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПлатежнаяВедомость_Темп.Ссылка
		|ИЗ
		|	ПлатежнаяВедомость_Темп КАК ПлатежнаяВедомость_Темп
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходСоСчета.Ссылка
		|ИЗ
		|	Документ.РасходСоСчета КАК РасходСоСчета
		|ГДЕ
		|	РасходСоСчета.Ссылка В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ТЗ.Ссылка
		|			ИЗ
		|				ПлатежнаяВедомость_Темп КАК ТЗ)";
	
	Запрос.УстановитьПараметр("ВидНачисленияУдержания", ВидНачисленияУдержания.ВыгрузитьКолонку("ВидНачисленияУдержания"));
	Запрос.УстановитьПараметр("Дата1", Дата1);
	Запрос.УстановитьПараметр("Дата2", Дата2);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Сотрудник", ВидНачисленияУдержания.ВыгрузитьКолонку("Сотрудник"));
	Запрос.УстановитьПараметр("AzRyТипСозданияДокумента", Перечисления.AzRyТипСозданияДокумента.Jira);
	
	ТЗПакет = Запрос.ВыполнитьПакет();
	ТЗ  = ТЗПакет[2].Выгрузить();
	ТЗ2 = ТЗПакет[3].Выгрузить();
	ТЗ3 = ТЗПакет[4].Выгрузить();
	
	ТЗДокументы      = ТЗ.Скопировать();
	ТЗСотрудники     = ТЗ.Скопировать();
	ТЗВидыНачисления = ТЗ.Скопировать();

	ТЗДокументы.Свернуть("Ссылка");
	ТЗСотрудники.Свернуть("Сотрудник");
	ТЗВидыНачисления.Свернуть("ВидНачисленияУдержания");
	МассивВидНачисленияУдержания = ТЗВидыНачисления.ВыгрузитьКолонку("ВидНачисленияУдержания");
	
	Для каждого ТекДок Из ТЗДокументы Цикл
		УдНачисление = Новый Массив;
		УдНалог      = Новый Массив;
		Док = ТекДок.Ссылка.ПолучитьОбъект();
		
		Для каждого ТекСотрудник Из ТЗСотрудники Цикл
			
			Отбор = Новый Структура();
			Отбор.Вставить("Сотрудник", ТекСотрудник.Сотрудник);
			
			СтрокиНачисления = Док.НачисленияУдержания.НайтиСтроки(Отбор);
			СтрокиНалог      = Док.НалогиНаДоходы.НайтиСтроки(Отбор);
			
			Для каждого ТекСтрока Из СтрокиНачисления Цикл
				Если Не МассивВидНачисленияУдержания.Найти(ТекСтрока.ВидНачисленияУдержания) = Неопределено Тогда
					УдНачисление.Добавить(ТекСтрока);	
				КонецЕсли; 			
			КонецЦикла;
			
			Для каждого ТекСтрока Из СтрокиНалог Цикл
				УдНалог.Добавить(ТекСтрока);	
			КонецЦикла;
		КонецЦикла;
		
		Для каждого УдНач Из УдНачисление Цикл
			Док.НачисленияУдержания.Удалить(УдНач);	
		КонецЦикла;
		
		Для каждого УдНалг Из УдНалог Цикл
			Док.НалогиНаДоходы.Удалить(УдНалг);	
		КонецЦикла;
		
		Док.Записать(РежимЗаписиДокумента.Проведение);
		
		Если Док.НачисленияУдержания.Количество() = 0 Тогда
			Док.УстановитьПометкуУдаления(Истина);
		КонецЕсли; 		
	КонецЦикла;
	
	//Для каждого ТекСтрока Из ТЗ2 Цикл
	//	Объ = ТекСтрока.Ссылка.ПолучитьОбъект();
	//	Объ.УстановитьПометкуУдаления(Истина);
	//	Объ.Записать(РежимЗаписиДокумента.Запись);
	//КонецЦикла;
	//
	//Для каждого ТекСтрока Из ТЗ3 Цикл
	//	Объ = ТекСтрока.Ссылка.ПолучитьОбъект();
	//	Объ.УстановитьПометкуУдаления(Истина);
	//	Объ.Записать(РежимЗаписиДокумента.Запись);
	//КонецЦикла;
		
КонецПроцедуры

