// ПРОЦЕДУРЫ И ФУНКЦИИ ОБЩЕГО НАЗНАЧЕНИЯ

Функция ВычислитьЗарплатуПоНачислениям(Организация, ТЗАктивныеСотрудники, ДатаДокумента, МассивНачисленииИУдержаний, МассивНалог, ТЗНДФЛ = Неопределено) Экспорт
	
	ТаблицаНачисленияИУдержания = ПустаяТаблицаНачисленияУдержания();
	ТЗДляОбработкиНалог         = ПустаяТаблицаНалог();
	
	СотрудникиМассив = СотрудникиМассивПоОтбору(ТЗАктивныеСотрудники.ВыгрузитьКолонку("Сотрудник"), ПараметрыДокументов);
	ТЗНачисленийИУдержаний = ТаблицаНачисленийИУдержаний(МассивНачисленииИУдержаний, ПараметрыДокументов, СотрудникиМассив, Организация, ТЗАктивныеСотрудники); // Таблица начислений и удержаний
	ТЗНДФЛ = ТаблицаНалогов(МассивНалог, Организация, ПараметрыДокументов, СотрудникиМассив); // Таблица налогов	
	// ხელფასების გამოთვლა დინამიურად იმ შემთხვევაში თუ მოხდა შუათვეში მიღება, გადაადგილება ან განთავისუფლება
	ДинамическиВычисляемыеЗарплаты = ДинамическоеВычислениеЗарплат(ТЗНачисленийИУдержаний, МассивНачисленииИУдержаний, Организация, ПараметрыДокументов);
	
	// Соответствие: Сотрудник - Тариф
	ТарифПоСотруднику = СоответствиеТарифнаяСтавка(ТЗНачисленийИУдержаний, ПараметрыДокументов.ОбъектНачисленияЗарплаты);
	
	// საპენსიოს გამოთვლა
	Для каждого ТекСтрока Из ТЗНачисленийИУдержаний Цикл
		Если ТарифПоСотруднику[ТекСтрока.Сотрудник] = Неопределено Тогда
			Продолжить;		
		КонецЕсли;
		// დაგროვებითი საპენსიოს გამოთვლა - СуммаПФ - ის ველის შევსება
		ПенсияВычислить(ТекСтрока, ТекСтрока.ВидНачисленияУдержания, ТарифПоСотруднику[ТекСтрока.Сотрудник]);
	КонецЦикла;	
	
	// დარიცხვა/დაკავებების ცხრილის შევსება
	Для каждого ТекСтрока Из ТЗНачисленийИУдержаний Цикл		
		Если ТарифПоСотруднику[ТекСтрока.Сотрудник] = Неопределено Тогда
			Продолжить;		
		КонецЕсли; 
		
		НоваяСтрока = ТаблицаНачисленияИУдержания.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		
		// დაგროვებითი საპენსიოს გამოთვლა
		//ПенсияЗначение = ПенсияВычислить(ТекСтрока, ТекСтрока.ВидНачисленияУдержания, ТарифПоСотруднику[ТекСтрока.Сотрудник]);
		//НоваяСтрока.Сумма   = ?(ПенсияЗначение = 0, НоваяСтрока.Сумма, ПенсияЗначение);
		//НоваяСтрока.Сумма   = ?(ТекСтрока.СуммаПФ = 0, НоваяСтрока.Сумма, ТекСтрока.СуммаПФ);	
		
		//Если ПараметрыДокументов.ВидНачисления = "I_Половина" Или ПараметрыДокументов.ВидНачисления = "II_Половина" Тогда			                           
		//	НоваяСтрокаНачисленияУдержания.Сумма = НоваяСтрокаНачисленияУдержания.Сумма / 2;
		//КонецЕсли;
		
		// საპენსიოს ჩანაწერების გადავსება
		Если ТекСтрока.ВидНачисленияУдержания = Справочники.AzRyНастройки.НачислениеПенсия.Значение Или ТекСтрока.ВидНачисленияУдержания = Справочники.AzRyНастройки.УдержаниеПенсия.Значение Тогда
			Если ТекСтрока.Актуальность Тогда
				ТекСтрока.Сумма     = ТарифПоСотруднику[ТекСтрока.Сотрудник].СуммаПФ;
				НоваяСтрока.Сумма   = ТарифПоСотруднику[ТекСтрока.Сотрудник].СуммаПФ;
			КонецЕсли; 
		КонецЕсли;		
		
		Если ДинамическиВычисляемыеЗарплаты <> Неопределено И ДинамическиВычисляемыеЗарплаты.Получить(ТекСтрока.Сотрудник) = Неопределено Тогда
			Если ПараметрыДокументов.ВидНачисления = "I_Половина" Или ПараметрыДокументов.ВидНачисления = "II_Половина" Тогда			                           
				НоваяСтрока.Сумма   = НоваяСтрока.Сумма / 2;
				НоваяСтрока.СуммаПФ = НоваяСтрока.СуммаПФ / 2;
			КонецЕсли;	
		КонецЕсли;
		
		НоваяСтрока.НаправлениеДеятельности = ПараметрыДокументов.НаправленияДеятельности;
		НоваяСтрока.ЗаказПокупателя         = ПараметрыДокументов.ЗаказПокупателя;
		НоваяСтрока.Проект                  = ПараметрыДокументов.Проект;
		//НоваяСтрока.СуммаПФ                 = ТекСтрока.СуммаПФ;
	КонецЦикла;
	
	// საშემოსავლოს ცხრილის შევსება
	Для каждого ТекСтрока2 Из ТаблицаНачисленияИУдержания Цикл
		
		Если ТекСтрока2.ВидНачисленияУдержания.Тип = Перечисления.ТипыНачисленийИУдержаний.Удержание Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор = Новый Структура();
		Отбор.Вставить("Сотрудник", ТекСтрока2.Сотрудник);
		Строки = ТЗНДФЛ.НайтиСтроки(Отбор);
		
		Если Не Строки.Количество() = 0 Тогда 
			
			Для каждого ТекСтроки Из Строки Цикл
				
				СуммаПенсия = 0;
				Если ТекСтрока2.ВидНачисленияУдержания = ПараметрыДокументов.ОбъектНачисленияЗарплаты Тогда
					СуммаПенсия = СуммаПенсия(ТекСтрока2.Сотрудник, ТаблицаНачисленияИУдержания);
					//ТекСтрока2.СуммаПФ = ТарифПоСотруднику[ТекСтрока.Сотрудник].СуммаПФ;
				КонецЕсли;
				
				НоваяСтрокаНалог = ТЗДляОбработкиНалог.Добавить();
				НоваяСтрокаНалог.Сотрудник = ТекСтроки.Сотрудник;
				НоваяСтрокаНалог.Налог     = ТекСтроки.ВидНачисленияУдержания;
				НоваяСтрокаНалог.Тип       = ТекСтроки.Тип;
				Если ТекСтрока2.ВидНачисленияУдержания = Справочники.AzRyНастройки.НачислениеПенсия.Значение Тогда 
					НоваяСтрокаНалог.Сумма = 0;
				Иначе 
					НоваяСтрокаНалог.Сумма = (ТекСтрока2.Сумма - СуммаПенсия) * ТекСтроки.ВидНачисленияУдержания.СтавкаНДФЛ/100;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
							 
	//Возврат СтруктураТЗ;
	Возврат ТаблицыВСтруктуру(ТаблицаНачисленияИУдержания, ФилтрТаблицыСотрудников2(ТЗДляОбработкиНалог, "Сумма", 0), ЭтотОбъект.ИсторияСотрудника.Выгрузить());
	                                                                                                  
КонецФункции

Функция ТаблицыВСтруктуру(НачисленияУдержания, Налог, ИсторияЗарплаты) Экспорт
	
	Стр = Новый Структура;
	Стр.Вставить("НачисленияУдержания", НачисленияУдержания); 
	Стр.Вставить("Налог", Налог);
	Стр.Вставить("ИсторияЗарплаты", ИсторияЗарплаты); 
	
	Возврат Стр;	
	
КонецФункции
 
// Пойск документа начислений
Процедура ПойскДокументаИПометкаУдаления(Параметры, Организация, Подразделение, ТипЗаписи)
		
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	AzRyАвтоматизацияНачисленийЗарплаты.Период,
	               |	AzRyАвтоматизацияНачисленийЗарплаты.Организация,
	               |	AzRyАвтоматизацияНачисленийЗарплаты.СтруктурныеЕдиница,
	               |	AzRyАвтоматизацияНачисленийЗарплаты.Документы,
	               |	AzRyАвтоматизацияНачисленийЗарплаты.AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты
	               |ИЗ
	               |	РегистрСведений.AzRyАвтоматизацияНачисленийЗарплаты КАК AzRyАвтоматизацияНачисленийЗарплаты
	               |ГДЕ
	               |	AzRyАвтоматизацияНачисленийЗарплаты.Период = &Период
	               |	И AzRyАвтоматизацияНачисленийЗарплаты.Организация = &Организация
	               |	И AzRyАвтоматизацияНачисленийЗарплаты.СтруктурныеЕдиница = &СтруктурныеЕдиница
	               |	И AzRyАвтоматизацияНачисленийЗарплаты.AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты = &AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты";
	
	Запрос.УстановитьПараметр("Период", Параметры.ПериодРегистраций);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтруктурныеЕдиница", Подразделение);
	Запрос.УстановитьПараметр("AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты", ТипЗаписи);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Не Результат.Количество() = 0 Тогда  
		Для каждого ТекДок Из Результат Цикл
			НДО = ТекДок.Документы.ПолучитьОбъект();
			НДО.УстановитьПометкуУдаления(Истина);
			НДО.Записать();
		КонецЦикла;
	КонецЕсли;
		
КонецПроцедуры

