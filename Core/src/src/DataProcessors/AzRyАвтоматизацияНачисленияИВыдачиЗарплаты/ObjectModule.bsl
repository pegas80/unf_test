Функция ТаблицыПоПодразделениям(ТЗ) Экспорт

	Ответ = Новый Соответствие;
	
	ТЗПодраздления = ТЗ.Скопировать();
	ТЗПодраздления.Свернуть("СтруктурнаяЕдиница");
	
	Для каждого ТекСтрока Из ТЗПодраздления Цикл
		
		Отбор = Новый Структура();
		Отбор.Вставить("СтруктурнаяЕдиница", ТекСтрока.СтруктурнаяЕдиница);
		Строки = ТЗ.НайтиСтроки(Отбор);
		
		ПустаяТаблица = ТЗ.СкопироватьКолонки();
		Для каждого ТекМассив Из Строки Цикл
			НоваяСтрока = ПустаяТаблица.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекМассив); 
		КонецЦикла;
		
		Ответ.Вставить(ТекСтрока.СтруктурнаяЕдиница, ПустаяТаблица);	
	КонецЦикла;
	
	Возврат Ответ;

КонецФункции
 

