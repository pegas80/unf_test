Функция ДинамическоеВычислениеЗарплат(ТЗДанные, МассивНачисленииИУдержаний, Организация, Параметры)
	
	ИсторияСотрудника.Очистить();
	
	Если Параметры.ВидНачисления = "I_Половина" Тогда	
		Период1 = НачалоМесяца(Параметры.ПериодРегистраций);
		Период2 = КонецДня(Дата(Год(Параметры.ПериодРегистраций), Месяц(Параметры.ПериодРегистраций), 15));
	ИначеЕсли Параметры.ВидНачисления = "II_Половина" Тогда
		Период1 = НачалоДня(Дата(Год(Параметры.ПериодРегистраций), Месяц(Параметры.ПериодРегистраций), 16));
		Период2 = КонецМесяца(Параметры.ПериодРегистраций);		
	ИначеЕсли Параметры.ВидНачисления = "Зарплата" Тогда	
		Период1 = НачалоМесяца(Параметры.ПериодРегистраций);
		Период2 = КонецМесяца(Параметры.ПериодРегистраций);
	КонецЕсли;
	
	Параметры.Вставить("Период1", Период1);
	Параметры.Вставить("Период2", Период2);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВложенныйЗапрос.Период,
		|	ВложенныйЗапрос.Регистратор,
		|	ВложенныйЗапрос.НомерСтроки,
		|	ВложенныйЗапрос.Активность,
		|	ВложенныйЗапрос.Организация,
		|	ВложенныйЗапрос.Сотрудник,
		|	ВложенныйЗапрос.ВидНачисленияУдержания,
		|	ВложенныйЗапрос.Валюта,
		|	ВложенныйЗапрос.Сумма,
		|	ВложенныйЗапрос.СчетЗатратРегл,
		|	ВложенныйЗапрос.Актуальность
		|ИЗ
		|	(ВЫБРАТЬ
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Период КАК Период,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Регистратор КАК Регистратор,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.НомерСтроки КАК НомерСтроки,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Активность КАК Активность,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Организация КАК Организация,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник КАК Сотрудник,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Валюта КАК Валюта,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Сумма КАК Сумма,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.СчетЗатратРегл КАК СчетЗатратРегл,
		|		ПлановыеНачисленияИУдержанияСрезПоследних.Актуальность КАК Актуальность
		|	ИЗ
		|		РегистрСведений.ПлановыеНачисленияИУдержания.СрезПоследних(&Период1, ) КАК ПлановыеНачисленияИУдержанияСрезПоследних
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ПлановыеНачисленияИУдержания.Период,
		|		ПлановыеНачисленияИУдержания.Регистратор,
		|		ПлановыеНачисленияИУдержания.НомерСтроки,
		|		ПлановыеНачисленияИУдержания.Активность,
		|		ПлановыеНачисленияИУдержания.Организация,
		|		ПлановыеНачисленияИУдержания.Сотрудник,
		|		ПлановыеНачисленияИУдержания.ВидНачисленияУдержания,
		|		ПлановыеНачисленияИУдержания.Валюта,
		|		ПлановыеНачисленияИУдержания.Сумма,
		|		ПлановыеНачисленияИУдержания.СчетЗатратРегл,
		|		ПлановыеНачисленияИУдержания.Актуальность
		|	ИЗ
		|		РегистрСведений.ПлановыеНачисленияИУдержания КАК ПлановыеНачисленияИУдержания
		|	ГДЕ
		|		ПлановыеНачисленияИУдержания.Период МЕЖДУ &Период1 И &Период2) КАК ВложенныйЗапрос
		|ГДЕ
		|	ВложенныйЗапрос.Организация = &Организация
		|	И ВложенныйЗапрос.ВидНачисленияУдержания В(&ВидНачисленияУдержания)
		|	И ВложенныйЗапрос.ВидНачисленияУдержания.Тип <> &Тип
		|	И ВложенныйЗапрос.Сотрудник В(&Сотрудник)";
	
	Запрос.УстановитьПараметр("ВидНачисленияУдержания", Параметры.ОбъектНачисленияЗарплаты);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Период1", Период1);
	Запрос.УстановитьПараметр("Период2", Период2);
	Запрос.УстановитьПараметр("Сотрудник", ТЗДанные.ВыгрузитьКолонку("Сотрудник"));
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыНачисленийИУдержаний.Налог);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();		

	ТЗСотрудники = ТЗДанные.Скопировать();
	ТЗСотрудники.Свернуть("Сотрудник");
	
	Соот = Новый Соответствие;
	Для каждого ТекСтрока Из ТЗСотрудники Цикл		
		Отбор = Новый Структура("Сотрудник", ТекСтрока.Сотрудник);
		Строки = РезультатЗапроса.НайтиСтроки(Отбор);	
		
		Если Строки.Количество() = 1 И ТипЗнч(Строки[0].Регистратор) = Тип("ДокументСсылка.ПриемНаРаботу") И Строки[0].Период > НачалоМесяца(Параметры.ПериодРегистраций) Тогда
			ЗарплатаСотрудника = РасчетЗарплаты(Строки, Параметры);
			Соот.Вставить(ТекСтрока.Сотрудник, ЗарплатаСотрудника);			
		ИначеЕсли Строки.Количество() > 1 Тогда				
			ЗарплатаСотрудника = РасчетЗарплаты(Строки, Параметры);
			Соот.Вставить(ТекСтрока.Сотрудник, ЗарплатаСотрудника); 	
		КонецЕсли; 
	КонецЦикла;
	
	// დინამიურად გამოთვლილი თანხების ჩანაცვლება ძირითად ცხრილში
	Для каждого ТекЗначение Из Соот Цикл
		Отбор = Новый Структура;
		Отбор.Вставить("Сотрудник", ТекЗначение.Ключ);
		//Отбор.Вставить("ВидНачисленияУдержания", Справочники.AzRyНастройки.НачислениеТарифнаяСтавка.Значение);
		Отбор.Вставить("ВидНачисленияУдержания", Параметры.ОбъектНачисленияЗарплаты);
		//тз = Новый ТаблицаЗначений;
		Строки = ТЗДанные.НайтиСтроки(Отбор);
		Если Строки.Количество() > 0 Тогда
			Строки[0].Сумма = ТекЗначение.Значение;		
		КонецЕсли; 
	КонецЦикла;
	
	Возврат Соот;
	
КонецФункции

Функция ТаблицаНалогов(МассивНалог, Организация, Параметры, СотрудникиМассив)

	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ
