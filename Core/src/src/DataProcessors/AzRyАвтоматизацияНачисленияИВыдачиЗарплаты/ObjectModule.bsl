Функция РасчетЗарплаты(Массив, Параметры)

	Если Не Массив[Массив.Количество()-1].Период = КонецДня(Параметры.ПериодРегистраций) Тогда
		СтрДата = Новый Структура;
		Для каждого ТекКолонка Из Массив[Массив.Количество()-1].Владелец().Колонки Цикл
			СтрДата.Вставить(ТекКолонка.Заголовок, "");			
		КонецЦикла;
		
		ЗаполнитьЗначенияСвойств(СтрДата, Массив[Массив.Количество()-1]);
		
		//Если Параметры.ВидНачисления = "I_Половина" Тогда	
		//	СтрДата.Период = КонецДня(Параметры.ПериодРегистраций);	
		//ИначеЕсли Параметры.ВидНачисления = "II_Половина" Тогда
		//	СтрДата.Период = КонецМесяца(Параметры.ПериодРегистраций);	
		//ИначеЕсли Параметры.ВидНачисления = "Зарплата" Тогда	
		//	СтрДата.Период = КонецДня(Параметры.ПериодРегистраций);	
		//КонецЕсли;
		
		СтрДата.Период = КонецДня(Параметры.ПериодРегистраций);
		СтрДата.Сумма = 0;
		
		Массив.Добавить(СтрДата);
	КонецЕсли;
	
	Ответ = ДанныеРабочихЧасов(Параметры.ПериодРегистраций);
	
	Н = 0;
	Сумма = 0;
	ПериодНачало = Неопределено;
	СтрЗарплата = 0;
	Для каждого ТекСтрока Из Массив Цикл
		
		// თუ ხელფასი ერთი და იგივეა ესეიგი ხელფასი არ გაიზარდა, მხოლოდ საკადრო გადაადგილება მოხდა ან განთავისუფლება
		Если СтрЗарплата = ТекСтрока.Сумма Тогда Продолжить; КонецЕсли;
		
		Если Н <> 0 Тогда
			
			Если Н = Массив.Количество()-1 Тогда
				Часов = 0;
			Иначе 
				Часов = (60*60*24);
			КонецЕсли; 
			
			КРД = AzRyFunctions.КоличествоРабочихДнейВМесяце(Год(Параметры.ПериодРегистраций), НачалоДня(ПериодНачало), КонецДня(ТекСтрока.Период - Часов));
			Сумма = Сумма + СтрЗарплата / Ответ.КРДВ * КРД;
			
			НоваяСтрока = ЭтотОбъект.ИсторияСотрудника.Добавить();
			НоваяСтрока.Сотрудник = ТекСтрока.Сотрудник;
			НоваяСтрока.Дата1 = НачалоДня(ПериодНачало);
			НоваяСтрока.Дата2 =  КонецДня(ТекСтрока.Период - Часов);
			НоваяСтрока.КоличествоРабДнейМесяца = Ответ.КРДВ;
			НоваяСтрока.КоличествоРабДней       = КРД;
			НоваяСтрока.Зарплата     = СтрЗарплата;
			НоваяСтрока.Зарплата2    = СтрЗарплата / Ответ.КРДВ * КРД;
			НоваяСтрока.ЗарплатаЗаОдинДень      = ?(НоваяСтрока.Зарплата2 = 0, 0, НоваяСтрока.Зарплата2 / КРД);
			НоваяСтрока.ЗарплатаИтог = Сумма;
		КонецЕсли; 
				
		СтрЗарплата = ТекСтрока.Сумма;
		
		Если Параметры.ВидНачисления = "I_Половина" Тогда	
			ПериодНачало   = ?(ТекСтрока.Период < НачалоМесяца(Параметры.ПериодРегистраций), НачалоМесяца(Параметры.ПериодРегистраций), ТекСтрока.Период);
		ИначеЕсли Параметры.ВидНачисления = "II_Половина" Тогда
			ПериодНачало   = ?(ТекСтрока.Период <= НачалоДня(Параметры.Период1), НачалоДня(Параметры.Период1), ТекСтрока.Период);		
		ИначеЕсли Параметры.ВидНачисления = "Зарплата" Тогда	
			ПериодНачало   = ?(ТекСтрока.Период < НачалоМесяца(Параметры.ПериодРегистраций), НачалоМесяца(Параметры.ПериодРегистраций), ТекСтрока.Период);
		КонецЕсли;
		
	    Н = Н +1;
	КонецЦикла;	

	Возврат Сумма;
	
КонецФункции
 
Функция ДанныеРабочихЧасов(ПериодРегистраций) Экспорт

	КРДВ = AzRyFunctions.КоличествоРабочихДнейВМесяце(Год(ПериодРегистраций), НачалоМесяца(ПериодРегистраций), КонецМесяца(ПериодРегистраций));
	
	Структура = Новый Структура;
	Структура.Вставить("КРДВ", КРДВ);
	
	Возврат Структура;

КонецФункции

Функция ОбработкаДокументовНачисленияЗаПериод(Период1, Период2) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НачислениеЗарплатыНачисленияУдержания.Ссылка,
		|	НачислениеЗарплатыНачисленияУдержания.НомерСтроки,
		|	НачислениеЗарплатыНачисленияУдержания.Сотрудник,
		|	НачислениеЗарплатыНачисленияУдержания.Должность,
		|	НачислениеЗарплатыНачисленияУдержания.ВидНачисленияУдержания,
		|	НачислениеЗарплатыНачисленияУдержания.ДатаНачала,
		|	НачислениеЗарплатыНачисленияУдержания.ДатаОкончания,
		|	НачислениеЗарплатыНачисленияУдержания.ОтработаноДней,
		|	НачислениеЗарплатыНачисленияУдержания.ОтработаноЧасов,
		|	НачислениеЗарплатыНачисленияУдержания.Размер,
		|	НачислениеЗарплатыНачисленияУдержания.Сумма,
		|	НачислениеЗарплатыНачисленияУдержания.СчетЗатратРегл,
		|	НачислениеЗарплатыНачисленияУдержания.НаправлениеДеятельности,
		|	НачислениеЗарплатыНачисленияУдержания.ЗаказПокупателя,
		|	НачислениеЗарплатыНачисленияУдержания.РучнаяКорректировка,
		|	НачислениеЗарплатыНачисленияУдержания.Показатель1,
		|	НачислениеЗарплатыНачисленияУдержания.Представление1,
		|	НачислениеЗарплатыНачисленияУдержания.Значение1,
		|	НачислениеЗарплатыНачисленияУдержания.Показатель2,
		|	НачислениеЗарплатыНачисленияУдержания.Представление2,
		|	НачислениеЗарплатыНачисленияУдержания.Значение2,
		|	НачислениеЗарплатыНачисленияУдержания.Показатель3,
		|	НачислениеЗарплатыНачисленияУдержания.Представление3,
		|	НачислениеЗарплатыНачисленияУдержания.Значение3,
		|	НачислениеЗарплатыНачисленияУдержания.AzRyНоменклатура,
		|	НачислениеЗарплатыНачисленияУдержания.AzRyDivision
		|ПОМЕСТИТЬ ТЗ
		|ИЗ
		|	Документ.НачислениеЗарплаты.НачисленияУдержания КАК НачислениеЗарплатыНачисленияУдержания
		|ГДЕ
		|	НачислениеЗарплатыНачисленияУдержания.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
		|	И НачислениеЗарплатыНачисленияУдержания.Ссылка.Проведен
		|	И НачислениеЗарплатыНачисленияУдержания.Ссылка.AzRyТипСозданияДокумента = &AzRyТипСозданияДокумента
		|	И НачислениеЗарплатыНачисленияУдержания.Сотрудник В(&Сотрудник)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НачислениеЗарплатыНалогиНаДоходы.Сотрудник,
		|	НачислениеЗарплатыНалогиНаДоходы.ВидНачисленияУдержания
		|ПОМЕСТИТЬ ТЗ_Налог
		|ИЗ
		|	Документ.НачислениеЗарплаты.НалогиНаДоходы КАК НачислениеЗарплатыНалогиНаДоходы
		|ГДЕ
		|	НачислениеЗарплатыНалогиНаДоходы.Ссылка.Дата МЕЖДУ &Дата1 И &Дата2
		|	И НачислениеЗарплатыНалогиНаДоходы.Ссылка.Проведен
