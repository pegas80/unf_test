					Если спСотрудники.НайтиПоЗначению(Выборка1.Сотрудник) = Неопределено Тогда
						спСотрудники.Добавить(Выборка1.Сотрудник);
					КонецЕсли; 

					Выборка2 = Выборка1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					Н = 0;
					Пока Выборка2.Следующий() Цикл
						ИтогСумма = 0;
						Выборка3 = Выборка2.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
						Пока Выборка3.Следующий() Цикл	
							Н = Н + 1;
							СоответствиеПарамЗнач = СоответствиеПарам.Получить(Выборка3.Сотрудник);
							
							Если СоответствиеПарамЗнач = Неопределено Или СоответствиеПарамЗнач.Сумма = Выборка3.Сумма Тогда 
								Продолжить;
							КонецЕсли;
							
							НоваяСтрока = НачисленияУдержания.Добавить();
							НоваяСтрока.AzRyDivision           = Выборка3.AzRyDivision;
							НоваяСтрока.Сотрудник              = Выборка3.Сотрудник;
							НоваяСтрока.ЗаказПокупателя        = Выборка3.ЗаказПокупателяПроектAzRy_ЗаказПокупателя;
							//НоваяСтрока.Показатель1 = "";
							//НоваяСтрока.Значение1              = Выборка3.ЗагрузкаПлан;
							//НоваяСтрока.НаправлениеДеятельности= Выборка3.ЗаказПокупателяПроектAzRy_ЗаказПокупателя.Проект.AzRyНаправленияДеятельности;
							НоваяСтрока.НаправлениеДеятельности= Выборка3.НаправленияДеятельности;
							НоваяСтрока.ОтработаноЧасов        = Выборка3.ЗагрузкаПлан;
							НоваяСтрока.ВидНачисленияУдержания = Выборка3.ВидНачисленияУдержания;
							НоваяСтрока.СчетЗатратРегл         = Выборка3.СотрудникСчетРасчетовСПерсоналом;
							НоваяСтрока.Размер                 = Выборка3.Сумма / Выборка2.ЗагрузкаПлан;
							НоваяСтрока.ДатаНачала             = НачалоМесяца(ДатаОбновления);
							НоваяСтрока.ДатаОкончания          = КонецМесяца(ДатаОбновления);
							НоваяСтрока.AzRyНоменклатура       = AzRyFunctions.НаправленияДеятельностиНоменклатура(НоваяСтрока.СчетЗатратРегл.Наименование);
							
							// 1. Поиск всех параметров-идентификаторов формулы
							СтруктураПараметров = Новый Структура;
							УправлениеНебольшойФирмойСервер.ДобавитьПараметрыВСтруктуру(НоваяСтрока.ВидНачисленияУдержания.Формула, СтруктураПараметров);
							
							// 2. Добавление показателя
							Счетчик = 0;
							Для каждого ПараметрСтруктуры Из СтруктураПараметров Цикл
								
								Если ПараметрСтруктуры.Ключ = "ОтработаноДней"
									ИЛИ ПараметрСтруктуры.Ключ = "ОтработаноЧасов"
									ИЛИ ПараметрСтруктуры.Ключ = "ТарифнаяСтавка" Тогда
									Продолжить;
								КонецЕсли; 
								
								ПараметрРасчета = Справочники.ПараметрыРасчетов.НайтиПоРеквизиту("Идентификатор", ПараметрСтруктуры.Ключ);
								//Если НЕ ЗначениеЗаполнено(ПараметрРасчета) Тогда		
								//	Сообщение = Новый СообщениеПользователю();
								//	Сообщение.Текст = НСтр("ru='Не найден параметр ';ka='Не найден параметр '") + ПараметрРасчета + НСтр("ru=' для сотрудника в строке № ';ka=' для сотрудника в строке № '") + (Объект.НачисленияУдержания.Индекс(СтрокаТабличнойЧасти) + 1);
								//	Сообщение.Сообщить();			
								//КонецЕсли; 
								
								Счетчик = Счетчик + 1;
								
								Если Счетчик > 3 Тогда
									Прервать;
								КонецЕсли; 
								
								НоваяСтрока["Показатель" + Счетчик] = ПараметрСтруктуры.Ключ;
								НоваяСтрока["Представление" + Счетчик] = ПараметрРасчета;
								НоваяСтрока["Значение" + Счетчик] = Выборка3.ЗагрузкаПлан;
								
							КонецЦикла;
							
							
							Если НоваяСтрока.РучнаяКорректировка ИЛИ НЕ ЗначениеЗаполнено(НоваяСтрока.ВидНачисленияУдержания.Формула) Тогда
								Продолжить;
							КонецЕсли; 
							
							// расчет размера начисления или удержания по формуле
							// 1. Добавляем параметры и значения в структуру
							СтруктураПараметров = Новый Структура;
							СтруктураПараметров.Вставить("ТарифнаяСтавка", НоваяСтрока.Размер);
							СтруктураПараметров.Вставить("ОтработаноДней", НоваяСтрока.ОтработаноДней);
							СтруктураПараметров.Вставить("ОтработаноЧасов", НоваяСтрока.ОтработаноЧасов);
							
							Для Счетчик = 1 По 3 Цикл
								Если ЗначениеЗаполнено(НоваяСтрока["Представление" + Счетчик]) Тогда
									СтруктураПараметров.Вставить(НоваяСтрока["Показатель" + Счетчик], НоваяСтрока["Значение" + Счетчик]);
								КонецЕсли; 
							КонецЦикла; 
							
							
							// 2. Рассчитываем по формулам					
							Формула = НоваяСтрока.ВидНачисленияУдержания.Формула;
							Для каждого Параметр Из СтруктураПараметров Цикл
								Формула = СтрЗаменить(Формула, "[" + Параметр.Ключ + "]", Формат(Параметр.Значение, "ЧРД=.; ЧН=0; ЧГ=0"));
							КонецЦикла;
							Попытка
								РассчитаннаяСумма = Вычислить(Формула);
							Исключение
								Сообщение = Новый СообщениеПользователю();
								Сообщение.Текст = НСтр("ru='Не удалось рассчитать сумму начисления  в строке №%НомерСтроки%. Возможно, формула содержит ошибку или не заполнены показатели.';ka='Не удалось рассчитать сумму начисления  в строке №%НомерСтроки%. Возможно, формула содержит ошибку или не заполнены показатели.'");
								//Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%НомерСтроки%", (Объект.НачисленияУдержания.Индекс(СтрокаНачислений) + 1));
								//Сообщение.Поле = "Объект.НачисленияУдержания[" + Объект.НачисленияУдержания.Индекс(СтрокаНачислений) + "].ВидНачисленияУдержания";
								//Сообщение.УстановитьДанные(Объект);
								Сообщение.Сообщить();
								РассчитаннаяСумма = 0;
							КонецПопытки;
							
							НоваяСтрока.Сумма = Окр(Выборка3.ЗагрузкаПлан * РассчитаннаяСумма, 2);
							
							СоответствиеПарамЗнач.Сумма = СоответствиеПарамЗнач.Сумма + НоваяСтрока.Сумма;
							
							//Если Н = ОтборCC(ТЗКопия, Выборка3.Организация, Выборка3.Сотрудник).Н Тогда
							//	НоваяСтрока.Сумма = НоваяСтрока.Сумма  + (Выборка3.Сумма - СоответствиеПарамЗнач.Сумма);
							//	СоответствиеПарамЗнач.Сумма = СоответствиеПарамЗнач.Сумма + (Выборка3.Сумма - СоответствиеПарамЗнач.Сумма);
							//	Продолжить;
							//КонецЕсли;	
							
							//Если СоответствиеПарамЗнач.Сумма > Выборка3.Сумма Тогда
							//	НоваяСтрока.Сумма = НоваяСтрока.Сумма  + (Выборка3.Сумма - СоответствиеПарамЗнач.Сумма);
							//	СоответствиеПарамЗнач.Сумма = СоответствиеПарамЗнач.Сумма + (Выборка3.Сумма - СоответствиеПарамЗнач.Сумма);
							//	Продолжить;
							//КонецЕсли;
							
						КонецЦикла;	
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;				
		КонецЦикла;
			
	Возврат "";
	
КонецФункции

Функция ОбновлениетаблицыДокументыНачисленияCC_2(ТЗ, ТЗНалоги = Неопределено) Экспорт
	
	ТЗСотрудники = ТЗ.Скопировать();
	ТЗСотрудники.Свернуть("Сотрудник");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ1.Организация,
	               |	ТЗ1.СтруктурнаяЕдиница,
	               |	ТЗ1.AzRyТипСозданияДокумента,
	               |	ТЗ1.Сотрудник,
	               |	ТЗ1.ВидНачисленияУдержания,
	               |	ТЗ1.ДатаНачала,
	               |	ТЗ1.ДатаОкончания,
	               |	ТЗ1.ОтработаноДней,
	               |	ТЗ1.ЗагрузкаПлан,
	               |	ТЗ1.ОтработаноЧасов,
	               |	ТЗ1.Размер,
	               |	ТЗ1.Сумма,
				   |	ТЗ1.СуммаПФ,
	               |	ТЗ1.СчетЗатратРегл,
	               |	ТЗ1.НаправлениеДеятельности,
	               |	ТЗ1.ЗаказПокупателя,
	               |	ТЗ1.РучнаяКорректировка,
	               |	ТЗ1.Показатель1,
	               |	ТЗ1.Представление1,
	               |	ТЗ1.Значение1,
	               |	ТЗ1.Показатель2,
	               |	ТЗ1.Представление2,
	               |	ТЗ1.Значение2,
	               |	ТЗ1.Показатель3,
	               |	ТЗ1.Представление3,
	               |	ТЗ1.Значение3,
	               |	ТЗ1.AzRyНоменклатура,
	               |	ТЗ1.AzRyDivision,
	               |	ТЗ1.Валюта,
	               |	ТЗ1.Начисление,
	               |	ТЗ1.ЗагрузкаПланИтог,
				   |	&ВидУдержанияПФ КАК ВидУдержанияПФ,
				   |	ТЗ1.Проект КАК Проект
	               |ПОМЕСТИТЬ ТЗ2
	               |ИЗ
	               |	&ТЗ КАК ТЗ1
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ2.Организация КАК Организация,
	               |	ТЗ2.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	ТЗ2.AzRyТипСозданияДокумента,
	               |	ТЗ2.Сотрудник,
	               |	ТЗ2.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
	               |	ТЗ2.ДатаНачала,
	               |	ТЗ2.ДатаОкончания,
	               |	ТЗ2.ОтработаноДней,
	               |	ТЗ2.ЗагрузкаПлан,
	               |	ТЗ2.ОтработаноЧасов,
	               |	ТЗ2.Размер,
	               |	ТЗ2.Сумма КАК Сумма,
				   |	ТЗ2.СуммаПФ КАК СуммаПФ,
	               |	ТЗ2.СчетЗатратРегл,
	               |	ТЗ2.НаправлениеДеятельности,
	               |	ТЗ2.ЗаказПокупателя,
	               |	ТЗ2.РучнаяКорректировка,
	               |	ТЗ2.Показатель1,
	               |	ТЗ2.Представление1,
	               |	ТЗ2.Значение1,
	               |	ТЗ2.Показатель2,
	               |	ТЗ2.Представление2,
	               |	ТЗ2.Значение2,
	               |	ТЗ2.Показатель3,
	               |	ТЗ2.Представление3,
	               |	ТЗ2.Значение3,
	               |	ТЗ2.AzRyНоменклатура,
	               |	ТЗ2.AzRyDivision,
	               |	ТЗ2.Валюта,
	               |	ТЗ2.Начисление КАК Начисление,
	               |	ТЗ2.ЗагрузкаПланИтог КАК ЗагрузкаПланИтог,
				   |	&ВидУдержанияПФ КАК ВидУдержанияПФ,
				   |	ТЗ2.Проект КАК Проект
	               |ИЗ
	               |	ТЗ2 КАК ТЗ2
	               |ИТОГИ ПО
	               |	Организация,
	               |	СтруктурнаяЕдиница";
	
	Запрос.УстановитьПараметр("ТЗ", ТЗ);
	Запрос.УстановитьПараметр("ВидУдержанияПФ", Справочники.AzRyНастройки.Пенсия.Значение);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СП = Новый СписокЗначений;
	
	Пока Выборка.Следующий() Цикл		
		Выборка1 = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);		
		Пока Выборка1.Следующий() Цикл			
			
			НЗ = Документы.НачислениеЗарплаты.СоздатьДокумент();	
			НЗ.Дата = ПараметрыДокументов.ДатаДокумента;
			НЗ.ВалютаДокумента    = Константы.НациональнаяВалюта.Получить();
			НЗ.Организация        = Выборка1.Организация;
			НЗ.ПериодРегистрации  = ПараметрыДокументов.ПериодРегистраций;
			НЗ.СтруктурнаяЕдиница = Выборка1.СтруктурнаяЕдиница;
			НЗ.УстановитьНовыйНомер();
			НЗ.НачисленияУдержания.Очистить();
			НЗ.НалогиНаДоходы.Очистить();
			НЗ.Комментарий = " ორგანიზაცია: " + Выборка1.Организация + " გამყოფილება: " + Выборка1.СтруктурнаяЕдиница;
			НЗ.Автор = Пользователи.ТекущийПользователь();
			
			Выборка2 = Выборка1.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка2.Следующий() Цикл
				Если Выборка2.ВидНачисленияУдержания = Справочники.AzRyНастройки.НачислениеПенсия.Значение Или Выборка2.ВидНачисленияУдержания = Справочники.AzRyНастройки.УдержаниеПенсия.Значение Тогда
					Продолжить;				
				КонецЕсли; 
				НЗ.AzRyТипСозданияДокумента = Выборка2.AzRyТипСозданияДокумента;
				
				// ТабЧасть - НачисленияУдержания
				НоваяСтрока = НЗ.НачисленияУдержания.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка2);
				НоваяСтрока.СчетЗатрат = НоваяСтрока.ВидНачисленияУдержания.СчетЗатрат;
			КонецЦикла;
			
			МассивСотрудникиДляТЗНалога = СотрудникиИзТаблицыНачисленияУдержания(НЗ.НачисленияУдержания);
			
			// ТабЧасть - НалогиНаДоходы
			Если Не ТЗНалоги = Неопределено Тогда
				Для каждого ТекЭлемент Из МассивСотрудникиДляТЗНалога Цикл
					НайденнаяСтрока = ТЗНалоги.Найти(ТекЭлемент, "Сотрудник");	
					
					НоваяСтрокаНалог = НЗ.НалогиНаДоходы.Добавить();
					НоваяСтрокаНалог.Сотрудник              = НайденнаяСтрока.Сотрудник;
					НоваяСтрокаНалог.ВидНачисленияУдержания = НайденнаяСтрока.Налог;
					НоваяСтрокаНалог.Сумма                  = НайденнаяСтрока.Сумма;
					НоваяСтрокаНалог.AzRyЗаказПокупателя    = ПараметрыДокументов.ЗаказПокупателя;				
				КонецЦикла;
			КонецЕсли; 
			
			НЗ.Записать(РежимЗаписиДокумента.Проведение);
			СП.Добавить(НЗ);			
		КонецЦикла;
	КонецЦикла;
	
	Возврат СП;
		
КонецФункции

Функция СоздатьСоответствиеПарам(ТЗ) Экспорт 

    ТЗ.Свернуть("Сотрудник, Сумма");

	МассивУдаления = Новый  Массив;
	Для каждого ТекСтрока Из ТЗ Цикл	
		Если ТекСтрока.Сумма = Null Тогда 
			МассивУдаления.Добавить(ТекСтрока);
		КонецЕсли;		
	КонецЦикла;
	
	Для каждого ТекМассив Из МассивУдаления Цикл
		ТЗ.Удалить(ТекМассив);
	КонецЦикла;
	
	СоответствиеПарам = Новый Соответствие;	
	Для каждого ТекС Из ТЗ Цикл
	
		СтруктураПарам = Новый Структура;
		СтруктураПарам.Вставить("Зарплата", ТекС.Сумма);
		СтруктураПарам.Вставить("Сумма", 0);
		
		СоответствиеПарам.Вставить(ТекС.Сотрудник, СтруктураПарам);
			
	КонецЦикла;
	
	Возврат СоответствиеПарам;

КонецФункции

