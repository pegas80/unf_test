Функция СотрудникиМассивПоОтбору(МассивСотрудников, Параметры)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник КАК Сотрудник
		|ИЗ
		|	РегистрСведений.ПлановыеНачисленияИУдержания.СрезПоследних(&Дата, ) КАК ПлановыеНачисленияИУдержанияСрезПоследних
		|ГДЕ
		|	ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник В(&Сотрудник)
		|	И ПлановыеНачисленияИУдержанияСрезПоследних.Организация = &Организация
		|	И ПлановыеНачисленияИУдержанияСрезПоследних.ВидНачисленияУдержания = &ВидНачисленияУдержания
		|	И ПлановыеНачисленияИУдержанияСрезПоследних.ВидНачисленияУдержания.Тип <> &Тип
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПлановыеНачисленияИУдержанияСрезПоследних.Сумма УБЫВ";

	Запрос.УстановитьПараметр("ВидНачисленияУдержания", Параметры.ОбъектНачисленияЗарплаты);
	Запрос.УстановитьПараметр("Дата", КонецДня(Параметры.ПериодРегистраций));
	Запрос.УстановитьПараметр("Организация", Организация);
	//Запрос.УстановитьПараметр("ПериодРегистрации", Параметры.ПериодРегистраций);
	Запрос.УстановитьПараметр("Сотрудник", МассивСотрудников);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыНачисленийИУдержаний.Налог);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Сотрудник");

КонецФункции

Функция ТарифСотрудниковJira(ДатаОбновления, РезультатТЗ)
	
	НДФЛ = Справочники.AzRyНастройки.УдержаниеНДФЛ.Значение.СтавкаНДФЛ/100;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаданияНаРаботу.Организация КАК Организация,
	               |	ЗаданияНаРаботу.ЗаказПокупателя.Проект КАК ЗаказПокупателяПроект,
	               |	ЗаданияНаРаботу.ЗаказПокупателя.Проект.AzRy_ЗаказПокупателя,
	               |	ЗаданияНаРаботу.Сотрудник КАК Сотрудник,
	               |	ЗаданияНаРаботу.ЗагрузкаПлан КАК ЗагрузкаПлан,
	               |	ЗаданияНаРаботу.ЗагрузкаПлан * ПлановыеНачисленияИУдержанияСрезПоследних.Сумма - ЗаданияНаРаботу.ЗагрузкаПлан * ПлановыеНачисленияИУдержанияСрезПоследних.Сумма * " + НДФЛ + " КАК СуммаБезНалога,
	               |	ПлановыеНачисленияИУдержанияСрезПоследних.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
	               |	ПлановыеНачисленияИУдержанияСрезПоследних.СчетЗатратРегл КАК СотрудникСчетРасчетовСПерсоналом,
	               |	ПлановыеНачисленияИУдержанияСрезПоследних.Валюта КАК Валюта,
	               |	ПлановыеНачисленияИУдержанияСрезПоследних.Сумма КАК Сумма,
	               |	&Налог
	               |ИЗ
	               |	РегистрНакопления.ЗаданияНаРаботу КАК ЗаданияНаРаботу
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПлановыеНачисленияИУдержания.СрезПоследних(
	               |				&Дата,
	               |				ВидНачисленияУдержания = &ВидНачисленияУдержания
	               |					И Сумма <> 0) КАК ПлановыеНачисленияИУдержанияСрезПоследних
	               |		ПО ЗаданияНаРаботу.Сотрудник = ПлановыеНачисленияИУдержанияСрезПоследних.Сотрудник
	               |			И ЗаданияНаРаботу.Организация = ПлановыеНачисленияИУдержанияСрезПоследних.Организация
	               |ГДЕ
	               |	ЗаданияНаРаботу.Период МЕЖДУ &Период1 И &Период2
	               |	И НЕ ПлановыеНачисленияИУдержанияСрезПоследних.Сумма = 0";
	
	Запрос.УстановитьПараметр("Период1", НачалоМесяца(ДатаОбновления));
	Запрос.УстановитьПараметр("Период2", КонецМесяца(ДатаОбновления));
	Запрос.УстановитьПараметр("Сотрудник", РезультатТЗ.ВыгрузитьКолонку("Сотрудник"));
	Запрос.УстановитьПараметр("Дата", НачалоМесяца(ДатаОбновления));
	Запрос.УстановитьПараметр("ВидНачисленияУдержания", Справочники.AzRyНастройки.НачислениеТарифнаяСтавка.Значение); 
	Запрос.УстановитьПараметр("Налог", Справочники.AzRyНастройки.УдержаниеНДФЛ.Значение);    
	
	ТЗСотрудникиСоотв = Запрос.Выполнить().Выгрузить();
	ТЗСотрудникиСоотв.Свернуть("Сотрудник, Сумма", "ЗагрузкаПлан");
	
	Возврат ТЗСотрудникиСоотв;

КонецФункции // ТарифСотрудниковJira()
 
Функция СтавкаПоРабочимЧисам(ДатаОбновления, СуммаWorklogs, Ставка)
	
	КРДВ = AzRyFunctions.КоличествоРабочихДнейВМесяце(Год(ДатаОбновления), НачалоМесяца(ДатаОбновления), КонецМесяца(ДатаОбновления));
	КЧР  = Справочники.AzRyНастройки.КоличествоРабочихЧасов.Значение;
	
	Зарплата = (Ставка / КРДВ / КЧР) * СуммаWorklogs;         
	
	К = 0;
	Если Зарплата > Ставка Тогда 
		К = Зарплата - Ставка;
	КонецЕсли;	
	
	Возврат Зарплата - К;
	
КонецФункции	

Функция СоответствиеТарифнаяСтавка(ТЗ, ТарифнаяСтавка) Экспорт

	Соответствие = Новый Соответствие;
	Отбор = Новый Структура;
	Отбор.Вставить("ВидНачисленияУдержания", ТарифнаяСтавка);
