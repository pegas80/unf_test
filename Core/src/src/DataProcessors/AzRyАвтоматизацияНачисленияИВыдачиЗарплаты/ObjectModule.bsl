	//НД = Документы.НачислениеЗарплаты.ПустаяСсылка();
	
	КРДВ = AzRyFunctions.КоличествоРабочихДнейВМесяце(Год(ДатаОбновления), НачалоМесяца(ДатаОбновления), КонецМесяца(ДатаОбновления));
	КЧР  = Справочники.AzRyНастройки.КоличествоРабочихЧасов.Значение;
	
	//Попытка
	
	НДФЛ = Справочники.AzRyНастройки.УдержаниеНДФЛ.Значение.СтавкаНДФЛ/100;
	
	// 2) 
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗ.Сотрудник,
	               |	ТЗ.ВидНачисленияУдержания,
	               |	ТЗ.Организация,
	               |	ТЗ.СтруктурнаяЕдиница,
	               |	ТЗ.AzRyDivision,
	               |	ТЗ.СчетЗатратРегл,
	               |	ТЗ.Валюта,
	               |	ТЗ.Сумма,
				   |	ТЗ.СуммаПФ,
	               |	ВЫРАЗИТЬ(ТЗ.Jira КАК СТРОКА(4)) КАК Jira,
	               |	ТЗ.НаправлениеДеятельности,
	               |	ТЗ.ЗаказПокупателя,
				   |	ТЗ.Проект
	               |ПОМЕСТИТЬ ТЗЗарплата
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |ГДЕ
	               |	ТЗ.НачисляемЗарплату
	               |	И (ВЫРАЗИТЬ(ТЗ.Jira КАК СТРОКА(4))) = ""Jira""
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ.Сотрудник,
	               |	ТЗ.ВидНачисленияУдержания,
	               |	ТЗ.Организация,
	               |	ТЗ.СтруктурнаяЕдиница,
	               |	ТЗ.AzRyDivision,
	               |	ТЗ.СчетЗатратРегл,
	               |	ТЗ.Валюта,
	               |	ТЗ.Сумма,
				   |	ТЗ.СуммаПФ,
	               |	ВЫРАЗИТЬ(ТЗ.Jira КАК СТРОКА(4)) КАК Jira,
	               |	ТЗ.НаправлениеДеятельности,
	               |	ТЗ.ЗаказПокупателя,
				   |	ТЗ.Проект
	               |ПОМЕСТИТЬ ТЗЗарплатаNotJira
	               |ИЗ
	               |	&ТЗ КАК ТЗ
	               |ГДЕ
	               |	ТЗ.НачисляемЗарплату
	               |	И (ВЫРАЗИТЬ(ТЗ.Jira КАК СТРОКА(4))) <> ""Jira""
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЗаданияНаРаботу.Сотрудник,
	               |	СУММА(ЗаданияНаРаботу.ЗагрузкаПлан) КАК ЗагрузкаПланИтог
	               |ПОМЕСТИТЬ ЗаданияНаРаботу_ЗагрузкаПлан
	               |ИЗ
	               |	РегистрНакопления.ЗаданияНаРаботу КАК ЗаданияНаРаботу
	               |ГДЕ
	               |	ЗаданияНаРаботу.Период МЕЖДУ &Период1 И &Период2
	               |	И ЗаданияНаРаботу.Сотрудник В(&Сотрудник)
	               |	И ЗаданияНаРаботу.Организация = &Организация
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЗаданияНаРаботу.Сотрудник
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗЗарплата.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	               |	ЗаданияНаРаботу.Организация КАК Организация,
	               |	ЗаданияНаРаботу.Сотрудник КАК Сотрудник,
	               |	ТЗЗарплата.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
	               |	&Период1 КАК ДатаНачала,
	               |	&Период2 КАК ДатаОкончания,
	               |	0 КАК ОтработаноДней,
	               |	ЗаданияНаРаботу.ЗагрузкаПлан КАК ЗагрузкаПлан,
	               |	ЗаданияНаРаботу.ЗагрузкаПлан КАК ОтработаноЧасов,
	               |	ВЫРАЗИТЬ(ТЗЗарплата.Сумма / ЗаданияНаРаботу_ЗагрузкаПлан.ЗагрузкаПланИтог КАК ЧИСЛО(15, 2)) КАК Размер,
	               |	ВЫРАЗИТЬ(ТЗЗарплата.Сумма / ЗаданияНаРаботу_ЗагрузкаПлан.ЗагрузкаПланИтог * ЗаданияНаРаботу.ЗагрузкаПлан КАК ЧИСЛО(15, 2)) КАК Сумма,
	               |	ТЗЗарплата.СчетЗатратРегл КАК СчетЗатратРегл,
	               |	ЗаданияНаРаботу.ЗаказПокупателя.Проект.AzRy_ЗаказПокупателя.Проект.AzRyНаправленияДеятельности КАК НаправлениеДеятельности,
	               |	ЗаданияНаРаботу.ЗаказПокупателя.Проект.AzRy_ЗаказПокупателя КАК ЗаказПокупателя,
	               |	ЛОЖЬ КАК РучнаяКорректировка,
	               |	"""" КАК Показатель1,
	               |	ЗНАЧЕНИЕ(Справочник.ПараметрыРасчетов.ПустаяСсылка) КАК Представление1,
	               |	0 КАК Значение1,
	               |	"""" КАК Показатель2,
	               |	ЗНАЧЕНИЕ(Справочник.ПараметрыРасчетов.ПустаяСсылка) КАК Представление2,
	               |	0 КАК Значение2,
	               |	"""" КАК Показатель3,
	               |	ЗНАЧЕНИЕ(Справочник.ПараметрыРасчетов.ПустаяСсылка) КАК Представление3,
	               |	0 КАК Значение3,
	               |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК AzRyНоменклатура,
	               |	ТЗЗарплата.AzRyDivision КАК AzRyDivision,
	               |	ТЗЗарплата.Валюта КАК Валюта,
	               |	ТЗЗарплата.Сумма КАК Начисление,
				   |	ТЗЗарплата.СуммаПФ КАК НачислениеПФ,
				   |	ВЫРАЗИТЬ(ТЗЗарплата.СуммаПФ / ЗаданияНаРаботу_ЗагрузкаПлан.ЗагрузкаПланИтог * ЗаданияНаРаботу.ЗагрузкаПлан КАК ЧИСЛО(15, 2)) КАК СуммаПФ,
	               |	ЗаданияНаРаботу_ЗагрузкаПлан.ЗагрузкаПланИтог,
	               |	&AzRyТипСозданияДокумента КАК AzRyТипСозданияДокумента,
	               |	ТЗЗарплата.СчетЗатратРегл КАК СотрудникСчетРасчетовСПерсоналом_DELETEME,
	               |	ЗаданияНаРаботу.ЗаказПокупателя.Проект КАК ЗаказПокупателяПроект_DELETEME,
	               |	ЗаданияНаРаботу.ЗаказПокупателя.Проект.AzRy_ЗаказПокупателя КАК ПроектЗаказПокупателя_DELETEME,
	               |	0 КАК СуммаБезНалога_DELETEME,
	               |	&Налог,
				   |	ЗаданияНаРаботу.AzRyПроект КАК Проект
	               |ИЗ
	               |	ТЗЗарплата КАК ТЗЗарплата
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаданияНаРаботу КАК ЗаданияНаРаботу
	               |		ПО ТЗЗарплата.Сотрудник = ЗаданияНаРаботу.Сотрудник
	               |			И ТЗЗарплата.Организация = ЗаданияНаРаботу.Организация
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ЗаданияНаРаботу_ЗагрузкаПлан КАК ЗаданияНаРаботу_ЗагрузкаПлан
	               |		ПО ТЗЗарплата.Сотрудник = ЗаданияНаРаботу_ЗагрузкаПлан.Сотрудник
	               |ГДЕ
	               |	ЗаданияНаРаботу.Период МЕЖДУ &Период1 И &Период2
	               |	И ЗаданияНаРаботу.Сотрудник В(&Сотрудник)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТЗЗарплатаNotJira.СтруктурнаяЕдиница,
