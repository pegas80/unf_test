Функция СозданиеОбновлениеДокументаНачислений2(ДатаОбновления, Организация, Подразделение, МассивНачисленииИУдержаний, ПараметрыДокументов, НачисляетьсяОтделныйДокумент, ТЗ, Коментарий, ВидНачисленияУдержания) Экспорт 
	                          	                                                             		
	Если ТабличнаяЧастьСотрудники.Количество() = 0 Тогда                                       	
		ВызватьИсключение "ორგანიზაცია : " + Организация.Наименование + ".  დარიცხვის თვე : " + Формат(ДатаОбновления, "Л=ka_GE; ДФ='MMMM yyyy'") + " - არ არის აღმოჩენილი დარიცხვა დაკავებები " + Формат(ДатаОбновления, "Л=ka_GE; ДФ=MMMM") + "ს თვით ";
	КонецЕсли;	
	
	// 1) Заполняем документ начисления и удержания
	
	// Ищем и удаляем старые документы
	//ПойскДокументаИПометкаУдаления(ПараметрыДокументов, Организация, Подразделение, Перечисления.AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты.НачислениеЗарплаты);
	
	ОбработкаТЗДляДжира = Обработки.AzRy_ОбновлениеДокументаНачислениеЗарплаты.Создать();                                 	
	
	НД = Документы.НачислениеЗарплаты.СоздатьДокумент();
	НД.AzRyТипСозданияДокумента = Перечисления.AzRyТипСозданияДокумента.Пользователь;
	НД.Дата = ПараметрыДокументов.ДатаДокумента;
	НД.ВалютаДокумента    = Константы.НациональнаяВалюта.Получить();
	НД.Организация        = Организация;                                                                                                                    	
	НД.ПериодРегистрации  = ПараметрыДокументов.ПериодРегистраций;
	НД.СтруктурнаяЕдиница = Подразделение;
	НД.УстановитьНовыйНомер();	
	НД.НачисленияУдержания.Очистить();
	НД.НалогиНаДоходы.Очистить();
	НД.Комментарий = Коментарий;
	НД.Автор = Пользователи.ТекущийПользователь();
	
	Для каждого СтрокаТаблицы Из ТЗ Цикл
		
		Если СтрокаТаблицы.Jira = "Jira" Тогда
			М = Новый Массив; М.Добавить(СтрокаТаблицы.Сотрудник);
			ОбработкаТЗДляДжира.ОбновлениетаблицыДокументыНачисления(НД.НачисленияУдержания, ДатаОбновления, М, ПараметрыДокументов, ВидНачисленияУдержания);
		Иначе
		    ЗаполнениетаблицыДокумента(НД.НачисленияУдержания.Добавить(), СтрокаТаблицы, ПараметрыДокументов);
		КонецЕсли; 
				
	КонецЦикла;
	
    // Свертка таблицы сотрудников	
	ТЗДляСвертки = СверткаТаблицыСотрудников(ТЗ);
	
	Если Не НачисляетьсяОтделныйДокумент Тогда 
		
		// ТЗ  НалогиНаДоходы
		Для каждого ТекСтрока Из ТЗДляСвертки Цикл	
			
			НайденнаяСтрока = ТабличнаяЧастьСотрудникиНалог.Найти(ТекСтрока.Сотрудник, "Сотрудник");
			Если Не НайденнаяСтрока = Неопределено Тогда
				
				НоваяСтрока = НД.НалогиНаДоходы.Добавить();
				НоваяСтрока.Сотрудник              = НайденнаяСтрока.Сотрудник;
				НоваяСтрока.ВидНачисленияУдержания = НайденнаяСтрока.Налог;
				НоваяСтрока.Сумма                  = НайденнаяСтрока.Сумма;
				НоваяСтрока.AzRyЗаказПокупателя    = ПараметрыДокументов.ЗаказПокупателя;
				
			КонецЕсли; 
			
		КонецЦикла;
		
	КонецЕсли;
	
	НД.Записать(РежимЗаписиДокумента.Проведение);
	
	МассивДокументов = Новый Массив;
	МассивДокументов.Добавить(НД.Ссылка);
	//ДобавитьЗаписВРегСведений(ПараметрыДокументов.ПериодРегистраций ,Организация, Подразделение, Перечисления.AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты.НачислениеЗарплаты, МассивДокументов);
	
	//Сообщить("'დარიცხვა დაკავების' დოკუმენტის დაგენერირება დასრულდა წარმატებით!");
	
	Возврат НД;
	
КонецФункции

Процедура ЗаполнениетаблицыДокумента(НоваяСтрока, Выборка3, ПараметрыДокументов)
	
	НоваяСтрока.AzRyDivision               = Выборка3.AzRyDivision;
	НоваяСтрока.Сотрудник                  = Выборка3.Сотрудник;
	НоваяСтрока.ВидНачисленияУдержания     = Выборка3.ВидНачисленияУдержания;
	НоваяСтрока.СчетЗатратРегл             = Выборка3.СчетЗатратРегл;
	НоваяСтрока.Размер                     = Выборка3.Сумма;
	НоваяСтрока.ДатаНачала                 = НачалоМесяца(ПараметрыДокументов.ПериодРегистраций);
	НоваяСтрока.ДатаОкончания              = КонецМесяца(ПараметрыДокументов.ПериодРегистраций);
	НоваяСтрока.НаправлениеДеятельности    = ПараметрыДокументов.НаправленияДеятельности;
	НоваяСтрока.AzRyНоменклатура           = ПараметрыДокументов.СчетЗатратНоменклатура;
	НоваяСтрока.ЗаказПокупателя            = ПараметрыДокументов.ЗаказПокупателя;
	// 1. Поиск всех параметров-идентификаторов формулы
	СтруктураПараметров = Новый Структура;
	УправлениеНебольшойФирмойСервер.ДобавитьПараметрыВСтруктуру(НоваяСтрока.ВидНачисленияУдержания.Формула, СтруктураПараметров);
	
	// 2. Добавление показателя
	Счетчик = 0;
	Для каждого ПараметрСтруктуры Из СтруктураПараметров Цикл
		
		Если ПараметрСтруктуры.Ключ = "ОтработаноДней"
			ИЛИ ПараметрСтруктуры.Ключ = "ОтработаноЧасов"
			ИЛИ ПараметрСтруктуры.Ключ = "ТарифнаяСтавка" Тогда
			Продолжить;
		КонецЕсли; 
		
		ПараметрРасчета = Справочники.ПараметрыРасчетов.НайтиПоРеквизиту("Идентификатор", ПараметрСтруктуры.Ключ);
		//Если НЕ ЗначениеЗаполнено(ПараметрРасчета) Тогда		
		//	Сообщение = Новый СообщениеПользователю();
		//	Сообщение.Текст = НСтр("ru='Не найден параметр ';ka='Не найден параметр '") + ПараметрРасчета + НСтр("ru=' для сотрудника в строке № ';ka=' для сотрудника в строке № '") + (Объект.НачисленияУдержания.Индекс(СтрокаТабличнойЧасти) + 1);
		//	Сообщение.Сообщить();			
		//КонецЕсли; 
		
		Счетчик = Счетчик + 1;
		
		Если Счетчик > 3 Тогда
			Прервать;
		КонецЕсли; 
		
		НоваяСтрока["Показатель" + Счетчик]    = ПараметрСтруктуры.Ключ;
		НоваяСтрока["Представление" + Счетчик] = ПараметрРасчета;
		//НоваяСтрока["Значение" + Счетчик] = Выборка3.ЗагрузкаПлан;
		
	КонецЦикла;
	
	
	Если НоваяСтрока.РучнаяКорректировка ИЛИ НЕ ЗначениеЗаполнено(НоваяСтрока.ВидНачисленияУдержания.Формула) Тогда
		Возврат;
	КонецЕсли; 
	
	// расчет размера начисления или удержания по формуле
	// 1. Добавляем параметры и значения в структуру			
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ТарифнаяСтавка",  НоваяСтрока.Размер);
	СтруктураПараметров.Вставить("ОтработаноДней",  НоваяСтрока.ОтработаноДней);
	СтруктураПараметров.Вставить("ОтработаноЧасов", НоваяСтрока.ОтработаноЧасов);
	
	Для Счетчик = 1 По 3 Цикл
		Если ЗначениеЗаполнено(НоваяСтрока["Представление" + Счетчик]) Тогда
			СтруктураПараметров.Вставить(НоваяСтрока["Показатель" + Счетчик], НоваяСтрока["Значение" + Счетчик]);
		КонецЕсли; 
	КонецЦикла; 
	
	
	// 2. Рассчитываем по формулам		
	Формула = НоваяСтрока.ВидНачисленияУдержания.Формула;
	Для каждого Параметр Из СтруктураПараметров Цикл
		Формула = СтрЗаменить(Формула, "[" + Параметр.Ключ + "]", Формат(Параметр.Значение, "ЧРД=.; ЧН=0; ЧГ=0"));
	КонецЦикла;
	Попытка
		РассчитаннаяСумма = Вычислить(Формула);
	Исключение
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ru='Не удалось рассчитать сумму начисления  в строке №%НомерСтроки%. Возможно, формула содержит ошибку или не заполнены показатели.';ka='Не удалось рассчитать сумму начисления  в строке №%НомерСтроки%. Возможно, формула содержит ошибку или не заполнены показатели.'");
		//Сообщение.Текст = СтрЗаменить(Сообщение.Текст, "%НомерСтроки%", (Объект.НачисленияУдержания.Индекс(СтрокаНачислений) + 1));
		//Сообщение.Поле = "Объект.НачисленияУдержания[" + Объект.НачисленияУдержания.Индекс(СтрокаНачислений) + "].ВидНачисленияУдержания";
		//Сообщение.УстановитьДанные(Объект);
		Сообщение.Сообщить();
		РассчитаннаяСумма = 0;
	КонецПопытки;
	
	НоваяСтрока.Сумма = Окр(РассчитаннаяСумма, 2);

КонецПроцедуры
 
// Создание документа ПлатежнаяВедомость
Функция СозданиеДокументаПлатежнаяВедомость(Организация, ДокументОснование, ПараметрыДокументов) Экспорт 
	
	ПроцентНДФЛ = ПараметрыДокументов.ПроцентНДФЛ/100;	
	МассивДокументовПлатежнаяВедомость = Новый Массив;
	
	// Ищем и удаляем старые документы --------------------------------------------------------
	//ПойскДокументаИПометкаУдаления(ПараметрыДокументов, Организация, Подразделение, Перечисления.AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты.ПлатежнаяВедомость);
	
	// Свертка таблицы сотрудников	
	ТЗДляСвертки = СверткаТаблицыСотрудников(ДокументОснование.НачисленияУдержания);
	
	Для каждого ТекСотрудник Из ТЗДляСвертки Цикл
		
		ПВ = Документы.ПлатежнаяВедомость.СоздатьДокумент();
		//ПВ.УстановитьНовыйНомер();
		ПВ.AzRyДокументОснование = ДокументОснование.Ссылка;
		ПВ.ВалютаДокумента   = ДокументОснование.ВалютаДокумента;
		ПВ.ВалютаРасчетов    = ДокументОснование.ВалютаДокумента;	
		КурсВалюты = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ДокументОснование.ВалютаДокумента, ТекущаяДата());
		ПВ.Курс      = КурсВалюты.Курс;                                                                                            	
		ПВ.Кратность = КурсВалюты.Кратность;
		ПВ.Организация = Организация;
		ПВ.СтруктурнаяЕдиница = ДокументОснование.СтруктурнаяЕдиница; 		
		ПВ.ПериодРегистрации = НачалоМесяца(ПараметрыДокументов.ПериодРегистраций);
		ПВ.Дата              = ПараметрыДокументов.ДатаДокументаПлВед;
		ПВ.ВидОперации       = Перечисления.ВидыОперацийПлатежнаяВедомость.Зарплата;
		ПВ.Комментарий       = ПараметрыДокументов.Коментарий + ": " + ТекСотрудник.Сотрудник;
		ПВ.Автор = Пользователи.ТекущийПользователь();
		 
		Отбор = Новый Структура();
		Отбор.Вставить("Сотрудник", ТекСотрудник.Сотрудник);
		Отбор.Вставить("НачисляемЗарплату", Истина);
		//Строки = ДокументОснование.НачисленияУдержания.НайтиСтроки(Отбор);
		//Строки = ТЗДляОбработки.НачисленияУдержания.НайтиСтроки(Отбор);
		Строки = ПараметрыДокументов.НачислениеИНалог.НачисленияУдержания.НайтиСтроки(Отбор); 
		//Строки = ТЗ.НайтиСтроки(Отбор);
		
		СуммаНачислений = 0;
		СуммаУдержаний = 0;
		СуммаПенсияНач = 0;
		СуммаПенсияУдр = 0;
		Для каждого ТекСтрока Из Строки Цикл
			
			Если ТекСтрока.ВидНачисленияУдержания.Тип = Перечисления.ТипыНачисленийИУдержаний.Начисление Тогда 								
				Если Справочники.AzRyНастройки.НачислениеПенсия.Значение <> ТекСтрока.ВидНачисленияУдержания Тогда
					СуммаНачислений  = СуммаНачислений + ТекСтрока.Сумма;
				Иначе 
					СуммаПенсияНач = СуммаПенсияНач + ТекСтрока.Сумма;
				КонецЕсли; 
			ИначеЕсли ТекСтрока.ВидНачисленияУдержания.Тип = Перечисления.ТипыНачисленийИУдержаний.Удержание Тогда 				
				Если Справочники.AzRyНастройки.УдержаниеПенсия.Значение <> ТекСтрока.ВидНачисленияУдержания Тогда
					СуммаУдержаний  = СуммаУдержаний + ТекСтрока.Сумма;
				Иначе 
					СуммаПенсияУдр = СуммаПенсияУдр + ТекСтрока.Сумма; 
				КонецЕсли;				
			КонецЕсли;
			
		КонецЦикла;
		
		НоваяСтрока = ПВ.Сотрудники.Добавить();
		НоваяСтрока.Сотрудник     = ТекСтрока.Сотрудник;
		НДФЛ = (СуммаНачислений - СуммаПенсияНач) * ПроцентНДФЛ;
		НоваяСтрока.СуммаПлатежа  = (СуммаНачислений - СуммаПенсияУдр - НДФЛ) - СуммаУдержаний;
		НоваяСтрока.СуммаРасчетов = НоваяСтрока.СуммаПлатежа;
		
		ПВ.Записать(РежимЗаписиДокумента.Запись);
		
		МассивДокументовПлатежнаяВедомость.Добавить(ПВ.Ссылка);
		
	КонецЦикла;
	
	//ДобавитьЗаписВРегСведений(ПараметрыДокументов.ПериодРегистраций ,Организация, Подразделение, Перечисления.AzRyТипЗаписыАвтоматизацияНачисленийЗарплаты.ПлатежнаяВедомость, МассивДокументовПлатежнаяВедомость);
	//Сообщить("'გადახდის განცხადებების' დოკუმენტების დაგენერირება დასრულდა წარმატებით!");
	Возврат МассивДокументовПлатежнаяВедомость;
	
КонецФункции	

// Создание документа расход со счета
Функция СозданиеДокументаРасходСоСчета(МассивДокОбектПлатежнаяВедомость, ПараметрыДокументов)  Экспорт
	
	МассивДокументов = Новый Массив;	
	Для каждого ТекДокумент Из МассивДокОбектПлатежнаяВедомость Цикл
		
		РС = Документы.РасходСоСчета.СоздатьДокумент();
		РС.ДокументОснование = ТекДокумент.Ссылка;
		РС.Дата = ПараметрыДокументов.ДатаДокументаРасСоСчета;
		РС.Организация = ТекДокумент.Организация;		
		РС.Статья = ПараметрыДокументов.СтатьиДвиженияДенежныхСредств;
		РС.Заполнить(ТекДокумент.Ссылка);	
		РС.Комментарий = ПараметрыДокументов.Коментарий + ": " + ТекДокумент.Сотрудники[0].Сотрудник;
		РС.Автор = Пользователи.ТекущийПользователь();
		Если ЗначениеЗаполнено(ПараметрыДокументов.БанкНомерСчета) Тогда
			РС.БанковскийСчет = ПараметрыДокументов.БанкНомерСчета;		
		КонецЕсли; 
		РС.Записать(РежимЗаписиДокумента.Проведение);
		
		МассивДокументов.Добавить(РС.Ссылка);
	КонецЦикла;
	
	Возврат МассивДокументов;
	
