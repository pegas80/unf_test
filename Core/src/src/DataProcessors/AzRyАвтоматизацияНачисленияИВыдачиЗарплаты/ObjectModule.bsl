Функция ВыполнитьКомандуНаСервереСС(ТЗ) Экспорт
		
	ПараметрыДокументов = ПараметрыЗапускаCC();
	
	// შეუცვლელი მონაცემები. ხელმეორედ ივსება ცხრილები ფომრზე. ეს შეიძლება გასათიში გვქონდეს
	//ТаблицыНачисленийИНалогов = ГенерацияТаблицНачисленийИНалогов(ОбработкаОбъект);
	ТаблицыНачисленийИНалогов = ГенерацияТаблицНачисленийИНалогов_ТаблицыВСтруктуру();

	СписокДокНачислениеЗарплаты      = Новый СписокЗначений;
	СписокДокНачисление              = Новый СписокЗначений;
	МассивДокОбектПлатежнаяВедомость = Новый Массив;
	МассивДокОбектРасходСоСчета      = Новый Массив;
	
	МассивНачисления = Новый Массив;
	МассивНачисления.Добавить(ОбъектНачисленияПенсия);
	МассивНачисления.Добавить(ОбъектУдержаниеПенсия);
	МассивНачисления.Добавить(ОбъектУдержаниеСтраховка);
	МассивНачисления.Добавить(ОбъектУдержаниеПитание);
	
	Соотв = Новый Соответствие;
	
	ПараметрыДокументов.Вставить("НачислениеИНалог", ТаблицыНачисленийИНалогов);
			
	ФильтрацияДанных(ТЗ, "НачисляемЗарплату", Истина);
	//ТЗОснНачислений = ТЗ.Скопировать();
	
	//ОчиститьНачисленияСотрудникам(НачалоМесяца(ПараметрыДокументов.ПериодРегистраций), КонецМесяца(ПараметрыДокументов.ПериодРегистраций), 
	//ПараметрыДокументов.Организация, ПараметрыДокументов.Подразделение, ТЗОснНачислений);
	
	// 1) Создание документа начислений
	//ТаблицаПоПодразделениям = ТаблицыПоПодразделениям(ТЗОснНачислений);
	
	ТТТ = ПолуФабрикать(Организация, ПериодРегистраций, ПараметрыДокументов.НачислениеИНалог.НачисленияУдержания, ПараметрыДокументов.ТипНачисленияJiraТариф);
	
	Если СоздатьДокументНачислениеЗарплаты = "Да" Тогда 			
		//Для каждого ТекПодразделение Из ТаблицаПоПодразделениям Цикл
			//Коментарий = ПараметрыДокументов.Коментарий + " ორგანიზაცია: " + Организация + " გამყოფილება: " + ТекПодразделение.Ключ;
			ДокОбектНачислений = ОбновлениетаблицыДокументыНачисленияCC_2(ТТТ, ПараметрыДокументов.НачислениеИНалог.Налог);
			//СписокДокНачислениеЗарплаты.Добавить(ДокОбектНачислений);
			СписокДокНачислениеЗарплаты.ЗагрузитьЗначения(ДокОбектНачислений.ВыгрузитьЗначения());
			СписокДокНачисление.ЗагрузитьЗначения(ДокОбектНачислений.ВыгрузитьЗначения());
			
			//Для каждого ТекЗначение Из МассивНачисления Цикл
			//	Если ТекЗначение = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка() Тогда Продолжить; КонецЕсли; 
			//	ТЗ = ФильтрацияДанных(ТЗ, "ВидНачисленияУдержания", ТекЗначение);
			//	СписокДокНачисление.Добавить(СозданиеОбновлениеДокументаНачислений(ПериодРегистраций, Организация, "", МассивНачисленииИУдержаний, ПараметрыДокументов, Истина, "", ПараметрыДокументов.КоментарийДляПенсии, ТекЗначение, ТТТ));
			//КонецЦикла;					
		//КонецЦикла;				
	КонецЕсли;	
	
	// 2) Создание массива документов платежная ведомость
	Если СоздатьДокументПлатежнаяВедомость = "Да" И СтатусОбработки = "Создание" Тогда 
		Для каждого ТекДокумент Из СписокДокНачислениеЗарплаты Цикл
			Ответ = СозданиеДокументаПлатежнаяВедомость(ТекДокумент.Значение.Организация, ТекДокумент.Значение, ПараметрыДокументов);
			Для каждого ТекДок Из Ответ Цикл
				МассивДокОбектПлатежнаяВедомость.Добавить(ТекДок);	
			КонецЦикла;
		КонецЦикла;
		
		// 3) Создание массива документов расход со счета
		Если СоздатьДокументРасходСоСчета = "Да" И СтатусОбработки = "Создание" Тогда 
			Ответ = СозданиеДокументаРасходСоСчета(МассивДокОбектПлатежнаяВедомость, ПараметрыДокументов);
			Для каждого ТекДок Из Ответ Цикл
				МассивДокОбектРасходСоСчета.Добавить(ТекДок);	
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Ответ = Новый Структура;
	Ответ.Вставить("СписокДокНачисление", СписокДокНачисление);
	Ответ.Вставить("МассивДокОбектПлатежнаяВедомость", МассивДокОбектПлатежнаяВедомость);
	Ответ.Вставить("МассивДокОбектРасходСоСчета", МассивДокОбектРасходСоСчета);
	
	Возврат Ответ;
	
КонецФункции

Процедура ПерезаполнитьТаблицыФорм(Парам) Экспорт

	ТабличнаяЧастьСотрудники.Очистить();
	ТабличнаяЧастьСотрудникиНалог.Очистить();
	ИсторияСотрудника.Очистить();
	
	Для каждого ТекСтрока Из Парам.НачисленияУдержания Цикл
		НоваяСтрока = ТабличнаяЧастьСотрудники.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
	КонецЦикла;
	
	Для каждого ТекСтрока Из Парам.Налог Цикл
		НоваяСтрока = ТабличнаяЧастьСотрудникиНалог.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
	КонецЦикла;
	
	Для каждого ТекСтрока Из Парам.ИсторияЗарплаты Цикл
		НоваяСтрока = ИсторияСотрудника.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
	КонецЦикла;	

КонецПроцедуры

Функция ПолуФабрикать(Организация, ДатаОбновления, НачисленияУдержания, JiraТариф)

