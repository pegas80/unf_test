	Запрос.УстановитьПараметр("ВидНачисленияУдержания", МассивНачисленииИУдержаний);
	Запрос.УстановитьПараметр("ПериодРегистрации", Параметры.ПериодРегистраций);
	Запрос.УстановитьПараметр("ТЗСотрудники", ТЗАктивныеСотрудники);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыНачисленийИУдержаний.Налог);
	Запрос.УстановитьПараметр("AzRyDivision", Справочники.AzRyDivision.ПустаяСсылка());
	//Запрос.УстановитьПараметр("ОснвВидНач", Справочники.AzRyНастройки.НачислениеТарифнаяСтавка.Значение);
	Запрос.УстановитьПараметр("НачИУдержJira", спНачИУдержJira);
	
