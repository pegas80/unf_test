	ОбработкаОбъект.ТабличнаяЧастьСотрудники.Очистить();
	ОбработкаОбъект.ТабличнаяЧастьСотрудникиНалог.Очистить();
	ОбработкаОбъект.ИсторияСотрудника.Очистить();
	
	НачатьТранзакцию();
	Попытка
		Ответ = ОбработкаОбъект.ОбработкаДокументовНачисленияЗаПериод2(НачалоМесяца(ОбработкаОбъект.ПериодРегистраций), КонецМесяца(ОбработкаОбъект.ПериодРегистраций));				
	Исключение
		Сообщить(ОписаниеОшибки());
		ОтменитьТранзакцию();
	КонецПопытки;
	ЗафиксироватьТранзакцию();
		
