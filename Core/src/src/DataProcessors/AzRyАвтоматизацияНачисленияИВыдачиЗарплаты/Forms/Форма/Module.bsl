		Объект.КоментарийНачисленийСтраховки = "ავტ. დარიცხვა : ჯანდაცვა I ნახევარი";
		Объект.КоментарийНачисленийПитания   = "ავტ. დარიცხვა : კვება I ნახევარი";
		Объект.КоментарийНачисленийПенсии    = "ავტ. დარიცხვა : პენსია I ნახევარი";		
	ИначеЕсли Объект.ВидНачисления = "II_Половина" Тогда
		Элементы.Декорация3.Заголовок = ЗаголовокНачислений + " II ნახევარი";
		Объект.КоментарийНачисленийСтраховки = "ავტ. დარიცხვა : ჯანდაცვა II ნახევარი";
		Объект.КоментарийНачисленийПитания   = "ავტ. დარიცხვა : კვება II ნახევარი";
		Объект.КоментарийНачисленийПенсии    = "ავტ. დარიცხვა : პენსია II ნახევარი";		
	ИначеЕсли Объект.ВидНачисления = "Зарплата" Тогда
		Элементы.Декорация3.Заголовок = "სრული " + ЗаголовокНачислений;
		Объект.КоментарийНачисленийСтраховки = "ავტ. დარიცხვა : ჯანდაცვა სრული";
		Объект.КоментарийНачисленийПитания   = "ავტ. დარიცხვა : კვება სრული";
		Объект.КоментарийНачисленийПенсии    = "ავტ. დარიცხვა : პენსია სრული";
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере
Функция ФилтрацияТЗОтчета(_ТабличнаяЧастьСотрудники, _ТабличнаяЧастьСотрудникиНалог)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗВремТаблица.ЗанимаемыхСтавок,
		|	ТЗВремТаблица.НачисляемЗарплату,
		|	ТЗВремТаблица.Сотрудник,
		|	ТЗВремТаблица.Должность,
		|	ТЗВремТаблица.ГрафикРаботы,
		|	ТЗВремТаблица.Валюта,
		|	ТЗВремТаблица.ВидНачисленияУдержания,
		|	ТЗВремТаблица.Сумма,
		|	ТЗВремТаблица.СчетЗатрат,
		|	ТЗВремТаблица.ВыплаченнаяСумма,
		|	ТЗВремТаблица.Тип
		|ПОМЕСТИТЬ ТЗВремТаблица
		|ИЗ
		|	&ТЗВремТаблица КАК ТЗВремТаблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗВремТаблица.ЗанимаемыхСтавок,
		|	ТЗВремТаблица.НачисляемЗарплату,
		|	ТЗВремТаблица.Сотрудник,
		|	ТЗВремТаблица.Должность,
		|	ТЗВремТаблица.ГрафикРаботы,
		|	ТЗВремТаблица.Валюта,
		|	ТЗВремТаблица.ВидНачисленияУдержания,
		|	ТЗВремТаблица.Сумма,
		|	ТЗВремТаблица.СчетЗатрат,
		|	ТЗВремТаблица.Тип,
		|	ТЗВремТаблица.ВыплаченнаяСумма
		|ИЗ
		|	ТЗВремТаблица КАК ТЗВремТаблица
		|ГДЕ
		|	ТЗВремТаблица.НачисляемЗарплату = ИСТИНА";

	Запрос.УстановитьПараметр("ТЗВремТаблица", _ТабличнаяЧастьСотрудники);
		
	ТЗ1 = Запрос.Выполнить().Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЗВремТаблица.Сотрудник,
	|	ТЗВремТаблица.Налог,
	|	ТЗВремТаблица.Сумма,
	|	ТЗВремТаблица.Тип
	|ПОМЕСТИТЬ ТЗВремТаблица2
	|ИЗ
	|	&ТЗВремТаблица2 КАК ТЗВремТаблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЗВремТаблица2.Сотрудник,
	|	ТЗВремТаблица2.Налог,
	|	ТЗВремТаблица2.Сумма,
	|	ТЗВремТаблица2.Тип
	|ИЗ
	|	ТЗВремТаблица2 КАК ТЗВремТаблица2
	|ГДЕ
	|	ТЗВремТаблица2.Сотрудник В(&Сотрудник)";
	
	Запрос.УстановитьПараметр("ТЗВремТаблица2", _ТабличнаяЧастьСотрудникиНалог);
	Запрос.УстановитьПараметр("Сотрудник", ТЗ1.ВыгрузитьКолонку("Сотрудник"));
	
	ТЗ2 = Запрос.Выполнить().Выгрузить();


	СтрПараметры = Новый Структура;
	СтрПараметры.Вставить("ТЗ1", ТЗ1);
	СтрПараметры.Вставить("ТЗ2", ТЗ2);
	
	Возврат СтрПараметры;
	
КонецФункции	

&НаСервере
Функция ФилтрацияТЗ(ТЗ, КолонкаФилтр, ПарамФилтр)

	НовТЗ = ТЗ.Скопировать();
	МассивПарам = Новый Массив;
	
	Для каждого ТекСтрока Из НовТЗ Цикл
	
		Если Не ТекСтрока[КолонкаФилтр] = ПарамФилтр Тогда 
			МассивПарам.Добавить(ТекСтрока);
		КонецЕсли;	
	
	КонецЦикла;
	
	
	Для каждого ТекМассив Из МассивПарам Цикл
	
		НовТЗ.Удалить(ТекМассив); 
	
	КонецЦикла;	
	
	Возврат НовТЗ;

