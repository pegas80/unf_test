&НаСервере
Процедура ВыполнитьКомандуНаСервере()
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.СтатусОбработки = "Создание";
	
	НачатьТранзакцию();	
	Попытка
		Ответ = ОбработкаОбъект.ВыполнитьКомандуНаСервереСС(ОбработкаОбъект.ТабличнаяЧастьСотрудники.Выгрузить());
	Исключение
		ОтменитьТранзакцию();
		Сообщить("დოკუმენტების დაფორმირება ვერ მოხერხდა....!" + ОписаниеОшибки(), СтатусСообщения.ОченьВажное);	
		Возврат;
	КонецПопытки;	
	//ЗафиксироватьТранзакцию();
	
	ДокументыНачислений.Очистить();
	ДокументыПлатежнаяВедомость.Очистить();
	ДокументыРасходСоСчета.Очистить();
	
	// 1) Начислений
	Для каждого ТекСтрока Из Ответ.СписокДокНачисление Цикл
		Если Не ТекСтрока.Значение.Проведен Тогда
			Продолжить;	
		КонецЕсли; 
		СтруктураИтогов = ТекСтрока.Значение.ПолучитьСуммуДокумента();
		НовСтрока = ДокументыНачислений.Добавить();
		НовСтрока.ДокументСсылка = ТекСтрока.Значение.Ссылка;
		НовСтрока.Подразделение  = ТекСтрока.Значение.СтруктурнаяЕдиница;
		НовСтрока.Начислено = СтруктураИтогов.СуммаНачислено;
		НовСтрока.Удержано = СтруктураИтогов.СуммаУдержано;
		НовСтрока.СуммаВыдачи = СтруктураИтогов.СуммаДокумента;
	КонецЦикла;			
			
	// 2) ПлатежнаяВедомость
	Для каждого ТекДок Из Ответ.МассивДокОбектПлатежнаяВедомость Цикл	
		НовСтрока = ДокументыПлатежнаяВедомость.Добавить();
		НовСтрока.ДокументСсылка = ТекДок.Ссылка;
		НовСтрока.СуммаДокумента = ТекДок.СуммаДокумента;		
		НовСтрока.Коментарий     = ТекДок.Комментарий;
	КонецЦикла;

	// 3) РасходСоСчета
	Для каждого ТекДок2 Из Ответ.МассивДокОбектРасходСоСчета Цикл	
		НовСтрока = ДокументыРасходСоСчета.Добавить();
		НовСтрока.ДокументСсылка = ТекДок2.Ссылка;
		НовСтрока.СуммаДокумента = ТекДок2.СуммаДокумента;
		НовСтрока.Коментарий     = ТекДок2.Комментарий;
	КонецЦикла;
	
	ОбновитьПодвалТаблиц();
	
	Сообщить("ოპერაცია დასრულდა წარმატებით.", СтатусСообщения.Информация);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЗСотрудникамиСервер(ОчиститьТаблицы)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОбработкаОбъект.ЗаполнитьТЗСотрудникамиСерверCC(ОчиститьТаблицы);
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Процедура ПеренестиДанныеВТаблицахФорм(ОбработкаОбъект, ТаблицыНачисленийИНалогов)
	
	// Переносим данные в таблицу объекта "ТабличнаяЧастьСотрудники"
	ТаблицыНачисленийИНалогов.НачисленияУдержания.Сортировать("jira Убыв, Сотрудник Убыв");
	Для каждого ТекСтрока Из ТаблицыНачисленийИНалогов.НачисленияУдержания Цикл	
		НоваяСтрока = ОбработкаОбъект.ТабличнаяЧастьСотрудники.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);	
	КонецЦикла;
	
	// Переносим данные в таблицу объекта "ТабличнаяЧастьСотрудникиНалог"
	ТаблицыНачисленийИНалогов.Налог.Сортировать("Сотрудник Убыв");
	Для каждого ТекСтрока2 Из ТаблицыНачисленийИНалогов.Налог Цикл	
		НоваяСтрока = ОбработкаОбъект.ТабличнаяЧастьСотрудникиНалог.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока2);	
	КонецЦикла;
	
	// Переносим данные в таблицу объекта "ИсторияСотрудника"
	ТаблицыНачисленийИНалогов.ИсторияЗарплаты.Сортировать("Сотрудник Убыв");
	ОбработкаОбъект.ИсторияСотрудника.Очистить();
	Для каждого ТекСтрока2 Из ТаблицыНачисленийИНалогов.ИсторияЗарплаты Цикл	
		НоваяСтрока = ОбработкаОбъект.ИсторияСотрудника.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока2);	
	КонецЦикла;
	
КонецПроцедуры
 
&НаСервере
Процедура НЗПриИзмененииСервер()
	
	// Реквизит Формы В Значение
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	
	// Перенисем данные в таблицу объекта "ТабличнаяЧастьСотрудники"
	Для каждого ТекСтрока Из ОбработкаОбъект.ТабличнаяЧастьСотрудники Цикл
		ТекСтрока.НачисляемЗарплату = НЗ;		
	КонецЦикла;
	
	// Значение В Реквизит Формы
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьОтчетСервер()
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");    
	ПараметрыДокументов = ОбработкаОбъект.ПараметрыЗапускаCC();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗНачисления.Сотрудник,
	               |	ТЗНачисления.ВидНачисленияУдержания КАК ВидыНачисленийИУдержаний,
	               |	ТЗНачисления.Тип,
	               |	ТЗНачисления.Сумма КАК СуммаНачислений
	               |ПОМЕСТИТЬ ТЗНачислений
	               |ИЗ
	               |	&ТЗНачисления КАК ТЗНачисления
	               |ГДЕ
	               |	ТЗНачисления.Тип = &ТипНачисления
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗУдержания.Сотрудник,
	               |	ТЗУдержания.ВидНачисленияУдержания КАК ВидыНачисленийИУдержаний,
	               |	ТЗУдержания.Тип,
	               |	ТЗУдержания.Сумма КАК СуммаУдержаний
	               |ПОМЕСТИТЬ ТЗУдержания
	               |ИЗ
	               |	&ТЗУдержания КАК ТЗУдержания
	               |ГДЕ
	               |	ТЗУдержания.Тип = &ТипУдержания
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗВыданнаяСумма.Сотрудник,
	               |	""ВЫПСУММА"" КАК ВидыНачисленийИУдержаний,
	               |	ТЗВыданнаяСумма.Тип,
	               |	ТЗВыданнаяСумма.ВыплаченнаяСумма
	               |ПОМЕСТИТЬ ТЗВыданнаяСумма
	               |ИЗ
	               |	&ТЗВыданнаяСумма КАК ТЗВыданнаяСумма
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗНалог.Сотрудник,
	               |	ТЗНалог.Налог КАК ВидыНачисленийИУдержаний,
	               |	ТЗНалог.Тип,
	               |	ТЗНалог.Сумма КАК СуммаНалога
	               |ПОМЕСТИТЬ ТЗНалог
	               |ИЗ
	               |	&ТЗНалог КАК ТЗНалог
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВложенныйЗапрос.Сотрудник КАК Сотрудник,
	               |	ВложенныйЗапрос.ВидыНачисленийИУдержаний,
	               |	ВложенныйЗапрос.СуммаНачислений КАК СуммаНачислений,
	               |	ВложенныйЗапрос.СуммаУдержаний КАК СуммаУдержаний,
	               |	ВложенныйЗапрос.СуммаНалога КАК СуммаНалога,
	               |	ВложенныйЗапрос.ВыплаченнаяСумма КАК ВыплаченнаяСумма,
	               |	ВложенныйЗапрос.СуммаНачислений - ВложенныйЗапрос.СуммаУдержаний - ВложенныйЗапрос.СуммаНалога КАК СуммаВыдачи
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ТЗНачислений.Сотрудник КАК Сотрудник,
	               |		ТЗНачислений.ВидыНачисленийИУдержаний КАК ВидыНачисленийИУдержаний,
	               |		ТЗНачислений.Тип КАК Тип,
	               |		ТЗНачислений.СуммаНачислений КАК СуммаНачислений,
	               |		0 КАК СуммаУдержаний,
	               |		0 КАК СуммаНалога,
	               |		0 КАК ВыплаченнаяСумма
	               |	ИЗ
	               |		ТЗНачислений КАК ТЗНачислений
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ТЗУдержания.Сотрудник,
	               |		ТЗУдержания.ВидыНачисленийИУдержаний,
	               |		ТЗУдержания.Тип,
	               |		0,
	               |		ТЗУдержания.СуммаУдержаний,
	               |		0,
	               |		0
	               |	ИЗ
	               |		ТЗУдержания КАК ТЗУдержания
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ТЗНалог.Сотрудник,
	               |		ТЗНалог.ВидыНачисленийИУдержаний,
	               |		ТЗНалог.Тип,
	               |		0,
	               |		0,
	               |		ТЗНалог.СуммаНалога,
	               |		0
	               |	ИЗ
	               |		ТЗНалог КАК ТЗНалог
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ТЗВыданнаяСумма.Сотрудник,
	               |		ТЗВыданнаяСумма.ВидыНачисленийИУдержаний,
	               |		ТЗВыданнаяСумма.Тип,
	               |		0,
	               |		0,
	               |		0,
	               |		ТЗВыданнаяСумма.ВыплаченнаяСумма
	               |	ИЗ
	               |		ТЗВыданнаяСумма КАК ТЗВыданнаяСумма) КАК ВложенныйЗапрос
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	СуммаНачислений УБЫВ
	               |ИТОГИ
	               |	СУММА(СуммаНачислений),
	               |	СУММА(СуммаУдержаний),
	               |	СУММА(СуммаНалога),
	               |	СУММА(ВыплаченнаяСумма),
	               |	СУММА(СуммаВыдачи)
	               |ПО
	               |	Сотрудник";
				   
	ТЗпараметры = ФилтрацияТЗОтчета(ОбработкаОбъект.ТабличнаяЧастьСотрудники, ОбработкаОбъект.ТабличнаяЧастьСотрудникиНалог);			   
				   
	Запрос.УстановитьПараметр("ТЗНачисления", ТЗпараметры.ТЗ1);
	Запрос.УстановитьПараметр("ТЗУдержания", ТЗпараметры.ТЗ1);
	Запрос.УстановитьПараметр("ТЗВыданнаяСумма", ТЗпараметры.ТЗ1);
	Запрос.УстановитьПараметр("ТЗНалог", ТЗпараметры.ТЗ2);
	
	Запрос.УстановитьПараметр("ТипНачисления", Перечисления.ТипыНачисленийИУдержаний.Начисление);	
	Запрос.УстановитьПараметр("ТипУдержания", Перечисления.ТипыНачисленийИУдержаний.Удержание);
		
	//Результат = Запрос.Выполнить().Выгрузить();
	
	Результат = Запрос.Выполнить();
	СпособОбхода = ОбходРезультатаЗапроса.ПоГруппировкамСИерархией;
	Дерево = Результат.Выгрузить(СпособОбхода); 
	
	ОбработкаОбъект.Отчет = Неопределено;
	ОбработкаОбъект.Отчет = Дерево;
	
	// Значение В Реквизит Формы
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
КонецПроцедуры

// При изменений сотруднику начисление надо обновыть таблицу НДФЛ Сотрудника
&НаСервере
Процедура ТабличнаяЧастьСотрудникиСуммаПриИзмененииСервер(Сотрудник)
	
	//ტარიფის ცვლილებისას უნდა განახლდეს საპენსიოს მნიშვნელობებიც	
	ОбработкаОбъект     = РеквизитФормыВЗначение("Объект");
	ПараметрыДокументов = ОбработкаОбъект.ПараметрыЗапускаCC();
	
	// 1) Отбор таблицы "ТабличнаяЧастьСотрудники"
	Отбор = Новый Структура;
	Отбор.Вставить("Сотрудник", Сотрудник);
	
	МассивСтрок = ОбработкаОбъект.ТабличнаяЧастьСотрудники.НайтиСтроки(Отбор);
	
	СуммаНачислений = 0;
	ПенсияЗначение  = 0;
	СоотВ = ОбработкаОбъект.СоответствиеТарифнаяСтавка(ОбработкаОбъект.ТабличнаяЧастьСотрудники, ПараметрыДокументов.ОбъектНачисленияЗарплаты);
	Для каждого ТекСтрока Из МассивСтрок Цикл	
			
		// დაგროვებითი საპენსიოს გამოთვლა
		Если ПенсияЗначение = 0 Тогда
			ПенсияЗначение = ОбработкаОбъект.ПенсияВычислить(ТекСтрока, ТекСтрока.ВидНачисленияУдержания, СоотВ[ТекСтрока.Сотрудник]);	
		КонецЕсли; 
		
		// 
		Если ТекСтрока.ВидНачисленияУдержания.Тип = Перечисления.ТипыНачисленийИУдержаний.Начисление И ТекСтрока.ВидНачисленияУдержания <> Справочники.AzRyНастройки.НачислениеПенсия.Значение Тогда
			СуммаНачислений = СуммаНачислений + ТекСтрока.Сумма;
		ИначеЕсли ТекСтрока.ВидНачисленияУдержания = Справочники.AzRyНастройки.УдержаниеПенсия.Значение Или ТекСтрока.ВидНачисленияУдержания = Справочники.AzRyНастройки.НачислениеПенсия.Значение Тогда			
			ТекСтрока.Сумма = ПенсияЗначение;
		ИначеЕсли ТекСтрока.ВидНачисленияУдержания.Тип = Перечисления.ТипыНачисленийИУдержаний.Удержание Тогда
			//СуммаНачислений = СуммаНачислений - ТекСтрока.Сумма;
		КонецЕсли;
	КонецЦикла;
	
	
	// 2) Отбор таблицы "ТабличнаяЧастьСотрудникиНалог"
	МассивСтрок2 = ОбработкаОбъект.ТабличнаяЧастьСотрудникиНалог.НайтиСтроки(Отбор);
	Если МассивСтрок2.Количество() = 0 Тогда
		НоваяСтрока = ОбработкаОбъект.ТабличнаяЧастьСотрудникиНалог.Добавить();
		НоваяСтрока.Сотрудник = Сотрудник; 
		НоваяСтрока.Налог     = Объект.ОбъектНДФЛЗапрлаты;
		НоваяСтрока.Сумма     = 0;
		НоваяСтрока.Тип       = Объект.ОбъектНДФЛЗапрлаты.Тип;
		
		МассивСтрок2 = ОбработкаОбъект.ТабличнаяЧастьСотрудникиНалог.НайтиСтроки(Отбор);
	КонецЕсли; 
	
	Для каждого ТекСтрока2 Из МассивСтрок2 Цикл	
		ТекСтрока2.Сумма = (СуммаНачислений - ПенсияЗначение) * ПараметрыДокументов.ПроцентНДФЛ/100;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ОбработкаОбъект, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура КоментарийДокументов()
	    
	Если Объект.ВидНачисления = "I_Половина" Тогда 
		Объект.Коментарий = "ავტ. დარიცხვა : " + ЗаголовокНачислений + " I ნახევარი";
		Объект.КоментарийНачисленийСтраховки = "ავტ. : ჯანდაცვა I ნახევარი";
		Объект.КоментарийНачисленийПитания   = "ავტ. დარიცხვა : კვება I ნახევარი";
		Объект.КоментарийНачисленийПенсии    = "ავტ. დარიცხვა : პენსია I ნახევარი";
	ИначеЕсли Объект.ВидНачисления = "II_Половина" Тогда
		Объект.Коментарий = "ავტ. დარიცხვა : " + ЗаголовокНачислений + " II ნახევარი";
		Объект.КоментарийНачисленийСтраховки = "ავტ. დარიცხვა : ჯანდაცვა II ნახევარი";
		Объект.КоментарийНачисленийПитания   = "ავტ. დარიცხვა : კვება II ნახევარი";
		Объект.КоментарийНачисленийПенсии    = "ავტ. დარიცხვა : პენსია II ნახევარი";
	ИначеЕсли Объект.ВидНачисления = "Зарплата" Тогда
		Объект.Коментарий = "ავტ. დარიცხვა : " + ЗаголовокНачислений + " სრული";
		Объект.КоментарийНачисленийСтраховки = "ავტ. დარიცხვა : ჯანდაცვა სრული";
		Объект.КоментарийНачисленийПитания   = "ავტ. დარიცხვა : კვება სრული";
		Объект.КоментарийНачисленийПенсии    = "ავტ. დარიცხვა : პენსია სრული";
	КонецЕсли;	

КонецПроцедуры

