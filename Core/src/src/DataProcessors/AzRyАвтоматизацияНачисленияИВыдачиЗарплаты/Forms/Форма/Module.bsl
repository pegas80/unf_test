&НаСервере
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	Если Параметры.Свойство("АдресВХранилище") И ЗначениеЗаполнено(Параметры.АдресВХранилище) Тогда
		
		СохраненныеНастройки = Новый Структура;
		Для Каждого КлючИЗначение Из Настройки Цикл
			// Преобразование имени для хранения ключа соответствия для хранения в структуре
			ИмяКлюча = СтрЗаменить(КлючИЗначение.Ключ,".","_QTQ_");
			ИмяКлюча = СтрЗаменить(ИмяКлюча," ","_QPQ_");
			Если ИмяКлюча = "" Тогда
				ИмяКлюча = "_QQQ_";
			КонецЕсли;
			СохраненныеНастройки.Вставить(ИмяКлюча, КлючИЗначение.Значение);
		КонецЦикла;
		
		Настройки.Очистить();
		
	Иначе
		
		//ДатаДокумента               = Настройки.Получить("ДатаДокумента");
		//ПериодРегистраций           = Настройки.Получить("ПериодРегистраций");
		Объект.Организация                   = Настройки.Получить("Организация");
		//Подразделение                 = Настройки.Получить("Подразделение");
		Объект.ОбъектНачисленияЗарплаты      = Настройки.Получить("ОбъектНачисленияЗарплаты");
		Объект.ОбъектНДФЛЗапрлаты            = Настройки.Получить("ОбъектНДФЛЗапрлаты");
		Объект.ОбъектНачисленияДивиденд      = Настройки.Получить("ОбъектНачисленияДивиденд");
		Объект.ОбъектНДФЛДивиденд            = Настройки.Получить("ОбъектНДФЛДивиденд");
		Объект.СтатьиДвиженияДенежныхСредств = Настройки.Получить("СтатьиДвиженияДенежныхСредств");
		Объект.Коментарий                    = Настройки.Получить("Коментарий");
				
	КонецЕсли;
	
