Функция ПерекодироватьТест(мИсходнаяСтрока,мИзКодировки,мВКодировку)

	Перем Текст, ИмяФайла, мРезультат;
	
	ИмяФайла = ПолучитьИмяВременногоФайла();
	
	Текст = Новый ТекстовыйДокумент;
	Текст.УстановитьТекст(мИсходнаяСтрока);
	Текст.Записать(ИмяФайла,мИзКодировки);
	Текст.Прочитать(ИмяФайла,мВКодировку);
	
	мРезультат = Текст.ПолучитьТекст();
	
	Возврат мРезультат;

КонецФункции // ПерекодироватьТест()

Функция ПолучитьШтрихкод(КодТовара,Длина=13)

	мДлинаКода = ?(мФорматШтрихкода=4,6,5);
	мДлинаКолв = Длина-?(мФорматШтрихкода=4,8,7);
	мДлинаКолв = ?(мДлинаКолв<0,0,мДлинаКолв);
	
	мШтрихкод = Лев(мПрефиксВТ + Формат(КодТовара,"ЧЦ="+мДлинаКода+"; ЧВН=; ЧГ=0") + "0000000000000000000000000000000000000",Длина);
	
	Возврат мШтрихкод;

КонецФункции // ПолучитьШтрихкод()


// Функция осуществляет выгрузку позиции в весы с печатью этикеток.
// (API v2.0)
//
// Параметры:
//  Объект                         - <*>
//                                 - Объект драйвера торгового оборудования.
//
//  PLU                            - <Число>
//                                 - Номер PLU.
//
//  КодТовара                      - <Число>
//                                 - Код товара.
//
//  Наименование                   - <Строка>
//                                 - Наименование номенклатуры.
//
//  Цена                           - <Число>
//                                 - Цена номенклатуры.
//
// Возвращаемое значение:
//  <ПеречислениеСсылка.ТООшибки*> - Результат работы функции.
//
Функция Выгрузить(Объект, PLU, КодТовара, Наименование, Цена, СрокГодности=0) Экспорт

	Результат = мНетОшибки;
	
	мНаименование = Наименование;
	
	мНаименование = СтрЗаменить(мНаименование,"і","i");
	мНаименование = СтрЗаменить(мНаименование,"І","I");

	Если мКодоваяСтраница<>1251 Тогда
		мНаименование = ПерекодироватьТест(мНаименование,КодировкаТекста.ANSI,КодировкаТекста.OEM);
	КонецЕсли;
	
	Объект.Драйвер.InitPLU();
	Объект.Драйвер.NumLine 			= 1;
	Объект.Драйвер.PLUName 			= Сред(мНаименование,1,24);
	Объект.Драйвер.NumLine 			= 2;
	Объект.Драйвер.PLUName 			= Сред(мНаименование,25,24);
	Объект.Драйвер.LabelFormat1 	= мФорматЕтикетки;
	Объект.Драйвер.BarcodeFormat 	= мФорматШтрихкода;
	Объект.Драйвер.UnitPrice 		= Окр(Цена*100,0);
	Объект.Драйвер.Weighed 			= Истина;
	Объект.Драйвер.EANData 			= ПолучитьШтрихкод(КодТовара,13);
	
	Если СрокГодности>0 Тогда
		Объект.Драйвер.SellByDate 		= Формат(СрокГодности,"ЧЦ=3; ЧВН=; ЧГ=0");
		Объект.Драйвер.PackedDate 		= "000";
		Объект.Драйвер.UsedByDate 		= Формат(СрокГодности,"ЧЦ=3; ЧВН=; ЧГ=0");
	КонецЕсли;
	
	//nКодОшибки 						= Объект.Драйвер.WritePLU(PLU); 
	nКодОшибки 						= Объект.Драйвер.WritePLU(КодТовара); 

	Если nКодОшибки>=0 Тогда
		Возврат Результат;
	КонецЕсли;	
	
	мОписаниеОшибки = "Помилка #"+Формат(nКодОшибки,"ЧГ=0");
	
	Если nКодОшибки>=-6 Тогда 
		мОписаниеОшибки = мОписаниеОшибки + ": Недостатньо ОЗУ.";
	ИначеЕсли nКодОшибки>=-5 Тогда
		мОписаниеОшибки = мОписаниеОшибки + ": Помилка запису.";
	Иначе
		мОписаниеОшибки = мОписаниеОшибки + ": Невідома помилка.";
	КонецЕсли;
	
	Объект.ОписаниеОшибки = мОписаниеОшибки;
	
	Результат = мОшибкаНеизвестно;

	Возврат Результат;
	
КонецФункции // Выгрузить()

// Функция осуществляет деинициализацию процедуры выгрузки данных в весы с печатью этикеток.
// (API v2.0)
//
// Параметры:
//  Объект                         - <*>
//                                 - Объект драйвера торгового оборудования.
//
// Возвращаемое значение:
//  <ПеречислениеСсылка.ТООшибки*> - Результат работы функции.
//
Функция ЗавершитьВыгрузку(Объект) Экспорт

	Результат = мНетОшибки;
	
	Отключить(Объект);
	
	Возврат Результат;

КонецФункции // ЗавершитьВыгрузку()

// Функция осуществляет выгрузку таблицы товаров в весы с печатью этикеток.
// (API v2.3)
//
// Параметры:
//  Объект                         - <*>
//                                 - Объект драйвера торгового оборудования.
//
//  Товары                         - <ТаблицаЗначений>
//                                 - Таблица товаров для выгрузки в весы.
//
// Возвращаемое значение:
//  <ПеречислениеСсылка.ТООшибки*> - Результат работы функции.
//
Функция ВыгрузитьТаблицу(Объект, Товары) Экспорт

	Результат = мНетОшибки;

	Результат = НачатьВыгрузку(Объект);
	
	Если Результат = мНетОшибки Тогда
		
		Для каждого Товар Из Товары Цикл
			
			Если НЕ Товар.Выгружать Тогда
				Продолжить;
			КонецЕсли;

			НаименованиеТовара = ПредставлениеТовара(Товар);
			Результат = Выгрузить(Объект, Товар.PLU,
			                              Товар.PLU,
			                              НаименованиеТовара,
			                              Товар.Цена);
			Если Результат <> мНетОшибки Тогда
				Прервать;
			КонецЕсли;
			
		КонецЦикла;

		Результат = ЗавершитьВыгрузку(Объект);
		
	КонецЕсли;

	Возврат Результат;

КонецФункции // Выгрузить()

&НаСервере
// Функция осуществляет очистку таблицы товаров в весы с печатью этикеток.
// (API v2.3)
//
// Параметры:
//  Объект                         - <*>
//                                 - Объект драйвера торгового оборудования.
//
// Возвращаемое значение:
//  <ПеречислениеСсылка.ТООшибки*> - Результат работы функции.
//
Функция ОчиститьТоварыВВесах(Объект) Экспорт

	Результат = мНетОшибки;

	Результат = НачатьВыгрузку(Объект);
	
	Если Результат = мНетОшибки Тогда
	
		nКодОшибки = Объект.Драйвер.DeleteTable(37); 

		Если nКодОшибки<0 Тогда
			
			мОписаниеОшибки = "Помилка #"+Формат(nКодОшибки,"ЧГ=0");
			
			Если nКодОшибки>=-1 Тогда 
				мОписаниеОшибки = мОписаниеОшибки + ": Недостатньо ОЗУ.";
			ИначеЕсли nКодОшибки>=-4 Тогда
				мОписаниеОшибки = мОписаниеОшибки + ": Помилка видалення.";
			ИначеЕсли nКодОшибки>=-3 Тогда 
				мОписаниеОшибки = мОписаниеОшибки + ": Немає таблиці з таким номером.";
			Иначе
				мОписаниеОшибки = мОписаниеОшибки + ": Невідома помилка.";
			КонецЕсли;
			
			Объект.ОписаниеОшибки = мОписаниеОшибки;
			
			Результат = мОшибкаНеизвестно;
			
		КонецЕсли;	
		
		Результат = ЗавершитьВыгрузку(Объект);
		
	КонецЕсли;

	Возврат Результат;

КонецФункции // ОчиститьТоварыВВесах()

