        //Малышев 2025-07-04 --)
		
		mhttp = Новый HTTPСоединение(Сервер,,,,,,Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаФайл(СокрЛП(СтруктураПараметров.Сертификат), СокрЛП(СтруктураПараметров.ПарольСертификата))));
	Иначе
		
		Если СтруктураПараметров.ИспользоватьТестовыйРежим Тогда
			Сервер = "test.tbconline.ge/dbi/dbiService";
		Иначе	
			Сервер = "tbconline.ge/dbi/dbiService";
		КонецЕсли;
		
		mhttp = Новый HTTPСоединение(Сервер,,,,,,Новый ЗащищенноеСоединениеOpenSSL());
	КонецЕсли;
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Accept-Encoding", "gzip,deflate");
	Заголовки.Вставить("Content-Type"	, "text/xml; charset=utf-8");
	Заголовки.Вставить("SoapAction"		, "http://www.mygemini.com/schemas/mygemini/"+СтруктураПараметров.Метод+"");
	Заголовки.Вставить("Connection"		, "Keep-Alive");
	Заголовки.Вставить("User-Agent"		, "Apache-HttpClient/4.1.1 (java 1.5)");
	
	Запрос = Новый HTTPЗапрос("/", Заголовки);
	
	USER = СтруктураПараметров.USER;
	PASSWORD = СтруктураПараметров.PASSWORD;
	Nonce = СтруктураПараметров.Nonce;
	ИмяМетода = СтруктураПараметров.Метод;
	ПрефиксЗапроса = СтруктураПараметров.ПрефиксЗапроса;
	СуфиксЗапроса = СтруктураПараметров.СуфиксЗапроса;
	ПервыйТэгСАтрибутами = СтруктураПараметров.ПервыйТэгСАтрибутами;
	МассивСсылокДокументовПакетов = Неопределено;
	
	xml = "";
	xml = xml + ПолучитьТекстШапки(USER, PASSWORD, Nonce, ИмяМетода, СуфиксЗапроса, ПервыйТэгСАтрибутами); 
	
	Если СтруктураПараметров.Метод = "GetAccountMovements" Тогда
		//Добавим фильтра если есть 
		Если СтруктураПараметров.Свойство("ФильтраЗапроса") Тогда 
			xml = xml + ДобавитьФильтры(СтруктураПараметров.ФильтраЗапроса, ПрефиксЗапроса);
		КонецЕсли;
		
	ИначеЕсли СтруктураПараметров.Метод = "GetPaymentOrderStatus" Тогда
		
		Если СтруктураПараметров.ЭтоПакет Тогда 
			xml = xml + "<" + ПрефиксЗапроса + "batchPaymentId>"+ СокрЛП(СтруктураПараметров.УИД) + "</" + ПрефиксЗапроса + "batchPaymentId>";
		Иначе
			xml = xml + "<" + ПрефиксЗапроса + "singlePaymentId>"+ СокрЛП(СтруктураПараметров.УИД) + "</" + ПрефиксЗапроса + "singlePaymentId>";
		КонецЕсли;
		
	ИначеЕсли СтруктураПараметров.Метод = "ImportSinglePaymentOrders" Тогда
		
		МассивСсылокДокументовПакетов = Новый Массив;
		тзПозиций = СтруктураПараметров.ТаблицаПозиций;
		
		ВыборкаДляЗаполнения = ПолучитьВыборкуЗаолненияПоДокументам(СтруктураПараметров.МассивДокументов);
		
		ТекстТэговРасходовСоСчетов = "";
		СчетчикПозиций = 1;
		КолвоДоковВЗапросе = 0;
		ПредыдущийДокумент = Неопределено;
		Пока ВыборкаДляЗаполнения.Следующий() Цикл 
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса + "singlePaymentOrder xsi:type=""" + ПрефиксЗапроса + ВыборкаДляЗаполнения["singlePaymentOrder"] + """>";
			
			Если НЕ ВыборкаДляЗаполнения.РазрешеноВыгрузить Тогда
				
				// с "" документы Зарплаты, которые выгружаются пакетом
				Если ВыборкаДляЗаполнения.Ссылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата
					ИЛИ ВыборкаДляЗаполнения.Ссылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников Тогда 
					МассивСсылокДокументовПакетов.Добавить(ВыборкаДляЗаполнения.Ссылка);
					Продолжить;
				Иначе
					
					Если ВыборкаДляЗаполнения.ОписатниеЗапрета <> "" Тогда 
						Сообщить(СтрЗаменить(СтрЗаменить(ВыборкаДляЗаполнения.ОписатниеЗапрета, "%ПарамДокументСсылка%", ВыборкаДляЗаполнения.Ссылка), "%ВидОперации%", ВыборкаДляЗаполнения.ВидОперации));
					КонецЕсли;
					
					Продолжить;
				КонецЕсли;
			Иначе                                                                                                         
				
				Если НЕ ЗначениеЗаполнено(ВыборкаДляЗаполнения.singlePaymentOrder) И Не ЗначениеЗаполнено(ВыборкаДляЗаполнения.CreditАccountNumber) Тогда
					Сообщить(НСтр("ru = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName +"'; ka = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName+"'"));
					Продолжить;
				КонецЕсли;
				
				Если ПредыдущийДокумент <> ВыборкаДляЗаполнения.Ссылка Тогда 
					КолвоДоковВЗапросе = КолвоДоковВЗапросе + 1;
					ПредыдущийДокумент = ВыборкаДляЗаполнения.Ссылка;
				КонецЕсли;
				
			КонецЕсли;
			
			СтруктураТэгов = СтруктураПараметров.СтруктурыТэгов[ВыборкаДляЗаполнения.singlePaymentOrder];
			
			Для Каждого Элем Из СтруктураТэгов Цикл 
				
				Если Элем.Ключ = "singlePaymentRequestId" Тогда 
					
					Если СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) <> "" Тогда 
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					КонецЕсли;
					
				ИначеЕсли Элем.Ключ = "documentNumber" Тогда 
					
					НомерДокумента = ВыборкаДляЗаполнения.documentNumber;
					НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(НомерДокумента, Истина, Истина);
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+"documentNumber>" + НомерДокумента + "</"+ПрефиксЗапроса+"documentNumber>";
					
				ИначеЕсли Элем.Ключ = "position" Тогда
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СчетчикПозиций + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					
					СтрокаПоизиции = тзПозиций.Добавить();
					СтрокаПоизиции.Позиция = Строка(СчетчикПозиций);
					СтрокаПоизиции.Сотрудник = ВыборкаДляЗаполнения.Сотрудник;
					СтрокаПоизиции.ДокументСсылка = ВыборкаДляЗаполнения.Ссылка;
					
					СчетчикПозиций = СчетчикПозиций + 1;
					//ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"ПрефиксЗапроса + Элем.Ключ + " xsi:type=""" + ПрефиксЗапроса + ВыборкаДляЗаполнения["singlePaymentOrder"] + """>";
				ИначеЕсли Элем.Значение = Неопределено Тогда 
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					
				ИначеЕсли ТипЗнч(Элем.Значение) = Тип("Структура") Тогда 
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">"; 
					Для Каждого ДопЭлемент Из Элем.Значение Цикл
						Если ДопЭлемент.Ключ = "amount" Тогда  
							ЦелаяЧасть = Цел(ВыборкаДляЗаполнения[ДопЭлемент.Ключ]);
							ДробнаяЧасть = ВыборкаДляЗаполнения[ДопЭлемент.Ключ] - ЦелаяЧасть;
							ЦелаяЧасть = СтрЗаменить(СтрЗаменить(СтрЗаменить(Строка(ЦелаяЧасть), ",", ""), Символы.НПП, ""),"", "");
							Если ДробнаяЧасть = 0 Тогда 
								ЗначенияПодстановки = ЦелаяЧасть;
							Иначе
								ЗначенияПодстановки = ЦелаяЧасть + "." + Сред(Строка(ДробнаяЧасть),3);
							КонецЕсли;
						Иначе
							
							ЗначенияПодстановки = СтрЗаменить(СтрЗаменить(Строка(ВыборкаДляЗаполнения[ДопЭлемент.Ключ]), ",", "."), Символы.НПП, "");
							
						КонецЕсли;
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+ДопЭлемент.Ключ+">" + СокрЛп(ЗначенияПодстановки) + "</"+ПрефиксЗапроса+ДопЭлемент.Ключ+">";
					КонецЦикла;
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса+Элем.Ключ+">";
				КонецЕсли;
			КонецЦикла;
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса + "singlePaymentOrder>";
			
		КонецЦикла;
		
		Если КолвоДоковВЗапросе = 0 Тогда 
			
			СтруктураОтвета = Новый Структура;
			Если МассивСсылокДокументовПакетов <> Неопределено И МассивСсылокДокументовПакетов.Количество() > 0 Тогда 
				СтруктураОтвета.Вставить("МассивСсылокДокументовПакетов", МассивСсылокДокументовПакетов);
			КонецЕсли;
			
			Возврат СтруктураОтвета;
			
		КонецЕсли;
		
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountNumber", "accountNumber");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "DebitАccountNumber", "accountNumber");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountCurrencyCode", "accountCurrencyCode");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "DebitАccountCurrencyCode", "accountCurrencyCode");
		
		xml = xml + ТекстТэговРасходовСоСчетов;
		
	ИначеЕсли СтруктураПараметров.Метод = "ImportBatchPaymentOrder" Тогда
		
		тзПозиций = СтруктураПараметров.ТаблицаПозиций;
		
		ВыборкаГруппыИмяПакета = ПолучитьВыборкуПакетногоЗаолненияПоДокументам(СтруктураПараметров.ТаблицаПакетнойВыгрузки);
		
		ТекстТэговРасходовСоСчетов = "";
		СчетчикПозиций = 1;
		
		КолвоДоковВЗапросе = 0;
		Пока ВыборкаГруппыИмяПакета.Следующий() Цикл 
			
			СчетчикПозиций = 1;
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов +"<myg:"+ИмяМетода+СуфиксЗапроса+">";
			
			ВыборкаГруппаНомерСчета = ВыборкаГруппыИмяПакета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаГруппаНомерСчета.Следующий() Цикл
				ВыборкаГруппаВалютаДебита = ВыборкаГруппаНомерСчета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаГруппаВалютаДебита.Следующий() Цикл
					//Дополним Текст Данными имени пакета и счата Дебита
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + ПолучитьТекстДебита(ВыборкаГруппаВалютаДебита);
					
					
					ВыборкаДляЗаполнения = ВыборкаГруппаВалютаДебита.Выбрать();
					
					Пока ВыборкаДляЗаполнения.Следующий() Цикл
						
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса + "paymentOrder xsi:type=""" + ПрефиксЗапроса + ВыборкаДляЗаполнения["singlePaymentOrder"] + """>";
						
						Если НЕ ВыборкаДляЗаполнения.РазрешеноВыгрузить Тогда
							
							// с "" документы Зарплаты, которые выгружаются пакетом
							Если ВыборкаДляЗаполнения.ОписатниеЗапрета <> "" Тогда 
								Сообщить(СтрЗаменить(СтрЗаменить(ВыборкаДляЗаполнения.ОписатниеЗапрета, "%ПарамДокументСсылка%", ВыборкаДляЗаполнения.Ссылка), "%ВидОперации%", ВыборкаДляЗаполнения.ВидОперации));
							КонецЕсли;
							
							Продолжить;
						Иначе
							
							Если НЕ ЗначениеЗаполнено(ВыборкаДляЗаполнения.singlePaymentOrder) И Не ЗначениеЗаполнено(ВыборкаДляЗаполнения.CreditАccountNumber) Тогда
								Сообщить(НСтр("ru = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName +"'; ka = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName+"'"));
								Продолжить;
							КонецЕсли;
							
							Если ПредыдущийДокумент <> ВыборкаДляЗаполнения.Ссылка Тогда 
								КолвоДоковВЗапросе = КолвоДоковВЗапросе + 1;
								ПредыдущийДокумент = ВыборкаДляЗаполнения.Ссылка;
							КонецЕсли;
							//КолвоДоковВЗапросе = КолвоДоковВЗапросе + 1;
							
						КонецЕсли;
						
						СтруктураТэгов = СтруктураПараметров.СтруктурыТэгов[ВыборкаДляЗаполнения.singlePaymentOrder];
						
						Для Каждого Элем Из СтруктураТэгов Цикл 
							
							Если Элем.Ключ = "singlePaymentRequestId" Тогда 
								
								//Повторная отправки выгруженного документа - не используется в конфигурации
								// создайте новый документ
								
							ИначеЕсли Элем.Ключ = "documentNumber" Тогда 
								
								НомерДокумента = ВыборкаДляЗаполнения.documentNumber;
								НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(НомерДокумента, Истина, Истина);
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+"documentNumber>" + НомерДокумента + "</"+ПрефиксЗапроса+"documentNumber>";
								
							ИначеЕсли Элем.Ключ = "position" Тогда
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СчетчикПозиций + "</"+ПрефиксЗапроса+Элем.Ключ+">";
								
								СтрокаПоизиции = тзПозиций.Добавить();
								СтрокаПоизиции.Позиция = Строка(СчетчикПозиций);
								СтрокаПоизиции.Сотрудник = ВыборкаДляЗаполнения.Сотрудник;
								СтрокаПоизиции.ДокументСсылка = ВыборкаДляЗаполнения.Ссылка;
								
								СчетчикПозиций = СчетчикПозиций + 1;
								
							ИначеЕсли Элем.Значение = Неопределено Тогда 
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
								
							ИначеЕсли ТипЗнч(Элем.Значение) = Тип("Структура") Тогда 
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">"; 
								Для Каждого ДопЭлемент Из Элем.Значение Цикл
									ЗначенияПодстановки = СтрЗаменить(СтрЗаменить(Строка(ВыборкаДляЗаполнения[ДопЭлемент.Ключ]), ",", "."), Символы.НПП, "");
									ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+ДопЭлемент.Ключ+">" + СокрЛП(ЗначенияПодстановки) + "</"+ПрефиксЗапроса+ДопЭлемент.Ключ+">";
								КонецЦикла;
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса+Элем.Ключ+">";
							КонецЕсли;
						КонецЦикла;
						
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса + "paymentOrder>";
						
					КонецЦикла;
				КонецЦикла;
				
			КонецЦикла;
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</myg:"+ИмяМетода+СуфиксЗапроса+">"
		КонецЦикла;
		
		Если КолвоДоковВЗапросе = 0 Тогда 
			Возврат новый Структура;
		КонецЕсли;
		
		//
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountNumber", "accountNumber");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountCurrencyCode", "accountCurrencyCode");
		
		xml = xml + ТекстТэговРасходовСоСчетов;
		
	КонецЕсли;
	
	xml = xml + ПолучитьТекстОкончания(ИмяМетода, СуфиксЗапроса);
	
	Запрос.УстановитьТелоИзСтроки(xml, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.Использовать);
	
	//mhttp.send(xml);
	Результат = mhttp.ОтправитьДляОбработки(Запрос);
	//res = mhttp.WaitForResponse();
	res = Результат.КодСостояния;
	
	//СтрокаJSONРезультат = mhttp.responseText;
	СтрокаJSONРезультат = Результат.ПолучитьТелоКакСтроку(); 
	СтрокаJSONРезультатОригенал = СтрокаJSONРезультат; //+++ Дмгг, 15.02.24, ONESOFT-2913
	
	Если СтрНайти(СтрокаJSONРезультат, "Error 500") > 0 Тогда
		Сообщить(НСтр("ka='შეცდომა მოთხოვნის გაგზავნისას';ru='Ошибка отправки запроса';en='Error sending request'") + Символы.НПП + СтрокаJSONРезультат);
		
		СтруктураОтвета = Новый Структура;
		Если МассивСсылокДокументовПакетов <> Неопределено И МассивСсылокДокументовПакетов.Количество() > 0 Тогда 
			СтруктураОтвета.Вставить("МассивСсылокДокументовПакетов", МассивСсылокДокументовПакетов);
		КонецЕсли;
		
		Возврат СтруктураОтвета;
	КонецЕсли;
	
	ТэгМетода = СтруктураПараметров.ПрефиксОтвета + СтруктураПараметров.Метод + СтруктураПараметров.СуфиксОтвета;
	ПозицНачТега = СтрНайти(СтрокаJSONРезультат, "<"+ТэгМетода);
	ПозицНачОшибки = СтрНайти(СтрокаJSONРезультат, "<faultstring");
	Если ПозицНачТега <> 0 Тогда 
		ДлинаКон = СтрДлина("</"+ТэгМетода+">");
		ПозцКон = СтрНайти(СтрокаJSONРезультат, "</"+ТэгМетода+">");
		СтрокаJSONРезультат = Сред(СтрокаJSONРезультат,ПозицНачТега, ПозцКон + ДлинаКон - ПозицНачТега);
	ИначеЕсли ПозицНачОшибки <> 0 Тогда
		//Вытянем текст Ошибки
		ДлинаКон = СтрДлина("</faultstring>");
		ПозцКон = СтрНайти(СтрокаJSONРезультат, "</faultstring>");
		ДлиннаНачТега = 27;
		ТекстОшибки = Сред(СтрокаJSONРезультат, ПозицНачОшибки + ДлиннаНачТега, ПозцКон - (ПозицНачОшибки+ДлиннаНачТега));
		
		СтруктураОтвета = Новый Структура;
		Если МассивСсылокДокументовПакетов <> Неопределено И МассивСсылокДокументовПакетов.Количество() > 0 Тогда 
			СтруктураОтвета.Вставить("МассивСсылокДокументовПакетов", МассивСсылокДокументовПакетов);
		КонецЕсли;
		
		СтруктураОтвета.Вставить("ТекстОшибки", ТекстОшибки);
		
		Возврат СтруктураОтвета;
		
	КонецЕсли;

	ПутьКВременномуФайлуОтвета = ПолучитьИмяВременногоФайла("xml"); 
	ЗаписьXML = Новый ЗаписьXML;
	
	ЗаписьXML.ОткрытьФайл(ПутьКВременномуФайлуОтвета);
	
	ЗаписьXML.ЗаписатьОбъявлениеXML();    
	
	ЗаписьXML.ЗаписатьБезОбработки(СтрокаJSONРезультат);
	
	ЗаписьXML.Закрыть();
	
	///////////////////////////////////
	//Прочитаем
	
	//+++ Дмгг, 15.02.24, ОбъектXDTO
	//СтруктураОтвета = ПрочитатьФайлОтвета(ПутьКВременномуФайлуОтвета, СтруктураПараметров); 
	СтруктураОтвета = ПрочитатьФайлОтветаИзСтрокиРезультата(СтрокаJSONРезультатОригенал, СтруктураПараметров); 
	//--- Дмгг, 15.02.24, ОбъектXDTO
	
	УдалитьФайлы(ПутьКВременномуФайлуОтвета);
	
	Если МассивСсылокДокументовПакетов <> Неопределено И МассивСсылокДокументовПакетов.Количество() > 0 Тогда 
		СтруктураОтвета.Вставить("МассивСсылокДокументовПакетов", МассивСсылокДокументовПакетов);
	КонецЕсли;
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция ПолучитьВыборкуУИД(Банк)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.ДокументСсылка,
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке
		|ПОМЕСТИТЬ ТаблицаСрезСтатусов
		|ИЗ
		|	РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(, Банк = &Банк) КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаСрезСтатусов.ДокументСсылка,
		|	ТаблицаСрезСтатусов.СтатусДокументаВИнтернетБанке,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД
		|ПОМЕСТИТЬ ТаблицаПред
		|ИЗ
		|	ТаблицаСрезСтатусов КАК ТаблицаСрезСтатусов,
		|	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПред.ДокументСсылка,
		|	ТаблицаПред.СтатусДокументаВИнтернетБанке,
		|	ТаблицаПред.УИД
		|ИЗ
		|	ТаблицаПред КАК ТаблицаПред
		|ГДЕ
		|	ТаблицаПред.СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.S)
		|			И ТаблицаПред.СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка)
		|	И ТаблицаПред.УИД <> """"
		|	И (ТаблицаПред.ДокументСсылка ССЫЛКА Документ.РасходСоСчета
		|			ИЛИ ТаблицаПред.ДокументСсылка ССЫЛКА Документ.Конвертация)";
	
	Запрос.УстановитьПараметр("Банк", Банк);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выбрать();
	
