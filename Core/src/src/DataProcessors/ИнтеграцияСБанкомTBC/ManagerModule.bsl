Процедура ЗаполнитьСтруктуруОтветаРекурсиеей(ОбъектXDTO, СтруктураЗаполнения, КлючПредыдущейСтруктуры = "")
	
	Для Каждого Строк Из ОбъектXDTO.Свойства() Цикл 
		
		Если ТипЗнч(ОбъектXDTO[Строк.Имя]) = Тип("ОбъектXDTO") Тогда 
			СледующаяСтруктура = Новый Структура;
			СтруктураЗаполнения.Вставить(Строк.Имя, СледующаяСтруктура);
			ЗаполнитьСтруктуруОтветаРекурсиеей(ОбъектXDTO[Строк.Имя], СледующаяСтруктура, Строк.Имя);
		ИначеЕсли ТипЗнч(ОбъектXDTO[Строк.Имя]) = Тип("СписокXDTO") Тогда
			
			МассивСтрокСписка = Новый Массив;
			
			
			Для Каждого СтрокаСписка Из (ОбъектXDTO[Строк.Имя]) Цикл 
				
				СледующаяСтруктура = Новый Структура;
				СтруктураЗаполнения.Вставить(Строк.Имя, СледующаяСтруктура);
				ЗаполнитьСтруктуруОтветаРекурсиеей(СтрокаСписка, СледующаяСтруктура, Строк.Имя);
				МассивСтрокСписка.Добавить(СледующаяСтруктура)
					
			КонецЦикла;
			
			СтруктураЗаполнения.Вставить(Строк.Имя, МассивСтрокСписка)
			
		ИначеЕсли ТипЗнч(ОбъектXDTO[Строк.Имя]) = Тип("Строка") Тогда 
			//Если КлючПредыдущейСтруктуры <> "" Тогда 
				СтруктураЗаполнения.Вставить(Строк.Имя, ОбъектXDTO[Строк.Имя]);
			//КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры

Функция ОбработатьТекстДляXML(Значение)
	
	ЗначениеВозврата = Значение;
	Если ТипЗнч(Значение) = Тип("Дата") Тогда 
		ЗначениеВозврата = ДатаВремяВСтроку(ЗначениеВозврата);
	КонецЕсли;
	
	ЗначениеВозврата = ЗаменитьНедопустимыСимволы(ЗначениеВозврата);
	
	Возврат ЗначениеВозврата;	
	
КонецФункции

Функция  ЗаменитьНедопустимыСимволы(Значение)
	
	ПЕРЕМ РЕЗ;
	
	РЕЗ=Строка(Значение);
	
	ТекДлинаСтроки = СтрДлина(Значение);
	
	РЕЗ=СтрЗаменить(РЕЗ,"&","&amp;");
	РЕЗ=СтрЗаменить(РЕЗ,"<","&lt;");
	РЕЗ=СтрЗаменить(РЕЗ,">","&gt;");
	РЕЗ=СтрЗаменить(РЕЗ,"'","&apos;");
	РЕЗ=СтрЗаменить(РЕЗ,"""","&quot;");
	
	Возврат РЕЗ
	
КонецФункции

Функция ДатаВремяВСтроку(Дата) 
	
	Если не ЗначениеЗаполнено(Дата) Тогда
		Возврат "";
	Иначе
		ДатаСтрока = Строка(Формат(Дата, "ДФ='yyyy-MM-dd'")) + "T" + Строка(Формат(Дата, "ДФ=HH:mm:ss"));
		Возврат ДатаСтрока;
	КонецЕсли;
	
КонецФункции