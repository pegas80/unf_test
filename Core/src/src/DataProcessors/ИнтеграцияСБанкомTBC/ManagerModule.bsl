	    |		ПО ВТ_ПредПроверка.Ссылка = ВТ_ДанныеДокументов.Ссылка
	    |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВыгружаемыхДокументов КАК ВТ_ВыгружаемыхДокументов
	    |		ПО ВТ_ПредПроверка.Ссылка = ВТ_ВыгружаемыхДокументов.ДокументСсылка
	    |ИТОГИ ПО
	    |	batchName,
	    |	DebitАccountNumber,
	    |	DebitАccountCurrencyCode";
	
	Запрос.УстановитьПараметр("ТаблицаПакетнойВыгрузки", ТаблицаПакетнойВыгрузки);
	//Запрос.УстановитьПараметр("МассивДоументов", МассивДокументов);
	Запрос.УстановитьПараметр("НацВалюта", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НациональнаяВалюта"));
	Запрос.УстановитьПараметр("КодЯзвка", ПользователиИнформационнойБазы.ТекущийПользователь().Язык.КодЯзыка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Функция ПолучитьТекстОкончания(ИмяМетода, Суффикс);
	
	ТекстВозврата = "";
	
	Если ИмяМетода <> "ImportBatchPaymentOrder" Тогда 
		ТекстВозврата = ТекстВозврата +"</myg:"+ИмяМетода+Суффикс+">";
	КонецЕсли;
	 
	ТекстВозврата = ТекстВозврата +"</soapenv:Body>"
	+"</soapenv:Envelope>";
	
	Возврат ТекстВозврата;
	
КонецФункции

Функция ПрочитатьФайлОтвета(ПутьКФайлу, СтруктураПараметров)
	
	ЧтениеТекста = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
	
	СтрокаXML = ЧтениеТекста.Прочитать();
	
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(СтрокаXML);
	
	РезультатРазборки = Новый Массив;
	
	ТипОбъектаXDTO = ФабрикаXDTO.Тип("http://schemas.xmlsoap.org/soap/envelope/", "Разборка");
	
	БлокXDTO = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
	
	СтруктураОтвета = Новый Структура;
	
	ЗаполнитьСтруктуруОтветаРекурсиеей(БлокXDTO, СтруктураОтвета);
	
	Возврат СтруктураОтвета;
	
КонецФункции

