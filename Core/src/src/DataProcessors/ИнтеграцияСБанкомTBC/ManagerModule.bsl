		|	ВТ_ДанныеДокументов.debitАccountCurrencyCodeИмяРеквизита КАК DebitАccountCurrencyCodeИмяРеквизита,
		|	ВТ_ДанныеДокументов.documentNumberИмяРеквизита,
		|	ВТ_ДанныеДокументов.amountИмяРеквизита,
		|	ВТ_ДанныеДокументов.currencyИмяРеквизита,
		|	ВТ_ДанныеДокументов.descriptionИмяРеквизита,
		|	ВТ_ДанныеДокументов.additionalDescriptionИмяРеквизита,
		|	ВТ_ДанныеДокументов.beneficiaryNameИмяРеквизита,
		|	ВТ_ДанныеДокументов.beneficiaryTaxCodeИмяРеквизита,
		|	ВТ_ДанныеДокументов.beneficiaryAddressИмяРеквизита,
		|	ВТ_ДанныеДокументов.beneficiaryBankCodeИмяРеквизита,
		|	ВТ_ДанныеДокументов.beneficiaryBankNameИмяРеквизита,
		|	ВТ_ДанныеДокументов.intermediaryBankCodeИмяРеквизита,
		|	ВТ_ДанныеДокументов.intermediaryBankNameИмяРеквизита,
		|	ВТ_ДанныеДокументов.chargeDetailsИмяРеквизита,
		|	ВТ_ДанныеДокументов.Сотрудник,
		|	ВТ_ДанныеДокументов.taxpayerCode,
		|	ВТ_ДанныеДокументов.taxpayerName,
		|	ВТ_ДанныеДокументов.treasuryCode,
		|	ВТ_ДанныеДокументов.taxpayerCodeИмяРеквизита,
		|	ВТ_ДанныеДокументов.taxpayerNameИмяРеквизита,
		|	ВТ_ДанныеДокументов.treasuryCodeИмяРеквизита
		|ИЗ
		|	ВТ_ПредПроверка КАК ВТ_ПредПроверка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеДокументов КАК ВТ_ДанныеДокументов
		|		ПО ВТ_ПредПроверка.Ссылка = ВТ_ДанныеДокументов.Ссылка";
	
	Запрос.УстановитьПараметр("МассивДоументов", МассивДокументов);
	Запрос.УстановитьПараметр("НацВалюта", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НациональнаяВалюта"));
	Запрос.УстановитьПараметр("КодЯзвка", ПользователиИнформационнойБазы.ТекущийПользователь().Язык.КодЯзыка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Функция ПолучитьВыборкуПакетногоЗаолненияПоДокументам(ТаблицаПакетнойВыгрузки)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	    "ВЫБРАТЬ
	    |	ТЗ.ДокументСсылка КАК ДокументСсылка,
	    |	ВЫРАЗИТЬ(ТЗ.ИмяПакета КАК СТРОКА(50)) КАК ИмяПакета,
	    |	ТЗ.БанковскийСчет КАК БанковскийСчет
	    |ПОМЕСТИТЬ ВТ_ВыгружаемыхДокументов
	    |ИЗ
	    |	&ТаблицаПакетнойВыгрузки КАК ТЗ
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ
	    |	РасходСоСчета.Ссылка,
	    |	ЕСТЬNULL(СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИНтернетБанке.ПрисутствуетТолькоВТекущейБазе)) КАК ТекущийСтатусДокумента,
	    |	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД,
	    |	ВЫБОР
	    |		КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Прочее)
	    |				ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.НаРасходы)
	    |			ТОГДА ЛОЖЬ
	    |		ИНАЧЕ ВЫБОР
	    |				КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
	    |						И РасходСоСчета.Проведен
	    |						И НЕ РасходСоСчета.ПометкаУдаления
	    |					ТОГДА ИСТИНА
	    |				ИНАЧЕ ЛОЖЬ
	    |			КОНЕЦ
	    |	КОНЕЦ КАК РазрешеноВыгрузить,
	    |	ВЫБОР
	    |		КОГДА &КодЯзвка = ""ru""
	    |			ТОГДА ВЫБОР
	    |					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Прочее)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ПрочиеРасчеты)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.НаРасходы)
	    |						ТОГДА ""Документ %ПарамДокументСсылка%: Выгрузка вида операции %ВидОперации% не предусмотрена""
	    |					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Зарплата)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников)
	    |						ТОГДА """"
	    |					ИНАЧЕ ВЫБОР
	    |							КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") <> """"
	    |								ТОГДА ""Документ %ПарамДокументСсылка%: был ранее выгружен""
	    |							КОГДА НЕ РасходСоСчета.Проведен
	    |								ТОГДА ""Документ %ПарамДокументСсылка%: должен быть проведенным""
	    |							КОГДА РасходСоСчета.ПометкаУдаления
	    |								ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы помеченые на удаление""
	    |							ИНАЧЕ """"
	    |						КОНЕЦ
	    |				КОНЕЦ
	    |		КОГДА &КодЯзвка = ""ka""
	    |			ТОГДА ВЫБОР
	    |					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Прочее)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ПрочиеРасчеты)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.НаРасходы)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ПенсионномуФонду)
	    |						ТОГДА ""Документ %ПарамДокументСсылка%: Выгрузка вида операции %ВидОперации% не предусмотрена""
	    |					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Зарплата)
	    |							ИЛИ РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников)
	    |						ТОГДА """"
	    |					ИНАЧЕ ВЫБОР
	    |							КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") <> """"
	    |								ТОГДА ""Документ %ПарамДокументСсылка%: был ранее выгружен""
	    |							КОГДА НЕ РасходСоСчета.Проведен
	    |								ТОГДА ""Документ %ПарамДокументСсылка%: должен быть проведенным""
	    |							КОГДА РасходСоСчета.ПометкаУдаления
	    |								ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы помеченые на удаление""
	    |							ИНАЧЕ """"
	    |						КОНЕЦ
	    |				КОНЕЦ
	    |	КОНЕЦ КАК ОписатниеЗапрета,
	    |	РасходСоСчета.ВидОперации
	    |ПОМЕСТИТЬ ВТ_ПредПроверка
	    |ИЗ
	    |	Документ.РасходСоСчета КАК РасходСоСчета
	    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	    |		ПО РасходСоСчета.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
	    |			И РасходСоСчета.БанковскийСчет.Банк = УИДДокументовВИнтернетБанке.Банк
	    |			И (ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) = УИДДокументовВИнтернетБанке.Сотрудник)
	    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
	    |		ПО РасходСоСчета.Ссылка = СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке
	    |			И РасходСоСчета.БанковскийСчет.Банк = СтатусыДокументовВИнтернетБанкеСрезПоследних.Банк
	    |			И (ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) = СтатусыДокументовВИнтернетБанкеСрезПоследних.Сотрудник)
	    |ГДЕ
	    |	РасходСоСчета.Ссылка В
	    |			(ВЫБРАТЬ
	    |				а.ДокументСсылка
	    |			ИЗ
	    |				ВТ_ВыгружаемыхДокументов КАК а)
	    |
	    |ОБЪЕДИНИТЬ ВСЕ
	    |
	    |ВЫБРАТЬ
	    |	Конвертация.Ссылка,
	    |	ЕСТЬNULL(СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИНтернетБанке.ПрисутствуетТолькоВТекущейБазе)),
	    |	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """"),
	    |	ВЫБОР
	    |		КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	    |			ТОГДА ВЫБОР
	    |					КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
	    |							И Конвертация.Проведен
	    |							И НЕ Конвертация.ПометкаУдаления
	    |						ТОГДА ИСТИНА
	    |					ИНАЧЕ ЛОЖЬ
	    |				КОНЕЦ
	    |		ИНАЧЕ ЛОЖЬ
	    |	КОНЕЦ,
	    |	ВЫБОР
	    |		КОГДА &КодЯзвка = ""ru""
	    |			ТОГДА ВЫБОР
	    |					КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	    |						ТОГДА ВЫБОР
	    |								КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") <> """"
	    |									ТОГДА ""Документ %ПарамДокументСсылка%: был ранее выгружен""
	    |								КОГДА НЕ Конвертация.Проведен
	    |									ТОГДА ""Документ %ПарамДокументСсылка%: должен быть проведенным""
	    |								КОГДА Конвертация.ПометкаУдаления
	    |									ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы помеченые на удаление""
	    |								ИНАЧЕ """"
	    |							КОНЕЦ
	    |					ИНАЧЕ ""Документ %ПарамДокументСсылка%: Выгрузка вида операции %ВидОперации% не предусмотрена""
	    |				КОНЕЦ
	    |		КОГДА &КодЯзвка = ""ka""
	    |			ТОГДА ВЫБОР
	    |					КОГДА Конвертация.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКонвертация.СоСчета)
	    |						ТОГДА ВЫБОР
	    |								КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") <> """"
	    |									ТОГДА ""Документ %ПарамДокументСсылка%: был ранее выгружен""
	    |								КОГДА НЕ Конвертация.Проведен
	    |									ТОГДА ""Документ %ПарамДокументСсылка%: должен быть проведенным""
	    |								КОГДА Конвертация.ПометкаУдаления
	    |									ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы помеченые на удаление""
	    |								ИНАЧЕ """"
	    |							КОНЕЦ
	    |					ИНАЧЕ ""Документ %ПарамДокументСсылка%: Выгрузка вида операции %ВидОперации% не предусмотрена""
	    |				КОНЕЦ
	    |	КОНЕЦ,
	    |	Конвертация.ВидОперации
	    |ИЗ
	    |	Документ.Конвертация КАК Конвертация
	    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	    |		ПО Конвертация.Ссылка = УИДДокументовВИнтернетБанке.ДокументСсылка
	    |			И Конвертация.Отправитель.Банк = УИДДокументовВИнтернетБанке.Банк
	    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
	    |		ПО Конвертация.Ссылка = СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке
	    |			И Конвертация.Отправитель.Банк = СтатусыДокументовВИнтернетБанкеСрезПоследних.Банк
	    |ГДЕ
	    |	Конвертация.Ссылка В
	    |			(ВЫБРАТЬ
	    |				а.ДокументСсылка
	    |			ИЗ
	    |				ВТ_ВыгружаемыхДокументов КАК а)
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ
	    |	""Поставщику"" КАК ВидОперации,
	    |	РасходСоСчета.Ссылка,
	    |	ВЫБОР
	    |		КОГДА РасходСоСчета.ВалютаДенежныхСредств = &НацВалюта
	    |				И РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК = РасходСоСчета.СчетКонтрагента.Банк.СВИФТБИК
	    |			ТОГДА ""TransferWithinBankPaymentOrderIo""
	    |		КОГДА РасходСоСчета.ВалютаДенежныхСредств <> &НацВалюта
	    |				И РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК = РасходСоСчета.СчетКонтрагента.Банк.СВИФТБИК
	    |			ТОГДА ""TransferWithinBankPaymentOrderIo""
	    |		КОГДА РасходСоСчета.ВалютаДенежныхСредств = &НацВалюта
	    |				И РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК <> РасходСоСчета.СчетКонтрагента.Банк.СВИФТБИК
	    |			ТОГДА ""TransferToOtherBankNationalCurrencyPaymentOrderIo""
	    |		КОГДА РасходСоСчета.ВалютаДенежныхСредств <> &НацВалюта
	    |				И РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК <> РасходСоСчета.СчетКонтрагента.Банк.СВИФТБИК
	    |			ТОГДА ""TransferToOtherBankForeignCurrencyPaymentOrderIo""
	    |	КОНЕЦ КАК singlePaymentOrder,
	    |	ПОДСТРОКА(РасходСоСчета.СчетКонтрагента.НомерСчета, 0, 22) КАК creditАccountNumber,
	    |	РасходСоСчета.СчетКонтрагента.ВалютаДенежныхСредств.Наименование КАК creditАccountCurrencyCode,
	    |	ПОДСТРОКА(РасходСоСчета.БанковскийСчет.НомерСчета, 0, 22) КАК debitАccountNumber,
	    |	РасходСоСчета.БанковскийСчет.ВалютаДенежныхСредств.Наименование КАК debitАccountCurrencyCode,
	    |	РасходСоСчета.Номер КАК documentNumber,
	    |	РасходСоСчета.СуммаДокумента КАК amount,
	    |	РасходСоСчета.ВалютаДенежныхСредств.Наименование КАК currency,
	    |	РасходСоСчета.НазначениеПлатежа КАК description,
	    |	РасходСоСчета.НазначениеПлатежа КАК additionalDescription,
	    |	ВЫБОР
	    |		КОГДА (ВЫРАЗИТЬ(РасходСоСчета.Контрагент.НаименованиеПолное КАК СТРОКА(150))) = """"
	    |			ТОГДА РасходСоСчета.Контрагент.Наименование
	    |		ИНАЧЕ РасходСоСчета.Контрагент.НаименованиеПолное
	    |	КОНЕЦ КАК beneficiaryName,
	    |	РасходСоСчета.Контрагент.ИНН КАК beneficiaryTaxCode,
	    |	РасходСоСчета.Контрагент.СтранаРегистрации.Наименование КАК beneficiaryAddress,
	    |	РасходСоСчета.СчетКонтрагента.Банк.СВИФТБИК КАК beneficiaryBankCode,
	    |	РасходСоСчета.СчетКонтрагента.Банк.Представление КАК beneficiaryBankName,
