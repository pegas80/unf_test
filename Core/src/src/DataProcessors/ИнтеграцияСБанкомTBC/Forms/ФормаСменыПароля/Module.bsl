
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Сертификат") Тогда 
		Сертификат = Параметры.Сертификат;
	КонецЕсли;
	
	Если Параметры.Свойство("ПарольСертификата") Тогда 
		ПарольСертификата = Параметры.ПарольСертификата;
	КонецЕсли;
	
	Если Параметры.Свойство("ИспользоватьТестовыйРежим") Тогда 
		ИспользоватьТестовыйРежим = Параметры.ИспользоватьТестовыйРежим;
	Иначе
		ИспользоватьТестовыйРежим = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму(Команда)
	ЭтаФорма.Закрыть();
КонецПроцедуры

