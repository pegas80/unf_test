				впНоваяСтрокаДок.Документ	= ДокОбъект.Ссылка;
				впНоваяСтрокаДок.Проведен	= Ложь;
			Иначе
				Попытка
					ДокОбъект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
					впНоваяСтрокаДок = Объект.СозданныеДокументы.Добавить();
					впНоваяСтрокаДок.Документ	= ДокОбъект.Ссылка;
					впНоваяСтрокаДок.Проведен	= Истина;
				Исключение
					ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
					впНоваяСтрокаДок = Объект.СозданныеДокументы.Добавить();
					впНоваяСтрокаДок.Документ	= ДокОбъект.Ссылка;
					впНоваяСтрокаДок.Проведен	= Ложь;
				КонецПопытки;
				// Олег Литвиненко 20.06.23 --->
				ИмяТабЧасти = "СозданныеДокументы";
				// Олег Литвиненко <---
			КонецЕсли;
			
			//Малышев 2025-07-18 отменил доработки Lazare
			СтрокаТТН.Документ			= ДокОбъект.Ссылка;
			СтрокаТТН.Флаг				= Ложь;
			СтрокаТТН.ДокументПревязан 	= Истина;
			
			//_Lazare
			//ОтмеченныеСтрокиТТН = Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Флаг, ЕстьОшибки, Полученный, НомерСтроки", Истина, Ложь, Истина, СтрокаТТН.НомерСтроки));
			ОтмеченныеСтрокиТТН = Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("НомерСтроки", СтрокаТТН.НомерСтроки));
