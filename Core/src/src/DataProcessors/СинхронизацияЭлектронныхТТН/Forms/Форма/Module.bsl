
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтавкаНДС18 = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС18"));
	ИспользоватьДокументыВА = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьДокументыВАДляЭлектронныхНакладных");
	Элементы.ТоварныеНакладныеНаПорталеЭтаИмущество.Видимость = ИспользоватьДокументыВА;
	
	Полученный						= Истина;
	СтатусТТНАктивный				= Истина;
	ВнутреннееПеремещение 			= Истина;
	РеализацияСТранспортировкой		= Истина;
	РеализацияБезТранспортировки	= Истина;
	Дистрибуция 					= Ложь;
	ВозвратПокупателяПокупателю 	= Истина;
	ПодчиненнаяТН					= Ложь;
	
	ДатаКон 			= ТекущаяДата();
	ДатаНач 			= ДатаКон - 86400*2;
	НациональнаяВалюта 	= УправлениеНебольшойФирмойПовтИсп.ПолучитьНациональнуюВалюту();
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Организация = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		Пользователи.ТекущийПользователь(),
		"ОсновнаяОрганизация");
		Если НЕ ЗначениеЗаполнено(Организация) Тогда
			Организация = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.Организации.ОсновнаяОрганизация");
		КонецЕсли;
	КонецЕсли;
	ЗаполнитьСоответствиеНоменклатуры();
	УчетЦенКонтрагентов = ПолучитьФункциональнуюОпцию("УчетЦенКонтрагентов");
	
	// Олег Литвиненко 14.06.23 --->
	ЗаполнениеРеквизитовСинхронизацияЭлектронныхТТН = ПолучитьФункциональнуюОпцию("ЗаполнениеРеквизитовСинхронизацияЭлектронныхТТН");
	// Олег Литвиненко <---
	
	//++Lazare 13.11.2023
	ПрихОрдВоВремяСинхронизациТТН = Константы.СоздатьПриходныйхОрдровВоВремяСинхронизациТТН.Получить();
	Элементы.ГруппаПриходныеОрдеры.Видимость = ПрихОрдВоВремяСинхронизациТТН;
	Элементы.СоздатьПрихадниеОрдери.Видимость = ПрихОрдВоВремяСинхронизациТТН;  
	Элементы.ТоварныеНакладныеНаПорталеОрдер.Видимость = ПрихОрдВоВремяСинхронизациТТН;
	Элементы.ТоварныеНакладныеНаПорталеПрихОрдер.Видимость = ПрихОрдВоВремяСинхронизациТТН;
	//--Lazare 13.11.2023	
КонецПроцедуры
&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗаполнитьСоответствиеНоменклатуры();
КонецПроцедуры
&НаКлиенте
Процедура ДатаНачПриИзменении(Элемент)
	
	ДанныеНеСоответствуютФильтру = Истина;
	УстановитьТекстПодсказки();
	
КонецПроцедуры
&НаКлиенте
Процедура ДатаКонПриИзменении(Элемент)
	
	ДанныеНеСоответствуютФильтру = Истина;
	УстановитьТекстПодсказки();
	
КонецПроцедуры
&НаКлиенте
Процедура ПоставщикПриИзменении(Элемент)
	
	ДанныеНеСоответствуютФильтру = Истина;
	УстановитьТекстПодсказки();
	
КонецПроцедуры
&НаКлиенте
Процедура ТоварныеНакладныеНаПорталеКонтрагентПриИзменении(Элемент)
	
	ТекДанные = Элементы.ТоварныеНакладныеНаПортале.ТекущиеДанные;
	ПоставщикПокупатель = УправлениеНебольшойФирмойСервер.ЗначенияРеквизитовОбъекта(ТекДанные.Контрагент, "Поставщик,Покупатель");
	ТекДанные.Поставщик		= ПоставщикПокупатель.Поставщик;
	ТекДанные.Покупатель	= ПоставщикПокупатель.Покупатель;
	
КонецПроцедуры


&НаКлиенте
Процедура ОбновитьДанные(Команда)
	
	ОчиститьСообщения();
	ОбновитьДанныеНаСервере();
	
КонецПроцедуры
&НаСервере
Процедура ОбновитьДанныеНаСервере()
	
	Объект.ТоварныеНакладныеНаПортале.Очистить();
	Объект.ТоварыНаПортале.Очистить();
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Сообщить(НСтр("ka='არ არის შევსებული შევსებული ველი ""ორგანიზაცია"".';ru='Не заполнен поле ""Организация""';en='Do not fill in the ""Organization""'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаНач) Или Не ЗначениеЗаполнено(ДатаКон) Тогда
		Сообщить(НСтр("ka='არ არის შევსებული პერიოდი';ru='Не заполнен период';en='Not full time'"));
		Возврат;
	КонецЕсли;
	
	Колво = 0;
	ТаблицаНакладных		= Объект.ТоварныеНакладныеНаПортале.Выгрузить();
	ТаблицаТоварыНакладных	= Объект.ТоварыНаПортале.Выгрузить();
	ИННКонтрагента			= СокрЛП(Контрагент.ИНН);
	itypes = "";
	Если ВнутреннееПеремещение 			Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",1", "1"); КонецЕсли;//1 გადაადგილება
	Если РеализацияСТранспортировкой 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",2", "2"); КонецЕсли;//2 რეალიზაცია ტრანსპორტირებით
	Если РеализацияБезТранспортировки 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",3", "3"); КонецЕсли;//3 რეალიზაცია ტრანსპორტირების გარეშე
	Если Дистрибуция 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",4", "4"); КонецЕсли;//4 დისტრიბუცია
	Если ВозвратПокупателяПокупателю 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",5", "5"); КонецЕсли;//5 უკან დაბრუნება
	Если ПодчиненнаяТН 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",6", "6"); КонецЕсли;//6 ქვე-ზედნადები
	
	П_Обработки = Новый Структура;
	П_Обработки.Вставить("Организация", 		Организация);
	П_Обработки.Вставить("ДатаНач", 			НачалоДня(ДатаНач));
	П_Обработки.Вставить("ДатаКон", 			КонецДня(ДатаКон));
	П_Обработки.Вставить("ИННКонтрагента",		ИННКонтрагента);
	П_Обработки.Вставить("itypes", 				itypes);
	
	
	Statuses = ",";
	Если СтатусТТНАктивный		Тогда statuses = ?(statuses = ",", statuses + "1", 	statuses + ",1");	КонецЕсли;//1 აქტიური
	Если СтатусТТНДоставленный	Тогда statuses = ?(statuses = ",", statuses + "2", 	statuses + ",2");	КонецЕсли;//2 დასრულებული
	
	//მიღებული
	Если Полученный И НЕ Statuses = "," Тогда
		П_Обработки.Вставить("Statuses", 			Statuses + ",");
	
		триДня 			= 86400 * 2;
		Если НачалоДня(ДатаКон) - НачалоДня(ДатаНач) <= триДня Тогда
			ТаблицаНакладных.Очистить();
			ТаблицаТоварыНакладных.Очистить();
			П_Обработки.Вставить("SoapAction", 		"get_buyer_waybills");
			
			ДанныеПриниятихНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
			Если НЕ ДанныеПриниятихНакладных = Неопределено Тогда
				П_Обработки.Вставить("SoapAction", 		"get_buyer_waybilll_goods_list");
				ДанныеТабПриниятихНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
				Если НЕ ДанныеТабПриниятихНакладных = Неопределено Тогда
					Объект.ТоварныеНакладныеНаПортале.Загрузить(ТаблицаНакладных);	
					Объект.ТоварыНаПортале.Загрузить(ТаблицаТоварыНакладных);
					Для Каждого нТоварыНаПортале ИЗ Объект.ТоварыНаПортале Цикл
						Если нТоварыНаПортале.VAT_TYPE = "0" Тогда
							нТоварыНаПортале.СуммаНДС = нТоварыНаПортале.AMOUNT - (нТоварыНаПортале.AMOUNT) /((100 + СтавкаНДС18)/100);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;				
			КонецЕсли;
		Иначе
			МассивДней = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьМассивДней(ДатаНач, ДатаКон);
			Для Каждого СтрокаДаты Из МассивДней Цикл
				ТаблицаНакладных.Очистить();
				ТаблицаТоварыНакладных.Очистить();
				П_Обработки.Вставить("ДатаНач", 		НачалоДня(СтрокаДаты.ДатаНач));
				П_Обработки.Вставить("ДатаКон", 		КонецДня(СтрокаДаты.ДатаКон));
				П_Обработки.Вставить("SoapAction", 		"get_buyer_waybills");
				
				ДанныеПриниятихНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
				Если НЕ ДанныеПриниятихНакладных = Неопределено Тогда
					П_Обработки.Вставить("SoapAction", 		"get_buyer_waybilll_goods_list");
					ДанныеТабПриниятихНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
					Если НЕ ДанныеТабПриниятихНакладных = Неопределено Тогда
						Для Каждого СтрокаНакладной Из ТаблицаНакладных Цикл
							нТоварныеНакладныеНаПортал = Объект.ТоварныеНакладныеНаПортале.Добавить();	
							ЗаполнитьЗначенияСвойств(нТоварныеНакладныеНаПортал, СтрокаНакладной);	
						КонецЦикла;
						
						Для Каждого СтокаТовара Из ТаблицаТоварыНакладных Цикл
							нТоварыНаПортале = Объект.ТоварыНаПортале.Добавить();	
							ЗаполнитьЗначенияСвойств(нТоварыНаПортале, СтокаТовара);
							Если СтокаТовара.VAT_TYPE = "0" Тогда
								нТоварыНаПортале.СуммаНДС = СтокаТовара.AMOUNT - (СтокаТовара.AMOUNT) /((100 + СтавкаНДС18)/100);
							КонецЕсли;
						КонецЦикла;						
					КонецЕсли;					
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Состояние", "მიღებული")).Количество() > 0 Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокНакладных("მიღებული", Объект.ТоварныеНакладныеНаПортале, Организация);
			ЗаполнитьСписокОрдеров();// ++ 13.11.2023 Lazare

		КонецЕсли;
	КонецЕсли;
	
	//Малышев 2025-07-17 ONESOFT-4224
	Для каждого СтрокаДокумента из Объект.ТоварныеНакладныеНаПортале Цикл
		
		Если не ЗначениеЗаполнено(СтрокаДокумента.Контрагент) и ЗначениеЗаполнено(СтрокаДокумента.SELLER_TIN) ТОгда
			СтрокаДокумента.Контрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", СтрокаДокумента.SELLER_TIN); 
			
			Если ЗначениеЗаполнено(СтрокаДокумента.Контрагент) Тогда
				СтрокаДокумента.Договор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаДокумента.Контрагент, "ДоговорПоУмолчанию");
				СтрокаДокумента.Подразделение = СтрокаДокумента.Договор.СтруктурнаяЕдиница;
			КонецЕсли;	
			
		КонецЕсли;
	КонецЦикла;
	
	
	Statuses = ",";
	//Если СтатусТТНСохраненный	Тогда statuses = ?(statuses = ",", statuses + "0", 	statuses + ",0");	КонецЕсли;//0 შენახული
	Если СтатусТТНАктивный		Тогда statuses = ?(statuses = ",", statuses + "1", 	statuses + ",1");	КонецЕсли;//1 აქტიური
	Если СтатусТТНДоставленный	Тогда statuses = ?(statuses = ",", statuses + "2", 	statuses + ",2");	КонецЕсли;//2 დასრულებული
	Если СтатусТТНОтмененный	Тогда statuses = ?(statuses = ",", statuses + "-2", statuses + ",-2");	КонецЕсли;//-2 გაუქმებული
	
	itypes = "";
	//Если ВнутреннееПеремещение 		Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",1", "1"); КонецЕсли;//1 გადაადგილება
	Если РеализацияСТранспортировкой 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",2", "2"); КонецЕсли;//2 რეალიზაცია ტრანსპორტირებით
	Если РеализацияБезТранспортировки 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",3", "3"); КонецЕсли;//3 რეალიზაცია ტრანსპორტირების გარეშე
	Если Дистрибуция 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",4", "4"); КонецЕсли;//4 დისტრიბუცია
	Если ВозвратПокупателяПокупателю 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",5", "5"); КонецЕсли;//5 უკან დაბრუნება
	Если ПодчиненнаяТН 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",6", "6"); КонецЕсли;//6 ქვე-ზედნადები
	
	//გაცემული
	Если Отправленный И НЕ Statuses = "," Тогда
		ТаблицаНакладных.Очистить();
		ТаблицаТоварыНакладных.Очистить();
		П_Обработки.Вставить("ДатаНач", 					НачалоДня(ДатаНач));
		П_Обработки.Вставить("ДатаКон", 					КонецДня(ДатаКон));
		П_Обработки.Вставить("Statuses", 					Statuses + ",");
		П_Обработки.Вставить("itypes", 						itypes);
		П_Обработки.Вставить("SoapAction", 					"get_waybills");
		
		ДанныеРасходныхНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
		Если НЕ ДанныеРасходныхНакладных = Неопределено Тогда
			П_Обработки.Вставить("SoapAction", 				"get_waybill_goods_list");
			ДанныеТоваровНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
			Если НЕ ДанныеТоваровНакладных = Неопределено Тогда
				Для Каждого СтрокаНакладной Из ТаблицаНакладных Цикл
					нТоварныеНакладныеНаПортал = Объект.ТоварныеНакладныеНаПортале.Добавить();	
					ЗаполнитьЗначенияСвойств(нТоварныеНакладныеНаПортал,СтрокаНакладной);	
				КонецЦикла;
				
				Для Каждого СтокаТовара Из ТаблицаТоварыНакладных Цикл
					нТоварыНаПортале = Объект.ТоварыНаПортале.Добавить();	
					ЗаполнитьЗначенияСвойств(нТоварыНаПортале,СтокаТовара);
					Если СтокаТовара.VAT_TYPE = "0" Тогда
						нТоварыНаПортале.СуммаНДС = СтокаТовара.AMOUNT - (СтокаТовара.AMOUNT) /((100 + СтавкаНДС18)/100);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		Если Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Состояние", "გაგზავნილი")).Количество() > 0 Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокНакладных("გაგზავნილი", Объект.ТоварныеНакладныеНаПортале, Организация);
		КонецЕсли;
	КонецЕсли;
	
	
	//შენახული
	Если СтатусТТНСохраненный Тогда
		ТаблицаНакладных.Очистить();
		ТаблицаТоварыНакладных.Очистить();
		П_Обработки.Вставить("ДатаНач", 					НачалоДня(ДатаНач));
		П_Обработки.Вставить("ДатаКон", 					КонецДня(ДатаКон));
		П_Обработки.Вставить("Statuses", 					",0,");
		П_Обработки.Вставить("СоответствиеНоменклатуры", 	Организация.СоответствиеПриВыгрузкеОтправленныхНоменклатур);
		П_Обработки.Вставить("SoapAction", 					"get_waybills");
		
		ДанныеРасходныхНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
		Если НЕ ДанныеРасходныхНакладных = Неопределено Тогда
			П_Обработки.Вставить("SoapAction", 				"get_waybill_goods_list");
			ДанныеТоваровНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
