Функция ПолучитьВидУдержанияПФ(Договор)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	УдержанияДляПенсионногоФондаСрезПоследних.ВидУдержания КАК ВидУдержания
	               |ИЗ
	               |	РегистрСведений.УдержанияДляПенсионногоФонда.СрезПоследних(, Договор = &Договор) КАК УдержанияДляПенсионногоФондаСрезПоследних
	               |ГДЕ
	               |	УдержанияДляПенсионногоФондаСрезПоследних.Актуальность";
	Запрос.УстановитьПараметр("Договор", Договор);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.ВидУдержания, Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка());
