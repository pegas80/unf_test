&НаКлиенте
Процедура СоздатьНоменклатуру(Команда)
	
	ТекущаяНакладная      = Элементы.ТоварныеНакладныеНаПортале.ТекущиеДанные ;
	Если ТекущаяНакладная = Неопределено Тогда
		Возврат
	КонецЕсли;	
	СоздатьНоменклатуруПолученные_НаСервере(ТекущаяНакладная.WAYBILL_NUMBER);
	
КонецПроцедуры

&НаСервере
Процедура СоздатьНоменклатуруПолученные_НаСервере(WAYBILL_NUMBER);
	
    СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Штука", 					УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("КлассификаторЕдиницИзмерения", "шт"));
	СтруктураПараметров.Вставить("СчетУчетаЗапасовРегл",    ПланыСчетов.Хозрасчетный.НайтиПоКоду("1610"));
	СтруктураПараметров.Вставить("СчетУчетаЗатратРегл",     ПланыСчетов.Хозрасчетный.НайтиПоКоду("1630"));
	СтруктураПараметров.Вставить("Запас",					Перечисления.ТипыНоменклатуры.Запас);
	СтруктураПараметров.Вставить("БезКатегории",			УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("КатегорииНоменклатуры", 	"БезКатегории"));
	СтруктураПараметров.Вставить("ОсновноеНаправление",		УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("НаправленияДеятельности", "ОсновноеНаправление"));	
			
	СтрокиНоменкалтурВТТН = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("WAYBILL_NUMBER", WAYBILL_NUMBER));		
	Для Каждого Стр из СтрокиНоменкалтурВТТН Цикл   		
		Если Стр.Номенклатура =  справочники.номенклатура.пустаяссылка()  Тогда 		
			СтруктураПараметров.Вставить("Код",Стр.BAR_CODE);
			СтруктураПараметров.Вставить("Наименование",Стр.W_NAME);
			СтруктураПараметров.Вставить("СтавкаНДС",Стр.VAT_TYPE);					
			Номенклатура         =  ПолучитьНоменклатуру(СтруктураПараметров); 
	        Стр.Номенклатура     =  Номенклатура ;
			Стр.ЕдиницаИзмерения =  Номенклатура.ЕдиницаИзмерения ;		
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

