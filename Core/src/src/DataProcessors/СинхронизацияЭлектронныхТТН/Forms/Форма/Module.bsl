			  НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтруктураПараметров.Код);		  
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда	   
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоКоду(СтруктураПараметров.Код);
			  КонецЕсли;			   
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда				  
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("ОсновнойШтрихКод", СтруктураПараметров.Код);
			  КонецЕсли; 
			  Ссылка = НайденнаяСсылка;
		КонецЕсли;	  
		//Приоритет Штрихкод>Артикул>Код>
        Если  ПриоритетПоиска = ПредопределенноеЗначение("Перечисление.ПриоритетСоответствияДляПоискаНоменклатурВБазе.ШтрихкодАртикулКод") Тогда 			
			  НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("ОсновнойШтрихКод", СтруктураПараметров.Код);
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда				  
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтруктураПараметров.Код);
			  КонецЕсли;
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда	   
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоКоду(СтруктураПараметров.Код);
			  КонецЕсли;			    
			  Ссылка = НайденнаяСсылка;
		КонецЕсли;
	    //Приоритет Штрихкод>Код>Артикул> 	
		Если  ПриоритетПоиска = ПредопределенноеЗначение("Перечисление.ПриоритетСоответствияДляПоискаНоменклатурВБазе.ШтрихкодКодАртикул") Тогда 		
			  НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("ОсновнойШтрихКод", СтруктураПараметров.Код);
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда	   
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоКоду(СтруктураПараметров.Код);
