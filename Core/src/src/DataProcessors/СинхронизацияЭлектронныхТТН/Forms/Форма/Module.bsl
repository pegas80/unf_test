	МассивID = ОтмеченныеСтроки.ВыгрузитьКолонку("ID");
	ТаблицаНайденныхДокументов = НайтиДокументПоID(МассивID);
	
	Для Каждого СтрокаТТН Из ОтмеченныеСтроки Цикл
		
		//++Lazare 22.12.2021	
		Если  ЗначениеЗаполнено(СтрокаТТН.SELLER_TIN) Тогда 
			ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервереНов(СтрокаТТН.SELLER_TIN);
		КонецЕсли;

		
		//+++ Дмгг
		//Проверка Документа по ID
		ТаблицаНайденныхДокументов = НайтиДокументПоID(СтрокаТТН.ID);
		//Создать документ
		Если СтрокаТТН.TYPE = 1 Тогда
			Если СтрокаТТН.ЭтаИмущество Тогда
				
				ПоискДокументаПоID = ТаблицаНайденныхДокументов.НайтиСтроки(Новый Структура("ТипДокумента, ID", "ПеремещениеВА", СтрокаТТН.ID));
				Если ПоискДокументаПоID.Количество() > 0 Тогда 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ ""Перемещение имущества"" с ID """+СтрокаТТН.ID+""" уже существует'; 
																		   |en = 'Документ ""Перемещение имущества"" с ID """+СтрокаТТН.ID+""" уже существует';
																		   |ka = 'Документ ""Перемещение имущества"" с ID """+СтрокаТТН.ID+""" уже существует'"));
					Продолжить;
				КонецЕсли;
				
				ДокОбъект = Документы.ПеремещениеВА.СоздатьДокумент();
			Иначе
				
