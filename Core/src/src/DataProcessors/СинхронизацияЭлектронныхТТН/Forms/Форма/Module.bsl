					СтрокаТЧ.ЦенаНоменклатуры = ЦеныПродажи[0].Цена;
				Иначе
					СтрокаТЧ.ЦенаНоменклатуры = 0;
				КонецЕсли;
			Иначе
				СтрокаТЧ.ЦенаНоменклатуры = 0;
			КонецЕсли;
		КонецЦикла;
	Иначе
		СтрокаТЧ = Объект.ТоварыНаПортале.НайтиПоИдентификатору(Идентификатор);
		Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
			ЦеныПродажи = РегистрыСведений.ЦеныНоменклатуры.СрезПоследних(, Новый Структура("ВидЦен, Номенклатура, Характеристика", ВидЦенПродажи, СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));
			Если Не ЦеныПродажи.Количество() = 0 Тогда
				СтрокаТЧ.ЦенаНоменклатуры = ЦеныПродажи[0].Цена;
			Иначе
				СтрокаТЧ.ЦенаНоменклатуры = 0;
			КонецЕсли;
		Иначе
			СтрокаТЧ.ЦенаНоменклатуры = 0;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНакладные(Команда)
	
	ОчиститьСообщения();
	Если ДанныеНеСоответствуютФильтру Тогда 
		Сообщить("Данные не соответствуют фильтру. Формирование отменено.");
		Возврат;
	КонецЕсли;
	
	ЕстьОшибки = Ложь;
	СоздатьДокументы_НаСервере(ЕстьОшибки);
	Если НЕ ЕстьОшибки Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаСозданныеДокументы;
		ЗаполнитьНоменклатуруПолученные_НаСервере();
		ЗаполнитьНоменклатуруОтправленные_НаСервере();
	КонецЕсли;
	
	Элементы.ТоварныеНакладныеНаПортале.Обновить();
	Элементы.СозданныеДокументы.Обновить();
	
КонецПроцедуры

