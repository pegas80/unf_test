				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтруктураПараметров.Код);
			  КонецЕсли;
			  Ссылка = НайденнаяСсылка;
		КонецЕсли;		
	    //Приоритет Код>Артикул>Штрихкод	
		Если  ПриоритетПоиска = ПредопределенноеЗначение("Перечисление.ПриоритетСоответствияДляПоискаНоменклатурВБазе.КодАртикулШтрихкод") Тогда 		
			  НайденнаяСсылка =  Справочники.Номенклатура.НайтиПоКоду(СтруктураПараметров.Код);
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда				  
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтруктураПараметров.Код);
			  КонецЕсли;
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда				  
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("ОсновнойШтрихКод", СтруктураПараметров.Код);
			  КонецЕсли;
			  Ссылка = НайденнаяСсылка;
		КонецЕсли;		
	    //Приоритет Код>Штрихкод>Артикул	
		Если  ПриоритетПоиска = ПредопределенноеЗначение("Перечисление.ПриоритетСоответствияДляПоискаНоменклатурВБазе.КодШтрихкодАртикул") Тогда 			
			  НайденнаяСсылка =  Справочники.Номенклатура.НайтиПоКоду(СтруктураПараметров.Код);
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда				  
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("ОсновнойШтрихКод", СтруктураПараметров.Код);
			  КонецЕсли;
			  Если НайденнаяСсылка = Справочники.Номенклатура.ПустаяСсылка() Тогда				  
				   НайденнаяСсылка = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул", СтруктураПараметров.Код);
			  КонецЕсли;
			  Ссылка = НайденнаяСсылка;
		КонецЕсли;		  
	КонецЕсли;
    //Создание номанклатуры	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда	
		НовНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();
		НовНоменклатура.Заполнить(Неопределено);
		НовНоменклатура.СчетУчетаЗапасовРегл    = СтруктураПараметров.СчетУчетаЗапасовРегл;
		НовНоменклатура.СчетУчетаЗатратРегл     = СтруктураПараметров.СчетУчетаЗатратРегл;	
		НовНоменклатура.Наименование 		    = СтруктураПараметров.Наименование;
		НовНоменклатура.НаименованиеПолное      = СтруктураПараметров.Наименование;
