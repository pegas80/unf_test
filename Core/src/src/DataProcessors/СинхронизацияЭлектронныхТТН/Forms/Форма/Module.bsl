		НовНоменклатура.КатегорияНоменклатуры   = СтруктураПараметров.БезКатегории;                                                                       
		НовНоменклатура.НаправлениеДеятельности = СтруктураПараметров.ОсновноеНаправление;		
		//СтавкаНДС
		Если СтруктураПараметров.СтавкаНДС = "1" Тогда 		
			НовНоменклатура.СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС0");			
		ИначеЕсли СтруктураПараметров.СтавкаНДС = "2" Тогда 
