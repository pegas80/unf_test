КонецПроцедуры

&НаСервере
Процедура СоздатьОрдерыНаСервере()
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	СтруктурныеЕдиницыКонтактнаяИнформация.Представление КАК Адрес,
	|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка КАК Склад,
	|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ТранспортноеСредство КАК ТранспортноеСредство
	|ИЗ
	|	Справочник.СтруктурныеЕдиницы.КонтактнаяИнформация КАК СтруктурныеЕдиницыКонтактнаяИнформация
	|ГДЕ
	|	СтруктурныеЕдиницыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы)
	|	И СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)
	|	И СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ОрдерныйСклад = ИСТИНА";
	ТаблицаСкладов = Запрос.Выполнить().Выгрузить();

	
	
	СтОтбора = Новый Структура;
	СтОтбора.Вставить("Ордер", Истина);

	
	ОтмеченныеСтроки = Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Ордер", Истина));

	
 	Для Каждого Док из ОтмеченныеСтроки Цикл 
		
		СтрокаСклада =  ТаблицаСкладов.Найти(Док.END_ADDRESS, "Адрес"); 		
		ДокОбъект = Документы.ПриходныйОрдер.СоздатьДокумент();
		Если ЗначениеЗаполнено(СтрокаСклада) Тогда 
			ДокОбъект.СтруктурнаяЕдиница = СтрокаСклада.Склад;	
		КонецЕсли;
		ДокОбъект.Организация = Организация;
		ДокОбъект.Дата = Док.ACTIVATE_DATE;
		ДокОбъект.Автор = Пользователи.ТекущийПользователь();
		ДокОбъект.НомерТТН = Док.WAYBILL_NUMBER;
		ДокОбъект.IDTТН = Док.ID; 
		
		Если ЗначениеЗаполнено(Док.Контрагент) Тогда 		
			ДокОбъект.Контрагент = Док.Контрагент;	
			ДокОбъект.Договор 	 = Док.Контрагент.ДоговорПоУмолчанию
		КонецЕсли;
			
		Если Док.WAYBILL_NUMBER = "" Тогда
			СтрокиТоваров = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("ID", 				Док.ID));
		Иначе
			СтрокиТоваров = Объект.ТоварыНаПортале.НайтиСтроки(Новый Структура("WAYBILL_NUMBER",	Док.WAYBILL_NUMBER));
		КонецЕсли;
		
		Для Каждого СтрокаТовары Из СтрокиТоваров Цикл		
			НоваяСтрокаТЧ = ДокОбъект.Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧ, СтрокаТовары);
			НоваяСтрокаТЧ.Количество = СтрокаТовары.QUANTITY;
		КонецЦикла;
		
		Попытка
			ДокОбъект.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
			впНоваяСтрокаДок = Объект.СозданныеОрдеры.Добавить();
			впНоваяСтрокаДок.Документ	= ДокОбъект.Ссылка;
			впНоваяСтрокаДок.Проведен	= Истина;
			Док.Ордер = Ложь;
		Исключение
			ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
			впНоваяСтрокаДок = Объект.СозданныеОрдеры.Добавить();
			впНоваяСтрокаДок.Документ	= ДокОбъект.Ссылка;
			впНоваяСтрокаДок.Проведен	= Ложь;
			Док.Ордер = Ложь;
		КонецПопытки;
	
		
		Док.ПрихОрдер  =  ДокОбъект.Ссылка;
	
	КонецЦикла;
	
		
	
КонецПроцедуры

