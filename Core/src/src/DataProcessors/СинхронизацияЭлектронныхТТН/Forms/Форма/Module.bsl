			ОтмеченныеСтрокиТТН = Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Флаг, ЕстьОшибки, Полученный", Истина, Ложь, Ложь));
			Для Каждого СтрокаТТН Из ОтмеченныеСтрокиТТН Цикл			
				СтрокаТТН.Документ			= ДокОбъект.Ссылка;
				СтрокаТТН.Флаг				= Ложь;
				СтрокаТТН.ДокументПревязан 	= Истина;			
			КонецЦикла;
			//_Lazare_					
