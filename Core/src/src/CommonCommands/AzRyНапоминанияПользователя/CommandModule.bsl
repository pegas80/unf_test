
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	СтруктураЗаписи = ПолучитьПараметрыИзИсточника(ПараметрКоманды);
	
	Для каждого ТекЭл Из СтруктураЗаписи Цикл
		
		МассивСтруктураЗаписи = Новый Массив;
		МассивСтруктураЗаписи.Добавить(ТекЭл);
		КлючЗаписи = Новый ("РегистрСведенийКлючЗаписи.AzRyНапоминанияПользователя", МассивСтруктураЗаписи);
		
		Попытка 
			Параметрыформы = Новый Структура("Ключ", КлючЗаписи);
			ОткрытьФорму("РегистрСведений.AzRyНапоминанияПользователя.Форма.ФормаЗаписи", Параметрыформы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно, ПараметрыВыполненияКоманды.НавигационнаяСсылка);
		Исключение
			ОткрытьФорму("РегистрСведений.AzRyНапоминанияПользователя.Форма.ФормаЗаписи", ТекЭл,          ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно, ПараметрыВыполненияКоманды.НавигационнаяСсылка);
		КонецПопытки;		
		
	КонецЦикла;				
								
КонецПроцедуры

&НаСервере
Функция ПолучитьПараметрыИзИсточника(ПараметрКоманды)
	
	Массив = Новый Массив;
	
	МассивПользователи = ДанныеДокумента(ПараметрКоманды);
	Для каждого ТекЭлПользователь Из МассивПользователи Цикл
		Если Не ТекЭлПользователь = Пользователи.ТекущийПользователь() Тогда
			Массив.Добавить(Новый Структура("Период, Получатель, Отправитель,  Источник, СтатусНапоминания", 
			 ТекущаяДата(), ТекЭлПользователь, Пользователи.ТекущийПользователь(), ПараметрКоманды, Перечисления.AzRyСтатусНапоминания.ОжидаетПодтверждения));
			//Массив.Добавить(Новый Структура("Получатель, Отправитель,  Источник, СтатусНапоминания", 
			//				ТекЭлПользователь, Пользователи.ТекущийПользователь(), ПараметрКоманды, Перечисления.AzRyСтатусНапоминания.ОжидаетПодтверждения));							
		КонецЕсли; 
	КонецЦикла;
	 
	Возврат Массив;
	
КонецФункции
 
&НаСервере
Функция ДанныеДокумента(Источник)
	
	МассивСклады = Новый Массив;                           
	МассивОтвет  = Новый Массив;
	
	Если Тип("ДокументСсылка.ПриходнаяНакладная") = ТипЗнч(Источник) Тогда				
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиница);
	ИначеЕсли Тип("ДокументСсылка.ЗаказПокупателя") = ТипЗнч(Источник) Тогда
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиницаРезерв);
	ИначеЕсли Тип("ДокументСсылка.ПеремещениеЗапасов") = ТипЗнч(Источник) Тогда	
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиница);
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиницаПолучатель);
	ИначеЕсли Тип("ДокументСсылка.СборкаЗапасов") = ТипЗнч(Источник) Тогда
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиницаПродукции);
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиницаЗапасов);
	Иначе		
		МассивСклады.Добавить(Источник.СтруктурнаяЕдиница);
	КонецЕсли;	    
	
	Для каждого ТекСклад Из МассивСклады Цикл
		Если ТекСклад.AzRyТекущийОтветственный <> Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
			ТекущийОтветственный = ЗапросПользователя(ТекСклад.AzRyТекущийОтветственный);
			Если ТекущийОтветственный = Неопределено Тогда
				Продолжить;
			КонецЕсли; 
			Если МассивОтвет.Найти(ТекущийОтветственный) = Неопределено Тогда		
				МассивОтвет.Добавить(ТекущийОтветственный);
			КонецЕсли;		
		КонецЕсли;
	КонецЦикла;
			
	Возврат МассивОтвет;
	
КонецФункции

&НаСервере
Функция ЗапросПользователя(ТекущийОтветственный)

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК ТекущийОтветственный_Сотрудник,
	|	&Физлицо КАК Физлицо
	|ПОМЕСТИТЬ вт_Таблица
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Физлицо = &Физлицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СотрудникиПользователя.Пользователь КАК ТекущийОтветственный_Пользователь
	|ИЗ
	|	вт_Таблица КАК вт_Таблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СотрудникиПользователя КАК СотрудникиПользователя
	|		ПО вт_Таблица.ТекущийОтветственный_Сотрудник = СотрудникиПользователя.Сотрудник
	|ГДЕ
	|	вт_Таблица.Физлицо <> ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
	|	И НЕ СотрудникиПользователя.Пользователь.ПометкаУдаления";
	
	//Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Физлицо", ТекущийОтветственный);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл	
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ТекущийОтветственный_Пользователь) Тогда
			Возврат ВыборкаДетальныеЗаписи.ТекущийОтветственный_Пользователь;			
		КонецЕсли;	
	КонецЦикла;	
	
КонецФункции
 
 
