      <segments>Список.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЖурналДокументовДокументыПоКонтрагенту.Ссылка,
	ЖурналДокументовДокументыПоКонтрагенту.Дата,
	ЖурналДокументовДокументыПоКонтрагенту.ПометкаУдаления,
	ЖурналДокументовДокументыПоКонтрагенту.Номер,
	ЖурналДокументовДокументыПоКонтрагенту.Проведен,
	ЖурналДокументовДокументыПоКонтрагенту.Тип,
	ЖурналДокументовДокументыПоКонтрагенту.Сумма,
	ЖурналДокументовДокументыПоКонтрагенту.Валюта,
	ЖурналДокументовДокументыПоКонтрагенту.ВидОперации,
	ЖурналДокументовДокументыПоКонтрагенту.Автор,
	ЖурналДокументовДокументыПоКонтрагенту.Ответственный,
	ЖурналДокументовДокументыПоКонтрагенту.Организация,
	ЖурналДокументовДокументыПоКонтрагенту.Комментарий
ИЗ
	(ВЫБРАТЬ
		ЖурналДокументовДокументыПоКонтрагенту.Ссылка КАК Ссылка,
		ЖурналДокументовДокументыПоКонтрагенту.Дата КАК Дата,
		ЖурналДокументовДокументыПоКонтрагенту.ПометкаУдаления КАК ПометкаУдаления,
		ЖурналДокументовДокументыПоКонтрагенту.Номер КАК Номер,
		ЖурналДокументовДокументыПоКонтрагенту.Проведен КАК Проведен,
		ЖурналДокументовДокументыПоКонтрагенту.Тип КАК Тип,
		ЖурналДокументовДокументыПоКонтрагенту.Сумма КАК Сумма,
		ЖурналДокументовДокументыПоКонтрагенту.Валюта КАК Валюта,
		ЖурналДокументовДокументыПоКонтрагенту.ВидОперации КАК ВидОперации,
		ЖурналДокументовДокументыПоКонтрагенту.Автор КАК Автор,
		ЖурналДокументовДокументыПоКонтрагенту.Ответственный КАК Ответственный,
		ЖурналДокументовДокументыПоКонтрагенту.Организация КАК Организация,
		ВЫРАЗИТЬ(ЖурналДокументовДокументыПоКонтрагенту.Комментарий КАК СТРОКА(500)) КАК Комментарий
	ИЗ
		ЖурналДокументов.ДокументыПоКонтрагенту КАК ЖурналДокументовДокументыПоКонтрагенту
	{ГДЕ
		(ЖурналДокументовДокументыПоКонтрагенту.Ссылка В
				(ВЫБРАТЬ
					КритерийОтбораДокументыПоКонтрагенту.Ссылка
				ИЗ
					КритерийОтбора.ДокументыПоКонтрагенту(&amp;ОтборКонтрагент) КАК КритерийОтбораДокументыПоКонтрагенту))}
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ВложенныйЗапрос.Ссылка,
		ВложенныйЗапрос.Ссылка.Дата,
		ВложенныйЗапрос.Ссылка.ПометкаУдаления,
		ВложенныйЗапрос.Ссылка.Номер,
		ВложенныйЗапрос.Ссылка.Проведен,
		ТИП(Документ.РасходСоСчета),
		ВложенныйЗапрос.Сумма_,
		ВложенныйЗапрос.ВалютаДокумента,
		ВложенныйЗапрос.Ссылка.ВидОперации,
		ВложенныйЗапрос.Ссылка.Автор,
		НЕОПРЕДЕЛЕНО,
		ВложенныйЗапрос.Организация,
		ВЫРАЗИТЬ(ВложенныйЗапрос.Ссылка.Комментарий КАК СТРОКА(500))
	ИЗ
		(ВЫБРАТЬ
			РасходСоСчетаВыплатаЗаработнойПлаты.Ссылка КАК Ссылка,
			МАКСИМУМ(Ведомости.Ведомость.ВалютаДокумента) КАК ВалютаДокумента,
			СУММА(Ведомости.Сумма_) КАК Сумма_,
			МАКСИМУМ(Ведомости.Ведомость.Организация) КАК Организация,
			МАКСИМУМ(Ведомости.Контрагент) КАК Контрагент
		ИЗ
			(ВЫБРАТЬ
				ПлатежнаяВедомостьСотрудники.Ссылка КАК Ведомость,
				ПлатежнаяВедомостьСотрудники.ВидУдержания.Контрагент КАК Контрагент,
				СУММА(ПлатежнаяВедомостьСотрудники.СуммаПлатежа) КАК Сумма_
			ИЗ
				Документ.ПлатежнаяВедомость.Сотрудники КАК ПлатежнаяВедомостьСотрудники
			ГДЕ
				ПлатежнаяВедомостьСотрудники.ВидУдержания.Контрагент = &amp;ОтборКонтрагент
			
			СГРУППИРОВАТЬ ПО
				ПлатежнаяВедомостьСотрудники.ВидУдержания.Контрагент,
				ПлатежнаяВедомостьСотрудники.Ссылка) КАК Ведомости
				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходСоСчета.ВыплатаЗаработнойПлаты КАК РасходСоСчетаВыплатаЗаработнойПлаты
				ПО Ведомости.Ведомость = РасходСоСчетаВыплатаЗаработнойПлаты.Ведомость
		
		СГРУППИРОВАТЬ ПО
			РасходСоСчетаВыплатаЗаработнойПлаты.Ссылка) КАК ВложенныйЗапрос) КАК ЖурналДокументовДокументыПоКонтрагенту</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
