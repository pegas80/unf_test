Процедура ИнициализироватьТаблицуПоПроектам(ДокументСсылкаАмортизацияВА, СтруктураДополнительныеСвойства)
	
	ДнейВпериоде = (КонецДня(КонецМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата)) + 1 - НачалоМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата)) / 86400;
	Если ДнейВпериоде = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата));
	Запрос.УстановитьПараметр("НачалоПериода", КонецДня(НачалоМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата)) + 1);
	Запрос.УстановитьПараметр("КонецПериода",  КонецДня(КонецМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата)) + 1);
	Запрос.УстановитьПараметр("ДнейВпериоде", ДнейВпериоде);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТаблицаДокумента.Период КАК Период,
	               |	ТаблицаДокумента.Организация КАК Организация,
	               |	ТаблицаДокумента.Продолжить КАК Продолжить,
	               |	ТаблицаДокумента.СообщениеОбОшибкеНачисленияАмортизации КАК СообщениеОбОшибкеНачисленияАмортизации,
	               |	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	               |	ТаблицаДокумента.ВнеоборотныйАктивПредставление КАК ВнеоборотныйАктивПредставление,
	               |	ТаблицаДокумента.Код КАК Код,
	               |	ТаблицаДокумента.АмортизацияКонечныйОстаток КАК АмортизацияКонечныйОстаток,
	               |	ТаблицаДокумента.БалансоваяСтоимость КАК БалансоваяСтоимость,
	               |	ТаблицаДокумента.ВсегоОсталосьСписать КАК ВсегоОсталосьСписать,
	               |	ТаблицаДокумента.Стоимость КАК Стоимость,
	               |	ТаблицаДокумента.Амортизация КАК Амортизация,
	               |	ТаблицаДокумента.Проект КАК Проект
	               |ИЗ
	               |	ТаблицаРасчетаАмортизации КАК ТаблицаДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.Организация,
	               |	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив,
	               |	&НачалоМесяца КАК Период,
	               |	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.Проект
	               |ПОМЕСТИТЬ втИзмененияПроектов
	               |ИЗ
	               |	РегистрСведений.УчетПоПроектамВнеоборотныхАктивов.СрезПоследних(
	               |			&НачалоПериода,
	               |			(Организация, ВнеоборотныйАктив) В
	               |				(ВЫБРАТЬ
	               |					Т.Организация,
	               |					Т.ВнеоборотныйАктив
	               |				ИЗ
	               |					ТаблицаРасчетаАмортизации КАК Т)) КАК УчетПоПроектамВнеоборотныхАктивовСрезПоследних
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	УчетПоПроектамВнеоборотныхАктивов.Организация,
	               |	УчетПоПроектамВнеоборотныхАктивов.ВнеоборотныйАктив,
	               |	НАЧАЛОПЕРИОДА(УчетПоПроектамВнеоборотныхАктивов.Период, ДЕНЬ),
	               |	УчетПоПроектамВнеоборотныхАктивов.Проект
	               |ИЗ
	               |	РегистрСведений.УчетПоПроектамВнеоборотныхАктивов КАК УчетПоПроектамВнеоборотныхАктивов
	               |ГДЕ
	               |	(УчетПоПроектамВнеоборотныхАктивов.Организация, УчетПоПроектамВнеоборотныхАктивов.ВнеоборотныйАктив) В
	               |			(ВЫБРАТЬ
	               |				Т.Организация,
	               |				Т.ВнеоборотныйАктив
	               |			ИЗ
	               |				ТаблицаРасчетаАмортизации КАК Т)
	               |	И УчетПоПроектамВнеоборотныхАктивов.Период >= &НачалоПериода
	               |	И УчетПоПроектамВнеоборотныхАктивов.Период < &КонецПериода
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.Организация,
	               |	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив,
	               |	НАЧАЛОПЕРИОДА(&КонецПериода, ДЕНЬ),
	               |	УчетПоПроектамВнеоборотныхАктивовСрезПоследних.Проект
	               |ИЗ
	               |	РегистрСведений.УчетПоПроектамВнеоборотныхАктивов.СрезПоследних(
	               |			&КонецПериода,
	               |			(Организация, ВнеоборотныйАктив) В
	               |				(ВЫБРАТЬ
	               |					Т.Организация,
	               |					Т.ВнеоборотныйАктив
	               |				ИЗ
	               |					ТаблицаРасчетаАмортизации КАК Т)) КАК УчетПоПроектамВнеоборотныхАктивовСрезПоследних
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	втИзмененияПроектовНачалоДействия.Организация,
	               |	втИзмененияПроектовНачалоДействия.ВнеоборотныйАктив,
	               |	втИзмененияПроектовНачалоДействия.Период КАК Период,
	               |	втИзмененияПроектовНачалоДействия.Проект,
	               |	МИНИМУМ(ЕСТЬNULL(втИзмененияПроектовОкончаниеДействия.Период, &КонецПериода)) КАК ПериодОкончания,
	               |	МИНИМУМ(РАЗНОСТЬДАТ(втИзмененияПроектовНачалоДействия.Период, ЕСТЬNULL(втИзмененияПроектовОкончаниеДействия.Период, &КонецПериода), ДЕНЬ)) КАК КоличествоДней
	               |ПОМЕСТИТЬ втТаблицаПоПроектам
	               |ИЗ
	               |	втИзмененияПроектов КАК втИзмененияПроектовНачалоДействия
	               |		Левое СОЕДИНЕНИЕ втИзмененияПроектов КАК втИзмененияПроектовОкончаниеДействия
	               |		ПО втИзмененияПроектовНачалоДействия.Организация = втИзмененияПроектовОкончаниеДействия.Организация
	               |			И втИзмененияПроектовНачалоДействия.ВнеоборотныйАктив = втИзмененияПроектовОкончаниеДействия.ВнеоборотныйАктив
	               |			И втИзмененияПроектовНачалоДействия.Период < втИзмененияПроектовОкончаниеДействия.Период
	               |ГДЕ
	               |	втИзмененияПроектовНачалоДействия.Период <> ЕСТЬNULL(втИзмененияПроектовОкончаниеДействия.Период, &КонецПериода)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	втИзмененияПроектовНачалоДействия.Организация,
	               |	втИзмененияПроектовНачалоДействия.ВнеоборотныйАктив,
	               |	втИзмененияПроектовНачалоДействия.Период,
	               |	втИзмененияПроектовНачалоДействия.Проект
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	втТаблицаАмортизации.Период,
	               |	втТаблицаАмортизации.Организация КАК Организация,
	               |	втТаблицаАмортизации.Продолжить КАК Продолжить,
	               |	втТаблицаАмортизации.СообщениеОбОшибкеНачисленияАмортизации КАК СообщениеОбОшибкеНачисленияАмортизации,
	               |	втТаблицаАмортизации.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	               |	втТаблицаАмортизации.ВнеоборотныйАктивПредставление,
	               |	втТаблицаАмортизации.Код,
	               |	втТаблицаАмортизации.АмортизацияКонечныйОстаток КАК АмортизацияКонечныйОстаток,
	               |	втТаблицаАмортизации.БалансоваяСтоимость КАК БалансоваяСтоимость,
	               |	втТаблицаАмортизации.ВсегоОсталосьСписать КАК ВсегоОсталосьСписать,
	               |	втТаблицаАмортизации.Стоимость КАК Стоимость,
	               |	втТаблицаАмортизации.Амортизация КАК Амортизация,
	               |	ЕСТЬNULL(втТаблицаПоПроектам.Проект, ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)) КАК Проект,
	               |	ЕСТЬNULL(втТаблицаПоПроектам.Период, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ПериодНачала,
	               |	ЕСТЬNULL(втТаблицаПоПроектам.ПериодОкончания, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ПериодОкончания,
	               |	ЕСТЬNULL(втТаблицаПоПроектам.КоличествоДней, &ДнейВпериоде) КАК КоличествоДней
	               |ИЗ
	               |	ТаблицаРасчетаАмортизации КАК втТаблицаАмортизации
	               |		ЛЕВОЕ СОЕДИНЕНИЕ втТаблицаПоПроектам КАК втТаблицаПоПроектам
	               |		ПО втТаблицаАмортизации.Организация = втТаблицаПоПроектам.Организация
	               |			И втТаблицаАмортизации.ВнеоборотныйАктив = втТаблицаПоПроектам.ВнеоборотныйАктив
	               |ИТОГИ
	               |	МАКСИМУМ(АмортизацияКонечныйОстаток),
	               |	МАКСИМУМ(БалансоваяСтоимость),
	               |	МАКСИМУМ(ВсегоОсталосьСписать),
	               |	МАКСИМУМ(Стоимость),
	               |	МАКСИМУМ(Амортизация),
	               |	СУММА(КоличествоДней)
	               |ПО
	               |	Организация,
	               |	ВнеоборотныйАктив";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Если РезультатЗапроса[3].Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаАмортизации = РезультатЗапроса[0].Выгрузить();
	ТаблицаАмортизации.Очистить();
	
	ВыборкаОрганизация = РезультатЗапроса[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизация.Следующий() Цикл
		ВыборкаОС = ВыборкаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаОС.Следующий() Цикл
			
			СтрокаАмортизации = Неопределено;
			АмортизацияКонечныйОстатокОсталось	= ВыборкаОС.АмортизацияКонечныйОстаток;
			БалансоваяСтоимостьОсталось			= ВыборкаОС.БалансоваяСтоимость;
			ВсегоОсталосьСписатьОсталось		= ВыборкаОС.ВсегоОсталосьСписать;
			СтоимостьОсталось					= ВыборкаОС.Стоимость;
			АмортизацияОсталось					= ВыборкаОС.Амортизация;
			КоличествоДнейОсталось				= ВыборкаОС.КоличествоДней;
			ДнейВПериодеОсталось				= ДнейВпериоде;
			
			ВыборкаДет = ВыборкаОС.Выбрать();
			Пока ВыборкаДет.Следующий() И КоличествоДнейОсталось > 0 Цикл
				
				КоэффПроекта = Окр(ВыборкаДет.КоличествоДней / ДнейВпериоде, 4);
				
				СтрокаАмортизации = ТаблицаАмортизации.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаАмортизации, ВыборкаДет);
				
				Если ВыборкаДет.КоличествоДней = ДнейВПериодеОсталось Тогда
					СтрокаАмортизации.АмортизацияКонечныйОстаток	= АмортизацияКонечныйОстатокОсталось;
					СтрокаАмортизации.БалансоваяСтоимость	= БалансоваяСтоимостьОсталось;
					СтрокаАмортизации.ВсегоОсталосьСписать	= ВсегоОсталосьСписатьОсталось;
					СтрокаАмортизации.Стоимость				= СтоимостьОсталось;
					СтрокаАмортизации.Амортизация			= АмортизацияОсталось;
				Иначе
					СтрокаАмортизации.АмортизацияКонечныйОстаток	= Окр(ВыборкаОС.АмортизацияКонечныйОстаток * КоэффПроекта, 2);
					СтрокаАмортизации.БалансоваяСтоимость	= Окр(ВыборкаОС.БалансоваяСтоимость * КоэффПроекта, 2);
					СтрокаАмортизации.ВсегоОсталосьСписать	= Окр(ВыборкаОС.ВсегоОсталосьСписать * КоэффПроекта, 2);
					СтрокаАмортизации.Стоимость				= Окр(ВыборкаОС.Стоимость * КоэффПроекта, 2);
					СтрокаАмортизации.Амортизация			= Окр(ВыборкаОС.Амортизация * КоэффПроекта, 2);
				КонецЕсли;
				
				АмортизацияКонечныйОстатокОсталось	= АмортизацияКонечныйОстатокОсталось - СтрокаАмортизации.АмортизацияКонечныйОстаток;
				БалансоваяСтоимостьОсталось		= БалансоваяСтоимостьОсталось - СтрокаАмортизации.БалансоваяСтоимость;
				ВсегоОсталосьСписатьОсталось	= ВсегоОсталосьСписатьОсталось - СтрокаАмортизации.ВсегоОсталосьСписать;
				СтоимостьОсталось				= СтоимостьОсталось - СтрокаАмортизации.Стоимость;
				АмортизацияОсталось				= АмортизацияОсталось - СтрокаАмортизации.Амортизация;
				КоличествоДнейОсталось			= КоличествоДнейОсталось - ВыборкаДет.КоличествоДней;
				ДнейВПериодеОсталось			= ДнейВПериодеОсталось - ВыборкаДет.КоличествоДней;
				
			КонецЦикла;
			
			Если ДнейВПериодеОсталось > 0 Тогда
				СтрокаАмортизацииОстаток = ТаблицаАмортизации.Добавить();
				Если СтрокаАмортизации = Неопределено Тогда
					ЗаполнитьЗначенияСвойств(СтрокаАмортизацииОстаток, ВыборкаОС);
				Иначе
					ЗаполнитьЗначенияСвойств(СтрокаАмортизацииОстаток, СтрокаАмортизации);
				КонецЕсли;
				
				СтрокаАмортизацииОстаток.Проект = Справочники.Проекты.ПустаяСсылка();
				
				СтрокаАмортизацииОстаток.АмортизацияКонечныйОстаток	= АмортизацияКонечныйОстатокОсталось;
				СтрокаАмортизацииОстаток.БалансоваяСтоимость	= БалансоваяСтоимостьОсталось;
				СтрокаАмортизацииОстаток.ВсегоОсталосьСписать	= ВсегоОсталосьСписатьОсталось;
				СтрокаАмортизацииОстаток.Стоимость				= СтоимостьОсталось;
				СтрокаАмортизацииОстаток.Амортизация			= АмортизацияОсталось;
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	//СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДоходыИРасходы", РезультатЗапроса.Выгрузить());
	
	Если ТаблицаАмортизации.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТаблицаДокумента.Период КАК Период,
	               |	ТаблицаДокумента.Организация КАК Организация,
				   |	ТаблицаДокумента.Продолжить КАК Продолжить,
				   |	ТаблицаДокумента.СообщениеОбОшибкеНачисленияАмортизации КАК СообщениеОбОшибкеНачисленияАмортизации,
	               |	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	               |	ТаблицаДокумента.ВнеоборотныйАктивПредставление КАК ВнеоборотныйАктивПредставление,
	               |	ТаблицаДокумента.Код КАК Код,
	               |	ТаблицаДокумента.Проект КАК Проект,
	               |	ТаблицаДокумента.АмортизацияКонечныйОстаток КАК АмортизацияКонечныйОстаток,
	               |	ТаблицаДокумента.БалансоваяСтоимость КАК БалансоваяСтоимость,
	               |	ТаблицаДокумента.ВсегоОсталосьСписать КАК ВсегоОсталосьСписать,
	               |	ТаблицаДокумента.Стоимость КАК Стоимость,
	               |	ТаблицаДокумента.Амортизация КАК Амортизация
	               |ПОМЕСТИТЬ втТаблицаАмортизации
	               |ИЗ
	               |	&ТаблицаАмортизации КАК ТаблицаДокумента
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |УНИЧТОЖИТЬ ТаблицаРасчетаАмортизации
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	втТаблицаАмортизации.Период,
	               |	втТаблицаАмортизации.Организация,
				   |	втТаблицаАмортизации.Продолжить КАК Продолжить,
				   |	втТаблицаАмортизации.СообщениеОбОшибкеНачисленияАмортизации КАК СообщениеОбОшибкеНачисленияАмортизации,
	               |	втТаблицаАмортизации.ВнеоборотныйАктив,
	               |	втТаблицаАмортизации.ВнеоборотныйАктивПредставление,
	               |	втТаблицаАмортизации.Код,
	               |	втТаблицаАмортизации.Проект,
	               |	втТаблицаАмортизации.АмортизацияКонечныйОстаток,
