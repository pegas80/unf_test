#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаАмортизацияВА, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Период",		   СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Организация",   СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("НачалоГода",	   НачалоГода(СтруктураДополнительныеСвойства.ДляПроведения.Дата));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата));
	Запрос.УстановитьПараметр("КонецПериода",  КонецМесяца(СтруктураДополнительныеСвойства.ДляПроведения.Дата));
	Запрос.УстановитьПараметр("Сообщение1",	   НСтр("ka='ამორტიზაცია ამ თვეს უკვე დაირიცხა!';ru='амортизация в этом месяце уже начислялась!';en='amortization of this month already accrued!'"));
	Запрос.УстановитьПараметр("Сообщение2",	   НСтр("ka='ამორტიზაციის დარიცხვის მეთოდი არ არის მითითებული!';ru='не указан способ начисления амортизации!';en='Unknown method of calculating depreciation!'"));
	Запрос.УстановитьПараметр("Сообщение3",	   НСтр("ka='ღირებულება არის 0-ის ტოლი!';ru='стоимость равна 0!';en='value is equal to 0!'"));
	Запрос.УстановитьПараметр("Сообщение4",	   НСтр("ka='გამოყენების ვადა ტოლია 0-ის!';ru='срок использования равен 0!';en='term use is 0!'"));
	Запрос.УстановитьПараметр("Сообщение5",	   НСтр("ka='სამუშაოების პროდუქციის მოცულობა ამორტიზაციის გამოსათვლელად შეუვსებელია!';ru='объем продукции работ для вычисления амортизации не заполнен!';en='volume production work for calculating depreciation is not filled!'"));
	Запрос.УстановитьПараметр("Сообщение6",	   НСтр("ka='თავდაპირველი ღირებულება ტოლია 0!';ru='первоначальная стоимость равна 0!';en='the initial value is equal to 0!'"));
	
	//ПодольскийАИ #УчетПроектов 10.12.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 10.12.2020 }
	
	// Установка исключительной блокировки контролируемых остатков денежных средств.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	&Организация КАК Организация";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Блокировка = Новый БлокировкаДанных;
	
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ВнеоборотныеАктивы");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Организация", "Организация");
	
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ВыработкаВнеоборотныхАктивов");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Организация", "Организация");
	
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ПараметрыВнеоборотныхАктивов");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Организация", "Организация");
	
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.СостоянияВнеоборотныхАктивов");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Организация", "Организация");
	

	//ПодольскийАИ #УчетПроектов 10.12.2020 {
	Если СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам Тогда
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.УчетПоПроектамВнеоборотныхАктивов");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Организация", "Организация");
	КонецЕсли;
	//ПодольскийАИ #УчетПроектов 10.12.2020 }
	
	Блокировка.Заблокировать();
	
	//Паганини#NexiaGeoLatex_
	НачислятьАмортизациюОтНачальнойСтоимости = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(ДокументСсылкаАмортизацияВА.Дата, Новый Структура("Организация", ДокументСсылкаАмортизацияВА.Организация)).НачислятьАмортизациюОтНачальнойСтоимости;
	Если НЕ НачислятьАмортизациюОтНачальнойСтоимости Тогда
	//_Паганини#NexiaGeoLatex	
	Запрос.Текст =
	//+++ Дмгг
