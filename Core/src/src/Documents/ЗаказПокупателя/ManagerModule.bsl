КонецПроцедуры // ИнициализироватьДанныеДокументаЗаказПокупателя()
	
	Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства, ДокументОбъектЗаказПокупателя) Экспорт
		
		Если ДокументОбъектЗаказПокупателя.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд Тогда
			ИнициализироватьДанныеДокументаЗаказНаряд(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства);
		Иначе
			ИнициализироватьДанныеДокументаЗаказПокупателя(ДокументСсылкаЗаказПокупателя, СтруктураДополнительныеСвойства);
		КонецЕсли;
		
	КонецПроцедуры
	
	#КонецОбласти
	
	#Область КонтрольОтрицательныхОстатков
	
	Процедура ВыполнитьКонтроль(ДокументОбъектЗаказПокупателя, ДополнительныеСвойства, Отказ, УдалениеПроведения = Ложь, ПроверятьИтогиРегистров = ЛОЖЬ) Экспорт
		// Kuzmich, 25.07.2019, Контролировать остатки запасов на складах при проведении документов
		Если Константы.КонтролироватьОстаткиЗапасовНаСкладахПриПроведении.Получить() Тогда
			
			Результат = УправлениеНебольшойФирмойСервер.ЗапросОтрицательныхОстатковЗапасовНаСкладахПриПроведенииДокумента(ДокументОбъектЗаказПокупателя);
			
			Если НЕ Результат.Пустой() Тогда
				Если ТипЗнч(ДокументОбъектЗаказПокупателя) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
					ДокументОбъектЗаказПокупателя_Объект = ДокументОбъектЗаказПокупателя.ПолучитьОбъект();
				ИначеЕсли ТипЗнч(ДокументОбъектЗаказПокупателя) = Тип("ДокументОбъект.ЗаказПокупателя") Тогда
					ДокументОбъектЗаказПокупателя_Объект = ДокументОбъектЗаказПокупателя;
				КонецЕсли;
				
				ВыборкаИзРезультатаЗапроса = Результат.Выбрать();
				УправлениеНебольшойФирмойСервер.СообщитьОбОшибкахПроведенияПоРегиструЗапасыНаСкладах(ДокументОбъектЗаказПокупателя_Объект, ВыборкаИзРезультатаЗапроса, Отказ);
			КонецЕсли;			
			
		КонецЕсли;
		// Kuzmich, 25.07.2019, Контролировать остатки запасов на складах при проведении документов
		
		//Малышев 2024-08-21 - отключил
		////Malyshev 2024-05-20
		//Если ДокументОбъектЗаказПокупателя.СостояниеЗаказа = Справочники.СостоянияЗаказНарядов.Завершен и ПроверятьИтогиРегистров = Ложь Тогда 
		//	Если ТипЗнч(ДокументОбъектЗаказПокупателя) = Тип("ДокументСсылка.ЗаказПокупателя") Тогда 
		//		ДокументОбъектЗаказПокупателя_Объект = ДокументОбъектЗаказПокупателя.ПолучитьОбъект();
		//	ИначеЕсли ТипЗнч(ДокументОбъектЗаказПокупателя) = Тип("ДокументОбъект.ЗаказПокупателя") Тогда
		//		ДокументОбъектЗаказПокупателя_Объект = ДокументОбъектЗаказПокупателя;
