Функция ЛарТетр(Сумма)
	
	Лари 	= Цел(Сумма);
	Тетри   = ОКР(100 * (Сумма - Лари), 0, 1);
	СуммаЛарТетр = "" + Лари + " ლარი. " + Цел(Тетри/10) + (Тетри - 10 * Цел(Тетри / 10)) + " თეთრი";
	
	СуммаЛарТетр = ЧислоПрописью(Сумма,"Л = ka_GE; ДП = Истина","ლარი, თეთრი, 2");  
	Возврат СуммаЛарТетр;      
	
