			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлФаксимильнаяПечать);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьПодвал.Рисунки.Факсимилия.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлПечати) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлПечати);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьПодвал.Рисунки.Печать.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаДокумент.Руководитель) Тогда
			Попытка
				ОбластьПодвал.Параметры.Руководитель = РС_ОбщегоНазначения.ПолучитьФИОФизЛиц(ВыборкаДокумент.Руководитель, ВыборкаДокумент.Дата);
			Исключение
			КонецПопытки;
		КонецЕсли;       
		
		ОбластьПодвал.Параметры.Ответственный = ВыборкаДокумент.Документ.Ответственный; 
		ОбластьПодвал.Параметры.Аддрес = УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(ВыборкаДокумент.Документ.СтруктурнаяЕдиницаРезерв, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);
        ОбластьПодвал.Параметры.Mail = УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(ОбластьПодвал.Параметры.Ответственный.Физлицо, Справочники.ВидыКонтактнойИнформации.EmailФизическиеЛица);
		//ОбластьПодвал.Параметры.Тел1 = УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(ОбластьПодвал.Параметры.Ответственный.Физлицо, Справочники.ВидыКонтактнойИнформации.ТелефонФизЛица);
			
		ПараметрыОтбора = Новый Структура("Вид",Справочники.ВидыКонтактнойИнформации.ТелефонФизЛица);	
		ДанныеОтбора = ОбластьПодвал.Параметры.Ответственный.Физлицо.КонтактнаяИнформация.Выгрузить(ПараметрыОтбора); 	
		Если ДанныеОтбора.количество() = 1 Тогда  	
			ОбластьПодвал.Параметры.Тел1 = ДанныеОтбора[0].Представление;
		ИначеЕсли  ДанныеОтбора.количество() > 1 Тогда
			ОбластьПодвал.Параметры.Тел1 = ДанныеОтбора[0].Представление;
			ОбластьПодвал.Параметры.Тел = "ტელ:";	
			ОбластьПодвал.Параметры.Тел2 = ДанныеОтбора[1].Представление;	
		КонецЕсли;        
					
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаДокумент.Документ);   
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
