		|	ТаблицаЗапасыПринятые.Заказ,
		|	ТаблицаЗапасыПринятые.СчетУчета,
		|	ТаблицаЗапасыПринятые.СчетУчетаРегл"; //+++ Дмгг
		
		Запрос.УстановитьПараметр("ПриемЗапасовТоварыНаКомиссии", НСтр("ka='მარაგების მიღება';ru='Прием запасов';en='Admission stocks'"));
		Запрос.УстановитьПараметр("ВалютаУпрУчета", Константы.ВалютаУчета.Получить());
		
