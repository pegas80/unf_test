		|		,Выразить(СуммаНДС * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК Число(15,2)) КАК СуммаНДС
		|		,Выразить(Всего * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК Число(15,2)) КАК Всего
		|	) КАК ТаблицаЗапасы
		|	,ЗаказПокупателя.Работы.(
		|		Номенклатура
		|		,Содержание
		|		,Выбор когда (ВЫРАЗИТЬ(Номенклатура.НаименованиеПолное КАК СТРОКА(1000))) = """"
		|			Тогда Номенклатура.Наименование
		|			Иначе Выразить(Номенклатура.НаименованиеПолное КАК СТРОКА(1000)) Конец КАК ПредставлениеНоменклатуры
		|		,Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры
		|		,Номенклатура.Код КАК ЗапасКод
		|		,Номенклатура.Артикул КАК Артикул
		|		,1 КАК КоэффициентЕдиницыИзмерения
		|		,Номенклатура.ЕдиницаИзмерения.Наименование КАК ЕдиницаИзмеренияПоОКЕИ_Наименование
		|		,Номенклатура.ЕдиницаИзмерения.Код КАК ЕдиницаИзмеренияПоОКЕИ_Код
		|		,Характеристика КАК Характеристика
		|		,Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|		,Неопределено КАК ВидУпаковки
		|		,ВЫРАЗИТЬ(Количество * Кратность * Коэффициент - &СмещениеДляОкругления КАК ЧИСЛО(15,3)) КАК Количество
		|		,Неопределено КАК КоличествоВОдномМесте
		|		,Неопределено КАК КоличествоМест
		|		,СтавкаНДС
		|		,Выразить(Цена * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК Число(15,2))
		|		,Выразить(Сумма * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК Число(15,2)) КАК Сумма
		|		,Выразить(СуммаНДС * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК Число(15,2)) КАК СуммаНДС
		|		,Выразить(Всего * ЗаказПокупателя.Курс / ЗаказПокупателя.Кратность КАК Число(15,2)) КАК Всего
		|	) КАК ТаблицаРаботыУслуги
		|Из Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|Где ЗаказПокупателя.Ссылка В (&МассивОбъектов)";
		
		// Олег Литвиненко 18.10.22 --->
		Запрос.УстановитьПараметр("СмещениеДляОкругления", 0.0005);
		// Олег Литвиненко <---
		ДанныеДокументов = Запрос.Выполнить().Выгрузить();
		ДоставкаСервер.ДобавитьСтрокуДоставкиТОРГ12(ДанныеДокументов);
		Возврат ДанныеДокументов;
		
	КонецФункции
	
	Функция ДанныеДокументовБланкТоварногоНаполнения(МассивОбъектов)
		
		Запрос = Новый Запрос;
