	|	ЗаказПокупателяРаботы.Ссылка.ВалютаДокумента,
	|	ЗаказПокупателяРаботы.НомерСтроки,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(ЗаказПокупателяРаботы.Номенклатура.НаименованиеПолное КАК СТРОКА(100))) = """"
	|			ТОГДА ЗаказПокупателяРаботы.Номенклатура.Наименование
	|		ИНАЧЕ ЗаказПокупателяРаботы.Номенклатура.НаименованиеПолное
	|	КОНЕЦ,
	|	ЗаказПокупателяРаботы.Характеристика,
	|	ЗаказПокупателяРаботы.Количество,
	|	ЗаказПокупателяРаботы.Цена,
	|	ЗаказПокупателяРаботы.СуммаНДС,
	|	ЗаказПокупателяРаботы.Всего,
	|	ЗаказПокупателяРаботы.Ссылка.Организация.БанковскийСчетПоУмолчанию.НомерСчета,
	|	ЗаказПокупателяРаботы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.Код,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(ЗаказПокупателяРаботы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.НаименованиеРуское КАК СТРОКА(100))) = """"
	|			ТОГДА ЗаказПокупателяРаботы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.Наименование
	|		ИНАЧЕ ЗаказПокупателяРаботы.Ссылка.Организация.БанковскийСчетПоУмолчанию.Банк.НаименованиеРуское
	|	КОНЕЦ,
	|	ЗаказПокупателяРаботы.Ссылка.Контрагент.ИНН,
	|	ЗаказПокупателяРаботы.Ссылка.Организация.ИНН,
	|	ЗаказПокупателяРаботы.Ссылка.Ответственный.Физлицо,
	|	ЗаказПокупателяРаботы.Ссылка.Организация.ФайлЛоготип,
	|	ЗаказПокупателяРаботы.Ссылка.Организация.ФайлФаксимильнаяПечать,
	|	ЗаказПокупателяРаботы.Ссылка.Организация.ФайлПечати,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(ЗаказПокупателяРаботы.Ссылка.Организация.ПодписьРуководителя.ФизическоеЛицо.НаименованиеРуское КАК СТРОКА(100))) = """"
	|			ТОГДА ЗаказПокупателяРаботы.Ссылка.Организация.ПодписьРуководителя.ФизическоеЛицо
	|		ИНАЧЕ ЗаказПокупателяРаботы.Ссылка.Организация.ПодписьРуководителя.ФизическоеЛицо.НаименованиеРуское
	|	КОНЕЦ
	|ИЗ
	|	Документ.ЗаказПокупателя.Работы КАК ЗаказПокупателяРаботы
	|ГДЕ
	|	ЗаказПокупателяРаботы.Ссылка В(&МассивОбъектов)
	// © Шишка В.В. [1 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	|ИТОГИ
	|	МАКСИМУМ(Продавец),
	|	МАКСИМУМ(Покупатель),
	|	КОЛИЧЕСТВО(НомерСтроки),
	|	СУММА(СуммаНДС),
	|	СУММА(Всего),
	|	МАКСИМУМ(БанковскийСчет)
	|ПО
	|	Документ";
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ВыборкаДокумент = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ПервыйДокумент = Истина;
	
	Пока ВыборкаДокумент.Следующий() Цикл
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		// Запомним номер строки, с которой начали выводить текущий документ.
		НомерСтрокиНачало	= ТабличныйДокумент.ВысотаТаблицы + 1;
		МакетПечатнойФормы	= УправлениеПечатью.МакетПечатнойФормы("Документ.ЗаказПокупателя.ПФ_MXL_InvoiceRus");//ПолучитьМакет("ПФ_MXL_Invoice");
		
		// Вывод шапки для документа
		ОбластьШапки = МакетПечатнойФормы.ПолучитьОбласть("Шапка");
		ОбластьШапки.Параметры.Заполнить(ВыборкаДокумент);
		Попытка
			ОбластьШапки.Параметры.Дата	= Формат(ВыборкаДокумент.Дата , "ДФ=dd.MM.yyyy");
		Исключение
		КонецПопытки;
		
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлЛоготип) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлЛоготип);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьШапки.Рисунки.Лого.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьШапки);
		
		// Вывод таблицной части
		ВыборкаДанныхДокумента = ВыборкаДокумент.Выбрать();
		ОбластьСтрока = МакетПечатнойФормы.ПолучитьОбласть("ТабличаяЧасть");
		Пока ВыборкаДанныхДокумента.Следующий() Цикл 
			ОбластьСтрока.Параметры.Заполнить(ВыборкаДанныхДокумента);
			ТабличныйДокумент.Вывести(ОбластьСтрока);
		КонецЦикла;
		
		// Вывод подвала для документа
		ОбластьПодвал = МакетПечатнойФормы.ПолучитьОбласть("Подвал");
		ОбластьПодвал.Параметры.Заполнить(ВыборкаДокумент);
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлФаксимильнаяПечать) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлФаксимильнаяПечать);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьПодвал.Рисунки.Факсимилия.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаДокумент.ФайлПечати) Тогда
			ДанныеКартинки = ПрисоединенныеФайлы.ПолучитьДвоичныеДанныеФайла(ВыборкаДокумент.ФайлПечати);
			Если ЗначениеЗаполнено(ДанныеКартинки) Тогда
				Попытка
					ОбластьПодвал.Рисунки.Печать.Картинка = Новый Картинка(ДанныеКартинки);
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(ВыборкаДокумент.Руководитель) Тогда
			Попытка
				ОбластьПодвал.Параметры.Руководитель = ВыборкаДокумент.Руководитель;
			Исключение
			КонецПопытки;
		КонецЕсли;
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		// В табличном документе зададим имя области, в которую был 
		// выведен объект. Нужно для возможности печати покомплектно.
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаДокумент.Документ);   
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции//_Паганини

Функция ПечатьPurchaseOrder(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати	= "ПараметрыПечати_PurchaseOrder";
	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_ЗаказПокупателя_PurchaseOrder";
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	
	ПервыйДокумент = Истина;
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
		/////////////////////////////////////////////////////////////////////////////////////////
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ЗаказПокупателя.ПФ_MXL_PurchaseOrder");
		ВалютаДокумента = ТекущийДокумент.ВалютаДокумента;
		Если ВалютаУчета = ВалютаДокумента Тогда
			ОбластьМакета = Макет.ПолучитьОбласть("МакетБезВалют");
		Иначе
			ОбластьМакета = Макет.ПолучитьОбласть("Макет");
		КонецЕсли;
		/////////////////////////////////////////////////////////////////////////////////////////
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Организация = ТекущийДокумент.Организация;
		ОбластьМакета.Параметры.Номер 					= ТекущийДокумент.Номер;
		ОбластьМакета.Параметры.Организация 			= Организация;
		ОбластьМакета.Параметры.ИННОрганизации 			= Организация.ИНН;
		ТаблицаЮрАдресОрг = Организация.КонтактнаяИнформация.Найти(Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации,"Вид");
		Если ТаблицаЮрАдресОрг <> Неопределено Тогда
			ОбластьМакета.Параметры.ЮрАдресОрганизации	= ТаблицаЮрАдресОрг.Представление
		КонецЕсли;
		ОбластьМакета.Параметры.Дата 					= ТекущийДокумент.Дата;
		ДополнительныеРеквизиты = ТекущийДокумент.ДополнительныеРеквизиты;
		Activity    = "";
		CostCenter  = "";
		Product		= "";
		Для Каждого СтрокаДР Из ДополнительныеРеквизиты Цикл
			Если Строка(СтрокаДР.Свойство) = "Activity" Тогда
				Activity 	= СтрокаДР.Значение;
			ИначеЕсли Строка(СтрокаДР.Свойство) = "Cost Center" Тогда
				CostCenter	= СтрокаДР.Значение;
			ИначеЕсли Строка(СтрокаДР.Свойство) = "Product" Тогда
				Product 	= СтрокаДР.Значение;
			КонецЕсли;
		КонецЦикла;
		ОбластьМакета.Параметры.Activity	= Activity;
		ОбластьМакета.Параметры.CostCenter 	= CostCenter;
		ОбластьМакета.Параметры.Product		= Product;
		Запасы = ТекущийДокумент.Запасы;
		СчетУчетаЗатрат = "";
		Номенклатура 	= "";
		Цена 			= "";
		Количество 		= "";
		Сумма			= "";
		Если Запасы.Количество() > 0 Тогда
			СчетУчетаЗатрат = Запасы[0].Номенклатура.СчетУчетаЗатрат.Код;
			Номенклатура	= Запасы[0].Номенклатура;
			Цена            = Запасы[0].Цена;
			Количество      = Запасы[0].Количество;
			Сумма           = Запасы[0].Сумма;
		КонецЕсли;
		ОбластьМакета.Параметры.AccountCode 	= СчетУчетаЗатрат;
		ОбластьМакета.Параметры.Автор 			= ТекущийДокумент.Автор;
		ОбластьМакета.Параметры.Контрагент 		= ТекущийДокумент.Контрагент;
		ОбластьМакета.Параметры.Номенклатура 	= Номенклатура;
		ОбластьМакета.Параметры.Цена 			= Цена;
		ОбластьМакета.Параметры.Количество		= Количество;
		ОбластьМакета.Параметры.Сумма 			= Сумма;
		
		ОбластьМакета.Параметры.СуммаВсего		= Сумма;
		Если ВалютаУчета <> ВалютаДокумента Тогда
			ОбластьМакета.Параметры.ВалютаДокумента	= ВалютаДокумента;
			ОбластьМакета.Параметры.GEL				= "GEL";
			КурсВалюты = ?(ТекущийДокумент.Кратность = 0, 1, ТекущийДокумент.Курс/ТекущийДокумент.Кратность);		
			ОбластьМакета.Параметры.КурсВалюты      = Окр(КурсВалюты		, 4);
			ОбластьМакета.Параметры.ВсегоЛари       = Окр(Сумма * КурсВалюты, 2);
		КонецЕсли;
		ОбластьМакета.Параметры.ВремяПечати     = ТекущаяДата();
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()
