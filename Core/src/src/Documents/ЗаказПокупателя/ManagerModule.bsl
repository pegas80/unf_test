		Если МобильноеПриложениеВызовСервера.НужноОграничитьФункциональность() Тогда
			Возврат;
		КонецЕсли;
		// Конец МобильноеПриложение
		
		СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
		
		// Если временные таблицы "ДвиженияЗапасыНаСкладахИзменение", "ДвиженияЗапасыИзменение",
		// "ДвиженияЗаказыПокупателейИзменение", "ДвиженияПотребностьВЗапасахИзменение",
		// "ДвиженияРасчетыСПокупателямиИзменение" содержат записи, необходимо выполнить 
		// контроль остатков.
		
		Если СтруктураВременныеТаблицы.ДвиженияЗапасыНаСкладахИзменение
			ИЛИ СтруктураВременныеТаблицы.ДвиженияЗапасыИзменение
			ИЛИ СтруктураВременныеТаблицы.ДвиженияЗапасыВРазрезеГТДИзменение
			ИЛИ СтруктураВременныеТаблицы.ДвиженияЗаказыПокупателейИзменение
			ИЛИ СтруктураВременныеТаблицы.ДвиженияПотребностьВЗапасахИзменение
			ИЛИ СтруктураВременныеТаблицы.ДвиженияРасчетыСПокупателямиИзменение 
			ИЛИ СтруктураВременныеТаблицы.ДвиженияСерийныеНомераИзменение
			ИЛИ СтруктураВременныеТаблицы.ДвиженияСерийныеНомераИзменение
			ИЛИ (Константы.ФункциональнаяОпцияРезервированиеЗапасов_new.Получить() И СтруктураВременныеТаблицы.ДвиженияРезервированиеЗапасовИзменение) // Kuzmich, ONESOFT-2440, Использование резервов - Переместить в хранилище - Исправления
			Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = СформироватьТекстЗапросаОстаткиЗапасыНаСкладах() // [0]
			
			//Малышев 2024-06-17 ONESOFT-3094 (--
	    	//+ СформироватьТекстЗапросаОстаткиЗапасы() // [1]
			+ УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКонтроля_ОстаткиЗапасов(ДополнительныеСвойства, Истина) // МассивРезультатов[1]
			//Малышев 2024-06-17 ONESOFT-3094 --)
		
			+ СформироватьТекстЗапросаОстаткиЗаказыПокупателей() // [2]
			+ СформироватьТекстЗапросаОстаткиПотребностьВЗапасах() // [3]
			+ СформироватьТекстЗапросаОстаткиРасчетыСПокупателями()// [4]
			+ СформироватьТекстЗапросаОстаткиСерийныеНомера()// [5]
			+ СформироватьТекстЗапросаОстаткиЗапасыВРазрезеГТД()
			//Малышев 2024-06-17 ONESOFT-3094 (--
			//+ СформироватьТекстЗапросаОстаткиЗапасыРегл()
			//+ УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКонтроля_ОстаткиЗапасов(ДополнительныеСвойства, Ложь) // [7]
			////Малышев 2024-06-17 ONESOFT-3094 --)
			//

			; // [7] //+++ Дмгг
			// Kuzmich, ONESOFT-2440, Использование резервов - Переместить в хранилище - Исправления
			Если Константы.ФункциональнаяОпцияРезервированиеЗапасов_new.Получить() И НЕ(ПроверятьИтогиРегистров И ДокументОбъектЗаказПокупателя.СостояниеЗаказа = Справочники.СостоянияЗаказНарядов.Завершен) Тогда
				
				Запрос.Текст = Запрос.Текст + УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКонтроля_ОстаткиЗапасов(ДополнительныеСвойства, ИСТИНА) // [7]
				 + РезервированиеЗапасов_new.ПолучитьТекстЗапросаКонтроля_РезервированиеЗапасов(ДополнительныеСвойства, ЛОЖЬ); //[11]
				
				Запрос.УстановитьПараметр("КонтролироватьОстаткиПриПроведенииПоПроектам",  ДополнительныеСвойства.УчетнаяПолитика.КонтролироватьОстаткиПриПроведенииПоПроектам);
				
				//Если ДокументОбъектЗаказПокупателя.СостояниеЗаказа = Справочники.СостоянияЗаказНарядов.Завершен И ЗначениеЗаполнено(ДокументОбъектЗаказПокупателя.Финиш) Тогда
				//	Если ДокументОбъектЗаказПокупателя.Финиш > ДокументОбъектЗаказПокупателя.Дата Тогда
				//		Запрос.УстановитьПараметр("МоментКонтроляРезерва", Новый Граница(ДокументОбъектЗаказПокупателя.Финиш,ВидГраницы.Исключая));
				//	Иначе
				//		Запрос.УстановитьПараметр("МоментКонтроляРезерва", ДокументОбъектЗаказПокупателя.МоментВремени());
				//	КонецЕсли;
				//Иначе
				//	Запрос.УстановитьПараметр("МоментКонтроляРезерва", ДокументОбъектЗаказПокупателя.МоментВремени());
				//КонецЕсли;
				
			Иначе
				
				Запрос.Текст = Запрос.Текст + УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКонтроля_ОстаткиЗапасов(ДополнительныеСвойства, Ложь); // [7]
				
			КонецЕсли;
			// Kuzmich, ONESOFT-2440, Использование резервов - Переместить в хранилище - Исправления
			
			Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
			Если НЕ ПроверятьИтогиРегистров Тогда 
				Запрос.УстановитьПараметр("МоментКонтроля", ДополнительныеСвойства.ДляПроведения.МоментКонтроля);
			Иначе 
				Запрос.УстановитьПараметр("МоментКонтроля", Дата(2999,12,31));
			КонецЕсли;
			
			МассивРезультатов = Запрос.ВыполнитьПакет();
			
			// Отрицательный остаток запасов на складе.
			Если НЕ МассивРезультатов[0].Пустой() Тогда
				ВыборкаИзРезультатаЗапроса = МассивРезультатов[0].Выбрать();
