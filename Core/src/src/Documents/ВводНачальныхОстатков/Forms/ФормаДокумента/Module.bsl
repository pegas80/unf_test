//+++ Дмгг
&НаКлиенте
Функция ПолучитьДанныеВыбораПоАдресу(Элемент, Адрес, СтандартнаяОбработка)

    // Выключим стандартную обработку
    СтандартнаяОбработка    =    Ложь;
    
    // Определим структуру для получения параметров отбора, 
    // так как стандартный выбор мы выключим значения структуры пусты                                                            
    ПараметрыПодбора    =    Новый Структура("Отбор,СтрокаПоиска,ВыборГруппИЭлементов",
                                Новый Структура(), // Здесь можно установить отбор
                                "",                // Передаем введенный в поле текст
                                ПредопределенноеЗначение("ИспользованиеГруппИЭлементов.Элементы"));
                                
    // Дополним стандартную структуру с дополнительными параметрами для поиска по адресу
    ПараметрыПодбора.Вставить("ДополнительныеПараметры", Новый Структура("Адрес", Адрес));
    
    
    // Передаем адрес и получаем список выбора
    Возврат    ПолучитьДанныеВыбора(Тип("СправочникСсылка.Адреса"), ПараметрыПодбора);

КонецФункции

&НаКлиенте
Процедура РедактироватьАдресаЗавершение(Результат, ДополнительныеПараметры) Экспорт
    
    ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	Если ЗначениеЗаполнено(Результат) Тогда 
		ТекСтрока.Адрес = Результат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыАдресНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	
	П = Новый Структура;
	П.Вставить("Ключ", ТекСтрока.Адрес);
	
	ОткрытьФорму("Справочник.Адреса.ФормаВыбора", П, ЭтаФорма,,,,Новый ОписаниеОповещения("РедактироватьАдресаЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыАдресОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	
	ТекСтрока.Адрес    =    ВыбранноеЗначение;	

КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыАдресАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;

    знТекст    =    ?(ПустаяСтрока(Текст), ТекСтрока.Адрес, Текст);
    ДанныеВыбора    =    ПолучитьДанныеВыбораПоАдресу(Элемент, знТекст, СтандартнаяОбработка);
	
КонецПроцедуры

&НаСервере
Процедура КредитыИЗаймиОсновнойДолгПриИзмененииНаСервере(СтрокаТабличнойЧасти)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВалютаДокумента.Курс КАК КурсДок,
		|	ВалютаДокумента.Кратность КАК КратностьДок,
		|	ВалютаНац.Курс КАК КурсНац,
		|	ВалютаНац.Кратность КАК КратностьНац,
		|	ВалютаУпрУчета.Курс КАК КурсУпр,
		|	ВалютаУпрУчета.Кратность КАК КратностьУпр
		|ИЗ
		|	РегистрСведений.КурсыВалют.СрезПоследних(&Дата, Валюта = &ВалютаУпр) КАК ВалютаУпрУчета,
		|	РегистрСведений.КурсыВалют.СрезПоследних(&Дата, Валюта = &ВалютаНац) КАК ВалютаНац,
		|	РегистрСведений.КурсыВалют.СрезПоследних(&Дата, Валюта = &ВалютаДок) КАК ВалютаДокумента";
	
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата()));
	Запрос.УстановитьПараметр("ВалютаУпр", Константы.ВалютаУчета.Получить());
	Запрос.УстановитьПараметр("ВалютаДок", СтрокаТабличнойЧасти.Валюта);
	Запрос.УстановитьПараметр("ВалютаНац", НациональнаяВалюта);
	РезультатЗапроса = Запрос.Выполнить();
	
	тзКурсов = РезультатЗапроса.Выгрузить();
	
	Если тзКурсов.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	СтрокаКурсов = тзКурсов[0];
	
	СтрокаТабличнойЧасти.ОсновнойДолгВал = СтрокаТабличнойЧасти.ОсновнойДолг * СтрокаКурсов.КратностьНац * СтрокаКурсов.КурсДок / (СтрокаКурсов.КратностьДок * СтрокаКурсов.КурсНац);
	
КонецПроцедуры

&НаКлиенте
Процедура КредитыИЗаймиОсновнойДолгПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.КредитыИЗайми.ТекущиеДанные;
	Если СтрокаТабличнойЧасти.Валюта <> НациональнаяВалюта Тогда
		КредитыИЗаймиОсновнойДолгПриИзмененииНаСервере(СтрокаТабличнойЧасти);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьТабличнуюЧастьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Ответ = Результат;
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ПересчитатьТабличнуюЧастьЗавершениеНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьТабличнуюЧастьЗавершениеНаСервере()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТабЧастьКредитыИЗаймы.Валюта,
		|	ТабЧастьКредитыИЗаймы.ДоговорКредитаЗайма,
		|	ТабЧастьКредитыИЗаймы.Контрагент,
		|	ТабЧастьКредитыИЗаймы.ОсновнойДолг,
		|	ТабЧастьКредитыИЗаймы.Проценты
		|ПОМЕСТИТЬ ВременнаяТаблицаКредитыИЗаймы
		|ИЗ
		|	&ТабЧастьКредитыИЗаймы КАК ТабЧастьКредитыИЗаймы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблицаКредитыИЗаймы.Валюта,
		|	ВременнаяТаблицаКредитыИЗаймы.ДоговорКредитаЗайма,
		|	ВременнаяТаблицаКредитыИЗаймы.Контрагент,
		|	ВременнаяТаблицаКредитыИЗаймы.ОсновнойДолг,
		|	ВременнаяТаблицаКредитыИЗаймы.Проценты,
		|	ВЫБОР
		|		КОГДА ВременнаяТаблицаКредитыИЗаймы.Валюта = &ВалютаНац
		|			ТОГДА 0
		|		ИНАЧЕ ВременнаяТаблицаКредитыИЗаймы.ОсновнойДолг * КурсыВалютСрезПоследних.Кратность * КурсыВалютНац.Курс / (КурсыВалютНац.Кратность * КурсыВалютСрезПоследних.Курс)
		|	КОНЕЦ КАК ОсновнойДолгВал,
		|	ВЫБОР
		|		КОГДА ВременнаяТаблицаКредитыИЗаймы.Валюта = &ВалютаНац
		|			ТОГДА 0
		|		ИНАЧЕ ВременнаяТаблицаКредитыИЗаймы.Проценты * КурсыВалютСрезПоследних.Кратность * КурсыВалютНац.Курс / (КурсыВалютНац.Кратность * КурсыВалютСрезПоследних.Курс)
		|	КОНЕЦ КАК ПроцентыВал
		|ИЗ
		|	ВременнаяТаблицаКредитыИЗаймы КАК ВременнаяТаблицаКредитыИЗаймы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(&Дата, ) КАК КурсыВалютСрезПоследних
		|		ПО ВременнаяТаблицаКредитыИЗаймы.Валюта = КурсыВалютСрезПоследних.Валюта,
		|	РегистрСведений.КурсыВалют.СрезПоследних(&Дата, Валюта = &ВалютаНац) КАК КурсыВалютНац";
	
	Запрос.УстановитьПараметр("ВалютаНац", НациональнаяВалюта);
	Запрос.УстановитьПараметр("Дата", Объект.Дата);
	Запрос.УстановитьПараметр("ТабЧастьКредитыИЗаймы", Объект.КредитыИЗайми.Выгрузить());
	
	тзРезультат = Запрос.Выполнить().Выгрузить();
	
	Объект.КредитыИЗайми.Загрузить(тзРезультат);

КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыДатаВводаВЭксплуатациюПриИзменении(Элемент)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	ПолучитьКоличествоМесяцевЭксплуатации(ТекСтрока);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьКоличествоМесяцевЭксплуатации(ТекСтрока)

	КоличествоГодов = Год(ДатаДокумента) - Год(ТекСтрока.ДатаВводаВЭксплуатацию);
	КоличествоМесяцев = Месяц(ДатаДокумента) - Месяц(ТекСтрока.ДатаВводаВЭксплуатацию);
	
	ТекСтрока.КоличествоМесяцеВЭксплуатации = ?(КоличествоМесяцев > 0, КоличествоГодов*12 + КоличествоМесяцев+1, (КоличествоГодов-1)*12 + (13 + КоличествоМесяцев));
	
КонецПроцедуры

