				ОстатокПерсчета = СтрокаТоваров.Сумма - СуммаПредоплатыВал;
				СуммаПредоплатыВал = 0;
			КонецЕсли;
			
							
		КонецЦикла;
		
		
	КонецЦикла;
	
	Если ОстатокПерсчета <> 0 Тогда 
		СуммаРегл = СуммаРегл + (ОстатокПерсчета * КурсДок * КратностьДок);
		СуммаНДСРегл = ?(ДокументСсылкаДополнительныеРасходы.СуммаВключаетНДС,//СуммаНДСРегл + ?(ДокументСсылкаПриходнаяНакладная.СуммаВключаетНДС, 
