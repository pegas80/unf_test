#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаЗапасы(ДокументСсылкаДополнительныеРасходы, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	МИНИМУМ(ТаблицаЗапасы.НомерСтроки) КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаЗапасы.Период КАК Период,
	|	ТаблицаЗапасы.Организация КАК Организация,
	|	ТаблицаЗапасы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ТаблицаЗапасы.СчетУчета КАК СчетУчета,
	|	ТаблицаЗапасы.СчетУчетаРегл КАК СчетУчетаРегл,
	|	ТаблицаЗапасы.Номенклатура КАК Номенклатура,
	|	ТаблицаЗапасы.Характеристика КАК Характеристика,
	|	ТаблицаЗапасы.Партия КАК Партия,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ТаблицаЗапасы.Проект КАК Проект,
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	ТаблицаЗапасы.ЗаказПокупателя КАК ЗаказПокупателя,
	|	ИСТИНА КАК ФиксированнаяСтоимость,
	|	&ОприходованиеЗапасов КАК СодержаниеПроводки,
	|	0 КАК Количество,
	//|	СУММА(ТаблицаЗапасы.СуммаИмпорт) КАК Сумма //СуммаРасходов) КАК Сумма
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаЗапасы.ВалютаРасчетов <> НацВалюта.Значение
	|			ТОГДА ТаблицаЗапасы.СуммаИмпорт
	|		ИНАЧЕ ТаблицаЗапасы.СуммаРасходов
	|	КОНЕЦ) КАК Сумма
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаЗапасы,
	|	Константа.НациональнаяВалюта КАК НацВалюта
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаЗапасы.Период,
	|	ТаблицаЗапасы.Организация,
	|	ТаблицаЗапасы.СтруктурнаяЕдиница,
	|	ТаблицаЗапасы.СчетУчета,
	|	ТаблицаЗапасы.СчетУчетаРегл,
	|	ТаблицаЗапасы.Номенклатура,
	|	ТаблицаЗапасы.Характеристика,
	|	ТаблицаЗапасы.Партия,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ТаблицаЗапасы.Проект,
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	ТаблицаЗапасы.ЗаказПокупателя";
	
	Запрос.УстановитьПараметр("ОприходованиеЗапасов", НСтр("ka='მარაგების შემოსავალში აყვანა';ru='Оприходование запасов';en='Posting of Goods'"));
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗапасы", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаЗапасы()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыСПоставщиками(ДокументСсылкаДополнительныеРасходы, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаДополнительныеРасходы);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ПериодКонтроля", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени.Дата);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ВозникновениеОбязательствПередПоставщиком", НСтр("ka='მომწოდებლის წინაშე ვალდებულებების წარმოშობა';ru='Возникновение обязательств перед поставщиком';en='The emergence of obligations to the supplier'"));
	Запрос.УстановитьПараметр("ЗачетАванса", НСтр("ka='წინასწარ გადახდილი თანხის ჩათვლა';ru='Зачет предоплаты';en='Зачет предоплаты'"));
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ka='სხვაობა კურსებს შორის';ru='Курсовая разница';en='Exchange difference'"));
	Запрос.УстановитьПараметр("СуммаВключаетНДС", ДокументСсылкаДополнительныеРасходы.СуммаВключаетНДС);
	
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК Порядок, 
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.Период КАК Дата,
	|	ТаблицаДокумента.Организация КАК Организация,
	|	ТаблицаДокумента.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.ВестиРасчетыПоДокументам КАК ВестиРасчетыПоДокументам,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПоставщиком КАК СчетУчета,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПоставщикомРегл КАК СчетУчетаРегл,
	|	ТаблицаДокумента.Договор КАК Договор,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА &Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Документ,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ЗаказПоставщику ССЫЛКА Документ.ЗаказПоставщику
	|				И ТаблицаДокумента.ЗаказПоставщику <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|				И ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.ЗаказПоставщику
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|	КОНЕЦ КАК Заказ,
	|	ТаблицаДокумента.ВалютаРасчетов КАК Валюта,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг) КАК ТипРасчетов,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта) КАК Проект,
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	//Паганини ПФ_
	//|	СУММА(ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ) КАК Сумма,
	//|	СУММА(ТаблицаДокумента.СуммаРасходовВал - ТаблицаДокумента.СуммаРасходовНДФЛВал) КАК СуммаВал,
	//|	СУММА(ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ) КАК СуммаДляОстатка,
	//|	СУММА(ТаблицаДокумента.СуммаРасходовВал - ТаблицаДокумента.СуммаРасходовНДФЛВал) КАК СуммаВалДляОстатка,
	//|	СУММА(ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ) КАК Сумма,
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаДокумента.ВалютаРасчетов <> НацВалюта.Значение И &СуммаВключаетНДС
	//|			ТОГДА ТаблицаДокумента.СуммаРасходов + ТаблицаДокумента.СуммаРасходовНДС - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	|			ТОГДА ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	//|		ИНАЧЕ ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	|		КОГДА ТаблицаДокумента.ВалютаРасчетов <> НацВалюта.Значение И НЕ &СуммаВключаетНДС
	|			ТОГДА ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	//--------------------------------------------------------------------------
	// © Шишка В.В. [17 мая 2022 г.]  НАЧАЛО
	//|		ИНАЧЕ ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	|		ИНАЧЕ ТаблицаДокумента.СуммаРасходовУпр - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	// © Шишка В.В. [17 мая 2022 г.]  КОНЕЦ
	//--------------------------------------------------------------------------
	|	КОНЕЦ) КАК Сумма,
	|	СУММА(ТаблицаДокумента.СуммаРасходовВал - ТаблицаДокумента.СуммаРасходовНДФЛВал - ТаблицаДокумента.СуммаРасходовПФВал) КАК СуммаВал,
	//|	СУММА(ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ) КАК СуммаДляОстатка,
	|	СУММА(ВЫБОР
	|		КОГДА ТаблицаДокумента.ВалютаРасчетов <> НацВалюта.Значение И &СуммаВключаетНДС
	|			ТОГДА ТаблицаДокумента.СуммаРасходов + ТаблицаДокумента.СуммаРасходовНДС - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	|		КОГДА ТаблицаДокумента.ВалютаРасчетов <> НацВалюта.Значение И НЕ &СуммаВключаетНДС
	|			ТОГДА ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	|		ИНАЧЕ ТаблицаДокумента.СуммаРасходов - ТаблицаДокумента.СуммаРасходовНДФЛ - ТаблицаДокумента.СуммаРасходовПФ
	|	КОНЕЦ) КАК СуммаДляОстатка,
	|	СУММА(ТаблицаДокумента.СуммаРасходовВал - ТаблицаДокумента.СуммаРасходовНДФЛВал - ТаблицаДокумента.СуммаРасходовПФВал) КАК СуммаВалДляОстатка,
	//_Паганини ПФ	
	|	ВЫРАЗИТЬ(&ВозникновениеОбязательствПередПоставщиком КАК СТРОКА(100)) КАК СодержаниеПроводки
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПоставщиками
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК ТаблицаДокумента,
	|	Константа.НациональнаяВалюта КАК НацВалюта
	|
	|ГДЕ 
	|	ТаблицаДокумента.СуммаРасходов <> 0
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДокумента.Период,
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.Контрагент,
	|	ТаблицаДокумента.ВестиРасчетыПоДокументам,
	|	ТаблицаДокумента.Договор,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ЗаказПоставщику ССЫЛКА Документ.ЗаказПоставщику
	|				И ТаблицаДокумента.ЗаказПоставщику <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|				И ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.ЗаказПоставщику
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|	КОНЕЦ,
	|	ТаблицаДокумента.ВалютаРасчетов,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПоставщиком,
	|	ТаблицаДокумента.СчетУчетаРасчетовСПоставщикомРегл,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА &Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	Расходы.Период,
	|	Расходы.Организация,
	|	Расходы.Контрагент,
	|	Расходы.ВестиРасчетыПоДокументам,
	|	Расходы.СчетУчетаРасчетовСПоставщиком,
	|	Расходы.СчетУчетаРасчетовСПоставщикомРегл,
	|	Расходы.Договор,
	|	ВЫБОР
	|		КОГДА Расходы.ВестиРасчетыПоДокументам
	|			ТОГДА &Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА Расходы.ЗаказПоставщику ССЫЛКА Документ.ЗаказПоставщику
	|				И Расходы.ЗаказПоставщику <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|				И Расходы.ВестиРасчетыПоЗаказам
	|			ТОГДА Расходы.ЗаказПоставщику
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|	КОНЕЦ,
	|	Расходы.ВалютаРасчетов,
	|	ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг),
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта),
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	СУММА(Расходы.СуммаНДС),
	|	СУММА(Расходы.СуммаНДСВал),
	|	СУММА(Расходы.СуммаНДС),
	|	СУММА(Расходы.СуммаНДСВал),
	|	ВЫРАЗИТЬ(&ВозникновениеОбязательствПередПоставщиком КАК СТРОКА(100))
	|ИЗ
	|	ВременнаяТаблицаРасходы КАК Расходы
	|ГДЕ
	|	Расходы.СуммаНДС <> 0
	|
	|СГРУППИРОВАТЬ ПО
	|	Расходы.Период,
	|	Расходы.Организация,
	|	Расходы.Контрагент,
	|	Расходы.ВестиРасчетыПоДокументам,
	|	Расходы.Договор,
	|	ВЫБОР
	|		КОГДА Расходы.ЗаказПоставщику ССЫЛКА Документ.ЗаказПоставщику
	|				И Расходы.ЗаказПоставщику <> ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|				И Расходы.ВестиРасчетыПоЗаказам
	|			ТОГДА Расходы.ЗаказПоставщику
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПоставщику.ПустаяСсылка)
	|	КОНЕЦ,
	|	Расходы.ВалютаРасчетов,
	|	Расходы.СчетУчетаРасчетовСПоставщиком,
	|	Расходы.СчетУчетаРасчетовСПоставщикомРегл,
	|	ВЫБОР
	|		КОГДА Расходы.ВестиРасчетыПоДокументам
	|			ТОГДА &Ссылка
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	3,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
	|	ТаблицаДокумента.Период,
	|	ТаблицаДокумента.Организация,
	|	ТаблицаДокумента.Контрагент,
	|	ТаблицаДокумента.ВестиРасчетыПоДокументам,
	|	ТаблицаДокумента.СчетУчетаАвансовПоставщику,
	|	ТаблицаДокумента.СчетУчетаАвансовПоставщикуРегл,
	|	ТаблицаДокумента.Договор,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
