Процедура СформироватьТаблицаЗакупкиДляКУДиР(ДокументСсылкаДополнительныеРасходы, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаДополнительныеРасходы);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВременнаяТаблицаПредоплата.Период КАК Период,
	|	ВременнаяТаблицаПредоплата.Период КАК ДатаДокумента,
	|	ВременнаяТаблицаПредоплата.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаПредоплата.ОрганизацияВНУ КАК Организация,
	|	&Ссылка КАК ТоварныйДокумент,
	|	ВременнаяТаблицаПредоплата.Документ КАК ДенежныйДокумент,
	|	ВременнаяТаблицаПредоплата.Документ.УчитыватьВНУ КАК УчитыватьВНУ,
	|	ВЫБОР
	|		КОГДА ВременнаяТаблицаПредоплата.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС)
	|			ТОГДА 18
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК СтавкаНДС,
	|	ЛОЖЬ КАК ЭтоТоварыКРеализации,
	|	СУММА(ВременнаяТаблицаПредоплата.СуммаВал) КАК СуммаВал,
	|	СУММА(ВременнаяТаблицаПредоплата.СуммаВал) КАК Сумма,
	|	0  СуммаНДС,
	|	ВременнаяТаблицаПредоплата.ВалютаРасчетов КАК Валюта
	|ИЗ
	|	ВременнаяТаблицаПредоплата КАК ВременнаяТаблицаПредоплата
	|ГДЕ
	|	ВременнаяТаблицаПредоплата.ВестиРасчетыПоДокументам
	|	И ВременнаяТаблицаПредоплата.ОрганизацияВНУ.ЮридическоеФизическоеЛицо = ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВременнаяТаблицаПредоплата.НомерСтроки,
	|	ВременнаяТаблицаПредоплата.Период,
	|	ВременнаяТаблицаПредоплата.ОрганизацияВНУ,
	|	ВременнаяТаблицаПредоплата.Документ,
	|	ВременнаяТаблицаПредоплата.НалогообложениеНДС,
	|	ВременнаяТаблицаПредоплата.ВалютаРасчетов,
	|	ВременнаяТаблицаПредоплата.Документ.УчитыватьВНУ
	|;
	|";
	
	ТаблицаРезультат = Запрос.Выполнить().Выгрузить();
	
	УчетВалюты = ПолучитьФункциональнуюОпцию("УчетВалютныхОпераций");
	НацВалюта = Константы.НациональнаяВалюта.Получить();
	ВалютаДокумента = ДокументСсылкаДополнительныеРасходы.ВалютаДокумента;
	
	Если УчетВалюты И ВалютаДокумента <> НацВалюта Тогда
		ТекущийКурс = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаДокумента, ДокументСсылкаДополнительныеРасходы.Дата);
		Для Каждого СтрокаОплаты Из ТаблицаРезультат Цикл
			СтрокаОплаты.Сумма = СтрокаОплаты.Сумма * ТекущийКурс.Курс / ТекущийКурс.Кратность;
			СтрокаОплаты.СуммаНДС = СтрокаОплаты.Сумма - СтрокаОплаты.Сумма /((100+ СтрокаОплаты.СтавкаНДС)/100);
			СтрокаОплаты.Сумма = СтрокаОплаты.Сумма - СтрокаОплаты.СуммаНДС;
		КонецЦикла;
	Иначе
		Для Каждого СтрокаОплаты Из ТаблицаРезультат Цикл
			СтрокаОплаты.СуммаНДС = СтрокаОплаты.Сумма - СтрокаОплаты.Сумма /((100+ СтрокаОплаты.СтавкаНДС)/100);
			СтрокаОплаты.Сумма = СтрокаОплаты.Сумма - СтрокаОплаты.СуммаНДС;
		КонецЦикла;
	КонецЕсли;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗакупкиДляКУДиР", ТаблицаРезультат);
	
КонецПроцедуры // СформироватьТаблицаЗакупкиДляКУДиР()

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаДополнительныеРасходы, СтруктураДополнительныеСвойства) Экспорт
	
	тзЗапасы = ДокументСсылкаДополнительныеРасходы.Запасы.Выгрузить();
	тзЗапасы.Колонки.Добавить("СуммаРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаНДСРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаРасходовРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаРасходовНДСРегл", Новый ОписаниеТипов("Число"));
	тзЗапасы.Колонки.Добавить("СуммаРасходовСНДС", Новый ОписаниеТипов("Число"));
	
	Для Каждого Строк Из тзЗапасы Цикл 
		Строк.СуммаРегл = Строк.Сумма * ДокументСсылкаДополнительныеРасходы.Курс * ДокументСсылкаДополнительныеРасходы.Кратность;
		Строк.СуммаНДСРегл = Строк.СуммаНДС * ДокументСсылкаДополнительныеРасходы.Курс * ДокументСсылкаДополнительныеРасходы.Кратность;
		Строк.СуммаРасходовРегл = Строк.СуммаРасходов * ДокументСсылкаДополнительныеРасходы.Курс * ДокументСсылкаДополнительныеРасходы.Кратность;
		Строк.СуммаРасходовНДСРегл = Строк.СуммаРасходовНДС * ДокументСсылкаДополнительныеРасходы.Курс * ДокументСсылкаДополнительныеРасходы.Кратность;
		Строк.СуммаРасходовСНДС = Строк.СуммаРасходовНДС+Строк.СуммаРасходов;
	КонецЦикла;
	
	Если ДокументСсылкаДополнительныеРасходы.ВалютаДокумента <> Константы.ВалютаУчета.Получить()
		И ДокументСсылкаДополнительныеРасходы.Предоплата.Количество() > 0 Тогда 
		
		ПересчитатьСуммыРегл(тзЗапасы, ДокументСсылкаДополнительныеРасходы);
		ПересчитатьСуммыРасходовРегл(тзЗапасы, ДокументСсылкаДополнительныеРасходы);
		
	КонецЕсли;
	
	тзЗапасы.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.ДополнительныеРасходы"));
	тзЗапасы.ЗаполнитьЗначения(ДокументСсылкаДополнительныеРасходы, "Ссылка");
	
	тзРасход = ДокументСсылкаДополнительныеРасходы.Расходы.Выгрузить();
	тзРасход.Колонки.Добавить("СуммаРегл", Новый ОписаниеТипов("Число"));
	тзРасход.Колонки.Добавить("СуммаНДСРегл", Новый ОписаниеТипов("Число"));
	
	Для Каждого Строк Из тзРасход Цикл 
		Строк.СуммаРегл = Строк.Сумма * ДокументСсылкаДополнительныеРасходы.Курс * ДокументСсылкаДополнительныеРасходы.Кратность;
		Строк.СуммаНДСРегл = Строк.СуммаНДС * ДокументСсылкаДополнительныеРасходы.Курс * ДокументСсылкаДополнительныеРасходы.Кратность;
	КонецЦикла;
	
	Если ДокументСсылкаДополнительныеРасходы.ВалютаДокумента <> Константы.ВалютаУчета.Получить()
		И ДокументСсылкаДополнительныеРасходы.Предоплата.Количество() > 0 Тогда 
		
		ПересчитатьСуммыРегл(тзРасход, ДокументСсылкаДополнительныеРасходы);
		
	КонецЕсли;
	
	тзРасход.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.ДополнительныеРасходы"));
	тзРасход.ЗаполнитьЗначения(ДокументСсылкаДополнительныеРасходы, "Ссылка");

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзЗапасы.Ссылка КАК Документ.ДополнительныеРасходы) КАК Ссылка,
	|	тзЗапасы.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(тзЗапасы.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	тзЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	тзЗапасы.Характеристика КАК Характеристика,
	|	тзЗапасы.ДокументПоступления КАК ДокументПоступления,
	|	тзЗапасы.Партия КАК Партия,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ВЫБОР
	|		КОГДА тзЗапасы.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
	|		ИНАЧЕ тзЗапасы.Проект
	|	КОНЕЦ КАК Проект,
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	тзЗапасы.Цена КАК Цена,
	|	тзЗапасы.Сумма КАК Сумма,
	|	тзЗапасы.СтавкаНДС КАК СтавкаНДС,
	|	тзЗапасы.СуммаНДС КАК СуммаНДС,
	|	тзЗапасы.ЗаказПокупателя КАК ЗаказПокупателя,
	|	тзЗапасы.Всего КАК Всего,
	|	тзЗапасы.СуммаРасходов КАК СуммаРасходов,
	|	тзЗапасы.Количество КАК Количество,
	|	тзЗапасы.СуммаРасходовНДФЛ КАК СуммаРасходовНДФЛ,
	|	тзЗапасы.СуммаРасходовПФ КАК СуммаРасходовПФ,
	|	тзЗапасы.СуммаИмпорт КАК СуммаИмпорт,
	|	тзЗапасы.СуммаРегл КАК СуммаРегл,
	|	тзЗапасы.СуммаРасходовНДС КАК СуммаРасходовНДС,
	|	тзЗапасы.СуммаРасходовНДСРегл КАК СуммаРасходовНДСРегл,
	|	тзЗапасы.СуммаРасходовРегл КАК СуммаРасходовРегл,
	|	тзЗапасы.СуммаНДСРегл КАК СуммаНДСРегл
	|ПОМЕСТИТЬ ВТ_Запасы
	|ИЗ
	|	&тзЗапасы КАК тзЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(тзРасходы.Ссылка КАК Документ.ДополнительныеРасходы) КАК Ссылка,
	|	тзРасходы.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(тзРасходы.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ВЫБОР
	|		КОГДА тзРасходы.Проект = ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта)
	|		ИНАЧЕ тзРасходы.Проект
	|	КОНЕЦ КАК Проект,
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	тзРасходы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	тзРасходы.Цена КАК Цена,
	|	тзРасходы.Сумма КАК Сумма,
	|	тзРасходы.СтавкаНДС КАК СтавкаНДС,
	|	тзРасходы.СуммаНДС КАК СуммаНДС,
	|	тзРасходы.Всего КАК Всего,
	|	тзРасходы.Количество КАК Количество,
	|	тзРасходы.СуммаРегл КАК СуммаРегл,
	|	ВЫРАЗИТЬ(тзРасходы.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержанияНДФЛ,
	|	ВЫРАЗИТЬ(тзРасходы.ВидУдержанияПФ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержанияПФ,
	|	тзРасходы.СуммаПФ,
	|	тзРасходы.СуммаНДФЛ КАК СуммаНДФЛ,
	|	тзРасходы.СуммаБезНалогов КАК СуммаБезНалогов,
	|	тзРасходы.СуммаНДСРегл КАК СуммаНДСРегл
	|ПОМЕСТИТЬ ВТ_Расходы
	|ИЗ
	|	&тзРасходы КАК тзРасходы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДополнительныеРасходы.Договор.ЭтоДоговорОбслуживания
	|				И ДополнительныеРасходы.Договор.ДоговорОбслуживанияНаправлениеДеятельности <> ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.ПустаяСсылка)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ВестиУчетРасходовПоДоговорамОбслуживания,
	|	ДополнительныеРасходы.Договор.ДоговорОбслуживанияНаправлениеДеятельности КАК НаправлениеДеятельности
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|	Документ.ДополнительныеРасходы КАК ДополнительныеРасходы
	|ГДЕ
	|	ДополнительныеРасходы.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Импорт.Ссылка КАК Ссылка,
	|	Импорт.Ссылка.Дата КАК Период,
	|	Импорт.Ссылка.Организация КАК Организация,
	|	Импорт.Ссылка.Импорт КАК ОтметкаИмпорт,
	|	Импорт.Ссылка.ВидНалогаНДС КАК ВидНалогаНДС,
	|	Импорт.Ссылка.ВидНалогаНДС.СчетУчетаРегл КАК СчетУчетаНДСРегл,
	|	Импорт.Ссылка.ВидНалогаНДС.СчетУчетаКВозмещениюРегл КАК СчетУчетаКВозмещениюНДСРегл,
	|	Импорт.ВидНалога КАК ВидНалога,
	|	Импорт.ВидНалога.СчетУчетаКВозмещениюРегл КАК СчетУчетаКВозмещениюРегл,
	|	Импорт.ВидНалога.СчетУчетаРегл КАК СчетУчетаРегл,
	|	Импорт.Сумма КАК Сумма,
	|	Импорт.ДобавлятьВСебистоимость КАК ДобавлятьВСебистоимость,
	|	Импорт.Ссылка.Договор.ВалютаРасчетов КАК ВалютаРасчетов,
	|	Импорт.ВычитаетыватьИзНДС КАК ВычитаетыватьИзНДС
	|ПОМЕСТИТЬ ВТ_Импорт
	|ИЗ
	|	Документ.ДополнительныеРасходы.ДопРасходыИмпорт КАК Импорт
	|ГДЕ
	|	Импорт.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	//+++ Дмгг
	|ВЫБРАТЬ
	|	ДополнительныеРасходыПредоплата.Ссылка,
	|	СУММА(ДополнительныеРасходыПредоплата.СуммаРасчетов) КАК СуммаРасчетов,
	|	СУММА(ДополнительныеРасходыПредоплата.СуммаРасчетов * ДополнительныеРасходыПредоплата.Курс / ДополнительныеРасходыПредоплата.Кратность) КАК СуммаРасчетовРеглПоКурсуПредоплаты
	|ПОМЕСТИТЬ ВременнаяТаблицаСуммаПредоплатыГрупп
	|ИЗ
	|	Документ.ДополнительныеРасходы.Предоплата КАК ДополнительныеРасходыПредоплата
	|ГДЕ
	|	ДополнительныеРасходыПредоплата.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ДополнительныеРасходыПредоплата.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДополнительныеРасходы.Ссылка КАК Ссылка,
	|	ДополнительныеРасходы.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаНеОплаченаВал,
	|	(ДополнительныеРасходы.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ДополнительныеРасходы.Курс / ДополнительныеРасходы.Кратность КАК СуммаНеОплаченаРегл,
	|	ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаРасчетовВал,
	|	ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты КАК СуммаРасчетовРегл,
	|	(ДополнительныеРасходы.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ДополнительныеРасходы.Курс / ДополнительныеРасходы.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) КАК СуммаДокументаРеглПоВсемКурсам,
	|	ВЫБОР
	|		КОГДА ДополнительныеРасходы.СуммаДокумента = 0
	|			ТОГДА 1
	|		ИНАЧЕ ((ДополнительныеРасходы.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ДополнительныеРасходы.Курс / ДополнительныеРасходы.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0)) / ДополнительныеРасходы.СуммаДокумента
	|	КОНЕЦ КАК СреднийКурсДокумента,
	|	1 КАК Кратность
	|ПОМЕСТИТЬ ВременнаяТаблицаСреднегоКурсаПредоплаты
	|ИЗ
	|	Документ.ДополнительныеРасходы КАК ДополнительныеРасходы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаСуммаПредоплатыГрупп КАК ВременнаяТаблицаСуммаПредоплатыГрупп
	|		ПО ДополнительныеРасходы.Ссылка = ВременнаяТаблицаСуммаПредоплатыГрупп.Ссылка
	|ГДЕ
	|	ДополнительныеРасходы.Ссылка = &Ссылка
	|;
