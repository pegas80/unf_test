// Процедура отмены проведения у подченненой счет фактуры (полученной)
//
Процедура КонтрольПодчиненнойСчетФактуры()
	
	СтруктураСчетаФактуры = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйСчетФактуру(Ссылка, Истина);
	Если СтруктураСчетаФактуры = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СчетФактура	 = СтруктураСчетаФактуры.Ссылка;
	Если Не СчетФактура.Проведен Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = НСтр("ka='მოძრაობების არარსებობის გამო დოკუმენტ %ПредставлениеТекущегоДокумента%-ს გაუტარდება %ПредставлениеСчетФактуры%.';ru='В связи с отсутствием движений у документа %ПредставлениеТекущегоДокумента% распроводится %ПредставлениеСчетФактуры%.';en='Due to the lack of movement in the document PredstavlenieTekuschegoDokumenta%%% rasprovoditsya PredstavlenieSchetFaktury%.'");
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ПредставлениеТекущегоДокумента%", """Поступление дополнительных расходов № " + Номер + " от " + Формат(Дата, "ДФ=dd.MM.yyyy") + """");
	ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ПредставлениеСчетФактуры%", """Счет фактура (полученная) № " + СтруктураСчетаФактуры.Номер + " от " + СтруктураСчетаФактуры.Дата + """");
	
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	
	СчетФактураОбъект = СчетФактура.ПолучитьОбъект();
	СчетФактураОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	
КонецПроцедуры //КонтрольПодчиненнойСчетФактуры()

#КонецОбласти

#КонецЕсли

// Kuzmich, 26.03.2019, распределение услуг по весу/объему
#Область РаспределениеУслугПоВесуОбъему

Функция РаспределитьТабЧастьРасходыПоВесу() ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Массив();
	
	ИсхСумма = 0;
	ИсхСуммаНДС = 0;
	БазаРаспределенияВес = 0;
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		Если ЗначениеЗаполнено(СтрокаЗапасы.Номенклатура.Вес) Тогда
			Если СтрокаЗапасы.Номенклатура.Вес>0 Тогда
				БазаРаспределенияВес = БазаРаспределенияВес + СтрокаЗапасы.Количество*СтрокаЗапасы.Номенклатура.Вес;
			Иначе
				Если РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
					РЕЗ.Добавить(СтрокаЗапасы.Номенклатура);
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
				РЕЗ.Добавить(СтрокаЗапасы.Номенклатура);
			КонецЕсли;
		КонецЕсли;
	
	КонецЦикла; 
	ВсегоРасходы = Расходы.Итог("СуммаБезНалогов");//Паганини Расходы.Итог("Всего")
	ВсегоНДСРасходы = Расходы.Итог("СуммаНДС");
	//Паганини_
	ИсхСуммаНДФЛ = 0;	
	ВсегоРасходыНДФЛ = Расходы.Итог("СуммаНДФЛ");
	ИсхСуммаПФ = 0;	
	ВсегоРасходыПФ = Расходы.Итог("СуммаПФ");
	//_Паганини
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		СтрокаЗапасы.СуммаРасходов = 0;
		СтрокаЗапасы.СуммаРасходовНДФЛ = 0;
		СтрокаЗапасы.СуммаРасходовПФ = 0;
		
		Если НЕ РЕЗ.Найти(СтрокаЗапасы.Номенклатура)=НЕОПРЕДЕЛЕНО Тогда
			Продолжить;
		КонецЕсли;
		
		ТекКоэффицинтВес = СтрокаЗапасы.Количество*СтрокаЗапасы.Номенклатура.Вес;
		СтрокаЗапасы.Коэффициент  =  ТекКоэффицинтВес ; //+++Lazare
		СтрокаЗапасы.СуммаРасходов = ?(БазаРаспределенияВес <> 0, Окр((ВсегоРасходы - ИсхСумма) * ТекКоэффицинтВес / БазаРаспределенияВес, 2, 1),0);
		СтрокаЗапасы.СуммаРасходовНДФЛ = ?(БазаРаспределенияВес <> 0, Окр((ВсегоРасходыНДФЛ - ИсхСуммаНДФЛ) * ТекКоэффицинтВес / БазаРаспределенияВес, 2, 1),0);//Паганини
		СтрокаЗапасы.СуммаРасходовПФ   = ?(БазаРаспределенияВес <> 0, Окр((ВсегоРасходыПФ   - ИсхСуммаПФ)   * ТекКоэффицинтВес / БазаРаспределенияВес, 2, 1),0);//Паганини ПФ
		БазаРаспределенияВес = БазаРаспределенияВес - ТекКоэффицинтВес;
		ИсхСумма = ИсхСумма + СтрокаЗапасы.СуммаРасходов;
		ИсхСуммаНДФЛ = ИсхСуммаНДФЛ + СтрокаЗапасы.СуммаРасходовНДФЛ;//Паганини
		ИсхСуммаПФ   = ИсхСуммаПФ   + СтрокаЗапасы.СуммаРасходовПФ;//Паганини ПФ
		
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции


