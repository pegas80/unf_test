// Процедура выполняет распределение затрат по количеству.
//
Процедура РаспределитьТабЧастьРасходыПоКоличеству() Экспорт
	
	ИсхСумма = 0;
	ИсхСуммаНДС = 0;
	БазаРаспределенияКоличество = Запасы.Итог("Количество");
	//ВсегоРасходы = Расходы.Итог("Всего");
	ВсегоРасходы = Расходы.Итог("Всего") - Расходы.Итог("СуммаНДС");
	ВсегоНДСРасходы = Расходы.Итог("СуммаНДС");
	//Паганини_
	ИсхСуммаНДФЛ = 0;	
	ВсегоРасходыНДФЛ = Расходы.Итог("СуммаНДФЛ");
	ИсхСуммаПФ = 0;	
	ВсегоРасходыПФ = Расходы.Итог("СуммаПФ");
	//_Паганини
	НОД = УправлениеНебольшойФирмойСервер.ПолучитьНОДДляМассива(Запасы.ВыгрузитьКолонку("Количество"), 1000);
	
	//Просьба не удалять, пока данное распределение поставлено на паузу
	ТзИмпортаСебестоимость = ДопРасходыИмпорт.Выгрузить(Новый Структура("ДобавлятьВСебистоимость", Истина), "Сумма");
	ВсегоИмпорт = ТзИмпортаСебестоимость.Итог("Сумма"); //+++ Дмгг
	ИсхСуммаИмпорт = 0; //+++ Дмгг
	
	Если НОД = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаЗапасы Из Запасы Цикл
		
		СтрокаЗапасы.Коэффициент = СтрокаЗапасы.Количество / НОД * 1000;
		СтрокаЗапасы.СуммаРасходов = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоРасходы - ИсхСумма) * СтрокаЗапасы.Количество / БазаРаспределенияКоличество, 2, 1),0);
		СтрокаЗапасы.СуммаРасходовНДФЛ = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоРасходыНДФЛ - ИсхСуммаНДФЛ) * СтрокаЗапасы.Количество / БазаРаспределенияКоличество, 2, 1),0);//Паганини
		СтрокаЗапасы.СуммаРасходовПФ   = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоРасходыПФ   - ИсхСуммаПФ)   * СтрокаЗапасы.Количество / БазаРаспределенияКоличество, 2, 1),0);//Паганини ПФ
		СтрокаЗапасы.СуммаРасходовНДС = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоНДСРасходы - ИсхСуммаНДС) * СтрокаЗапасы.Количество / БазаРаспределенияКоличество, 2, 1),0);
		
		СтрокаЗапасы.СуммаИмпорт = ?(БазаРаспределенияКоличество <> 0, Окр((ВсегоИмпорт- ИсхСуммаИмпорт) * СтрокаЗапасы.Количество / БазаРаспределенияКоличество, 2, 1),0);//+++ Дмгг
		ИсхСуммаИмпорт = ИсхСуммаИмпорт + СтрокаЗапасы.СуммаИмпорт; //+++ Дмгг
		БазаРаспределенияКоличество = БазаРаспределенияКоличество - СтрокаЗапасы.Количество;
		
		ИсхСумма = ИсхСумма + СтрокаЗапасы.СуммаРасходов;
		ИсхСуммаНДС = ИсхСуммаНДС + СтрокаЗапасы.СуммаРасходовНДС;
		ИсхСуммаНДФЛ = ИсхСуммаНДФЛ + СтрокаЗапасы.СуммаРасходовНДФЛ;//Паганини
		ИсхСуммаПФ = ИсхСуммаПФ + СтрокаЗапасы.СуммаРасходовПФ;//Паганини ПФ
		
	КонецЦикла;
	
КонецПроцедуры // РаспределитьТабЧастьРасходыПоКоличеству()

