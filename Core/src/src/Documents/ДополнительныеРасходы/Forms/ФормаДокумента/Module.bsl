	Объект.Предоплата.Загрузить(ТаблицаДляЗагрузки);  
	
	//++24.04.2024 Lazare 
	Для Каждого Строк из Объект.Предоплата Цикл 	
		СтуктураЗаполнения = ПолучитьСтавкиНаСервере(Строк.СуммаРасчетов);
		Строк.СуммаНДФЛ = СтуктураЗаполнения.СуммаНДФЛ;
