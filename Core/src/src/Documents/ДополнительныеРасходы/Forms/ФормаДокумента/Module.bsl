&НаКлиенте
Процедура ЗапасыКоэффициентПриИзменении(Элемент)
	
	ИсхСумма = 0;
	БазаРаспределения = Объект.Запасы.Итог("Коэффициент");
	ВсегоРасходы = Объект.Расходы.Итог("Всего");
	
	Для каждого СтрокаЗапасы Из Объект.Запасы Цикл
		СтрокаЗапасы.СуммаРасходов = ?(БазаРаспределения <> 0, Окр((ВсегоРасходы - ИсхСумма) * СтрокаЗапасы.Коэффициент / БазаРаспределения, 2, 1),0);
		БазаРаспределения = БазаРаспределения - СтрокаЗапасы.Коэффициент;
		ИсхСумма = ИсхСумма + СтрокаЗапасы.СуммаРасходов;
	КонецЦикла;
	
