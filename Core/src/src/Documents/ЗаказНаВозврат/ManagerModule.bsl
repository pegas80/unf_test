Процедура ВывестиОшибкиКонтроляКоличестваПриВозврате(СписокСтрок) Экспорт
	Перем Ошибки;
	
	Если СписокСтрок.Количество() Тогда
		
		Отказ = Истина;
		
		Для Каждого ТекСтр Из СписокСтрок Цикл
			
			ТекстОднойОшибки = ?(СписокСтрок.Количество()=1, 
				СтрШаблон("Возвращено больше, чем продано. Продано %1", ТекСтр.КоличествоОборот), 
				СтрШаблон("Продано %1",ТекСтр.КоличествоОборот));
				
			ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.Запасы[%1].Количество", 
				ТекстОднойОшибки, "Количество", ТекСтр.НомерСтроки-1, "Возвращено больше, чем продано");
			КонецЦикла;
			
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки);	
		
	КонецЕсли;
	
КонецПроцедуры