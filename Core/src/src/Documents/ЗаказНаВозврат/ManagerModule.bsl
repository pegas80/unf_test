Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаЗаказНаВозврат, СтруктураДополнительныеСвойства, ДокументОбъектЗаказНаВозврат) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаВозврат.Ссылка КАК Ссылка,
	|	ЗаказНаВозврат.Дата КАК Дата,
	|	ЗаказНаВозврат.Организация КАК Организация,
	|	ЗаказНаВозврат.Контрагент КАК Контрагент,
	|	ЗаказНаВозврат.Договор КАК Договор,
	|	ЗаказНаВозврат.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
	|	ЗаказНаВозврат.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
	|	ЗаказНаВозврат.ТорговаяТочка КАК ТорговаяТочка,
	|	ЗаказНаВозврат.СуммаДокумента КАК СуммаДокумента
	|ПОМЕСТИТЬ втШапка
	|ИЗ
	|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
	|ГДЕ
	|	ЗаказНаВозврат.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказНаВозвратЗапасы.Ссылка КАК Ссылка,
	|	втШапка.Дата КАК Дата,
	|	втШапка.Организация КАК Организация,
	|	втШапка.Контрагент КАК Контрагент,
	|	втШапка.Договор КАК Договор,
	|	ЗаказНаВозвратЗапасы.Номенклатура КАК Номенклатура,
	|	ЗаказНаВозвратЗапасы.Количество КАК Количество,
	|	ЗаказНаВозвратЗапасы.Сумма КАК Сумма
	|ПОМЕСТИТЬ втЗапасы
	|ИЗ
	|	Документ.ЗаказНаВозврат.Запасы КАК ЗаказНаВозвратЗапасы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втШапка КАК втШапка
	|		ПО ЗаказНаВозвратЗапасы.Ссылка = втШапка.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УчетнаяПолитикаРеглСрезПоследних.КонтрольКоличестваПриВозврате КАК КонтрольКоличества,
	|	ДОБАВИТЬКДАТЕ(&ДатаДокумента, МЕСЯЦ, УчетнаяПолитикаРеглСрезПоследних.СрокКонтроляКоличестваПриВозврате) КАК ДатаКонтроляКоличества
	|ИЗ
	|	РегистрСведений.УчетнаяПолитикаРегл.СрезПоследних(&ДатаДокумента, Организация = &Организация) КАК УчетнаяПолитикаРеглСрезПоследних";
	
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаЗаказНаВозврат);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ДатаДокумента", НачалоДня(СтруктураДополнительныеСвойства.ДляПроведения.Дата));
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Выборка = МассивРезультатов[МассивРезультатов.Количество()-1].Выбрать();
	Выборка.Следующий();
	
	СтруктураДополнительныеСвойства.ДляПроведения.Вставить("КонтрольКоличества", Выборка.КонтрольКоличества);
	СтруктураДополнительныеСвойства.ДляПроведения.Вставить("ДатаКонтроляКоличества", Выборка.ДатаКонтроляКоличества);
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [3 октября 2023]  НАЧАЛО
	//СформироватьПроданныеИВозвращенныеТовары(ДокументСсылкаЗаказНаВозврат, СтруктураДополнительныеСвойства);
	СформироватьТаблицуЗаявкиНаВозврат(ДокументСсылкаЗаказНаВозврат, СтруктураДополнительныеСвойства);
	// © Шишка В.В. [3 октября 2023]  КОНЕЦ
	//--------------------------------------------------------------------------
	
КонецПроцедуры

