Процедура СформироватьТаблицуЗаявкиНаВозврат(ДокументСсылка, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	втЗапасы.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	втЗапасы.Организация КАК Организация,
	|	втЗапасы.Контрагент КАК Контрагент,
	|	втЗапасы.Договор КАК Договор,
	|	втЗапасы.Номенклатура КАК Номенклатура,
	|	СУММА(втЗапасы.Количество) КАК Количество
	|ИЗ
	|	втЗапасы КАК втЗапасы
	|
	|СГРУППИРОВАТЬ ПО
	|	втЗапасы.Дата,
	|	втЗапасы.Организация,
	|	втЗапасы.Контрагент,
	|	втЗапасы.Договор,
	|	втЗапасы.Номенклатура";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаЗаявкиНаВозврат", РезультатЗапроса);
	
КонецПроцедуры// Олег Литвиненко <-
