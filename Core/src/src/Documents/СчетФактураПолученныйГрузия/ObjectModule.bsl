
// Процедура - обработчик события ОбработкаЗаполнения объекта.
//
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка) Экспорт 
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриходнаяНакладная") Или 
		 ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ДополнительныеРасходы") Или 
		 ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетПереработчика") Тогда
		Контрагент = ДанныеЗаполнения.Контрагент;
		Организация = ДанныеЗаполнения.Организация;
		Автор = ДанныеЗаполнения.Автор;
		ПериодРегистрации = НачалоМесяца(ДанныеЗаполнения.Дата);
		НоваяСтрока = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДанныеЗаполнения;
	КонецЕсли;
	
	//Малышев 2025-12-10 ONESOFT-4482 ((--
	Если (ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РасходнаяНакладная") и ДанныеЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику) 
		ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаПоступления")
		Тогда 
		Контрагент = ДанныеЗаполнения.Контрагент;
		Организация = ДанныеЗаполнения.Организация;
		Автор = ДанныеЗаполнения.Автор;
		ПериодРегистрации = НачалоМесяца(ДанныеЗаполнения.Дата);
		ДатаВходящегоДокумента = ДанныеЗаполнения.Дата;
		
		НоваяСтрока = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДанныеЗаполнения.ДокументОснование;
		СтруктураСумм = Документы.СчетФактураПолученныйГрузия.СуммыДокументаДляСчетФактурыПолученного(НоваяСтрока.ДокументОснование);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураСумм);
		
		//
		Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РасходнаяНакладная") 
			и ДанныеЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику 
			и ЗначениеЗаполнено(ДанныеЗаполнения.ДокументОснование)
			Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	РасходнаяНакладная.Ссылка КАК ДокументВозврата,
			|	РасходнаяНакладная.Дата КАК Дата
			|ИЗ
			|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
			|ГДЕ
			|	РасходнаяНакладная.ДокументОснование = &ДокументПервогоПрихода
			|	И РасходнаяНакладная.Ссылка <> &ТекущийВозврат
			|   и РасходнаяНакладная.Дата <= &ДатаПоследнейКорректировки
			|УПОРЯДОЧИТЬ ПО
			|	Дата";
			Запрос.УстановитьПараметр("ТекущийВозврат", ДанныеЗаполнения);
			Запрос.УстановитьПараметр("ДокументПервогоПрихода", ДанныеЗаполнения.ДокументОснование);
			Запрос.УстановитьПараметр("ДатаПоследнейКорректировки", ДанныеЗаполнения.Дата);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока выборка.Следующий() Цикл
				НоваяСтрока = ДокументыОснования.Добавить();
				НоваяСтрока.ДокументОснование = выборка.ДокументВозврата;
				СтруктураСумм = Документы.СчетФактураПолученныйГрузия.СуммыДокументаДляСчетФактурыПолученного(НоваяСтрока.ДокументОснование);
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураСумм);
			КонецЦикла;
			
		КонецЕсли;
		
		
		НоваяСтрока = ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДанныеЗаполнения;
		
	КонецЕсли;
	//Малышев 2025-12-10 ONESOFT-4482 --))

КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	//СуммаДокумента = ДокументыОснования.Итог("СуммаДокумента");
	//СуммаНДС = ДокументыОснования.Итог("СуммаНДС");
	//--------------------------------------------------------------------------
	// © Шишка В.В. [11 августа 2022]  НАЧАЛО
	Если НЕ ДатаИзмененаПользователем Тогда
	
		Если КонецМесяца(ДатаВходящегоДокумента) < КонецМесяца(ТекущаяДатаСеанса())
			И НЕ Дата = КонецМесяца(ДатаВходящегоДокумента)
			Тогда
			
			Дата = КонецМесяца(ДатаВходящегоДокумента);
			УстановитьНовыйНомер();
			
		ИначеЕсли НЕ Дата = КонецМесяца(ДатаВходящегоДокумента) Тогда
			
			Дата = КонецМесяца(ДатаВходящегоДокумента);	
			
		КонецЕсли; 	
	
	КонецЕсли; 
	// © Шишка В.В. [11 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	
	Если Аванс Тогда
		ДокументыОснования.Очистить();
		СуммаДокумента	= ДокументыПлатежа.Итог("Сумма");
		СуммаНДС 		= ДокументыПлатежа.Итог("СуммаНДС");
	Иначе
		СуммаДокумента	= 0;
		СуммаНДС 		= 0;
		Для Каждого СтрокаТЧ ИЗ ДокументыОснования Цикл
			Если НЕ ТипЗнч(СтрокаТЧ.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда
				СуммаДокумента 		= СуммаДокумента	+ СтрокаТЧ.СуммаДокумента;
				СуммаНДС 			= СуммаНДС 			+ СтрокаТЧ.СуммаНДС;
			Иначе
				//СуммаДокумента 	= СуммаДокумента	- СтрокаТЧ.СуммаДокумента;
				//СуммаНДС 			= СуммаНДС 			- СтрокаТЧ.СуммаНДС;		
				//Lazare_
				СуммаДокумента 		= СуммаДокумента	+ СтрокаТЧ.СуммаДокумента;  //Сумма возврата минусовое число
				СуммаНДС 			= СуммаНДС 			+ СтрокаТЧ.СуммаНДС;        //НДС возврата минусовое число
				//_Lazare			
			КонецЕсли;
			
			//Lazare_
			Если  ТипЗнч(СтрокаТЧ.ДокументОснование) = Тип("ДокументСсылка.ПриходнаяНакладная")Тогда 
				СсылкаНаОбъект 		= СтрокаТЧ.ДокументОснование.Ссылка ;
				Если НЕ СсылкаНаОбъект.IDСФ = Формат(Идентификатор,"ЧГ=0") ИЛИ НЕ СсылкаНаОбъект.НомерСФ = НомерВходящегоДокумента Тогда
					ДокОбъект      		= СсылкаНаОбъект.ПолучитьОбъект();
					ДокОбъект.IDСФ      = Формат(Идентификатор,"ЧГ=0") ;
					ДокОбъект.НомерСФ   = НомерВходящегоДокумента ; 
					ДокОбъект.ОбменДанными.Загрузка = Истина;
					ДокОбъект.Записать();
				КонецЕсли;
			КонецЕсли;
			//_Lazare
		КонецЦикла;
		ДокументыПлатежа.Очистить();
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	РС_ОбщегоНазначения.СинхронизироватьРеквизитыДокументовОснованийСчетаФактуры(ЭтотОбъект);
	
	//Малышев 2025-12-10 ONESOFT-4482 ((-- 
	//для первой корректировки если ставим статус Отправленная корректировочная, то 
	//у первой СФ ставим статус с подтвержденной на первичную. для второй корректрировке и выше  уже ничего не меняем
	Если Статус = Перечисления.СтатусыСФ.ОтправленнаяКорректировочная и ДокументыОснования.Количество() = 2 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СФ_Корректировочная.Ссылка КАК СФ_Корректировочная,
		|	СФ_Корректировочная.Ссылка.Статус КАК СтатусКорректировочной,
		|	СФ_Корректировочная.ДокументОснование КАК ДокументОснование,
		|	СФ_Обычная.Ссылка.Статус КАК СтатусОбычной,
		|	СФ_Обычная.Ссылка КАК СФ_Обычная
		|ИЗ
		|	Документ.СчетФактураПолученныйГрузия.ДокументыОснования КАК СФ_Корректировочная
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученныйГрузия.ДокументыОснования КАК СФ_Обычная
		|		ПО СФ_Корректировочная.ДокументОснование = СФ_Обычная.ДокументОснование
		|ГДЕ
		|	СФ_Корректировочная.Ссылка = &Ссылка
		|	И СФ_Обычная.Ссылка <> &Ссылка
		|	И СФ_Обычная.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Подтвержденная)
		|	И СФ_Корректировочная.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.ОтправленнаяКорректировочная)";
		
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Об = Выборка.СФ_Обычная.ПолучитьОбъект();
			Об.Статус = Перечисления.СтатусыСФ.Первичная;
			Если Об.Проведен Тогда
				Об.Записать(РежимЗаписиДокумента.Проведение);
			Иначе     
				Об.Записать();
			КонецЕсли;	
			 Сообщить(СтрШаблон(НСТР("ka='დოკუმენტში %1 სტატუსი შეიცვალა %2';
			 							|ru='У документа %1 сменился статус на %2';
										|en='At the document %1 status changed to %2'"),Об,Об.Статус));
			 
			 ЭтотОбъект.ДополнительныеСвойства.Вставить("ПервичнаяСФ", Об.Ссылка);
		КонецЦикла;	
	КонецЕсли;	
	//Малышев 2025-12-10 ONESOFT-4482 --))

КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если Аванс Тогда
		//ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.Документ");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.Договор");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.Сумма");
		ПроверяемыеРеквизиты.Добавить("ДокументыПлатежа.СуммаНДС");
	КонецЕсли;
КонецПроцедуры

// Процедура - обработчик события ОбработкаПроведения объекта.
//
Процедура ОбработкаПроведения(Отказ, Режим)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Инициализация дополнительных свойств для проведения документа.
	УправлениеНебольшойФирмойСервер.ИнициализироватьДополнительныеСвойстваДляПроведения(Ссылка, ДополнительныеСвойства);
	
	// Инициализация данных документа.
	Документы.СчетФактураПолученныйГрузия.ИнициализироватьДанныеДокумента(Ссылка, ДополнительныеСвойства);
	
	// Подготовка наборов записей.
	УправлениеНебольшойФирмойСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтразитьХозрасчетный(ДополнительныеСвойства, Движения, Отказ);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтразитьАвансыПолученныхФактур(ДополнительныеСвойства, Движения, Отказ);
	Если ЗначениеЗаполнено(ВидНалога) Тогда // Kuzmich, 18.09.2019, Добавление бух проводок в счет фактурах
		УправлениеНебольшойФирмойСервер.ОтразитьРасчетыПоНалогам(ДополнительныеСвойства, Движения, Отказ);
	КонецЕсли;
	
	// Запись наборов записей
	УправлениеНебольшойФирмойСервер.ЗаписатьНаборыЗаписей(ЭтотОбъект);
	
	ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц.Закрыть();
	
КонецПроцедуры

