
// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетФактураПолученныйГрузияДокументыПлатежа.Ссылка,
		|	СчетФактураПолученныйГрузияДокументыПлатежа.Ссылка.Организация,
		|	СчетФактураПолученныйГрузияДокументыПлатежа.Ссылка.Контрагент,
		|	КОНЕЦПЕРИОДА(СчетФактураПолученныйГрузияДокументыПлатежа.Ссылка.ДатаВходящегоДокумента, МЕСЯЦ) КАК Период,
		|	СчетФактураПолученныйГрузияДокументыПлатежа.НомерСтроки КАК НомерСтроки,
		|	СчетФактураПолученныйГрузияДокументыПлатежа.Документ,
		|	СчетФактураПолученныйГрузияДокументыПлатежа.Договор,
		|	СчетФактураПолученныйГрузияДокументыПлатежа.СуммаНДС КАК Сумма
		|ПОМЕСТИТЬ ДокументыПлатежа
		|ИЗ
		|	Документ.СчетФактураПолученныйГрузия.ДокументыПлатежа КАК СчетФактураПолученныйГрузияДокументыПлатежа
		|ГДЕ
		|	СчетФактураПолученныйГрузияДокументыПлатежа.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", 		ДокументСсылкаСчетФактураПолученный);
	Запрос.Выполнить();
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_СчетФактураПолученныйГрузия(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаАвансыПолученныхФактур_СчетФактураПолученныйГрузия(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства);
	
	СформироватьТаблицаРасчетыПоНалогам(ДокументСсылкаСчетФактураПолученный, СтруктураДополнительныеСвойства); // Kuzmich, 16.09.2019, Добавление бух проводок в счет фактурах
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Выполняет контроль возникновения отрицательных остатков.
//
Процедура ВыполнитьКонтроль(ДокументСсылкаСчетФактураПолученный, ДополнительныеСвойства, Отказ, УдалениеПроведения = Ложь) Экспорт
	
	Если Не УправлениеНебольшойФирмойСервер.ВыполнитьКонтрольОстатков() Тогда
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

