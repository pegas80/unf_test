	Запрос.УстановитьПараметр("РозничнаяВыручка", НСтр("ka='საცალო გაყიდვიდან მიღებული შემოსავალი';ru='Розничная выручка';en='retail sales'"));
	Запрос.УстановитьПараметр("Себестоимость", НСтр("ka='თვითღირებულება';ru='Себестоимость';en='Cost price'"));
