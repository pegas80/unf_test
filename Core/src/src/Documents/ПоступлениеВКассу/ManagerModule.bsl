		КонецЦикла;
		Если ИтогСуммаУчета <> ДокументСсылкаПоступлениеВКассу.СуммаУчета Тогда
			Дельта = ИтогСуммаУчета - ДокументСсылкаПоступлениеВКассу.СуммаУчета;
			ТЗРезультатЗапроса.Сортировать("Сумма Убыв");
