	тзСебестоимость = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Строк Из Запасы  Цикл 
		
		ПоискСебестоимости = тзСебестоимость.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", Строк.Номенклатура, Строк.Характеристика));
		
		Если ПоискСебестоимости.Количество() <> 0 Тогда 
			Строк.Себестоимость = ПоискСебестоимости[0].Себестоимость / ПоискСебестоимости[0].Количество * Строк.Количество;
			Строк.СебестоимостьЕдиницы = ПоискСебестоимости[0].Себестоимость / ПоискСебестоимости[0].Количество;
		КонецЕсли;
		
	КонецЦикла;
	
