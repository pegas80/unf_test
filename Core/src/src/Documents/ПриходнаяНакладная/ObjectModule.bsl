Процедура ПроверитьПРивешениеЦены(Отказ)

	тзЗапасы = Запасы.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	тзЗапасы.НомерСтроки КАК НомерСтроки,
		|	тзЗапасы.Номенклатура КАК Номенклатура,
		|	тзЗапасы.Характеристика КАК Характеристика,
		|	тзЗапасы.Цена КАК Цена
		|ПОМЕСТИТЬ ВТ_Запасы
		|ИЗ
		|	&тзЗапасы КАК тзЗапасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОграничениеЦенКонтрагентаСрезПоследних.Номенклатура КАК Номенклатура,
		|	ОграничениеЦенКонтрагентаСрезПоследних.Характеристика КАК Характеристика,
		|	ВТ_Запасы.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	РегистрСведений.ОграничениеЦенКонтрагента.СрезПоследних(
		|			&Дата,
		|			Контрагент = &Контрагент
		|				И (Номенклатура, Характеристика) В
		|					(ВЫБРАТЬ
		|						а.Номенклатура,
		|						а.Характеристика
		|					ИЗ
		|						ВТ_Запасы КАК а)) КАК ОграничениеЦенКонтрагентаСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Запасы КАК ВТ_Запасы
		|		ПО ОграничениеЦенКонтрагентаСрезПоследних.Номенклатура = ВТ_Запасы.Номенклатура
		|			И ОграничениеЦенКонтрагентаСрезПоследних.Характеристика = ВТ_Запасы.Характеристика
		|ГДЕ
		|	ВТ_Запасы.Цена > ОграничениеЦенКонтрагентаСрезПоследних.Цена";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("тзЗапасы", тзЗапасы);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ТекстСообщения = НСтр("ka='%НомерСтроки%  სტრიქონში  ჩანართში მარაგები გადაჭარბებულია შესყიდვის ფასი.';ru='Для строки %НомерСтроки% списка ""Запасы"", привышена закупочная цена.';en='Для строки %НомерСтроки% списка ""Запасы"", привышена закупочная цена.'"
		);
		//ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Номенклатура%", СокрЛП(Строка(СтрокаРасходы.Номенклатура))); 
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%НомерСтроки%",Строка(ВыборкаДетальныеЗаписи.НомерСтроки));
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(
		ЭтотОбъект,
		ТекстСообщения,
		"Запасы",
		ВыборкаДетальныеЗаписи.НомерСтроки,
		"Цена",
		Отказ
		);
		
	КонецЦикла;

КонецПроцедуры
