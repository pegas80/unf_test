			БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Склады", ВыборкаДетальныеЗаписи.СтруктурнаяЕдиница);
			
			инд1 = инд1+1;
			НаборЗаписейХозрасчетный1.Записать(Истина);
			
		ИначеЕсли  ТипЗнЧ(ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная")  
			       или ТипЗнЧ(ДокументОснование) = Тип("ДокументСсылка.ЗаказПокупателя")  //Малышев 2024-09-23 ONESOFT-3469
			Тогда 
			
			Для Каждого Проводка из НаборЗаписейХозрасчетный1 Цикл 
				Если Проводка.СчетДт.Количественный и Проводка.СчетДт.ТипСчета = ПредопределенноеЗначение("Перечисление.ТипыСчетов.Запасы")
