		|			ТОГДА ЕСТЬNULL(ВТ_ЗапасыОборотыДляСебестоимости.Себестоимость, 0)
		|		КОГДА ЕСТЬNULL(ВТ_ПоследняяПродажа.СебестоимостьОборот, 0) > 0
		|			ТОГДА ЕСТЬNULL(ВТ_ПоследняяПродажа.СебестоимостьОборот, 0)
