		|		ПО ВТ_Запасы.Номенклатура = ВТ_ЗапасыОстатки.Номенклатура
		|			И ВТ_Запасы.Характеристика = ВТ_ЗапасыОстатки.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗапасыОборотыДляСебестоимости КАК ВТ_ЗапасыОборотыДляСебестоимости
		|		ПО ВТ_Запасы.Номенклатура = ВТ_ЗапасыОборотыДляСебестоимости.Номенклатура
		|			И ВТ_Запасы.Характеристика = ВТ_ЗапасыОборотыДляСебестоимости.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПоследняяПродажа КАК ВТ_ПоследняяПродажа
		|		ПО ВТ_Запасы.Номенклатура = ВТ_ПоследняяПродажа.Номенклатура
		|			И ВТ_Запасы.Характеристика = ВТ_ПоследняяПродажа.Характеристика";
		
	Запрос.УстановитьПараметр("НачалоПериода", (Дата - (86400* 30)));
