Процедура ПроверитьДанныеПоВозвратуНаСервере(Отказ)
	
	Перем УчетнаяПолитика;
	Если ДополнительныеСвойства.Свойство("УчетнаяПолитика", УчетнаяПолитика)
		И НЕ УчетнаяПолитика.КонтрольКоличестваПриВозврате
		Тогда
	
		Возврат;	
	
	КонецЕсли; 
	Если НЕ ЭтоНовый() Тогда
	
		НаборДвижений = РегистрыНакопления.Продажи.СоздатьНаборЗаписей();
		НаборДвижений.Отбор.Регистратор.Установить(Ссылка);
		НаборДвижений.Записать();
		
	КонецЕсли; 
	ПроверяемыеДанные = Новый Массив;
	Для каждого ТекСтрока Из Запасы Цикл
	
		СтруктураДанныеСтроки = Новый Структура("НомерСтроки, ID, Количество, Договор"
								, ТекСтрока.НомерСтроки
								, ТекСтрока.Номенклатура.УникальныйИдентификатор()
								, ТекСтрока.Количество
								, Договор.УникальныйИдентификатор());
		ПроверяемыеДанные.Добавить(СтруктураДанныеСтроки);
	
	КонецЦикла;
	МассивОшибок = Новый Массив;
	ОПТИМУС_ОбменДистрибуция.ВыполнитьПрорверкуПоЗаявкамНаВозврат(, Новый ХранилищеЗначения(ПроверяемыеДанные, Новый СжатиеДанных(9)), МассивОшибок, Дата);
	МассивСтрокОшибок = Новый Массив;
	Для каждого ТекЭлемент Из МассивОшибок Цикл
	
		ТекущийСписокОшибок = Неопределено;
		Если ТекЭлемент.Свойство("ОшибкиВозвратаТоваров", ТекущийСписокОшибок)
			И ТипЗнч(ТекущийСписокОшибок) = Тип("Массив")
			Тогда
		
			Для каждого ТекСтрокаОшибки Из ТекущийСписокОшибок Цикл
			
				МассивСтрокОшибок.Добавить(ТекСтрокаОшибки);	
			
			КонецЦикла; 
		
		КонецЕсли; 
	
	КонецЦикла;  
	Если МассивСтрокОшибок.Количество() Тогда
	
		Отказ = Истина;
		ОтразитьОшибкиВозвратов(МассивОшибок);	
	
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОтразитьОшибкиВозвратов(МассивОшибок)

	ШаблонСтроки = НСтр("ka='სტრიქონში %1 დაბრუნებული საქონლის რაოდენობა %2 რაოდენობით %3 აღემატება გაყიდულს %4';ru='В строке %1 возвращаемое количество товара %2 в количестве %3 превышает закупленное %4';en='სტრიქონში %1 დაბრუნებული საქონლის რაოდენობა %2 რაოდენობით %3 აღემატება გაყიდულს %4'");
	ШаблонСтрокиКонец = НСтр("ka='მაქსიმუმ შეგიძლიათ დააბრუნოთ %1, დოკუმენტი არ გაგზავნილა მონაცემთა ბაზაში 1C გთხოვთ დააკორექტიროთ ვიზიტი';ru='Максимум можно вернуть %1, документ не был отправлен в базу 1С Прошу исправить визит';en='მაქსიმუმ შეგიძლიათ დააბრუნოთ %1, დოკუმენტი არ გაგზავნილა მონაცემთა ბაზაში 1C გთხოვთ დააკორექტიროთ ვიზიტი'");

	Если ТипЗнч(МассивОшибок) = Тип("Массив") Тогда
	
		СтрокаОшибки = ""; 
		Для каждого ТекЭлемент Из МассивОшибок Цикл
		
			Для каждого ТекСтрокаОшибки Из ТекЭлемент.ОшибкиВозвратаТоваров Цикл
			
				СтрокаОшибки = СтрокаОшибки + ?(ПустаяСтрока(СтрокаОшибки), "", Символы.ПС) +
				СтрШаблон(ШаблонСтроки, ТекСтрокаОшибки.НомерСтроки
				, ТекСтрокаОшибки.Номенклатура + ?(ЗначениеЗаполнено(ТекСтрокаОшибки.Характеристика), " " + ТекСтрокаОшибки.Характеристика, "")
				, ТекСтрокаОшибки.Количество
				, ТекСтрокаОшибки.КоличествоРазницаПродаж) + Символы.ПС +
				СтрШаблон(ШаблонСтрокиКонец, Макс(ТекСтрокаОшибки.КоличествоРазницаПродаж, 0));
			
			КонецЦикла;
		
		КонецЦикла;
		Если Не ПустаяСтрока(СтрокаОшибки) Тогда
		
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрокаОшибки;
			Сообщение.Сообщить();	
		
		КонецЕсли;			
	
	КонецЕсли;

КонецПроцедуры // ОтразитьОшибкиВозвратов()

