		//	Ст.Себестоимость = (СуммаКорректировки )*-1;	
		//КонецЦикла;
		
		
		Если (НЕ Окр(СуммаКорректировки, 2) = 0) Тогда
			
			тзНаборЗаписейЗапасы = НаборЗаписейЗапасы.Выгрузить();
			МассивПоискПоиск = тзНаборЗаписейЗапасы.НайтиСтроки(Новый Структура("Номенклатура, Характеристика", ВыборкаДетальныеЗаписи.Номенклатура, ВыборкаДетальныеЗаписи.Характеристика));
			
			Если МассивПоискПоиск.Количество() <> 0 Тогда   
				
