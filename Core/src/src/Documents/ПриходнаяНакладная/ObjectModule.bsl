Функция ПолучитьСтавкиНаСервере(СуммаРасчетов)
	
	СтруктураВозврата = Новый Структура;
	
	СтавкаПФ = 0;
	тзСтавкиПФ = РегистрыСведений.УдержанияДляПенсионногоФонда.СрезПоследних(Дата, Новый Структура("Контрагент, Договор", Контрагент, Договор));
	Если тзСтавкиПФ.Количество() <> 0 Тогда 
		СтавкаПФ = тзСтавкиПФ[0].ВидУдержания.СтавкаПФ;
	КонецЕсли;
	
	СтавкаНДС = 0;
	Если НЕ НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
		
		Если НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
		Иначе
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
		КонецЕсли;
	
	Иначе
		СтавкаНДС = Организация.СтавкаНДСПоУмолчанию;
	КонецЕсли;
	
	Если Договор.УчитыватьНДФЛ Тогда          
		Если СуммаВключаетНДС Тогда 
			Ставки = РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(0, Договор.ВидУдержанияНДФЛ);
			СуммаБезНалогов = СуммаРасчетов;
			СуммаНДФЛ		= Окр(СуммаРасчетов/((100-Ставки.СтавкаНДФЛ)/100)*(Ставки.СтавкаНДФЛ/100), 2);
			СуммаПФ			= Окр(((СуммаРасчетов+СуммаНДФЛ)/((100-СтавкаПФ)/100))*(СтавкаПФ/100), 2);
			//СуммаНДС		= Окр(СуммаРасчетов - СуммаРасчетов/(1+(Ставки.СтавкаНДС/100)), 2);
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаПФ;
			
			СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
			СтруктураВозврата.Вставить("СуммаПФ", СуммаПФ);
			
		Иначе
			Ставки = РС_ОбщегоНазначения.ПолучитьЗначенииСтавок(0, Договор.ВидУдержанияНДФЛ);
			//СуммаНДФЛ = Окр(СуммаРасчетов/((100 - Ставки.СтавкаНДФЛ)/ Ставки.СтавкаНДФЛ), 2);
			//СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
			//СтруктураВозврата.Вставить("СуммаПФ", Окр(((СуммаРасчетов+СуммаНДФЛ)/((100 - СтавкаПФ)/ 100)) - (СуммаРасчетов+СуммаНДФЛ), 2));
			СуммаБезНалогов = СуммаРасчетов;
			СуммаНДС		= Окр(СуммаРасчетов - СуммаРасчетов*((100-СтавкаНДС)/100), 2);
			СуммаНДФЛ		= Окр((СуммаРасчетов + СуммаНДС)/((100-Ставки.СтавкаНДФЛ)/100)*(Ставки.СтавкаНДФЛ/100), 2);
			СуммаПФ			= Окр(((СуммаРасчетов + СуммаНДС + СуммаНДФЛ)/((100-СтавкаПФ)/100)) * (СтавкаПФ / 100), 2);
			
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
			
			СтруктураВозврата.Вставить("СуммаНДФЛ",СуммаНДФЛ);
			СтруктураВозврата.Вставить("СуммаПФ", СуммаПФ);
			
		КонецЕсли;
	Иначе 
		СтруктураВозврата.Вставить("СуммаНДФЛ",0);
		СтруктураВозврата.Вставить("СуммаПФ", 0);
	КонецЕсли;

	Возврат СтруктураВозврата;
	
КонецФункции
	
