	//НаборЗаписейХозрасчетный.Отбор.Регистратор.Установить(Ссылка);
	//НаборЗаписейХозрасчетный.Прочитать();
	НаборЗаписейХозрасчетный1 = РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
	НаборЗаписейХозрасчетный1.Отбор.Регистратор.Установить(Ссылка);	
	НаборЗаписейХозрасчетный1.Прочитать();
	
	
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	//ИндХозрасчетный = 0 ;
	инд1 = НаборЗаписейХозрасчетный1.количество() ;
	Инд = 0;
	//ИндХозрасчетный = НаборЗаписейЗапасы.количество();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СуммаРасходов = 0  ;
		Если ВыборкаДетальныеЗаписи.КоличествоПродаж = 0 Тогда
			СуммаКорректировки = 0;
		Иначе                  
			ЦенаПродажи = ВыборкаДетальныеЗаписи.СуммаПродаж / ВыборкаДетальныеЗаписи.КоличествоПродаж;
			СуммаВозвратов = ЦенаПродажи * ВыборкаДетальныеЗаписи.КоличествоВозвратов;
			СуммаКорректировки = ВыборкаДетальныеЗаписи.СуммаВозвратов - ЦенаПродажи * ВыборкаДетальныеЗаписи.КоличествоВозвратов;
			//Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура ;
			//Характеристика = ВыборкаДетальныеЗаписи.Характеристика;	
			//Партия = ВыборкаДетальныеЗаписи.Партия;
		КонецЕсли;
		
		//Отбор = Новый  Структура ;
		//Отбор.Вставить("Номенклатура" ,Номенклатура);
		//Отбор.Вставить("Характеристика",Характеристика);
		//Отбор.Вставить("Партия", Партия);
		
		//Строки  = Запасы.НайтиСтроки(Отбор) ;	
