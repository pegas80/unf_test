Процедура ПроверкаОстаткаРеализованныхЗапасовПриВозврате(Отказ)

	//ПроверкаКоличестваПриВозвратеОтПокупателя
	Если Отказ ИЛИ
		 НЕ ЗначениеЗаполнено(ДокументОснование) ИЛИ
		 НЕ ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") ИЛИ
		 НЕ ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя Тогда
		Возврат;
	КонецЕсли;
	
	УчетнаяПолитикаРегл = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(Дата, Новый Структура("Организация", Организация));
	Если НЕ УчетнаяПолитикаРегл.ПроверкаКоличестваПриВозвратеОтПокупателя Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Запасы.НомерСтроки КАК НомерСтроки,
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Партия КАК Партия,
		|	Запасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	Запасы.Количество КАК Количество
		|ПОМЕСТИТЬ ЗапасыПред
		|ИЗ
		|	&Запасы КАК Запасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЗапасыПред.НомерСтроки) КАК НомерСтроки,
		|	ЗапасыПред.Номенклатура КАК Номенклатура,
		|	ЗапасыПред.Характеристика КАК Характеристика,
		|	ЗапасыПред.Партия КАК Партия,
		|	СУММА(ЗапасыПред.Количество * ВЫБОР
		|			КОГДА ТИПЗНАЧЕНИЯ(ЗапасыПред.ЕдиницаИзмерения) = ТИП(Справочник.ЕдиницыИзмерения)
		|				ТОГДА ВЫРАЗИТЬ(ЗапасыПред.ЕдиницаИзмерения КАК Справочник.ЕдиницыИзмерения).Коэффициент
		|			ИНАЧЕ 1
		|		КОНЕЦ) КАК КоличествоВозврата
		|ПОМЕСТИТЬ Запасы
		|ИЗ
		|	ЗапасыПред КАК ЗапасыПред
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыПред.Характеристика,
		|	ЗапасыПред.Партия,
		|	ЗапасыПред.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПродажиОбороты.Номенклатура КАК Номенклатура,
		|	ПродажиОбороты.Характеристика КАК Характеристика,
		|	ПродажиОбороты.Партия КАК Партия,
		|	СУММА(ПродажиОбороты.КоличествоОборот) КАК КоличествоОстаток
		|ПОМЕСТИТЬ ОстаткиРеализации
		|ИЗ
		|	РегистрНакопления.Продажи.Обороты(
		|			,
		|			,
		|			Авто,
		|			Документ = &ДокументОснование
		|				И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)) КАК ПродажиОбороты
		|ГДЕ
		|	НЕ ПродажиОбороты.Регистратор = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПродажиОбороты.Номенклатура,
		|	ПродажиОбороты.Характеристика,
		|	ПродажиОбороты.Партия
		|
		|ИМЕЮЩИЕ
		|	СУММА(ПродажиОбороты.КоличествоОборот) > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.НомерСтроки КАК НомерСтроки,
		|	Запасы.Номенклатура КАК Номенклатура,
		|	Запасы.Характеристика КАК Характеристика,
		|	Запасы.Партия КАК Партия,
		|	Запасы.КоличествоВозврата КАК КоличествоВозврата,
		|	ЕСТЬNULL(ОстаткиРеализации.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ИЗ
		|	Запасы КАК Запасы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ОстаткиРеализации КАК ОстаткиРеализации
		|		ПО Запасы.Номенклатура = ОстаткиРеализации.Номенклатура
		|			И Запасы.Характеристика = ОстаткиРеализации.Характеристика
		|			И Запасы.Партия = ОстаткиРеализации.Партия
		|ГДЕ
		|	Запасы.КоличествоВозврата > ЕСТЬNULL(ОстаткиРеализации.КоличествоОстаток, 0)";
	Запрос.УстановитьПараметр("ДокументОснование", 	ДокументОснование);
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("Запасы", 			Запасы.Выгрузить());
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ТекстСообщения = НСтр("ru = 'Для номенклатуры ""'; ka = 'ნომენკლატურისთვის ""'; en = 'ნომენკლატურისთვის ""'") 						+ Выборка.Номенклатура +
						 ?(ЗначениеЗаполнено(Выборка.Характеристика),	НСтр("ru = '"" с характеристиком ""'; ka = '"" მახასიათებლით ""'; en = '"" მახასიათებლით ""'") 	+ Выборка.Характеристика, "") + 
						 ?(ЗначениеЗаполнено(Выборка.Партия), 			НСтр("ru = '"" с партием ""'; ka = '"" პარტიით ""'; en = '"" პარტიით ""'")						+ Выборка.Партия, 		  "") + 
						 НСтр("ru = '"" в документе указанное количество ""'; ka = '"" დოკუმენტში მითითებული რაოდენობა ""'; en = '"" დოკუმენტში მითითებული რაოდენობა ""'") 	+ Выборка.КоличествоВозврата + 
						 НСтр("ru = '"" привышает остаток реализованного количества ""'; ka = '"" აღემატება რეალიზებული საქონლის რაოდენობის ნაშთს ""'; en = '"" აღემატება რეალიზებული საქონლის რაოდენობის ნაშთს ""'") + Выборка.КоличествоОстаток + """";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,"Запасы",Выборка.НомерСтроки,"Номенклатура",Отказ);
	КонецЦикла;

КонецПроцедуры
