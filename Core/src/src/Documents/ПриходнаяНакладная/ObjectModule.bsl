&НаСервере
Процедура ЗаполнитьПоПродажамиНаСервере(ЗапасыИзВизита = Неопределено)Экспорт 
	
	Если ЗапасыИзВизита = Неопределено Тогда 
		ТаблицаЗапасы = Запасы.Выгрузить();
	Иначе 
		ТаблицаЗапасы = ЗапасыИзВизита;
	КонецЕсли;
	
    ТаблицаЗапасыЦени = ТаблицаЗапасы.скопировать(); 
	ТаблицаЗапасы.Свернуть("Номенклатура","Количество");
	
	КопияТаблицаЗапасы = Новый ТаблицаЗначений;
	КопияТаблицаЗапасы = ТаблицаЗапасы.СкопироватьКолонки();
	КопияТаблицаЗапасы.Колонки.Добавить("ДокументОснование" );		  
	КопияТаблицаЗапасы.Колонки.Добавить("Цена");		  
	КопияТаблицаЗапасы.Колонки.Добавить("Себестоимость");		  
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	ТабТоваров.Номенклатура КАК Номенклатура,
	|	ТабТоваров.Количество КАК Количество
	|ПОМЕСТИТЬ врТабТоваров
	|ИЗ
	|	&ТабТоваров КАК ТабТоваров
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Документ КАК Документ,
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Характеристика КАК Характеристика,
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Партия КАК Партия,
	|	СУММА(ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.КоличествоКонечныйОстаток) КАК КоличествоПродажи,
	|	СУММА(ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.СуммаКонечныйОстаток) КАК СуммаПродажи,
	|	СУММА(ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.СебестоимостьКонечныйОстаток) КАК СебестоимостьПродажи,
	|	СУММА(ВЫБОР
	|			КОГДА ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.КоличествоКонечныйОстаток > 0
	|				ТОГДА ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.СуммаКонечныйОстаток / ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.КоличествоКонечныйОстаток
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Цена,
	|	СУММА(ВЫБОР
	|			КОГДА ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.КоличествоКонечныйОстаток > 0
	|				ТОГДА ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.СебестоимостьКонечныйОстаток / ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.КоличествоКонечныйОстаток
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СебестоимостьЕд
	|ПОМЕСТИТЬ врТабПродажи
	|ИЗ
	|	РегистрНакопления.ЦеныВозвратаНоменклатурDgFIFO.ОстаткиИОбороты(
	|			,
	|			&Дата,
	|			Авто,
	|			,
	|			Документ.Контрагент = &Контрагент
	|				И Документ.Договор = &Договор
	|				И ВЫБОР
	|					КОГДА &ЕстьДокумент
	|						ТОГДА Документ = &Документ
	|					ИНАЧЕ ИСТИНА
	|				КОНЕЦ) КАК ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты
	|
	|СГРУППИРОВАТЬ ПО
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Документ,
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Номенклатура,
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Характеристика,
	|	ЦеныВозвратаНоменклатурDgFIFOОстаткиИОбороты.Партия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	врТабТоваров.Номенклатура КАК Номенклатура,
	|	СУММА(врТабТоваров.Количество) КАК Количество,
	|	врТабПродажи.Документ КАК ДокументОснование,
	|	СУММА(врТабПродажи.КоличествоПродажи) КАК КоличествоПродажи,
	|	СУММА(врТабПродажи.СебестоимостьПродажи) КАК СебестоимостьПродажи,
	|	СУММА(врТабПродажи.Цена) КАК Цена,
	|	СУММА(врТабПродажи.СебестоимостьЕд) КАК СебестоимостьЕд
	|ИЗ
	|	врТабПродажи КАК врТабПродажи
	|		ЛЕВОЕ СОЕДИНЕНИЕ врТабТоваров КАК врТабТоваров
	|		ПО врТабПродажи.Номенклатура = врТабТоваров.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	врТабПродажи.Документ,
	|	врТабТоваров.Номенклатура
	|
	|УПОРЯДОЧИТЬ ПО
	|	врТабПродажи.Документ.Дата
	|ИТОГИ
	|	МАКСИМУМ(Количество),
	|	СУММА(КоличествоПродажи)
	|ПО
	|	Номенклатура";
	//
	//     "ВЫБРАТЬ
	//     |	ЦеныВозвратаНоменклатурDgFIFOОстатки.Документ КАК Документ,
	//     |	ЦеныВозвратаНоменклатурDgFIFOОстатки.Номенклатура КАК Номенклатура,
	//     |	ЦеныВозвратаНоменклатурDgFIFOОстатки.КоличествоОстаток КАК КоличествоОстаток,
	//     |	ЦеныВозвратаНоменклатурDgFIFOОстатки.СуммаОстаток КАК СуммаОстаток
	//     |ПОМЕСТИТЬ ВТ_ЦеныВозвратаНоменклатурDgFIFO
	//     |ИЗ
	//     |	РегистрНакопления.ЦеныВозвратаНоменклатурDgFIFO.Остатки(&МоментВремени, ) КАК ЦеныВозвратаНоменклатурDgFIFOОстатки
	//     |ГДЕ
	//     |	ЦеныВозвратаНоменклатурDgFIFOОстатки.Номенклатура В(&ТабТоваров)
	//     |	И ЦеныВозвратаНоменклатурDgFIFOОстатки.Контрагент = &Контрагент
	//     |	И ЦеныВозвратаНоменклатурDgFIFOОстатки.Документ.Договор = &Договор
	//     |	И ЦеныВозвратаНоменклатурDgFIFOОстатки.КоличествоОстаток > 0
	//     |;
	//     |
	//     |////////////////////////////////////////////////////////////////////////////////
	//     |ВЫБРАТЬ
	//     |	ПродажиОбороты.Документ КАК Документ
	//     |ИЗ
	//     |	РегистрНакопления.Продажи.Обороты(
	//     |			,
	//     |			&МоментВремени,
	//     |			,
	//     |			Документ ССЫЛКА Документ.РасходнаяНакладная
	//     |				И Документ.Контрагент = &Контрагент
	//     |				И Документ.Договор = &Договор
	//     |				И ВЫБОР
	//     |					КОГДА &ЕстьДокумент
	//     |						ТОГДА Документ = &Документ
	//     |					ИНАЧЕ ИСТИНА
	//     |				КОНЕЦ) КАК ПродажиОбороты
	//     |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЦеныВозвратаНоменклатурDgFIFO КАК ВТ_ЦеныВозвратаНоменклатурDgFIFO
	//     |		ПО ПродажиОбороты.Документ = ВТ_ЦеныВозвратаНоменклатурDgFIFO.Документ
	//     |			И ПродажиОбороты.Номенклатура = ВТ_ЦеныВозвратаНоменклатурDgFIFO.Номенклатура"
	
	Запрос.УстановитьПараметр("ТабТоваров", ТаблицаЗапасы);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Договор", 	Договор);
	Запрос.УстановитьПараметр("ЕстьДокумент", ЗначениеЗаполнено(ДокументОснование));
	Запрос.УстановитьПараметр("Документ", 	ДокументОснование);
	Запрос.УстановитьПараметр("Дата", 	Дата);

	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(МоментВремени(), ВидГраницы.Исключая));
	
	//тест =  Запрос.Выполнить().Выгрузить();
	
	ВыборкаНоменклатура = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаНоменклатура.Следующий() Цикл
		КоличествоПогасить=0;
		КоличествоПогасить = ВыборкаНоменклатура.Количество;
		
		ВыборкаПродажи = ВыборкаНоменклатура.Выбрать(); 		
		Пока ВыборкаПродажи.Следующий() Цикл
			Если Не ВыборкаПродажи.КоличествоПродажи > 0 Тогда
				Продолжить;
			КонецЕсли;
			Если   КоличествоПогасить <> Null Тогда 
				Если КоличествоПогасить >0 Тогда  
					стрЗапасы = КопияТаблицаЗапасы.Добавить();
					ЗаполнитьЗначенияСвойств(стрЗапасы,ВыборкаПродажи);
					стрЗапасы.Количество = Мин(ВыборкаПродажи.КоличествоПродажи,КоличествоПогасить);
					стрЗапасы.Себестоимость = ВыборкаПродажи.СебестоимостьЕд * стрЗапасы.Количество;
					КоличествоПогасить 	 = КоличествоПогасить - ВыборкаПродажи.КоличествоПродажи;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Если   КоличествоПогасить <> Null Тогда 
			Если КоличествоПогасить > 0 Тогда 
				стрЗапасы = КопияТаблицаЗапасы.Добавить();
				ЗаполнитьЗначенияСвойств(стрЗапасы,ВыборкаНоменклатура);
				стрЗапасы.Количество = КоличествоПогасить;
			КонецЕсли;	
		КонецЕсли;

	КонецЦикла;
	
	Если 	КопияТаблицаЗапасы.количество()>0 Тогда 
		
		Запасы.Загрузить(КопияТаблицаЗапасы);
		
		// Заполнение табличной части документа.
		Для каждого СтрокаТабличнойЧасти Из Запасы Цикл
			Если СтрокаТабличнойЧасти.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас Тогда
				//НайденнаяСтрока = ТаблицаЗапасыЦени.Найти(СтрокаТабличнойЧасти.Номенклатура,"Номенклатура");
				//Если Не НайденнаяСтрока = Неопределено И НайденнаяСтрока.Цена > 0 Тогда 
				//	СтрокаТабличнойЧасти.Цена = НайденнаяСтрока.Цена;
				//КонецЕсли;
				СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
				
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				
				СтрокаТабличнойЧасти.СтавкаНДС = СтрокаТабличнойЧасти.Номенклатура.СтавкаНДС;
				СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
				СтрокаТабличнойЧасти.СуммаНДС = ?(СуммаВключаетНДС, 
				СтрокаТабличнойЧасти.Сумма - (СтрокаТабличнойЧасти.Сумма) / ((СтавкаНДС + 100) / 100),
				СтрокаТабличнойЧасти.Сумма * СтавкаНДС / 100);
				СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

