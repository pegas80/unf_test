Функция ПолучитьСтруктуруДТРегл(МассивСчетовДтРегл, МассивСчетовКтРегл, ДокументСсылкаПриходнаяНакладная)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйВидыСубконто1.Ссылка КАК Счет,
		|	ХозрасчетныйВидыСубконто1.Ссылка.Код КАК Код,
		|	ХозрасчетныйВидыСубконто1.ВидСубконто.ИмяПредопределенныхДанных КАК ВидСубконто
		|ИЗ
		|	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто1
		|ГДЕ
		|	(ХозрасчетныйВидыСубконто1.Ссылка В (&МасивСчетовДтРегл)
		|			ИЛИ ХозрасчетныйВидыСубконто1.Ссылка В (&МасивСчетовКтРегл))
		|ИТОГИ ПО
		|	Счет";
	
	Запрос.УстановитьПараметр("МасивСчетовДтРегл", МассивСчетовДтРегл);
	Запрос.УстановитьПараметр("МасивСчетовКтРегл", МассивСчетовКтРегл);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСчетов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СоответствиеСчетов = Новый Соответствие;
	
	Пока ВыборкаСчетов.Следующий() Цикл
		
		СтруктураСубконто = Новый Структура;
		СтруктураСубконто.Вставить("ВидСубконто1", "");
		СтруктураСубконто.Вставить("ВидСубконто2", "");
		СтруктураСубконто.Вставить("ВидСубконто3", "");
		
		ВыборкаДетальныхЗаписей = ВыборкаСчетов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Счетчик = 1;
		Пока ВыборкаДетальныхЗаписей.Следующий() Цикл
			
			СтруктураСубконто["ВидСубконто"+Счетчик] = ВыборкаДетальныхЗаписей.ВидСубконто;
			
			Счетчик = Счетчик + 1;
			
		КонецЦикла;
		
		СоответствиеСчетов.Вставить(ВыборкаСчетов.Счет, СтруктураСубконто);
		
	КонецЦикла;
	
	СтруктураСубконтоДт = ПолучитьСтруктуруЗаполненияСубконтоДт(ДокументСсылкаПриходнаяНакладная);
	СтруктураСубконтоКт = ПолучитьСтруктуруЗаполненияСубконтоКт(ДокументСсылкаПриходнаяНакладная);
	
	СтруктураВозврата = Новый Структура;
	
	СтруктураВозврата.Вставить("СоответствиеСчетов", СоответствиеСчетов);
	СтруктураВозврата.Вставить("СтруктураСубконтоДт", СтруктураСубконтоДт);
	СтруктураВозврата.Вставить("СтруктураСубконтоКт", СтруктураСубконтоКт);
	
	Возврат СтруктураВозврата;
	
КонецФункции


