				ОбластьМакета.Параметры.ВсегоНДС = "-";
				
			Иначе
				
				ОбластьМакета.Параметры.НДС = ?(Шапка.СуммаВключаетНДС, "მათ შორის დღგ:", "Сумма НДС:");
