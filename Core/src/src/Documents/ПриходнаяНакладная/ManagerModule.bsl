КонецФункции // ПолучитьСтруктуруЗаполненияСубконто()

Функция ПолучитьСтруктуруЗаполненияСубконтоКт(ДокументСсылкаПриходнаяНакладная)

	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Продавцы"						, "");
	СтруктураВозврата.Вставить("Подразделения"					, "Подразделение");
	СтруктураВозврата.Вставить("СчетФактураПокупателя"			, "");
	СтруктураВозврата.Вставить("Валюты"							, ДокументСсылкаПриходнаяНакладная.ВалютаДокумента);
	СтруктураВозврата.Вставить("Сотрудники"						, "");
	СтруктураВозврата.Вставить("СотрудникНоменклатура"			, "Номенклатура");
	СтруктураВозврата.Вставить("КонтрагентыСотрудники"			, ДокументСсылкаПриходнаяНакладная.Контрагент);
	СтруктураВозврата.Вставить("Контрагенты"					, ДокументСсылкаПриходнаяНакладная.Контрагент);
	СтруктураВозврата.Вставить("СчетФактураПоставщика"			, "");
	СтруктураВозврата.Вставить("Номенклатура"					, "Номенклатура");
	СтруктураВозврата.Вставить("ХарактеристикиНоменклатуры"		, "Характеристика");
	СтруктураВозврата.Вставить("ОбособленныеПодразделения"		, "");
	СтруктураВозврата.Вставить("Продукция"						, "");
	СтруктураВозврата.Вставить("БанковскиеСчета"				, "");
	СтруктураВозврата.Вставить("Касса"							, "");
	СтруктураВозврата.Вставить("СтавкиНДФЛ"						, "");
	СтруктураВозврата.Вставить("Склады"							, "СтруктурнаяЕдиница");
	СтруктураВозврата.Вставить("ТипыСуммГрафикаКредитовИЗаймов"	, "");
	СтруктураВозврата.Вставить("ДоговорыКредитовИЗаймов"		, "");
	СтруктураВозврата.Вставить("НомераГТД"						, "");
	СтруктураВозврата.Вставить("РаботникиОрганизаций"			, "");
	СтруктураВозврата.Вставить("СтатьиДвиженияДенежныхСредств"	, "");
	СтруктураВозврата.Вставить("Имущество"						, "");
	СтруктураВозврата.Вставить("ДокументыРасчетовСКонтрагентами", "");
	СтруктураВозврата.Вставить("Партии"							, "Партия");
	СтруктураВозврата.Вставить("Договоры"						, ДокументСсылкаПриходнаяНакладная.Договор);
	
	Возврат СтруктураВозврата;

КонецФункции // ПолучитьСтруктуруЗаполненияСубконто()

Процедура ЗаполнитьСебестоимостьТоваровПоСреднемуЗначению(Документ) Экспорт
	
	ДокументОбъект = Неопределено;
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ПриходнаяНакладная") Тогда 
		ДокументОбъект = Документ;
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
		ДокументОбъект = Документ.ПолучитьОбъект();
	КонецЕсли;
	
	Если ДокументОбъект = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	            ДокументОбъект = Документы.ПриходнаяНакладная.НайтиПоНомеру().ПолучитьОбъект();
				
	МоментКонтроля = ?(ЗначениеЗаполнено(ДокументОбъект.Дата), ДокументОбъект.Дата, ТекущаяДата());
	МоментКонтроля = ?(ДокументОбъект.Проведен, МоментКонтроля - 1, МоментКонтроля);
	
	тзЗапасы = ДокументОбъект.Запасы.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзЗапасы.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	тзЗапасы.ЕдиницаИзмерения,
		|	тзЗапасы.Характеристика,
		|	тзЗапасы.СерийныеНомера,
		|	тзЗапасы.Цена,
		|	тзЗапасы.ПроцентСкидкиНаценки,
		|	тзЗапасы.Сумма,
		|	тзЗапасы.СтавкаНДС,
		|	тзЗапасы.СуммаНДС,
		|	тзЗапасы.Заказ,
		|	тзЗапасы.Всего,
		|	тзЗапасы.Себестоимость,
		|	тзЗапасы.СуммаРасходов,
		|	тзЗапасы.Содержание,
		|	тзЗапасы.КлючСвязи,
		|	тзЗапасы.ИдентификаторСтроки,
		|	тзЗапасы.НеобходимостьВводаАкцизнойМарки,
		|	тзЗапасы.Партия,
		|	тзЗапасы.Количество,
		|	тзЗапасы.СтранаПроисхождения,
		|	тзЗапасы.НомерГТД,
		|	тзЗапасы.ТоварыДляПроизводства,
		|	тзЗапасы.СуммаРасходовНДФЛ,
		|	тзЗапасы.СуммаРасходовНДС,
		|	тзЗапасы.СуммаРасходовПФ,
		|	тзЗапасы.СтруктурнаяЕдиница,
		|	тзЗапасы.НаправлениеДеятельности
		|ПОМЕСТИТЬ ВТ_Запасы
		|ИЗ
		|	&тзЗапасы КАК тзЗапасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыОстаткиИОбороты.Регистратор КАК Регистратор,
		|	ЗапасыОстаткиИОбороты.Организация КАК Организация,
		|	ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ЗапасыОстаткиИОбороты.СчетУчета КАК СчетУчета,
		|	ЗапасыОстаткиИОбороты.Номенклатура КАК Номенклатура,
		|	ЗапасыОстаткиИОбороты.Характеристика КАК Характеристика,
		|	ЗапасыОстаткиИОбороты.СчетУчетаРегл КАК СчетУчетаРегл,
		|	ЗапасыОстаткиИОбороты.КоличествоОборот КАК КоличествоОборот,
		|	ЗапасыОстаткиИОбороты.СуммаОборот КАК СуммаОборот
		|ПОМЕСТИТЬ ВТ_Обороты
		|ИЗ
		|	РегистрНакопления.Запасы.ОстаткиИОбороты(
		|			,
		|			&МоментКонтроля,
		|			Регистратор,
		|			,
		|			Организация = &Организация
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|				И СчетУчета = &СчетУчета
		|				И СчетУчетаРегл = &СчетУчетаРегл
		|				И (Номенклатура, Характеристика, СчетУчета, СчетУчетаРегл) В
		|					(ВЫБРАТЬ
		|						а.Номенклатура,
		|						а.Характеристика,
		|						а.Номенклатура.СчетУчетаЗапасов,
		|						а.Номенклатура.СчетУчетаЗапасовРегл
		|					ИЗ
		|						ВТ_Запасы КАК а)) КАК ЗапасыОстаткиИОбороты
		|ГДЕ
		|	ЗапасыОстаткиИОбороты.СуммаОборот <> 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Обороты.Организация КАК Организация,
		|	ВТ_Обороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ВТ_Обороты.СчетУчета КАК СчетУчета,
		|	ВТ_Обороты.Номенклатура КАК Номенклатура,
		|	ВТ_Обороты.Характеристика КАК Характеристика,
		|	ВТ_Обороты.СчетУчетаРегл КАК СчетУчетаРегл,
		|	СУММА(ВТ_Обороты.КоличествоОборот) КАК КоличествоОстаток,
		|	СУММА(ВТ_Обороты.СуммаОборот) КАК СуммаОстаток
		|ПОМЕСТИТЬ ВТ_Пред
		|ИЗ
		|	ВТ_Обороты КАК ВТ_Обороты
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Обороты.Организация,
		|	ВТ_Обороты.СтруктурнаяЕдиница,
		|	ВТ_Обороты.СчетУчета,
		|	ВТ_Обороты.Номенклатура,
		|	ВТ_Обороты.Характеристика,
		|	ВТ_Обороты.СчетУчетаРегл
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Запасы.Номенклатура,
		|	ВТ_Запасы.ЕдиницаИзмерения,
		|	ВТ_Запасы.Характеристика,
		|	ВТ_Запасы.СерийныеНомера,
		|	ВТ_Запасы.Цена,
		|	ВТ_Запасы.ПроцентСкидкиНаценки,
		|	ВТ_Запасы.Сумма,
		|	ВТ_Запасы.СтавкаНДС,
		|	ВТ_Запасы.СуммаНДС,
		|	ВТ_Запасы.Заказ,
		|	ВТ_Запасы.Всего,
		|	ВЫБОР
		|		КОГДА ВТ_Пред.СуммаОстаток ЕСТЬ NULL
		|				ИЛИ ВТ_Пред.КоличествоОстаток ЕСТЬ NULL
		|			ТОГДА ВТ_Запасы.Себестоимость
		|		КОГДА ВТ_Пред.КоличествоОстаток = 0
		|			ТОГДА ВТ_Запасы.Себестоимость
		|		ИНАЧЕ ВТ_Пред.СуммаОстаток / ВТ_Пред.КоличествоОстаток * ВТ_Запасы.Количество
		|	КОНЕЦ КАК Себестоимость,
		|	ВТ_Запасы.СуммаРасходов,
		|	ВТ_Запасы.Содержание,
		|	ВТ_Запасы.КлючСвязи,
		|	ВТ_Запасы.ИдентификаторСтроки,
		|	ВТ_Запасы.НеобходимостьВводаАкцизнойМарки,
		|	ВТ_Запасы.Партия,
		|	ВТ_Запасы.Количество,
		|	ВТ_Запасы.СтранаПроисхождения,
		|	ВТ_Запасы.НомерГТД,
		|	ВТ_Запасы.ТоварыДляПроизводства,
		|	ВТ_Запасы.СуммаРасходовНДФЛ,
		|	ВТ_Запасы.СуммаРасходовНДС,
		|	ВТ_Запасы.СуммаРасходовПФ,
		|	ВТ_Запасы.СтруктурнаяЕдиница,
		|	ВТ_Запасы.НаправлениеДеятельности
		|ИЗ
		|	ВТ_Запасы КАК ВТ_Запасы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Пред КАК ВТ_Пред
		|		ПО ВТ_Запасы.Номенклатура = ВТ_Пред.Номенклатура
		|			И ВТ_Запасы.Характеристика = ВТ_Пред.Характеристика";
	
	Запрос.УстановитьПараметр("МоментКонтроля", МоментКонтроля);
	Запрос.УстановитьПараметр("Организация", ДокументОбъект.Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ДокументОбъект.СтруктурнаяЕдиница);
	
	тзРезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ДокументОбъект.Запасы.Загрузить(тзРезультатЗапроса);
	
Конецпроцедуры

