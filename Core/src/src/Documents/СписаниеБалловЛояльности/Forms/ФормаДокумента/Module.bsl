
&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
	ПересчитатьНДСВСТроках();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БалыЛояльностиОстатки.КоличествоОстаток КАК Количество,
	|	БалыЛояльностиОстатки.СуммаОстаток КАК Сумма
	|ИЗ
	|	РегистрНакопления.БалыЛояльности.Остатки(
	|			&ДатаОтчета,
	|			Контрагент = &Контрагент
	|				И КартаЛояльности = &КартаЛояльности
	|				И Договор = &Договор) КАК БалыЛояльностиОстатки";
	
	Запрос.УстановитьПараметр("ДатаОтчета", Новый Граница(Объект.Дата, ВидГраницы.Исключая));
	Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
	Запрос.УстановитьПараметр("КартаЛояльности", Объект.КартаЛояльности);
	Запрос.УстановитьПараметр("Договор", Объект.Договор);
	Объект.КартыЛояльности.Загрузить(Запрос.Выполнить().Выгрузить());
	
	
КонецПроцедуры

