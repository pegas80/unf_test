// Процедура заполнения документа на основании.
//
// Параметры:
//	ДокументОснование - ДокументСсылка.РасходнаяНакладная - Данные заполнения документа.
//	
Процедура ЗаполнитьПоРасходнойНакладной(ДокументОснование) Экспорт
	
	Если ДокументОснование.ВидОперации <> Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю Тогда
		ТекстИсключения = НСтр("ka='დოკუმენტის შეყვანა ოპერაციის საფუძველზე შეუძლებელია - ""%ВидОперации""!';ru='Невозможен ввод документа на основании операции - ""%ВидОперации""!';en='You can not enter a document on the basis of the operation - ""% VidOperatsii""!'");
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ВидОперации", ДокументОснование.ВидОперации);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДата()));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитВыданный) КАК ВидДоговора,
	|	&Ссылка КАК ДокументОснование,
	|	ДокументРасходнаяНакладная.Организация КАК Организация,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(&Ссылка) КАК Основание,
	|	ДокументРасходнаяНакладная.Контрагент КАК Контрагент,
	|	ДокументРасходнаяНакладная.ВалютаДокумента КАК ВалютаРасчетов,
	|	&Ссылка КАК ДокументРеализации,
	|	&Дата КАК ДатаПредоставления
	|ИЗ
	|	Документ.РасходнаяНакладная КАК ДокументРасходнаяНакладная
	|ГДЕ
	|	ДокументРасходнаяНакладная.Ссылка = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	КонецЕсли;
	
	ЗаполнитьСуммуОстаткомЗадолженности();
	
КонецПроцедуры

