Процедура ЗаполнитьСуммуОстаткомЗадолженности()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДата()));
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(РасчетыСПокупателямиОстатки.СуммаВалОстаток, 0)) КАК СуммаЗадолженности
	|ИЗ
	|	РегистрНакопления.РасчетыСПокупателями.Остатки(
	|			&Дата,
	|			Организация = &Организация
	|				И Контрагент = &Контрагент
	|				И &УсловиеПоДоговору
	|				И &УсловиеПоДокументу) КАК РасчетыСПокупателямиОстатки";
	
	ПараметрыСделки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ДокументРеализации,
		"Договор, Контрагент.ВестиРасчетыПоДоговорам, Контрагент.ВестиРасчетыПоДокументам");
	
	Если ПараметрыСделки.КонтрагентВестиРасчетыПоДоговорам Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДоговору", "Договор = &Договор");
		Запрос.УстановитьПараметр("Договор", ПараметрыСделки.Договор);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДоговору", "ИСТИНА");
	КонецЕсли;
	
	Если ПараметрыСделки.КонтрагентВестиРасчетыПоДокументам Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДокументу", "Документ = &Документ");
		Запрос.УстановитьПараметр("Документ", ДокументРеализации);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоДокументу", "ИСТИНА");
		
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
