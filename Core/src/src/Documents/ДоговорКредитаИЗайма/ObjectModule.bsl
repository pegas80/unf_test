// Процедура заполнения документа на основании.
//
// Параметры:
//	ДокументОснование - ДокументСсылка.ЗаказПокупателя - Данные заполнения документа.
//	
Процедура ЗаполнитьПоЗаказуНаряду(ДокументОснование) Экспорт
	
	Если ДокументОснование.ВидОперации <> Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаряд Тогда
		ТекстИсключения = НСтр("ka='დოკუმენტის შეყვანა ოპერაციის საფუძველზე შეუძლებელია - ""%ВидОперации""!';ru='Невозможен ввод документа на основании операции - ""%ВидОперации""!';en='You can not enter a document on the basis of the operation - ""%ВидОперации""!'");
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%ВидОперации", ДокументОснование.ВидОперации);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	Если ДокументОснование.СостояниеЗаказа <> Справочники.СостоянияЗаказНарядов.Завершен Тогда
		ТекстИсключения = НСтр("ka='დოკუმენტის შეყვანა ოპერაციის საფუძველზე შეუძლებელია - ""%Состояние""!';ru='Невозможен ввод документа в состоянии - ""%Состояние""!';en='You can not enter a document on the basis of the status - ""%Состояние""!'");
		ТекстИсключения = СтрЗаменить(ТекстИсключения, "%Состояние", ДокументОснование.СостояниеЗаказа);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
//ДокументОснование.СостояниеЗаказа	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	Запрос.УстановитьПараметр("Дата", ?(ЗначениеЗаполнено(Дата), Дата, ТекущаяДата()));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКредитаИЗайма.КредитВыданный) КАК ВидДоговора,
	|	&Ссылка КАК ДокументОснование,
	|	ДокументЗаказНаряд.Организация КАК Организация,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(&Ссылка) КАК Основание,
	|	ДокументЗаказНаряд.Контрагент КАК Контрагент,
	|	ДокументЗаказНаряд.ВалютаДокумента КАК ВалютаРасчетов,
	|	&Ссылка КАК ДокументРеализации,
	|	&Дата КАК ДатаПредоставления
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ДокументЗаказНаряд
	|ГДЕ
	|	ДокументЗаказНаряд.Ссылка = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	КонецЕсли;
	
	ЗаполнитьСуммуОстаткомЗадолженности();
	
КонецПроцедуры
	
