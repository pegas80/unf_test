Функция ПолучитьСтруктуруЭлНакладных(Знач ДокументОбъект) Экспорт
	
	СтруктураТН = Новый Структура;	
	СтруктураТН.Вставить("Объект",						 	 ДокументОбъект.Ссылка);
	СтруктураТН.Вставить("Организация",						 ДокументОбъект.Организация);
	СтруктураТН.Вставить("Документ",						 ДокументОбъект.ДокументыОснования[0].ДокументОснование);
	СтруктураТН.Вставить("СтатусТН",						 ДокументОбъект.СтатусТН);
	СтруктураТН.Вставить("ID_ТН",							 ДокументОбъект.ID_ТН);
	СтруктураТН.Вставить("ТаблицаТоваровЭлНакладных",		 ДокументОбъект.ТоварыЭлНакладных.Выгрузить());
	СтруктураТН.Вставить("ТаблицаШапкаRS",		 			 ДокументОбъект.ШапкаRS.Выгрузить());

	//+++ Дмгг
	// проверка-костыль, походу при обмене не во всех случаях заполняется отправитель/получатель
	ОтправительПолучатель = ДокументОбъект.ГрузоПолучатель; 
	Если НЕ ЗначениеЗаполнено(ДокументОбъект.ГрузоОтправитель) Тогда 
		Если ДокументОбъект.ДокументыОснования.Количество() > 0 Тогда 
			Для Каждого Строк Из ДокументОбъект.ДокументыОснования Цикл 
				Если ЗначениеЗаполнено(Строк.ДокументОснование) Тогда 
					ОтправительПолучатель = Строк.ДокументОснование.Контрагент;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого Элем Из СтруктураТН.ТаблицаШапкаRS Цикл 
		
		Если Элем.ИмяПараметраRS = "BUYER_TIN" И НЕ ЗначениеЗаполнено(Элем.ЗначениеПараметраRS) Тогда 
			Элем.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(ОтправительПолучатель), СокрЛП(ОтправительПолучатель.ИНН), "");
		ИначеЕсли Элем.ИмяПараметраRS = "CHEK_BUYER_TIN" И НЕ ЗначениеЗаполнено(Элем.ЗначениеПараметраRS) Тогда 
			Элем.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(ОтправительПолучатель), ?(ОтправительПолучатель.ЯвляетсяНеРезидентом,0,1), 0);
		ИначеЕсли Элем.ИмяПараметраRS = "BUYER_NAME" И НЕ ЗначениеЗаполнено(Элем.ЗначениеПараметраRS) Тогда
			Элем.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(ОтправительПолучатель), ОтправительПолучатель.Наименование, "");
		КонецЕсли;		
		
	КонецЦикла;
	//--- Дмгг
	
	Возврат СтруктураТН;

КонецФункции

