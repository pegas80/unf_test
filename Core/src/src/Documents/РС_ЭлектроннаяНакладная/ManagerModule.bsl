		МассивСтрок.Очистить();
		МассивСтрок.Добавить(ОбластьТовары);
		МассивСтрок.Добавить(ОбластьТовары2);
		МассивСтрок.Добавить(ОбластьПустаяСтрока);
		МассивСтрок.Добавить(ОбластьПустаяСтрока);
		
		//МассивСтрок.Добавить(ОбластьПодвал);		
		КоличествоТоваров = ТаблицаТовары.Количество();	
		Для Каждого ВыборкаТовары Из ТаблицаТовары Цикл
			ОбластьТовары.Параметры.Заполнить(ВыборкаТовары);
			Попытка
				ОбластьТовары.Параметры.Номенклатура = Строка(ВыборкаТовары.Номенклатура) + ?(ИспользоватьХарактеристики, ?(ЗначениеЗаполнено(ВыборкаТовары.ХарактеристикаНоменклатуры), ", " + Строка(ВыборкаТовары.ХарактеристикаНоменклатуры), ""), "");
			Исключение
			КонецПопытки;
			Если НЕ КоличествоТоваров = 1 Тогда
				ОбластьТовары2.Параметры.Заполнить(ТаблицаТовары[ТаблицаТовары.Количество() - КоличествоТоваров + 1]);						
				Попытка
					ОбластьТовары2.Параметры.Номенклатура = Строка(ВыборкаТовары.Номенклатура) + ?(ИспользоватьХарактеристики, ?(ЗначениеЗаполнено(ВыборкаТовары.ХарактеристикаНоменклатуры), ", " + Строка(ВыборкаТовары.ХарактеристикаНоменклатуры), ""), "");
				Исключение
				КонецПопытки;
			КонецЕсли;
			Если ТабличныйДокумент.ПроверитьВывод(МассивСтрок) Тогда
				ТабличныйДокумент.Вывести(ОбластьТовары);
				КоличествоТоваров = КоличествоТоваров - 1;
				//Если КоличествоТоваров = 6 Тогда
				//	ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				//	ТабличныйДокумент.Вывести(ОбластьПриложение);
				//	ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);
				//КонецЕсли;	 
			Иначе
				//ТабличныйДокумент.Вывести(ОбластьПодвал);
				//ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				ТабличныйДокумент.Вывести(ОбластьПриложение);	
				ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);
				ТабличныйДокумент.Вывести(ОбластьТовары);
				КоличествоТоваров = КоличествоТоваров - 1;
			КонецЕсли;
			Если КоличествоТоваров = 0 Тогда
				ТабличныйДокумент.Вывести(ОбластьПодвал);
			КонецЕсли;	
		КонецЦикла;
	КонецЕсли;
		
	Возврат ТабличныйДокумент
	
КонецФункции


// Функция формирует печатную форму документа по указанному макету.
//
// Параметры:
//	ТабличныйДокумент - ТабличныйДокумент в который будет выводится печатная
//				   форма.
//  ИмяМакета    - Строка, имя макета печатной формы.
//
Функция ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, ИмяМакета) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_РС_ЭлектроннаяНакладная";
	
	ПервыйДокумент = Истина;
	
	Если ИмяМакета = "ТоварнаяНакладнаяRS" Тогда
		
	КонецЕсли;
	
	Для каждого ТекущийДокумент Из МассивОбъектов Цикл
	
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Если ИмяМакета = "ТоварнаяНакладнаяRS" Тогда
					
			ТабличныйДокумент.Вывести(СформироватьПечатнуюФормуТоварнаяНакладнаяRS(ТекущийДокумент));
				
		КонецЕсли;
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТоварнаяНакладнаяRS") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ТоварнаяНакладнаяRS", НСтр("ka='სასაქონლო ზედნადების ცხრილი';ru='Товарная накладная RS';en='Waybill RS'"), ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, "ТоварнаяНакладнаяRS"));
		
	КонецЕсли;
	
	// параметры отправки печатных форм по электронной почте
	УправлениеНебольшойФирмойСервер.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
	
КонецПроцедуры

// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	// ТоварнаяНакладнаяRS
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ТоварнаяНакладнаяRS";
	КомандаПечати.Представление = НСтр("ka='სასაქონლო ზედნადების ცხრილი';ru='Товарная накладная RS';en='Waybill RS'");
	КомандаПечати.СписокФорм    = "ФормаСписка,ФормаДокумента";
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	КомандаПечати.Порядок = 1;
	
КонецПроцедуры

