	Попытка
		ОбластьПодвал.Параметры.ПримечаниеТТН = ТекущийДокумент.КомментарийТН;
	Исключение
	КонецПопытки;
	
	Попытка
		ОбластьПриложение.Параметры.Приложения = ВыборкаШапка.НомерНакладной + " სასაქონლო ზედნადების დანართი";
	Исключение
	КонецПопытки;
	
	ТаблицаТовары = Выборка[2].Выгрузить();	
	
	Если ТаблицаТовары.Количество() = 0 Тогда
		ТабличныйДокумент.Вывести(ОбластьТовары);
		ТабличныйДокумент.Вывести(ОбластьПодвал);
	Иначе	
