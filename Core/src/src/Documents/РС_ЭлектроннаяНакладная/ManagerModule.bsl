Функция ОпределитьТипТН(ТипТН) Экспорт
	
	ТипНакладной = 0;
	Если ТипТН = Перечисления.РС_ТипыТН.ВнутреннееПеремещение Тогда 
		ТипНакладной = 1;
	ИначеЕсли ТипТН = Перечисления.РС_ТипыТН.РеализацияСТранспортировкой Тогда 
		ТипНакладной = 2;
	ИначеЕсли ТипТН = Перечисления.РС_ТипыТН.РеализацияБезТранспортировки Тогда 
		ТипНакладной = 3;
	ИначеЕсли ТипТН = Перечисления.РС_ТипыТН.Дистрибуция Тогда 
		ТипНакладной = 4;
	ИначеЕсли ТипТН = Перечисления.РС_ТипыТН.ВозвратОтПокупателя Тогда 
		ТипНакладной = 5;
	ИначеЕсли ТипТН = Перечисления.РС_ТипыТН.ПодчиненнаяТН Тогда 
		ТипНакладной = 6;
	КонецЕсли;
	
	Возврат ТипНакладной;
	
КонецФункции

Функция ПолучитьВидТранспортировкиЭл(ТипТН, ВидТранспортировки, Прицеп, ДругойТранспорт, TRANS_ID, TRANS_TXT) Экспорт 
	
	TRANS_ID = 0;
	TRANS_TXT = "";
	Если ТипТН = Перечисления.РС_ТипыТН.РеализацияБезТранспортировки Тогда 
		TRANS_ID = 0;
	ИначеЕсли ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Автомобильная Тогда 
		TRANS_ID = 1;
		TRANS_TXT = Прицеп;
	ИначеЕсли ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Железнодорожная Тогда
		TRANS_ID = 2;
	ИначеЕсли ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Авиационная Тогда
		TRANS_ID = 3;
	ИначеЕсли ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Автомобильная_Заграничная Тогда
		TRANS_ID = 6;
		TRANS_TXT = Прицеп;
	ИначеЕсли ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Перегрузчик_Автомобильная Тогда
		TRANS_ID = 7;
		TRANS_TXT = Прицеп;
	Иначе 		
		TRANS_ID	= 4;
		TRANS_TXT	= ДругойТранспорт;
	КонецЕсли;

	
КонецФункции

Функция СформироватьСуммуПрописьюБезЦифр(Сумма, Валюта)
	
	//Если Валюта.ПараметрыПрописи = "" Тогда
	//	Возврат ФорматСумм(Сумма);                           
	//Иначе                                          		
		Если Валюта.ПараметрыПрописиНаРусском = "" Тогда
			Возврат ФорматСумм(Сумма);
		Иначе
