	КонецЕсли;
	Попытка
		ОбластьПодвал.Параметры.ВремяПечати				= Формат(ТекущаяДата(), "ДФ=""дд/ММ/гггг, ЧЧ:мм:сс"";L = ""ka""");
	Исключение
