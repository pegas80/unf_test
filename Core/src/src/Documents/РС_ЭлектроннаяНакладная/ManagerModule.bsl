#Область ИнтерфейсПечати

Функция СформироватьПечатнуюФормуТоварнаяНакладнаяRS(ТекущийДокумент) 
	
	ИспользоватьХарактеристики = Константы.ФункциональнаяОпцияИспользоватьХарактеристики.Получить();
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_РС_ЭлектроннаяНакладная_ПФ_MXL_ТоварнаяНакладнаяRS";
	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_СчетНаОплату_ПФ_MXL_ТоварнаяНакладнаяRS";
	//ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.АвтоМасштаб = истина;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
		
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.РС_ЭлектроннаяНакладная.ПФ_MXL_ТоварнаяНакладнаяRS");
	
	ОбластьШапка		= Макет.ПолучитьОбласть("Шапка");
	ОбластьПриложение	= Макет.ПолучитьОбласть("Приложение");														
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");	
	ОбластьТовары		= Макет.ПолучитьОбласть("СтрокаТаблицы");
	ОбластьТовары2		= Макет.ПолучитьОбласть("СтрокаТаблицы");
	ОбластьПодвал		= Макет.ПолучитьОбласть("Подвал");
	ОбластьПустаяСтрока		= Макет.ПолучитьОбласть("ПустаяСтрока");
	
	ОбластьТЧЛицензииНаВырубкуЛесаШапка  = Макет.ПолучитьОбласть("ТЧЛицензииНаВырубкуЛесаШапка"); 
	ОбластьТЧЛицензииНаВырубкуЛесаСтрока = Макет.ПолучитьОбласть("ТЧЛицензииНаВырубкуЛесаСтрока");
	ОбластьНомерТаблички                 = Макет.ПолучитьОбласть("НомерТаблички");
	ОбластьНадписьЛицензии               = Макет.ПолучитьОбласть("НадписьЛицензии");
	
	ТабличныйДокумент.Очистить();
	
	ВалютаРегл = Константы.НациональнаяВалюта.Получить();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",                ТекущийДокумент.Ссылка);
	//Запрос.УстановитьПараметр("ДатаДокумента",		   ТекущийДокумент.Ссылка.Дата);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Константы.ЭлектроннаяНакладнаяДатуБратьИзДатыТранспортировки
	|			ТОГДА РС_ЭлектроннаяНакладная.ДатаНачалаТранспортировки
	|		ИНАЧЕ РС_ЭлектроннаяНакладная.ДатаАктивации
	|	КОНЕЦ КАК ДатаПоставки,
	|	РС_ЭлектроннаяНакладная.НомерТН КАК НомерНакладной,
	|	РС_ЭлектроннаяНакладная.Дата КАК ДатаДокумента,
	|	""(დღგ–ს გადამხდელი)"" КАК ПлателщикНДС1,
	|	РС_ЭлектроннаяНакладная.Организация.НаименованиеПолное КАК Отправитель,
	|	РС_ЭлектроннаяНакладная.Организация.ИНН КАК ИННОтправителя,
	|	""(დღგ–ს გადამხდელი)"" КАК ПлателщикНДС2,
	|	РС_ЭлектроннаяНакладная.ГрузоПолучатель.НаименованиеПолное КАК Получатель,
	|	РС_ЭлектроннаяНакладная.ГрузоПолучатель.ИНН КАК ИННПолучателя,
	|	РС_ЭлектроннаяНакладная.ТипТН КАК ТипТТН,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладная.АдресОтправки = """"
	|			ТОГДА ""Х""
	|		ИНАЧЕ РС_ЭлектроннаяНакладная.АдресОтправки
	|	КОНЕЦ КАК АдресНачалаТранспортировки,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладная.ТипТН = ЗНАЧЕНИЕ(Перечисление.РС_ТипыТН.РеализацияБезТранспортировки)
	|			ТОГДА ""Х""
	|		ИНАЧЕ РС_ЭлектроннаяНакладная.АдресДоставки
	|	КОНЕЦ КАК АдресДоставки,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Прочее)
	|			ТОГДА РС_ЭлектроннаяНакладная.КомментарийТН
	|		ИНАЧЕ РС_ЭлектроннаяНакладная.ВидТранспортировки
	|	КОНЕЦ КАК ВидТранспортировки,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладная.ТипТН = ЗНАЧЕНИЕ(Перечисление.РС_ТипыТН.РеализацияБезТранспортировки)
	|			ТОГДА ""Х""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Прочее)
	|						ИЛИ РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Железнодорожная)
	|						ИЛИ РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Авиационная)
	|					ТОГДА ""Х""
	|				ИНАЧЕ РС_ЭлектроннаяНакладная.ГосНомерАвтомобиля
	|			КОНЕЦ
	|	КОНЕЦ КАК НомерТранспорта,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладная.ТипТН = ЗНАЧЕНИЕ(Перечисление.РС_ТипыТН.РеализацияБезТранспортировки)
	|			ТОГДА """"
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Прочее)
	|						ИЛИ РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Железнодорожная)
	|						ИЛИ РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Авиационная)
	|					ТОГДА """"
	|				ИНАЧЕ ВЫБОР
	|						КОГДА РС_ЭлектроннаяНакладная.КомментарийТН = """"""""
	|							ТОГДА ""Х""
	|						ИНАЧЕ РС_ЭлектроннаяНакладная.КомментарийТН
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ОписаниеТранспортировки,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладная.ТипТН = ЗНАЧЕНИЕ(Перечисление.РС_ТипыТН.РеализацияСТранспортировкой)
	|				И НЕ(РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Автомобильная)
	|						ИЛИ РС_ЭлектроннаяНакладная.ВидТранспортировки = ЗНАЧЕНИЕ(Перечисление.РС_ВидыТранспортировки.Автомобильная_Заграничная))
	|			ТОГДА ""Х""
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РС_ЭлектроннаяНакладная.ТипТН = ЗНАЧЕНИЕ(Перечисление.РС_ТипыТН.РеализацияБезТранспортировки)
	|					ТОГДА ""Х""
	|				ИНАЧЕ ВЫБОР
	|						КОГДА РС_ЭлектроннаяНакладная.НомерУдостоверения = """"
	|							ТОГДА РС_ЭлектроннаяНакладная.Перевозчик.ИНН
	|						ИНАЧЕ РС_ЭлектроннаяНакладная.НомерУдостоверения
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ИННВодителя,
	|	РС_ЭлектроннаяНакладная.СуммаОплатыТранспортировки КАК РасходВодителя,
	|	РС_ЭлектроннаяНакладная.Отпустил КАК ОтправительТТН,
	|	РС_ЭлектроннаяНакладная.Получил КАК ПолучательТТН,
	|	РС_ЭлектроннаяНакладная.ДатаДоставкиТН КАК ДатаЗавершенияТранспортировки,
	|	РС_ЭлектроннаяНакладная.КомментарийТН КАК ПримечаниеТТН,
	|	РС_ЭлектроннаяНакладная.Прицеп
	|ИЗ
	|	Документ.РС_ЭлектроннаяНакладная КАК РС_ЭлектроннаяНакладная,
	|	Константы КАК Константы
	|ГДЕ
	|	РС_ЭлектроннаяНакладная.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(РС_ЭлектроннаяНакладнаяТовары.Сумма) КАК Сумма
	|ИЗ
	|	Документ.РС_ЭлектроннаяНакладная.Товары КАК РС_ЭлектроннаяНакладнаяТовары
	|ГДЕ
	|	РС_ЭлектроннаяНакладнаяТовары.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РС_ЭлектроннаяНакладнаяТовары.НомерСтроки КАК НомерСтроки,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(РС_ЭлектроннаяНакладнаяТовары.Номенклатура.НаименованиеПолное КАК СТРОКА(1))) = "" ""
	|			ТОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.Наименование
	|		ИНАЧЕ РС_ЭлектроннаяНакладнаяТовары.Номенклатура.НаименованиеПолное
	|	КОНЕЦ КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.ОсновнойШтрихКод = """"
	|			ТОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.Код
	|		ИНАЧЕ РС_ЭлектроннаяНакладнаяТовары.Номенклатура.ОсновнойШтрихКод
	|	КОНЕЦ КАК Код1,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.ЕдиницаИзмерения = РС_ЭлектроннаяНакладнаяТовары.ЕдиницаИзмерения
	|			ТОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ РС_ЭлектроннаяНакладнаяТовары.ЕдиницаИзмерения
	|	КОНЕЦ КАК ЕдиницаИзмерения,
	|	РС_ЭлектроннаяНакладнаяТовары.Количество,
	|	РС_ЭлектроннаяНакладнаяТовары.Цена КАК Цена,
	|	РС_ЭлектроннаяНакладнаяТовары.Сумма КАК Сумма,
	|	РС_ЭлектроннаяНакладнаяТовары.Характеристика КАК ХарактеристикаНоменклатуры,
	|	ВЫБОР
	|		КОГДА РС_ЭлектроннаяНакладнаяТовары.Ссылка.Организация.СоответствиеНоменклатур = ЗНАЧЕНИЕ(Перечисление.СоответствияНоменклатуры.ПоШтрихкоду)
	|			ТОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.ОсновнойШтрихКод
	|		КОГДА РС_ЭлектроннаяНакладнаяТовары.Ссылка.Организация.СоответствиеНоменклатур = ЗНАЧЕНИЕ(Перечисление.СоответствияНоменклатуры.ПоАртикулу)
	|			ТОГДА РС_ЭлектроннаяНакладнаяТовары.Номенклатура.Артикул
	|		ИНАЧЕ РС_ЭлектроннаяНакладнаяТовары.Номенклатура.Код
	|	КОНЕЦ КАК Код,
	|	"""" КАК Код2
	|ИЗ
	|	Документ.РС_ЭлектроннаяНакладная.Товары КАК РС_ЭлектроннаяНакладнаяТовары
	|ГДЕ
	|	РС_ЭлектроннаяНакладнаяТовары.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	Выборка = Запрос.ВыполнитьПакет();
	ВыборкаШапка = Выборка[0].Выбрать();
	ВыборкаШапка.Следующий();
	ОбластьШапка.Параметры.Заполнить(ВыборкаШапка);
	Попытка
		ОбластьШапка.Параметры.Дата		= Формат(ТекущийДокумент.Ссылка.ДатаНачалаТранспортировки,	"ДФ=""дд/ММ/гггг"";L = ""ka"""); //ВыборкаШапка.ДатаПоставки
	Исключение
	КонецПопытки;
	Попытка
		ОбластьШапка.Параметры.Время	= Формат(ТекущийДокумент.Ссылка.ДатаНачалаТранспортировки,	"ДФ=""ЧЧ:мм:сс"";L = ""ka""");	
	Исключение
	КонецПопытки;	
	//Если Ссылка.СтатусТН = Перечисления.РС_СтатусыТН.Отмененный Тогда
	//	ДатаОтмены = ПолучитьДатуОтмены(Ссылка);
	//	Попытка
	//		ОбластьШапка.Параметры.ДатаОтмены	= "გაუქმების თარიღი: " + Формат(ДатаОтмены,	"ДФ=""дд/ММ/гггг"";L = ""ka""");
	//	Исключение
	//	КонецПопытки;
	//КонецЕсли;
	
	Попытка
		ОбластьШапка.Параметры.ИННВодителя = ВыборкаШапка.ИННВодителя + "  " +ВыборкаШапка.Перевозчик;
	Исключение
	КонецПопытки;
	
	//ВыводитьПресселера = МодульСтатическихДанных.ПолучитьВыводитьТорговогоПредставителяПриПечатиНакладной();
	//Если ВыводитьПресселера Тогда
	//	Попытка
	//		ОбластьШапка.Параметры.Преселлер = Строка(ВыборкаШапка.Преселлер);
	//	Исключение
	//	КонецПопытки;
	//Иначе
		Попытка
			ОбластьШапка.Параметры.Преселлер = "";
		Исключение
		КонецПопытки;
	//КонецЕсли;
	
	//Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ
	//|	НалогообложениеКонтрагентаСрезПоследних.ВидНалогообложения
	//|ИЗ
	//|	РегистрСведений.НалогообложениеКонтрагента.СрезПоследних(&Период, Контрагент = &Контрагент) КАК НалогообложениеКонтрагентаСрезПоследних";
	
	//Запрос.УстановитьПараметр("Период", Ссылка.Дата);
	//Запрос.УстановитьПараметр("Контрагент", Ссылка.Контрагент);
	//Резултат = Запрос.Выполнить().Выбрать();
	//Если Резултат.Следующий() Тогда 
	//	Если Резултат.ВидНалогообложения = Перечисления.НалогообложениеНДС.ОблагаетсяНДС Тогда 
	//		Попытка
	//			ОбластьШапка.Параметры.ПлателщикНДС2 = "(დღგ–ს გადამხდელი)"; 	
	//		Исключение
	//		КонецПопытки;
	//	КонецЕсли;
	//Иначе 
	//	Попытка
			ОбластьШапка.Параметры.ПлателщикНДС2 = "(დღგ–ს გადამხდელი)";
	//	Исключение
	//	КонецПопытки;
	//КонецЕсли;
	
	//ОбластьШапка.Параметры.КатегорияНакладной = ?(ВыборкаШапка.КатегорияТН = Перечисления.КатегорииТТН.Лесопосадки, "ხე-ტყის", "");
	
//rajak	
	Если ТекущийДокумент.ТипТН = Перечисления.РС_ТипыТН.ВозвратОтПокупателя Тогда 
		
		 ОбластьШапка.Параметры.Отправитель = ТекущийДокумент.ГрузоОтправитель;
		 ОбластьШапка.Параметры.ИННОтправителя = ТекущийДокумент.ГрузоОтправитель.ИНН;
		 ОбластьШапка.Параметры.Получатель = ТекущийДокумент.ГрузоПолучатель;
		 ОбластьШапка.Параметры.ИННПолучателя = ТекущийДокумент.ГрузоПолучатель.ИНН;
		
	КонецЕсли;
//rajak	
	
	ТабличныйДокумент.Вывести(ОбластьШапка);
	
	ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);
	
	ВыгрузкаОбщаяСумма = Выборка[1].Выбрать();
	ВыгрузкаОбщаяСумма.Следующий();
	ОбщаяСумма = ?(ВыгрузкаОбщаяСумма.Сумма = Null, 0, ВыгрузкаОбщаяСумма.Сумма);
	
	
	ОбластьПодвал.Параметры.Заполнить(ВыборкаШапка);		
	Попытка
		ОбластьПодвал.Параметры.ОбщаяСумма = ?(ОбщаяСумма = 0, "0", ?(ОбщаяСумма >= 1, ?(ОбщаяСумма %Цел(ОбщаяСумма)= 0, Формат(ОбщаяСумма, "ЧЦ=15; ЧДЦ=0; ЧРД=.; ЧРГ=' '; ЧН=0"),
		Формат(ОбщаяСумма, "ЧЦ=15; ЧДЦ=2; ЧРД=.; ЧРГ=' '; ЧН=0")),Формат(ОбщаяСумма, "ЧЦ=15; ЧДЦ=2; ЧРД=.; ЧРГ=' '; ЧН=0")));
	Исключение
	КонецПопытки;
	Попытка
		ОбластьПодвал.Параметры.ОбщаяСуммаПрописью = СформироватьСуммуПрописьюБезЦифр(ОбщаяСумма, ВалютаРегл);	 
	Исключение
	КонецПопытки;
	
	Попытка
		ОбластьПодвал.Параметры.Тире ="-";		
	Исключение
	КонецПопытки;
	Попытка
