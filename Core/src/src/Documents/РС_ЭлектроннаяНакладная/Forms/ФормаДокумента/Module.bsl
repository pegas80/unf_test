	ТекДанные.СуммаНДС	= Окр(ТекДанные.Сумма	* СтавкаНДС/(100 + СтавкаНДС), 2);
КонецПроцедуры



&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	ТекДанные.ЕдиницаИзмерения 	= ПолучитьЗначенияРеквизита(ТекДанные.Номенклатура, "ЕдиницаИзмерения");
	ТекДанные.СтавкаНДС 		= ПолучитьЗначенияРеквизита(ТекДанные.Номенклатура, "СтавкаНДС");
	СтавкаНДС = ПолучитьЗначенияРеквизита(ТекДанные.СтавкаНДС, "Ставка");
	ТекДанные.СуммаНДС	= Окр(ТекДанные.Сумма	* СтавкаНДС/(100 + СтавкаНДС), 2);
КонецПроцедуры

