	 КонецЕсли;
	 //Записать();Паганини
	 
	// УдалитьУслугиИзТаблицы();//Паганини#OneSoft: Перенес в условие, где заполняется таблица
	
	Если ТипЗнч(Объект.ГрузоПолучатель)= Тип("СправочникСсылка.Контрагенты")и Объект.ГрузоПолучатель.ПересчитатьКоличество
		Тогда 
		ПересчитатьКоличествоИзДополнительнойЕдиницыИзмеренияВОсновнуюЕдиницуИзмерения();	
	КонецЕсли;
	 
	 ДокументОбъект = РеквизитФормыВЗначение("Объект");
	 ДокументОбъект.СформироватьТаблицуЭлНакладных();
	 ДокументОбъект.СформироватьТаблицуШапкаRS();
	 ЗначениеВРеквизитФормы(ДокументОбъект,"Объект");
	 Записать();//Паганини
 
 КонецПроцедуры // ()

 Процедура УдалитьУслугиИзТаблицы() 
	
	Для Каждого Стр Из Объект.Товары Цикл 
		Если Стр.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Запас Тогда
			Объект.Товары.Удалить(Стр);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры	

&НаСервере
Процедура ЗаполнитьТоварыНаСервере()
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) ИЛИ Модифицированность Тогда
		Записать();
	КонецЕсли;

	Объект.Товары.Очистить(); 
	ЗапольнитьРеквизитиНакладной(Объект.ДокументыОснования.Выгрузить().ВыгрузитьКолонку("ДокументОснование"));
	
КонецПроцедуры


&НаКлиенте
Процедура ЗаполнитьТовары(Команда)
	
	Если Объект.Товары.Количество() > 0 Тогда 
		Режим = РежимДиалогаВопрос.ДаНет;
		ТекстВопроса = Нстр("ka='შევსებამდე გასუფთავდება არსებული საქონლის ცხრილი. გაგრძელდეს?';ru='Перед заполнением очистится табличная часть Товары. Продолжить?';en='Before filling cleared tabular section Goods. Proceed?'");
		
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтаФорма, Параметры);
		ПоказатьВопрос(Оповещение, ТекстВопроса, Режим, 0);
	Иначе 
		ЗаполнитьТоварыНаСервере();
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	Иначе 
		ЗаполнитьТоварыНаСервере();
	КонецЕсли;

КонецПроцедуры


