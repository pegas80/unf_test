КонецПроцедуры

&НаКлиенте
Процедура ОтменитьТН(Команда) Экспорт
	
	Режим = РежимДиалогаВопрос.ДаНет;
	Ответ = Вопрос(НСтр("ru = 'Вы уверены что хотите отменить ТН?';"
	+ " ka = 'დარწმუნებული ხართ რომ გნებავთ ზედნადების გაუქმება?'"), Режим, 0);
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ОбновитьДанныеОтправкиНаСервере();
	Операция_ЭлНакладная(Команда.Имя);
	Прочитать();
КонецПроцедуры

&НаКлиенте
Процедура СоздатьИАктивироватьТН(Команда) Экспорт
	ОбновитьДанныеОтправкиНаСервере();
	Операция_ЭлНакладная(Команда.Имя);
	Прочитать();
КонецПроцедуры

//Паганини
&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	СтавкаНДС = ПолучитьЗначенияРеквизита(ТекДанные.СтавкаНДС, "Ставка");
	ТекДанные.Сумма 	= ТекДанные.Количество	* ТекДанные.Цена;
	ТекДанные.СуммаНДС	= Окр(ТекДанные.Сумма	* СтавкаНДС/(100 + СтавкаНДС), 2);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыЦенаПриИзменении(Элемент)
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	СтавкаНДС = ПолучитьЗначенияРеквизита(ТекДанные.СтавкаНДС, "Ставка");
	ТекДанные.Сумма 	= ТекДанные.Количество	* ТекДанные.Цена;
	ТекДанные.СуммаНДС	= Окр(ТекДанные.Сумма	* СтавкаНДС/(100 + СтавкаНДС), 2);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыСуммаПриИзменении(Элемент)
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	СтавкаНДС = ПолучитьЗначенияРеквизита(ТекДанные.СтавкаНДС, "Ставка");
	ТекДанные.Цена 	= ?(ТекДанные.Количество = 0, 0, Окр(ТекДанные.Сумма / ТекДанные.Количество, 2));
	ТекДанные.СуммаНДС	= Окр(ТекДанные.Сумма	* СтавкаНДС/(100 + СтавкаНДС), 2);
КонецПроцедуры

