 &НаСервере
 Процедура ЗапольнитьРеквизитиНакладной(МассивДокументовОснования)
	 
	 //ЗапольнитьЗначенияШапки();
	 Если Объект.ТипТН = Перечисления.РС_ТипыТН.ВозвратОтПокупателя Тогда
