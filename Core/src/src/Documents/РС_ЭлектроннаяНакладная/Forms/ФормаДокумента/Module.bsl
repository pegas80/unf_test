&НаКлиенте
Процедура СоздатьТН(Команда) Экспорт 
	ОбновитьДанныеОтправкиНаСервере();	
	Операция_ЭлНакладная(Команда.Имя);
	Прочитать();
	
КонецПроцедуры


&НаКлиенте
Процедура Операция_ЭлНакладная(КомандаТН)
	
	ОчиститьСообщения();//Паганини
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) ИЛИ Модифицированность Тогда
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		Если Не Объект.РучнаяКорректировка Тогда 
			ОбновитьДанныеОтправкиНаСервере();
			Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
		КонецЕсли; 
	КонецЕсли;
	
	Результат = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбработатьОперациюТН(КомандаТН, Объект);
	Если Не Результат = 0 Тогда 
		Сообщить(Результат);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруЭлНакладных()
	
	Возврат Документы.РС_ЭлектроннаяНакладная.ПолучитьСтруктуруЭлНакладных(Объект.Ссылка);
	
КонецФункции

&НаСервере
Процедура ОбновитьДанныеОтправкиНаСервере()
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	//Lazare_
	Если Не ПустаяСтрока(ДокументОбъект.ТранспортноеСредство)и ДокументОбъект.ТранспортноеСредство = ПредопределенноеЗначение("Справочник.ТранспортныеСредства.ОбщественныйТранспорт")Тогда 
		ДокументОбъект.ГосНомерАвтомобиля = ДокументОбъект.ТранспортноеСредство.Наименование ;
	КонецЕсли ;	
	//_Lazare	
	ДокументОбъект.СформироватьТаблицуЭлНакладных();
	ДокументОбъект.СформироватьТаблицуШапкаRS();
	ЗначениеВРеквизитФормы(ДокументОбъект,"Объект");
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеОтправки(Команда)
	ОбновитьДанныеОтправкиНаСервере();
КонецПроцедуры

