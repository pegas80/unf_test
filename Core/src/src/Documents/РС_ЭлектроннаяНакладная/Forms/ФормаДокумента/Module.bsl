&НаСервере
Процедура ПересчитатьКоличествоИзДополнительнойЕдиницыИзмеренияВОсновнуюЕдиницуИзмерения()
		
	Для Каждого Стр Из Объект.Товары Цикл 	
		
		Если ТипЗнч(Стр.ЕдиницаИзмерения)= ТИП("СправочникСсылка.КлассификаторЕдиницИзмерения")и Стр.ЕдиницаИзмерения.ПересчитатьКоличествоВТТН Тогда 	
			СпЕдиницыИзмерения = ПолучитьЕдиницыИзмеренияНоманклатры(Стр.номенклатура);
			Если СпЕдиницыИзмерения <> Неопределено Тогда 
				Стр.Количество  = Стр.Количество / СпЕдиницыИзмерения.Коэффициент;
				Стр.Цена        = Стр.Цена * СпЕдиницыИзмерения.Коэффициент;
				Стр.Сумма       = Стр.Количество * Стр.Цена;
				Стр.ЕдиницаИзмерения  = СпЕдиницыИзмерения;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	 
 КонецПроцедуры
 
 &Насервере
 Функция  ПолучитьЕдиницыИзмеренияНоманклатры(Номенклатруа)
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст =  
	 "ВЫБРАТЬ
	 |	ЕдиницыИзмерения.Ссылка КАК ЕдиницыИзмерения
	 |ИЗ
	 |	Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	 |ГДЕ
	 |	ЕдиницыИзмерения.Владелец = &Владелец
	 |	И ЕдиницыИзмерения.ПометкаУдаления = ЛОЖЬ";
	 
	 Запрос.УстановитьПараметр("Владелец",Номенклатруа);
	 
	 РезЗапроса = Запрос.Выполнить().Выгрузить();
	 
	 Если РезЗапроса.Количество()> 0 Тогда 
		 Возврат РезЗапроса[0].ЕдиницыИзмерения;
	 КонецЕсли;      	 
	 
 КонецФункции
 //--Lazare 05.06.2022



