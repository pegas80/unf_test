	УстановитьВидимостьИДоступность();
КонецПроцедуры

&НаСервере
Процедура ВидТранспортировкиПриИзмененииНаСервере()
	// Kuzmich, 17.05.2022. ПлательщикТранспортировкиТН по-умолчанию
	Если Константы.ПлательщикТранспортировкиТН_в_Организации.Получить() Тогда
		
		Если Объект.ТипТН = Перечисления.РС_ТипыТН.РеализацияСТранспортировкой ИЛИ Объект.ТипТН = Перечисления.РС_ТипыТН.ВозвратОтПокупателя Тогда
			Если Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Автомобильная
				ИЛИ Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Автомобильная_Заграничная
				ИЛИ	Объект.ВидТранспортировки = Перечисления.РС_ВидыТранспортировки.Перегрузчик_Автомобильная
				Тогда
				Если ЗначениеЗаполнено(Объект.Организация) Тогда
					Объект.ПлательщикТранспортировкиТН = Объект.Организация.ПлательщикТранспортировкиТН;
				Иначе
					Объект.ПлательщикТранспортировкиТН = Перечисления.ПлательщикТранспортировкиТН.ПустаяСсылка();
				КонецЕсли;
			Иначе
				Объект.ПлательщикТранспортировкиТН = Перечисления.ПлательщикТранспортировкиТН.ПустаяСсылка();
			КонецЕсли;
		КонецЕсли;	
		
	КонецЕсли;
	// Kuzmich, 17.05.2022. ПлательщикТранспортировкиТН по-умолчанию
КонецПроцедуры

