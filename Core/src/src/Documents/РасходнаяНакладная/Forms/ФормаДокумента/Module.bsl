&НаКлиенте
Процедура ЗаполнитьПоОстаткам(Команда)
	
	Если Объект.Запасы.Количество() > 0 Тогда 
		
		Режим = РежимДиалогаВопрос.ДаНет;
		Ответ = Вопрос(НСтр("ru = 'Табличная часть ""Запасы"" будет очищена. Продолжить?';"
		+ " ka = 'ცხრილური ნაწილი ""მარაგები"" გასუფთავდება ! გაგრძელდეს?'"), Режим, 0);
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыПодбора = Новый Структура;
	
	ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаВыбораПодразделения", ПараметрыПодбора,,,,, Новый ОписаниеОповещения("ЗаполненияПоОстатком_БезвозмезнаяПродажаЗавершение", ЭтотОбъект, Новый Структура("ПараметрыПодбора", ПараметрыПодбора)));
	
