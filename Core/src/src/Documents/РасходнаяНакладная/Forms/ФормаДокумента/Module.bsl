Функция СписокТранспортныхСредств()
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТранспортныеСредства.Ссылка
	               |ИЗ
	               |	Справочник.ТранспортныеСредства КАК ТранспортныеСредства
	               |ГДЕ
	               |	НЕ ТранспортныеСредства.Ссылка В(&Список)";
	
   Запрос.УстановитьПараметр("Список",ЭтотОбъект.Контрагент.ТранспортныеСредства.ВыгрузитьКолонку("ТранпсортноеСедство"));
   Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
    
