&НаСервере
Процедура ЗаполненияПоОстатком_БезвозмезнаяПродажаФрагмент(Подразделение)

	СтавкаНДС = НЕОПРЕДЕЛЕНО;
	Если НЕ Объект.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС") Тогда
		
		Если Объект.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС") Тогда
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
		Иначе
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
		КонецЕсли;	
																
	Иначе
		СтавкаНДС = Объект.Организация.СтавкаНДСПоУмолчанию;
	КонецЕсли;
	
	ЗначениеСтавкиНДС = СтавкаНДС.Ставка;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиСрезПоследних.Сотрудник КАК Сотрудник,
		|	СотрудникиСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	СотрудникиСрезПоследних.ЗанимаемыхСтавок КАК ЗанимаемыхСтавок,
		|	СотрудникиСрезПоследних.ВидУдержанияНДФЛ КАК ВидУдержанияНДФЛ,
		|	СотрудникиСрезПоследних.ВидУдержанияПФ КАК ВидУдержанияПФ,
		|	СотрудникиСрезПоследних.УчастникПенсионногоФонда КАК УдерживатьПенсию,
		|	1 КАК КоличествоСотрудников
		|ПОМЕСТИТЬ ВТ_Сотрудники
		|ИЗ
		|	РегистрСведений.Сотрудники.СрезПоследних(
		|			&НаДату,
		|			СтруктурнаяЕдиница В (&Подразделение)
		|				И Организация = &Организация) КАК СотрудникиСрезПоследних
		|ГДЕ
		|	СотрудникиСрезПоследних.ЗанимаемыхСтавок <> 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТ_Сотрудники.КоличествоСотрудников) КАК КоличествоСотрудников
		|ПОМЕСТИТЬ ВТ_КоличествоСотрудников
		|ИЗ
		|	ВТ_Сотрудники КАК ВТ_Сотрудники
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыНаСкладахОстатки.Номенклатура,
		|	ЗапасыНаСкладахОстатки.Характеристика,
		|	ЗапасыНаСкладахОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|	ВТ_КоличествоСотрудников.КоличествоСотрудников
		|ПОМЕСТИТЬ ВТ_Остатки
		|ИЗ
		|	РегистрНакопления.ЗапасыНаСкладах.Остатки(
		|			&НаДату,
		|			СтруктурнаяЕдиница = &Склад
		|				И Организация = &Организация) КАК ЗапасыНаСкладахОстатки,
		|	ВТ_КоличествоСотрудников КАК ВТ_КоличествоСотрудников
		|ГДЕ ЗапасыНаСкладахОстатки.КоличествоОстаток > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Характеристика,
		|	ЦеныНоменклатурыСрезПоследних.Цена
		|ПОМЕСТИТЬ ВТ_Цены
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			&НаДату,
		|			ВидЦен = &ВидЦен
		|				И (Номенклатура, Характеристика) В
		|					(ВЫБРАТЬ
		|						а.Номенклатура,
		|						а.Характеристика
		|					ИЗ
		|						ВТ_Остатки КАК а)) КАК ЦеныНоменклатурыСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Остатки.Номенклатура,
		|	ВТ_Остатки.Характеристика,
		|	ВТ_Остатки.КоличествоСотрудников,
		|	ВТ_Остатки.КоличествоОстаток,
		|	ВТ_Остатки.КоличествоОстаток / ВТ_Остатки.КоличествоСотрудников КАК Количество
		|ПОМЕСТИТЬ ВТ_КоличествоЗаполнения
		|ИЗ
		|	ВТ_Остатки КАК ВТ_Остатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КоличествоЗаполнения.Номенклатура,
		|	ВТ_КоличествоЗаполнения.Характеристика,
		|	ВТ_КоличествоЗаполнения.КоличествоСотрудников,
		|	ВТ_КоличествоЗаполнения.КоличествоОстаток,
		|	ВТ_КоличествоЗаполнения.Количество,
		|	ВТ_Сотрудники.Сотрудник,
		|	ВТ_Сотрудники.СтруктурнаяЕдиница,
		|	ВТ_Сотрудники.ВидУдержанияНДФЛ,
		|	ВТ_Сотрудники.ВидУдержанияПФ,
		|	ВТ_Сотрудники.УдерживатьПенсию
		|ПОМЕСТИТЬ ВТ_НомСотрудники
		|ИЗ
		|	ВТ_КоличествоЗаполнения КАК ВТ_КоличествоЗаполнения,
		|	ВТ_Сотрудники КАК ВТ_Сотрудники
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_НомСотрудники.Номенклатура,
		|	ВТ_НомСотрудники.Характеристика,
		|	ВТ_НомСотрудники.КоличествоСотрудников,
		|	ВТ_НомСотрудники.КоличествоОстаток,
		|	ВТ_НомСотрудники.Количество,
		|	ВТ_НомСотрудники.Сотрудник,
		|	ВТ_НомСотрудники.СтруктурнаяЕдиница,
		|	ВТ_НомСотрудники.ВидУдержанияНДФЛ,
		|	ВТ_НомСотрудники.ВидУдержанияПФ,
		|	ВТ_Цены.Цена,
		|	ВТ_НомСотрудники.УдерживатьПенсию
		|ПОМЕСТИТЬ ВТ_ПлюсЦена
		|ИЗ
		|	ВТ_НомСотрудники КАК ВТ_НомСотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Цены КАК ВТ_Цены
		|		ПО ВТ_НомСотрудники.Номенклатура = ВТ_Цены.Номенклатура
		|			И ВТ_НомСотрудники.Характеристика = ВТ_Цены.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПлюсЦена.Номенклатура,
		|	ВТ_ПлюсЦена.Характеристика,
		|	ВТ_ПлюсЦена.КоличествоСотрудников,
		|	ВТ_ПлюсЦена.КоличествоОстаток,
		|	ВТ_ПлюсЦена.Количество,
		|	ВТ_ПлюсЦена.Сотрудник,
		|	ВТ_ПлюсЦена.СтруктурнаяЕдиница,
		|	ВТ_ПлюсЦена.ВидУдержанияНДФЛ КАК ВидНалогаНДФЛ,
		|	ВТ_ПлюсЦена.ВидУдержанияПФ,
		|	ВТ_ПлюсЦена.Цена,
		|	ВЫБОР
		|		КОГДА &ЦенаВключаетНалоги = ЗНАЧЕНИЕ(Перечисление.ВидВлключениеНалоговВЦену.ЦенаВключаетНалоги)
		|			ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена - ВЫБОР
		|					КОГДА ВТ_ПлюсЦена.УдерживатьПенсию
		|						ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * 0.02
		|					ИНАЧЕ 0
		|				КОНЕЦ - (ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена - ВЫБОР
		|					КОГДА ВТ_ПлюсЦена.УдерживатьПенсию
		|						ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * 0.02
		|					ИНАЧЕ 0
		|				КОНЕЦ) * 0.2 - (ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена - ВЫБОР
		|					КОГДА ВТ_ПлюсЦена.УдерживатьПенсию
		|						ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * 0.02
		|					ИНАЧЕ 0
		|				КОНЕЦ - (ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена - ВЫБОР
		|					КОГДА ВТ_ПлюсЦена.УдерживатьПенсию
		|						ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * 0.02
		|					ИНАЧЕ 0
		|				КОНЕЦ) * 0.2) / (1 + &СтавкаНДСЗначение / 100)
		|		ИНАЧЕ ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * &СтавкаНДСЗначение / 100
		|	КОНЕЦ КАК СуммаНДС,
		|	ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена КАК Сумма,
		|	ВЫБОР
		|		КОГДА ВТ_ПлюсЦена.УдерживатьПенсию
		|			ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * 0.02
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК УдержаниеПенсии,
		|	(ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена - ВЫБОР
		|		КОГДА ВТ_ПлюсЦена.УдерживатьПенсию
		|			ТОГДА ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена * 0.02
		|		ИНАЧЕ 0
		|	КОНЕЦ) * 0.2 КАК СуммаНДФЛ,
		|	ВТ_ПлюсЦена.Количество * ВТ_ПлюсЦена.Цена КАК Всего,
		|	&СчетДоходоаБП,
		|	ВТ_ПлюсЦена.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	&СтавкаНДС КАК СтавкаНДС
		// Kuzmich, 22.11.2020, Реквизиты УдерживатьПенсию и СчетДоходовБП в табличной части Запасы для вида операции БезвозмезднаяПродажаСотруднику в документе РасходнаяНакладная
		|	,ВТ_ПлюсЦена.УдерживатьПенсию КАК УдерживатьПенсию
		|	,&СчетДоходовБП КАК СчетДоходовБП
		// Kuzmich, 22.11.2020, Реквизиты УдерживатьПенсию и СчетДоходовБП в табличной части Запасы для вида операции БезвозмезднаяПродажаСотруднику в документе РасходнаяНакладная
		|ИЗ
		|	ВТ_ПлюсЦена КАК ВТ_ПлюсЦена";
	
	Запрос.УстановитьПараметр("ВидЦен", Объект.ВидЦен);
	Запрос.УстановитьПараметр("НаДату", ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата-1, ТекущаяДата()));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("Склад", Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("СтавкаНДСЗначение", ЗначениеСтавкиНДС);
	Запрос.УстановитьПараметр("ЦенаВключаетНалоги", Объект.ЦенаВключаетНалоги);
	Запрос.УстановитьПараметр("СчетДоходоаБП", Объект.СчетДоходовБП);
	Запрос.УстановитьПараметр("СтавкаНДС", СтавкаНДС);
	// Kuzmich, 22.11.2020, Реквизиты УдерживатьПенсию и СчетДоходовБП в табличной части Запасы для вида операции БезвозмезднаяПродажаСотруднику в документе РасходнаяНакладная
	Запрос.УстановитьПараметр("СчетДоходовБП", Объект.СчетДоходовБП);
	// Kuzmich, 22.11.2020, Реквизиты УдерживатьПенсию и СчетДоходовБП в табличной части Запасы для вида операции БезвозмезднаяПродажаСотруднику в документе РасходнаяНакладная
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Объект.Запасы.Загрузить(РезультатЗапроса);	

КонецПроцедуры

&НаСервере
Функция ЗапасыНаправлениеДеятельностиПриИзмененииНаСервере(НаправлениеДеятельности)
	
	СчетУчетаВыручкиОтПродажРегл = НаправлениеДеятельности.СчетУчетаВыручкиОтПродажРегл;
	Если НЕ ЗначениеЗаполнено(СчетУчетаВыручкиОтПродажРегл) Тогда
		СчетУчетаВыручкиОтПродажРегл = Справочники.НаправленияДеятельности.ОсновноеНаправление.СчетУчетаВыручкиОтПродажРегл;
	КонецЕсли;
	
	Возврат СчетУчетаВыручкиОтПродажРегл;
	
КонецФункции

&НаКлиенте
Процедура ЗапасыНаправлениеДеятельностиПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.Запасы.ТекущиеДанные;
	
	ТекущаяСтрока.СчетУчетаВыручкиОтПродажРегл = ЗапасыНаправлениеДеятельностиПриИзмененииНаСервере(ТекущаяСтрока.НаправлениеДеятельности);
	
КонецПроцедуры

// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
&НаСервере
Функция ПолучитьЦенуПоСебестоимости(Идентификатор)
	
	ПЕРЕМ РЕЗ;
	
	СтрокаТабличнойЧасти = Объект.Запасы.НайтиПоИдентификатору(Идентификатор);

	РЕЗ = 0;
	
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Характеристика) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоОстаток,
		|	СУММА(ЗапасыОстатки.СуммаОстаток) КАК СуммаОстаток,
		|	ЗапасыОстатки.Номенклатура,
		|	ЗапасыОстатки.Характеристика
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(
		|			,
		|			Номенклатура = &Номенклатура
		|				И Характеристика = &Характеристика
		|				И СчетУчетаРегл = &СчетУчета) КАК ЗапасыОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстатки.Номенклатура,
		|	ЗапасыОстатки.Характеристика";
		
		Запрос.УстановитьПараметр("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
		Запрос.УстановитьПараметр("СчетУчета", СтрокаТабличнойЧасти.Номенклатура.СчетУчетаЗапасовРегл);
		Запрос.УстановитьПараметр("Характеристика", СтрокаТабличнойЧасти.Характеристика);
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоОстаток,
		|	СУММА(ЗапасыОстатки.СуммаОстаток) КАК СуммаОстаток,
		|	ЗапасыОстатки.Номенклатура
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(
		|			,
		|			Номенклатура = &Номенклатура
		|				И СчетУчетаРегл = &СчетУчета) КАК ЗапасыОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстатки.Номенклатура";
		
		Запрос.УстановитьПараметр("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
		Запрос.УстановитьПараметр("СчетУчета", СтрокаТабличнойЧасти.Номенклатура.СчетУчетаЗапасовРегл);
	КонецЕсли;
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		РЕЗ =  ВыборкаДетальныеЗаписи.СуммаОстаток/ВыборкаДетальныеЗаписи.КоличествоОстаток;
		
	КонецЦикла;
	
	Возврат РЕЗ;

КонецФункции // ()

&НаКлиенте
Процедура ЦенаПоСебестоимостиПриИзменении(Элемент)
	
	Если НЕ ((Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.БезвозмезднаяПродажаСотруднику")) ИЛИ Объект.ЦенаПоСебестоимости) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТабличнойЧасти Из Объект.Запасы Цикл
		
		СтрокаТабличнойЧасти.Цена = ПолучитьЦенуПоСебестоимости(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
		
		РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НалоговыйДокументНадписьОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ОчиститьСообщения();
	
	Если НЕ ПроверитьВозможностьСозданияЭЛНакладной() Тогда 
		Возврат;	
	КонецЕсли;
	
	
	ПараметрыФормы   = Новый Структура;
	массивДокументов = Новый Массив;
	массивДокументов.Добавить(Объект.Ссылка);
	ПараметрыФормы.Вставить("ДокументыОснования", массивДокументов);
	
	УправлениеНебольшойФирмойКлиент.ОткрытьНалоговыйДокумент(ЭтотОбъект,ПараметрыФормы);
	
	СтатистикаИспользованияФормКлиент.ПриИнтерактивномДействии(ЭтотОбъект, Элемент, "ОбработкаНавигационнойСсылки");
КонецПроцедуры

Процедура ЗаполнитьИтогКоличество()
	
	КолТоваров = 0;
	для Каждого стр из Объект.Запасы цикл
		КолТоваров = КолТоваров + стр.Количество;		
	КонецЦикла;
	Объект.КоличествоТоваров = КолТоваров;	
	
КонецПроцедуры


