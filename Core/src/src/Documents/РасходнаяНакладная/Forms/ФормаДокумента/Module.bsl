				Объект.ВидЦен = Объект.СтруктурнаяЕдиница.РозничныйВидЦен;
				
				СтруктураРеквизитовФормы = Новый Структура;
				
				СтруктураРеквизитовФормы.Вставить("БылиВнесеныИзменения", 			ИСТИНА);
				
