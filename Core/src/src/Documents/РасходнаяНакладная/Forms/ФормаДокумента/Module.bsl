&НаСервере
Процедура УстановитьВиимостИспользованияБалов()

	ВидноВидИспользования = ЛОЖЬ;
	
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) Тогда 
		Элементы.ВидИспользоыванияБалов.Видимость = Истина;
		ВидноВидИспользования = Истина;
	Иначе
		Элементы.ВидИспользоыванияБалов.Видимость = Ложь;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) 
		И Объект.ВидИспользоыванияБалов = Перечисления.ВидыИспользованияБалов.Накопление Тогда 
			
		Элементы.НакопленоБалов.Видимость = Истина;
		Элементы.ДоступноБалов.Видимость = ЛОЖЬ;
		Элементы.ЗапасыБалыРасход.Видимость = ЛОЖЬ;
		
	ИначеЕсли ЗначениеЗаполнено(Объект.КартаЛояльности) 
		И Объект.ВидИспользоыванияБалов = Перечисления.ВидыИспользованияБалов.Расход Тогда 
			
		Элементы.НакопленоБалов.Видимость = ЛОЖЬ;
		Элементы.ДоступноБалов.Видимость = Истина;
		Элементы.ЗапасыБалыРасход.Видимость = Истина;
		
	ИначеЕсли ЗначениеЗаполнено(Объект.КартаЛояльности) 
		И Объект.ВидИспользоыванияБалов = Перечисления.ВидыИспользованияБалов.НакоплениеИРасход Тогда 
			
		Элементы.НакопленоБалов.Видимость = Истина;
		Элементы.ДоступноБалов.Видимость = Истина;
		Элементы.ЗапасыБалыРасход.Видимость = Истина;
		
	Иначе
		Элементы.НакопленоБалов.Видимость = Ложь;
		Элементы.ДоступноБалов.Видимость = ЛОЖЬ;
		Элементы.ЗапасыБалыРасход.Видимость = ЛОЖЬ;
	КонецЕсли;

КонецПроцедуры

