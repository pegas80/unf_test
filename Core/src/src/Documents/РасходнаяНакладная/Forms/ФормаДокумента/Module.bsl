&НаСервере
Процедура ЗапасыСотрудникПриИзмененииНаСервере(УИД)
	
	СтрокаЗапасов = Объект.Запасы.НайтиПоИдентификатору(УИД);
	тзДанныеСотрудника = РегистрыСведений.Сотрудники.СрезПоследних(?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата()),Новый Структура("Организация, Сотрудник", Объект.Организация, СтрокаЗапасов.Сотрудник));
	
	Если тзДанныеСотрудника.Количество() <> 0 Тогда 
		СтрокаЗапасов.СтруктурнаяЕдиница = тзДанныеСотрудника[0].СтруктурнаяЕдиница;
		СтрокаЗапасов.УдерживатьПенсию = тзДанныеСотрудника[0].УчастникПенсионногоФонда;
		СтрокаЗапасов.ВидУдержанияПФ = тзДанныеСотрудника[0].ВидУдержанияПФ;
		СтрокаЗапасов.ВидНалогаНДФЛ = тзДанныеСотрудника[0].ВидУдержанияНДФЛ;
		//СтрокаЗапасов.ВидНачисленияУдержания  = ВидНалогаНДФЛ[0].ВидНачисленияУдержания;
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ЗапасыСотрудникПриИзменении(Элемент)  
	
	ТекСтрока = Элементы.Запасы.ТекущиеДанные;
	УИД = ТекСтрока.ПолучитьИдентификатор();
	ЗапасыСотрудникПриИзмененииНаСервере(УИД);
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	Если (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.БезвозмезднаяПродажаСотруднику")) И Объект.ЦенаПоСебестоимости Тогда
		ТекСтрока.Цена = ПолучитьЦенуПоСебестоимости(ТекСтрока.ПолучитьИдентификатор());
	КонецЕсли;
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	ОбновитьПодвалФормы();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСчетаУдержания(Команда)
	
	ДатаФильтра = ?(ЗначениеЗаполнено(Объект.Дата),Объект.Дата,ТекущаяДата());
	ПараметрыОтрытия = Новый Структура;
	СтруктураОтбора  = Новый Структура();
	//СтруктураЗаполнения  = Новый Структура();
	
	ПараметрыОтрытия.Вставить("Отборы", СтруктураОтбора);
	
	
	АдресСтруктурыВХранилище = ПоместитьСтруктуруВХранилище();
	ПараметрыОтрытия.Вставить("АдресСтруктурыВХранилище", АдресСтруктурыВХранилище);
	
	ОткрытьФорму("Документ.РасходнаяНакладная.Форма.ФормаЗаполненияСчетовУдержаний", ПараметрыОтрытия, ЭтаФорма,,,, Новый ОписаниеОповещения("РедактироватьСчетаУдержанияЗапасовБП", ЭтотОбъект, Новый Структура("АдресСтруктурыВХранилище", АдресСтруктурыВХранилище)));
	
КонецПроцедуры
//+++ Дмгг

Функция ПоместитьСтруктуруВХранилище()
	
	Если Объект.Запасы.Количество() > 0 Тогда 
		
		ПерваяСтрокаЗапасы = Объект.Запасы[0];
		ВидНачисленияУдержания = ВидНачисленияУдержания;
		ВидНалогаНДФЛ = ПерваяСтрокаЗапасы.ВидНалогаНДФЛ;
		СчетДоходовБП = СчетДоходовБП;
		ВидУдержанияПФ = ПерваяСтрокаЗапасы.ВидУдержанияПФ;
		
	КонецЕсли;
	
	
	Возврат ПоместитьВоВременноеХранилище(
		Новый Структура("ВидНачисленияУдержания, ВидНалогаНДФЛ, СчетДоходовБП, ТолькоНеЗаполеные, ВидУдержанияПФ", ВидНачисленияУдержания, ВидНалогаНДФЛ, СчетДоходовБП, ЛОЖЬ, ВидУдержанияПФ),
		УникальныйИдентификатор
	);
	
КонецФункции

&НаКлиенте
Процедура РедактироватьСчетаУдержанияЗапасовБП(Результат, ДополнительныеПараметры) Экспорт

	АдресСтруктурыВХранилище = ДополнительныеПараметры.АдресСтруктурыВХранилище;
    
    КодВозврата = Результат;
    
    РедактироватьСчетаУдержанияЗапасовБПФрагмент(АдресСтруктурыВХранилище, КодВозврата);

КонецПроцедуры

&НаКлиенте
Процедура РедактироватьСчетаУдержанияЗапасовБПФрагмент(Знач АдресСтруктурыВХранилище, Знач КодВозврата)
    
    Если (КодВозврата = КодВозвратаДиалога.OK) Тогда
        ПолучитьСтруктуруИзХранилищаДляБП(АдресСтруктурыВХранилище);
    КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПолучитьСтруктуруИзХранилищаДляБП(АдресСтруктурыВХранилище)
	
	СтруктураЗаполнения = ПолучитьИзВременногоХранилища(АдресСтруктурыВХранилище);
	
	ВидНачисленияУдержания = СтруктураЗаполнения.ВидНачисленияУдержания;
	ВидНалогаНДФЛ = СтруктураЗаполнения.ВидНалогаНДФЛ;
	СчетДоходовБП = СтруктураЗаполнения.СчетДоходовБП;
	ВидУдержанияПФ = СтруктураЗаполнения.ВидУдержанияПФ;
	
	Если СтруктураЗаполнения.ТолькоНеЗаполеные Тогда 
		
		Для Каждого Строк Из Объект.Запасы Цикл 
			
			Если НЕ ЗначениеЗаполнено(ВидНачисленияУдержания) Тогда 
				ВидНачисленияУдержания = СтруктураЗаполнения.ВидНачисленияУдержания;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Строк.ВидНалогаНДФЛ) Тогда 
				Строк.ВидНалогаНДФЛ = СтруктураЗаполнения.ВидНалогаНДФЛ;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(СчетДоходовБП) Тогда 
				СчетДоходовБП = СтруктураЗаполнения.СчетДоходовБП;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(Строк.ВидУдержанияПФ) Тогда 
				Строк.ВидУдержанияПФ = СтруктураЗаполнения.ВидУдержанияПФ;
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого Строк Из Объект.Запасы Цикл 
			ЗаполнитьЗначенияСвойств(Строк, СтруктураЗаполнения);
		КонецЦикла;
		
		СчетДоходовБП = СтруктураЗаполнения.СчетДоходовБП;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЦенаВключаетНалогиПриИзменении(Элемент)
	
	Для Каждого СтрокаТабличнойЧасти Из Объект.Запасы Цикл 
		
		Если Объект.ЦенаВключаетНалоги = ПредопределенноеЗначение("Перечисление.ВидВлключениеНалоговВЦену.ЦенаБезНалогов") Тогда 
			
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
			
			Если СтрокаТабличнойЧасти.Количество = 0 Тогда 
				Цена = 0;
			Иначе
				Цена = СтрокаТабличнойЧасти.Сумма / СтрокаТабличнойЧасти.Количество;
			КонецЕсли;
			
			УдержаниеПенсии = ?(СтрокаТабличнойЧасти.УдерживатьПенсию ,СтрокаТабличнойЧасти.Сумма * 0.02, 0);
			СуммаНДФЛ = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии) * 0.2;
			СуммаНДС = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии - СтрокаТабличнойЧасти.СуммаНДФЛ)-(СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии - СтрокаТабличнойЧасти.СуммаНДФЛ)/(1 + (СтавкаНДС/100));
			
			Всего = СтрокаТабличнойЧасти.Сумма;
			
			Если СтрокаТабличнойЧасти.Количество = 0 Тогда 
				Цена = 0;
			Иначе
				СтрокаТабличнойЧасти.Цена = (СтрокаТабличнойЧасти.Сумма - УдержаниеПенсии - СуммаНДФЛ - СуммаНДС) / СтрокаТабличнойЧасти.Количество;
			КонецЕсли;
			
			//Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
			СтрокаТабличнойЧасти.СуммаНДС = СуммаНДС;//Сумма * (СтавкаНДС/100);
			
			//СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
			СтрокаТабличнойЧасти.СуммаНДФЛ = СуммаНДФЛ;//(Сумма + СтрокаТабличнойЧасти.СуммаНДС) * 1.25 - (Сумма + СтрокаТабличнойЧасти.СуммаНДС);
			
			СтрокаТабличнойЧасти.УдержаниеПенсии = УдержаниеПенсии;//(Сумма + СтрокаТабличнойЧасти.СуммаНДС + СтрокаТабличнойЧасти.СуммаНДС)/0.98*0.02;//?(СтрокаТабличнойЧасти.УдерживатьПенсию ,СтрокаТабличнойЧасти.Сумма * 0.02, 0);
			//СтрокаТабличнойЧасти.СуммаНДФЛ = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии) * 0.2;
			//СтрокаТабличнойЧасти.СуммаНДС = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии - СтрокаТабличнойЧасти.СуммаНДФЛ)-(СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии - СтрокаТабличнойЧасти.СуммаНДФЛ)/(1 + (СтавкаНДС/100));
			//СтрокаТабличнойЧасти.Сумма = Сумма + СтрокаТабличнойЧасти.СуммаНДС + СтрокаТабличнойЧасти.СуммаНДС + СтрокаТабличнойЧасти.УдержаниеПенсии;
			СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма;// + СтрокаТабличнойЧасти.СуммаНДС + СтрокаТабличнойЧасти.СуммаНДС + СтрокаТабличнойЧасти.УдержаниеПенсии;
			
			//СтрокаТабличнойЧасти.Цена = 
			
		ИначеЕсли Объект.ЦенаВключаетНалоги = ПредопределенноеЗначение("Перечисление.ВидВлключениеНалоговВЦену.ЦенаВключаетНалоги") Тогда 
			
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
			
			Если СтрокаТабличнойЧасти.Количество = 0 Тогда 
				СтрокаТабличнойЧасти.Цена = 0;
			Иначе
				СтрокаТабличнойЧасти.Цена = СтрокаТабличнойЧасти.Сумма / СтрокаТабличнойЧасти.Количество;
			КонецЕсли;
			
			СтрокаТабличнойЧасти.УдержаниеПенсии = ?(СтрокаТабличнойЧасти.УдерживатьПенсию ,СтрокаТабличнойЧасти.Сумма * 0.02, 0);
			СтрокаТабличнойЧасти.СуммаНДФЛ = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии) * 0.2;
			СтрокаТабличнойЧасти.СуммаНДС = (СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии - СтрокаТабличнойЧасти.СуммаНДФЛ)-(СтрокаТабличнойЧасти.Сумма - СтрокаТабличнойЧасти.УдержаниеПенсии - СтрокаТабличнойЧасти.СуммаНДФЛ)/(1 + (СтавкаНДС/100));
			СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
			
		КонецЕсли;
		
	КонецЦикла;
	
