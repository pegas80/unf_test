	// Шапка
	ДоступнаОтправкаЕГАИС = ПолучитьФункциональнуюОпцию("ВестиСведенияДляДекларацийПоАлкогольнойПродукции")
		И (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю")
		ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику"));
		
	Элементы.ФормаПередатьДанныеВЕГАИС.Видимость = ДоступнаОтправкаЕГАИС;
	Элементы.ЗапасыСправкаБ.Видимость = ДоступнаОтправкаЕГАИС;
	
	Элементы.ФормаПередатьДанныеВЕГАИС.Доступность = Объект.Проведен И НЕ Объект.ПереданВЕГАИС;
	
	Элементы.ГруппаЕГАИС.Видимость = ДоступнаОтправкаЕГАИС;
	
