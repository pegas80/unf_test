&НаКлиенте
Процедура ЗапасыНоменклатураПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	Если ЗначениеЗаполнено(СтрокаТабличнойЧасти.Номенклатура) Тогда
		СтрокаТабличнойЧасти.Усушка_СписаниеНаПотери = СтрокаТабличнойЧасти_Номенклатура_Усушка_СписаниеНаПотери(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	КонецЕсли;
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	
	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
	СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
	СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	//Lazare_
	Если ПолучитьФункционалТипЦеныНоменклатурыПоКоличеству() Тогда 
		//СтрокаТабличнойЧасти.Количество = 1;
		ОптоваяЦена = ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка");
		ВидЦен = УправлениеНебольшойФирмойСервер.ПолучитьВидЦеныПоДиапазонуКоличестваНоменклатуры(СтруктураДанные,СтрокаТабличнойЧасти.Количество);		
		Объект.ОптоваяЦенаВДок = ВидЦен;
	КонецЕсли;
	
	//_Lazare
	Если ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		
		СтруктураДанные.Вставить("ДатаОбработки",	 Объект.Дата);
		СтруктураДанные.Вставить("ВалютаДокумента",  Объект.ВалютаДокумента);
		СтруктураДанные.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
		//Lazare_
		Если ВидЦен = Неопределено Тогда 
		СтруктураДанные.Вставить("ВидЦен", Объект.ВидЦен);
		Иначе 
		СтруктураДанные.Вставить("ВидЦен",ВидЦен);//Было
		КонецЕсли;
		//_Lazare
		СтруктураДанные.Вставить("Коэффициент", 1);
		СтруктураДанные.Вставить("ВидСкидкиНаценки", Объект.ВидСкидкиНаценки);
		
	КонецЕсли;
	
	// ДисконтныеКарты
	СтруктураДанные.Вставить("ДисконтнаяКарта", Объект.ДисконтнаяКарта);
	СтруктураДанные.Вставить("КартаЛояльности", Объект.КартаЛояльности); //+++ Дмгг
	СтруктураДанные.Вставить("ПроцентСкидкиПоДисконтнойКарте", Объект.ПроцентСкидкиПоДисконтнойКарте);
	//СтруктураДанные.Вставить("ПроцентСкидкиПоКартеЛояльности", Объект.ПроцентСкидкиПоКартеЛояльности); //+++ Дмгг
	// Конец ДисконтныеКарты
	
	СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
	СтрокаТабличнойЧасти.СтранаПроисхождения = СтруктураДанные.СтранаПроисхождения;
	СтрокаТабличнойЧасти.НомерГТД = Неопределено;
	//СтрокаТабличнойЧасти.Количество = 1;//Паганини
	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = СтруктураДанные.ПроцентСкидкиНаценки;
	//+++ Дмгг
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) Тогда 
		СтрокаТабличнойЧасти.ПроцентСкидкаЛояльности = ПолучитьПроцентСкидкиЛояльности(); //СтруктураДанные.ПроцентСкидкаЛояльности; //+++ Дмгг
	КонецЕсли;
	//--- Дмгг
	СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС;
	СтрокаТабличнойЧасти.Содержание = "";
	
	СтрокаТабличнойЧасти.ТипНоменклатурыЗапас = СтруктураДанные.ЭтоЗапас;
	СтрокаТабличнойЧасти.НеобходимостьВводаСправкиНаАлкоголь = СтруктураДанные.ЭтоАлкогольнаяПродукция;
	
	СтрокаТабличнойЧасти.ВесЕдиницыТовара = СтруктураДанные.ВесЕдиницыТовара;
	СтрокаТабличнойЧасти.Вес = СтруктураДанные.ВесЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	СтрокаТабличнойЧасти.ОбъемЕдиницыТовара = СтруктураДанные.ОбъемЕдиницыТовара;
	СтрокаТабличнойЧасти.Объем = СтруктураДанные.ОбъемЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	// Kuzmich, 21.05.2019, Счет выручки в табличной части
	СтрокаТабличнойЧасти.СчетУчетаВыручкиОтПродажРегл = СтруктураДанные.СчетУчетаВыручкиОтПродажРегл;
	// Kuzmich, 21.05.2019, Счет выручки в табличной части
	СтрокаТабличнойЧасти.НаправлениеДеятельности = СтруктураДанные.НаправлениеДеятельности; //+++ Дмгг
	//Серийные номера
	Для каждого ВыделеннаяСтрока Из Элементы.Запасы.ВыделенныеСтроки Цикл
		ТекущиеДанныеСтроки = Элементы.Запасы.ДанныеСтроки(ВыделеннаяСтрока);
		РаботаССерийнымиНомерамиКлиентСервер.УдалитьСерийныеНомераПоКлючуСвязи(Объект.СерийныеНомера, ТекущиеДанныеСтроки,,ИспользоватьСерийныеНомераОстатки);
	КонецЦикла;
	
	ОбновитьНаименованиеДляРС(СтрокаТабличнойЧасти);
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	Если (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.БезвозмезднаяПродажаСотруднику")) И Объект.ЦенаПоСебестоимости Тогда
		СтрокаТабличнойЧасти.Цена = ПолучитьЦенуПоСебестоимости(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	КонецЕсли;
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	//+++ Дмгг
	//РассчитатьСуммуВСтрокеТабличнойЧасти();
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) Тогда 
		Для Каждого Строк из Объект.Запасы Цикл 
			Строк.ПроцентСкидкаЛояльности = Объект.ПроцентСкидкиПоКартеЛояльности;
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строк);
		КонецЦикла;
	Иначе
		РассчитатьСуммуВСтрокеТабличнойЧасти();
	КонецЕсли;
	//--- Дмгг
	ОбновитьПодвалФормы();
	РассчитатьОбъемИВесВДокументе();
	
	СтрокаТабличнойЧасти.Себестоимость = ПолучитьСебестоимостьНоменклатуры(СтрокаТабличнойЧасти.Номенклатура , СтрокаТабличнойЧасти.Характеристика);
	//ЗаполнитьИтогКоличество(); //+++ Дмгг;
	
	СтрокаТабличнойЧасти.ЦенаЗакупки = ПолучитьЦенуЗакупки(СтрокаТабличнойЧасти.Номенклатура,СтрокаТабличнойЧасти.Характеристика);
	
	//Lazare_	
	Если ГруппыПользователя.Количество() Тогда 		
		
		ГруппаНоменклатуры = РС_ОбщегоНазначения.ПолучитьЗначениеРеквизита(Элементы.Запасы.ТекущиеДанные.Номенклатура, "Родитель");
		НайденнаяГруппа    = ГруппыПользователя.НайтиПоЗначению(ГруппаНоменклатуры) ;		
		
		Если НайденнаяГруппа = Неопределено Тогда  		
			СтрокаТабличнойЧасти.ТолькоПросмотр = Истина
		Иначе 
			СтрокаТабличнойЧасти.ТолькоПросмотр = Ложь		
		КонецЕсли;		
	КонецЕсли;  				
	//_Lazare

	 СтрокаТабличнойЧасти.КоличествоНаСкладе = УправлениеНебольшойФирмойСервер.ПолучитьКоличествоЗапасовНаСкладе(Объект.Дата,СтрокаТабличнойЧасти.Номенклатура,Объект.Организация,Объект.СтруктурнаяЕдиница);
	
КонецПроцедуры

//+++ Дмгг
&НаСервере
Функция ПолучитьПроцентНакопления()

	ВсегоПоДокументу = Объект.Запасы.Итог("Сумма");
	
	СуммаПорогаПоКарте = 0;
	ПроцентПорога = 0;
	
	СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[0].НижняяГраницаЛояльность;
	
	Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Цикл 
		
		Если ВсегоПоДокументу >= СуммаПорогаПоКарте Тогда 
			ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ].СкидкаЛояльность;
			Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Тогда 
				СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ+1].НижняяГраницаЛояльность;
			Иначе
				Прервать;
			КонецЕсли;
		Иначе
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПроцентПорога;

КонецФункции // ПолучитьПроцентНакопления()

&НаСервере
Функция ПолучитьПроцентСкидкиЛояльности()

	//ВсегоПоДокументу = Объект.Запасы.Итог("Всего");
	ВсегоПоДокументу = 0;
	тзЗапасы = Объект.Запасы.Выгрузить(,"Количество, Цена");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	тзЗапасы.Цена КАК Цена,
		|	тзЗапасы.Количество КАК Количество
		|ПОМЕСТИТЬ ВТ_Запасы
		|ИЗ
		|	&тзЗапасы КАК тзЗапасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ВТ_Запасы.Цена * ВТ_Запасы.Количество), 0) КАК СуммаБезСкидок
		|ИЗ
		|	ВТ_Запасы КАК ВТ_Запасы";
	
	Запрос.УстановитьПараметр("тзЗапасы", тзЗапасы);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВсегоПоДокументу = ВыборкаДетальныеЗаписи.СуммаБезСкидок;
	КонецЦикла;
	
	СуммаПорогаПоКарте = 0;
	ПроцентПорога = 0;
	
	СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[0].НижняяГраница;
	
	Для Сч = 0 По Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Цикл 
		
		Если ВсегоПоДокументу >= СуммаПорогаПоКарте Тогда 
			ПроцентПорога = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ].Скидка;
			Если Сч <> Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок.Количество() - 1 Тогда 
				СуммаПорогаПоКарте = Объект.КартаЛояльности.Владелец.ПорогиНакопительныхСкидок[СЧ+1].НижняяГраница;
			Иначе
				Прервать;
			КонецЕсли;
		Иначе
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПроцентПорога;

КонецФункции

&НаСервере
Функция ПолучитьСебестоимостьНоменклатуры(Номенклатура , Характеристика)
	
	
	Если Константы.ПоказатСебестоимостиВТаблице.Получить() = Истина Тогда
		Если ЗначениеЗаполнено(Характеристика) Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоОстаток,
				|	СУММА(ЗапасыОстатки.СуммаОстаток) КАК СуммаОстаток,
				|	ЗапасыОстатки.Номенклатура,
				|	ЗапасыОстатки.Характеристика
				|ИЗ
				|	РегистрНакопления.Запасы.Остатки(
				|			,
				|			Номенклатура = &Номенклатура
				|				И Характеристика = &Характеристика
				|				И СчетУчетаРегл = &СчетУчета) КАК ЗапасыОстатки
				|
				|СГРУППИРОВАТЬ ПО
				|	ЗапасыОстатки.Номенклатура,
				|	ЗапасыОстатки.Характеристика";
			
			Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
			Запрос.УстановитьПараметр("СчетУчета", Номенклатура.СчетУчетаЗапасовРегл);
			Запрос.УстановитьПараметр("Характеристика", Характеристика);
		Иначе
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	СУММА(ЗапасыОстатки.КоличествоОстаток) КАК КоличествоОстаток,
				|	СУММА(ЗапасыОстатки.СуммаОстаток) КАК СуммаОстаток,
				|	ЗапасыОстатки.Номенклатура
				|ИЗ
				|	РегистрНакопления.Запасы.Остатки(
				|			,
				|			Номенклатура = &Номенклатура
				|				И СчетУчетаРегл = &СчетУчета) КАК ЗапасыОстатки
				|
				|СГРУППИРОВАТЬ ПО
				|	ЗапасыОстатки.Номенклатура";
			
			Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
			Запрос.УстановитьПараметр("СчетУчета", Номенклатура.СчетУчетаЗапасовРегл);
		КонецЕсли;
			
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл

		 Себетоимость =  ВыборкаДетальныеЗаписи.СуммаОстаток/ ВыборкаДетальныеЗаписи.КоличествоОстаток;
		
	КонецЦикла;
	
	Возврат Себетоимость;

	КонецЕсли;

	
КонецФункции

&НаКлиенте
Процедура ЗапасыХарактеристикаПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	СтруктураДанные = Новый Структура;
	СтруктураДанные.Вставить("Номенклатура",	 СтрокаТабличнойЧасти.Номенклатура);
	СтруктураДанные.Вставить("Характеристика",	 СтрокаТабличнойЧасти.Характеристика);
	//Lazare_
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	Если ПолучитьФункционалТипЦеныНоменклатурыПоКоличеству() Тогда 
		СтрокаТабличнойЧасти.Количество = 1;
		ОптоваяЦена = ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка");
		ВидЦен = УправлениеНебольшойФирмойСервер.ПолучитьВидЦеныПоДиапазонуКоличестваНоменклатуры(СтруктураДанные,СтрокаТабличнойЧасти.Количество);
		Объект.ОптоваяЦенаВДок = ВидЦен;
	КонецЕсли;
	//_Lazare
	
	Если ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		
		СтруктураДанные.Вставить("ДатаОбработки",	 	Объект.Дата);
		СтруктураДанные.Вставить("ВалютаДокумента",	 	Объект.ВалютаДокумента);
		СтруктураДанные.Вставить("СуммаВключаетНДС", 	Объект.СуммаВключаетНДС);
		
		СтруктураДанные.Вставить("СтавкаНДС", 			СтрокаТабличнойЧасти.СтавкаНДС);
		СтруктураДанные.Вставить("Цена",			 	СтрокаТабличнойЧасти.Цена);
		//Lazare_
		Если ВидЦен = Неопределено Тогда 
		СтруктураДанные.Вставить("ВидЦен", Объект.ВидЦен);//Было
		Иначе 
			СтруктураДанные.Вставить("ВидЦен", ВидЦен);
		КонецЕсли;
		//_Lazare
		СтруктураДанные.Вставить("ЕдиницаИзмерения", СтрокаТабличнойЧасти.ЕдиницаИзмерения);
		
	КонецЕсли;
	
	СтруктураДанные = ПолучитьДанныеХарактеристикаПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	СтрокаТабличнойЧасти.Содержание = "";
	
	ОбновитьНаименованиеДляРС(СтрокаТабличнойЧасти);
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	Если (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.БезвозмезднаяПродажаСотруднику")) И Объект.ЦенаПоСебестоимости Тогда
		СтрокаТабличнойЧасти.Цена = ПолучитьЦенуПоСебестоимости(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	КонецЕсли;
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	ОбновитьПодвалФормы();
	
	СтрокаТабличнойЧасти.Себестоимость = ПолучитьСебестоимостьНоменклатуры(СтрокаТабличнойЧасти.Номенклатура , СтрокаТабличнойЧасти.Характеристика);

	
КонецПроцедуры


&НаКлиенте
Процедура ЗапасыСодержаниеАвтоПодбор(Элемент, Текст, ДанныеВыбора, Параметры, Ожидание, СтандартнаяОбработка)
	
	Если Ожидание = 0 Тогда
		
		СтандартнаяОбработка = Ложь;
		
		СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
		ШаблонСодержания = УправлениеНебольшойФирмойСервер.ПолучитьТекстСодержания(СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.Характеристика);
		
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ШаблонСодержания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапасыКоличествоПриИзменении(Элемент)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	СтрокаТабличнойЧасти.Вес = СтрокаТабличнойЧасти.ВесЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	СтрокаТабличнойЧасти.Объем = СтрокаТабличнойЧасти.ОбъемЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	Если (Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.БезвозмезднаяПродажаСотруднику")) И Объект.ЦенаПоСебестоимости Тогда
		СтрокаТабличнойЧасти.Цена = ПолучитьЦенуПоСебестоимости(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	КонецЕсли;
	// Kuzmich, 16.02.2020, Цена по себестоимости при безвозмездной продаже сотруднику
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	
	//Lazare_
	Если ПолучитьФункционалТипЦеныНоменклатурыПоКоличеству() Тогда 		
		СтруктураДанные = Новый Структура ;
		СтруктураДанные.Вставить("Организация", Объект.Организация);
		СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
		СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
		ОптоваяЦена = ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка");
		ВидЦен = УправлениеНебольшойФирмойСервер.ПолучитьВидЦеныПоДиапазонуКоличестваНоменклатуры(СтруктураДанные,СтрокаТабличнойЧасти.Количество);
		Если ВидЦен = ПредопределенноеЗначение("Справочник.ВидыЦен.Оптовая")  Тогда 		
			ОптоваяЦена = ВидЦен;
		КонецЕсли;
		Если ВидЦен <>  ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка")или ВидЦен <> Неопределено Тогда 
			СтруктураДанные.Вставить("ДатаОбработки", Объект.Дата);
			СтруктураДанные.Вставить("ВалютаДокумента", Объект.ВалютаДокумента);
			СтруктураДанные.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
			Если ВидЦен = Неопределено Тогда 
			СтруктураДанные.Вставить("ВидЦен",Объект.ВидЦен);	
			Иначе 	
			СтруктураДанные.Вставить("ВидЦен", ВидЦен);
			КонецЕсли;
			СтруктураДанные.Вставить("Коэффициент", 1);
			СтруктураДанные.Вставить("ВидСкидкиНаценки", Объект.ВидСкидкиНаценки);
			СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
			СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
			РассчитатьСуммуВСтрокеТабличнойЧасти();
			Объект.ОптоваяЦенаВДок = ВидЦен;
		КонецЕсли;			
	КонецЕсли;
	//Lazare_
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	Если СтрокаТабличнойЧасти.Усушка_КоличествоСобрПотери<>0 И Усушка_ТекущееКоличество<>0 Тогда
		СтрокаТабличнойЧасти.Усушка_КоличествоСобрПотери = СтрокаТабличнойЧасти.Усушка_КоличествоСобрПотери * СтрокаТабличнойЧасти.Количество / Усушка_ТекущееКоличество;
		СтрокаТабличнойЧасти.Усушкa_КоличествоСтарое = СтрокаТабличнойЧасти.Усушкa_КоличествоСтарое * СтрокаТабличнойЧасти.Количество / Усушка_ТекущееКоличество;
	КонецЕсли;
	// Kuzmich, 24.09.2021, Потери при сушке, GermanButcher 2010
	
	//+++ Дмгг
	Если ЗначениеЗаполнено(объект.КартаЛояльности) Тогда 
		Объект.ПроцентСкидкиПоКартеЛояльности = ПолучитьПроцентСкидкиЛояльности(); 
		Объект.ПроцентНакопленияБалов = ПолучитьПроцентНакопления();
		Для Каждого Строк из Объект.Запасы Цикл 
			Строк.ПроцентСкидкаЛояльности = Объект.ПроцентСкидкиПоКартеЛояльности;
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строк);
		КонецЦикла;
	КонецЕсли;
	//--- Дмгг
	ОбновитьПодвалФормы();
	РассчитатьОбъемИВесВДокументе();
	//ЗаполнитьИтогКоличество(); //+++ Дмгг;
	
	
КонецПроцедуры // ЗапасыКоличествоПриИзменении()

&НаКлиенте
Процедура ЗапасыЕдиницаИзмеренияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтрокаТабличнойЧасти = Элементы.Запасы.ТекущиеДанные;
	
	Если СтрокаТабличнойЧасти.ЕдиницаИзмерения = ВыбранноеЗначение Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаТабличнойЧасти.Цена = 0
		И СтрокаТабличнойЧасти.Вес = 0
		И СтрокаТабличнойЧасти.Объем = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийКоэффициент = 0;
	Если ТипЗнч(СтрокаТабличнойЧасти.ЕдиницаИзмерения) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда
		ТекущийКоэффициент = 1;
	КонецЕсли;
	
	Коэффициент = 0;
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.КлассификаторЕдиницИзмерения") Тогда
		Коэффициент = 1;
	КонецЕсли;
	
	Если ТекущийКоэффициент = 0 И Коэффициент = 0 Тогда
		СтруктураДанные = ПолучитьДанныеЕдиницаИзмеренияПриИзменении(СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.ЕдиницаИзмерения, ВыбранноеЗначение);
	ИначеЕсли ТекущийКоэффициент = 0 Тогда
		СтруктураДанные = ПолучитьДанныеЕдиницаИзмеренияПриИзменении(СтрокаТабличнойЧасти.Номенклатура, СтрокаТабличнойЧасти.ЕдиницаИзмерения);
	ИначеЕсли Коэффициент = 0 Тогда
		СтруктураДанные = ПолучитьДанныеЕдиницаИзмеренияПриИзменении(СтрокаТабличнойЧасти.Номенклатура, Неопределено, ВыбранноеЗначение);
	ИначеЕсли ТекущийКоэффициент = 1 И Коэффициент = 1 Тогда
		СтруктураДанные = Новый Структура("ТекущийКоэффициент, Коэффициент", 1, 1);
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(
		СтруктураДанные,
		ВесИОбъемЕдиницТоваров(СтрокаТабличнойЧасти.Номенклатура, ВыбранноеЗначение, Коэффициент));
	КонецЕсли;
	
	Если СтруктураДанные.ТекущийКоэффициент <> 0 Тогда
		СтрокаТабличнойЧасти.Цена = СтрокаТабличнойЧасти.Цена * СтруктураДанные.Коэффициент / СтруктураДанные.ТекущийКоэффициент;
		СтрокаТабличнойЧасти.ВесЕдиницыТовара = СтруктураДанные.ВесЕдиницыТовара;
		СтрокаТабличнойЧасти.Вес = СтрокаТабличнойЧасти.ВесЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
		СтрокаТабличнойЧасти.ОбъемЕдиницыТовара = СтруктураДанные.ОбъемЕдиницыТовара;
		СтрокаТабличнойЧасти.Объем = СтрокаТабличнойЧасти.ОбъемЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	КонецЕсли;
	
	РассчитатьСуммуВСтрокеТабличнойЧасти();
	ОбновитьПодвалФормы();
	РассчитатьОбъемИВесВДокументе();
	
КонецПроцедуры // ЗапасыЕдиницаИзмеренияОбработкаВыбора()

