				СтруктураРеквизитовФормы.Вставить("КратностьРасчетов", 				Объект.Кратность);
				
				СтруктураРеквизитовФормы.Вставить("ПредВалютаДокумента", 			Объект.ВалютаДокумента);
				СтруктураРеквизитовФормы.Вставить("ПредНалогообложениеНДС", 		Объект.НалогообложениеНДС);
				СтруктураРеквизитовФормы.Вставить("ПредСуммаВключаетНДС", 			Объект.СуммаВключаетНДС);
				
				СтруктураРеквизитовФормы.Вставить("ПерезаполнитьЦены", 				ИСТИНА);
				СтруктураРеквизитовФормы.Вставить("ПересчитатьЦены", 				ИСТИНА);
				
				СтруктураРеквизитовФормы.Вставить("ПерезаполнитьСкидки",			ИСТИНА);
				СтруктураРеквизитовФормы.Вставить("ДисконтнаяКарта",  				Объект.ДисконтнаяКарта);
				СтруктураРеквизитовФормы.Вставить("ПроцентСкидкиПоДисконтнойКарте",	Объект.ПроцентСкидкиПоДисконтнойКарте);
				СтруктураРеквизитовФормы.Вставить("Контрагент",						Объект.Контрагент);
				
				РЕЗ = СтруктураРеквизитовФормы;
				
			КонецЕсли;
