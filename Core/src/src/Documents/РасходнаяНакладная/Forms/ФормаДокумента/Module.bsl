&НаСервере
Процедура ПересчитатьКурсКратностьПриКопированииДокумента() //+++ Дмгг
	
	СтруктураКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекущаяДата(), Новый Структура("Валюта", Объект.ВалютаДокумента));
	КратностьНовый = СтруктураКурсКратность.Кратность;
	КурсНовый = СтруктураКурсКратность.Курс;
	
	Объект.Курс = КурсНовый;
	Объект.Кратность = КратностьНовый;
	
	Для каждого СтрокаТабличнойЧасти Из Объект.Предоплата Цикл
		
		КурсКон = ?(Объект.ВалютаДокумента = НациональнаяВалюта, КурсНациональнаяВалюта, Объект.Курс);
		КратностьКон = ?(Объект.ВалютаДокумента = НациональнаяВалюта, КратностьНациональнаяВалюта, Объект.Кратность);
		
		Если (СтрокаТабличнойЧасти.Курс = КурсКон) И (СтрокаТабличнойЧасти.Кратность = КратностьКон) Тогда
			СтрокаТабличнойЧасти.СуммаПлатежа = СтрокаТабличнойЧасти.СуммаРасчетов;
			Продолжить;
		КонецЕсли;
		
		Если СтрокаТабличнойЧасти.Курс = 0 ИЛИ КурсКон = 0 ИЛИ СтрокаТабличнойЧасти.Кратность = 0 ИЛИ КратностьКон = 0 Тогда
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = НСтр("ka='აღმოჩენილია ვალუტის ნულოვანი კურსი. გადათვლა არ შესრულდა.';ru='Обнаружен нулевой курс валюты. Пересчет не выполнен.';en='Discovered a zero rate. Adjustment is not performed.'");
			Сообщение.Сообщить();
			СтрокаТабличнойЧасти.СуммаПлатежа = СтрокаТабличнойЧасти.СуммаРасчетов;
			Продолжить;
		КонецЕсли;
		
		СтрокаТабличнойЧасти.СуммаПлатежа = Окр((СтрокаТабличнойЧасти.СуммаРасчетов * СтрокаТабличнойЧасти.Курс * КратностьКон) / (КурсКон * СтрокаТабличнойЧасти.Кратность), 2);
	КонецЦикла;
	
КонецПроцедуры
