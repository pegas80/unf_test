&НаСервере
Процедура СформироватьПроверкаВидимостьДоступностьСервер()
	
	Если КОнстанты.ЗапретРедактированияДокументовОператоров.Получить() = Истина 
		И Не РольДоступна("АдминистраторСистемы") И ПараметрыСеанса.ТекущийПользователь <> Объект.Автор Тогда
		
		ЭтаФорма.ТолькоПросмотр = Истина;
		
	КонецЕсли;

	
	//Т 
	Если Константы.ПоказатСебестоимостиВТаблице.Получить() = Истина Тогда
		ЭтаФорма.Элементы.ЗапасыСебестоимость.Видимость = Истина;
	КонецЕсли;


	Если Не РольДоступна("АдминистраторСистемы") = Истина И Константы.ФункциональДляУдаленияСвязанныхОбъектов.Получить() = Истина Тогда
		ЭтаФорма.Элементы.ДокументОснование.ТолькоПросмотр = Истина;
		ЭтаФорма.Элементы.Заказ.ТолькоПросмотр = Истина;
	КонецЕсли;

КонецПроцедуры

