&НаСервере
Функция ПолучитьЦенуЗакупки(Номенклатура,Характеристика)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Закупки.Период КАК Период,
	               |	Закупки.Количество,
	               |	Закупки.Сумма
	               |ИЗ
	               |	РегистрНакопления.Закупки КАК Закупки
	               |ГДЕ
	               |	Закупки.Организация = &Организация
	               |	И Закупки.Номенклатура = &Номенклатура
	               |	И Закупки.Характеристика = &Характеристика
	               |	И Закупки.Количество <> 0
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Период УБЫВ";
	
	Запрос.УстановитьПараметр("Организация",Объект.Организация);
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",Характеристика);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Сумма/Выборка.Количество;
	Иначе
		Возврат 0;
	КонецЕсли;	
	
КонецФункции	

