&НаСервере
Функция РазобратьШтрихкод(Штрихкод, ВариантРаспознаванияШтрихкода)

	СтруктураРезультата = Неопределено;
	Вес = 0;
	Цена = 0;
	
	Если ВариантРаспознаванияШтрихкода = Перечисления.ВариантыРаспознованияШтрихкодов.Вес Тогда
		
		СтрокаЦелое = Сред(Штрихкод, 9, 1);
		СтрокаДробное = Сред(Штрихкод, 10, 3);
		
		Попытка
			
			Вес = Число(СтрокаЦелое + "." + СтрокаДробное);
			
		Исключение
			
			Вес = 0;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
			
		КонецПопытки; 
		
		ШтрихкодДляПоиска = Сред(ШтрихКод,4,5);//Паганини Сред(ШтрихКод,4,4)

	ИначеЕсли ВариантРаспознаванияШтрихкода = Перечисления.ВариантыРаспознованияШтрихкодов.Цена Тогда
		
		СтрокаЦелое = Сред(Штрихкод, 8, 3);
		СтрокаДробное = Сред(Штрихкод, 11, 2);
		
		Попытка
			
			Цена = Число(СтрокаЦелое + "." + СтрокаДробное);
			Вес = 1;
			
		Исключение
			
			Цена = 0;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
			
		КонецПопытки; 
		
		ШтрихкодДляПоиска = Сред(ШтрихКод,4,4);//Сред(Штрихкод,1,7) + "00000" + Сред(ШтрихКод,13,1);
		
	КонецЕсли; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика,
	|	ШтрихкодыНоменклатуры.ЕдиницаИзмерения,
	|	ЕСТЬNULL(ШтрихкодыНоменклатуры.Номенклатура.ЕдиницаИзмерения.Весовая,ЛОЖЬ) КАК Весовая
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", ШтрихкодДляПоиска);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		СтруктураРезультата = Новый Структура;
		СтруктураРезультата.Вставить("Номенклатура", ВыборкаДетальныеЗаписи.Номенклатура);
		СтруктураРезультата.Вставить("Характеристика", ВыборкаДетальныеЗаписи.Характеристика);
		СтруктураРезультата.Вставить("ЕдиницаИзмерения", ВыборкаДетальныеЗаписи.ЕдиницаИзмерения);
		СтруктураРезультата.Вставить("Весовая", ВыборкаДетальныеЗаписи.Весовая);
		СтруктураРезультата.Вставить("Вес", Вес);
		СтруктураРезультата.Вставить("Цена", Цена);
		
	Иначе
		
		Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			
			СтруктураРезультата = Новый Структура;
			СтруктураРезультата.Вставить("Номенклатура", ВыборкаДетальныеЗаписи.Номенклатура);
			СтруктураРезультата.Вставить("Характеристика", ВыборкаДетальныеЗаписи.Характеристика);
			СтруктураРезультата.Вставить("ЕдиницаИзмерения", ВыборкаДетальныеЗаписи.ЕдиницаИзмерения);
			СтруктураРезультата.Вставить("Весовая", Ложь);
			СтруктураРезультата.Вставить("Вес", 1);
			//СтруктураРезультата.Вставить("Цена", Цена);
			
		КонецЕсли;		
		
	КонецЕсли;
	
	Возврат СтруктураРезультата;
	
КонецФункции

&НаКлиенте
Процедура ДобавитьШтрихкодВТабличнуюЧасть(Штрихкод, ВариантРаспознаванияШтрихкода) Экспорт

	СтруктураРезультата = РазобратьШтрихкод(Штрихкод, ВариантРаспознаванияШтрихкода);
	Если СтруктураРезультата = Неопределено Тогда
		
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka='Товар со штрихкодом %1 не найден!';ru='Товар со штрихкодом %1 не найден!';en='Product barcode% 1 can not be found!'"), Штрихкод);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
		
	КонецЕсли; 
	
	Если ВариантРаспознаванияШтрихкода = ПредопределенноеЗначение("Перечисление.ВариантыРаспознованияШтрихкодов.Вес") Тогда
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура", СтруктураРезультата.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", СтруктураРезультата.Характеристика);
		//СтруктураПоиска.Вставить("ЕдиницаИзмерения", СтруктураРезультата.ЕдиницаИзмерения);
		
		Строки = Объект.Запасы.НайтиСтроки(СтруктураПоиска);
		Если Строки.Количество() > 0 Тогда
			
			Строки[0].Количество = Строки[0].Количество + СтруктураРезультата.Вес;
			РассчитатьСуммуВСтрокеТабличнойЧасти(Строки[0]);
			
		Иначе
			
			НоваяСтрока = Объект.Запасы.Добавить();
			НоваяСтрока.Номенклатура = СтруктураРезультата.Номенклатура;
			НоваяСтрока.Характеристика = СтруктураРезультата.Характеристика;
			//НоваяСтрока.ЕдиницаИзмерения = СтруктураРезультата.ЕдиницаИзмерения;
			НоменклатураПриИзменении(НоваяСтрока);
			НоваяСтрока.Количество = СтруктураРезультата.Вес;
			РассчитатьСуммуВСтрокеТабличнойЧасти(НоваяСтрока);
			
		КонецЕсли; 
		
	ИначеЕсли ВариантРаспознаванияШтрихкода = ПредопределенноеЗначение("Перечисление.ВариантыРаспознованияШтрихкодов.Цена") Тогда
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура", СтруктураРезультата.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", СтруктураРезультата.Характеристика);
		//СтруктураПоиска.Вставить("ЕдиницаИзмерения", СтруктураРезультата.ЕдиницаИзмерения);
		
		Если СтруктураРезультата.Весовая Тогда
			
			НоваяСтрока = Объект.Запасы.Добавить();
			НоваяСтрока.Номенклатура = СтруктураРезультата.Номенклатура;
			НоваяСтрока.Характеристика = СтруктураРезультата.Характеристика;
			//НоваяСтрока.ЕдиницаИзмерения = СтруктураРезультата.ЕдиницаИзмерения;
			НоменклатураПриИзменении(НоваяСтрока);
			
			РассчитатьСуммуВСтрокеТабличнойЧасти(НоваяСтрока);
			НоваяСтрока.Сумма = СтруктураРезультата.Цена;
			НоваяСтрока.СуммаНДС = СтруктураРезультата.Цена * 0.18;
			НоваяСтрока.Количество = ?(НоваяСтрока.Цена = 0, 0, СтруктураРезультата.Цена / НоваяСтрока.Цена);
			НоваяСтрока.Всего = НоваяСтрока.Сумма;
			
		Иначе
			
			Строки = Объект.Запасы.НайтиСтроки(СтруктураПоиска);
			Если Строки.Количество() > 0 Тогда
				
				Строки[0].Количество = Строки[0].Количество + СтруктураРезультата.Вес;

				Строки[0].Цена = СтруктураРезультата.Цена;
				РассчитатьСуммуВСтрокеТабличнойЧасти(Строки[0]);
				
			Иначе
				
				НоваяСтрока = Объект.Запасы.Добавить();
				НоваяСтрока.Номенклатура = СтруктураРезультата.Номенклатура;
				НоваяСтрока.Характеристика = СтруктураРезультата.Характеристика;
				//НоваяСтрока.ЕдиницаИзмерения = СтруктураРезультата.ЕдиницаИзмерения;
				НоменклатураПриИзменении(НоваяСтрока);
				НоваяСтрока.Цена = СтруктураРезультата.Цена;
				РассчитатьСуммуВСтрокеТабличнойЧасти(НоваяСтрока);
				
			КонецЕсли; 
			
		КонецЕсли; 
		
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура НоменклатураПриИзменении(СтрокаТабличнойЧасти)

	СтруктураДанные = Новый Структура();
	СтруктураДанные.Вставить("Организация", Объект.Организация);
	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
	СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
	СтруктураДанные.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	
	Если ЗначениеЗаполнено(Объект.ВидЦен) Тогда
		
		СтруктураДанные.Вставить("ДатаОбработки",	 Объект.Дата);
		СтруктураДанные.Вставить("ВалютаДокумента",  Объект.ВалютаДокумента);
		СтруктураДанные.Вставить("СуммаВключаетНДС", Объект.СуммаВключаетНДС);
		СтруктураДанные.Вставить("ВидЦен", Объект.ВидЦен);
		СтруктураДанные.Вставить("Коэффициент", 1);
		СтруктураДанные.Вставить("ВидСкидкиНаценки", Объект.ВидСкидкиНаценки);
		
	КонецЕсли;
	
	// ДисконтныеКарты
	СтруктураДанные.Вставить("ДисконтнаяКарта", Объект.ДисконтнаяКарта);
	СтруктураДанные.Вставить("ПроцентСкидкиПоДисконтнойКарте", Объект.ПроцентСкидкиПоДисконтнойКарте);
	// Конец ДисконтныеКарты
	
	СтруктураДанные = ПолучитьДанныеНоменклатураПриИзменении(СтруктураДанные);
	
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтруктураДанные.ЕдиницаИзмерения;
	СтрокаТабличнойЧасти.СтранаПроисхождения = СтруктураДанные.СтранаПроисхождения;
	СтрокаТабличнойЧасти.НомерГТД = Неопределено;
	СтрокаТабличнойЧасти.Количество = 1;
	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
	СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = СтруктураДанные.ПроцентСкидкиНаценки;
	СтрокаТабличнойЧасти.СтавкаНДС = СтруктураДанные.СтавкаНДС;
	СтрокаТабличнойЧасти.Содержание = "";
	
	СтрокаТабличнойЧасти.ТипНоменклатурыЗапас = СтруктураДанные.ЭтоЗапас;
	СтрокаТабличнойЧасти.НеобходимостьВводаСправкиНаАлкоголь = СтруктураДанные.ЭтоАлкогольнаяПродукция;
	
	СтрокаТабличнойЧасти.ВесЕдиницыТовара = СтруктураДанные.ВесЕдиницыТовара;
	СтрокаТабличнойЧасти.Вес = СтруктураДанные.ВесЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	СтрокаТабличнойЧасти.ОбъемЕдиницыТовара = СтруктураДанные.ОбъемЕдиницыТовара;
	СтрокаТабличнойЧасти.Объем = СтруктураДанные.ОбъемЕдиницыТовара * СтрокаТабличнойЧасти.Количество;
	
	//Серийные номера
	Для каждого ВыделеннаяСтрока Из Элементы.Запасы.ВыделенныеСтроки Цикл
		ТекущиеДанныеСтроки = Элементы.Запасы.ДанныеСтроки(ВыделеннаяСтрока);
		РаботаССерийнымиНомерамиКлиентСервер.УдалитьСерийныеНомераПоКлючуСвязи(Объект.СерийныеНомера, ТекущиеДанныеСтроки,,ИспользоватьСерийныеНомераОстатки);
	КонецЦикла;
	
	//РассчитатьСуммуВСтрокеТабличнойЧасти();
	ОбновитьПодвалФормы();
	РассчитатьОбъемИВесВДокументе();

КонецПроцедуры // ()
 

#КонецОбласти 


//Паганини
&НаКлиенте
Процедура ЗаполнитьФактуры(Команда)
	Если Объект.ФактурыАвансов.Количество() > 0 Тогда
		Ответ = Вопрос(НСТР("ka='გაგზავნილი ავანსების ა/ფ-ის ცხრილი არ არის ცარიელი. გასუფთავდეს და გაგრძელდეს?';ru='Таблица СФ Отправленных авансов не пустая. Очистить и продолжить?';en='Table SF Sent advances is not empty. Clear and continue?'"), РежимДиалогаВопрос.ОКОтмена);
		Если НЕ Ответ = КодВозвратаДиалога.ОК Тогда
			Возврат;
		КонецЕсли;
		Объект.ФактурыАвансов.Очистить();
	КонецЕсли;
	ЗаполнитьФактурыНаСервере();
	Модифицированность = Истина;
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьФактурыНаСервере()
	
	//СуммаОсталосьРаспределить = Объект.Запасы.Итог("СуммаНДС");
	
	тзПредоплаты = Объект.Предоплата.выгрузить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	тзПредоплата.СуммаРасчетов КАК СуммаРасчетов,
		|	тзПредоплата.Курс КАК Курс,
		|	тзПредоплата.Кратность КАК Кратность
		|ПОМЕСТИТЬ ВТ_Предоплата
		|ИЗ
		|	&тзПредоплата КАК тзПредоплата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
	 	|	ВЫБРАТЬ
		//|	ВТ_Предоплата.Ссылка КАК Ссылка,
		|	СУММА(ВТ_Предоплата.СуммаРасчетов) КАК СуммаРасчетов,
		|	СУММА(ВТ_Предоплата.СуммаРасчетов * ВТ_Предоплата.Курс / ВТ_Предоплата.Кратность) КАК СуммаРасчетовРеглПоКурсуПредоплаты
		|ПОМЕСТИТЬ ВременнаяТаблицаСуммаПредоплатыГрупп
		|ИЗ
		|	ВТ_Предоплата КАК ВТ_Предоплата
		//Документ.РасходнаяНакладная.Предоплата КАК РасходнаяНакладнаяПредоплата
		|
		//|СГРУППИРОВАТЬ ПО
		//|	ВТ_Предоплата.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		//|	РасходнаяНакладная.Ссылка КАК Ссылка,
		//|	РасходнаяНакладная.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаНеОплаченаВал,
		|	&СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаНеОплаченаВал,
		//|	(РасходнаяНакладная.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * РасходнаяНакладная.Курс / РасходнаяНакладная.Кратность КАК СуммаНеОплаченаРегл,
		|	(&СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * &Курс / &Кратность КАК СуммаНеОплаченаРегл,
		|	ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаРасчетовВал,
		|	ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты КАК СуммаРасчетовРегл,
		//|	(РасходнаяНакладная.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * РасходнаяНакладная.Курс / РасходнаяНакладная.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) КАК СуммаДокументаРеглПоВсемКурсам,
		|	(&СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * &Курс / &Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) КАК СуммаДокументаРеглПоВсемКурсам,
		|	ВЫБОР
		//|		КОГДА РасходнаяНакладная.СуммаДокумента = 0
		|		КОГДА &СуммаДокумента = 0
		|			ТОГДА 1
		//|		ИНАЧЕ ((РасходнаяНакладная.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * РасходнаяНакладная.Курс / РасходнаяНакладная.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0)) / РасходнаяНакладная.СуммаДокумента
		|		ИНАЧЕ ((&СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * &Курс / &Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0)) / &СуммаДокумента
		|	КОНЕЦ КАК СреднийКурсДокумента,
		|	1 КАК Кратность
		|ПОМЕСТИТЬ ВременнаяТаблицаСреднегоКурсаПредоплаты
		|ИЗ
		//|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		//|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаСуммаПредоплатыГрупп КАК ВременнаяТаблицаСуммаПредоплатыГрупп
		//|		ПО РасходнаяНакладная.Ссылка = ВременнаяТаблицаСуммаПредоплатыГрупп.Ссылка
		|	ВременнаяТаблицаСуммаПредоплатыГрупп КАК ВременнаяТаблицаСуммаПредоплатыГрупп
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		//|	ВременнаяТаблицаСреднегоКурсаПредоплаты.Ссылка КАК Ссылка,
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты.СреднийКурсДокумента КАК Курс,
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты.Кратность КАК Кратность
		|ИЗ
		|	ВременнаяТаблицаСреднегоКурсаПредоплаты КАК ВременнаяТаблицаСреднегоКурсаПредоплаты";
	
	Запрос.УстановитьПараметр("тзПредоплата", 	тзПредоплаты);
	//Запрос.УстановитьПараметр("СуммаДокумента", Объект.СуммаДокумента);
	Запрос.УстановитьПараметр("СуммаДокумента", Объект.Запасы.Итог("Всего"));
	Запрос.УстановитьПараметр("Курс", 			Объект.Курс);
	Запрос.УстановитьПараметр("Кратность", 		Объект.Кратность);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	срКурс = 0;
	срКратность = 0;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		срКурс = ВыборкаДетальныеЗаписи.Курс;
		срКратность = ВыборкаДетальныеЗаписи.Кратность;
	КонецЦикла;
	
	Если срКурс = 1 ИЛИ срКурс = 0 ИЛИ срКратность = 0 Тогда 
		СуммаОсталосьРаспределить = Объект.Запасы.Итог("СуммаНДС");
	Иначе
		
		СуммаОсталосьРаспределить = 0;
		Для Каждого Строки Из Объект.Запасы Цикл 
			
			СуммаОсталосьРаспределить = СуммаОсталосьРаспределить + ((Строки.Всего - (Строки.Всего / (1 + (Строки.СтавкаНДС.Ставка / 100)))) * срКурс / срКратность);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Если СуммаОсталосьРаспределить = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаАвансов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьТаблицуАвансовФактур(Объект.Ссылка, "РасходнаяНакладная", Объект.Дата, Объект.Организация, Объект.Контрагент);
	Для Каждого Выборка ИЗ ТаблицаАвансов Цикл
		НоваяСтрока = Объект.ФактурыАвансов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		Если СуммаОсталосьРаспределить <= Выборка.СуммаНДС Тогда
			НоваяСтрока.СуммаНДС = СуммаОсталосьРаспределить;
			Прервать;
		КонецЕсли;
		СуммаОсталосьРаспределить = СуммаОсталосьРаспределить - НоваяСтрока.СуммаНДС
	КонецЦикла;
	
КонецПроцедуры


&НаКлиенте
Процедура ДобавитьФактуры(Команда)
	СтруктураАдреса = ПолучитьАдресТаблицыОстатков();
	Результат = ОткрытьФормуМодально("Документ.РасходнаяНакладная.Форма.ФормаОстаткиАвансовФактур", СтруктураАдреса);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ЗаполнитьВыделенныеСтроки(Результат.АдресТаблицы);
	Модифицированность = Истина;
КонецПроцедуры

Процедура ЗаполнитьВыделенныеСтроки(АдресТаблицы)
	ВыделенныеСтроки = ПолучитьИзВременногоХранилища(АдресТаблицы);
	Для Каждого СтрокаТЧ ИЗ ВыделенныеСтроки Цикл
		НовСтрока = Объект.ФактурыАвансов.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаТЧ);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ПолучитьАдресТаблицыОстатков()
	ТаблицаАвансов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьТаблицуАвансовФактур(Объект.Ссылка, "РасходнаяНакладная", Объект.Дата, Объект.Организация, Объект.Контрагент, Объект.ФактурыАвансов);
	Возврат Новый Структура("АдресТаблицы", ПоместитьВоВременноеХранилище(ТаблицаАвансов));
КонецФункции

//+++ Истоин
&НаСервере
Процедура ЗаполнитьСчетаБезвозмезднойПродажи()
	
	СтруктураСчетовКурсРазниц = РегистрыСведений.УчетнаяПолитикаРегл.СоздатьМенеджерЗаписи();
	СтруктураСчетовКурсРазниц.Организация = ?(НЕ ЗначениеЗаполнено(Объект.Организация), УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(ПараметрыСеанса.ТекущийПользователь, "ОсновнаяОрганизация"), Объект.Организация);
	СтруктураСчетовКурсРазниц.Период = ?(НЕ ЗначениеЗаполнено(Объект.Дата), ТекущаяДата(),ОБъект.Дата);
	СтруктураСчетовКурсРазниц.Прочитать();
	
	Если СтруктураСчетовКурсРазниц.Выбран() Тогда
	
		Объект.СчетЗатратБезвозмезднойПродажи 			 = СтруктураСчетовКурсРазниц.СчетЗатратБезвозмезднойПродажи;
		Объект.СчетЗатратНДСБезвозмезднойПродажи   		 = СтруктураСчетовКурсРазниц.СчетЗатратНДСБезвозмезднойПродажи;
		Объект.СчетУчетаНалогаНаПрибыль     			 = СтруктураСчетовКурсРазниц.СчетУчетаНалогаНаПрибыль;
		Объект.СчетУчетаНалогаНаПрибыльПодлежащийОплате  = СтруктураСчетовКурсРазниц.СчетУчетаНалогаНаПрибыльПодлежащийОплате;
		Объект.СчетУчетаСвободнаяпродажа                 = СтруктураСчетовКурсРазниц.СчетУчетаСвободнаяпродажа;
		
		Объект.СчетЗатратБезвозмезднойПродажиСотрудник 	 = СтруктураСчетовКурсРазниц.СчетЗатратБезвозмезднойПродажиСотрудник;
		Объект.СчетЗатратНДСБезвозмезднойПродажиСотрудник= СтруктураСчетовКурсРазниц.СчетЗатратНДСБезвозмезднойПродажиСотрудник;
		Объект.СчетЗатратНДФЛСотрудник     				 = СтруктураСчетовКурсРазниц.СчетЗатратНДФЛСотрудник;
		Объект.СчетЗатратПФСотрудник					 = СтруктураСчетовКурсРазниц.СчетЗатратПФСотрудник;
		Объект.СчетУчетаСвободнаяпродажаСотрудник        = СтруктураСчетовКурсРазниц.СчетУчетаСвободнаяпродажаСотрудник;
		
	Иначе
		
		ПустойСчет = ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.ПустаяСсылка");
		Объект.СчетЗатратБезвозмезднойПродажи 			= ПустойСчет;
		Объект.СчетЗатратНДСБезвозмезднойПродажи 		= ПустойСчет;
		Объект.СчетУчетаНалогаНаПрибыль 				= ПустойСчет;
		Объект.СчетУчетаНалогаНаПрибыльПодлежащийОплате = ПустойСчет;
		Объект.СчетУчетаСвободнаяпродажа                = ПустойСчет;
		
		Объект.СчетЗатратБезвозмезднойПродажиСотрудник 	 = ПустойСчет;
