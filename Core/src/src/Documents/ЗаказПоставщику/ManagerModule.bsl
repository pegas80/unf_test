//Паганини_
// Устанавливает статус для списка документов
//
// Параметры:
// 		МассивДокументов - Массив - Массив документов
// 		НовыйСтатус - Строка - Имя нового статуса для документов
//
// Возвращаемое значение:
// 		Число - Количество документов у которых был изменен статус
//
// ВАЖНО. При использования процедуры для каждого типа документа из массива должны быть объявлены функции:
// В модуле менеджера документа:
// 		Функция СформироватьЗапросПроверкиПриСменеСтатуса(МассивДокументов, НовыйСтатус, ДополнительныеПараметры) Экспорт
// 		Функция ПроверкаПередСменойСтатуса(ВыборкаПроверки, НовыйСтатус, ДополнительныеПараметры) Экспорт
// В модуле объекта документа:
// 		Функция УстановитьСтатус(НовыйСтатус, ДополнительныеПараметры) Экспорт
Функция УстановитьСостояниеДокументов(Знач МассивДокументов, Знач СтатусЗаказа) Экспорт
	
	// Получение шаблонов сообщений стандартных ошибок
	ШаблонОшибкиСостояниеСовпадает	= НСтр("ka='დოკუმენტს %Документ% უკვე მინიჭებული აქვს მდგომარეობა ""%Состояние%""';ru='Документу %Документ% уже присвоено состояние ""%Состояние%""';en='Document% Document% is already assigned to the state ""% status%""'");
	ШаблонОшибкиНеПроведен        	= НСтр("ka='დოკუმენტი %Документ% არ არის გატარებული. შეუძლებელია მდგომარეობის შეცვლა';ru='Документ %Документ% не проведен. Невозможно изменить состояние';en='Document%% Document not conducted. You can not change the state'");
	ШаблонОшибкиПомеченНаУдаление 	= НСтр("ka='დოკუმენტი %Документ% მონიშნულია წაშლაზე. შეუძლებელია მდგომარეობის შეცვლა';ru='Документ %Документ% помечен на удаление. Невозможно изменить состояние';en='Document% Document% marked for deletion. You can not change the state'");
	ШаблонОшибкиПредыдущееСостояние	= НСтр("ka='დოკუმენტი %Документ%: შეუძლებელია გადავიდეს მდგომარეობაში ""%Состояние%"" მდგომარეობიდან ""%ПредыдущееСостояние%""';ru='Документ %Документ%: невозможно перейти в состояние ""%Состояние%"" из состояния ""%ПредыдущееСостояние%""';en='The document% Document%: it is impossible to go into a state of ""% status%"" from the ""%% PredyduscheeSostoyanie""'");
	ШаблонОшибкиЗаблокировать     	= НСтр("ka='ვერ მოხედხდა დაბლოკვა %Документ%. %ОписаниеОшибки%';ru='Не удалось заблокировать %Документ%. %ОписаниеОшибки%';en='Could not lock% Document%. % OpisanieOshibki%'");
	ШаблонОшибкиЗаписать          	= НСтр("ka='ვერ მოხერხდა დოკუმენტის ჩაწერა %Документ%. %ОписаниеОшибки%';ru='Не удалось записать %Документ%. %ОписаниеОшибки%';en='Unable to write% Document%. % OpisanieOshibki%'");
	
	СтатусОткрыт				 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.Открыт");
	СтатусПереданВЗакупку		 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.ПереданВЗакупку");
	СтатусПодтвержденЗакупками	 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.ПодтвержденЗакупками");
	СтатусПодтвержден			 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.Подтвержден");
	СтатусПодтвержденМенеджером		 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.ПодтвержденМенеджером");
	СтатусЗакуплен				 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.Закуплен");
	
	КоличествоОбработанных = 0;
	
	НовоеСостояние = Справочники.СостоянияЗаказовПоставщикам.ПолучитьСостояниеПоЗначениюСтатуса(СтатусЗаказа);
	
	// Формирование запроса
	Запрос = СформироватьЗапросПроверкиПриСменеСостояния(МассивДокументов, НовоеСостояние);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат 0;
	КонецЕсли;
		
	// Цикл обхода выборки
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		// Универсальные проверки
		Если Выборка.ПометкаУдаления Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрЗаменить(ШаблонОшибкиПомеченНаУдаление, "%Документ%", Выборка.Представление), Выборка.Ссылка);
			Продолжить;
		КонецЕсли;
		
		Если Не Выборка.Проведен Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрЗаменить(ШаблонОшибкиНеПроведен, "%Документ%", Выборка.Представление), Выборка.Ссылка);
			Продолжить;
		КонецЕсли;

		Если Выборка.СостояниеСовпадает Тогда

			ТекстОшибки = СтрЗаменить(ШаблонОшибкиСостояниеСовпадает, "%Документ%", Выборка.Представление);
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Состояние%", Выборка.НовоеСостояние);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Выборка.Ссылка);
			Продолжить;
			
		КонецЕсли;
			
		Если Не РольДоступна("ПолныеПрава") Тогда
			Если СтатусЗаказа = СтатусПереданВЗакупку И Выборка.ТекущийСтатус <> СтатусОткрыт 
				ИЛИ СтатусЗаказа = СтатусПодтвержденЗакупками И Выборка.ТекущийСтатус <> СтатусПереданВЗакупку
				ИЛИ СтатусЗаказа = СтатусЗакуплен И НЕ (Выборка.ТекущийСтатус = СтатусПодтвержден ИЛИ Выборка.ТекущийСтатус = СтатусПодтвержденМенеджером)
				Тогда
				ТекстОшибки = СтрЗаменить(ШаблонОшибкиПредыдущееСостояние, "%Документ%", Выборка.Представление);
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Состояние%", Выборка.НовоеСостояние);
				ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ПредыдущееСостояние%", Выборка.ТекущееСостояние);
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Выборка.Ссылка);
				Продолжить;
			КонецЕсли; 
		КонецЕсли; 
		
		// Захват объекта для редактирования
		Попытка
			ЗаблокироватьДанныеДляРедактирования(Выборка.Ссылка);
		Исключение
			ТекстОшибки = СтрЗаменить(ШаблонОшибкиЗаблокировать, "%Документ%", Выборка.Представление);
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ОписаниеОшибки%", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Выборка.Ссылка);
			Продолжить;
		КонецПопытки;
			
		// Получение объекта документа
		Объект = Выборка.Ссылка.ПолучитьОбъект();
		
		// Установка статуса документа
		Объект.СостояниеЗаказа = НовоеСостояние;
		//Если Не Объект.УстановитьСтатус(НовоеСостояние) Тогда
		//	Продолжить;
		//КонецЕсли;
			
		// Запись документа
		РежимЗаписи = ?(Выборка.ЗаписьПроведением, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
		ТекстОшибкиЗаписи = "";
		РезультатЗаписи = ЗаписатьОбъектБезКонтроляПрав(Объект, РежимЗаписи, ТекстОшибкиЗаписи);
		Если РезультатЗаписи = Истина Тогда
			КоличествоОбработанных = КоличествоОбработанных + 1;
		Иначе
			ТекстОшибки = СтрЗаменить(ШаблонОшибкиЗаписать, "%Документ%", Выборка.Представление);
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ОписаниеОшибки%", ТекстОшибкиЗаписи);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, Выборка.Ссылка);
		КонецЕсли; 
		
	КонецЦикла; // выборки документов данного типа
	
	Возврат КоличествоОбработанных;

КонецФункции

// Устанавливает статус для текущего документа
//
// Параметры:
// 		ДокументОбъект - ДокументОбъект
// 		НовыйСтатус - Перечисление.СтатусыВнутреннихЗаказов - Значение нового статуса документа
//
// Возвращаемое значение:
// 		Булево - Признак успешного изменения статусов
Функция ИзменитьСостояниеДокумента(ДокументОбъект, Знач СтатусЗаказа) Экспорт
	
	// Получение шаблонов сообщений стандартных ошибок
	ШаблонОшибкиСостояниеСовпадает	= НСтр("ka='დოკუმენტს %Документ%უკვე მინიჭებული აქვს მდგომარეობა ""%Состояние%""';ru='Документу %Документ% уже присвоено состояние ""%Состояние%""';en='Document% Document% is already assigned to the state ""% status%""'");
	ШаблонОшибкиНеПроведен        	= НСтр("ka='დოკუმენტი %Документ% არ არის გატარებული. შეუძლებელია მდგომარეობის შეცვლა';ru='Документ %Документ% не проведен. Невозможно изменить состояние';en='Document%% Document not conducted. You can not change the state'");
	ШаблонОшибкиПомеченНаУдаление 	= НСтр("ka='დოკუმენტი %Документ% მონიშნულია წაშლაზე. შეუძლებელია მდგომარეობის შეცვლა';ru='Документ %Документ% помечен на удаление. Невозможно изменить состояние';en='Document% Document% marked for deletion. You can not change the state'");
	ШаблонОшибкиПредыдущееСостояние	= НСтр("ka='დოკუმენტი %Документ%: შეუძლებელია მდგომარეობიდან ""%ПредыдущееСостояние%"" მდგომარეობაში ""%Состояние%"" გადაყვანა';ru='Документ %Документ%: невозможно перейти в состояние ""%Состояние%"" из состояния ""%ПредыдущееСостояние%""';en='The document% Document%: it is impossible to go into a state of ""% status%"" from the ""%% PredyduscheeSostoyanie""'");
	ШаблонОшибкиЗаблокировать     	= НСтр("ka='ვერ მოხერხდა დაბლოკვა %Документ%. %ОписаниеОшибки%';ru='Не удалось заблокировать %Документ%. %ОписаниеОшибки%';en='Could not lock% Document%. % OpisanieOshibki%'");
	ШаблонОшибкиЗаписать          	= НСтр("ka='ვერ მოხერხდა ჩაწერა %Документ%. %ОписаниеОшибки%';ru='Не удалось записать %Документ%. %ОписаниеОшибки%';en='Unable to write% Document%. % OpisanieOshibki%'");
	
	СтатусОткрыт				 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.Открыт");
	СтатусПереданВЗакупку		 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.ПереданВЗакупку");
	СтатусПодтвержденЗакупками	 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.ПодтвержденЗакупками");
	СтатусПодтвержден			 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.Подтвержден");
	СтатусПодтвержденМенеджером	 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.ПодтвержденМенеджером");
	СтатусЗакуплен				 = ПредопределенноеЗначение("Перечисление.СтатусыВнутреннихЗаказов.Закуплен");
	
	СостояниеИзменено = Ложь;
	
	НовоеСостояние = Справочники.СостоянияЗаказовПоставщикам.ПолучитьСостояниеПоЗначениюСтатуса(СтатусЗаказа);
	                            
	ПредставлениеДокумента = "" + ДокументОбъект;
	
	СостояниеСовпадает = (ДокументОбъект.СостояниеЗаказа = НовоеСостояние);
	ТекущийСтатус = ДокументОбъект.СостояниеЗаказа.СтатусВнутреннегоЗаказа;
	
	// Универсальные проверки
	Если ДокументОбъект.ПометкаУдаления Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрЗаменить(ШаблонОшибкиПомеченНаУдаление, "%Документ%", ПредставлениеДокумента), ДокументОбъект.Ссылка);
		Возврат СостояниеИзменено;
	КонецЕсли;
	
	Если Не ДокументОбъект.Проведен Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрЗаменить(ШаблонОшибкиНеПроведен, "%Документ%", ПредставлениеДокумента), ДокументОбъект.Ссылка);
		Возврат СостояниеИзменено;
	КонецЕсли;
	
	Если СостояниеСовпадает Тогда
		
		ТекстОшибки = СтрЗаменить(ШаблонОшибкиСостояниеСовпадает, "%Документ%", ПредставлениеДокумента);
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Состояние%", НовоеСостояние);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, ДокументОбъект.Ссылка);
		Возврат СостояниеИзменено;
		
	КонецЕсли;
	
	Если Не РольДоступна("ПолныеПрава") Тогда
		Если СтатусЗаказа = СтатусПереданВЗакупку И ТекущийСтатус <> СтатусОткрыт 
			ИЛИ СтатусЗаказа = СтатусПодтвержденЗакупками И ТекущийСтатус <> СтатусПереданВЗакупку
			ИЛИ СтатусЗаказа = СтатусЗакуплен И НЕ (ТекущийСтатус = СтатусПодтвержден ИЛИ ТекущийСтатус = СтатусПодтвержденМенеджером)
			Тогда
			ТекстОшибки = СтрЗаменить(ШаблонОшибкиПредыдущееСостояние, "%Документ%", ПредставлениеДокумента);
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Состояние%", НовоеСостояние);
			ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ПредыдущееСостояние%", ДокументОбъект.СостояниеЗаказа);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, ДокументОбъект.Ссылка);
			Возврат СостояниеИзменено;
		КонецЕсли; 
	КонецЕсли; 
	
	// Установка статуса документа
	ДокументОбъект.СостояниеЗаказа = НовоеСостояние;
	
	// Запись документа
	РежимЗаписи = РежимЗаписиДокумента.Проведение;
	ТекстОшибкиЗаписи = "";
	РезультатЗаписи = ЗаписатьОбъектБезКонтроляПрав(ДокументОбъект, РежимЗаписи, ТекстОшибкиЗаписи);
	Если РезультатЗаписи = Истина Тогда
		СостояниеИзменено = Истина;
	Иначе
		ТекстОшибки = СтрЗаменить(ШаблонОшибкиЗаписать, "%Документ%", ПредставлениеДокумента);
		ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ОписаниеОшибки%", ТекстОшибкиЗаписи);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, ДокументОбъект.Ссылка);
	КонецЕсли; 
	
	Возврат СостояниеИзменено;

КонецФункции

// Формирует запрос проверки при смене статуса списка документов
//
// Параметры:
//	МассивДокументов - Массив - Массив ссылок на документы, которые надо проверять
//	НовыйСтатус - Строка - Имя нового статуса
//	ДополнительныеПараметры - Структура - Структура дополнительных параметров
//
// Возвращаемое значение:
//	Запрос - Запрос проверки перед сменой статуса
//
Функция СформироватьЗапросПроверкиПриСменеСостояния(МассивДокументов, НовоеСостояние) Экспорт
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТаблицаДокументов.Ссылка КАК Ссылка,
	|	ПРЕДСТАВЛЕНИЕ(ТаблицаДокументов.Ссылка) КАК Представление,
	|	ТаблицаДокументов.СостояниеЗаказа КАК ТекущееСостояние,
	|	ТаблицаДокументов.СостояниеЗаказа.СтатусВнутреннегоЗаказа КАК ТекущийСтатус,
	|	&Состояние КАК НовоеСостояние,
	|	ВЫБОР
	|		КОГДА ТаблицаДокументов.СостояниеЗаказа = &Состояние
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СостояниеСовпадает,
	|	ТаблицаДокументов.Проведен КАК Проведен,
	|	ТаблицаДокументов.ПометкаУдаления КАК ПометкаУдаления,
	|	ИСТИНА КАК ЗаписьПроведением
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ТаблицаДокументов
	|ГДЕ
	|	ТаблицаДокументов.Ссылка В(&МассивДокументов)";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Состояние", НовоеСостояние);
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	
	Возврат Запрос;
	
КонецФункции

Функция ЗаписатьОбъектБезКонтроляПрав(ОбъектДляЗаписи, РежимЗаписи, ТекстОшибки = "") Экспорт

	Попытка
		ОбъектДляЗаписи.Записать(РежимЗаписи);
		Возврат Истина;
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки
	
КонецФункции
