КонецПроцедуры

&НаКлиенте
Процедура УстановитьСостояниеЗаказа(НовыйСтатус)
	
	ВыделенныеСтроки = ПроверитьПолучитьВыделенныеВСпискеСсылки(Элементы.Список);
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстВопроса = НСтр("ru='У выделенных в списке заказов будет установлено состояние " + НовыйСтатус + ". Продолжить?';
						|ka = 'გამოყოფილი სტრიქონებისთვის სიაში დაყენებული იქნება მდგომარეობა " + НовыйСтатус + ". გაგრძელდეს?'");
	Ответ = Вопрос(ТекстВопроса,РежимДиалогаВопрос.ДаНет);
	
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоОбработанных = УстановитьСостояниеДокументовНаСервере(ВыделенныеСтроки, НовыйСтатус);
	ОповеститьПользователяОбУстановкеСостояния(Элементы.Список, КоличествоОбработанных, ВыделенныеСтроки.Количество(), "" + НовыйСтатус);

КонецПроцедуры	

&НаСервереБезКонтекста
Функция УстановитьСостояниеДокументовНаСервере(Знач МассивДокументов, Знач СтатусЗаказа)

	Возврат Документы.ЗаказПоставщику.УстановитьСостояниеДокументов(МассивДокументов, СтатусЗаказа);	

КонецФункции
 &НаКлиенте
Процедура ОповеститьПользователяОбУстановкеСостояния(СписокДокументов, КоличествоОбработанных, КоличествоВсего, Состояние)
	
	Если КоличествоОбработанных > 0 Тогда
		
		СписокДокументов.Обновить();
		
		ТекстСообщения = НСтр("ka=' %КоличествоВсего% გამოყოფილი სტრიქონიდან %КоличествоОбработанных% დოკუმენტისთვის დადგინდა მდგომარეობა""%Состояние%""';ru='Для %КоличествоОбработанных% из %КоличествоВсего% выделенных в списке заказов поставщикам установлено состояние ""%Состояние%""';en='For KolichestvoObrabotannyh%% of%% KolichestvoVsego selected in the list of orders to suppliers established state ""% status%""'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%КоличествоОбработанных%", КоличествоОбработанных);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%КоличествоВсего%",        КоличествоВсего);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Состояние%",              Состояние);
		ТекстЗаголовка = НСтр("ka='მდგომარეობა ""%Состояние%"" დადგენილია';ru='Состояние ""%Состояние%"" установлено';en='Status ""% status%"" is set'");
		ТекстЗаголовка = СтрЗаменить(ТекстЗаголовка, "%Состояние%", Состояние);
		ПоказатьОповещениеПользователя(ТекстЗаголовка,, ТекстСообщения, БиблиотекаКартинок.Информация32);
		
	Иначе
		
		ТекстСообщения = НСтр("ka='მდგომარეობა ""%Состояние%"" არ არის დადგენილი არცერთი შეკვეთისთვის.';ru='Состояние ""%Состояние%"" не установлено ни для одного заказа поставщику.';en='Status ""% status%"" is not set for any order to the supplier.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Состояние%", Состояние);
		ТекстЗаголовка = НСтр("ka='მდგომარეობა ""%Состояние%"" არ არის დადგენილი';ru='Состояние ""%Состояние%"" не установлено';en='Status ""% status%"" not found'");
		ТекстЗаголовка = СтрЗаменить(ТекстЗаголовка, "%Состояние%", Состояние);
		ПоказатьОповещениеПользователя(ТекстЗаголовка,, ТекстСообщения, БиблиотекаКартинок.Информация32);
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Функция ПроверитьПолучитьВыделенныеВСпискеСсылки(Список) Экспорт
	
	МассивСсылок = Новый Массив;
	
	Для н = 0 По Список.ВыделенныеСтроки.Количество()-1 Цикл
		Если ТипЗнч(Список.ВыделенныеСтроки[н]) <> Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
			МассивСсылок.Добавить(Список.ВыделенныеСтроки[н]);
		КонецЕсли;
	КонецЦикла;
	
	Если МассивСсылок.Количество() = 0 Тогда
		Предупреждение( НСтр("ka='ბრძანება არ შეიძლება შესრულდეს მითითებული ობიექტისთვის!';ru='Команда не может быть выполнена для указанного объекта!';en='The command can not be executed for that object!'"));
	КонецЕсли;
	
	Возврат МассивСсылок;
	
КонецФункции
