&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ВерсионированиеОбъектов
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов	
	
	//УправлениеНебольшойФирмойСервер.ЗаполнитьШапкуДокумента(
	//Объект,
	//,
	//Параметры.ЗначениеКопирования,
	//Параметры.Основание,
	//СостояниеДокумента,
	//КартинкаСостоянияДокумента,
	//РазрешеноПроведение,
	//Параметры.ЗначенияЗаполнения
	//);
	
	Если Не ЗначениеЗаполнено(Объект.ВалютаДокумента) Тогда 
		Объект.ВалютаДокумента = Справочники.Валюты.ПустаяСсылка();	
		СтрПарам = ПолучитьКурсВалюты(Объект.Дата, Объект.ВалютаДокумента);
		Объект.Курс = СтрПарам.Курс;
		Объект.Кратность = СтрПарам.Кратность;
	КонецЕсли;
	
	УО = ЭтаФорма.УсловноеОформление; 
	УО.Элементы.Очистить(); 
	ЭлементУО = УО.Элементы.Добавить();
	
	ОбновитьОформлениеТЗ();
			
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОбновытьОформлениеСтраницыТипПродажы();
	
	Если Не ЗначениеЗаполнено(Объект.Проект) Тогда
		ЭтаФорма.Элементы.Проекты.Доступность = Ложь;		
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.ПроектыВерсия) Тогда
		ЭтаФорма.Элементы.ПроектыВерсия.Доступность = Ложь;		
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	УправлениеНебольшойФирмойКлиент.ОбновитьСостояниеДокумента(Объект, СостояниеДокумента, КартинкаСостоянияДокумента, РазрешеноПроведение);
	
КонецПроцедуры

&НаКлиенте
Процедура ВалютаДокументаПриИзменении(Элемент)
	
	Если Не ЗначениеЗаполнено(Объект.Курс) Тогда 
		СтрПарам = ПолучитьКурсВалюты(Объект.Дата, Объект.ВалютаДокумента);
		Объект.Курс = СтрПарам.Курс;
		Объект.Кратность = СтрПарам.Кратность;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	Отказ = ПроверкаДанныхПриЗаписи();
КонецПроцедуры

&НаКлиенте
Процедура ГарантийныеУсловияПриИзменении(Элемент)
	ОбновытьОформлениеСтраницыТипПродажы();	
КонецПроцедуры

&НаКлиенте
Процедура ПереходКПоддержкеПриИзменении(Элемент)
	ОбновытьОформлениеСтраницыТипПродажы();
КонецПроцедуры

&НаКлиенте
Процедура ПереходВУслугиПриИзменении(Элемент)
	ОбновытьОформлениеСтраницыТипПродажы();
КонецПроцедуры

&НаКлиенте
Процедура ПриобретениеИзСвоейКомпанииПриИзменении(Элемент)
	ОбновытьОформлениеСтраницыТипПродажы();
КонецПроцедуры

&НаКлиенте
Процедура ТипПродажиИПриИзменении(Элемент)
	ОбновитьОформлениеТЗ();
	Элементы.ТипПродажи.Обновить();
КонецПроцедуры 

&НаКлиенте
Процедура ТипПродажиПриАктивизацииЯчейки(Элемент)
	
	НовыйМассив = Новый Массив();			
	Если Элемент.ТекущиеДанные <> Неопределено И ТипПродажиГотоваяПродукция(Элемент.ТекущиеДанные.ТипПродажи) Тогда   
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.Номенклатура"));
		НашеОписание = Новый ОписаниеТипов(Массив);
		Элемент.ТекущийЭлемент.ОграничениеТипа = НашеОписание;
	Иначе 			
		Массив = Новый Массив();
		Массив.Добавить(Тип("Строка"));
		НашеОписание = Новый ОписаниеТипов(Массив);
	    Элемент.ТекущийЭлемент.ОграничениеТипа = НашеОписание;
	КонецЕсли;
	
КонецПроцедуры

