&НаСервере
Процедура ОбновитьОформлениеТЗ()

	ЭтаФорма.УсловноеОформление.Элементы.Очистить();
	
	Для каждого ТС Из Объект.ТипПродажи Цикл
		
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Колонка");
		ТЗ.Колонки.Добавить("Значение");
		
		Если ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.Услуга Тогда 
			// TODO ...
		ИначеЕсли ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.Продукт Тогда
			// TODO ...
		ИначеЕсли ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.ГотоваяПродукция Тогда
			
			НоваяСтрока = ТЗ.Добавить();
			НоваяСтрока.Колонка = "ТипПродажиОтветственныйЗаПроизводство";
			НоваяСтрока.Значение = Истина;
			
			НоваяСтрока = ТЗ.Добавить();
			НоваяСтрока.Колонка = "ТипПродажиСпецификация";
			НоваяСтрока.Значение = Истина;
			
		ИначеЕсли ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.Сервис Тогда
			
			НоваяСтрока = ТЗ.Добавить();
			НоваяСтрока.Колонка = "ТипПродажиОтветственныйЗаПроизводство";
			НоваяСтрока.Значение = Истина;
			
			НоваяСтрока = ТЗ.Добавить();
			НоваяСтрока.Колонка = "ТипПродажиПериодичностьСписаниеЗапасов";
			НоваяСтрока.Значение = Истина;	
			
		КонецЕсли;
		
		Если ТЗ.Количество() > 0 Тогда  			
			УсловноеОформлениеДобавитьУсловые(ТС.НомерСтроки, ТЗ, Ложь, Истина);
		КонецЕсли;
				
	КонецЦикла;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбновытьОформлениеСтраницыТипПродажы()
	
	Элементы.ГарантийныеУсловияДатаОкончания.АвтоОтметкаНезаполненного = Объект.ГарантийныеУсловия;
	Элементы.ГарантийныеУсловияДатаОкончания.ОтметкаНезаполненного     = Объект.ГарантийныеУсловия;
	Элементы.ГарантийныеУсловияТекст.Доступность                       = Объект.ГарантийныеУсловия;
	
	Элементы.ПереходКПоддержкеДатаОкончания.АвтоОтметкаНезаполненного  = Объект.ПереходКПоддержке;
	Элементы.ПереходКПоддержкеДатаОкончания.ОтметкаНезаполненного      = Объект.ПереходКПоддержке;
	Элементы.ПереходКПоддержкеТекст.Доступность                        = Объект.ПереходКПоддержке;
	
	Элементы.ПереходВУслугиДатаОкончания.АвтоОтметкаНезаполненного     = Объект.ПереходВУслуги;
	Элементы.ПереходВУслугиДатаОкончания.ОтметкаНезаполненного         = Объект.ПереходВУслуги;
	Элементы.ПереходВУслугиТекст.Доступность                           = Объект.ПереходВУслуги;
	
	Элементы.ПриобретениеИзСвоейКомпанииНаимОрг.АвтоОтметкаНезаполненного                   = Объект.ПриобретениеИзСвоейКомпании;
	Элементы.ПриобретениеИзСвоейКомпанииНаимОрг.ОтметкаНезаполненного                       = Объект.ПриобретениеИзСвоейКомпании;
	Элементы.ПриобретениеИзСвоейКомпанииДоговор.АвтоОтметкаНезаполненного = Объект.ПриобретениеИзСвоейКомпании;
	Элементы.ПриобретениеИзСвоейКомпанииДоговор.ОтметкаНезаполненного     = Объект.ПриобретениеИзСвоейКомпании;
	
КонецПроцедуры
  
&НаСервере
Процедура УсловноеОформлениеДобавитьУсловые(НомерСтроки, ТЗ, ТолькоПросмотр, ОтметкаНезаполненного) 
	
	ЭлементУО = ЭтаФорма.УсловноеОформление.Элементы.Добавить();
	
	Для каждого ТекСтрока Из ТЗ Цикл
		Оформляемоеполе = ЭлементУО.Поля.Элементы.Добавить(); // Поля таблицы для которых будет действовать оформление 
		Оформляемоеполе.Поле = Новый ПолеКомпоновкиДанных(ТекСтрока.Колонка); 
		Оформляемоеполе.Использование = ТекСтрока.Значение; 				
	КонецЦикла;
		
	ЭлементОтбора = ЭлементУО.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); // отбор текущей строки таблицы 
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Объект.ТипПродажи.НомерСтроки"); 
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно; 
	ЭлементОтбора.ПравоеЗначение = НомерСтроки; 
	
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", ТолькоПросмотр);               // Установка оформления  
	ЭлементУО.Оформление.УстановитьЗначениеПараметра("ОтметкаНезаполненного", ОтметкаНезаполненного); // Установка оформления	
	
КонецПроцедуры

&НаСервере
Функция ПроверкаДанныхПриЗаписи()

	Отказ = Ложь;
	
	// 1) Проверка таблицы "ТипПродажи"	
	Для каждого ТС Из Объект.ТипПродажи Цикл		
		Если ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.Услуга Тогда 
			// TODO ...
		ИначеЕсли ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.Продукт Тогда
			// TODO ...
		ИначеЕсли ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.ГотоваяПродукция Тогда	
			 
			Если Не ЗначениеЗаполнено(ТС.ОтветственныйЗаПроизводство) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поля таблицы документа [Тип продажи]["+ТС.НомерСтроки+"][Ответственный за производство] не заполнены.';ka='[გაყიდვის ტიპის]["+ТС.НомерСтроки+"][წარმოებაზე პას. პირი] დოკუმენტის ცხრილის ველები შეუვსებელია, გთხოვთ გადაამოწმეთ.'"), , ); Отказ = Истина;
			ИначеЕсли Не ЗначениеЗаполнено(ТС.Спецификация) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поля таблицы документа [Тип продажи]["+ТС.НомерСтроки+"][Спецификация] не заполнены.';ka='[გაყიდვის ტიპის]["+ТС.НомерСтроки+"][სპეციფიკაცია] დოკუმენტის ცხრილის ველები შეუვსებელია, გთხოვთ გადაამოწმეთ.'"), , ); Отказ = Истина;
			КонецЕсли;	
				
		ИначеЕсли ТС.ТипПродажи = Перечисления.AzRyДоговорТипПродажи.Сервис Тогда	
			 
			Если Не ЗначениеЗаполнено(ТС.ОтветственныйЗаПроизводство) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поля таблицы документа [Тип продажи]["+ТС.НомерСтроки+"][Ответственный за производство] не заполнены.';ka='[გაყიდვის ტიპის]["+ТС.НомерСтроки+"][წარმოებაზე პას. პირი] დოკუმენტის ცხრილის ველები შეუვსებელია, გთხოვთ გადაამოწმეთ.'"), , ); Отказ = Истина;
			ИначеЕсли Не ЗначениеЗаполнено(ТС.ПериодичностьСписаниеЗапасов) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поля таблицы документа [Тип продажи]["+ТС.НомерСтроки+"][Периодичность списание запасов] не заполнены.';ka='[გაყიდვის ტიპის]["+ТС.НомерСтроки+"][მარაგების ჩამოწერის პერიოდულობა] დოკუმენტის ცხრილის ველები შეუვსებელია, გთხოვთ გადაამოწმეთ.'"), , ); Отказ = Истина;
			КонецЕсли;
	
		КонецЕсли;
	КонецЦикла;	
	
	// 2) Проверка Поля Страницы ТипПродажи
	Если Объект.ГарантийныеУсловия Тогда
		Если Объект.ГарантийныеУсловияДатаОкончания = Дата(1,1,1) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поле ""ГарантийныеУсловияДатаОкончания"" не заполнено';ka='ველი ""საგარანტიო პირობების საბოლოო თარიღი"" არ არის შევსებული'"), ,"ГарантийныеУсловияДатаОкончания");
			Отказ = Истина;
		КонецЕсли;	
	КонецЕсли;
	
	Если Объект.ПереходКПоддержке Тогда
		Если Объект.ПереходКПоддержкеДатаОкончания = Дата(1,1,1) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поле ""ПереходКПоддержкеДатаОкончания"" не заполнено';ka='ველი ""გადადის მხარდაჭერაში საბოლოო თარიღი"" არ არის შევსებული'"), ,"ПереходКПоддержкеДатаОкончания");
			Отказ = Истина;
		КонецЕсли;	
	КонецЕсли;
	
	Если Объект.ПереходВУслуги Тогда
		Если Объект.ПереходВУслугиДатаОкончания = Дата(1,1,1) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поле ""ПереходВУслугиДатаОкончания"" не заполнено';ka='ველი ""გადადის სერვისში საბოლოო თარიღი"" არ არის შევსებული'"), ,"ПереходВУслугиДатаОкончания");
			Отказ = Истина;
		КонецЕсли;	
	КонецЕсли;
	
	Если Объект.ПриобретениеИзСвоейКомпании Тогда
		Если Не ЗначениеЗаполнено(Объект.ПриобретениеИзСвоейКомпанииНаимОрг) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Поле ""НаименованиеОрганизаций"" не заполнено';ka='ველი ""კომპანიის დასახელება"" არ არის შევსებული'"), ,"ПриобретениеИзСвоейКомпании");
			Отказ = Истина;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Отказ;

КонецФункции

&НаКлиенте
Процедура ТипПродажиПриИзменении(Элемент)
	ОбновитьОформлениеТЗ();
	Элементы.ТипПродажи.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура ТипПродажиПослеУдаления(Элемент)
	ОбновитьОформлениеТЗ();
	Элементы.ТипПродажи.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура КонтактноеЛицоПриИзменении(Элемент)
	КонтактноеЛицоПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура КонтактноеЛицоПриИзмененииНаСервере()
	
	Если СокрЛП(Объект.ТелефонОсновной) = "" Или СокрЛП(Объект.ТелефонМобильный) = "" Или СокрЛП(Объект.АдресЭлектроннойПочты) = "" Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтактныеЛицаКонтактнаяИнформация.Ссылка КАК Ссылка,
		|	КонтактныеЛицаКонтактнаяИнформация.НомерСтроки КАК НомерСтроки,
		|	КонтактныеЛицаКонтактнаяИнформация.Тип КАК Тип,
		|	КонтактныеЛицаКонтактнаяИнформация.Вид КАК Вид,
		|	КонтактныеЛицаКонтактнаяИнформация.Представление КАК Представление,
		|	КонтактныеЛицаКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
		|	КонтактныеЛицаКонтактнаяИнформация.Страна КАК Страна,
		|	КонтактныеЛицаКонтактнаяИнформация.Регион КАК Регион,
		|	КонтактныеЛицаКонтактнаяИнформация.Город КАК Город,
		|	КонтактныеЛицаКонтактнаяИнформация.АдресЭП КАК АдресЭП,
		|	КонтактныеЛицаКонтактнаяИнформация.ДоменноеИмяСервера КАК ДоменноеИмяСервера,
		|	КонтактныеЛицаКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
		|	КонтактныеЛицаКонтактнаяИнформация.НомерТелефонаБезКодов КАК НомерТелефонаБезКодов
		|ИЗ
		|	Справочник.КонтактныеЛица.КонтактнаяИнформация КАК КонтактныеЛицаКонтактнаяИнформация
		|ГДЕ
		|	КонтактныеЛицаКонтактнаяИнформация.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка", Объект.КонтактноеЛицо);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Первый = Истина;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон И Первый Тогда
				ТелефонОсновной = ВыборкаДетальныеЗаписи.Представление;
				Первый = Ложь;
				Продолжить;
			КонецЕсли;
			Если ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон И Не Первый Тогда
				ТелефонМобильный = ВыборкаДетальныеЗаписи.Представление;
				Продолжить;
			КонецЕсли;
			Если ВыборкаДетальныеЗаписи.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
				АдресЭлектроннойПочты = ВыборкаДетальныеЗаписи.Представление;
				Продолжить;
			КонецЕсли;						
		КонецЦикла;
		
		Если СокрЛП(Объект.ТелефонОсновной) = "" Тогда
			Объект.ТелефонОсновной = ТелефонОсновной;
		КонецЕсли;                                   
		Если СокрЛП(Объект.ТелефонМобильный) = "" Тогда
			Объект.ТелефонМобильный = ТелефонМобильный;
		КонецЕсли; 
		Если СокрЛП(Объект.АдресЭлектроннойПочты) = "" Тогда
			Объект.АдресЭлектроннойПочты = АдресЭлектроннойПочты;
		КонецЕсли;		
	КонецЕсли; 
	
КонецПроцедуры

