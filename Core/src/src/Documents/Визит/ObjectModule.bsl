	//--------------------------------------------------------------------------
	
	
КонецПроцедуры

//--------------------------------------------------------------------------
// © Шишка В.В. [28 сентября 2023]  НАЧАЛО
Процедура ВыполнитьПроверкуВозвращаемыхТоваров() Экспорт

	УчетнаяПолитика = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(КонецДня(Дата), Новый Структура("Организация", Организация));
	Если Не УчетнаяПолитика.КонтрольКоличестваПриВозврате ИЛИ УчетнаяПолитика.СрокКонтроляКоличестваПриВозврате = 0 Тогда
	
		ДополнительныеСвойства.Вставить("ОшибкиВозвратаТоваров", Новый Массив);
		ДополнительныеСвойства.Вставить("НеВыполнятьПроверку", Истина);
		Возврат;	
	
	КонецЕсли; 
	ТаблицаВозврата = ЗаказНаВозврат.Выгрузить();
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЗаказНаВозврат", ТаблицаВозврата);
	//Запрос.УстановитьПараметр("Возврат", ВозвратОтПокупателя.Выгрузить());
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Договор", Договор);
	Запрос.УстановитьПараметр("КоличествоМесяцевКонтроля", УчетнаяПолитика.СрокКонтроляКоличестваПриВозврате);

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказНаВозврат.НомерСтроки КАК НомерСтроки,
	|	ВЫРАЗИТЬ(ЗаказНаВозврат.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(ЗаказНаВозврат.Характеристика КАК Справочник.ХарактеристикиНоменклатуры) КАК Характеристика,
	|	ЗаказНаВозврат.Количество КАК Количество
	|ПОМЕСТИТЬ ВТ_Возврат
	|ИЗ
	|	&ЗаказНаВозврат КАК ЗаказНаВозврат
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Возврат.Номенклатура КАК Номенклатура,
	|	ВТ_Возврат.Характеристика КАК Характеристика,
	|	СУММА(ВТ_Возврат.Количество) КАК Количество
	|ПОМЕСТИТЬ ВТ_ВозвратИтог
	|ИЗ
	|	ВТ_Возврат КАК ВТ_Возврат
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Возврат.Номенклатура,
	|	ВТ_Возврат.Характеристика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура КАК Номенклатура,
	|	ВложенныйЗапрос.Характеристика КАК Характеристика,
	|	СУММА(ВложенныйЗапрос.КоличествоПродано) КАК КоличествоПродано,
	|	СУММА(ВложенныйЗапрос.КоличествоВозвращено) КАК КоличествоВозвращено
	|ПОМЕСТИТЬ ВТ_ПродажиВозвратыПериода
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПродажиОбороты.Номенклатура КАК Номенклатура,
	|		ПродажиОбороты.Характеристика КАК Характеристика,
	|		СУММА(ВЫБОР
	|				КОГДА ПродажиОбороты.Регистратор ССЫЛКА Документ.РасходнаяНакладная
	|					ТОГДА ПродажиОбороты.КоличествоОборот
	|				ИНАЧЕ 0
	|			КОНЕЦ) КАК КоличествоПродано,
	|		СУММА(ВЫБОР
	|				КОГДА ПродажиОбороты.Регистратор ССЫЛКА Документ.ПриходнаяНакладная
	|					ТОГДА -ПродажиОбороты.КоличествоОборот
	|				ИНАЧЕ 0
	|			КОНЕЦ) КАК КоличествоВозвращено
	|	ИЗ
	|		РегистрНакопления.Продажи.Обороты(
	|				ДОБАВИТЬКДАТЕ(&Дата, ДЕНЬ, -1 * &КоличествоМесяцевКонтроля),
	|				КОНЕЦПЕРИОДА(&Дата, ДЕНЬ),
	|				Регистратор,
	|				Организация = &Организация
	|					И Контрагент = &Контрагент
	|					И (ВЫРАЗИТЬ(Документ КАК Документ.РасходнаяНакладная).Договор = &Договор
	|						ИЛИ ВЫРАЗИТЬ(Документ КАК Документ.ПриходнаяНакладная).Договор = &Договор)
	|					И (Номенклатура, Характеристика) В
	|						(ВЫБРАТЬ
	|							ВТ_ВозвратИтог.Номенклатура КАК Номенклатура,
	|							ВТ_ВозвратИтог.Характеристика КАК Характеристика
	|						ИЗ
	|							ВТ_ВозвратИтог КАК ВТ_ВозвратИтог)) КАК ПродажиОбороты
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ПродажиОбороты.Номенклатура,
	|		ПродажиОбороты.Характеристика) КАК ВложенныйЗапрос
	|
	|СГРУППИРОВАТЬ ПО
	|	ВложенныйЗапрос.Номенклатура,
	|	ВложенныйЗапрос.Характеристика
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Возврат.НомерСтроки КАК НомерСтроки,
	|	ВТ_Возврат.Номенклатура.Наименование КАК Номенклатура,
	|	ЕСТЬNULL(ВТ_Возврат.Характеристика.Наименование, """") КАК Характеристика,
	|	ВТ_Возврат.Количество КАК Количество,
	|	ВТ_ВозвратИтог.Количество КАК КоличествоИтого,
	|	ЕСТЬNULL(ВТ_ПродажиВозвратыПериода.КоличествоПродано, 0) - ЕСТЬNULL(ВТ_ПродажиВозвратыПериода.КоличествоВозвращено, 0) КАК КоличествоРазницаПродаж,
	|	ЕСТЬNULL(ВТ_ПродажиВозвратыПериода.КоличествоПродано, 0) КАК КоличествоПродано,
	|	ЕСТЬNULL(ВТ_ПродажиВозвратыПериода.КоличествоВозвращено, 0) КАК КоличествоВозвращено
	|ИЗ
	|	ВТ_Возврат КАК ВТ_Возврат
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ВозвратИтог КАК ВТ_ВозвратИтог
	|		ПО ВТ_Возврат.Номенклатура = ВТ_ВозвратИтог.Номенклатура
	|			И ВТ_Возврат.Характеристика = ВТ_ВозвратИтог.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПродажиВозвратыПериода КАК ВТ_ПродажиВозвратыПериода
	|		ПО ВТ_Возврат.Номенклатура = ВТ_ПродажиВозвратыПериода.Номенклатура
	|			И ВТ_Возврат.Характеристика = ВТ_ПродажиВозвратыПериода.Характеристика
	|ГДЕ
	|	ЕСТЬNULL(ВТ_ПродажиВозвратыПериода.КоличествоПродано, 0) - ЕСТЬNULL(ВТ_ПродажиВозвратыПериода.КоличествоВозвращено, 0) < ВТ_ВозвратИтог.Количество";
	
	Выборка = Запрос.Выполнить().Выбрать();
	МассивОшибок = Новый Массив;
	МассивСтрокНаУдаление = Новый Массив;
	Пока Выборка.Следующий() Цикл
	
		СтруктураСтрока = Новый Структура("НомерСтроки, Номенклатура, Характеристика, Количество, КоличествоИтого, КоличествоРазницаПродаж, КоличествоПродано, КоличествоВозвращено"
								, Выборка.НомерСтроки
								, Выборка.Номенклатура
								, Выборка.Характеристика
								, Выборка.Количество
								, Выборка.КоличествоИтого
								, Выборка.КоличествоРазницаПродаж
								, Выборка.КоличествоПродано
								, Выборка.КоличествоВозвращено
								);
		МассивОшибок.Добавить(СтруктураСтрока);
		МассивСтрокНаУдаление.Добавить(ЗаказНаВозврат[Выборка.НомерСтроки - 1]);
	
	КонецЦикла;
	Если МассивОшибок.Количество() Тогда
		
		ДополнительныеСвойства.Вставить("ОшибкиВозвратаТоваров", МассивОшибок);
		Для каждого ТекЭлемент Из МассивСтрокНаУдаление Цикл
		
			ЗаказНаВозврат.Удалить(ТекЭлемент);		
		
		КонецЦикла; 
		
	КонецЕсли; 

КонецПроцедуры

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если НЕ ДополнительныеСвойства.Свойство("НеВыполнятьПроверкуВозврата") Тогда
	
		УдалитьДвиженияПозаявкамНаВозвратПодчиненныхДокументов();
		ВыполнитьПроверкуВозвращаемыхТоваров();	
	
	КонецЕсли; 
	Если ЭтоНовый() И ( 
		ЗаказПокупателя.Количество() 
		+ ВозвратОтПокупателя.Количество() 
		+ Реализация.Количество() 
		+ ЗаказНаВозврат.Количество() 
		+ ВнутреннийЗаказ.Количество()
		+ ВнутреннийЗаказ1.Количество()) = 0
		И НЕ(ОбменДанными.Загрузка) // Kuzmich, 14.04.2024, (ONESOFT-3020) ხარვეზი დისტრიბუციის აპლიკაციიდან ფულის დოკუმენტის შექმნისას
		Тогда
	
		Отказ = Истина;
	
	КонецЕсли; 
	
КонецПроцедуры

Процедура УдалитьДвиженияПозаявкамНаВозвратПодчиненныхДокументов() Экспорт

	Если НЕ ЭтоНовый() Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаВозврат.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
		|ГДЕ
		|	ЗаказНаВозврат.ДокументВизита = &ДокументВизита
		|	И ЗаказНаВозврат.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПриходнаяНакладная.Ссылка
		|ИЗ
		|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
		|ГДЕ
		|	ПриходнаяНакладная.ДокументВизита = &ДокументВизита
		|	И ПриходнаяНакладная.Проведен";
		
		Запрос.УстановитьПараметр("ДокументВизита", Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			НаборЗаписей = РегистрыНакопления.ЗаявкиНаВозврат.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Ссылка);
			НаборЗаписей.Прочитать();
			НаборЗаписей.Очистить();
			НаборЗаписей.Записать();
			Если ТипЗнч(Выборка.Ссылка) = Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			
				НаборЗаписей = РегистрыНакопления.Продажи.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Ссылка);
				НаборЗаписей.Прочитать();
				НаборЗаписей.Очистить();
				НаборЗаписей.Записать();
			
			КонецЕсли; 
			
		КонецЦикла;
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли; 	

КонецПроцедуры
 
 	
