//Паганини
Процедура СоздатьПроизводство(Отказ)
	
	пПроизводство1 = Документы.СборкаЗапасов.НайтиПоРеквизиту("ОснованиеПроизводство", Ссылка);
	//Если пПроизводство1.Проведен Тогда
	//	ТекстСообщения = "მოცემული დოკუმენტის საფუძველზე უკვე გატარებულია დოკუმენტი """ + Строка(пПроизводство1) +
	//					 """. წარმოების გასაგრძელებლად აუცილებელია მოცემულ დოკუმენტზე გატარების მოხსნა.";
	//	УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,,,,Отказ);
	//	Возврат;
	//КонецЕсли;

	//1.
	ЗапросДляСкладаСписания = Новый Запрос;
	ЗапросДляСкладаСписания.УстановитьПараметр("Дата", 				Новый Граница(Новый МоментВремени(Дата),	ВидГраницы.Включая));
	ЗапросДляСкладаСписания.Текст =
		"ВЫБРАТЬ
		|	СкладАтоматическогоПроизводстваСрезПоследних.Склад
		|ИЗ
		|	РегистрСведений.СкладАтоматическогоПроизводства.СрезПоследних(&Дата, ) КАК СкладАтоматическогоПроизводстваСрезПоследних";
	РезультатЗапроса = ЗапросДляСкладаСписания.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		СкладДляСписания = РезультатЗапроса.Склад;
	Иначе
		ТекстСообщения = "მოცემული პერიოდისთვის არ არის მითითებული ""ავტომატური წარმოების საწყობი"". შეუძლებელია წარმოების ფორმირება";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,,,,Отказ);
		Возврат;
	КонецЕсли;
	
	//2.
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.УстановитьПараметр("Дата", 						Новый Граница(Новый МоментВремени(Дата),	ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Ссылка", 					Ссылка);
	Запрос.УстановитьПараметр("Организация", 				Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиницаЗапасов", 	СтруктурнаяЕдиницаЗапасов);
	Запрос.УстановитьПараметр("СкладДляСписания", 			СкладДляСписания);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СборкаЗапасовЗапасы.Номенклатура,
		|	СУММА(ВЫБОР
		|			КОГДА СборкаЗапасовЗапасы.ЕдиницаИзмерения ССЫЛКА Справочник.КлассификаторЕдиницИзмерения
		|				ТОГДА СборкаЗапасовЗапасы.Количество
		|			ИНАЧЕ СборкаЗапасовЗапасы.Количество * СборкаЗапасовЗапасы.ЕдиницаИзмерения.Коэффициент
		|		КОНЕЦ) КАК Количество
		|ПОМЕСТИТЬ ЗапасыДокумента
		|ИЗ
		|	Документ.СборкаЗапасов.Запасы КАК СборкаЗапасовЗапасы
		|ГДЕ
		|	СборкаЗапасовЗапасы.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	СборкаЗапасовЗапасы.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыДокумента.Номенклатура,
		|	ЗапасыДокумента.Номенклатура КАК Аналог,
		|	0 КАК Приоритет
		|ПОМЕСТИТЬ АналогиПред
		|ИЗ
		|	ЗапасыДокумента КАК ЗапасыДокумента
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	АналогиНоменклатуры.Номенклатура,
		|	АналогиНоменклатуры.Аналог,
		|	АналогиНоменклатуры.Приоритет + 1
		|ИЗ
		|	РегистрСведений.АналогиНоменклатуры КАК АналогиНоменклатуры
		|ГДЕ
		|	АналогиНоменклатуры.Номенклатура В
		|			(ВЫБРАТЬ
		|				ЗапасыДокумента.Номенклатура
		|			ИЗ
		|				ЗапасыДокумента КАК ЗапасыДокумента)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АналогиПред.Номенклатура,
		|	АналогиПред.Аналог КАК Аналог,
		|	МИНИМУМ(АналогиПред.Приоритет) КАК Приоритет
		|ПОМЕСТИТЬ Аналоги
		|ИЗ
		|	ЗапасыДокумента КАК ЗапасыДокумента,
		|	АналогиПред КАК АналогиПред
		|
		|СГРУППИРОВАТЬ ПО
		|	АналогиПред.Номенклатура,
		|	АналогиПред.Аналог
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ЗапасыОбороты.Номенклатура,
		|	СУММА(ЗапасыОбороты.КоличествоОборот) КАК КоличествоОстаток
		|ПОМЕСТИТЬ ОстаткиПред
		|ИЗ
		|	РегистрНакопления.Запасы.Обороты(
		|			,
		|			&Дата,
		|			Авто,
		|			Организация = &Организация
		|				И СтруктурнаяЕдиница В (&СтруктурнаяЕдиницаЗапасов, &СкладДляСписания)
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						Аналоги.Аналог
		|					ИЗ
		|						Аналоги КАК Аналоги)) КАК ЗапасыОбороты
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОбороты.СтруктурнаяЕдиница,
		|	ЗапасыОбороты.Номенклатура
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗапасыОбороты.СтруктурнаяЕдиница,
		|	ЗапасыОбороты.Номенклатура,
		|	СУММА(ВЫБОР
		|			КОГДА ЗапасыОбороты.КоличествоОборот > 0
		|				ТОГДА ЗапасыОбороты.КоличествоОборот
		|			ИНАЧЕ -ЗапасыОбороты.КоличествоОборот
		|		КОНЕЦ)
		|ИЗ
		|	РегистрНакопления.Запасы.Обороты(
		|			,
		|			,
		|			Авто,
		|			Организация = &Организация
		|				И СтруктурнаяЕдиница В (&СтруктурнаяЕдиницаЗапасов, &СкладДляСписания)
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						Аналоги.Аналог
		|					ИЗ
		|						Аналоги КАК Аналоги)) КАК ЗапасыОбороты
		|ГДЕ
		|	ЗапасыОбороты.Регистратор = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОбороты.Номенклатура,
		|	ЗапасыОбороты.СтруктурнаяЕдиница
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыОстаткиПред.СтруктурнаяЕдиница,
		|	ЗапасыОстаткиПред.Номенклатура,
		|	СУММА(ЗапасыОстаткиПред.КоличествоОстаток) КАК КоличествоОстаток
		|ПОМЕСТИТЬ Остатки
		|ИЗ
		|	ОстаткиПред КАК ЗапасыОстаткиПред
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстаткиПред.СтруктурнаяЕдиница,
		|	ЗапасыОстаткиПред.Номенклатура
		|
		|ИМЕЮЩИЕ
		|	СУММА(ЗапасыОстаткиПред.КоличествоОстаток) > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыДокумента.Номенклатура,
		|	ЗапасыДокумента.Количество - ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Количество
		|ПОМЕСТИТЬ ЗапасыДляСписания
		|ИЗ
		|	ЗапасыДокумента КАК ЗапасыДокумента
		|		ЛЕВОЕ СОЕДИНЕНИЕ Остатки КАК Остатки
		|		ПО ЗапасыДокумента.Номенклатура = Остатки.Номенклатура
		|			И (&СтруктурнаяЕдиницаЗапасов = Остатки.СтруктурнаяЕдиница)
		|ГДЕ
		|	ЗапасыДокумента.Количество > ЕСТЬNULL(Остатки.КоличествоОстаток, 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ЗапасыДокумента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ АналогиПред
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ОстаткиПред";
	Запрос.Выполнить();

	
	//3.
	ЗапросНужнаСписать = Новый Запрос;
	ЗапросНужнаСписать.МенеджерВременныхТаблиц = МВТ;
	ЗапросНужнаСписать.Текст =
		"ВЫБРАТЬ
		|	ЗапасыДляСписания.Номенклатура,
		|	ЗапасыДляСписания.Количество
		|ИЗ
		|	ЗапасыДляСписания КАК ЗапасыДляСписания";
	ТаблицаНужнаСписать = ЗапросНужнаСписать.Выполнить().Выгрузить();
	Если ТаблицаНужнаСписать.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	//4.	
	ЗапросОстатков = Новый Запрос;
	ЗапросОстатков.МенеджерВременныхТаблиц = МВТ;
	ЗапросОстатков.Текст =
		"ВЫБРАТЬ
		|	Аналоги.Номенклатура КАК Номенклатура,
		|	Остатки.Номенклатура КАК Аналог,
		|	Аналоги.Приоритет КАК Приоритет,
		|	Остатки.КоличествоОстаток
		|ИЗ
		|	Остатки КАК Остатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Аналоги КАК Аналоги
		|		ПО Остатки.Номенклатура = Аналоги.Аналог
		|ГДЕ
		|	Остатки.СтруктурнаяЕдиница = &СкладДляСписания
		|
		|УПОРЯДОЧИТЬ ПО
		|	Аналоги.Номенклатура,
		|	Приоритет";
	ЗапросОстатков.УстановитьПараметр("СкладДляСписания", 			СкладДляСписания);
	ТаблицаОстатков = ЗапросОстатков.Выполнить().Выгрузить();
	Если ТаблицаОстатков.Количество() = 0 Тогда
		ТекстСообщения = "მოცემული მარაგების დასაკომპლექტებლად არ მოიძებნა ნაშთები საწყობში """ + СкладДляСписания+ """.";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,,,,Отказ);
		Возврат;
	КонецЕсли;
	
	//Создать Документ
	Если ЗначениеЗаполнено(пПроизводство1) Тогда
		СсылкапПроизводство1 = пПроизводство1.ПолучитьОбъект();
		СсылкапПроизводство1.Продукция.Очистить();
		СсылкапПроизводство1.Запасы.Очистить();
		СсылкапПроизводство1.Отходы.Очистить();
		СсылкапПроизводство1.СерийныеНомера.Очистить();
		СсылкапПроизводство1.СерийныеНомераПродукция.Очистить();
		СсылкапПроизводство1.ПометкаУдаления = Ложь;
	Иначе
		СсылкапПроизводство1 = Документы.СборкаЗапасов.СоздатьДокумент();
	КонецЕсли;
	
	СсылкапПроизводство1.Дата							= Дата - 1;
	СсылкапПроизводство1.ВидОперации					= Перечисления.ВидыОперацийСборкаЗапасов.Сборка;
	СсылкапПроизводство1.Организация					= Организация;
	СсылкапПроизводство1.ОснованиеПроизводство			= Ссылка;
	СсылкапПроизводство1.Автор							= ПараметрыСеанса.ТекущийПользователь;
	СсылкапПроизводство1.СтруктурнаяЕдиница				= СкладДляСписания;
	СсылкапПроизводство1.СтруктурнаяЕдиницаЗапасов		= СкладДляСписания;
	СсылкапПроизводство1.СтруктурнаяЕдиницаПродукции	= СтруктурнаяЕдиницаЗапасов;
	СсылкапПроизводство1.СтруктурнаяЕдиницаОтходов		= СтруктурнаяЕдиницаЗапасов;
	
	Для Каждого СтрокаНС Из ТаблицаНужнаСписать Цикл
		ОсталосьСписать = СтрокаНС.Количество;//Перем
		НайденныеСтрокиОстатка = ТаблицаОстатков.НайтиСтроки(Новый Структура("Номенклатура", СтрокаНС.Номенклатура));
		Если НайденныеСтрокиОстатка.Количество() = 0 Тогда
			ТекстСообщения = "მარაგის დასაკომპლექტებლად """ + СтрокаНС.Номенклатура + """ არ არის საკმარისი """ + ОсталосьСписать + СтрокаНС.Номенклатура.ЕдиницаИзмерения + """ საწყობში """ + СкладДляСписания + """. ";
			УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,,,,Отказ);
			Возврат;	
		КонецЕсли;
		
		СтрПродукция = СсылкапПроизводство1.Продукция.Добавить();
		СтрПродукция.Номенклатура		= СтрокаНС.Номенклатура;
		СтрПродукция.ЕдиницаИзмерения	= СтрПродукция.Номенклатура.ЕдиницаИзмерения;
		СтрПродукция.Количество			= СтрокаНС.Количество;
		
		Для Каждого СтрокаОСТ ИЗ НайденныеСтрокиОстатка Цикл
			//
			СписываемоеКоличество	= Мин(ОсталосьСписать, СтрокаОСТ.КоличествоОстаток);//Перем
			ОсталосьСписать			= ОсталосьСписать - СписываемоеКоличество;          //Перем
			
			//
			Если СписываемоеКоличество = 0 Тогда
				ТекстСообщения = "მარაგის დასაკომპლექტებლად """ + СтрокаНС.Номенклатура + """ არ არის საკმარისი """ + ОсталосьСписать + СтрокаНС.Номенклатура.ЕдиницаИзмерения + """ საწყობში """ + СкладДляСписания + """. ";
				УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,,,,Отказ);
				Прервать;
			КонецЕсли;
			СтрЗапасы = СсылкапПроизводство1.Запасы.Добавить();
			СтрЗапасы.Номенклатура		= СтрокаОСТ.Аналог;
			СтрЗапасы.ЕдиницаИзмерения	= СтрЗапасы.Номенклатура.ЕдиницаИзмерения;
			СтрЗапасы.Количество		= СписываемоеКоличество;
			
			//
			СтрокаНС.Количество		= СтрокаНС.Количество - СписываемоеКоличество;
			Если СтрокаНС.Количество = 0 Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ОсталосьСписать > 0 Тогда
			ТекстСообщения = "მარაგის დასაკომპლექტებლად """ + СтрокаНС.Номенклатура + """ არ არის საკმარისი """ + ОсталосьСписать + СтрокаНС.Номенклатура.ЕдиницаИзмерения + """ საწყობში """ + СкладДляСписания + """. ";
			УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(ЭтотОбъект, ТекстСообщения,,,,Отказ);
		КонецЕсли;
	КонецЦикла;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	//Возврат;
	
	Попытка	
		СсылкапПроизводство1.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(СсылкапПроизводство1, ОписаниеОшибки(),,,,Отказ);
	КонецПопытки;
	
КонецПроцедуры

