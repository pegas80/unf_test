		//ОбластьПодвал.Параметры.ИтогоЦена = Формат(ИтогоЦена, "ЧДЦ=2");
		
		ОбластьПодвал.Параметры.НомерДатаДоговора = НомерПриемаПечать + " от " + СтрЗаменить(Формат(ДатаПриема,"Л=ru_RU; ДЛФ=DD"), "г.", "года");
		ОбластьПодвал.Параметры.НомерДатаДоговораГру = СтрЗаменить(СтрЗаменить(Формат(ДатаПриема,"Л=ka_GE; ДФ=yyyy"), ".", " ") + " წლის " + СтрЗаменить(Формат(ДатаПриема,"Л=ka_GE; ДФ=d.MMMM"), ".", " "), МесяцДатыТекстомПлатформа, МесяцДатыТекстомДляПФ) + " გაფორმებული №" + НомерПриемаПечать;
		ОбластьПодвал.Параметры.ЦенаЛари = Цел(ИтогоЦена);
		ОбластьПодвал.Параметры.ЦенаТетри = (ИтогоЦена - Цел(ИтогоЦена)) * 100;
		
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
	КонецЦикла;
	
КонецПроцедуры // СформироватьНакладную()

Функция ПлучитьДокументПринятнияНаРаботу(Сотрудник)

	СтуркутраПриемаНаРаботу = Новый Структура("ДатаПриема, НомерПриема, НомерПаспорта");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиСрезПервых.Период КАК Период,
		|	СотрудникиСрезПервых.Регистратор.Номер КАК РегистраторНомер,
		|	ЕСТЬNULL(ДокументыФизическихЛицСрезПоследних.Серия, """") КАК Серия,
		|	ЕСТЬNULL(ДокументыФизическихЛицСрезПоследних.Номер, """") КАК Номер
		|ИЗ
		|	РегистрСведений.Сотрудники.СрезПервых(, Сотрудник = &Сотрудник) КАК СотрудникиСрезПервых
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних(, ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ПаспортГР)) КАК ДокументыФизическихЛицСрезПоследних
		|		ПО СотрудникиСрезПервых.Сотрудник.Физлицо = ДокументыФизическихЛицСрезПоследних.Физлицо";
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтуркутраПриемаНаРаботу.ДатаПриема = ВыборкаДетальныеЗаписи.Период;
		СтуркутраПриемаНаРаботу.НомерПриема = ВыборкаДетальныеЗаписи.РегистраторНомер;
		СтуркутраПриемаНаРаботу.НомерПаспорта = ВыборкаДетальныеЗаписи.Серия + ВыборкаДетальныеЗаписи.Номер;
	КонецЦикла;
	
	Возврат СтуркутраПриемаНаРаботу;

КонецФункции // ПлучитьДокументПринятнияНаРаботу(ВыборкаРезультат.ОтветственноеЛицо)()

Функция ПоменятьПоследнююБукву(МесяцДатыТекстомПлатформа)
	
	ДлиннаТекста = СтрДлина(МесяцДатыТекстомПлатформа);
	
	НовыйВариант = Лев(МесяцДатыТекстомПлатформа, ДлиннаТекста-1) + "ს";
	
	Возврат НовыйВариант;
	
КонецФункции

