
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаПеремещениеВА);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ВалютаУчета", УправлениеНебольшойФирмойПовтИсп.ПолучитьВалютуУчета());
	
	//ПодольскийАИ #УчетПроектов 10.12.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 10.12.2020 }
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПеремещениеВА.Ссылка,
	|	ПеремещениеВА.Номер,
	|	ПеремещениеВА.Дата,
	|	ПеремещениеВА.Организация
	|ПОМЕСТИТЬ ВременнаяТаблицаШапка
	|ИЗ
	|	Документ.ПеремещениеВА КАК ПеремещениеВА
	|ГДЕ
	|	ПеремещениеВА.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка,
	|	ПеремещениеВАВнеоборотныеАктивы.НомерСтроки,
	|	ПеремещениеВАВнеоборотныеАктивы.ВнеоборотныйАктив,
	|	ПеремещениеВАВнеоборотныеАктивы.СтруктурнаяЕдиница,
	|	ПеремещениеВАВнеоборотныеАктивы.СтруктурнаяЕдиницаПолучатель,
	|	ПеремещениеВАВнеоборотныеАктивы.Адрес,
	|	ПеремещениеВАВнеоборотныеАктивы.АдресПолучатель,
	|	ПеремещениеВАВнеоборотныеАктивы.ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	ПеремещениеВАВнеоборотныеАктивы.ПервоначальнаяСтоимость,
	|	ПеремещениеВАВнеоборотныеАктивы.НачислятьАмортизациюВТекущемМесяце,
	|	ПеремещениеВАВнеоборотныеАктивы.СрокИспользованияДляВычисленияАмортизации,
	|	ПеремещениеВАВнеоборотныеАктивы.СтоимостьДляВычисленияАмортизации КАК СтоимостьДляВычисленияАмортизации,
	|	ПеремещениеВАВнеоборотныеАктивы.СчетЗатрат,
	|	ПеремещениеВАВнеоборотныеАктивы.НаправлениеДеятельности,
	|	ПеремещениеВАВнеоборотныеАктивы.СчетЗатратРегл,
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка.Дата КАК Период,
	|	&ВалютаУчета КАК Валюта,
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка.Организация КАК Организация,
	|	ПеремещениеВАВнеоборотныеАктивы.ГодовойПроцентАмортизацииДляУменьшенногоОстатка КАК ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
	|	ПеремещениеВАВнеоборотныеАктивы.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка КАК ЛиквидационнаяСтоимостьДляУменьшенногоОстатка,
	//ПодольскийАИ #УчетПроектов 08.12.2020 {
	|	Выбор 
	|		Когда &УчетПоПроектам 
	|			Тогда ПеремещениеВАВнеоборотныеАктивы.Проект
	|		Иначе Значение(Справочник.Проекты.ПустаяСсылка)
	|	Конец КАК Проект,
	|	Выбор 
	|		Когда &УчетПоПроектам 
	|			Тогда ПеремещениеВАВнеоборотныеАктивы.ПроектПолучатель
	|		Иначе Значение(Справочник.Проекты.ПустаяСсылка)
	|	Конец КАК ПроектПолучатель 
	//+++ Дмгг
	|,
	|	ВЫБОР
	|		КОГДА ФункциональнаяОпцияЗаполненияОтветственногоЛицаВДокументеПеремещениеВА.Значение
	|			ТОГДА ПеремещениеВАВнеоборотныеАктивы.ОтветственноеЛицо
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|	КОНЕЦ КАК ОтветственноеЛицо,
	|	ВЫБОР
	|		КОГДА ФункциональнаяОпцияЗаполненияОтветственногоЛицаВДокументеПеремещениеВА.Значение
	|			ТОГДА ПеремещениеВАВнеоборотныеАктивы.РыночнаяЦена
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Цена
	|,
	|	ПеремещениеВАВнеоборотныеАктивы.Амортизация,
	|	ПеремещениеВАВнеоборотныеАктивы.ВидОперации
	//ПодольскийАИ #УчетПроектов 08.12.2020 }
	|ПОМЕСТИТЬ ВременнаяТаблицаВнеоборотныхАктивов
	|ИЗ
	|	Документ.ПеремещениеВА.ВнеоборотныеАктивы КАК ПеремещениеВАВнеоборотныеАктивы
	|,	Константа.ФункциональнаяОпцияЗаполненияОтветственногоЛицаВДокументеПеремещениеВА КАК ФункциональнаяОпцияЗаполненияОтветственногоЛицаВДокументеПеремещениеВА //+++ Дмгг
	|ГДЕ
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка = &Ссылка";
	
	Запрос.ВыполнитьПакет();
	
	// Формирование таблиц движений по разделам учета.
	СформироватьТаблицаПараметрыВнеоборотныхАктивов(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства);
	
	//ПодольскийАИ #УчетПроектов 08.12.2020 {
	СформироватьТаблицаУчетПоПроектамВнеоборотныхАктивов(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства);
	//ПодольскийАИ #УчетПроектов 08.12.2020 }
	
	СформироватьТаблицаСостоянияВнеоборотныхАктивов(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства);
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_ПеремещениеВА(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства);
	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаПараметрыВнеоборотныхАктивов(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ТаблицаДокумента.СтруктурнаяЕдиницаПолучатель КАК СтруктурнаяЕдиница,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.ОбъемПродукцииРаботДляВычисленияАмортизации КАК ОбъемПродукцииРаботДляВычисленияАмортизации,	
	|	ТаблицаДокумента.НачислятьАмортизациюВТекущемМесяце КАК ПрименитьВТекущемМесяце,
	|	ТаблицаДокумента.СрокИспользованияДляВычисленияАмортизации КАК СрокИспользованияДляВычисленияАмортизации,
	|	ТаблицаДокумента.СтоимостьДляВычисленияАмортизации КАК СтоимостьДляВычисленияАмортизации,
	|	ТаблицаДокумента.СчетЗатрат КАК СчетЗатрат,
	|	ТаблицаДокумента.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ТаблицаДокумента.АдресПолучатель КАК Адрес,
	|	ТаблицаДокумента.СчетЗатратРегл КАК СчетЗатратРегл,
	|	ТаблицаДокумента.ГодовойПроцентАмортизацииДляУменьшенногоОстатка КАК ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
	|	ТаблицаДокумента.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка КАК ЛиквидационнаяСтоимостьДляУменьшенногоОстатка,
	//+++ Дмгг
	|	ТаблицаДокумента.ОтветственноеЛицо КАК ОтветственноеЛицо,
	|	ТаблицаДокумента.Цена КАК Цена,
	|	ТаблицаДокумента.ВидОперации
	//--- Дмгг
	|ИЗ
	|	ВременнаяТаблицаВнеоборотныхАктивов КАК ТаблицаДокумента
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаПараметрыВнеоборотныхАктивов", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаПараметрыВнеоборотныхАктивов()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаСостоянияВнеоборотныхАктивов(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.Амортизация КАК НачислятьАмортизацию,
	|	ТаблицаДокумента.НачислятьАмортизациюВТекущемМесяце КАК НачислятьАмортизациюВТекущемМесяце,
	|	ЗНАЧЕНИЕ(Перечисление.СостоянияВнеоборотныхАктивов.ПринятКУчету) КАК Состояние
	//--- Дмгг
	|ИЗ
	|	ВременнаяТаблицаВнеоборотныхАктивов КАК ТаблицаДокумента
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаСостоянияВнеоборотныхАктивов", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаПараметрыВнеоборотныхАктивов()

//ПодольскийАИ #УчетПроектов 08.12.2020 {
// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаУчетПоПроектамВнеоборотныхАктивов(ДокументСсылкаПеремещениеВА, СтруктураДополнительныеСвойства)
	
	Если Не СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.Период КАК Период,
	|	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.Проект КАК ПроектТекущий,
	|	ТаблицаДокумента.ПроектПолучатель КАК Проект
	|ИЗ
	|	ВременнаяТаблицаВнеоборотныхАктивов КАК ТаблицаДокумента
	|ГДЕ
	|	ТаблицаДокумента.Проект <> ТаблицаДокумента.ПроектПолучатель
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаУчетПоПроектамВнеоборотныхАктивов", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаПараметрыВнеоборотныхАктивов()

//ПодольскийАИ #УчетПроектов 08.12.2020 }

#Область ИнтерфейсПечати

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	Перем Ошибки;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_АктПриемаПередачи") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,              
															"ПФ_MXL_АктПриемаПередачи", 
															НСтр("ru = 'Акт приема-передачи'; en = 'Акт приема-передачи'; ka = 'მიღება ჩაბარების აქტი'"), 
															ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_АктПриемаПередачи"));
															
	ИначеЕсли УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_АктПриемаПередачиВозврат") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,              
															"ПФ_MXL_АктПриемаПередачиВозврат", 
															НСтр("ru = 'Акт приема-передачи Возврат'; en = 'Акт приема-передачи Возврат'; ka = 'მიღება ჩაბარების აქტი დაბრუნება'"), 
															ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, "ПФ_MXL_АктПриемаПередачиВозврат"));
		
	КонецЕсли;
	

	Если Ошибки <> Неопределено Тогда
		
		ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки);
		
	КонецЕсли;
	
	// параметры отправки печатных форм по электронной почте
	УправлениеНебольшойФирмойСервер.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
	
КонецПроцедуры

// Сформировать печатные формы объектов
//
Функция ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	Перем Ошибки;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	ПервыйДокумент = Истина;
	
	Для Каждого ТекущийДокумент Из МассивОбъектов Цикл
	
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Если ИмяМакета = "ПФ_MXL_АктПриемаПередачи" Тогда
			
			СформироватьАктПриемаПередачи(ТабличныйДокумент, ТекущийДокумент);
			
		ИначеЕсли ИмяМакета = "ПФ_MXL_АктПриемаПередачиВозврат" Тогда
			
			СформироватьАктПриемаПередачиВозврат(ТабличныйДокумент, ТекущийДокумент);
			
		КонецЕсли;

		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки);
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	ЗначениеИдентификатора = "ПФ_MXL_АктПриемаПередачи";
	//ЗначениеИдентификатора = СтрШаблон(ЗначениеИдентификатора, Обработки.ПечатьАктПередачиПрав.ИдентификаторПечатнойФормы());
	
	Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ФункциональнаяОпцияЗаполненияОтветственногоЛицаВДокументеПеремещениеВА") Тогда 
		КомандаПечати = КомандыПечати.Добавить();
		КомандаПечати.Идентификатор = "ПФ_MXL_АктПриемаПередачи";
		КомандаПечати.Представление = НСтр("ru = 'Акт приема-передачи'; en = 'Акт приема-передачи'; ka = 'მიღება ჩაბარების აქტი'");
		КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
		КомандаПечати.Порядок = 32;
		
		КомандаПечати = КомандыПечати.Добавить();
		КомандаПечати.Идентификатор = "ПФ_MXL_АктПриемаПередачиВозврат";
		КомандаПечати.Представление = НСтр("ru = 'Акт приема-передачи Возврат'; en = 'Акт приема-передачи Возврат'; ka = 'მიღება ჩაბარების აქტი დაბრუნება'");
		КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
		КомандаПечати.Порядок = 33;
		
	КонецЕсли;

КонецПроцедуры

Процедура СформироватьАктПриемаПередачи(ТабличныйДокумент, ТекущийДокумент)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка КАК Ссылка,
	|	ПеремещениеВАВнеоборотныеАктивы.НомерСтроки КАК НомерСтроки,
	|	ПеремещениеВАВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ПеремещениеВАВнеоборотныеАктивы.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПеремещениеВАВнеоборотныеАктивы.СтруктурнаяЕдиницаПолучатель КАК СтруктурнаяЕдиницаПолучатель,
	|	ПеремещениеВАВнеоборотныеАктивы.Адрес КАК Адрес,
	|	ПеремещениеВАВнеоборотныеАктивы.АдресПолучатель КАК АдресПолучатель,
	|	ПеремещениеВАВнеоборотныеАктивы.ОбъемПродукцииРаботДляВычисленияАмортизации КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	ПеремещениеВАВнеоборотныеАктивы.ПервоначальнаяСтоимость КАК ПервоначальнаяСтоимость,
	|	ПеремещениеВАВнеоборотныеАктивы.НачислятьАмортизациюВТекущемМесяце КАК НачислятьАмортизациюВТекущемМесяце,
	|	ПеремещениеВАВнеоборотныеАктивы.СрокИспользованияДляВычисленияАмортизации КАК СрокИспользованияДляВычисленияАмортизации,
	|	ПеремещениеВАВнеоборотныеАктивы.СчетЗатрат КАК СчетЗатрат,
	|	ПеремещениеВАВнеоборотныеАктивы.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ПеремещениеВАВнеоборотныеАктивы.СчетЗатратРегл КАК СчетЗатратРегл,
	|	ПеремещениеВАВнеоборотныеАктивы.СтоимостьДляВычисленияАмортизации КАК СтоимостьДляВычисленияАмортизации,
	|	ПеремещениеВАВнеоборотныеАктивы.ГодовойПроцентАмортизацииДляУменьшенногоОстатка КАК ГодовойПроцентАмортизацииДляУменьшенногоОстатка,
	|	ПеремещениеВАВнеоборотныеАктивы.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка КАК ЛиквидационнаяСтоимостьДляУменьшенногоОстатка,
	|	ПеремещениеВАВнеоборотныеАктивы.Проект КАК Проект,
	|	ПеремещениеВАВнеоборотныеАктивы.ПроектПолучатель КАК ПроектПолучатель,
	|	ПеремещениеВАВнеоборотныеАктивы.ОтветственноеЛицо КАК ОтветственноеЛицо,
	|	ПеремещениеВАВнеоборотныеАктивы.РыночнаяЦена КАК РыночнаяЦена,
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка.Дата КАК Дата,
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка.Организация.ИНН КАК ИНН,
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка.Организация.Представление КАК Организация
	|ИЗ
	|	Документ.ПеремещениеВА.ВнеоборотныеАктивы КАК ПеремещениеВАВнеоборотныеАктивы
	|ГДЕ
	|	ПеремещениеВАВнеоборотныеАктивы.Ссылка = &ТекущийДокумент
	|
	|УПОРЯДОЧИТЬ ПО
	|	ОтветственноеЛицо
	|ИТОГИ ПО
	|	ОтветственноеЛицо";
	
	ВыборкаРезультат = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПеремещениеВА.ПФ_MXL_АктПриемаПередачи");
	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьСтрокаТаблицы = Макет.ПолучитьОбласть("СтрокаТаблицы");
	ОбластьПустаяСтрока = Макет.ПолучитьОбласть("ПустаяСтрока");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	Пока ВыборкаРезультат.Следующий() Цикл 
		
		СтруктураПринятияНаРаботу = ПлучитьДокументПринятнияНаРаботу(ВыборкаРезультат.ОтветственноеЛицо);
		
		
		ОбластьЗаголовок.Параметры.ДатаРус = Формат(ТекущийДокумент.Дата,"ДФ=dd.MM.yyyy") + " г.";
		ОбластьЗаголовок.Параметры.ДатаГру = Формат(ТекущийДокумент.Дата,"ДФ=dd.MM.yyyy") + " წ.";
		ОбластьЗаголовок.Параметры.Организация = ТекущийДокумент.Организация;
		ОбластьЗаголовок.Параметры.ИНН = ТекущийДокумент.Организация.ИНН;
		ОбластьЗаголовок.Параметры.Сотрудник = ВыборкаРезультат.ОтветственноеЛицо;
		ОбластьЗаголовок.Параметры.СотрудникРус = ВыборкаРезультат.ОтветственноеЛицо.НаименованиеНаИностранскомЯзыке;
		ОбластьЗаголовок.Параметры.ДокументСотрудника = ВыборкаРезультат.ОтветственноеЛицо.Физлицо.ИНН;//СтруктураПринятияНаРаботу.НомерПаспорта;
		НомерПриема = ?(СтруктураПринятияНаРаботу.НомерПриема= Неопределено, "", СтруктураПринятияНаРаботу.НомерПриема);
		ДатаПриема = ?(СтруктураПринятияНаРаботу.ДатаПриема= Неопределено, "", СтруктураПринятияНаРаботу.ДатаПриема);
		НомерПриемаПечать = ПрефиксацияОбъектовКлиентСервер.ПолучитьНомерНаПечать(НомерПриема, Истина, Истина);
		ОбластьЗаголовок.Параметры.НомерДатаДоговора = НомерПриемаПечать + " от " + СтрЗаменить(Формат(ДатаПриема,"Л=ru_RU; ДЛФ=DD"), "г.", "года");
		МесяцДатыТекстомПлатформа = Формат(ДатаПриема,"Л=ka_GE; ДФ=MMMM");
		МесяцДатыТекстомДляПФ = ПоменятьПоследнююБукву(МесяцДатыТекстомПлатформа);
		ОбластьЗаголовок.Параметры.НомерДатаДоговораГру = СтрЗаменить(СтрЗаменить(Формат(ДатаПриема,"Л=ka_GE; ДФ=yyyy"), ".", " ") + " წლის " + СтрЗаменить(Формат(ДатаПриема,"Л=ka_GE; ДФ=d.MMMM"), ".", " "), МесяцДатыТекстомПлатформа, МесяцДатыТекстомДляПФ) + " გაფორმებული №" + НомерПриемаПечать;
		
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		//Для Каждого Строк Из ВыборкаСтрокВА Цикл 
		НПП = 1;
		ИтогоЦена = 0;
		РезультатТаблица = ВыборкаРезультат.Выбрать();
		Пока РезультатТаблица.Следующий() Цикл
			
			ОбластьСтрокаТаблицы.Параметры.НПП = НПП;
			ОбластьСтрокаТаблицы.Параметры.ОсновноеСредство = РезультатТаблица.ВнеоборотныйАктив;
			ОбластьСтрокаТаблицы.Параметры.Количество = 1;
			ОбластьСтрокаТаблицы.Параметры.Цена = Формат(РезультатТаблица.РыночнаяЦена, "ЧДЦ=2");
			
			НПП = НПП + 1;
			ИтогоЦена = ИтогоЦена + РезультатТаблица.РыночнаяЦена;
			ТабличныйДокумент.Вывести(ОбластьСтрокаТаблицы);
			
		КонецЦикла;
		
		ТабличныйДокумент.Вывести(ОбластьПустаяСтрока);
		
		ОбластьПодвал.Параметры.ИтогоЦена = Формат(ИтогоЦена, "ЧДЦ=2");
		
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
	КонецЦикла;
	
КонецПроцедуры // СформироватьНакладную()

