	РезультатЗапроса = Запрос.Выполнить();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаУправленческий", РезультатЗапроса.Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаУправленческий()

Процедура СформироватьТаблицаРасчетыСПерсоналом(ДокументСсылкаВзаимозачет, СтруктураДополнительныеСвойства);

	ТаблицаСотрудники = Новый ТаблицаЗначений;
	ТаблицаСотрудники.Колонки.Добавить("Сотрудник", 				Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаСотрудники.Колонки.Добавить("ПенсионныйФонд",			Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	ТаблицаСотрудники.Колонки.Добавить("ДоговорПенсионногоФонда",	Новый ОписаниеТипов("СправочникСсылка.ДоговорыКонтрагентов"));
	ТаблицаСотрудники.Колонки.Добавить("ВидУдержанияПФ",			Новый ОписаниеТипов("СправочникСсылка.ВидыНачисленийИУдержаний"));
	ТаблицаСотрудники.Колонки.Добавить("ВидУдержанияНДФЛ",			Новый ОписаниеТипов("СправочникСсылка.ВидыНачисленийИУдержаний"));
	ТаблицаСотрудники.Колонки.Добавить("ВидНалога",					Новый ОписаниеТипов("СправочникСсылка.ВидыНалогов"));
	ТаблицаСотрудники.Колонки.Добавить("ВидНалогаВыплат",			Новый ОписаниеТипов("СправочникСсылка.ВидыНалогов"));	
	ТаблицаСотрудники.Колонки.Добавить("ПериодРегистрации",			Новый ОписаниеТипов("Дата"));
	ТаблицаСотрудники.Колонки.Добавить("СтавкаНДФЛ",				Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2)));
	ТаблицаСотрудники.Колонки.Добавить("СтавкаПФ",					Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15, 2)));
	ПредидущийПериод	= Дата(1,1,1);
	Для Каждого СтрокатС ИЗ ДокументСсылкаВзаимозачет.РасчетыСПерсоналом Цикл
		Если НЕ ПредидущийПериод = СтрокатС.ПериодРегистрации Тогда
			ПредидущийПериод = СтрокатС.ПериодРегистрации;	
			
			СтрокаС = ТаблицаСотрудники.Добавить();
			СтрокаС.Сотрудник = ДокументСсылкаВзаимозачет.Сотрудник; 
			СтрокаС.ПенсионныйФонд = ДокументСсылкаВзаимозачет.ВидУдержанияПФ.Контрагент;
			СтрокаС.ДоговорПенсионногоФонда = ДокументСсылкаВзаимозачет.ВидУдержанияПФ.Договор;
			СтрокаС.ВидУдержанияПФ = ДокументСсылкаВзаимозачет.ВидУдержанияПФ;
			СтрокаС.ВидУдержанияНДФЛ = ДокументСсылкаВзаимозачет.ВидУдержанияНДФЛ;
			СтрокаС.ВидНалога = ДокументСсылкаВзаимозачет.ВидУдержанияНДФЛ.ВидНалога;
			СтрокаС.ВидНалогаВыплат = ДокументСсылкаВзаимозачет.ВидУдержанияНДФЛ.ВидНалогаВыплат;
			СтрокаС.ПериодРегистрации = СтрокатС.ПериодРегистрации ;
			СтрокаС.СтавкаНДФЛ = ДокументСсылкаВзаимозачет.ВидУдержанияНДФЛ.СтавкаНДФЛ;
			СтрокаС.СтавкаПФ = ДокументСсылкаВзаимозачет.ВидУдержанияНДФЛ.СтавкаПФ;			
		КонецЕсли;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.Текст =
		 "ВЫБРАТЬ
		 |	ТаблицаСотрудники.Сотрудник КАК Сотрудник,
		 |	ТаблицаСотрудники.ПериодРегистрации КАК ПериодРегистрации,
		 |	ТаблицаСотрудники.ПенсионныйФонд КАК ПенсионныйФонд,
		 |	ТаблицаСотрудники.ДоговорПенсионногоФонда КАК ДоговорПенсионногоФонда,
		 |	ТаблицаСотрудники.СтавкаНДФЛ КАК СтавкаНДФЛ,
		 |	ВЫРАЗИТЬ(ТаблицаСотрудники.ВидУдержанияПФ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержанияПФ,
		 |	ТаблицаСотрудники.СтавкаПФ КАК СтавкаПФ,
		 |	ТаблицаСотрудники.ВидНалога КАК ВидНалога,
		 |	ТаблицаСотрудники.ВидНалогаВыплат КАК ВидНалогаВыплат,
		 |	ТаблицаСотрудники.ВидУдержанияНДФЛ КАК ВидУдержанияНДФЛ
		 |ПОМЕСТИТЬ ТаблицаСотрудники
		 |ИЗ
		 |	&ТаблицаСотрудники КАК ТаблицаСотрудники
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	Взаимозачет.СуммаВал КАК СуммаВал,
		 |	Взаимозачет.Валюта КАК Валюта,
		 |	Взаимозачет.Сумма КАК Сумма,
		 |	Взаимозачет.Ссылка КАК Ссылка,
		 |	Взаимозачет.НомерСтроки КАК НомерСтроки,
		 |	Взаимозачет.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		 |	ВЫРАЗИТЬ(ТаблицаСотрудники.ВидУдержанияПФ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержанияПФ,
		 |	Взаимозачет.СуммаПФ КАК СуммаПФ,
		 |	Взаимозачет.СуммаНДФЛ КАК СуммаНДФЛ,
		 |	Взаимозачет.Ссылка.Организация КАК Организация,
		 |	Взаимозачет.Ссылка.Сотрудник КАК Сотрудник,
		 |	Взаимозачет.ПериодРегистрации КАК ПериодРегистрации,
		 |	ТаблицаСотрудники.ВидНалога КАК ВидНалога,
		 |	ТаблицаСотрудники.ВидНалогаВыплат КАК ВидНалогаВыплат,
		 |	ВЫРАЗИТЬ(ТаблицаСотрудники.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержанияНДФЛ,
		 |	Взаимозачет.Всего КАК Всего,
		 |	Взаимозачет.СуммаВал / ((100 - Взаимозачет.Ссылка.ВидУдержанияНДФЛ.СтавкаНДФЛ) / 100) * (Взаимозачет.Ссылка.ВидУдержанияНДФЛ.СтавкаНДФЛ / 100) КАК СуммаНДФЛВал
		 |ПОМЕСТИТЬ РасчетСПерсоналом
		 |ИЗ
		 |	Документ.Взаимозачет.РасчетыСПерсоналом КАК Взаимозачет
		 |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСотрудники КАК ТаблицаСотрудники
		 |		ПО Взаимозачет.ПериодРегистрации = ТаблицаСотрудники.ПериодРегистрации
		 |			И Взаимозачет.Ссылка.Сотрудник = ТаблицаСотрудники.Сотрудник
		 |ГДЕ
		 |	Взаимозачет.Ссылка = &Ссылка
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	ВЫРАЗИТЬ(ТаблицаСотрудники.ВидУдержанияПФ КАК Справочник.ВидыНачисленийИУдержаний) КАК ВидУдержанияПФ,
		 |	Взаимозачет.СуммаПФ КАК СуммаПФ,
		 |	Взаимозачет.НомерСтроки КАК НомерСтроки,
		 |	Взаимозачет.Ссылка.Дата КАК Период,
		 |	Взаимозачет.Ссылка.Организация КАК Организация,
		 |	Взаимозачет.Ссылка.ВидУдержанияПФ.Контрагент КАК Контрагент,
		 |	Взаимозачет.Валюта КАК Валюта,
		 |	Взаимозачет.СуммаВал / ((100 - Взаимозачет.Ссылка.ВидУдержанияНДФЛ.СтавкаНДФЛ) / 100) * (Взаимозачет.Ссылка.ВидУдержанияНДФЛ.СтавкаНДФЛ / 100) КАК СуммаНДФЛВал,
		 |	Взаимозачет.СуммаВал КАК СуммаВал,
		 |	ТаблицаСотрудники.Сотрудник КАК Сотрудник,
		 |	ТаблицаСотрудники.ПериодРегистрации КАК ПериодРегистрации
		 |ПОМЕСТИТЬ Пф
		 |ИЗ
		 |	Документ.Взаимозачет.РасчетыСПерсоналом КАК Взаимозачет
		 |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаСотрудники КАК ТаблицаСотрудники
		 |		ПО Взаимозачет.ПериодРегистрации = ТаблицаСотрудники.ПериодРегистрации
		 |			И Взаимозачет.Ссылка.Сотрудник = ТаблицаСотрудники.Сотрудник
		 |ГДЕ
		 |	Взаимозачет.Ссылка = &Ссылка
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	&Организация КАК Организация,
		 |	&Период КАК Период,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		 |	РасчетСПерсоналом.ВидНалога КАК ВидНалога,
		 |	РасчетСПерсоналом.СуммаНДФЛ КАК Сумма,
		 |	&РасчетыПоНалогам КАК СодержаниеПроводки
		 |ИЗ
		 |	ТаблицаСотрудники КАК ТаблицаСотрудники,
		 |	РасчетСПерсоналом КАК РасчетСПерсоналом
		 |ГДЕ
		 |	РасчетСПерсоналом.СуммаНДФЛ > 0
		 |
		 |ОБЪЕДИНИТЬ ВСЕ
		 |
		 |ВЫБРАТЬ
		 |	&Организация,
		 |	&Период,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
		 |	РасчетСПерсоналом.ВидНалогаВыплат,
		 |	РасчетСПерсоналом.СуммаНДФЛ,
		 |	&РасчетыПоНалогам
		 |ИЗ
		 |	РасчетСПерсоналом КАК РасчетСПерсоналом
		 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаСотрудники КАК ТаблицаСотрудники
		 |		ПО РасчетСПерсоналом.ПериодРегистрации = ТаблицаСотрудники.ПериодРегистрации
		 |ГДЕ
		 |	РасчетСПерсоналом.СуммаНДФЛ > 0
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	&Организация КАК Организация,
		 |	&Период КАК Период,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		 |	РасчетСПерсоналом.Сотрудник КАК Сотрудник,
		 |	РасчетСПерсоналом.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		 |	РасчетСПерсоналом.Валюта КАК Валюта,
		 |	РасчетСПерсоналом.ПериодРегистрации КАК ПериодРегистрации,
		 |	РасчетСПерсоналом.Сумма КАК Сумма,
		 |	РасчетСПерсоналом.СуммаВал КАК СуммаВал,
		 |	&РасчетыСПерсоналом КАК СодержаниеПроводки
		 |ИЗ
		 |	РасчетСПерсоналом КАК РасчетСПерсоналом
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	Пф.НомерСтроки КАК НомерСтроки,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		 |	Пф.Период КАК Период,
		 |	Пф.Организация КАК Организация,
		 |	Пф.Сотрудник КАК Плательщик,
		 |	Пф.Сотрудник КАК СотрудникКонтрагент,
		 |	Пф.ПериодРегистрации КАК ПериодРегистрации,
		 |	Пф.ВидУдержанияПФ КАК ВидНачисленияУдержания,
		 |	Пф.Валюта КАК Валюта,
		 |	Пф.СуммаПФ КАК Сумма,
		 |	(Пф.СуммаВал + Пф.СуммаНДФЛВал) / ((100 - Пф.ВидУдержанияПФ.СтавкаПФ) / 100) * (Пф.ВидУдержанияПФ.СтавкаПФ / 100) КАК СуммаВал,
		 |	ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.Начисленный) КАК Операция,
		 |	&НалогПенсионногоФонда КАК СодержаниеПроводки
		 |ИЗ
		 |	Пф КАК Пф
		 |ГДЕ
		 |	Пф.СуммаПФ > 0
		 |	И НЕ Пф.ВидУдержанияПФ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
		 |
		 |ОБЪЕДИНИТЬ ВСЕ
		 |
		 |ВЫБРАТЬ
		 |	Пф.НомерСтроки,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
		 |	Пф.Период,
		 |	Пф.Организация,
		 |	Пф.Организация,
		 |	Пф.Сотрудник,
		 |	Пф.ПериодРегистрации,
		 |	Пф.ВидУдержанияПФ,
		 |	Пф.Валюта,
		 |	Пф.СуммаПФ,
		 |	(Пф.СуммаВал + Пф.СуммаНДФЛВал) / ((100 - Пф.ВидУдержанияПФ.СтавкаПФ) / 100) * (Пф.ВидУдержанияПФ.СтавкаПФ / 100),
		 |	ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.Начисленный),
		 |	&НалогПенсионногоФонда
		 |ИЗ
		 |	Пф КАК Пф
		 |ГДЕ
		 |	Пф.СуммаПФ > 0
		 |	И НЕ Пф.ВидУдержанияПФ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
		 |
		 |ОБЪЕДИНИТЬ ВСЕ
		 |
		 |ВЫБРАТЬ
		 |	Пф.НомерСтроки,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
		 |	Пф.Период,
		 |	Пф.Организация,
		 |	НЕОПРЕДЕЛЕНО,
		 |	НЕОПРЕДЕЛЕНО,
		 |	НЕОПРЕДЕЛЕНО,
		 |	Пф.ВидУдержанияПФ,
		 |	Пф.Валюта,
		 |	Пф.СуммаПФ * 2,
		 |	(Пф.СуммаВал + Пф.СуммаНДФЛВал) / ((100 - Пф.ВидУдержанияПФ.СтавкаПФ) / 100) * (Пф.ВидУдержанияПФ.СтавкаПФ / 100) * 2,
		 |	ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.КОплате),
		 |	&НалогПенсионногоФонда
		 |ИЗ
		 |	Пф КАК Пф
		 |ГДЕ
		 |	Пф.СуммаПФ > 0
		 |	И НЕ Пф.ВидУдержанияПФ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	РасчетСПерсоналом.Ссылка.Дата КАК Период,
		 |	РасчетСПерсоналом.Организация КАК Организация,
		 |	РасчетСПерсоналом.Сотрудник КАК Получатель,
		 |	РасчетСПерсоналом.ВидУдержанияНДФЛ.СтавкаНДФЛ КАК СтавкаНДФЛ,
		 |	РасчетСПерсоналом.Всего КАК СуммаВыдачи,
		 |	РасчетСПерсоналом.СуммаНДФЛ КАК СуммаНДФЛ,
		 |	РасчетСПерсоналом.СуммаПФ КАК СуммаПФСотрудника,
		 |	РасчетСПерсоналом.СуммаПФ КАК СуммаПФОрганизации,
		 |	ВЫБОР
		 |		КОГДА ЕСТЬNULL(ВЫРАЗИТЬ(РасчетСПерсоналом.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний).СтавкаНДФЛ, 0) = 0
		 |			ТОГДА РасчетСПерсоналом.Сумма + РасчетСПерсоналом.СуммаНДФЛ + РасчетСПерсоналом.СуммаПФ
		 |		ИНАЧЕ РасчетСПерсоналом.СуммаПФ
		 |	КОНЕЦ КАК СуммаЛьготы
		 |ИЗ
		 |	РасчетСПерсоналом КАК РасчетСПерсоналом
		 |ГДЕ
		 |	НЕ РасчетСПерсоналом.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	РасчетСПерсоналом.Ссылка.Дата КАК Период,
		 |	РасчетСПерсоналом.Организация КАК Организация,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		 |	РасчетСПерсоналом.ВидУдержанияНДФЛ КАК ВидНачисленияУдержания,
		 |	РасчетСПерсоналом.Сотрудник КАК Сотрудник,
		 |	РасчетСПерсоналом.ПериодРегистрации КАК ПериодРегистрации,
		 |	РасчетСПерсоналом.Валюта КАК Валюта,
		 |	ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.Начисленный) КАК Операция,
		 |	РасчетСПерсоналом.СуммаНДФЛ КАК Сумма,
		 |	РасчетСПерсоналом.СуммаНДФЛВал КАК СуммаВал,
		 |	&ПогашениеНалога КАК СодержаниеПроводки
		 |ИЗ
		 |	РасчетСПерсоналом КАК РасчетСПерсоналом
		 |ГДЕ
		 |	НЕ РасчетСПерсоналом.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
		 |
		 |ОБЪЕДИНИТЬ ВСЕ
		 |
		 |ВЫБРАТЬ
		 |	РасчетСПерсоналом.Ссылка.Дата,
		 |	РасчетСПерсоналом.Организация,
		 |	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
		 |	РасчетСПерсоналом.ВидУдержанияНДФЛ,
		 |	РасчетСПерсоналом.Сотрудник,
		 |	РасчетСПерсоналом.ПериодРегистрации,
		 |	РасчетСПерсоналом.Валюта,
		 |	ЗНАЧЕНИЕ(Перечисление.ОперацииПФ.КОплате),
		 |	РасчетСПерсоналом.СуммаНДФЛ,
		 |	РасчетСПерсоналом.СуммаНДФЛВал,
		 |	&НачислениеНалога
		 |ИЗ
		 |	РасчетСПерсоналом КАК РасчетСПерсоналом
		 |ГДЕ
		 |	НЕ РасчетСПерсоналом.ВидУдержанияНДФЛ = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)" ;
	
	Запрос.УстановитьПараметр("Организация",ДокументСсылкаВзаимозачет.Организация);
	Запрос.УстановитьПараметр("Период",	СтруктураДополнительныеСвойства.ДляПроведения.Дата);
	Запрос.УстановитьПараметр("ТаблицаСотрудники",ТаблицаСотрудники);
	Запрос.УстановитьПараметр("Ссылка",ДокументСсылкаВзаимозачет);
	Запрос.УстановитьПараметр("РасчетыПоНалогам",НСтр("ru='Подоходный налог с выплат';ka='გადახდების საშემოსავლო გადასახადი'"));
	Запрос.УстановитьПараметр("РасчетыСПерсоналом",НСтр("ru='Погашение обязательств перед персоналом';ka='პერსონალის წინაშე ვალდებულებების დაფარვა'"));
	Запрос.УстановитьПараметр("НалогПенсионногоФонда",НСтр("ka='საპენსიო ფონდის გადასახადი';ru='Налог пенсионного фонда';en='Tax pension fund'"));
	Запрос.УстановитьПараметр("НачислениеНалога",	НСтр("ka='გადასახადის დარიცხვა';ru='Начисление налога';en='tax accrual'"));
	Запрос.УстановитьПараметр("ПогашениеНалога",	НСтр("ka='გადასახადის დაფარვა';ru='Погашение налога';en='repayment of the tax'"));	
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоНалогам", МассивРезультатов[3].Выгрузить());
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПерсоналом", МассивРезультатов[4].Выгрузить());
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПенсионнымФондом", МассивРезультатов[5].Выгрузить());
	//СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДекларация", МассивРезультатов[6].Выгрузить());
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыНДФЛ", МассивРезультатов[7].Выгрузить());

	// Kuzmich, 24.11.2024, (ONESOFT-3522) Декларация для ИП (Индивидуальный предприниматель)
	ТаблицаДекларация = МассивРезультатов[6].Выгрузить();
	Если СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Свойство("ТаблицаДекларация") И СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДекларация.Количество()>0 Тогда
		
		Для каждого СтрокаТаблицаДекларация Из ТаблицаДекларация Цикл
		
			НоваяСтрокаТаблицаДекларация = СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаДекларация.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТаблицаДекларация,СтрокаТаблицаДекларация);
		
		КонецЦикла;
	
	Иначе
		
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаДекларация", ТаблицаДекларация);
	
	КонецЕсли;
	// Kuzmich, 24.11.2024, (ONESOFT-3522) Декларация для ИП (Индивидуальный предприниматель)
КонецПроцедуры                        

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаВзаимозачет, СтруктураДополнительныеСвойства) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаВзаимозачет);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Взаимозачет", НСтр("ka='ურთიერთჩათვლა';ru='Взаимозачет';en='netting'"));
	Запрос.УстановитьПараметр("ПереуступкаДолга", НСтр("ka='ვალის გადაპირება';ru='Переуступка долга';en='novation'"));
	Запрос.УстановитьПараметр("КорректировкаДолга", НСтр("ka='ვალის კორექტირება';ru='Корректировка долга';en='adjustment of duty'"));
	
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("УчетРасчетовПоПрочимОперациям", НСтр("ka='სხვა ოპერაციების მიხედვით ანგარიშსწორების აღრიცხვა';ru='Учет расчетов по прочим операциям';en='The account of calculations on other transactions'"));
	Запрос.УстановитьПараметр("Комментарий", НСтр("ka='ურთიერთჩათვლა';ru='Взаимозачет';en='netting'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	1 КАК Порядок,
	|	ТаблицаДокумента.ПризнакАванса КАК ПризнакАванса,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ПризнакАванса
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Долг)
	|	КОНЕЦ КАК ТипРасчетов,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ПризнакАванса
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		КОГДА НЕ ТаблицаДокумента.ПризнакАванса
	|				И (ТаблицаДокумента.Документ ССЫЛКА Документ.РасходнаяНакладная
	|					ИЛИ ТаблицаДокумента.Документ ССЫЛКА Документ.ЗаказПокупателя)
	|				И (ТаблицаДокумента.Ссылка.ДокументРасчетов ССЫЛКА Документ.ПоступлениеВКассу
	|					ИЛИ ТаблицаДокумента.Ссылка.ДокументРасчетов ССЫЛКА Документ.ПоступлениеНаСчет)
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ КАК ВидДвижения,
	|	МАКСИМУМ(ТаблицаДокумента.НомерСтроки) КАК НомерСтроки,
