#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область Проведение

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыСПокупателями(ДокументСсылкаВзаимозачет, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаВзаимозачет);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ПериодКонтроля", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени.Дата);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ka='სხვაობა კურსებს შორის';ru='Курсовая разница';en='Exchange difference'"));
	
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.СодержаниеПроводки КАК СодержаниеПроводки,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.ВидДвижения КАК ВидДвижения,
	|	ТаблицаДокумента.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.Договор КАК Договор,
	|	ТаблицаДокумента.Валюта КАК Валюта,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА ТаблицаДокумента.Документ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Документ,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.Заказ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
	|	КОНЕЦ КАК Заказ,
	|	ТаблицаДокумента.ТипРасчетов КАК ТипРасчетов,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта) КАК Проект,
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	ТаблицаДокумента.СчетУчета КАК СчетУчета,
	// Щербаков +++
	|	ТаблицаДокумента.СчетУчетаРегл КАК СчетУчетаРегл,
	// Щербаков ---
	|	ТаблицаДокумента.Дата КАК Дата,
	|	СУММА(ТаблицаДокумента.СуммаУчета) КАК Сумма,
	|	СУММА(ТаблицаДокумента.СуммаРасчетов) КАК СуммаВал,
	|	СУММА(ТаблицаДокумента.СуммаУчетаОстаток) КАК СуммаДляОстатка,
	|	СУММА(ТаблицаДокумента.СуммаРасчетовОстаток) КАК СуммаВалДляОстатка
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПокупателями
	|ИЗ
	|	ВременнаяТаблицаПокупатели КАК ТаблицаДокумента
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДокумента.НомерСтроки,
	|	ТаблицаДокумента.СодержаниеПроводки,
	|	ТаблицаДокумента.ВидДвижения,
	|	ТаблицаДокумента.Контрагент,
	|	ТаблицаДокумента.Договор,
	|	ТаблицаДокумента.Валюта,
	|	ТаблицаДокумента.ТипРасчетов,
	//ПодольскийАИ #УчетПроектов 15.02.2021 {
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта),
	//ПодольскийАИ #УчетПроектов 15.02.2021 }
	|	ТаблицаДокумента.СчетУчета,
	// Щербаков +++
	|	ТаблицаДокумента.СчетУчетаРегл,
	// Щербаков ---
	|	ТаблицаДокумента.Дата,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА ТаблицаДокумента.Документ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.Заказ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент,
	|	Договор,
	|	Валюта,
	|	Документ,
	|	Заказ,
	|	ТипРасчетов,
	|	СчетУчета";
	
	Запрос.Выполнить();
	
	// Установка исключительной блокировки контролируемых остатков расчетов с контрагентами.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВременнаяТаблицаРасчетыСПокупателями.Организация КАК Организация,
	|	ВременнаяТаблицаРасчетыСПокупателями.Контрагент КАК Контрагент,
	|	ВременнаяТаблицаРасчетыСПокупателями.Договор КАК Договор,
	|	ВременнаяТаблицаРасчетыСПокупателями.Документ КАК Документ,
	|	ВременнаяТаблицаРасчетыСПокупателями.Заказ КАК Заказ,
	|	ВременнаяТаблицаРасчетыСПокупателями.ТипРасчетов КАК ТипРасчетов
	|ИЗ
	|	ВременнаяТаблицаРасчетыСПокупателями";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РасчетыСПокупателями");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	
	Для каждого КолонкаРезультатЗапроса Из РезультатЗапроса.Колонки Цикл
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных(КолонкаРезультатЗапроса.Имя, КолонкаРезультатЗапроса.Имя);
	КонецЦикла;
	Блокировка.Заблокировать();
	
	НомерЗапроса = 0;
	Запрос.Текст = УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПокупателями(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	// Щербаков +++
	Запрос.Текст = Запрос.Текст + ";" + УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПокупателямиРегл(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	// Щербаков ---
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПокупателями", МассивРезультатов[НомерЗапроса].Выгрузить());
	
КонецПроцедуры // СформироватьТаблицаРасчетыСПокупателями()

// Формирует таблицу значений, содержащую данные для проведения по регистру.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура СформироватьТаблицаРасчетыСПоставщиками(ДокументСсылкаВзаимозачет, СтруктураДополнительныеСвойства)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаВзаимозачет);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ПериодКонтроля", СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени.Дата);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ka='სხვაობა კურსებს შორის';ru='Курсовая разница';en='Exchange difference'"));
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.Ссылка КАК Ссылка,
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ТаблицаДокумента.СодержаниеПроводки КАК СодержаниеПроводки,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.ВидДвижения КАК ВидДвижения,
	|	ТаблицаДокумента.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.Договор КАК Договор,
	|	ТаблицаДокумента.Валюта КАК Валюта,
	|	ТаблицаДокумента.ПризнакАванса КАК ПризнакАванса,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА ТаблицаДокумента.Документ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Документ,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.Заказ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.Заказпоставщику.ПустаяСсылка)
	|	КОНЕЦ КАК Заказ,
	|	ТаблицаДокумента.ТипРасчетов КАК ТипРасчетов,
	|	ТаблицаДокумента.СчетУчета КАК СчетУчета,
	// Щербаков +++
	|	ТаблицаДокумента.СчетУчетаРегл КАК СчетУчетаРегл,
	// Щербаков ---
	|	ТаблицаДокумента.Дата КАК Дата,
	|	СУММА(ТаблицаДокумента.СуммаУчета) КАК Сумма,
	|	СУММА(ТаблицаДокумента.СуммаРасчетов) КАК СуммаВал,
	|	СУММА(ТаблицаДокумента.СуммаУчетаОстаток) КАК СуммаДляОстатка,
	|	СУММА(ТаблицаДокумента.СуммаРасчетовОстаток) КАК СуммаВалДляОстатка
	|ПОМЕСТИТЬ ВременнаяТаблицаРасчетыСПоставщиками
	|ИЗ
	|	ВременнаяТаблицаПоставщики КАК ТаблицаДокумента
	|
	|СГРУППИРОВАТЬ ПО
	|	ТаблицаДокумента.НомерСтроки,
	|	ТаблицаДокумента.СодержаниеПроводки,
	|	ТаблицаДокумента.ВидДвижения,
	|	ТаблицаДокумента.Контрагент,
	|	ТаблицаДокумента.Ссылка,
	|	ТаблицаДокумента.Договор,
	|	ТаблицаДокумента.Валюта,
	|	ТаблицаДокумента.ТипРасчетов,
	|	ТаблицаДокумента.ПризнакАванса,
	|	ТаблицаДокумента.СчетУчета,
	// Щербаков +++
	|	ТаблицаДокумента.СчетУчетаРегл,
	// Щербаков ---
	|	ТаблицаДокумента.Дата,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоДокументам
	|			ТОГДА ТаблицаДокумента.Документ
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.ВестиРасчетыПоЗаказам
	|			ТОГДА ТаблицаДокумента.Заказ
	|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.Заказпоставщику.ПустаяСсылка)
	|	КОНЕЦ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Контрагент,
	|	Договор,
	|	Валюта,
	|	Документ,
	|	Заказ,
	|	ТипРасчетов,
	|	СчетУчета";
	
	Запрос.Выполнить();
	
	// Установка исключительной блокировки контролируемых остатков расчетов с контрагентами.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВременнаяТаблицаРасчетыСПоставщиками.Организация КАК Организация,
	|	ВременнаяТаблицаРасчетыСПоставщиками.Контрагент КАК Контрагент,
	|	ВременнаяТаблицаРасчетыСПоставщиками.Договор КАК Договор,
	|	ВременнаяТаблицаРасчетыСПоставщиками.Документ КАК Документ,
	|	ВременнаяТаблицаРасчетыСПоставщиками.Заказ КАК Заказ,
	|	ВременнаяТаблицаРасчетыСПоставщиками.ТипРасчетов КАК ТипРасчетов
	|ИЗ
	|	ВременнаяТаблицаРасчетыСПоставщиками";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.РасчетыСПоставщиками");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.ИсточникДанных = РезультатЗапроса;
	
	Для каждого КолонкаРезультатЗапроса из РезультатЗапроса.Колонки Цикл
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных(КолонкаРезультатЗапроса.Имя, КолонкаРезультатЗапроса.Имя);
	КонецЦикла;
	Блокировка.Заблокировать();
	
	НомерЗапроса = 0;
	Запрос.Текст = УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПоставщиками_КорректировкаДолга(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	// Щербаков +++
	Запрос.Текст = Запрос.Текст + ";" + УправлениеНебольшойФирмойСервер.ПолучитьТекстЗапросаКурсовыеРазницыРасчетыСПоставщикамиРегл(Запрос.МенеджерВременныхТаблиц, Ложь, НомерЗапроса);
	// Щербаков ---
	//+++ Дмгг
	Запрос.УстановитьПараметр("Отправитель", ДокументСсылкаВзаимозачет.КонтрагентИсточник);
	Запрос.УстановитьПараметр("Получатель", ДокументСсылкаВзаимозачет.Контрагент);
	Запрос.УстановитьПараметр("ВидОперации", ДокументСсылкаВзаимозачет.ВидОперации);
	Запрос.УстановитьПараметр("ДоговорПолучатель", ДокументСсылкаВзаимозачет.Договор);
	//--- Дмгг	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	//СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПоставщиками", МассивРезультатов[НомерЗапроса].Выгрузить());
	// Kuzmich, 24.11.2024, (ONESOFT-3522) Декларация для ИП (Индивидуальный предприниматель)
	ТаблицаРасчетыСПоставщиками = МассивРезультатов[НомерЗапроса].Выгрузить();
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыСПоставщиками", ТаблицаРасчетыСПоставщиками);
	
	Если ТаблицаРасчетыСПоставщиками.Количество()>0 Тогда
	
		ЗапросДекларация = Новый Запрос;
		ЗапросДекларация.Текст =
			"ВЫБРАТЬ
			|	Взаимозачет.Организация КАК Организация,
			|	Взаимозачет.Контрагент КАК Контрагент,
			|	Взаимозачет.ВидУдержанияНДФЛ КАК ВидУдержанияНДФЛ
			|ПОМЕСТИТЬ Взаимозачет
			|ИЗ
			|	Документ.Взаимозачет КАК Взаимозачет
			|ГДЕ
			|	Взаимозачет.Ссылка = &Ссылка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаблицаРасчетыСПоставщиками.Период КАК Период,
			|	ТаблицаРасчетыСПоставщиками.Организация КАК Организация,
			|	ТаблицаРасчетыСПоставщиками.Контрагент КАК Контрагент,
			|	ТаблицаРасчетыСПоставщиками.Договор КАК Договор,
			|	ТаблицаРасчетыСПоставщиками.Сумма КАК Сумма
			|ПОМЕСТИТЬ ТаблицаРасчетыСПоставщиками
			|ИЗ
			|	&ТаблицаРасчетыСПоставщиками КАК ТаблицаРасчетыСПоставщиками
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаблицаРасчетыСПоставщиками.Период КАК Период,
			|	ТаблицаРасчетыСПоставщиками.Организация КАК Организация,
			|	ТаблицаРасчетыСПоставщиками.Контрагент КАК Контрагент,
			|	ТаблицаРасчетыСПоставщиками.Договор КАК Договор,
			|	СУММА(ТаблицаРасчетыСПоставщиками.Сумма) КАК Сумма
			|ПОМЕСТИТЬ ТаблицаДокумента
			|ИЗ
			|	ТаблицаРасчетыСПоставщиками КАК ТаблицаРасчетыСПоставщиками
			|
			|СГРУППИРОВАТЬ ПО
			|	ТаблицаРасчетыСПоставщиками.Период,
			|	ТаблицаРасчетыСПоставщиками.Организация,
			|	ТаблицаРасчетыСПоставщиками.Контрагент,
			|	ТаблицаРасчетыСПоставщиками.Договор
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТаблицаДокумента.Период КАК Период,
			|	ТаблицаДокумента.Организация КАК Организация,
			|	ТаблицаДокумента.Контрагент КАК Получатель,
			|	ВЫРАЗИТЬ(ТаблицаДокумента.Договор КАК Справочник.ДоговорыКонтрагентов) КАК Договор,
			|	ЕСТЬNULL(ВЫРАЗИТЬ(Взаимозачет.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний).СтавкаНДФЛ, 0) КАК СтавкаНДФЛ,
			|	ЕСТЬNULL(ВЫРАЗИТЬ(ТаблицаДокумента.Договор КАК Справочник.ДоговорыКонтрагентов).ВидОплатыУслуг, ЗНАЧЕНИЕ(Справочник.ВидыОплатУслуг.ПустаяСсылка)) КАК ВидОплатыУслуг,
			|	ТаблицаДокумента.Сумма КАК СуммаВыдачи,
			|	0 КАК СуммаНДФЛ,
			|	0 КАК СуммаПФСотрудника,
			|	0 КАК СуммаПФОрганизации,
			|	ВЫБОР
			|		КОГДА ЕСТЬNULL(ВЫРАЗИТЬ(Взаимозачет.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний).СтавкаНДФЛ, 0) = 0
			|			ТОГДА ТаблицаДокумента.Сумма
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК СуммаЛьготы
			|ИЗ
			|	ТаблицаДокумента КАК ТаблицаДокумента
			|		ЛЕВОЕ СОЕДИНЕНИЕ Взаимозачет КАК Взаимозачет
			|		ПО ТаблицаДокумента.Организация = Взаимозачет.Организация
			|			И ТаблицаДокумента.Контрагент = Взаимозачет.Контрагент
			|ГДЕ
			|	(ВЫРАЗИТЬ(ТаблицаДокумента.Договор КАК Справочник.ДоговорыКонтрагентов).УчитыватьНДФЛ
			|				И НЕ (ВЫРАЗИТЬ(Взаимозачет.ВидУдержанияНДФЛ КАК Справочник.ВидыНачисленийИУдержаний)) = ЗНАЧЕНИЕ(Справочник.ВидыНачисленийИУдержаний.ПустаяСсылка)
			|			ИЛИ ВЫРАЗИТЬ(ТаблицаДокумента.Договор КАК Справочник.ДоговорыКонтрагентов).УслугаИП
			|				И НЕ ВЫРАЗИТЬ(ТаблицаДокумента.Договор КАК Справочник.ДоговорыКонтрагентов).ВидОплатыУслуг = ЗНАЧЕНИЕ(Справочник.ВидыОплатУслуг.ПустаяСсылка))";
		
		ЗапросДекларация.УстановитьПараметр("Ссылка", ДокументСсылкаВзаимозачет.Ссылка);
		ЗапросДекларация.УстановитьПараметр("ТаблицаРасчетыСПоставщиками", ТаблицаРасчетыСПоставщиками);
		
