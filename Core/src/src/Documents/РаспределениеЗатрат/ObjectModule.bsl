			НоваяСтрока.Номенклатура = ВыборкаДетализация.Номенклатура;
			НоваяСтрока.Характеристика = ВыборкаДетализация.Характеристика;
			НоваяСтрока.Партия = ВыборкаДетализация.Партия;
			НоваяСтрока.Проект = ВыборкаДетализация.Проект;  //Малышев 2024-06-22 ONESOFT-3264
			НоваяСтрока.ДокументПоступления = ВыборкаДетализация.ДокументПоступления;  //Малышев 2024-12-09 ONESOFT-3646
			НоваяСтрока.ЗаказПокупателя = ВыборкаДетализация.ЗаказПокупателя;
			НоваяСтрока.Спецификация = ВыборкаДетализация.Спецификация;
			
			НоваяСтрока.Сумма = Окр((ВыборкаДетализация.Сумма - ИсхСумма) * ВыборкаДетализация.Себестоимость / БазаРаспределения + ПредСумма, 2, 1);//?(БазаРаспределения <> 0, Окр((ВыборкаДетализация.Сумма - ИсхСумма) * ВыборкаДетализация.Себестоимость / БазаРаспределения, 2, 1),0);
			БазаРаспределения = БазаРаспределения - ВыборкаДетализация.Себестоимость;
			ИсхСумма = ИсхСумма + НоваяСтрока.Сумма;
			
			ПредСумма = 0;
			
		КонецЦикла;
		
		Если ПредСумма <> 0 Тогда 
			НоваяСтрока.Сумма = НоваяСтрока.Сумма + ?(Окр(ПредСумма, 2, 1) = 0, 1, Окр(ПредСумма, 2, 1));
		КонецЕсли;

	КонецЦикла;
	
	МенеджерВременныхТаблиц.Закрыть();
	
КонецПроцедуры // ВыполнитьРаспределениеЗатратПоКоличеству()
