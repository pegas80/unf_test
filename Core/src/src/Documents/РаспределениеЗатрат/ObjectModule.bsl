		НоваяСтрока = Затраты.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
        НоваяСтрока.КлючСвязи = КлючСвязи;
		
		КлючСвязи = КлючСвязи + 1;
		
	КонецЦикла;
	
