#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаПередачаВА, СтруктураДополнительныеСвойства) Экспорт
	
	// Щербаков +++
	ТЗВнеоборотныеАктивы = ДокументСсылкаПередачаВА.ВнеоборотныеАктивы.Выгрузить();
	ТЗВнеоборотныеАктивы.Колонки.Добавить("СуммаРегл"	, Новый ОписаниеТипов("Число"));
	ТЗВнеоборотныеАктивы.Колонки.Добавить("СуммаНДСРегл", Новый ОписаниеТипов("Число"));
	
	Для Каждого Строк Из ТЗВнеоборотныеАктивы Цикл 
		Строк.СуммаРегл = Строк.Сумма * ДокументСсылкаПередачаВА.Курс * ДокументСсылкаПередачаВА.Кратность;
		Строк.СуммаНДСРегл = Строк.СуммаНДС * ДокументСсылкаПередачаВА.Курс * ДокументСсылкаПередачаВА.Кратность;
	КонецЦикла;
	
	Если ДокументСсылкаПередачаВА.ВалютаДокумента <> Константы.ВалютаУчета.Получить()
		И ДокументСсылкаПередачаВА.Предоплата.Количество() > 0 Тогда 
		
		РегламентированныйУчетСервер.ПересчитатьСуммыВалютыПредоплатыВСуммыРеглУчета(ТЗВнеоборотныеАктивы, ДокументСсылкаПередачаВА);
		
	КонецЕсли;
	
	ТЗВнеоборотныеАктивы.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("ДокументСсылка.ПередачаВА"));
	ТЗВнеоборотныеАктивы.Колонки.Добавить("СчетЗатратРегл", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));     
	ТЗВнеоборотныеАктивы.Колонки.Добавить("СчетДоходаРегл", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	ТЗВнеоборотныеАктивы.ЗаполнитьЗначения(ДокументСсылкаПередачаВА					, "Ссылка");
	ТЗВнеоборотныеАктивы.ЗаполнитьЗначения(ДокументСсылкаПередачаВА.СчетЗатратРегл	, "СчетЗатратРегл");
	ТЗВнеоборотныеАктивы.ЗаполнитьЗначения(ДокументСсылкаПередачаВА.СчетДоходаРегл	, "СчетДоходаРегл");
	// Щербаков ---
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаПередачаВА);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	// Щербаков +++
	Запрос.УстановитьПараметр("ТЗВнеоборотныеАктивы", ТЗВнеоборотныеАктивы);
	Запрос.УстановитьПараметр("ИспользоватьТолькоРегламентированныйПланСчетов", СтруктураДополнительныеСвойства.ИспользованиеТолькоРеглПланаСчетов);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПередачаВАВнеоборотныеАктивы.Ссылка,
	|	ПередачаВАВнеоборотныеАктивы.НомерСтроки,
	|	ПередачаВАВнеоборотныеАктивы.ВнеоборотныйАктив,
	|	ПередачаВАВнеоборотныеАктивы.Стоимость,
	|	ПередачаВАВнеоборотныеАктивы.ОстаточнаяСтоимость,
	|	ПередачаВАВнеоборотныеАктивы.Амортизация,
	|	ПередачаВАВнеоборотныеАктивы.АмортизацияЗаМесяц,
	|	ПередачаВАВнеоборотныеАктивы.Сумма,
	|	ПередачаВАВнеоборотныеАктивы.СтавкаНДС,
	|	ПередачаВАВнеоборотныеАктивы.СуммаНДС,
	|	ПередачаВАВнеоборотныеАктивы.СуммаНДСРегл,
	|	ПередачаВАВнеоборотныеАктивы.СуммаРегл,
	|	ПередачаВАВнеоборотныеАктивы.Всего,
	|	ПередачаВАВнеоборотныеАктивы.СчетЗатратРегл,
	|	ПередачаВАВнеоборотныеАктивы.СчетДоходаРегл
	|,	ПередачаВАВнеоборотныеАктивы.КоличествоМесяцеВЭксплуатации КАК КоличествоМесяцеВЭксплуатации //+++ Дмгг
	|ПОМЕСТИТЬ Вт_ВнеоборотныеАктивы
	|ИЗ
	|	&ТЗВнеоборотныеАктивы КАК ПередачаВАВнеоборотныеАктивы";
	
	Запрос.Выполнить();
	// Щербаков ---
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаДокумента.НомерСтроки КАК НомерСтроки,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ТаблицаДокумента.Ссылка.Дата КАК Период,
	|	&Ссылка КАК Документ,
	|	&Организация КАК Организация,
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатрат КАК СчетУчетаАмортизации,
	//+++ Дмгг
	//|	ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатрат.ТипСчета КАК ТипСчетаАмортизации,
	|	ВЫБОР
	|		КОГДА &ИспользоватьТолькоРегламентированныйПланСчетов
	|			ТОГДА ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатратРегл.ТипСчета
	|		ИНАЧЕ ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатрат.ТипСчета
	|	КОНЕЦ КАК ТипСчетаАмортизации,
	//--- Дмгг
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ЗНАЧЕНИЕ(Справочник.НаправленияДеятельности.Прочее) КАК НаправлениеДеятельностиПродажи,
	|	ТаблицаДокумента.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ТаблицаДокумента.ВнеоборотныйАктив.СчетУчета КАК СчетУчета,
	|	ТаблицаДокумента.ВнеоборотныйАктив.СчетАмортизации КАК СчетАмортизации,
	|	ТаблицаДокумента.Ссылка.Контрагент КАК Контрагент,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоДоговорам КАК ВестиРасчетыПоДоговорам,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоДокументам КАК ВестиРасчетыПоДокументам,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиРасчетыПоЗаказам КАК ВестиРасчетыПоЗаказам,
	|	ТаблицаДокумента.Ссылка.Контрагент.ВестиУчетОплатыПоСчетам КАК ВестиУчетОплатыПоСчетам,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаРасчетовСПокупателем КАК СчетУчетаРасчетовСПокупателем,
	|	ТаблицаДокумента.Ссылка.Договор КАК Договор,
	|	ТаблицаДокумента.Ссылка.Договор.ВалютаРасчетов КАК ВалютаРасчетов,
	|	ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка) КАК ЗаказПокупателя,
	|	ТаблицаДокумента.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаДокумента.Стоимость КАК Стоимость,
	|	ТаблицаДокумента.Амортизация КАК Амортизация,
	|	ТаблицаДокумента.АмортизацияЗаМесяц КАК АмортизацияЗаМесяц,
	|	ТаблицаДокумента.ОстаточнаяСтоимость КАК ОстаточнаяСтоимость,
	|	ВЫРАЗИТЬ(ВЫБОР
	|			КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|				ТОГДА ТаблицаДокумента.СуммаНДС * КурсыРегВалюты.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * КурсыРегВалюты.Кратность)
	// Щербаков +++
	//|			ИНАЧЕ ТаблицаДокумента.СуммаНДС * ТаблицаДокумента.Ссылка.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность)
	|			ИНАЧЕ ТаблицаДокумента.СуммаНДСРегл
	// Щербаков ---
	|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК СуммаНДС,
	|	ВЫРАЗИТЬ(ВЫБОР
	|			КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|				ТОГДА ТаблицаДокумента.Всего * КурсыРегВалюты.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * КурсыРегВалюты.Кратность)
	// Щербаков +++
	//|			ИНАЧЕ ТаблицаДокумента.Всего * ТаблицаДокумента.Ссылка.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность)
	|			ИНАЧЕ ТаблицаДокумента.СуммаРегл
	// Щербаков ---
	|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК Сумма,
	|	ВЫРАЗИТЬ(ВЫБОР
	|			КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|				ТОГДА ТаблицаДокумента.Всего * КурсыРегВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность / (ТаблицаДокумента.Ссылка.Курс * КурсыРегВалюты.Кратность)
	|			ИНАЧЕ ТаблицаДокумента.Всего
	|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК СуммаВал,
	|	ИСТИНА КАК ФиксированнаяСтоимость,
	|	ТаблицаДокумента.Ссылка.ВидНалогаНДС КАК ВидНалогаНДС,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.СуммаВключаетНДС
	|			ТОГДА ВЫРАЗИТЬ(ВЫБОР
	|						КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|							ТОГДА (ТаблицаДокумента.Всего - ТаблицаДокумента.СуммаНДС) * КурсыРегВалюты.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * КурсыРегВалюты.Кратность)
	// Щербаков +++
	//|						ИНАЧЕ (ТаблицаДокумента.Всего - ТаблицаДокумента.СуммаНДС) * ТаблицаДокумента.Ссылка.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность)
	|						ИНАЧЕ ТаблицаДокумента.СуммаРегл - ТаблицаДокумента.СуммаНДСРегл
	// Щербаков ---
	|					КОНЕЦ КАК ЧИСЛО(15, 2))
	|		ИНАЧЕ ВЫРАЗИТЬ(ВЫБОР
	|					КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|						ТОГДА ТаблицаДокумента.Сумма * КурсыРегВалюты.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * КурсыРегВалюты.Кратность)
	// Щербаков +++
	//|					ИНАЧЕ ТаблицаДокумента.Сумма * ТаблицаДокумента.Ссылка.Курс * КурсыУпрВалюты.Кратность / (КурсыУпрВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность)
	|					ИНАЧЕ ТаблицаДокумента.СуммаРегл
	// Щербаков ---
	|				КОНЕЦ КАК ЧИСЛО(15, 2))
	|	КОНЕЦ КАК СуммаБезНДС,
	|	ВЫБОР
	|		КОГДА ТаблицаДокумента.Ссылка.СуммаВключаетНДС
	|			ТОГДА ВЫРАЗИТЬ(ВЫБОР
	|						КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|							ТОГДА (ТаблицаДокумента.Всего - ТаблицаДокумента.СуммаНДС) * КурсыРегВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность / (ТаблицаДокумента.Ссылка.Курс * КурсыРегВалюты.Кратность)
	|						ИНАЧЕ ТаблицаДокумента.Всего - ТаблицаДокумента.СуммаНДС
	|					КОНЕЦ КАК ЧИСЛО(15, 2))
	|		ИНАЧЕ ВЫРАЗИТЬ(ВЫБОР
	|					КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|						ТОГДА ТаблицаДокумента.Сумма * КурсыРегВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность / (ТаблицаДокумента.Ссылка.Курс * КурсыРегВалюты.Кратность)
	|					ИНАЧЕ ТаблицаДокумента.Сумма
	|				КОНЕЦ КАК ЧИСЛО(15, 2))
	|	КОНЕЦ КАК СуммаБезНДСВал,
	|	ВЫРАЗИТЬ(ВЫБОР
	|			КОГДА ТаблицаДокумента.Ссылка.ВалютаДокумента = КонстантаНациональнаяВалюта.Значение
	|				ТОГДА ТаблицаДокумента.СуммаНДС * КурсыРегВалюты.Курс * ТаблицаДокумента.Ссылка.Кратность / (ТаблицаДокумента.Ссылка.Курс * КурсыРегВалюты.Кратность)
	|			ИНАЧЕ ТаблицаДокумента.СуммаНДС
	|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК СуммаНДСВал,
	// Щербаков +++
	|	ПараметрыВнеоборотныхАктивовСрезПоследних.СчетЗатратРегл КАК СчетУчетаАмортизацииРегл,
	|	ТаблицаДокумента.ВнеоборотныйАктив.СчетУчетаРегл КАК СчетУчетаРегл,
	|	ТаблицаДокумента.ВнеоборотныйАктив.СчетАмортизацииРегл КАК СчетАмортизацииРегл,
	|	ТаблицаДокумента.Ссылка.Контрагент.СчетУчетаРасчетовСПокупателемРегл КАК СчетУчетаРасчетовСПокупателемРегл,
	|	ТаблицаДокумента.СчетЗатратРегл КАК СчетЗатратРегл,
	|	ТаблицаДокумента.СчетДоходаРегл КАК СчетДоходаРегл
	// Щербаков ---
	|,	ТаблицаДокумента.КоличествоМесяцеВЭксплуатации КАК КоличествоМесяцеВЭксплуатации //+++ Дмгг
	|ПОМЕСТИТЬ ВременнаяТаблицаВнеоборотныеАктивы
	|ИЗ
	// Щербаков +++
	//|	Документ.ПередачаВА.ВнеоборотныеАктивы КАК ТаблицаДокумента
	|	Вт_ВнеоборотныеАктивы КАК ТаблицаДокумента
	// Щербаков ---
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних(&МоментВремени, ) КАК ПараметрыВнеоборотныхАктивовСрезПоследних
	|		ПО (&Организация = ПараметрыВнеоборотныхАктивовСрезПоследних.Организация)
	|			И ТаблицаДокумента.ВнеоборотныйАктив = ПараметрыВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(
	|				&МоментВремени,
	|				Валюта В
	|					(ВЫБРАТЬ
	|						КонстантаВалютаУчета.Значение
	|					ИЗ
	|						Константа.ВалютаУчета КАК КонстантаВалютаУчета)) КАК КурсыУпрВалюты
	|		ПО (ИСТИНА)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КурсыВалют.СрезПоследних(
	|				&МоментВремени,
	|				Валюта В
	|					(ВЫБРАТЬ
	|						КонстантаНациональнаяВалюта.Значение
	|					ИЗ
	|						Константа.НациональнаяВалюта КАК КонстантаНациональнаяВалюта)) КАК КурсыРегВалюты
	|		ПО (ИСТИНА),
	|	Константа.НациональнаяВалюта КАК КонстантаНациональнаяВалюта
	|ГДЕ
	|	ТаблицаДокумента.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ТаблицаДокумента.НомерСтроки) КАК НомерСтроки,
	|	ТаблицаДокумента.Ссылка.Дата КАК Период,
	|	&Организация КАК Организация,
	|	ТаблицаДокумента.Ссылка.Контрагент КАК Контрагент,
