&НаКлиенте
Процедура ЗаполнитьДоМинимальногоОстатка(Команда)
	ОчиститьСообщения();
	Если Объект.Запасы.Количество() > 0 Тогда
		Ответ = Неопределено;
		ПоказатьВопрос(Новый ОписаниеОповещения("КомандаЗаполнитьДоМинимальногоОстатка", ЭтотОбъект), НСтр("ka='ცხრილი გასუფთავდება! გავაგრძელოთ ოპერაციის შესრულება?';ru='Табличная часть будет очищена! Продолжить выполнение операции?';en='Tabular section will be cleared! To continue the operation?'"), РежимДиалогаВопрос.ДаНет, 0);
        Возврат; 
	КонецЕсли;
	ЗаполнитьДоМинимальногоОстаткаНаСервере();
КонецПроцедуры
&НаКлиенте
Процедура КомандаЗаполнитьДоМинимальногоОстатка(Результат, ДополнительныеПараметры) Экспорт
    
    Ответ = Результат;
    Если Ответ <> КодВозвратаДиалога.Да Тогда
        Возврат;
    КонецЕсли; 
    
    ЗаполнитьДоМинимальногоОстаткаНаСервере();

КонецПроцедуры
&НаСервере
Процедура ЗаполнитьДоМинимальногоОстаткаНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МинимальныеОстаткиСкладаСрезПоследних.Номенклатура,
		|	СУММА(МинимальныеОстаткиСкладаСрезПоследних.Количество) КАК Количество
		|ПОМЕСТИТЬ Лимиты
		|ИЗ
		|	РегистрСведений.МинимальныеОстаткиСклада.СрезПоследних(&Дата, СтруктурнаяЕдиница = &СтруктурнаяЕдиницаПолучатель) КАК МинимальныеОстаткиСкладаСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	МинимальныеОстаткиСкладаСрезПоследних.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыОстаткиИОбороты.Номенклатура,
		|	СУММА(ВЫБОР
		|			КОГДА ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница = &СтруктурнаяЕдиницаОтправитель
		|				ТОГДА ЗапасыОстаткиИОбороты.КоличествоОборот
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОстатокОтправителя,
		|	СУММА(ВЫБОР
		|			КОГДА ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница = &СтруктурнаяЕдиницаПолучатель
		|				ТОГДА ЗапасыОстаткиИОбороты.КоличествоОборот
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОстатокПолучателя
		|ПОМЕСТИТЬ Остатки
		|ИЗ
		|	РегистрНакопления.Запасы.ОстаткиИОбороты(
		|			,
		|			,
		|			Авто,
		|			,
		|			Номенклатура В
		|					(ВЫБРАТЬ
		|						Лимиты.Номенклатура
		|					ИЗ
		|						Лимиты КАК Лимиты)
		|				И СтруктурнаяЕдиница В (&СтруктурнаяЕдиницаОтправитель, &СтруктурнаяЕдиницаПолучатель)) КАК ЗапасыОстаткиИОбороты
		|ГДЕ
		|	НЕ ЗапасыОстаткиИОбороты.Регистратор = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстаткиИОбороты.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Лимиты.Номенклатура КАК Номенклатура,
		|	Лимиты.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ВЫБОР
		|		КОГДА Лимиты.Количество - Остатки.ОстатокПолучателя < Остатки.ОстатокОтправителя
		|			ТОГДА Лимиты.Количество - Остатки.ОстатокПолучателя
		|		ИНАЧЕ Остатки.ОстатокОтправителя
		|	КОНЕЦ КАК Количество,
		|	ЕСТЬNULL(Остатки.ОстатокОтправителя, 0) > 0
		|		И Лимиты.Количество - ЕСТЬNULL(Остатки.ОстатокПолучателя, 0) > 0 КАК Загружать,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(Остатки.ОстатокОтправителя, 0) = 0
		|				И Лимиты.Количество - ЕСТЬNULL(Остатки.ОстатокПолучателя, 0) > 0
		|			ТОГДА ИСТИНА
		|		КОГДА Остатки.ОстатокОтправителя > 0
		|				И Лимиты.Количество - ЕСТЬNULL(Остатки.ОстатокПолучателя, 0) - ЕСТЬNULL(Остатки.ОстатокОтправителя, 0) > 0
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК НеХватаетОстатков,
		|	Лимиты.Количество КАК Лимит,
		|	Лимиты.Количество - ЕСТЬNULL(Остатки.ОстатокПолучателя, 0) - ЕСТЬNULL(Остатки.ОстатокОтправителя, 0) КАК НеХватает,
		|	ПРЕДСТАВЛЕНИЕ(&СтруктурнаяЕдиницаОтправитель) КАК Отправитель
		|ИЗ
		|	Лимиты КАК Лимиты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Остатки КАК Остатки
		|		ПО Лимиты.Номенклатура = Остатки.Номенклатура";
	Запрос.УстановитьПараметр("Дата", 							?(Объект.Ссылка.Пустая() И НачалоДня(Объект.Дата) = НачалоДня(ТекущаяДата()), ТекущаяДата(), Объект.Дата));
	Запрос.УстановитьПараметр("Ссылка", 						Объект.Ссылка);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиницаОтправитель",	Объект.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиницаПолучатель",	?(ЧерезТранзитныйСклад, Объект.СтруктурнаяЕдиницаКонечныйПолучатель, Объект.СтруктурнаяЕдиницаПолучатель));
	
	Таблица = Запрос.Выполнить().Выгрузить();
	
	Объект.Запасы.Очистить();
	ЗагрузаемыеСтроки = Таблица.НайтиСтроки(Новый Структура("Загружать", Истина));
	Для Каждого СтрокаЗ ИЗ ЗагрузаемыеСтроки Цикл 
		НовСтрока = Объект.Запасы.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока, СтрокаЗ);
	КонецЦикла;
	
	ТаблицаНеХватаетОстатков = Таблица.НайтиСтроки(Новый Структура("НеХватаетОстатков", Истина));
	Для Каждого СтрокаТЧ ИЗ ТаблицаНеХватаетОстатков Цикл
		Сообщить(НСтр("ka='ნომენკლატურა ""';ru='Номенклатура ""';en='Nomenclature ""'") + СтрокаТЧ.Номенклатура + НСтр("ka='"" საწყობში ""';ru='"" на складу ""';en='""In stock""'") + СтрокаТЧ.Отправитель +
				 НСтр("ka='"" თარიღზე ""';ru='"" на дату ""';en='"" on the date ""'") + Строка(Объект.Дата) +
				 НСтр("ka='"" არასაკმარისია ლიმიტის შესავსებად. დანაკლისი:';ru='"" не хватает для заполнения лимитов. Не хватает:';en='""Is not enough to fill the limits are not enough.:'") +
				 Строка(СтрокаТЧ.НеХватает) + НСтр("ka=', ლიმიტი:';ru=', Лимит:';en=', Limit:'") + Строка(СтрокаТЧ.Лимит));
	КонецЦикла;
	
КонецПроцедуры


&НаСервере
Функция МассивПринятыхВА()
	
	ДатаЗапроса = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата-1, ТекущаяДата());
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
		|ИЗ
		|	РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(&НаДату, ) КАК СостоянияВнеоборотныхАктивовСрезПоследних
		|ГДЕ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияВнеоборотныхАктивов.ПринятКУчету)";
	
	Запрос.УстановитьПараметр("НаДату", ДатаЗапроса);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВнеоборотныйАктив");	
	
КонецФункции


&НаКлиенте
Процедура ЗапасыВнеоборотныйАктивИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	
	МассивПринятыхВА = МассивПринятыхВА();
	НовыйПараметрСсылки = Новый ПараметрВыбора("Отбор.Ссылка", МассивПринятыхВА);
	
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(НовыйПараметрСсылки);
	НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
	Элементы.ЗапасыВнеоборотныйАктив.ПараметрыВыбора = НовыеПараметры;	// Вставить содержимое обработчика.
	
КонецПроцедуры


&НаКлиенте
Процедура СтруктурнаяЕдиницаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПеремещениеЗапасов.СписаниеТаваровНаОС") Тогда 
		
		НовыйПараметрСсылки = Новый ПараметрВыбора("Отбор.ТипСтруктурнойЕдиницы", ПредопределенноеЗначение("Перечисление.ТипыСтруктурныхЕдиниц.Склад"));
		
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НовыйПараметрСсылки);
		НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.СтруктурнаяЕдиница.ПараметрыВыбора = НовыеПараметры;
		
	КонецЕсли;	
	
КонецПроцедуры

// Kuzmich, 16.07.2019, Заполнение Перемещения из заказа покупателя
&НаКлиенте
Процедура ЗаполнитьПоЗаказуПокупателя(ВыбранноеЗначение)
	Если ТипЗНЧ(ВыбранноеЗначение)=Тип("ДокументСсылка.ЗаказПокупателя") Тогда
		
		МассивСтрок = ЗаполнитьПоЗаказуПокупателяНаСервере(ВыбранноеЗначение);
		Для каждого СтрМассивСтрок Из МассивСтрок Цикл
		
			СтрокаТабличнойЧасти = Объект.Запасы.НайтиПоИдентификатору(СтрМассивСтрок);
			Если НЕ СтрокаТабличнойЧасти = НЕОПРЕДЕЛЕНО Тогда
			
				ЗапасыНоменклатураПриИзменении(НЕОПРЕДЕЛЕНО, СтрокаТабличнойЧасти);
				РассчитатьСуммуВСтрокеТабличнойЧасти();
				СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Себестоимость;
				ЗапасыСтранаПроисхожденияПриИзменении(НЕОПРЕДЕЛЕНО, СтрокаТабличнойЧасти);
				ЗапасыНомерГТДПриИзменении(НЕОПРЕДЕЛЕНО, СтрокаТабличнойЧасти);
			
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ЗаполнитьПоЗаказуПокупателяНаСервере(ВыбранноеЗначение)
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Массив();
	
	Для каждого СтрЗапасыЗаказПокупателя Из ВыбранноеЗначение.Запасы Цикл
		
		СтруктураПоиска = Новый Структура("Номенклатура,Характеристика,СерийныеНомера,Партия,НомерГТД,ЗаказПокупателя");
		ЗаполнитьЗначенияСвойств(СтруктураПоиска,СтрЗапасыЗаказПокупателя);
		МассивНайденныхСтрок = Объект.Запасы.НайтиСтроки(СтруктураПоиска);
		
		Если МассивНайденныхСтрок.Количество()=0 Тогда
			СтрокаТабличнойЧасти = Объект.Запасы.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти,СтрЗапасыЗаказПокупателя);
			СтрокаТабличнойЧасти.ЗаказПокупателя = ВыбранноеЗначение.Ссылка;
			РЕЗ.Добавить(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПоЗаказамПокупателя(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("СостояниеЗаказа", Справочники_СостоянияЗаказовПокупателей_Собран());
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", ПараметрыОтбора);
	ПараметрыФормы.Вставить("РежимВыбора", ИСТИНА);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", ИСТИНА);
	ПараметрыФормы.Вставить("МножественныйВыбор", ИСТИНА);
	
	ОткрытьФорму("Документ.ЗаказПокупателя.ФормаВыбора",ПараметрыФормы, ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Функция Справочники_СостоянияЗаказовПокупателей_Собран()
	Возврат Справочники.СостоянияЗаказовПокупателей.Собран;
КонецФункции
