    Ответ = Результат;
    Если Ответ = КодВозвратаДиалога.Да Тогда
        ЗаполнитьПоДокументу(Объект.ДокументОснование);
    КонецЕсли;

КонецПроцедуры // ЗаполнитьПоОснованию()

// Процедура обработчик события команды ЗаполнитьПоОстаткам
//
