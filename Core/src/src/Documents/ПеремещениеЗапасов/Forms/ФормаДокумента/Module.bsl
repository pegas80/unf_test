&НаКлиенте
Процедура ЗаполнитьПроектПоДокументу(ПроектЗначение = Неопределено, мВидОперации)
	
	Если ПроектЗначение = Неопределено Тогда
		Если мВидОперации = "СписаниеНаРасходы" Тогда
			Объект.Проект = КэшЗначений.ПустойПроект;
		ИначеЕсли мВидОперации = "Перемещение" Тогда
			Объект.ПроектОтправитель = КэшЗначений.ПустойПроект;
			Объект.ПроектПолучатель = КэшЗначений.ПустойПроект;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого СтрокаЗапасы Из Объект.Запасы Цикл
		Если мВидОперации = "СписаниеНаРасходы" Тогда
			СтрокаЗапасы.Проект = Объект.Проект;
		ИначеЕсли мВидОперации = "Перемещение" Тогда
			СтрокаЗапасы.ПроектОтправитель = Объект.ПроектОтправитель;
			СтрокаЗапасы.ПроектПолучатель = Объект.ПроектПолучатель;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
