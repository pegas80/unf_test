&НаКлиенте
Процедура ЗапасыКоличествоВДорогеПриИзменении(Элемент)
	ТекДанные = Элементы.Запасы.ТекущиеДанные;
	Если ТекДанные.КоличествоВДороге > ТекДанные.Количество Тогда
		Предупреждение(НСТР("ka='""რაოდენობა გზაში"" არ უნდა იყოს მეტი ""რაოდენობაზე""';ru='""Количество в дороге"" не должно быть больше количества';en='""Number of the road"" should not be greater than the number'"), 20);
		ТекДанные.КоличествоВДороге = ТекДанные.Количество;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ДатаПеремещенияИзТранзитаПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.ДатаПеремещенияИзТранзита) И Объект.ДатаПеремещенияИзТранзита <= Объект.Дата Тогда
		Предупреждение(НСТР("ka='ტრანზიტიდან გადაადგილების თარიღი უნდა იყოს დოკუმენტის თარიღზე მეტი.';ru='Дата перемещения из транзита должно быть больше даты документа.';en='Date of transit movement must be greater than the document date.'"), 20);
		Объект.ДатаПеремещенияИзТранзита = Объект.Дата + 1;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗапонитьКоличествоВДороге(Команда)
	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл
		СтрокаТЧ.КоличествоВДороге = СтрокаТЧ.Количество;
	КонецЦикла;
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКоличествоВДороге(Команда)
	Для Каждого СтрокаТЧ Из Объект.Запасы Цикл
		СтрокаТЧ.КоличествоВДороге = 0;
	КонецЦикла;
	Модифицированность = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЧерезТранзитныйСкладПриИзменении(Элемент)
	ЗаполнитьСтруктурныеЕдиницыПолучателейИУстановитьВидимость("ЧерезТранзитныйСкладПриИзменении");
КонецПроцедуры

&НаКлиенте
Процедура СтруктурнаяЕдиницаКонечныйПолучательПриИзменении(Элемент)
	ЗаполнитьСтруктурныеЕдиницыПолучателейИУстановитьВидимость("СтруктурнаяЕдиницаКонечныйПолучательПриИзменении");
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтруктурныеЕдиницыПолучателейИУстановитьВидимость(ИмяСобытия)
	
	ЭтаПеремещение 			= (Объект.ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.Перемещение);
	ЧерезТранзитныйСклад 	= Объект.ЧерезТранзитныйСклад И ЭтаПеремещение;
	
	//Если ЗначениеЗаполнено(Объект.ДокументПеремещенияВТранзит) Тогда
	//	ТолькоПросмотр = Истина;
	//КонецЕсли;
	
	Элементы.СтруктурнаяЕдиницаКонечныйПолучатель.Видимость = ЧерезТранзитныйСклад;
	Элементы.СтруктурнаяЕдиницаПолучатель.ТолькоПросмотр 	= ЧерезТранзитныйСклад;
	Элементы.ЯчейкаПолучатель.ТолькоПросмотр 				= ЧерезТранзитныйСклад;
	
	Если ИмяСобытия = "ЧерезТранзитныйСкладПриИзменении" ИЛИ
		 ИмяСобытия = "ПриСозданииНаСервере" ИЛИ
		 ИмяСобытия = "ВидОперацииПриИзменении" Тогда
		 
		ЗначениеЗаполнено_ДокументПеремещенияВТранзит = ЗначениеЗаполнено(Объект.ДокументПеремещенияВТранзит); 
		 
		Элементы.ДатаПеремещенияИзТранзита.Видимость	= ЧерезТранзитныйСклад;
		Элементы.ЗапасыКоличествоВДороге.Видимость 		= ЧерезТранзитныйСклад;
		Элементы.ЗапасыЗаполнитьОчистить.Видимость		= ЧерезТранзитныйСклад;
		Элементы.ДокументПеремещенияВТранзит.Видимость	= ЗначениеЗаполнено_ДокументПеремещенияВТранзит;
		Элементы.ДокументОснованиеНадпись.Доступность	= НЕ ЗначениеЗаполнено_ДокументПеремещенияВТранзит;
		Элементы.ЧерезТранзитныйСклад.Видимость			= УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах") И НЕ ЗначениеЗаполнено_ДокументПеремещенияВТранзит;
		
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах") Тогда
			Если ЧерезТранзитныйСклад Тогда
				Если Не ЗначениеЗаполнено(Объект.СтруктурнаяЕдиницаПолучатель) Тогда
					Объект.СтруктурнаяЕдиницаКонечныйПолучатель = Объект.СтруктурнаяЕдиницаПолучатель;
				КонецЕсли;
				Объект.СтруктурнаяЕдиницаКонечныйПолучатель	= УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("СтруктурныеЕдиницы", "ТранзитныйСклад");
			ИначеЕсли ЗначениеЗаполнено(Объект.СтруктурнаяЕдиницаКонечныйПолучатель) Тогда
				Объект.СтруктурнаяЕдиницаКонечныйПолучатель = Объект.СтруктурнаяЕдиницаКонечныйПолучатель;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "СтруктурнаяЕдиницаПолучательПриИзменении" Тогда
		Если ЧерезТранзитныйСклад Тогда
			Объект.СтруктурнаяЕдиницаКонечныйПолучатель = УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("СтруктурныеЕдиницы", "ТранзитныйСклад");
		Иначе
			Объект.СтруктурнаяЕдиницаКонечныйПолучатель	= Объект.СтруктурнаяЕдиницаПолучатель;
		КонецЕсли;
	ИначеЕсли ИмяСобытия = "СтруктурнаяЕдиницаКонечныйПолучательПриИзменении" Тогда
		Объект.СтруктурнаяЕдиницаКонечныйПолучатель = УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("СтруктурныеЕдиницы", "ТранзитныйСклад");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СтруктурнаяЕдиницаКонечныйПолучательОткрытие(Элемент, СтандартнаяОбработка)
	Если Элементы.СтруктурнаяЕдиницаКонечныйПолучатель.РежимВыбораИзСписка
		И НЕ ЗначениеЗаполнено(Объект.СтруктурнаяЕдиницаКонечныйПолучатель) Тогда
		
		СтандартнаяОбработка = Ложь;
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьИДоступностьПоЗаказуНаПеремещения()
	
	пЗаказНаПеремещения = (Объект.ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.Перемещение И ЗначениеЗаполнено(Объект.ДокументОснование) И ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.ВнутреннийЗаказ"));
	Элементы.ЗапасыКоличествоВДороге.Видимость 			= пЗаказНаПеремещения;
	Элементы.ЗапасыЗапонитьКоличествоВДороге.Видимость 	= пЗаказНаПеремещения;
	Элементы.ЗапасыОчиститьКоличествоВДороге.Видимость 	= пЗаказНаПеремещения;
	Если пЗаказНаПеремещения Тогда
		Если Объект.Проведен И НЕ ПравоИзмененияЗаказовНаПеремещения Тогда
			Если ОсновнойСкладПользователя = Объект.СтруктурнаяЕдиницаПолучатель Тогда
				Для Каждого пЭлемент ИЗ ЭтаФорма.Элементы Цикл
					Если ТипЗнч(пЭлемент) = Тип("ПолеФормы") Тогда
						пЭлемент.ТолькоПросмотр = Истина;
					КонецЕсли;
				КонецЦикла;
				Элементы.Запасы.ТолькоПросмотр 							= Ложь;
				Элементы.ЗапасыКоличествоВДороге.ТолькоПросмотр 		= Ложь;
				КомандыЗапасов = Элементы.Запасы.КоманднаяПанель.ПодчиненныеЭлементы;
				Для Каждого пКоманда Из КомандыЗапасов Цикл
					Если ТипЗнч(пКоманда) = Тип("ГруппаФормы") Тогда
						Если НЕ пКоманда.Имя = "ЗапасыЗаполнитьОчистить" Тогда
							ПодчиненныеКоманды = пКоманда.ПодчиненныеЭлементы;
							Для Каждого пПодчиненнаяКоманда Из ПодчиненныеКоманды Цикл
								пПодчиненнаяКоманда.Доступность = Ложь;
							КонецЦикла;
						КонецЕсли;
					Иначе
						пКоманда.Доступность = Ложь;
					КонецЕсли;
				КонецЦикла;
			Иначе
				ТолькоПросмотр = Истина;
				Элементы.Запасы.КоманднаяПанель.Доступность = Ложь;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ТолькоПросмотр = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
