	// Производство.
	Если Константы.ФункциональнаяОпцияИспользоватьПодсистемуПроизводство.Получить() Тогда
		
		// Установка способа выбора структурной единицы в зависимости от ФО.
		Если НЕ Константы.ФункциональнаяОпцияУчетПоНесколькимПодразделениям.Получить()
			И НЕ ФункциональнаяОпцияУчетПоНесколькимСкладам Тогда
			
			Элементы.СтруктурнаяЕдиница.РежимВыбораИзСписка = Истина;
			Элементы.СтруктурнаяЕдиница.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ОсновнойСклад);
			Элементы.СтруктурнаяЕдиница.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение);
			
			Элементы.СтруктурнаяЕдиницаПолучатель.РежимВыбораИзСписка = Истина;
			Элементы.СтруктурнаяЕдиницаПолучатель.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение);
			Элементы.СтруктурнаяЕдиницаПолучатель.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ОсновнойСклад);
			//Паганини_
			Элементы.СтруктурнаяЕдиницаКонечныйПолучатель.РежимВыбораИзСписка = Истина;
			Элементы.СтруктурнаяЕдиницаКонечныйПолучатель.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение);
			Элементы.СтруктурнаяЕдиницаКонечныйПолучатель.СписокВыбора.Добавить(Справочники.СтруктурныеЕдиницы.ОсновнойСклад);
			//_Паганини
		КонецЕсли;
		
	КонецЕсли;
	
	Если Константы.ФункциональнаяОпцияИспользоватьПодсистемуПроизводство.Получить()
		ИЛИ ФункциональнаяОпцияУчетПоНесколькимСкладам Тогда
		
		Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийПеремещениеЗапасов.Перемещение, НСтр("ka='მარაგების გადაადგილება';ru='Перемещение';en='displacement'"));
		
	ИначеЕсли НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Объект.ВидОперации = Перечисления.ВидыОперацийПеремещениеЗапасов.СписаниеНаРасходы;
		
	КонецЕсли;
	
	Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийПеремещениеЗапасов.СписаниеНаРасходы, НСтр("ka='ხარჯებზე ჩამოწერა';ru='Списание на расходы';en='Deduction of expenses'"));
	Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийПеремещениеЗапасов.ПередачаВЭксплуатацию, НСтр("ka='ექსპლუატაციაში გადაცემა';ru='Передача в эксплуатацию';en='Transfer into operation'"));
	Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийПеремещениеЗапасов.ВозвратИзЭксплуатации, НСтр("ka='ექსპლუატაციიდან დაბრუნება';ru='Возврат из эксплуатации';en='Return of service'"));
	Элементы.ВидОперации.СписокВыбора.Добавить(Перечисления.ВидыОперацийПеремещениеЗапасов.СписаниеТаваровНаОС, НСтр("ka='მარაგების ძ/ს–ზე ჩამოწერა';ru='Списание таваров на ОС';en='Write-off of Tawara OS'"));//+++ Дмгг
	
