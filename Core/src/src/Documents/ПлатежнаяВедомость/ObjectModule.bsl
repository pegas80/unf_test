//ПодольскийАИ #УчетПроектов 25.11.2020 {
Процедура РаспределитьОстаткиСотрудникиПоПроектам()
	
	ТабЧастьСотрудники = ЭтотОбъект.Сотрудники.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Таблица.Сотрудник,
	|	выбор 
	|		когда &СтруктурнаяЕдиница = Значение(Справочник.СтруктурныеЕдиницы.ПустаяСсылка) 
	|			тогда Таблица.СтруктурнаяЕдиница 
	|			иначе &СтруктурнаяЕдиница 
	|	конец как СтруктурнаяЕдиница, //Малышев 2025-02-12 ONESOFT-3849
	|	Таблица.СуммаПлатежа КАК СуммаПлатежа,
	|	Таблица.СуммаРасчетов КАК СуммаРасчетов,
	|	Таблица.ВидУдержанияНДФЛ КАК ВидУдержанияНДФЛ,
	|	Таблица.НДФЛПлатежа КАК НДФЛПлатежа,
	|	Таблица.ВидУдержанияПФ КАК ВидУдержанияПФ,
	|	Таблица.СуммаПФПлатежа КАК СуммаПФПлатежа,
	|	Таблица.СуммаЛгот КАК СуммаЛгот
	|ПОМЕСТИТЬ ДокТЧ
	|ИЗ
	|	&ТаблицаДокумента КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Таблица.Сотрудник КАК Сотрудник,
	|	Таблица.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница, //Малышев 2025-02-12 ONESOFT-3849
	|	Таблица.СуммаПлатежа КАК СуммаПлатежа,
	|	Таблица.СуммаРасчетов КАК СуммаРасчетов,
	|	Таблица.ВидУдержанияНДФЛ КАК ВидУдержанияНДФЛ,
	|	Таблица.НДФЛПлатежа КАК НДФЛПлатежа,
	|	Таблица.ВидУдержанияПФ КАК ВидУдержанияПФ,
	|	Таблица.СуммаПФПлатежа КАК СуммаПФПлатежа,
	|	Таблица.СуммаЛгот КАК СуммаЛгот,
	|	РасчетыСПерсоналомОстатки.Проект КАК Проект,
	|	СУММА(ВЫБОР
	|			КОГДА &ВалютаРасчетов = &ВалютаДокумента
	|				ТОГДА РасчетыСПерсоналомОстатки.СуммаВалОстаток
	|			ИНАЧЕ ВЫРАЗИТЬ(РасчетыСПерсоналомОстатки.СуммаВалОстаток * &Курс * КурсыВалютыДокумента.Кратность / КурсыВалютыДокумента.Курс * &Кратность КАК ЧИСЛО(15, 2))
	|		КОНЕЦ) КАК СуммаПлатежаПоПроекту,
	|	СУММА(ЕСТЬNULL(РасчетыСПерсоналомОстатки.СуммаОстаток, 0)) КАК СуммаРасчетовПоПроекту
	|ИЗ
	|	ДокТЧ КАК Таблица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСПерсоналом.Остатки(
	|				,
	|				Организация = &Организация
	|					И ПериодРегистрации = &ПериодРегистрации
	|					И Валюта = &ВалютаРасчетов
	//|					И СтруктурнаяЕдиница = &СтруктурнаяЕдиница  
	|					И (&СтруктурнаяЕдиница = Значение(Справочник.СтруктурныеЕдиницы.ПустаяСсылка) 
	|						или СтруктурнаяЕдиница = &СтруктурнаяЕдиница)	//Малышев 2025-02-12 ONESOFT-3849
	|			) КАК РасчетыСПерсоналомОстатки
	//|		ПО Таблица.Сотрудник = РасчетыСПерсоналомОстатки.Сотрудник ,
	|		ПО Таблица.Сотрудник = РасчетыСПерсоналомОстатки.Сотрудник и Таблица.СтруктурнаяЕдиница = РасчетыСПерсоналомОстатки.СтруктурнаяЕдиница,
	|	РегистрСведений.КурсыВалют.СрезПоследних(&Дата, Валюта = &ВалютаДокумента) КАК КурсыВалютыДокумента
	|ГДЕ
	|	РасчетыСПерсоналомОстатки.СуммаВалОстаток > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	Таблица.Сотрудник,
	|	Таблица.СтруктурнаяЕдиница, //Малышев 2025-02-12 ONESOFT-3849
	|	Таблица.СуммаПлатежа,
	|	Таблица.СуммаРасчетов,
	|	Таблица.ВидУдержанияНДФЛ,
	|	Таблица.НДФЛПлатежа,
	|	Таблица.ВидУдержанияПФ,
	|	Таблица.СуммаПФПлатежа,
	|	Таблица.СуммаЛгот,
	|	РасчетыСПерсоналомОстатки.Проект
	|ИТОГИ
	|	МАКСИМУМ(СуммаПлатежа),
	|	МАКСИМУМ(СуммаРасчетов),
	|	МАКСИМУМ(НДФЛПлатежа),
	|	МАКСИМУМ(СуммаПФПлатежа),
	|	МАКСИМУМ(СуммаЛгот),
	|	СУММА(СуммаПлатежаПоПроекту),
	|	СУММА(СуммаРасчетовПоПроекту)
	|ПО
	|	Сотрудник,
	|	СтруктурнаяЕдиница, //Малышев 2025-02-12 ONESOFT-3849
	|	ВидУдержанияНДФЛ,
	|	ВидУдержанияПФ";
	
	Запрос.УстановитьПараметр("ТаблицаДокумента",	ТабЧастьСотрудники);
	Запрос.УстановитьПараметр("ПериодРегистрации", 	ПериодРегистрации);
	Запрос.УстановитьПараметр("Организация", 		УправлениеНебольшойФирмойСервер.ПолучитьОрганизацию(Организация));
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ВалютаРасчетов",		ВалютаРасчетов);
	Запрос.УстановитьПараметр("ВалютаДокумента",	ВалютаДокумента);
	Запрос.УстановитьПараметр("Курс",				Курс);
	Запрос.УстановитьПараметр("Кратность",			Кратность);
	Запрос.УстановитьПараметр("КонецМесяца", 		КонецМесяца(ПериодРегистрации));
	Запрос.УстановитьПараметр("Дата", 				Дата);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ЭтотОбъект.Сотрудники.Очистить();
	
	ВыборкаСотрудник = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСотрудник.Следующий() Цикл
		//Малышев (--  2025-02-12 ONESOFT-3849
		ВыборкаСтруктурнаяЕдиница = ВыборкаСотрудник.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	    Пока ВыборкаСтруктурнаяЕдиница.Следующий() Цикл
		
		//ВыборкаНДФЛ = ВыборкаСотрудник.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВыборкаНДФЛ = ВыборкаСтруктурнаяЕдиница.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		//Малышев --)
		Пока ВыборкаНДФЛ.Следующий() Цикл
			
			ВыборкаПФ = ВыборкаНДФЛ.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПФ.Следующий() Цикл
				
				ОсталосьСуммаРасчетов = ВыборкаПФ.СуммаРасчетов;
				ОсталосьНДФЛПлатежа = ВыборкаПФ.НДФЛПлатежа;
				ОсталосьСуммаПФПлатежа = ВыборкаПФ.СуммаПФПлатежа;
				ОсталосьСуммаЛгот = ВыборкаПФ.СуммаЛгот;
				
				ДобавленаСтрока = Ложь;
				ВыборкаДет = ВыборкаПФ.Выбрать();
				Пока ВыборкаДет.Следующий() Цикл
					СтрокаСотрудник = ЭтотОбъект.Сотрудники.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаСотрудник, ВыборкаДет);
					
					Коэффициент = 0;
					Если ВыборкаПФ.СуммаПлатежа <> 0 Тогда
						Коэффициент = ВыборкаДет.СуммаПлатежаПоПроекту / СтрокаСотрудник.СуммаПлатежа;
					КонецЕсли;
					
					СтрокаСотрудник.СуммаПлатежа = ВыборкаДет.СуммаПлатежаПоПроекту;
					СтрокаСотрудник.СуммаРасчетов = ВыборкаДет.СуммаРасчетовПоПроекту;
					
					СтрокаСотрудник.НДФЛПлатежа = Окр(СтрокаСотрудник.НДФЛПлатежа * Коэффициент, 2);
					СтрокаСотрудник.СуммаПФПлатежа = Окр(СтрокаСотрудник.СуммаПФПлатежа * Коэффициент, 2);
					СтрокаСотрудник.СуммаЛгот = Окр(СтрокаСотрудник.СуммаЛгот * Коэффициент, 2);
					
					ОсталосьСуммаРасчетов = ОсталосьСуммаРасчетов - СтрокаСотрудник.СуммаПлатежа;
					ОсталосьНДФЛПлатежа = ОсталосьНДФЛПлатежа - СтрокаСотрудник.НДФЛПлатежа;
					ОсталосьСуммаПФПлатежа = ОсталосьСуммаПФПлатежа - СтрокаСотрудник.СуммаПФПлатежа;
					ОсталосьСуммаЛгот = ОсталосьСуммаЛгот - СтрокаСотрудник.СуммаЛгот;
					
					ДобавленаСтрока = Истина;
				КонецЦикла;
				
				Если ДобавленаСтрока Тогда
					Если ОсталосьСуммаРасчетов <> 0 Тогда
						СтрокаСотрудник.СуммаРасчетов = СтрокаСотрудник.СуммаРасчетов + ОсталосьСуммаРасчетов;
					КонецЕсли;
					Если ОсталосьНДФЛПлатежа <> 0 Тогда
						СтрокаСотрудник.НДФЛПлатежа = СтрокаСотрудник.НДФЛПлатежа + ОсталосьНДФЛПлатежа;
					КонецЕсли;
					Если ОсталосьСуммаПФПлатежа <> 0 Тогда
						СтрокаСотрудник.СуммаПФПлатежа = СтрокаСотрудник.СуммаПФПлатежа + ОсталосьСуммаПФПлатежа;
					КонецЕсли;
					Если ОсталосьСуммаЛгот <> 0 Тогда
						СтрокаСотрудник.СуммаЛгот = СтрокаСотрудник.СуммаЛгот + ОсталосьСуммаЛгот;
					КонецЕсли;
					ДобавленаСтрока = Ложь;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		КонецЦикла; //СтруктурнаяЕдиница
	КонецЦикла;
	
КонецПроцедуры
