	"ВЫБРАТЬ
	|	Константы.ФункциональнаяОпцияУчетПоПроектам КАК УчетПоПроектам
	|ИЗ
	|	Константы КАК Константы");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Формирование ключей, содержащих данные учетной политики.
	Для каждого Колонка Из РезультатЗапроса.Колонки Цикл
		ДопСвойства.Вставить(Колонка.Имя);
	КонецЦикла;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	// Заполнение значений для ключей, содержащих данные учетной политики.
	ЗаполнитьЗначенияСвойств(ДопСвойства, Выборка);
	
	//ПодольскийАИ #УчетПроектов 25.11.2020 }
	
	Если ВидОперации = Перечисления.ВидыОперацийПлатежнаяВедомость.Зарплата Тогда
	
