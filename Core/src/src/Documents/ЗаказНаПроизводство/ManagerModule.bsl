	|	КОНЕЦ";
    // Kuzmich, ONESOFT-2440, Использование резервов - Переместить в хранилище - Исправления
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаЗаказНаПроизводство);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ИспользоватьХарактеристики", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьХарактеристики);
	Запрос.УстановитьПараметр("ИспользоватьПартии",  СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьПартии);
	Запрос.УстановитьПараметр("РезервированиеЗапасов", НСтр("ka='მარაგების რეზერვირება';ru='Резервирование запасов';en='inventory reservations'"));
    Запрос.УстановитьПараметр("УчетПоПроектам",  СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам); //Малышев 2024-06-26 ONESOFT-3279
	
	Результат = Запрос.ВыполнитьПакет();

	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаГрафикДвиженияЗапасов", Результат[0].Выгрузить());
