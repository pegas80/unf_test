&НаСервере
Процедура ЗаполнитьПлатежныеВедомостиДетальныйНаСервере(Ведомость)
	
	Для Каждого Строк Из Ведомость.Сотрудники Цикл 
		
		СтруктураПоиска = Новый Структура("Ведомость, Сотрудник", Ведомость, Строк.Сотрудник);
		
		МассивСтроок = Объект.ПлатежныеВедомостиДетальный.НайтиСтроки(СтруктураПоиска);
		
		Если МассивСтроок.Количество() = 0 Тогда 
			
			СтрокаЗаполнения = Объект.ПлатежныеВедомостиДетальный.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаЗаполнения, Строк);
			СтрокаЗаполнения.Ведомость = Ведомость;
			СтрокаЗаполнения.Сумма = Строк.СуммаРасчетов;
			
		Иначе 
			
			Продолжить;
			
		КонецЕсли;	
		
	КонецЦикла;
	
