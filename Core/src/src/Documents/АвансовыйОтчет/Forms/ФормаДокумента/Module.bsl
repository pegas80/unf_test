&НаСервере
Процедура ПересчитатьСуммыТЧ(ПредНалогообложениеНДС, ПредСуммаВключаетНДС, пСтавкаНДСПоУмолчанию = Неопределено)
	
	ОблагаетсяНДС					= (Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС);
	ИзмениласьСуммаВключаетНДС		= НЕ ПредСуммаВключаетНДС = Объект.СуммаВключаетНДС;
	ИзмениласьНалогообложениеНДС	= (   ПредНалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС И НЕ ОблагаетсяНДС) ИЛИ
								      (НЕ ПредНалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС И    ОблагаетсяНДС);
	Если НЕ ИзмениласьСуммаВключаетНДС И НЕ ИзмениласьНалогообложениеНДС Тогда
		Возврат;
	КонецЕсли;
	Если пСтавкаНДСПоУмолчанию = Неопределено Тогда
		пСтавкаНДСПоУмолчанию	= Объект.Организация.СтавкаНДСПоУмолчанию
	КонецЕсли;
	
	//Запасы
	Для Каждого СтрокаЗапасы  ИЗ Объект.Запасы Цикл
		Если ИзмениласьНалогообложениеНДС Тогда
			Если ОблагаетсяНДС Тогда
				Номенклатура			= СтрокаЗапасы.Номенклатура;
				СтрокаЗапасы.СтавкаНДС	= ?(ЗначениеЗаполнено(Номенклатура.СтавкаНДС), Номенклатура.СтавкаНДС, пСтавкаНДСПоУмолчанию);
			Иначе
				Если Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
					СтрокаЗапасы.СтавкаНДС	= УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
				Иначе
					СтрокаЗапасы.СтавкаНДС	= УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		РС_ОбщегоНазначения.ПересчитатьСуммыСтроки_АвансовыйОтчет_Запасы("Всего", СтрокаЗапасы, Объект.СуммаВключаетНДС);
	КонецЦикла;
	//Расходы
	Для Каждого СтрокаРасходы ИЗ Объект.Расходы Цикл
		Если ИзмениласьНалогообложениеНДС Тогда
			Если ОблагаетсяНДС Тогда
				Номенклатура			= СтрокаРасходы.Номенклатура;
				СтрокаРасходы.СтавкаНДС	= ?(ЗначениеЗаполнено(Номенклатура.СтавкаНДС), Номенклатура.СтавкаНДС, пСтавкаНДСПоУмолчанию);
			Иначе
				Если Объект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
					СтрокаРасходы.СтавкаНДС	= УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
				Иначе
					СтрокаРасходы.СтавкаНДС	= УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ДополнительныеРасходы("СуммаБезНалогов", СтрокаРасходы, Объект.СуммаВключаетНДС);
	КонецЦикла;
	
КонецПроцедуры

