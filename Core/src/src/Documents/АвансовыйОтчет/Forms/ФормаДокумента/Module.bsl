&НаКлиенте
Процедура Подбор(Команда)
	
	
	Если Объект.Оплаты.Количество()= 0 тогда
		ПоказатьПредупреждение(Неопределено,НСтр("ka='დასაწყისში მიუთითეთ კონტრაგენტი!';ru='Укажите вначале контрагента!';en='Specify the first contractor!'"));
		Возврат;
	КонецЕсли;
	
	АдресРасшифровкаПлатежаВХранилище = ПоместитьОплатыВХранилище();
	
	ПараметрыПодбора = Новый Структура(
		"АдресРасшифровкаПлатежаВХранилище,
		|Компания,
		|ВалютаДенежныхСредств,
		|Дата,
		|Ссылка,
		|СуммаДокумента",
		АдресРасшифровкаПлатежаВХранилище,
		Компания,
		Объект.ВалютаДокумента,
		Объект.Дата,
		Объект.Ссылка,
		СуммаДокумента);
	
	Результат = Неопределено;
	
	ОткрытьФорму("Документ.АвансовыйОтчет.Форма.ФормаПодбораДолговПоставщикам", ПараметрыПодбора,,,,, Новый ОписаниеОповещения("ПодборЗавершение", ЭтотОбъект, Новый Структура("АдресРасшифровкаПлатежаВХранилище", АдресРасшифровкаПлатежаВХранилище)));
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборЗавершение(Результат1, ДополнительныеПараметры) Экспорт
	
	АдресРасшифровкаПлатежаВХранилище = ДополнительныеПараметры.АдресРасшифровкаПлатежаВХранилище;
		
	Результат = Результат1;
	Если Результат = КодВозвратаДиалога.OK Тогда	
		ПолучитьОплатыИзХранилища(АдресРасшифровкаПлатежаВХранилище);		
	КонецЕсли;

КонецПроцедуры 

&НаСервере
Функция ПоместитьОплатыВХранилище()
	
	Возврат ПоместитьВоВременноеХранилище(
		Объект.Оплаты.Выгрузить(,
			"Контрагент,
			|Договор,
			|ПризнакАванса,
			|Документ,
			|Заказ,
			|СуммаРасчетов,
			|Курс,
			|Кратность,
			|СуммаПлатежа"
		),
		УникальныйИдентификатор
	);
	
КонецФункции

&НаСервере
Процедура ПолучитьОплатыИзХранилища(АдресРасшифровкаПлатежаВХранилище, Очищать = Истина)
	
	ТаблицаРасшифровкаПлатежа = ПолучитьИзВременногоХранилища(АдресРасшифровкаПлатежаВХранилище);
	Если Очищать Тогда
		Объект.Оплаты.Очистить();
	КонецЕсли;
	Для каждого СтрокаОплаты Из ТаблицаРасшифровкаПлатежа Цикл
		Строка = Объект.Оплаты.Добавить();
		ЗаполнитьЗначенияСвойств(Строка, СтрокаОплаты);
		Строка.ВестиРасчетыПоДоговорам = СтрокаОплаты.Контрагент.ВестиРасчетыПоДоговорам;
		Строка.ВестиРасчетыПоДокументам = СтрокаОплаты.Контрагент.ВестиРасчетыПоДокументам;
		Строка.ВестиРасчетыПоЗаказам = СтрокаОплаты.Контрагент.ВестиРасчетыПоЗаказам;
		Строка.ВестиУчетОплатыПоСчетам = СтрокаОплаты.Контрагент.ВестиУчетОплатыПоСчетам;	
			
		Строка.Курс = ?(
		Строка.Курс = 0,
		1,
		Строка.Курс
		);
		Строка.Кратность = ?(
		Строка.Кратность = 0,
		1,
		Строка.Кратность
		);
		
		Строка.СуммаПлатежа = УправлениеНебольшойФирмойСервер.ПересчитатьИзВалютыВВалюту(
		Строка.СуммаРасчетов,
		Строка.Курс,
		Объект.Курс,
		Строка.Кратность,
		Объект.Кратность
		);		
	КонецЦикла;
	
	ПотраченоИтог = Объект.Запасы.Итог("Всего") + Объект.Расходы.Итог("Всего") + Объект.Оплаты.Итог("СуммаПлатежа") + Объект.ПлатежныеВедомости.Итог("Сумма");
	
КонецПроцедуры

