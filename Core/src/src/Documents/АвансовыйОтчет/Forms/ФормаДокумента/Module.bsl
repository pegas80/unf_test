	// Олег Литвиненко <---
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСуммуНДФЛ(СтрокаТЧ)

	Если Не ЗначениеЗаполнено(СтрокаТЧ.ТипНДФЛ) И Не ЗначениеЗаполнено(СтрокаТЧ.Документ) Тогда
		СтрокаТЧ.СуммаНДФЛ = 0;//Паганини
		Возврат;
	КонецЕсли;
	
	// заполним сумму НДФЛ по типу НДФЛ, выбранного документа
	СтрокаТЧ.СуммаНДФЛ = ЗаполнитьСуммуНДФЛПоТипуНДФЛДокументаОплаты(СтрокаТЧ.ТипНДФЛ, СтрокаТЧ.Документ);
	
КонецПроцедуры // ЗаполнитьСуммуНДФЛ()


&НаСервереБезКонтекста
Функция ЗаполнитьСуммуНДФЛПоТипуНДФЛДокументаОплаты(ТипНДФЛ, ДокументОплаты)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СУММА(ДополнительныеРасходыРасходы.СуммаНДФЛ) КАК СуммаНДФЛ,
		|	ДополнительныеРасходыРасходы.ТипНДФЛ
		|ИЗ
		|	Документ.ДополнительныеРасходы.Расходы КАК ДополнительныеРасходыРасходы
		|ГДЕ
		|	ДополнительныеРасходыРасходы.ТипНДФЛ = &ТипНДФЛ
		|	И ДополнительныеРасходыРасходы.Ссылка = &ДокументОплаты
		|
		|СГРУППИРОВАТЬ ПО
		|	ДополнительныеРасходыРасходы.ТипНДФЛ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СУММА(ПриходнаяНакладнаяРасходы.СуммаНДФЛ),
		|	ПриходнаяНакладнаяРасходы.ТипНДФЛ
		|ИЗ
		|	Документ.ПриходнаяНакладная.Расходы КАК ПриходнаяНакладнаяРасходы
		|ГДЕ
		|	ПриходнаяНакладнаяРасходы.ТипНДФЛ = &ТипНДФЛ
		|	И ПриходнаяНакладнаяРасходы.Ссылка = &ДокументОплаты
		|
		|СГРУППИРОВАТЬ ПО
		|	ПриходнаяНакладнаяРасходы.ТипНДФЛ";
	
	Запрос.УстановитьПараметр("ДокументОплаты"	, ДокументОплаты);
	Запрос.УстановитьПараметр("ТипНДФЛ"			, ТипНДФЛ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	СуммаНДФЛ = 0;
	
	Если Выборка.Следующий() Тогда
		СуммаНДФЛ = Выборка.СуммаНДФЛ;	
	КонецЕсли;

	Возврат СуммаНДФЛ;	

КонецФункции // ЗаполнитьСуммуНДФЛПоТипуНДФЛДокументаОплаты()

// Олег Литвиненко 11.10.22 --->
&НаКлиенте
Процедура ЗаполнитьСуммуРасчетов(СтрокаТекущиеДанные)
	
	СтрокаТекущиеДанные.СуммаРасчетов = ЗаполнитьСуммуРасчетовПоДокументу(СтрокаТекущиеДанные.Документ);
	
КонецПроцедуры

&НаСервере
Функция ЗаполнитьСуммуРасчетовПоДокументу(Документ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	РасчетыСПоставщикамиОстатки.СуммаОстаток КАК СуммаОстаток
	               |ИЗ
	               |	РегистрНакопления.РасчетыСПоставщиками.Остатки(
	               |			&НаДату,
	               |			Организация = &Организация
	               |				И Документ = &Документ) КАК РасчетыСПоставщикамиОстатки";
	Запрос.УстановитьПараметр("НаДату", ?(ЗначениеЗаполнено(Объект.Ссылка), Новый Граница(Новый МоментВремени(Объект.Дата, Объект.Ссылка), ВидГраницы.Исключая), ТекущаяДата()));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Документ", Документ);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка.СуммаОстаток, 0);
	
КонецФункции// Олег Литвиненко <---

