	//Паганини ПФ_
	//РассчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТабличнойЧасти);
	РассчитатьСуммуВСтрокеТабличнойЧасти(Элементы.Расходы.ТекущаяСтрока, "Расходы", "Количество");
