&НаКлиенте
// Процедура заполняет табличную часть Сотрудники остатками по начислениям.
//
Процедура ПересчитатьСуммуПоВалюте(СтрокаТабличнойЧасти, ИзмененоНачисление, ИзмененоКВыдаче, ДополнительныеПараметры = Неопределено)
	
	РасчитатьСуммы_ПФ_НДФЛ(Элементы.ПлатежныеВедомостиДетальный.ТекущаяСтрока);//Паганини ПФ
	
КонецПроцедуры

&НаСервере
Процедура РасчитатьСуммы_ПФ_НДФЛ(Идентификатор)
	
	СтавкаНДФЛ	= 0;
	СтавкаПФ	= 0;
	
	Если ТипЗнч(Идентификатор) = Тип("Число") Тогда
		ТекСтрока = Объект.ПлатежныеВедомостиДетальный.НайтиПоИдентификатору(Идентификатор);
	Иначе
		ТекСтрока = Идентификатор; 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекСтрока.ВидУдержанияНДФЛ) Тогда
		СтавкаНДФЛ = ТекСтрока.ВидУдержанияНДФЛ.СтавкаНДФЛ;
	КонецЕсли;
	Если ЗначениеЗаполнено(ТекСтрока.ВидУдержанияПФ) Тогда
		СтавкаПФ = ТекСтрока.ВидУдержанияПФ.СтавкаПФ;
	КонецЕсли;
	
	СтрукОтвета = ПолучитьСуммоНалоговыхЛгот(Объект.Организация,ТекСтрока.Сотрудник,ТекСтрока.СтруктурнаяЕдиница,ТекСтрока.Ведомость.ПериодРегистрации,ТекСтрока.Ведомость);
	СуммаЛгот = СтрукОтвета.Сумма;
	ПроцентПодоходного = СтрукОтвета.ПроцентПодоходного;
	СуммаПлатежа = ТекСтрока.Сумма;
	СтавкаЛгот = СтавкаНДФЛ-ПроцентПодоходного;
	
	Если СтавкаЛгот < 0 Тогда
		СтавкаЛгот = 0
	КонецЕсли;	
	
	НДФЛЛгот = СуммаЛгот * (СтавкаЛгот/100);	
	НэтЛгот = СуммаЛгот - НДФЛЛгот;
	
	Если НэтЛгот >= СуммаПлатежа Тогда	
		
		Если СуммаПлатежа/((100-СтавкаЛгот)/100) < СуммаЛгот Тогда
			СуммаДляНалогов = 0;
			СуммаЛгот = СуммаПлатежа/((100-СтавкаЛгот)/100); 
		Иначе
			СуммаДляНалогов = Окр(СуммаПлатежа /((100-СтавкаЛгот)/100),2) - СуммаЛгот;
			СуммаЛгот = СуммаЛгот;
		КонецЕсли;	
		
		НДФЛБезЛгот = Окр((СуммаДляНалогов) /((100-СтавкаНДФЛ)/100), 2) - СуммаДляНалогов;
		НДФЛЛгот    = Окр((СуммаЛгот) - СуммаЛгот*((100-СтавкаЛгот)/100),2);
		
	Иначе		
		НДФЛБезЛгот = Окр((СуммаПлатежа - НэтЛгот)/((100-СтавкаНДФЛ)/100) - (СуммаПлатежа - НэтЛгот),2);			
	КонецЕсли;	
		
		
	ТекСтрока.НДФЛПлатежа		= НДФЛБезЛгот + НДФЛЛгот;
	ТекСтрока.СуммаЛгот = СуммаЛгот;
	ТекСтрока.СуммаПФПлатежа	= Окр((ТекСтрока.Сумма + ТекСтрока.НДФЛПлатежа) * СтавкаПФ/(100 - СтавкаПФ), 2);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСуммоНалоговыхЛгот(Организация,Сотрудник,Подразделение,Дата,Ведомость) 
	
	СтрукОтвета = Новый Структура;
	СтрукОтвета.Вставить("Сумма",0);
	СтрукОтвета.Вставить("ПроцентПодоходного",20);
	
	Если Ведомость.ВидОперации = Перечисления.ВидыОперацийПлатежнаяВедомость.Аванс Тогда
		СтрукОтвета = РС_ОбщегоНазначения.ПолучитьСуммоНалоговыхЛгот(Организация,Сотрудник,Подразделение,Дата+1);
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	НалоговыеЛготыОстатки.Сотрудник,
	               |	НалоговыеЛготыОстатки.СуммаОстаток КАК Сумма,
	               |	НалоговыеЛготыОстатки.Организация,
	               |	НалоговыеЛготыОстатки.Подразделение,
	               |	НалоговыеЛготыИнформацияСрезПоследних.ПроцентПодоходного
	               |ИЗ
	               |	РегистрНакопления.НалоговыеЛготы.Остатки(
	               |			&Дата,
	               |			Организация = &Организация
	               |				И Подразделение = &Подразделение
	               |				И Сотрудник = &Сотрудник
	               |				И ТипЛгот = &ТипЛгот) КАК НалоговыеЛготыОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалоговыеЛготыИнформация.СрезПоследних КАК НалоговыеЛготыИнформацияСрезПоследних
	               |		ПО НалоговыеЛготыОстатки.Организация = НалоговыеЛготыИнформацияСрезПоследних.Организация
	               |			И НалоговыеЛготыОстатки.Сотрудник = НалоговыеЛготыИнформацияСрезПоследних.Сотрудник
	               |			И НалоговыеЛготыОстатки.Подразделение = НалоговыеЛготыИнформацияСрезПоследних.Подразделение";
	
	
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	Запрос.УстановитьПараметр("Сотрудник",Сотрудник);
	Запрос.УстановитьПараметр("Дата",Дата+1);
	Запрос.УстановитьПараметр("Организация",Организация);	
	
	Если Ведомость.ВидОперации = Перечисления.ВидыОперацийПлатежнаяВедомость.УдержаниеДляКонтрагента Тогда
		Запрос.УстановитьПараметр("ТипЛгот",Перечисления.ТипЛгот.УдержаниеДляКонтрагента);
	Иначе
		Запрос.УстановитьПараметр("ТипЛгот",Перечисления.ТипЛгот.Прочее);
	КонецЕсли;
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		СтрукОтвета.Сумма = СтрукОтвета.Сумма + Выборка.Сумма;
		СтрукОтвета.ПроцентПодоходного = Выборка.ПроцентПодоходного;
	КонецЕсли; 
	
	Возврат СтрукОтвета;
	
КонецФункции
//--- Дмгг, 07.05.2025, ONESOFT-4025
