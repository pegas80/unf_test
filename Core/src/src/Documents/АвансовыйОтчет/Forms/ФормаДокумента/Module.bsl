&НаСервере
Процедура ПересчитатьСуммыСтрокиРасхода(Идентификатор, ИмяПоля)
	Если Идентификатор = Неопределено Тогда
		Для Каждого СтрокаТЧ ИЗ Объект.Расходы Цикл
			Идентификатор = СтрокаТЧ.ПолучитьИдентификатор();
			ТекДанные = Объект.Расходы.НайтиПоИдентификатору(Идентификатор);
			РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
		КонецЦикла;
	Иначе
		ТекДанные = Объект.Расходы.НайтиПоИдентификатору(Идентификатор);
		РС_ОбщегоНазначения.ПересчитатьСуммыСтрокиРасхода_ДополнительныеРасходы(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
	КонецЕсли;
КонецПроцедуры


