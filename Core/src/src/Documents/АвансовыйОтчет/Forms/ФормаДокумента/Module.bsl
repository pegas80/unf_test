			ТекДанные = Объект.РасшифровкаПлатежа.НайтиПоИдентификатору(Идентификатор);
			РС_ОбщегоНазначения.ПересчитатьСуммыСтроки_АвансовыйОтчет_Запасы(ИмяПоля, ТекДанные, Объект.СуммаВключаетНДС);
