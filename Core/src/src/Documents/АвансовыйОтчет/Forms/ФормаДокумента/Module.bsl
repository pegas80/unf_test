		//КонецЦикла;	
		//_Паганини ПФ
		
	КонецЕсли;	
	
	//Паганини ПФ_
	ПересчитатьСуммыТЧ(ПредНалогообложениеНДС, ПредСуммаВключаетНДС, Объект.Организация.СтавкаНДСПоУмолчанию);
	//_Паганини ПФ
	
