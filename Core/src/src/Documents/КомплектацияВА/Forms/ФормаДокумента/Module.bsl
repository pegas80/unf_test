&НаКлиенте
Функция ПолучитьДанныеВыбораПоАдресу(Элемент, Адрес, СтандартнаяОбработка)

    // Выключим стандартную обработку
    СтандартнаяОбработка    =    Ложь;
    
    // Определим структуру для получения параметров отбора, 
    // так как стандартный выбор мы выключим значения структуры пусты                                                            
    ПараметрыПодбора    =    Новый Структура("Отбор,СтрокаПоиска,ВыборГруппИЭлементов",
                                Новый Структура(), // Здесь можно установить отбор
                                "",                // Передаем введенный в поле текст
                                ПредопределенноеЗначение("ИспользованиеГруппИЭлементов.Элементы"));
                                
    // Дополним стандартную структуру с дополнительными параметрами для поиска по адресу
    ПараметрыПодбора.Вставить("ДополнительныеПараметры", Новый Структура("Адрес", Адрес));
    
    
    // Передаем адрес и получаем список выбора
    Возврат    ПолучитьДанныеВыбора(Тип("СправочникСсылка.Адреса"), ПараметрыПодбора);

КонецФункции

&НаКлиенте
Процедура РедактироватьАдресаЗавершение(Результат, ДополнительныеПараметры) Экспорт
    
	//ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	ТекСтрока = Элементы.ГруппаПервичныеДанные.ПодчиненныеЭлементы.Адрес.ВыделенныйТекст;
	Если ЗначениеЗаполнено(Результат) Тогда 
		//ТекСтрока.Адрес = Результат;
		Объект.Адрес = Результат ;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыАдресНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	
	П = Новый Структура;
	П.Вставить("Ключ", ТекСтрока.Адрес);
	
	ОткрытьФорму("Справочник.Адреса.ФормаВыбора", П, ЭтаФорма,,,,Новый ОписаниеОповещения("РедактироватьАдресаЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыАдресОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	
	ТекСтрока.Адрес    =    ВыбранноеЗначение;	

КонецПроцедуры

&НаКлиенте
Процедура ВнеоборотныеАктивыАдресАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;

    знТекст    =    ?(ПустаяСтрока(Текст), ТекСтрока.Адрес, Текст);
    ДанныеВыбора    =    ПолучитьДанныеВыбораПоАдресу(Элемент, знТекст, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура АдресНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	//ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	ТекСтрока = Элементы.ГруппаПервичныеДанные.ПодчиненныеЭлементы.Адрес.ВыделенныйТекст;	
	П = Новый Структура;
	//П.Вставить("Ключ", ТекСтрока.Адрес);
	П.Вставить("Ключ", ТекСтрока);
	ОткрытьФорму("Справочник.Адреса.ФормаВыбора", П, ЭтаФорма,,,,Новый ОписаниеОповещения("РедактироватьАдресаЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура АдресОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	
	ТекСтрока.Адрес    =    ВыбранноеЗначение;
	
КонецПроцедуры

&НаКлиенте
Процедура АдресАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	
	//ТекСтрока = Элементы.ВнеоборотныеАктивы.ТекущиеДанные;
	ТекСтрока =Элементы.ГруппаПервичныеДанные.ПодчиненныеЭлементы.Адрес.ВыделенныйТекст;

    знТекст    =    ?(ПустаяСтрока(Текст), ТекСтрока, Текст);
    ДанныеВыбора    =    ПолучитьДанныеВыбораПоАдресу(Элемент, знТекст, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ИмуществоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Ссылка", СписокКонтрагентов());
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(НовыйПараметр);
	НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
	Элементы.Имущество.ПараметрыВыбора = НовыеПараметры;
	
КонецПроцедуры

&НаСервере
Функция СписокКонтрагентов()
    
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнеоборотныеАктивы.Ссылка КАК Ссылка,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.Организация КАК Организация,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.НачислятьАмортизацию КАК НачислятьАмортизацию,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.НачислятьАмортизациюВТекущемМесяце КАК НачислятьАмортизациюВТекущемМесяце,
		|	СостоянияВнеоборотныхАктивовСрезПоследних.Состояние КАК Состояние
		|ИЗ
		|	Справочник.ВнеоборотныеАктивы КАК ВнеоборотныеАктивы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(&ДатаОтбора, ) КАК СостоянияВнеоборотныхАктивовСрезПоследних
		|		ПО ВнеоборотныеАктивы.Ссылка = СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
		|ГДЕ
		|	НЕ ВнеоборотныеАктивы.ПометкаУдаления
		|	И СостоянияВнеоборотныхАктивовСрезПоследних.Состояние ЕСТЬ NULL
		|	И НЕ ВнеоборотныеАктивы.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("ДатаОтбора", ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата()));
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
    
КонецФункции