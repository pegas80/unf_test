
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//+++ Дмгг
	ДатаДокумента = Объект.Дата;
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
		ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ТекущаяДата()); //+++ Дмгг
	Иначе
		ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ДатаДокумента);
	КонецЕсли;
	//--- Дмгг
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Комплектация;
		объект.СчетСписанияВА = ПланыСчетов.Хозрасчетный.НайтиПоКоду("2199");
	КонецЕсли;
	
	Компания = УправлениеНебольшойФирмойСервер.ПолучитьОрганизацию(Объект.Организация);
	
	УстановитьВидимость();
	УстановитьЗаголовки();
	НеСписыватьПриИзмененииНаСервере();
	
	УстановитьВидимостьДляГруппУменьшенногоОстаткаНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура Рассчитать(Команда)
	
	Если Объект.Проведен Тогда
		ПоказатьПредупреждение(Неопределено,НСтр("ka='ამორტიზაციის გაანგარიშება შესაძლებელია მხოლოდ გაუტარებელ დოკუმენტში';ru='Рассчет амортизации возможен только в непроведенном документе.';en='Calculation of depreciation is only possible in a failure to document.'"));
		Возврат;
	КонецЕсли;
	
	ПоказатьВопрос(Новый ОписаниеОповещения("РассчитатьЗавершение", ЭтотОбъект), НСтр("ka='შეტანილი მონაცემები გადაითვლება! გავაგრძელოთ?';ru='Введенные данные будут пересчитаны! Продолжить?';en='The entered data will be recalculated! Proceed?'"),РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьЗавершение(Результат, ДополнительныеПараметры) Экспорт
    
    Если Объект.КомплектующиеВА.Количество() > 0
        И Результат = КодВозвратаДиалога.Нет Тогда
        Возврат;
    КонецЕсли;
    
    АдресВнеоборотныеАктивыВХранилище = ПоместитьВнеоборотныеАктивыВХранилище();
    РассчитатьАмортизацию(АдресВнеоборотныеАктивыВХранилище, Объект.Дата, Компания);
    ПолучитьВнеоборотныеАктивыИзХранилища(АдресВнеоборотныеАктивыВХранилище);

КонецПроцедуры

&НаСервере
Функция ПоместитьВнеоборотныеАктивыВХранилище()
	
	Возврат ПоместитьВоВременноеХранилище(
		Объект.КомплектующиеВА.Выгрузить(,
			"НомерСтроки,
			|ВнеоборотныйАктив"
		),
		УникальныйИдентификатор
	);
	
КонецФункции

&НаСервереБезКонтекста
Процедура РассчитатьАмортизацию(АдресВнеоборотныеАктивыВХранилище, Дата, Организация)
	
	ТаблицаВнеоборотныеАктивы = ПолучитьИзВременногоХранилища(АдресВнеоборотныеАктивыВХранилище);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Период", Дата);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоГода", НачалоГода(Дата));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Дата));
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(Дата));
	Запрос.УстановитьПараметр("СписокВнеоборотныхАктивов", ТаблицаВнеоборотныеАктивы.ВыгрузитьКолонку("ВнеоборотныйАктив"));
	Запрос.УстановитьПараметр("ТаблицаВнеоборотныеАктивы", ТаблицаВнеоборотныеАктивы);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СписокАмортизируемыхВА.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ПРЕДСТАВЛЕНИЕ(СписокАмортизируемыхВА.ВнеоборотныйАктив) КАК ВнеоборотныйАктивПредставление,
	|	СписокАмортизируемыхВА.ВнеоборотныйАктив.Код КАК Код,
	|	СписокАмортизируемыхВА.НачалоНачислятьАмортизацию КАК НачалоНачислятьАмортизацию,
	|	СписокАмортизируемыхВА.КонецНачислятьАмортизацию КАК КонецНачислятьАмортизацию,
	|	СписокАмортизируемыхВА.КонецНачислятьВТекущемМесяце КАК КонецНачислятьВТекущемМесяце,
	|	ЕСТЬNULL(СтоимостьВА.АмортизацияКонечныйОстаток, 0) КАК АмортизацияКонечныйОстаток,
	|	ЕСТЬNULL(СтоимостьВА.АмортизацияОборот, 0) КАК АмортизацияОборот,
	|	ЕСТЬNULL(СтоимостьВА.СтоимостьКонечныйОстаток, 0) КАК БалансоваяСтоимость,
	|	ЕСТЬNULL(СтоимостьВА.СтоимостьНачальныйОстаток, 0) КАК СтоимостьНачальныйОстаток,
	|	ЕСТЬNULL(АмортизацияОстаткиИОбороты.СтоимостьНачальныйОстаток, 0) - ЕСТЬNULL(АмортизацияОстаткиИОбороты.АмортизацияНачальныйОстаток, 0) КАК СтоимостьНаНачалоГода,
	|	ЕСТЬNULL(СписокАмортизируемыхВА.ВнеоборотныйАктив.СпособАмортизации, 0) КАК СпособНачисленияАмортизации,
	|	ЕСТЬNULL(СписокАмортизируемыхВА.ВнеоборотныйАктив.НачальнаяСтоимость, 0) КАК ПервоначальнаяСтоимость,
	|	ЕСТЬNULL(ПараметрыАмортизацииСрезПоследних.ПрименитьВТекущемМесяце, 0) КАК ПрименитьВТекущемМесяце,
	|	ПараметрыАмортизацииСрезПоследних.Период КАК Период,
	|	ВЫБОР
	|		КОГДА ПараметрыАмортизацииСрезПоследних.ПрименитьВТекущемМесяце
	|			ТОГДА ЕСТЬNULL(ПараметрыАмортизацииСрезПоследних.СрокИспользованияДляВычисленияАмортизации, 0)
	|		ИНАЧЕ ЕСТЬNULL(ПараметрыАмортизацииСрезПоследнихНачалоМесяца.СрокИспользованияДляВычисленияАмортизации, 0)
	|	КОНЕЦ КАК СрокИспользованияДляВычисленияАмортизации,
	|	ВЫБОР
	|		КОГДА ПараметрыАмортизацииСрезПоследних.ПрименитьВТекущемМесяце
	|			ТОГДА ЕСТЬNULL(ПараметрыАмортизацииСрезПоследних.СтоимостьДляВычисленияАмортизации, 0)
	|		ИНАЧЕ ЕСТЬNULL(ПараметрыАмортизацииСрезПоследнихНачалоМесяца.СтоимостьДляВычисленияАмортизации, 0)
	|	КОНЕЦ КАК СтоимостьДляВычисленияАмортизации,
	|	ЕСТЬNULL(ИзменениеПризнакаАмортизации.ИзменениеНачислАморт, ЛОЖЬ) КАК ИзменениеНачислАморт,
	|	ЕСТЬNULL(ИзменениеПризнакаАмортизации.НачислятьВТекМесяце, ЛОЖЬ) КАК НачислятьВТекМесяце,
	|	ЕСТЬNULL(ВыработкаВнеоборотногоАктиваОбороты.КоличествоОборот, 0) КАК ОбъемВыработки,
	|	ВЫБОР
	|		КОГДА ПараметрыАмортизацииСрезПоследних.ПрименитьВТекущемМесяце
	|			ТОГДА ЕСТЬNULL(ПараметрыАмортизацииСрезПоследних.ОбъемПродукцииРаботДляВычисленияАмортизации, 0)
	|		ИНАЧЕ ЕСТЬNULL(ПараметрыАмортизацииСрезПоследнихНачалоМесяца.ОбъемПродукцииРаботДляВычисленияАмортизации, 0)
	|	КОНЕЦ КАК ОбъемПродукцииРаботДляВычисленияАмортизации,
	|	ПараметрыАмортизацииСрезПоследних.СтруктурнаяЕдиница,
	|	ЕСТЬNULL(СтоимостьВА.КоличествоМесяцеВЭксплуатацииКонечныйОстаток, 0) КАК КоличествоМесяцеВЭксплуатацииКонечныйОстаток
	|ПОМЕСТИТЬ ВременнаяТаблицаДляРасчетаАмортизации
	|ИЗ
	|	(ВЫБРАТЬ
	|		СрезПервых.НачислятьАмортизацию КАК НачалоНачислятьАмортизацию,
	|		СрезПоследних.НачислятьАмортизацию КАК КонецНачислятьАмортизацию,
	|		СрезПоследних.НачислятьАмортизациюВТекущемМесяце КАК КонецНачислятьВТекущемМесяце,
	|		СрезПоследних.ВнеоборотныйАктив КАК ВнеоборотныйАктив
	|	ИЗ
	|		(ВЫБРАТЬ
	|			СостояниеВнеоборотногоАктиваСрезПервых.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|			СостояниеВнеоборотногоАктиваСрезПервых.НачислятьАмортизацию КАК НачислятьАмортизацию,
	|			СостояниеВнеоборотногоАктиваСрезПервых.НачислятьАмортизациюВТекущемМесяце КАК НачислятьАмортизациюВТекущемМесяце,
	|			СостояниеВнеоборотногоАктиваСрезПервых.Период КАК Период
	|		ИЗ
	|			РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(
	|					&НачалоПериода,
	|					Организация = &Организация
	|						И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК СостояниеВнеоборотногоАктиваСрезПервых) КАК СрезПервых
	|			ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				СостояниеВнеоборотногоАктиваСрезПоследних.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|				СостояниеВнеоборотногоАктиваСрезПоследних.НачислятьАмортизацию КАК НачислятьАмортизацию,
	|				СостояниеВнеоборотногоАктиваСрезПоследних.НачислятьАмортизациюВТекущемМесяце КАК НачислятьАмортизациюВТекущемМесяце,
	|				СостояниеВнеоборотногоАктиваСрезПоследних.Период КАК Период
	|			ИЗ
	|				РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(
	|						&КонецПериода,
	|						Организация = &Организация
	|							И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК СостояниеВнеоборотногоАктиваСрезПоследних) КАК СрезПоследних
	|			ПО СрезПервых.ВнеоборотныйАктив = СрезПоследних.ВнеоборотныйАктив) КАК СписокАмортизируемыхВА
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты(
	|				&НачалоГода,
	|				,
	|				,
	|				,
	|				Организация = &Организация
	|					И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК АмортизацияОстаткиИОбороты
	|		ПО СписокАмортизируемыхВА.ВнеоборотныйАктив = АмортизацияОстаткиИОбороты.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты(
	|				&НачалоПериода,
	|				&КонецПериода,
	|				,
	|				,
	|				Организация = &Организация
	|					И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК СтоимостьВА
	|		ПО СписокАмортизируемыхВА.ВнеоборотныйАктив = СтоимостьВА.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних(
	|				&КонецПериода,
	|				Организация = &Организация
	|					И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК ПараметрыАмортизацииСрезПоследних
	|		ПО СписокАмортизируемыхВА.ВнеоборотныйАктив = ПараметрыАмортизацииСрезПоследних.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыВнеоборотныхАктивов.СрезПоследних(
	|				&НачалоПериода,
	|				Организация = &Организация
	|					И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК ПараметрыАмортизацииСрезПоследнихНачалоМесяца
	|		ПО СписокАмортизируемыхВА.ВнеоборотныйАктив = ПараметрыАмортизацииСрезПоследнихНачалоМесяца.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ИСТИНА) КАК ИзменениеНачислАморт,
	|			СостояниеВнеоборотногоАктива.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|			СостояниеВнеоборотногоАктиваСрезПоследних.НачислятьАмортизациюВТекущемМесяце КАК НачислятьВТекМесяце
	|		ИЗ
	|			РегистрСведений.СостоянияВнеоборотныхАктивов КАК СостояниеВнеоборотногоАктива
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(
	|						&КонецПериода,
	|						Организация = &Организация
	|							И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК СостояниеВнеоборотногоАктиваСрезПоследних
	|				ПО СостояниеВнеоборотногоАктива.ВнеоборотныйАктив = СостояниеВнеоборотногоАктиваСрезПоследних.ВнеоборотныйАктив
	|		ГДЕ
	|			СостояниеВнеоборотногоАктива.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|			И СостояниеВнеоборотногоАктива.Организация = &Организация
	|			И СостояниеВнеоборотногоАктива.ВнеоборотныйАктив В(&СписокВнеоборотныхАктивов)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			СостояниеВнеоборотногоАктива.ВнеоборотныйАктив,
	|			СостояниеВнеоборотногоАктиваСрезПоследних.НачислятьАмортизациюВТекущемМесяце) КАК ИзменениеПризнакаАмортизации
	|		ПО СписокАмортизируемыхВА.ВнеоборотныйАктив = ИзменениеПризнакаАмортизации.ВнеоборотныйАктив
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВыработкаВнеоборотныхАктивов.Обороты(
	|				&НачалоПериода,
	|				&КонецПериода,
	|				,
	|				Организация = &Организация
	|					И ВнеоборотныйАктив В (&СписокВнеоборотныхАктивов)) КАК ВыработкаВнеоборотногоАктиваОбороты
	|		ПО СписокАмортизируемыхВА.ВнеоборотныйАктив = ВыработкаВнеоборотногоАктиваОбороты.ВнеоборотныйАктив
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	&Организация КАК Организация,
	|	&Период КАК Период,
	|	Таблица.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	Таблица.ВнеоборотныйАктивПредставление КАК ВнеоборотныйАктивПредставление,
	|	Таблица.Код КАК Код,
	|	Таблица.АмортизацияКонечныйОстаток КАК АмортизацияКонечныйОстаток,
	|	Таблица.БалансоваяСтоимость КАК БалансоваяСтоимость,
	|	0 КАК Стоимость,
	|	ВЫБОР
	|		КОГДА ВЫБОР
	|				КОГДА Таблица.СуммаАмортизации < Таблица.ВсегоОсталосьСписать
	|					ТОГДА Таблица.СуммаАмортизации
	|				ИНАЧЕ Таблица.ВсегоОсталосьСписать
	|			КОНЕЦ > 0
	|			ТОГДА ВЫБОР
	|					КОГДА Таблица.СуммаАмортизации < Таблица.ВсегоОсталосьСписать
	|						ТОГДА Таблица.СуммаАмортизации
	|					ИНАЧЕ Таблица.ВсегоОсталосьСписать
	|				КОНЕЦ
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Амортизация,
	|	Таблица.СтруктурнаяЕдиница,
	|	Таблица.КоличествоМесяцеВЭксплуатацииКонечныйОстаток
	|ПОМЕСТИТЬ ТаблицаРасчетаАмортизации
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА Таблица.СпособНачисленияАмортизации = ЗНАЧЕНИЕ(Перечисление.СпособыНачисленияАмортизацииВнеоборотныхАктивов.Линейный)
	|				ТОГДА Таблица.СтоимостьДляВычисленияАмортизации / ВЫБОР
	|						КОГДА Таблица.СрокИспользованияДляВычисленияАмортизации = 0
	|							ТОГДА 1
	|						ИНАЧЕ Таблица.СрокИспользованияДляВычисленияАмортизации
	|					КОНЕЦ
	|			КОГДА Таблица.СпособНачисленияАмортизации = ЗНАЧЕНИЕ(Перечисление.СпособыНачисленияАмортизацииВнеоборотныхАктивов.ПропорциональноОбъемуПродукции)
	|				ТОГДА Таблица.СтоимостьДляВычисленияАмортизации * Таблица.ОбъемВыработки / ВЫБОР
	|						КОГДА Таблица.ОбъемПродукцииРаботДляВычисленияАмортизации = 0
	|							ТОГДА 1
	|						ИНАЧЕ Таблица.ОбъемПродукцииРаботДляВычисленияАмортизации
	|					КОНЕЦ
	|			ИНАЧЕ 0
	|		КОНЕЦ КАК СуммаАмортизации,
	|		Таблица.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|		Таблица.ВнеоборотныйАктивПредставление КАК ВнеоборотныйАктивПредставление,
	|		Таблица.Код КАК Код,
	|		Таблица.АмортизацияКонечныйОстаток КАК АмортизацияКонечныйОстаток,
	|		Таблица.БалансоваяСтоимость КАК БалансоваяСтоимость,
	|		Таблица.БалансоваяСтоимость - Таблица.АмортизацияКонечныйОстаток КАК ВсегоОсталосьСписать,
	|		Таблица.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|		Таблица.КоличествоМесяцеВЭксплуатацииКонечныйОстаток КАК КоличествоМесяцеВЭксплуатацииКонечныйОстаток
	|	ИЗ
	|		ВременнаяТаблицаДляРасчетаАмортизации КАК Таблица) КАК Таблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВременнаяТаблицаДляРасчетаАмортизации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаВнеоборотныеАктивы.НомерСтроки КАК НомерСтроки,
	|	ТаблицаВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив
	|ПОМЕСТИТЬ ТаблицаВнеоборотныеАктивы
	|ИЗ
	|	&ТаблицаВнеоборотныеАктивы КАК ТаблицаВнеоборотныеАктивы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаВнеоборотныеАктивы.НомерСтроки КАК НомерСтроки,
	|	ТаблицаВнеоборотныеАктивы.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
	|	ТаблицаРасчетаАмортизации.БалансоваяСтоимость КАК Стоимость,
	|	ТаблицаРасчетаАмортизации.Амортизация КАК АмортизацияЗаМесяц,
	|	ТаблицаРасчетаАмортизации.АмортизацияКонечныйОстаток КАК Амортизация,
	|	ТаблицаРасчетаАмортизации.БалансоваяСтоимость - ТаблицаРасчетаАмортизации.АмортизацияКонечныйОстаток КАК ОстаточнаяСтоимость,
	|	ТаблицаРасчетаАмортизации.СтруктурнаяЕдиница,
	|	ТаблицаРасчетаАмортизации.КоличествоМесяцеВЭксплуатацииКонечныйОстаток КАК КоличествоМесяцеВЭксплуатации
	|ИЗ
	|	ТаблицаВнеоборотныеАктивы КАК ТаблицаВнеоборотныеАктивы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаРасчетаАмортизации КАК ТаблицаРасчетаАмортизации
	|		ПО ТаблицаВнеоборотныеАктивы.ВнеоборотныйАктив = ТаблицаРасчетаАмортизации.ВнеоборотныйАктив
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТаблицаВнеоборотныеАктивы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ТаблицаРасчетаАмортизации";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ТаблицаАмортизации = РезультатЗапроса[4].Выгрузить();
	
	ПоместитьВоВременноеХранилище(ТаблицаАмортизации, АдресВнеоборотныеАктивыВХранилище);
	
КонецПроцедуры // РассчитатьАмортизацию()

&НаСервере
Процедура ПолучитьВнеоборотныеАктивыИзХранилища(АдресВнеоборотныеАктивыВХранилище)
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Комплектация Тогда 
		
		ТаблицаВнеоборотныеАктивы = ПолучитьИзВременногоХранилища(АдресВнеоборотныеАктивыВХранилище);
		Объект.КомплектующиеВА.Очистить();
		Для каждого СтрокаВнеоборотныеАктивы Из ТаблицаВнеоборотныеАктивы Цикл
			Строка = Объект.КомплектующиеВА.Добавить();
			ЗаполнитьЗначенияСвойств(Строка, СтрокаВнеоборотныеАктивы);
		КонецЦикла;
		
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Разукомплектация Тогда
		
		ТаблицаВнеоборотныеАктивы = ПолучитьИзВременногоХранилища(АдресВнеоборотныеАктивыВХранилище);
		
		Если ТаблицаВнеоборотныеАктивы.Количество() <> 0 Тогда 
			СтрокаЗаполнения = ТаблицаВнеоборотныеАктивы[0];
			
			Объект.СтруктурнаяЕдиница 	= СтрокаЗаполнения.СтруктурнаяЕдиница;
			Объект.Стоимость 			= СтрокаЗаполнения.Стоимость;
			Объект.ОстаточнаяСтоимость 	= СтрокаЗаполнения.ОстаточнаяСтоимость;
			Объект.Амортизация 			= СтрокаЗаполнения.Амортизация;
			Объект.АмортизацияЗаМесяц 	= СтрокаЗаполнения.АмортизацияЗаМесяц;
			Объект.КоличествоМесяцеВЭксплуатации 	= СтрокаЗаполнения.КоличествоМесяцеВЭксплуатации;
			
		Иначе 
			
			Объект.СтруктурнаяЕдиница 	= Справочники.СтруктурныеЕдиницы.ПустаяСсылка();
			Объект.Стоимость 			= 0;
			Объект.ОстаточнаяСтоимость 	= 0;
			Объект.Амортизация 			= 0;
			Объект.АмортизацияЗаМесяц 	= 0;
			Объект.КоличествоМесяцеВЭксплуатации 	= 0;
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	
	// Обработка события изменения организации.
	Объект.Номер = "";
	СтруктураДанные = ПолучитьДанныеОрганизацияПриИзменении(Объект.Организация);
	Компания = СтруктураДанные.Компания;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьДанныеОрганизацияПриИзменении(Организация)
	
	СтруктураДанные = Новый Структура();
	
	СтруктураДанные.Вставить(
		"Компания",
		УправлениеНебольшойФирмойСервер.ПолучитьОрганизацию(Организация)		
	);
	
	Возврат СтруктураДанные;
	
КонецФункции

&НаКлиенте
Процедура КомплектующиеВАИмуществоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	МассивПринятыхВА = МассивПринятыхВА();
	НовыйПараметрСсылки = Новый ПараметрВыбора("Отбор.Ссылка", МассивПринятыхВА);
	
    НовыйМассив = Новый Массив();
    НовыйМассив.Добавить(НовыйПараметрСсылки);
    НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
    Элементы.КомплектующиеВАИмущество.ПараметрыВыбора = НовыеПараметры;
	
КонецПроцедуры

&НаСервере
Функция МассивПринятыхВА()

	ДатаЗапроса = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата-1, ТекущаяДата());
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.ВнеоборотныйАктив
		|ИЗ
		|	РегистрСведений.СостоянияВнеоборотныхАктивов.СрезПоследних(&НаДату, ) КАК СостоянияВнеоборотныхАктивовСрезПоследних
		|ГДЕ
		|	СостоянияВнеоборотныхАктивовСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияВнеоборотныхАктивов.ПринятКУчету)";
	
	Запрос.УстановитьПараметр("НаДату", ДатаЗапроса);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВнеоборотныйАктив");
	

КонецФункции // МассивПринятыхВА()()

&НаСервере
Процедура УстановитьВидимость()

	Если Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Комплектация Тогда
		
		Элементы.ГруппаКомплектующиеВА.Видимость = Истина;
		Элементы.ДопГруппаДеукомплектации.Видимость = ЛОЖЬ;
		Элементы.ГруппаСчетаСпособАмотризации.Видимость = Истина;
		Элементы.Группа.Видимость = Истина;
		Элементы.Декомплектация.Видимость = Ложь;
		Элементы.СтоимостьАмортизация.Видимость = Ложь;
		Элементы.ГруппаРазукомплектация.Видимость = Ложь;
		Элементы.ГруппаКомплектуемоеВА.Видимость = Истина;
		
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Разукомплектация Тогда
		
		Элементы.ГруппаКомплектующиеВА.Видимость = Ложь;
		Элементы.ДопГруппаДеукомплектации.Видимость = Истина;
		Элементы.ГруппаСчетаСпособАмотризации.Видимость = Ложь;
		Элементы.Группа.Видимость = Ложь;
		Элементы.Декомплектация.Видимость = Истина;
		Элементы.СтоимостьАмортизация.Видимость = Истина;
		Элементы.ГруппаРазукомплектация.Видимость = Истина;
		Элементы.ГруппаКомплектуемоеВА.Видимость = Ложь;
		
	КонецЕсли;
	

КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовки()
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Комплектация Тогда
		
		Элементы.ГруппаКомплектуемоеВА.Заголовок = НСтр("ka='კომპლექტი';ru='Комплектуемое имущество';en='Can be combined property'");
		
		Элементы.ГруппаИмуществоИнвНомер.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Разукомплектация Тогда
		
		Элементы.ГруппаКомплектуемоеВА.Заголовок = НСтр("ka='კომპლექტი';ru='Комплект';en='kit'");
		
		Элементы.ГруппаИмуществоИнвНомер.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	ВидОперацииПриИзмененииНаСервере();
	УстановитьВидимость();
	УстановитьЗаголовки();
	
КонецПроцедуры

&НаСервере
Процедура ВидОперацииПриИзмененииНаСервере()
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Комплектация Тогда 
		
		Объект.ДекомплектующиеВА.Очистить();
		
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийКомплектацииВА.Разукомплектация Тогда
		
		Объект.КомплектующиеВА.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РаспределитьСтоимостьКомплектаНаСервере()
	
	Документ = РеквизитФормыВЗначение("Объект");
	Документ.РаспределитьСтоимостьИАмортизацию();
	ЗначениеВРеквизитФормы(Документ, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьСтоимостьКомплекта(Команда)
	
	РаспределитьСтоимостьКомплектаНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ИмуществоПриИзменении(Элемент)
	
	СтруктураДанных = ПолучитьСтруктуруПоИмуществуНаСервере(Объект.Имущество);
	
	Объект.ГодовойПроцентАмортизацииДляУменьшенногоОстатка 	= СтруктураДанных.ГодовойПроцентАмортизацииДляУменьшенногоОстатка;
	Объект.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка 	= СтруктураДанных.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийКомплектацииВА.Разукомплектация") Тогда 
		
		АдресВнеоборотныеАктивыВХранилище = ПоместитьВнеоборотныеАктивыВХранилищеДекомплектации();
		РассчитатьАмортизацию(АдресВнеоборотныеАктивыВХранилище, Объект.Дата, Компания);
		ПолучитьВнеоборотныеАктивыИзХранилища(АдресВнеоборотныеАктивыВХранилище);
		
	КонецЕсли;
	
	УстановитьВидимостьДляГруппУменьшенногоОстаткаНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьДляГруппУменьшенногоОстаткаНаСервере()
	
	ВидимостьУменьшенногоОстатка = Объект.Имущество.СпособАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка;
	Элементы.ГруппаУменьшенногоОстатка.Видимость = ВидимостьУменьшенногоОстатка;
	Элементы.ГруппаУменьшенногоОстатка1.Видимость = ВидимостьУменьшенногоОстатка;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСтруктуруПоИмуществуНаСервере(Имущество)

	СтруктураДанных = Новый Структура;
	
	СтруктураДанных.Вставить("СпособАмортизацииУменьшенногоОстатка"				, Имущество.СпособАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка);
	СтруктураДанных.Вставить("СпособАмортизацииЛинейный"						, Имущество.СпособАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.Линейный);
	СтруктураДанных.Вставить("СпособАмортизацииПропорциональноОбъемуПродукции"	, Имущество.СпособАмортизации = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.ПропорциональноОбъемуПродукции);
	СтруктураДанных.Вставить("ГодовойПроцентАмортизацииДляУменьшенногоОстатка"	, Имущество.ГодовойПроцентАмортизацииДляУменьшенногоОстатка);
	СтруктураДанных.Вставить("ЛиквидационнаяСтоимостьДляУменьшенногоОстатка"	, Имущество.ЛиквидационнаяСтоимостьДляУменьшенногоОстатка);

	Возврат СтруктураДанных;
	
КонецФункции // НаСервере()

&НаСервере
Функция ПоместитьВнеоборотныеАктивыВХранилищеДекомплектации()
	
	тзВозврата = Новый ТаблицаЗначений;
	
	тзВозврата.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число"));
	тзВозврата.Колонки.Добавить("ВнеоборотныйАктив", Новый ОписаниеТипов("СправочникСсылка.ВнеоборотныеАктивы"));
	
	НовСтрока = тзВозврата.Добавить();
	НовСтрока.НомерСтроки = 1;
	НовСтрока.ВнеоборотныйАктив = Объект.Имущество;
	
	Возврат ПоместитьВоВременноеХранилище(тзВозврата, УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Процедура НеСписыватьПриИзмененииНаСервере()
	
	Элементы.ДоляСтоимости1.Доступность = Объект.НеСписывать;
	Элементы.СтоимостьПослеПроведения1.Доступность = Объект.НеСписывать;
	Элементы.АмортизацияПослеПроведения1.Доступность = Объект.НеСписывать;
	Элементы.АмортизацияЗаМесяцПослеПровледения1.Доступность = Объект.НеСписывать;
	
КонецПроцедуры

&НаКлиенте
Процедура НеСписыватьПриИзменении(Элемент)
	
	Если НЕ Объект.НеСписывать Тогда 
		Объект.ДоляСтоимости						= 0;
		Объект.СтоимостьПослеПроведения             = 0;
		Объект.АмортизацияПослеПроведения           = 0;
		Объект.АмортизацияЗаМесяцПослеПровледения   = 0;
	КонецЕсли;
	
	НеСписыватьПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ДекомплектующиеВАСчетЗатратПриИзмененииНаСервере(УИД)
	
	СтрокаТаблицы = Объект.ДекомплектующиеВА.НайтиПоИдентификатору(УИД);
	
	СтрокаТаблицы.СчетЗатрат = СтрокаТаблицы.СчетЗатратРегл.СчетАналогУУ;
	
КонецПроцедуры

&НаКлиенте
Процедура ДекомплектующиеВАСчетЗатратПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ДекомплектующиеВА.ТекущиеДанные;
	
	УИД = ТекущаяСтрока.ПолучитьИдентификатор();
	
	ДекомплектующиеВАСчетЗатратПриИзмененииНаСервере(УИД);
	
КонецПроцедуры

&НаКлиенте
Процедура ДоляСтоимостиПриИзменении(Элемент)
	
	Если Объект.ДоляСтоимости >= 1 Тогда 
		Сообщить(НСтр("ka='განაწილების კოეფიციენტის ჯამი არ შეიძლება იყოს 1-ზე მეტი';ru='Доля распределения не может быть равна больше ""1""';en='The share of distribution can not be more than equal to ""1""'"));
		Возврат;
	КонецЕсли;
	
	Объект.СтоимостьПослеПроведения = Объект.Стоимость * Объект.ДоляСтоимости;
	Объект.АмортизацияПослеПроведения = Объект.Амортизация * Объект.ДоляСтоимости;
	Объект.АмортизацияЗаМесяцПослеПровледения = Объект.АмортизацияЗаМесяц * Объект.ДоляСтоимости;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(Объект.Дата); //+++ Дмгг
	
КонецПроцедуры

