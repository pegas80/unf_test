#Область ИнициализацияДаных


// Инициализирует таблицы значений, содержащие данные табличных частей документа.
// Таблицы значений сохраняет в свойствах структуры "ДополнительныеСвойства".
//
Процедура ИнициализироватьДанныеДокумента(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства) Экспорт
	
	
	Запрос = Новый Запрос(ТекстЗапросаИнициализироватьДанныеДокумента());
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	// Олег Литвиненко 15.09.22 --->
	Запрос.УстановитьПараметр("СмещениеДляОкругления", 0.0005);
	// Олег Литвиненко <---
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылкаПродажаЛицензии);
	Запрос.УстановитьПараметр("Организация", СтруктураДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("МоментВремени", Новый Граница(СтруктураДополнительныеСвойства.ДляПроведения.МоментВремени, ВидГраницы.Включая));
	Запрос.УстановитьПараметр("ИспользоватьХарактеристики", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьХарактеристики);
	Запрос.УстановитьПараметр("ИспользоватьПартии", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьПартии);
	Запрос.УстановитьПараметр("УчетПоЯчейкам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоЯчейкам);
	
	//ПодольскийАИ #УчетПроектов 10.10.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", СтруктураДополнительныеСвойства.УчетнаяПолитика.УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 10.10.2020 }
	
	Запрос.УстановитьПараметр("ИспользоватьСерийныеНомера", СтруктураДополнительныеСвойства.УчетнаяПолитика.ИспользоватьСерийныеНомера);
	
	Запрос.УстановитьПараметр("ВалютаУчета", Константы.ВалютаУчета.Получить());
	Запрос.УстановитьПараметр("ВалютаНациональная", Константы.НациональнаяВалюта.Получить());
	Запрос.УстановитьПараметр("ВалютаНакладной", ДокументСсылкаПродажаЛицензии.ВалютаДокумента);
	Запрос.УстановитьПараметр("ДатаПродажи", ДокументСсылкаПродажаЛицензии.Дата);
	
	
	Запрос.ВыполнитьПакет();
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПодготовитьСтруктурыСубконтоСчетовДоходаПродажи(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства); //+++ Дмгг
	
	// Формирование проводок документа.
	УправлениеНебольшойФирмойСервер.СформироватьТаблицуПроводок(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);
	СформитоватьТаблицаЛицензии(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);	
	СформироватьТаблицаПродажи(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);
	СформироватьТаблицаРасчетыПоНалогам(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);
	СформироватьТаблицаРасчетыСПокупателями(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);
	СформироватьТаблицаДоходыИРасходы(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);

	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_ПродажаЛицензии(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);


	
	// Рублевые суммы документов
	Если  ДокументСсылкаПродажаЛицензии.Договор.ВалютаРасчетов <> Константы.НациональнаяВалюта.Получить() Тогда
		
		ТаблицаВзаиморасчеты = РублевыеСуммыДокументов.ПодготовитьТаблицуДокументаРасчетыВВалюте(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);
		Если СтруктураДополнительныеСвойства.ДляПроведения.ВалютаДокумента <> СтруктураДополнительныеСвойства.ДляПроведения.НациональнаяВалюта Тогда
			РублевыеСуммыДокументов.РаспределитьАвансыПоТаблицеРеализации(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства, ТаблицаВзаиморасчеты);
		КонецЕсли;
		РублевыеСуммыДокументов.СформироватьТаблицаРублевыеСуммыДокументовВВалюте(ДокументСсылкаПродажаЛицензии, СтруктураДополнительныеСвойства);
		РублевыеСуммыДокументов.ДобавитьДвиженияВТаблицуРасчетов(
			ТаблицаВзаиморасчеты,
			СтруктураДополнительныеСвойства.ТаблицыДляДвижений.ТаблицаРасчетыСПокупателями,
			ДокументСсылкаПродажаЛицензии,
			СтруктураДополнительныеСвойства,
			Ложь);
			
	Иначе
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРублевыеСуммыДокументовВВалюте", Новый ТаблицаЗначений);
	КонецЕсли;

	
КонецПроцедуры // ИнициализироватьДанныеДокумента()

Функция ТекстЗапросаИнициализироватьДанныеДокумента()
	
	Возврат	
	"ВЫБРАТЬ
	|	ПродажаЛицензии.Ссылка КАК Ссылка,
	|	ПродажаЛицензии.НомерСтроки КАК НомерСтроки,
	|	ПродажаЛицензии.Номенклатура КАК Номенклатура,
	|	ПродажаЛицензии.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	НЕОПРЕДЕЛЕНО КАК Характеристика,
	|	НЕОПРЕДЕЛЕНО КАК СерийныеНомера,
	|	ПродажаЛицензии.Цена КАК Цена,
	|	НЕОПРЕДЕЛЕНО КАК ПроцентСкидкиНаценки,
	|	ПродажаЛицензии.СтавкаНДС КАК СтавкаНДС,
	|	НЕОПРЕДЕЛЕНО КАК Заказ,
	|	ПродажаЛицензии.Всего КАК Себестоимость,
	|	НЕОПРЕДЕЛЕНО КАК ТипНоменклатурыЗапас,
	|	НЕОПРЕДЕЛЕНО КАК Резерв,
	|	НЕОПРЕДЕЛЕНО КАК Содержание,
	|	НЕОПРЕДЕЛЕНО КАК КлючСвязи,
	|	НЕОПРЕДЕЛЕНО КАК СуммаАвтоматическойСкидки,
	|	НЕОПРЕДЕЛЕНО КАК СправкаБ,
	|	НЕОПРЕДЕЛЕНО КАК Партия,
	|	1 КАК Количество,
	|	НЕОПРЕДЕЛЕНО КАК СтранаПроисхождения,
	|	НЕОПРЕДЕЛЕНО КАК НомерГТД,
	|	НЕОПРЕДЕЛЕНО КАК ТоварыДляПроизводства,
	|	НЕОПРЕДЕЛЕНО КАК Вес,
	|	НЕОПРЕДЕЛЕНО КАК ЭтоПодарок,
	|	НЕОПРЕДЕЛЕНО КАК Сотрудник,
	|	НЕОПРЕДЕЛЕНО КАК СтруктурнаяЕдиница,
	|	НЕОПРЕДЕЛЕНО КАК СуммаНДФЛ,
	|	НЕОПРЕДЕЛЕНО КАК УдержаниеПенсии,
	|	НЕОПРЕДЕЛЕНО КАК УдерживатьПенсию,
	|	НЕОПРЕДЕЛЕНО КАК СуммаНДСБезвозмездно,
	|	НЕОПРЕДЕЛЕНО КАК Объем,
	|	ПродажаЛицензии.Всего - ПродажаЛицензии.Всего / (1 + ПродажаЛицензии.СтавкаНДС.Ставка / 100) КАК СуммаНДС,
	|	ВЫРАЗИТЬ(ПродажаЛицензии.Всего - ВЫБОР
	|			КОГДА ПродажаЛицензии.СтавкаНДС.Ставка = 0
	|				ТОГДА 0
	|			ИНАЧЕ ПродажаЛицензии.Всего - ПродажаЛицензии.Всего / (1 + ПродажаЛицензии.СтавкаНДС.Ставка / 100)
	|		КОНЕЦ КАК ЧИСЛО(15, 6)) КАК Сумма,
	|	НЕОПРЕДЕЛЕНО КАК ВидНачисленияУдержания,
	|	НЕОПРЕДЕЛЕНО КАК ВидНалогаНДФЛ,
	|	НЕОПРЕДЕЛЕНО КАК СчетДоходовБП,
	|	НЕОПРЕДЕЛЕНО КАК ВидУдержанияПФ,
	|	НЕОПРЕДЕЛЕНО КАК НаправлениеДеятельности,
	|	ЗНАЧЕНИЕ(Справочник.Проекты.БезПроекта) КАК Проект,
	|	НЕОПРЕДЕЛЕНО КАК ПровестиНалогПрибили,
	|	НЕОПРЕДЕЛЕНО КАК СчетУчетаВыручкиОтПродажРегл,
	|	ПродажаЛицензии.ЕдиницаИзмерения.Коэффициент КАК ЕдиницаИзмеренияКоэффициент,
	|	ПродажаЛицензии.Всего КАК Всего,
	|	ПродажаЛицензии.СтавкаЛицензии.Ставка КАК СтавкаЛицензии
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасыПерерасчетПред
	|ИЗ
	|	Документ.ПродажаЛицензии.Запасы КАК ПродажаЛицензии
	|ГДЕ
	|	ПродажаЛицензии.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫРАЗИТЬ(СУММА(ВЫРАЗИТЬ(ВременнаяТаблицаЗапасыПерерасчет.СуммаНДС КАК ЧИСЛО(15, 6))) КАК ЧИСЛО(15, 6)) КАК СуммаНДС,
	|	СУММА(1) КАК КоличествоСтрок,
	|	ВЫРАЗИТЬ(СУММА(ВЫРАЗИТЬ(ВременнаяТаблицаЗапасыПерерасчет.Сумма КАК ЧИСЛО(15, 6))) КАК ЧИСЛО(15, 6)) КАК Сумма
	|ПОМЕСТИТЬ вт_ЗапасыГрупп
	|ИЗ
	|	ВременнаяТаблицаЗапасыПерерасчетПред КАК ВременнаяТаблицаЗапасыПерерасчет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаЗапасыПерерасчет.Ссылка КАК Ссылка,
	|	ВременнаяТаблицаЗапасыПерерасчет.НомерСтроки КАК НомерСтроки,
	|	ВременнаяТаблицаЗапасыПерерасчет.Номенклатура КАК Номенклатура,
	|	ВременнаяТаблицаЗапасыПерерасчет.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВременнаяТаблицаЗапасыПерерасчет.Характеристика КАК Характеристика,
	|	ВременнаяТаблицаЗапасыПерерасчет.СерийныеНомера КАК СерийныеНомера,
	|	ВременнаяТаблицаЗапасыПерерасчет.Цена КАК Цена,
	|	ВременнаяТаблицаЗапасыПерерасчет.ПроцентСкидкиНаценки КАК ПроцентСкидкиНаценки,
	|	ВременнаяТаблицаЗапасыПерерасчет.СтавкаНДС КАК СтавкаНДС,
	|	ВременнаяТаблицаЗапасыПерерасчет.Заказ КАК Заказ,
	|	ВременнаяТаблицаЗапасыПерерасчет.ТипНоменклатурыЗапас КАК ТипНоменклатурыЗапас,
	|	ВременнаяТаблицаЗапасыПерерасчет.Содержание КАК Содержание,
	|	ВременнаяТаблицаЗапасыПерерасчет.КлючСвязи КАК КлючСвязи,
	|	ВременнаяТаблицаЗапасыПерерасчет.Резерв КАК Резерв,
	|	ВременнаяТаблицаЗапасыПерерасчет.СправкаБ КАК СправкаБ,
	|	ВременнаяТаблицаЗапасыПерерасчет.Партия КАК Партия,
	|	ВременнаяТаблицаЗапасыПерерасчет.Количество КАК Количество,
	|	ВременнаяТаблицаЗапасыПерерасчет.СтранаПроисхождения КАК СтранаПроисхождения,
	|	ВременнаяТаблицаЗапасыПерерасчет.НомерГТД КАК НомерГТД,
	|	ВременнаяТаблицаЗапасыПерерасчет.ТоварыДляПроизводства КАК ТоварыДляПроизводства,
	|	ВременнаяТаблицаЗапасыПерерасчет.Вес КАК Вес,
	|	ВременнаяТаблицаЗапасыПерерасчет.Объем КАК Объем,
	|	ВременнаяТаблицаЗапасыПерерасчет.ЭтоПодарок КАК ЭтоПодарок,
	|	ВременнаяТаблицаЗапасыПерерасчет.Сотрудник КАК Сотрудник,
	|	ВременнаяТаблицаЗапасыПерерасчет.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВременнаяТаблицаЗапасыПерерасчет.СуммаНДФЛ КАК СуммаНДФЛ,
	|	ВременнаяТаблицаЗапасыПерерасчет.УдержаниеПенсии КАК УдержаниеПенсии,
	|	ВременнаяТаблицаЗапасыПерерасчет.УдерживатьПенсию КАК УдерживатьПенсию,
	|	ВЫРАЗИТЬ(ВременнаяТаблицаЗапасыПерерасчет.СуммаНДС КАК ЧИСЛО(15, 6)) КАК СуммаНДС,
	|	ВременнаяТаблицаЗапасыПерерасчет.СуммаНДСБезвозмездно КАК СуммаНДСБезвозмездно,
	|	ВЫРАЗИТЬ(ВременнаяТаблицаЗапасыПерерасчет.Сумма КАК ЧИСЛО(15, 6)) КАК Сумма,
	|	ВременнаяТаблицаЗапасыПерерасчет.ВидНачисленияУдержания КАК ВидНачисленияУдержания,
	|	ВременнаяТаблицаЗапасыПерерасчет.ВидНалогаНДФЛ КАК ВидНалогаНДФЛ,
	|	ВременнаяТаблицаЗапасыПерерасчет.СчетДоходовБП КАК СчетДоходовБП,
	|	ВременнаяТаблицаЗапасыПерерасчет.ВидУдержанияПФ КАК ВидУдержанияПФ,
	|	ВременнаяТаблицаЗапасыПерерасчет.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	ВЫБОР
	|		КОГДА &УчетПоПроектам
	|			ТОГДА ВременнаяТаблицаЗапасыПерерасчет.Проект
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)
	|	КОНЕЦ КАК Проект,
	|	ВременнаяТаблицаЗапасыПерерасчет.ПровестиНалогПрибили КАК ПровестиНалогПрибили,
	|	ВременнаяТаблицаЗапасыПерерасчет.СчетУчетаВыручкиОтПродажРегл КАК СчетУчетаВыручкиОтПродажРегл,
	|	ВременнаяТаблицаЗапасыПерерасчет.ЕдиницаИзмеренияКоэффициент КАК ЕдиницаИзмеренияКоэффициент,
	|	ВременнаяТаблицаЗапасыПерерасчет.Себестоимость КАК Себестоимость,
	|	ВременнаяТаблицаЗапасыПерерасчет.Всего КАК Всего,
	|	ВременнаяТаблицаЗапасыПерерасчет.СтавкаЛицензии КАК СтавкаЛицензии
	|ПОМЕСТИТЬ ВременнаяТаблицаЗапасыПерерасчет
	|ИЗ
	|	ВременнаяТаблицаЗапасыПерерасчетПред КАК ВременнаяТаблицаЗапасыПерерасчет,
	|	вт_ЗапасыГрупп КАК вт_ЗапасыГрупп
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПродажаЛицензииПредоплата.Ссылка КАК Ссылка,
	|	СУММА(ПродажаЛицензииПредоплата.СуммаРасчетов) КАК СуммаРасчетов,
	|	СУММА(ПродажаЛицензииПредоплата.СуммаРасчетов * ПродажаЛицензииПредоплата.Курс / ПродажаЛицензииПредоплата.Кратность) КАК СуммаРасчетовРеглПоКурсуПредоплаты
	|ПОМЕСТИТЬ ВременнаяТаблицаСуммаПредоплатыГрупп
	|ИЗ
	|	Документ.ПродажаЛицензии.Предоплата КАК ПродажаЛицензииПредоплата
	|ГДЕ
	|	ПродажаЛицензииПредоплата.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПродажаЛицензииПредоплата.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПродажаЛицензии.Ссылка КАК Ссылка,
	|	ПродажаЛицензии.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаНеОплаченаВал,
	|	(ПродажаЛицензии.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ПродажаЛицензии.Курс / ПродажаЛицензии.Кратность КАК СуммаНеОплаченаРегл,
	|	ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0) КАК СуммаРасчетовВал,
	|	ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты КАК СуммаРасчетовРегл,
	|	(ПродажаЛицензии.СуммаДокумента - ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетов, 0)) * ПродажаЛицензии.Курс / ПродажаЛицензии.Кратность + ЕСТЬNULL(ВременнаяТаблицаСуммаПредоплатыГрупп.СуммаРасчетовРеглПоКурсуПредоплаты, 0) КАК СуммаДокументаРеглПоВсемКурсам,
	|	ВЫБОР
	|		КОГДА ПродажаЛицензии.СуммаДокумента = 0
