Процедура РассчитатьОстаточнаяСтоимостьНаСервере()
	
	Для Каждого Ст из Объект.Запасы Цикл 	
		
		//ДокументМоментВремени = Новый Граница(Объект.Ссылка, ВидГраницы.Включая); 
		
		//СебестоимостьОстаток = РегистрыНакопления.Лизензии.Остатки(Новый Граница(Объект.Ссылка.МоментВремени(), ВидГраницы.Включая),Новый Структура("Номенклатура,Организация",Ст.Номенклатура,Объект.Организация));
		
		СебестоимостьОстаток = РегистрыНакопления.Лицензии.Остатки(Объект.Дата,Новый Структура("Номенклатура,Организация",Ст.Номенклатура,Объект.Организация));

		Если СебестоимостьОстаток.Количество()>0 Тогда 
			Ст.ОстаточнаяСтоимость =  СебестоимостьОстаток[0].Себестоимость;  
			Ст.СписываетсяСебестоимость = Ст.ОстаточнаяСтоимость *  Ст.СтавкаЛицензии.Ставка /100; 
		Иначе 
			Ст.ОстаточнаяСтоимость = 0; 
			Ст.СписываетсяСебестоимость = 0;
		КонецЕсли;  
	КонецЦикла;     
	
