Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если не Объект.Проведен Тогда     //и не ЗначениеЗаполнено(Объект.Ссылка)
		НомерСтроки = "";	
		Для Каждого Ст из Объект.Запасы Цикл 
			Если ПолучитьСтавкуЛицензии(Ст.СтавкаЛицензии) = 100 Тогда  
				НомерСтроки = НомерСтроки + Ст.НомерСтроки + ",";
			КонецЕсли;		
		КонецЦикла;        
		
		Если ЗначениеЗаполнено(НомерСтроки) Тогда 
			Режим = РежимДиалогаВопрос.ДаНет;  
			Ответ = Вопрос(НСтр("ru = ' სტრიქონში არსებული ლიცენზიის თვითღირებულება განულდება, გსურთ დოკუმენტის გატარება?'; ka = ' სტრიქონში არსებული ლიცენზიის თვითღირებულება განულდება, გსურთ დოკუმენტის გატარება?'" ), Режим, 0); 
			Если Ответ = КодВозвратаДиалога.Нет Тогда
				Отказ = Истина;  
			КонецЕсли		
		КонецЕсли		
	КонецЕсли;  
		
