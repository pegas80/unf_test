Функция СформироватьПечатнуюФормуСчетФактураRS(ТекущийДокумент)
	
	ИспользоватьХарактеристики = Константы.ФункциональнаяОпцияИспользоватьХарактеристики.Получить();
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_СчетФактураОтправленныйГрузия_ПФ_MXL_СчетФактураRS";

	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
		
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.СчетФактураОтправленныйГрузия.ПФ_MXL_СчетФактураRS");
	
	ОбластьШапка		        = Макет.ПолучитьОбласть("Шапка");
	ОбластьТабдичнаяЧасть	    = Макет.ПолучитьОбласть("ТабдичнаяЧасть");														
	ОбластьПодвалТабличнойЧасти = Макет.ПолучитьОбласть("ПодвалТабличнойЧасти");	
	ОбластьПодвалНакладная		= Макет.ПолучитьОбласть("ПодвалНакладная");
	ОбластьПодвалПодпись		= Макет.ПолучитьОбласть("ПодвалПодпись");	
	ТабличныйДокумент.Очистить();
	
	
	ОбластьШапка.Параметры.НомерВходящегоДокумента = ТекущийДокумент.НомерВходящегоДокумента;
	ОбластьШапка.Параметры.МесяцВходящегоДокумента = Формат(ТекущийДокумент.ДатаВходящегоДокумента,"ДФ=МMММ");	
	ОбластьШапка.Параметры.ГодВходящегоДокумента = Формат(ТекущийДокумент.ДатаВходящегоДокумента,"ДФ=yyyy");
	
	ОбластьШапка.Параметры.ЧислоДата = Формат(ТекущийДокумент.Дата,"ДФ=dd");
	ОбластьШапка.Параметры.МесяцДата =Формат(ТекущийДокумент.Дата,"ДФ=МMММ");
	ОбластьШапка.Параметры.ГодДата = Формат(ТекущийДокумент.Дата,"ДФ=yyyy");
		
	 ОбластьШапка.Параметры.Заполнить(ПолучитьРазделенныйИД(ТекущийДокумент.Организация.ИНН, "Организация"));
	 ОбластьШапка.Параметры.Заполнить(ПолучитьРазделенныйИД(ТекущийДокумент.Контрагент.ИНН, "Контрагент"));
	 ОбластьШапка.Параметры.Организация = ТекущийДокумент.Организация;
	 ОбластьШапка.Параметры.Контрагент = ТекущийДокумент.Контрагент;
	 ТабличныйДокумент.Вывести(ОбластьШапка);
	 
	 ИтогВсего = 0;
	 ИтогСуммаНДС = 0;
	 
	 
	 Для Каждого стр Из ТекущийДокумент.Запасы Цикл 
		 
		 
		 ОбластьТабдичнаяЧасть.Параметры.Заполнить(стр);
		 
		 ИтогВсего = ИтогВсего + стр.Всего;
		 ИтогСуммаНДС = ИтогСуммаНДС + стр.СуммаНДС;
		 
		 ТабличныйДокумент.Вывести(ОбластьТабдичнаяЧасть);
	 КонецЦикла;
	 
	 ОбластьПодвалТабличнойЧасти.Параметры.ИтогВсего =  ИтогВсего;
	 ОбластьПодвалТабличнойЧасти.Параметры.ИтогСуммаНДС =  ИтогСуммаНДС;
	 ТабличныйДокумент.Вывести(ОбластьПодвалТабличнойЧасти);
	 
	 
	 Для Каждого стр Из ТекущийДокумент.ДокументыОснования Цикл 
		 
		 Если ТипЗнч(стр.ДокументОснование) = Тип("ДокументСсылка.РасходнаяНакладная") Тогда 
			 
			 НайденныйЭлНакладная = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(стр.ДокументОснование); 
			 
		 КонецЕсли;
		 
	 КонецЦикла;
	 
	 Если ЗначениеЗаполнено(НайденныйЭлНакладная) Тогда 
		 
		 ОбластьПодвалНакладная.Параметры.НомерНакладная = НайденныйЭлНакладная.Ссылка.НомерТН;
		 ОбластьПодвалНакладная.Параметры.ДатаНакладная = НайденныйЭлНакладная.Дата;
		 ТабличныйДокумент.Вывести(ОбластьПодвалНакладная);
		 
	 КонецЕсли;
	 
	 
	  ТабличныйДокумент.Вывести(ОбластьПодвалПодпись);
	 //НайденныйЭлНакладная = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(стр.ДокументОснование);

	
	// Вставить обработку выборки ВыборкаДетальныеЗаписи
		//ОбластьШапка.Параметры.Заполнить();	
	//
	//Выборка = Запрос.Выполнить().Выгрузить();
	//Выборка.Следующий();
	//ОбластьШапка.Параметры.Заполнить(Выборка);
	//
	

	
	Возврат ТабличныйДокумент
	
КонецФункции

Функция  ПолучитьРазделенныйИД(ИД, ВладелецИД)
	
	
	Если ВладелецИД = "Организация" Тогда 
		
		 ИмяКлюча = "ИДОгр";
	ИначеЕсли ВладелецИД = "Контрагент" Тогда 
		
		ИмяКлюча = "ИДКонтр";
	КонецЕсли;
	
	
	струкЦифров = Новый Структура;
	
	Для инд = 1 По СтрДлина(ИД) Цикл 
		струкЦифров.Вставить(ИмяКлюча+Строка(инд),Сред(ИД, инд, 1));
	КонецЦикла;
	
	Возврат струкЦифров;	
КонецФункции

// Функция формирует печатную форму документа по указанному макету.
//
// Параметры:
//	ТабличныйДокумент - ТабличныйДокумент в который будет выводится печатная
//				   форма.
//  ИмяМакета    - Строка, имя макета печатной формы.
//
Функция ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, ИмяМакета)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПараметрыПечати_СчетФактураОтправленныйГрузия";
	
	ПервыйДокумент = Истина;
	
	Если ИмяМакета = "СчетФактураRS" Тогда
		
	КонецЕсли;
	
	Для каждого ТекущийДокумент Из МассивОбъектов Цикл
	
		Если НЕ ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Если ИмяМакета = "СчетФактураRS" Тогда
					
			ТабличныйДокумент.Вывести(СформироватьПечатнуюФормуСчетФактураRS(ТекущийДокумент));
				
		КонецЕсли;
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ТекущийДокумент);
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции // ПечатнаяФорма()

// Сформировать печатные формы объектов
//
// ВХОДЯЩИЕ:
//   ИменаМакетов    - Строка    - Имена макетов, перечисленные через запятую
//   МассивОбъектов  - Массив    - Массив ссылок на объекты которые нужно распечатать
//   ПараметрыПечати - Структура - Структура дополнительных параметров печати
//
// ИСХОДЯЩИЕ:
//   КоллекцияПечатныхФорм - Таблица значений - Сформированные табличные документы
//   ПараметрыВывода       - Структура        - Параметры сформированных табличных документов
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "СчетФактураRS") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "СчетФактураRS", НСтр("en='Waybill RS';ka='ანგარიშ ფაქტურა ცხრილი';ru='Счет Фактура RS'"), ПечатнаяФорма(МассивОбъектов, ОбъектыПечати, "СчетФактураRS"));
		
	КонецЕсли;
	
	// параметры отправки печатных форм по электронной почте
	УправлениеНебольшойФирмойСервер.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
	
КонецПроцедуры

// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	// СчетФактураRS
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "СчетФактураRS";
	КомандаПечати.Представление = НСтр("en='Waybill RS';ka='ანგარიშ ფაქტურა ცხრილი';ru='Счет Фактура RS'");
	КомандаПечати.СписокФорм    = "ФормаСписка,ФормаДокумента";
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	КомандаПечати.Порядок = 1;
	
КонецПроцедуры
