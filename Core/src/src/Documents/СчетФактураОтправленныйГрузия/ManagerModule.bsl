Процедура ИнициализироватьДанныеДокумента(ДокументСчетФактураОтправленныйГрузия, СтруктураДополнительныеСвойства) Экспорт

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка,
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Организация,
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Контрагент,
		|	КОНЕЦПЕРИОДА(СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.ДатаВходящегоДокумента, МЕСЯЦ) КАК Период,
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.НомерСтроки КАК НомерСтроки,
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.Документ,
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.Договор,
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.СуммаНДС КАК Сумма
		|ПОМЕСТИТЬ ДокументыПлатежа
		|ИЗ
		|	Документ.СчетФактураОтправленныйГрузия.ДокументыПлатежа КАК СчетФактураОтправленныйГрузияДокументыПлатежа
		|ГДЕ
		|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", 		ДокументСчетФактураОтправленныйГрузия);
	Запрос.Выполнить();
	
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаХозрасчетный_СчетФактураОтправленныйГрузия(ДокументСчетФактураОтправленныйГрузия, СтруктураДополнительныеСвойства);
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицаАвансыОтправленныхФактур_СчетФактураОтправленныйГрузия(ДокументСчетФактураОтправленныйГрузия, СтруктураДополнительныеСвойства);
	
	СформироватьТаблицаРасчетыПоНалогам(ДокументСчетФактураОтправленныйГрузия, СтруктураДополнительныеСвойства); // Kuzmich, 16.09.2019, Добавление бух проводок в счет фактурах
КонецПроцедуры

// Kuzmich, 16.09.2019, Добавление бух проводок в счет фактурах
Процедура СформироватьТаблицаРасчетыПоНалогам(ДокументСсылкаСчетФактураОтправленныйГрузия, СтруктураДополнительныеСвойства)
	
	Если ЗначениеЗаполнено(ДокументСсылкаСчетФактураОтправленныйГрузия.ВидНалога) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Дата КАК Период,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Организация КАК Организация,
		|	СчетФактураОтправленныйГрузияДокументыОснования.ДокументОснование.ВидНалогаНДС КАК ВидНалога,
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.СчетУчетаРегл КАК СчетУчета,
		|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НалоговыеОбязательства) КАК СрокУплаты,
		|	&СодержаниеПроводки КАК СодержаниеПроводки,
		|	СчетФактураОтправленныйГрузияДокументыОснования.СуммаНДС КАК Сумма
		|ИЗ
		|	Документ.СчетФактураОтправленныйГрузия.ДокументыОснования КАК СчетФактураОтправленныйГрузияДокументыОснования
		|ГДЕ
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Дата,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход),
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Организация,
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.ВидНалога,
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.СчетУчетаРегл,
		|	ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.НалоговыеОбязательства),
		|	&СодержаниеПроводки,
		|	СчетФактураОтправленныйГрузияДокументыОснования.СуммаНДС
		|ИЗ
		|	Документ.СчетФактураОтправленныйГрузия.ДокументыОснования КАК СчетФактураОтправленныйГрузияДокументыОснования
		|ГДЕ
		|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка = &Ссылка";
		
		Запрос.УстановитьПараметр("Ссылка",	ДокументСсылкаСчетФактураОтправленныйГрузия);
		Запрос.УстановитьПараметр("СодержаниеПроводки",	НСТР("ka='დღგ';ru='НДС';en='VAT'"));
		
		РезультатЗапроса = Запрос.Выполнить();
		врТаблицаРасчетыПоНалогам = РезультатЗапроса.Выгрузить();	
		врТаблицаРасчетыПоНалогам.Свернуть("Период,ВидДвижения,Организация,ВидНалога,СчетУчета,СрокУплаты,СодержаниеПроводки","Сумма");
		СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаРасчетыПоНалогам", врТаблицаРасчетыПоНалогам);
		
	КонецЕсли;
КонецПроцедуры
