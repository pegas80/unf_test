#Область ОтборыПоСубконто

&НаСервере
Процедура ПолучитьТекстОтборовJSON()

	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
	
		СтатьяОтчетаОбъект = РеквизитФормыВЗначение("Объект");
		Для Сч = 0 По СтатьяОтчетаОбъект.Источники.Количество() - 1 Цикл
		
			СтрокаОбъекта = СтатьяОтчетаОбъект.Источники[Сч];
			ДанныеОтборов = СтрокаОбъекта.ОтборыПоСубконто.Получить();
			Если ТипЗнч(ДанныеОтборов) = Тип("ТаблицаЗначений") Тогда
				
				ЗаписьJSON = Новый ЗаписьJSON;
				ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON(, Символы.Таб);
				ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);
				СериализаторXDTO.ЗаписатьJSON(ЗаписьJSON, ДанныеОтборов);
				Объект.Источники[Сч].ТекстОтбора_JSON = ЗаписьJSON.Закрыть();
				
			КонецЕсли; 
		
		КонецЦикла; 
	
	КонецЕсли; 	

КонецПроцедуры // ПолучитьТекстОтборовJSON()

&НаКлиенте
Процедура ИсточникиТекстОтбора_JSONОткрытие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.Источники.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
	
		ПараметрыФормыОтборов = Новый Структура("СчетУчета, ИдентификаторСтроки, ТекстJSON", ТекущиеДанные.СчетУчета, ТекущиеДанные.ПолучитьИдентификатор(), ТекущиеДанные.ТекстОтбора_JSON);
		ОткрытьФорму("Справочник.ДЛ_СтатьиУниверсальногоОтчета.Форма.ФормаОтборовСубконто", ПараметрыФормыОтборов, ЭтотОбъект, УникальныйИдентификатор,,, Новый ОписаниеОповещения("ИсточникиТекстОтбора_JSONОткрытиеЗавершение", ЭтотОбъект), );
		
	
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ИсточникиТекстОтбора_JSONОткрытиеЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
	
		СтрокаТЧ = Объект.Источники.НайтиПоИдентификатору(Результат.ИдентификаторСтроки);
		СтрокаТЧ.ТекстОтбора_JSON = Результат.ТекстJSON;
	
	КонецЕсли; 	

КонецПроцедуры
 


#КонецОбласти 	
