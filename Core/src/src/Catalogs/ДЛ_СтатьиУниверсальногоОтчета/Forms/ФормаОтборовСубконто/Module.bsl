
&НаКлиенте
Процедура ТаблицаСубконтоВидСубконтоНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Элементы.ТаблицаСубконтоВидСубконто.СписокВыбора.Очистить();
	ТекущиеДанные = Элементы.ТаблицаСубконто.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено И ЗначениеЗаполнено(СчетУчета) Тогда
	
		СписокСубконто = ПолучитьСписокВидовСубконтоСчета(СчетУчета);
		Для каждого ТекЭлемент Из СписокСубконто Цикл
		
			Элементы.ТаблицаСубконтоВидСубконто.СписокВыбора.Добавить(ТекЭлемент.Значение);
		
		КонецЦикла; 
	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокВидовСубконтоСчета(СчетУчета)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("СчетУчета", СчетУчета);
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ХозрасчетныйВидыСубконто.НомерСтроки КАК НомерСтроки,
	|	ХозрасчетныйВидыСубконто.ВидСубконто КАК ВидСубконто,
	|	ХозрасчетныйВидыСубконто.ВидСубконто.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
	|	ХозрасчетныйВидыСубконто.ВидСубконто.Наименование КАК Наименование,
	|	ХозрасчетныйВидыСубконто.ВидСубконто.ТипЗначения КАК ТипЗначения
	|ИЗ
	|	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
	|ГДЕ
	|	ХозрасчетныйВидыСубконто.Ссылка = &СчетУчета
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки";
	СписокСубконто = Новый СписокЗначений;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
	
		СписокСубконто.Добавить(Выборка.ВидСубконто);	
	
	КонецЦикла;
	Возврат СписокСубконто;
	
КонецФункции // ПолучитьСписокВидовСубконтоСчета()


&НаКлиенте
Процедура ТаблицаСубконтоВидСубконтоПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаСубконто.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
	
		ТекущиеДанные.НомерСубконто = Неопределено;
		ТекущиеДанные.ИмяСубконто = Неопределено;
		ТекущиеДанные.ЗначениеСубконто = Неопределено;
		ТекущиеДанные.ВидСравнения = Неопределено;
		ТекущиеДанные.ЗначениеСубконтоСписок.Очистить();
		ДанныеСубконто = ПолучитьТипыЗначенийСубконто(ТекущиеДанные.ВидСубконто, СчетУчета);
		ЗаполнитьЗначенияСвойств(ТекущиеДанные, ДанныеСубконто);
		Элементы.ТаблицаСубконтоЗначениеСубконто.ОграничениеТипа = ДанныеСубконто.ТипЗначения;
		ТекущиеДанные.ЗначениеСубконтоСписок.ТипЗначения = ДанныеСубконто.ТипЗначения;
	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьТипыЗначенийСубконто(ВидСубконто, СчетУчета)
	
	СтруктураДанныхСубконто = Новый Структура("НомерСубконто, ВидСубконто, ИмяСубконто, ТипЗначения"); 
	Если ЗначениеЗаполнено(ВидСубконто) И ЗначениеЗаполнено(СчетУчета) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХозрасчетныйВидыСубконто.НомерСтроки КАК НомерСубконто,
		|	ХозрасчетныйВидыСубконто.ВидСубконто КАК ВидСубконто,
		|	ХозрасчетныйВидыСубконто.ВидСубконто.ИмяПредопределенныхДанных КАК ИмяСубконто,
		|	ХозрасчетныйВидыСубконто.ВидСубконто.ТипЗначения КАК ТипЗначения
		|ИЗ
		|	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
		|ГДЕ
		|	ХозрасчетныйВидыСубконто.Ссылка = &СчетУчета
		|	И ХозрасчетныйВидыСубконто.ВидСубконто = &ВидСубконто";
		
		Запрос.УстановитьПараметр("СчетУчета", СчетУчета);
		Запрос.УстановитьПараметр("ВидСубконто", ВидСубконто);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		Если Выборка.Следующий() Тогда
		
			ЗаполнитьЗначенияСвойств(СтруктураДанныхСубконто, Выборка);	
		
		КонецЕсли; 
		
		
		Возврат СтруктураДанныхСубконто;
		
	КонецЕсли; 

КонецФункции // ПолучитьТипыЗначенийСубконто()

