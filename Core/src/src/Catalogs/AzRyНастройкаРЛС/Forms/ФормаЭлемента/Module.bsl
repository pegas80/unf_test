&НаКлиенте
Процедура ПользовательПриИзменении(Элемент)

	Если Не ЗначениеЗаполнено(Объект.Наименование) Тогда
		Объект.Наименование = Объект.Пользователь;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ЗаполнениеТаблицыОрганизаций

&НаКлиенте
Процедура ЗаполнитьОрганизации(Команда)

	Если ТаблицаЗаполнена() Тогда

		ТекстВопроса = НСтр(
			"ka='ცხრილი უკვე შევსებულია. გსურთ გადაწერა?';
			|ru='Таблица уже заполнена. Перезаписать?';
			|en='The table is already filled. Overwrite?'"
		);

		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОтветПользователя", ЭтотОбъект),
			ТекстВопроса,
			РежимДиалогаВопрос.ДаНет,
			,
			КодВозвратаДиалога.Нет
		);

	Иначе
		ЗаполнитьОрганизацииНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтветПользователя(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗаполнитьОрганизацииНаСервере();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция ТаблицаЗаполнена()
	Возврат Объект.Организации.Количество() > 0;
КонецФункции

&НаСервере
Процедура ЗаполнитьОрганизацииНаСервере()

	Объект.Организации.Очистить();

	Выборка = Справочники.Организации.Выбрать();

	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.Организации.Добавить();
		НоваяСтрока.Организация = Выборка.Ссылка;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ВыборОрганизаций

&НаКлиенте
Процедура ОрганизацияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;

	ТекущаяСтрока  = Элементы.Организации.ТекущиеДанные;
	ТекущееЗначение = ?(ТекущаяСтрока <> Неопределено, ТекущаяСтрока.Организация, Неопределено);

	СписокДляВыбора = ПолучитьДоступныеОрганизации(ТекущееЗначение);

	Если СписокДляВыбора.Количество() = 0 Тогда

		ТекстСообщения = НСтр(
			"ka='ყველა ორგანიზაცია უკვე დამატებულია!';
			|ru='Все организации уже добавлены!';
			|en='All organizations are already added!'"
		);

		ПоказатьПредупреждение(, ТекстСообщения);
		Возврат;

	КонецЕсли;

	// Открываем список с флажками для множественного выбора
	СписокДляВыбора.ПоказатьОтметкуЭлементов(
		Новый ОписаниеОповещения("ОрганизацииВыбраны", ЭтотОбъект),
		"Выберите организации"
	);

КонецПроцедуры

																 
&НаКлиенте
Процедура ОрганизацииВыбраны(СписокВыбора, ДополнительныеПараметры) Экспорт

	Если СписокВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ПерваяОтмеченная = Истина;

	Для Каждого Элемент Из СписокВыбора Цикл
		Если Элемент.Пометка Тогда

			Если ПерваяОтмеченная Тогда
				// Первый выбранный элемент — заполняем текущую строку
				ТекущаяСтрока = Элементы.Организации.ТекущиеДанные;
				Если ТекущаяСтрока <> Неопределено Тогда
					ТекущаяСтрока.Организация = Элемент.Значение;
				КонецЕсли;
				ПерваяОтмеченная = Ложь;
			Иначе
				// Остальные выбранные — добавляем новыми строками
				НоваяСтрока = Объект.Организации.Добавить();
				НоваяСтрока.Организация = Элемент.Значение;
			КонецЕсли;

		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаСервере
Функция ПолучитьДоступныеОрганизации(ТекущееЗначение)

	УжеДобавленные = Новый Массив;
	Для Каждого Строка Из Объект.Организации Цикл
		Если ЗначениеЗаполнено(Строка.Организация)
			И Строка.Организация <> ТекущееЗначение Тогда
			УжеДобавленные.Добавить(Строка.Организация);
		КонецЕсли;
	КонецЦикла;

	СписокВыбора = Новый СписокЗначений;
	Выборка = Справочники.Организации.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если УжеДобавленные.Найти(Выборка.Ссылка) = Неопределено Тогда
			СписокВыбора.Добавить(Выборка.Ссылка, Выборка.Наименование);
		КонецЕсли;
	КонецЦикла;

	Возврат СписокВыбора;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

&НаКлиенте
Процедура УстановитьВидимость()

	Элементы.ГруппаОрганизации.Видимость        = Объект.ОграниченияПоОрганизациям;
	Элементы.ГруппаКонтрагенты.Видимость        = Объект.ОграниченияПоКонтрагентам;
	Элементы.ГруппаПодразделения.Видимость      = Объект.ОграниченияПоПодразделениям;
	Элементы.ГруппаПроекты.Видимость            = Объект.ОграниченияПоПроектам;
	Элементы.ГруппаСтруктурныеЕдиницы.Видимость = Объект.ОграниченияПоСтруктурныеЕдиницам;
	Элементы.ГруппаБанковскиеСчета.Видимость    = Объект.ОграниченияПоБанковскимСчетам;

КонецПроцедуры

#КонецОбласти
