
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПропорциональноОбъемуПродукции = Перечисления.СпособыНачисленияАмортизацииВнеоборотныхАктивов.ПропорциональноОбъемуПродукции;
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Если Объект.СпособАмортизации = ПропорциональноОбъемуПродукции Тогда
		Элементы.ЕдиницаИзмерения.Видимость = Истина;
	Иначе
		Элементы.ЕдиницаИзмерения.Видимость = Ложь;
		Объект.ЕдиницаИзмерения = Неопределено;
	КонецЕсли;
	
	ОтчетыУНФ.ПриСозданииНаСервереФормыСвязанногоОбъекта(ЭтотОбъект);
	
	// СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки
	ДополнительныеОтчетыИОбработки.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки
	
	// СтандартныеПодсистемы.Печать
	УправлениеПечатью.ПриСозданииНаСервере(ЭтаФорма);
	// Конец СтандартныеПодсистемы.Печать
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
	Элементы.ГруппаУСН.Доступность = Объект.УчитыватьВНУ;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		ПолучитьДанныеФормы();
	КонецЕсли;
	
	РазрешенПросмотрЦен = Истина;
	
КонецПроцедуры // ПриСозданииНаСервере()

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	УстановитьВидимостьРеквизитов();
	
	//+++ Дмгг
	МесячныйПроцентУменьшенногоОстатка = Объект.ГодовойПроцентАмортизацииДляУменьшенногоОстатка / 12;
	//--- Дмгг
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзменилисьСчетаВнеоборотныеАктивы" Тогда
		Объект.СчетУчета = Параметр.СчетУчета;
		Объект.СчетАмортизации = Параметр.СчетАмортизации;
		//+++
		Объект.СчетУчетаРегл = Параметр.СчетУчетаРегл;
		Объект.СчетАмортизацииРегл = Параметр.СчетАмортизацииРегл;
		//---
		//--------------------------------------------------------------------------
		// © Шишка В.В. [7 августа 2023]  НАЧАЛО
		Объект.ТипВнеоборотныеАктивы = Параметр.ТипВнеоборотныеАктивы;	
		// © Шишка В.В. [7 августа 2023]  КОНЕЦ
		//--------------------------------------------------------------------------
		
		Модифицированность = Истина;
		
	ИначеЕсли ИмяСобытия = "ИзмененаРыночнаяЦена"
		И Параметр Тогда
		
		ПодключитьОбработчикОжидания("ОбработкаОповещенияЗаписьВРегистреЦенКлиент", 0.5, Истина);
		
	КонецЕсли;
	
	// СтандартныеПодсистемы.Свойства 
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	Если ЗначениеЗаполнено(Объект.ТипВнеоборотныеАктивы) Тогда
		ТекущийОбъект.СчетУчетаРегл = Объект.ТипВнеоборотныеАктивы.СчетУчетаРегл;
		ТекущийОбъект.СчетАмортизацииРегл  = Объект.ТипВнеоборотныеАктивы.СчетАмортизацииРегл;
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
// Процедура обработчик события ПриИзменении поля ввода СпособАмортизации.
//
Процедура СпособАмортизацииПриИзменении(Элемент)
	
	УстановитьВидимостьРеквизитов();
	
КонецПроцедуры // СпособАмортизацииПриИзменении()

&НаКлиенте
Процедура УчитыватьВНУПриИзменении(Элемент)
	Элементы.ГруппаУСН.Доступность = Объект.УчитыватьВНУ;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьРеквизитов()
	
	Если Объект.СпособАмортизации = ПропорциональноОбъемуПродукции Тогда
		Элементы.ЕдиницаИзмерения.Видимость = Истина;
		Элементы.ГруппаУменьшенногоОстатка.Видимость = Ложь;
		Элементы.НачальнаяСтоимостьВалютаУчета.Видимость = Истина;
	//+++ Дмгг
	ИначеЕсли Объект.СпособАмортизации = ПредопределенноеЗначение("Перечисление.СпособыНачисленияАмортизацииВнеоборотныхАктивов.УменьшенногоОстатка") Тогда
		Элементы.ЕдиницаИзмерения.Видимость = Ложь;
		Объект.ЕдиницаИзмерения = Неопределено;
		Элементы.НачальнаяСтоимостьВалютаУчета.Видимость = Ложь;
		Элементы.ГруппаУменьшенногоОстатка.Видимость = Истина;
	//--- Дмгг
	Иначе
		Элементы.ЕдиницаИзмерения.Видимость = Ложь;
		Объект.ЕдиницаИзмерения = Неопределено;
		Элементы.ГруппаУменьшенногоОстатка.Видимость = Ложь;
		Элементы.НачальнаяСтоимостьВалютаУчета.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры // УстановитьВидимостьРеквизитов()

#КонецОбласти

#Область ОбработчикиБиблиотек

// СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки
&НаКлиенте
Процедура Подключаемый_ВыполнитьНазначаемуюКоманду(Команда)
	Если НЕ ДополнительныеОтчетыИОбработкиКлиент.ВыполнитьНазначаемуюКомандуНаКлиенте(ЭтаФорма, Команда.Имя) Тогда
		РезультатВыполнения = Неопределено;
		ДополнительныеОтчетыИОбработкиВыполнитьНазначаемуюКомандуНаСервере(Команда.Имя, РезультатВыполнения);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДополнительныеОтчетыИОбработкиВыполнитьНазначаемуюКомандуНаСервере(ИмяЭлемента, РезультатВыполнения)
	ДополнительныеОтчетыИОбработки.ВыполнитьНазначаемуюКомандуНаСервере(ЭтаФорма, ИмяЭлемента, РезультатВыполнения);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки

