&НаСервере
Процедура Инициализация()	
	
	ДополнительныеСвойства1 = Новый Структура;
	
	ДополнительныеСвойства1.Вставить("ПримитивныеТипы", Новый Структура ("Число, Строка, Дата, Булево",
	Тип("Число"), Тип("Строка"), Тип("Дата"), Тип("Булево")));
	
	Если Объект.ПерваяСтрокаДанныхТабличногоДокумента < 2 Тогда
		Объект.ПерваяСтрокаДанныхТабличногоДокумента = 2;
	КонецЕсли;
	
	ДополнительныеСвойства1.Вставить("Колонки", Новый Структура);

КонецПроцедуры // ()

