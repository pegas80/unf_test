		Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ПустаяСсылка();
	ИначеЕсли Объект.СсылкаИсточника = "РасходСоСчета" Тогда
		Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ПустаяСсылка();
	КонецЕсли;

КонецПроцедуры

