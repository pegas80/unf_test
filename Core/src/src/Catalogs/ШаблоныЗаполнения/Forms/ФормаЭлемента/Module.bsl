
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)    	
	
	ДанныеСтрокиЗагрузка = Неопределено;
	Если  Параметры.Свойство("ШаблоныЗаполнения") Тогда 
		ШаблоныЗаполнения = Параметры.ШаблоныЗаполнения;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьНастройки(Неопределено,ДанныеСтрокиЗагрузка);
	КонецЕсли;
	
	СписокВыбора = Элементы.СсылкаИсточника.СписокВыбора;
	СписокВыбора.Добавить("ПоступлениеНаСчет",Нстр("ka='ანგარიშზე თანხის მიღება';ru='Поступление На Счет';en='Receipts on an account'"));
	СписокВыбора.Добавить("РасходСоСчета",Нстр("ka='დანახარჯი ანგარიშიდან';ru='Расход Со Счета';en='Flow from the account'"));

	//Malyshev 2024-05-27 ONESOFT-3063
	//СписокВыбора.Добавить("ПоступлениеВКассу",Нстр("ka='შემოსავალი სალაროში';ru='Поступление в кассу';en='Admission to the cashier'"));
	//СписокВыбора.Добавить("РасходИзКассы",Нстр("ka='დანახარჯი სალაროდან';ru='Расход из кассы';en='Flow from the cash'"));
	
	
	СписокВыбора.Добавить("ПеремещениеДС",Нстр("ka='ფულის გადაადგილება';ru='Перемещение денег';en='Moving money'"));
	СписокВыбора.Добавить("Конвертация",Нстр("ka='კონვერტაცია';ru='Конвертация';en='Conversion'"));
	
	Массив = Новый Массив;
	Для Каждого Эл Из НастройкиОтбор.Настройки.ДоступныеПоляВыбора.Элементы Цикл 
		Массив.Добавить(строка(Эл.Поле));		
	КонецЦикла;    
	
	Если не ТолькоПросмотр и ЗначениеЗаполнено(Объект.СсылкаИсточника) и не ЗначениеЗаполнено(Объект.ИдентификаторОбъектаМетаданных) Тогда
		СсылкаИсточникаПриИзмененииНаСервере();
	КонецЕсли;
	
	ВидимостьГруппПоСсылкаИсточника();
	ПолучитьСписокВидыОпераций(); 
	ВидимостьЭлементовПоВидуОперации();	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНастройки(врХрНКД,ДанныеСтрокиЗагрузка)
	
	BOG = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia;
	TBC = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.TBC;
	Cartu = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.Cartu;
	VTB = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.VTB;
	ProCredit = Объект.ТипОбменаСИнтернетБанком = Перечисления.ТипыОбменаСИнтернетБанком.ProCredit;
	
	впОбъект = РеквизитФормыВЗначение("Объект");
	Если BOG Тогда
		СхемаКомпоновкиДанных = впОбъект.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_BOG");
	ИначеЕсли TBC Тогда
		СхемаКомпоновкиДанных = впОбъект.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_TBC");
	ИначеЕсли Cartu Тогда
		СхемаКомпоновкиДанных = впОбъект.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_CARTU");
	ИначеЕсли VTB Тогда
		СхемаКомпоновкиДанных = впОбъект.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_VTB");
	ИначеЕсли ProCredit Тогда
		СхемаКомпоновкиДанных = впОбъект.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_ProCredit");
	Иначе
		Возврат;
	КонецЕсли;
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, УникальныйИдентификатор);
	
	Если врХрНКД = Неопределено Тогда 
		ТекВариант = СхемаКомпоновкиДанных.ВариантыНастроек.Найти("Основной");
		врНастройки = ТекВариант.Настройки;
	Иначе 
		врНастройки = врХрНКД;
	КонецЕсли;
	НастройкиОтбор.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных));
	НастройкиОтбор.ЗагрузитьНастройки(врНастройки);
	
	Если Не ДанныеСтрокиЗагрузка = Неопределено Тогда 
		Для Каждого Стр Из ДанныеСтрокиЗагрузка Цикл 
			НовыйЭлементОтбора = НастройкиОтбор.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			НовыйЭлементОтбора.ЛевоеЗначение  = Стр.ЛевоеЗначение;
			НовыйЭлементОтбора.Использование  = Стр.Использование;
			НовыйЭлементОтбора.ВидСравнения   = Стр.ВидСравнения;
			НовыйЭлементОтбора.ПравоеЗначение = Стр.ПравоеЗначение;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры  

