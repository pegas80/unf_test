		//ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Прочее);
		//ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Налоги);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ВыдачаКредитаКонтрагенту);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Зарплата);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Налоги);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.НаРасходы);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ПенсионномуФонду);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ПереводНаДругойСчет);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Покупателю);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Поставщику);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Прочее);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ПрочиеРасчеты);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.СнятиеНаличных);
		
	//Malyshev 2024-05-27 ONESOFT-3063	
	ИначеЕсли Объект.ИдентификаторОбъектаМетаданных.ПолноеИмя = "Документ.РасходИзКассы"  Тогда
		Для каждого ЭлементВидаОперации из Метаданные.Перечисления.ВидыОперацийРасходИзКассы.ЗначенияПеречисления Цикл
			ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходИзКассы[ЭлементВидаОперации.Имя]);			
		КонецЦикла;	
		
	//Malyshev 2024-05-27 ONESOFT-3063
	ИначеЕсли Объект.ИдентификаторОбъектаМетаданных.ПолноеИмя = "Документ.ПоступлениеВКассу"  Тогда
		Для каждого ЭлементВидаОперации из Метаданные.Перечисления.ВидыОперацийПоступлениеВКассу.ЗначенияПеречисления Цикл
			ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеВКассу[ЭлементВидаОперации.Имя]);			
		КонецЦикла;			
		
	КонецЕсли;
	
	Элементы.ВидОперации.СписокВыбора.Очистить();
	Для каждого МойЭлемент из ВидыПДР Цикл
		Элементы.ВидОперации.СписокВыбора.Добавить(МойЭлемент.Значение);	
	КонецЦикла;	
	
	Возврат ВидыПДР;
КонецФункции // ()

