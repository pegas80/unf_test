	<dataSet xsi:type="DataSetQuery">
		<name>ИННСправочников</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>ИНН</dataPath>
			<field>ИНН</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ИННвКонтрагенти</dataPath>
			<field>ИННвКонтрагенти</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ИНН в контрагенти</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>ბაზაში კონტრაგენტების გსნ</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Inn in counterparty</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ИННвОрганизации</dataPath>
			<field>ИННвОрганизации</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ИНН в организации</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>ბაზაში ორგანიზაციის გსნ</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Inn in the organization</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ИННвСотрудники</dataPath>
			<field>ИННвСотрудники</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>ИНН в сотрудники</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>ბაზაში თანამშრომლების გსნ</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Inn in employees</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ВложенныйЗапрос.ИНН,
	ВложенныйЗапрос.ИННвКонтрагенти,
	ВложенныйЗапрос.ИННвСотрудники,
	ВложенныйЗапрос.ИННвОрганизации
ИЗ
	(ВЫБРАТЬ
		Организации.ИНН КАК ИНН,
		ЛОЖЬ КАК ИННвКонтрагенти,
		ЛОЖЬ КАК ИННвСотрудники,
		ИСТИНА КАК ИННвОрганизации
	ИЗ
		Справочник.Организации КАК Организации
	ГДЕ
		НЕ Организации.ИНН = ""
		И НЕ Организации.ПометкаУдаления
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		Контрагенты.ИНН,
		ИСТИНА,
		ЛОЖЬ,
		ЛОЖЬ
	ИЗ
		Справочник.Контрагенты КАК Контрагенты
	ГДЕ
		НЕ Контрагенты.ИНН = ""
		И НЕ Контрагенты.ПометкаУдаления
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		Сотрудники.Физлицо.ИНН,
		ЛОЖЬ,
		ИСТИНА,
		ЛОЖЬ
	ИЗ
		Справочник.Сотрудники КАК Сотрудники
	ГДЕ
		НЕ Сотрудники.Физлицо.ИНН = ""
		И НЕ Сотрудники.ПометкаУдаления) КАК ВложенныйЗапрос
ГДЕ
	НЕ ВложенныйЗапрос.ИНН = ""</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
		<name>БанковскийСчетОрганизаций</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>НомерСчета</dataPath>
			<field>НомерСчета</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Номер счета</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>ანგარიშის ნომერი</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Account number</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СобственныйБанковскийСчет</dataPath>
			<field>СобственныйБанковскийСчет</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Собственный банковский счет</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>საკუთარი საბანკო ანგარიში</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Own bank account</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	БанковскиеСчета.НомерСчета,
	ИСТИНА КАК СобственныйБанковскийСчет
ИЗ
	Справочник.БанковскиеСчета КАК БанковскиеСчета
ГДЕ
	БанковскиеСчета.Владелец = &amp;Организация</query>
	</dataSet>
