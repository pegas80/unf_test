			КонецЦикла; 
			СтруктураОтвета = МассивОтветов;
			
		ИначеЕсли (ТипЗНЧ(РЕЗ)=Тип("Структура"))ИЛИ(ТипЗНЧ(РЕЗ)=Тип("Соответствие")) Тогда
			Если РЕЗ.Результат Тогда
				
				СтруктураОтвета.IsSuccess = ИСТИНА;
				Если СтрДлина(СокрЛП(РЕЗ.Описание))=0 Тогда
					СтруктураОтвета.Message = СтрокаСодержанияУдачногоЗавершения;
				Иначе
					СтруктураОтвета.Message = СокрЛП(РЕЗ.Описание);
				КонецЕсли;
				
			Иначе
				
				Ответ = Новый HTTPСервисОтвет(400);
				СтруктураОтвета.IsSuccess = ЛОЖЬ;
				Если СтрДлина(СокрЛП(РЕЗ.Описание))=0 Тогда
					СтруктураОтвета.Message = "String data would be truncated (Description)";
				Иначе
					СтруктураОтвета.Message = СокрЛП(РЕЗ.Описание);
				КонецЕсли;
				
			КонецЕсли;
			СтруктураОтвета.Value = РЕЗ.ВозвращаемоеЗначение;
		Иначе
			
			Ответ = Новый HTTPСервисОтвет(400);
			СтруктураОтвета.IsSuccess = ЛОЖЬ;
			Если СтрДлина(СокрЛП(РЕЗ.Описание))=0 Тогда
				СтруктураОтвета.Message = "String data would be truncated (Description)";
			Иначе
				СтруктураОтвета.Message = СокрЛП(РЕЗ.Описание);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ТелоОтвета = Новый ЗаписьJSON();
	ТелоОтвета.УстановитьСтроку();
	ЗаписатьJSON(ТелоОтвета, СтруктураОтвета);
	ТелоОтвета = ТелоОтвета.Закрыть();
	
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета);
	
