#Область СтруктураПодчиненности
Функция CheckWithReference(ЗапросHTTP)

	СтрокаПараметра = "Ref";
	
	СтруктураОтвета = Новый Структура("IsSuccess,Value,Message",ИСТИНА,"","");		
	Ответ = Новый HTTPСервисОтвет(200);
	
	ТекСсылка = ЗапросHTTP.ПараметрыЗапроса.Получить(СтрокаПараметра);
	
	Если ТекСсылка = НЕОПРЕДЕЛЕНО Тогда
	
		ТелоЗапроса = ПолучитьТелоЗапросаHTTP(ЗапросHTTP);
		Попытка
			
			Флаг = ЛОЖЬ;
			
			ТекстЗапроса = Новый ЧтениеJSON();
			ТекстЗапроса.УстановитьСтроку(ТелоЗапроса);
			Пока ТекстЗапроса.Прочитать() Цикл
				
				ТекTип = ТекстЗапроса.ТипТекущегоЗначения;
				Если ТекTип = ТипЗначенияJSON.ИмяСвойства Тогда
					
					Если ТекстЗапроса.ТекущееЗначение = СтрокаПараметра Тогда
					
						Флаг = ИСТИНА;
					
					КонецЕсли;
					
				ИначеЕсли ((ТекTип = ТипЗначенияJSON.Строка) ИЛИ (ТекTип = ТипЗначенияJSON.Строка)) И Флаг Тогда
					
					ТекСсылка = ТекстЗапроса.ТекущееЗначение;
					Флаг = ЛОЖЬ;
					
				КонецЕсли;
				
			КонецЦикла;
			ТекстЗапроса.Закрыть();
			
		Исключение
			
			Поз = СтрНайти(ТелоЗапроса,СтрокаПараметра+"=""");
			Если Поз>0 Тогда
			
				ТекСсылка = СРЕД(ТелоЗапроса,Поз+11);
			
			КонецЕсли;
			
		КонецПопытки;
	
	КонецЕсли;
		
	Если ТекСсылка = НЕОПРЕДЕЛЕНО Тогда
	
		Ответ = Новый HTTPСервисОтвет(400);
		СтруктураОтвета.IsSuccess = ЛОЖЬ;
		СтруктураОтвета.Value = ТекСсылка;
		СтруктураОтвета.Message = "Invalid reference";
		
	Иначе
		
		//Поз1 = СтрНайти(ТекСсылка,"""");
		//Если Поз1>0 Тогда
		//	ТекСсылка = СтрЗаменить(ТекСсылка,"""","")
		//КонецЕсли;
		
		Ответ = Новый HTTPСервисОтвет(200);
		
		СтруктураОтвета = Новый Структура("IsSuccess,Value,Message",ИСТИНА,"","");
		
		СтруктураДляВозврата = Новый Структура("Результат,ВозвращаемоеЗначение,Описание");
		
		РЕЗ = РозницаHTTP.ПолучитьСвязанныеОбъекты(СтруктураДляВозврата,ТекСсылка);
		
		Если ТипЗНЧ(РЕЗ)=Тип("Массив") Тогда
			
			МассивОтветов = Новый Массив();
			
			Ответ = Новый HTTPСервисОтвет(200);
			Для каждого СтрРЕЗ Из РЕЗ Цикл
			
				СтрМассивОтветов = Новый Структура("IsSuccess,Value,Message",СтрРЕЗ.Результат,СтрРЕЗ.ВозвращаемоеЗначение,СтрРЕЗ.Описание);
				МассивОтветов.Добавить(СтрМассивОтветов);
							
			КонецЦикла; 
			СтруктураОтвета = МассивОтветов;
			
		ИначеЕсли (ТипЗНЧ(РЕЗ)=Тип("Структура"))ИЛИ(ТипЗНЧ(РЕЗ)=Тип("Соответствие")) Тогда
			Если РЕЗ.Результат Тогда
				
				СтруктураОтвета.IsSuccess = ИСТИНА;
				СтруктураОтвета.Message = СокрЛП(РЕЗ.Описание);
				
			Иначе
				
				Ответ = Новый HTTPСервисОтвет(400);
				СтруктураОтвета.IsSuccess = ЛОЖЬ;
				Если СтрДлина(СокрЛП(РЕЗ.Описание))=0 Тогда
					СтруктураОтвета.Message = "String data would be truncated (Description)";
				Иначе
					СтруктураОтвета.Message = СокрЛП(РЕЗ.Описание);
				КонецЕсли;
				
			КонецЕсли;
			СтруктураОтвета.Value = РЕЗ.ВозвращаемоеЗначение;
		Иначе
			
			Ответ = Новый HTTPСервисОтвет(400);
			СтруктураОтвета.IsSuccess = ЛОЖЬ;
			Если СтрДлина(СокрЛП(РЕЗ.Описание))=0 Тогда
				СтруктураОтвета.Message = "String data would be truncated (Description)";
			Иначе
				СтруктураОтвета.Message = СокрЛП(РЕЗ.Описание);
			КонецЕсли;
			
		КонецЕсли;		
		
	КонецЕсли;
	
	ТелоОтвета = Новый ЗаписьJSON();
	ТелоОтвета.УстановитьСтроку();
	ЗаписатьJSON(ТелоОтвета, СтруктураОтвета);
	ТелоОтвета = ТелоОтвета.Закрыть();
	
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета);
	
	Возврат Ответ;
КонецФункции
#КонецОбласти

