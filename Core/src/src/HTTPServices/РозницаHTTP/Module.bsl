			Ответ.УстановитьТелоИзСтроки(ТелоОтвета);
			
			Возврат Ответ;
		КонецЕсли;

		Если ТипЗНЧ(РЕЗ)=Тип("Массив") Тогда
			
			МассивОтветов = Новый Массив();
			
			Ответ = Новый HTTPСервисОтвет(200);
