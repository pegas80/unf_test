#Область ОбщиеПроцедурыИФункции
Функция ПолучитьТелоЗапросаHTTP(ЗапросHTTP)

	ТелоЗапроса = ЗапросHTTP.ПолучитьТелоКакСтроку();
	
	ПОЗ = СтрНайти(ТелоЗапроса,"JSON Data");
	Если ПОЗ>0 Тогда
		
		ТелоЗапроса = СРЕД(ТелоЗапроса,ПОЗ+9);
		
	КонецЕсли;
	
	ТелоЗапроса = СокрЛП(ТелоЗапроса);
	
	Возврат ТелоЗапроса;
КонецФункции // ()

Функция ПоискПоОдномуПараметру(ЗапросHTTP,СтрокаПараметра,ТекстЗапросаПоискаПараметра,ТекстОшибки,УбиратьКавычки=ИСТИНА,УбиратьПробелы=ИСТИНА,ДопПараметр=НЕОПРЕДЕЛЕНО)
	ПЕРЕМ ТекПараметр;
	
	СтруктураОтвета = Новый Структура("IsSuccess,Value,Message",ИСТИНА,"","");		
	Ответ = Новый HTTPСервисОтвет(200);
	
	ТекПараметр = ЗапросHTTP.ПараметрыЗапроса.Получить(СтрокаПараметра);
	
	Если ТекПараметр = НЕОПРЕДЕЛЕНО Тогда
	
		ТелоЗапроса = ПолучитьТелоЗапросаHTTP(ЗапросHTTP);
		Попытка
			
			Флаг = ЛОЖЬ;
			
			ТекстЗапроса = Новый ЧтениеJSON();
			ТекстЗапроса.УстановитьСтроку(ТелоЗапроса);
			Пока ТекстЗапроса.Прочитать() Цикл
				
				ТекTип = ТекстЗапроса.ТипТекущегоЗначения;
				Если ТекTип = ТипЗначенияJSON.ИмяСвойства Тогда
					
					Если ТекстЗапроса.ТекущееЗначение = СтрокаПараметра Тогда
					
						Флаг = ИСТИНА;
					
					КонецЕсли;
					
				ИначеЕсли ((ТекTип = ТипЗначенияJSON.Строка) ИЛИ (ТекTип = ТипЗначенияJSON.Строка)) И Флаг Тогда
					
					ТекПараметр = ТекстЗапроса.ТекущееЗначение;
					Флаг = ЛОЖЬ;
					
				КонецЕсли;
				
			КонецЦикла;
			ТекстЗапроса.Закрыть();
			
		Исключение
			
			Поз = СтрНайти(ТелоЗапроса,СтрокаПараметра+"=""");
			Если Поз>0 Тогда
			
				ТекПараметр = СРЕД(ТелоЗапроса,Поз+11);
				Поз1 = СтрНайти(ТекПараметр,"""");
				Если Поз1>0 И УбиратьКавычки Тогда
				
					//ТекПараметр = ЛЕВ(ТекПараметр,Поз1-1);
					ТекПараметр = СтрЗаменить(ТекПараметр,"""","")
				
				КонецЕсли;
			
			КонецЕсли;
			
		КонецПопытки;
	
	КонецЕсли;
	
	Если УбиратьКавычки Тогда
		ТекПараметр = СтрЗаменить(ТекПараметр,"""","")
	КонецЕсли;
	
	Если ТекПараметр = НЕОПРЕДЕЛЕНО Тогда
	
		Ответ = Новый HTTPСервисОтвет(400);
		СтруктураОтвета.IsSuccess = ЛОЖЬ;
		СтруктураОтвета.Value = "";
		СтруктураОтвета.Message = ТекстОшибки;
		
	Иначе
		
		Если УбиратьПробелы Тогда
			ТекПараметр = СтрЗаменить(ТекПараметр," ","");
		Иначе
			ТекПараметр = СокрЛП(Строка(ТекПараметр));
		КонецЕсли;
			
		Запрос = Новый Запрос;
		Запрос.Текст = ТекстЗапросаПоискаПараметра;
		
		Запрос.УстановитьПараметр("ТекПараметр", ТекПараметр);
		Если НЕ ДопПараметр=НЕОПРЕДЕЛЕНО Тогда
			Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
		КонецЕсли;
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
		
			Ответ = Новый HTTPСервисОтвет(400);
			СтруктураОтвета.IsSuccess = ЛОЖЬ;
			СтруктураОтвета.Message = ТекстОшибки;
		
		
		КонецЕсли;
		
		СтруктураОтвета.Value = ТекПараметр;

	КонецЕсли;
	
	ТелоОтвета = Новый ЗаписьJSON();
	ТелоОтвета.УстановитьСтроку();
	ЗаписатьJSON(ТелоОтвета, СтруктураОтвета);
	ТелоОтвета = ТелоОтвета.Закрыть();
	
	Ответ.УстановитьТелоИзСтроки(ТелоОтвета);
	
	Возврат Ответ;	

КонецФункции
#КонецОбласти

#Область СтандартныеОперации
Функция СтандартныеОперации(ЗапросHTTP,СтрокаОперации,СтрокаСодержанияУдачногоЗавершения)
