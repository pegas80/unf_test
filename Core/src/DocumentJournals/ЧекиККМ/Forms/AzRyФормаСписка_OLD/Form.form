    <name>ЧекиККМ</name>
    <title>
      <key>ru</key>
      <value>Чеки ККМ</value>
    </title>
    <title>
      <key>ka</key>
      <value>საკასო ჩეკები</value>
    </title>
    <title>
      <key>en</key>
      <value>checks CMC</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.Type</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.ЕстьЧекНаВозврат</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.КассаККМИспользоватьБезПодключенияОборудования</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.КассоваяСмена</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.НомерЧекаККМ</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЖурналДокументовЧекиККМ.Ссылка КАК Ссылка,
	ЖурналДокументовЧекиККМ.ПометкаУдаления КАК ПометкаУдаления,
	ЖурналДокументовЧекиККМ.Архивный КАК Архивный,
	ВЫБОР
		КОГДА ЖурналДокументовЧекиККМ.НомерЧекаККМ > 0
			ТОГДА ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
		ИНАЧЕ ЖурналДокументовЧекиККМ.Статус
	КОНЕЦ КАК Статус,
	ВЫБОР
		КОГДА ЖурналДокументовЧекиККМ.Ссылка ССЫЛКА Документ.ЧекККМ
			ТОГДА ЖурналДокументовЧекиККМ.Ссылка.ПолученоНаличными
		ИНАЧЕ 0
	КОНЕЦ КАК ПолученоНаличными,
	ВЫБОР
		КОГДА ЖурналДокументовЧекиККМ.Ссылка ССЫЛКА Документ.ЧекККМ
			ТОГДА ЖурналДокументовЧекиККМ.Ссылка.СуммаОплатыПлатежнымиКартами
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаОплатыПлатежнымиКартами,
	ЖурналДокументовЧекиККМ.Номер КАК Номер,
	ЖурналДокументовЧекиККМ.Дата КАК Дата,
	ЖурналДокументовЧекиККМ.Проведен КАК Проведен,
	ЖурналДокументовЧекиККМ.ВалютаДокумента КАК ВалютаДокумента,
	ЖурналДокументовЧекиККМ.КассаККМ КАК КассаККМ,
	ЖурналДокументовЧекиККМ.КассоваяСмена КАК КассоваяСмена,
	ЖурналДокументовЧекиККМ.НомерЧекаККМ КАК НомерЧекаККМ,
	ЖурналДокументовЧекиККМ.Организация КАК Организация,
	ЖурналДокументовЧекиККМ.Склад КАК Склад,
	ЖурналДокументовЧекиККМ.СуммаДокумента КАК СуммаДокумента,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(ЖурналДокументовЧекиККМ.Ссылка) = ТИП(Документ.ЧекККМВозврат)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЕстьЧекНаВозврат,
	ЖурналДокументовЧекиККМ.Тип КАК Тип,
	ВЫРАЗИТЬ(ЖурналДокументовЧекиККМ.Комментарий КАК СТРОКА(500)) КАК Комментарий,
	ЖурналДокументовЧекиККМ.КассаККМ.ИспользоватьБезПодключенияОборудования КАК КассаККМИспользоватьБезПодключенияОборудования,
	ЖурналДокументовЧекиККМ.Автор КАК Автор,
	ЖурналДокументовЧекиККМ.ЕстьЗаказы КАК ЕстьЗаказы,
	ЖурналДокументовЧекиККМ.ДисконтнаяКарта КАК ДисконтнаяКарта,
	ЖурналДокументовЧекиККМ.Покупатель КАК Покупатель,
	ЖурналДокументовЧекиККМ.Заказ КАК Заказ,
	ВЫБОР
		КОГДА НЕ ЖурналДокументовЧекиККМ.Ссылка.AzRyЭлектроннаяНакладная
			ТОГДА 0
		КОГДА РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка ЕСТЬ NULL
			ТОГДА 1
		КОГДА НЕ РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка ЕСТЬ NULL
			ТОГДА ВЫБОР
					КОГДА РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.СтатусТН = ЗНАЧЕНИЕ(Перечисление.РС_СтатусыТН.НеСоздана)
						ТОГДА 3
					ИНАЧЕ 3
				КОНЕЦ
		ИНАЧЕ 3
	КОНЕЦ КАК AzRyНадоСоздатЭлНакладную
ИЗ
	ЖурналДокументов.ЧекиККМ КАК ЖурналДокументовЧекиККМ
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
		ПО ЖурналДокументовЧекиККМ.Ссылка = РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование</queryText>
      <mainTable>DocumentJournal.ЧекиККМ</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
