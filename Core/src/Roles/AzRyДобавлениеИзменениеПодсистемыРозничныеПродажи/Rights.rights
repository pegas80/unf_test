				ТОГДА ДокументТест.Контрагент В
						(ВЫБРАТЬ
							НастройкаРЛСКонтрагенты.Контрагент
						ИЗ
							Справочник.AzRyНастройкаРЛС.Контрагенты КАК НастройкаРЛСКонтрагенты
						ГДЕ
							НастройкаРЛСКонтрагенты.Ссылка.Пользователь = &amp;ТекущийПользователь
						СГРУППИРОВАТЬ ПО
							НастройкаРЛСКонтрагенты.Контрагент)
			ИНАЧЕ 1 = 1
		КОНЕЦ
	И ВЫБОР
			КОГДА ВложенныйЗапрос.ОграниченияПоПодразделениям
				ТОГДА ДокументТест.СтруктурнаяЕдиница В
						(ВЫБРАТЬ
							НастройкаРЛСПодразделения.Подразделение
						ИЗ
							Справочник.AzRyНастройкаРЛС.Подразделения КАК НастройкаРЛСПодразделения
						ГДЕ
							НастройкаРЛСПодразделения.Ссылка.Пользователь = &amp;ТекущийПользователь
						СГРУППИРОВАТЬ ПО
							НастройкаРЛСПодразделения.Подразделение)
			ИНАЧЕ 1 = 1
		КОНЕЦ
	И ВЫБОР
		КОГДА ВложенныйЗапрос.ОграниченияПоПроектам
			ТОГДА ДокументТест.AzRyПроекты В
					(ВЫБРАТЬ
						НастройкаРЛСПроект.Проект
					ИЗ
						Справочник.AzRyНастройкаРЛС.Проекты КАК НастройкаРЛСПроект
					ГДЕ
						НастройкаРЛСПроект.Ссылка.Пользователь = &amp;ТекущийПользователь
					СГРУППИРОВАТЬ ПО
						НастройкаРЛСПроект.Проект)
		ИНАЧЕ 1 = 1
	КОНЕЦ	</condition>
			</restrictionByCondition>
		</right>
		<right>
			<name>Insert</name>
			<value>true</value>
			<restrictionByCondition>
				<condition>#ПоЗначениям( "Документ.ЗаказПокупателя","Добавление","",
"ГруппыКонтрагентов","Контрагент", "","", "","", "","", "","", "","", "","", "","", "","", "","", "","", "","", "","", "","", "","", "","" )</condition>
			</restrictionByCondition>
