#Область ПеременныеФормы

//&НаКлиенте
//Перем УстановкаОсновнойОрганизацийВыполнена; // Признак успешной установки основной организаций из формы контрагента

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ИспользоватьКакОсновной(Команда)
	
	Если ТипЗнч(Элементы.Список.ТекущаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка")
		Или Элементы.Список.ТекущиеДанные = Неопределено
		Или Элементы.Список.ТекущиеДанные.ЭтоОсновнаяОрганизация Тогда
		
		Возврат;
	КонецЕсли;
	
	НоваяОсновнаяОрганизация = Элементы.Список.ТекущиеДанные.Ссылка;
	
	// Если открыта форма контрагента, то изменение основного договора выполняем в ней
	УстановкаОсновнойОрганизацииВыполнена = Ложь;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Контрагент", ВладелецЭлемента(Элементы.Список.ТекущиеДанные.Ссылка));
	СтруктураПараметров.Вставить("НоваяОсновнаяОрганизация", НоваяОсновнаяОрганизация);
	
	Оповестить("УстановкаОсновнойОрганизации", СтруктураПараметров, ЭтотОбъект);
	
	// Если форма контрагента закрыта, то запишем основной договор контрагента самостоятельно
	//Если Не УстановкаОсновнойОрганизацииВыполнена Тогда
	//	ЗаписатьОсновнуюОрганизациюКонтрагента(СтруктураПараметров);
	//КонецЕсли;
	
	// Обновим динамический список
	Если ЗначениеЗаполнено(КонтрагентВладелец) Тогда
		Список.Параметры.УстановитьЗначениеПараметра("ОсновнаяОрганизация", НоваяОсновнаяОрганизация);
	Иначе
		Элементы.Список.Обновить();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат; // Возврат при получении формы для анализа.
	КонецЕсли;
	
	Параметры.Отбор.Свойство("Владелец", КонтрагентВладелец);
	
	Если ЗначениеЗаполнено(КонтрагентВладелец) Тогда
		// Контекстное открытие формы с отбором по контрагенту
	
		АвтоЗаголовок = Ложь;
		Заголовок = НСтр("ka='ორგანიზაციები  ';ru='Организаций с';en='Organizations'") + " """ + КонтрагентВладелец + """";
		
		Список.Параметры.УстановитьЗначениеПараметра("ОсновнаяОрганизация", КонтрагентВладелец.AzRyОрганизацияПоУмолчанию);
		
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Процедура ЗаписатьОсновнуюОрганизациюКонтрагента(СтруктураПараметров)
	
	КонтрагентОбъект = СтруктураПараметров.Контрагент.ПолучитьОбъект();
	КонтрагентУспешноЗаблокирован = Истина;
	
	Попытка
		КонтрагентОбъект.Заблокировать();
	Исключение
		
		КонтрагентУспешноЗаблокирован = Ложь;
		
		ТекстСообщения = СтрШаблон(
		НСтр("ka='ძირითადი ორგანიზაციის შესაცვლელად კონტრაგენტის დაბლოკვა ვერ მოხერხდა: %1, შემდეგი მიზეზით: %2';ru='Не удалось заблокировать контрагента: %1, для изменения основной организаций, по причине:"
					"%2'", Метаданные.ОсновнойЯзык.КодЯзыка), 
		СтруктураПараметров.Контрагент, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Предупреждение,, КонтрагентОбъект, ОписаниеОшибки());
		
	КонецПопытки;
	
	// Если удалось заблокировать, изменим договор по умолчанию у контрагента
	Если КонтрагентУспешноЗаблокирован Тогда
		КонтрагентОбъект.AzRyОрганизацияПоУмолчанию = СтруктураПараметров.НоваяОсновнаяОрганизация;
		КонтрагентОбъект.Записать();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура СписокПриАктивизацииСтроки(Элемент)
	
	Если ТипЗнч(Элементы.Список.ТекущаяСтрока) <> Тип("СтрокаГруппировкиДинамическогоСписка")
		И Элементы.Список.ТекущиеДанные <> Неопределено Тогда
		
		Элементы.ИспользоватьКакОсновной.Доступность = Не Элементы.Список.ТекущиеДанные.ЭтоОсновнаяОрганизация;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ВладелецЭлемента(Ссылка)

	Возврат Ссылка.Владелец;

КонецФункции
 