
&НаКлиенте
Процедура КомандаOK(Команда)

	Результат = Новый Структура;
	Результат.Вставить("Наименование", Наименование);
	Результат.Вставить("Компания", Компания);
	Результат.Вставить("ИНН", ИНН);
	Результат.Вставить("ДокументУдостоверяющийЛичность", ДокументУдостоверяющийЛичность);
	Результат.Вставить("КонтактнаяИнформация", ЭтаФорма.КонтактнаяИнформация);
	Результат.Вставить("ДанныеКонтактныхЛиц", ЭтаФорма.ДанныеКонтактныхЛиц);
	Результат.Вставить("ВидКонтрагента", ВидКонтрагента);
	Результат.Вставить("НалогообложениеНДС", НалогообложениеНДС);
	
	Если (Не ЗначениеЗаполнено(Наименование) И Не ЗначениеЗаполнено(Компания))
		Или Не ЗначениеЗаполнено(ИНН)
		Или (ЭтоФизическоеЛицо() И Не ЗначениеЗаполнено(ДокументУдостоверяющийЛичность)) Тогда
		
			Сообщить("სავალდებულო ველების შევსება აუცილებელია", СтатусСообщения.Важное);
		
			Возврат;	
		
	КонецЕсли;
	
	Для каждого ТекСтрока Из ЭтотОбъект.КонтактнаяИнформация Цикл	
		
		Если ТекСтрока.Тип = ЗначениеПеречисления("Адрес") Тогда		
			Если Не ЗначениеЗаполнено(ТекСтрока.Представление) Тогда		
				Сообщить("საქონლის მიწოდების ველის შევსება აუცილებელია. ", СтатусСообщения.Важное);
				Возврат;		
			КонецЕсли; 				
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого ТекСтрока Из ЭтотОбъект.ДанныеКонтактныхЛиц Цикл	
		
		Если Не ЗначениеЗаполнено(ТекСтрока.Наименование) Тогда
			
			Сообщить("საკონტაქტო პირის სახელის და გვარის ველის შევსება აუცილებელია. ", СтатусСообщения.Важное);
			Возврат;	
			
		КонецЕсли; 
		
		Для каждого ТекЭл Из ТекСтрока.КонтактнаяИнформация Цикл
					
			Если ТекЭл.Тип = ЗначениеПеречисления("АдресЭлектроннойПочты") Тогда		
				Если Не ЗначениеЗаполнено(ТекЭл.Представление) Тогда		
					Сообщить("საკონტაქტო პირის ელ. მისამართის ველის შევსება აუცილებელია. ", СтатусСообщения.Важное);
					Возврат;				
				КонецЕсли; 				
			КонецЕсли;
			
			Если ТекЭл.Тип = ЗначениеПеречисления("Телефон") Тогда		
				Если Не ЗначениеЗаполнено(ТекЭл.Представление) Тогда		
					Сообщить("საკონტაქტო პირის ტელეფონის ველის შევსება აუცილებელია. ", СтатусСообщения.Важное);
					Возврат;				
				КонецЕсли; 				
			КонецЕсли;	
			
		КонецЦикла;
		
	КонецЦикла;
	
	Закрыть(Новый Структура("ПоляДляЗаполнения", Результат));
	
КонецПроцедуры

&НаСервере
Функция ЗначениеПеречисления(Имя)

	Возврат Перечисления.ТипыКонтактнойИнформации[Имя];	

КонецФункции
 

 &НаСервере
