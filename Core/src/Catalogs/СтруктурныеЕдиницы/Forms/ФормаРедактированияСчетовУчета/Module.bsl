
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СчетУчетаВРознице = Параметры.СчетУчетаВРознице;
	СчетУчетаНаценки = Параметры.СчетУчетаНаценки;
	СчетУчетаВРозницеРегл = Параметры.СчетУчетаВРозницерегл;
	СчетУчетаНаценкиРегл = Параметры.СчетУчетаНаценкиРегл;
	СчетУчетаРегл = Параметры.СчетУчетаРегл;
	Ссылка = Параметры.Ссылка;
	
	Если ОтказИзменитьСчетУчета(Ссылка) Тогда
		Элементы.ГруппаСчетовУчета.Подсказка = НСтр("ka='ბაზაში არის მოძრაობები ამ საცალო ვაჭრობის წერტილის მიხედვით! აღრიცხვის დათვლის შეცვლა აკრძალულია!';ru='В базе есть движения по этой розничной точке! Изменение счета учета запрещено!';en='At the base there is movement on this retail outlet! Change in accounting account banned!'");
		Элементы.ГруппаСчетовУчета.Доступность = Ложь;
		Элементы.ПоУмолчанию.Видимость = Ложь;
	КонецЕсли;
	
	ЭтоРозницаСуммовойУчет = Ссылка.ТипСтруктурнойЕдиницы = Перечисления.ТипыСтруктурныхЕдиниц.РозницаСуммовойУчет;
	ТранзитныйСклад  = Ссылка.ТранзитныйСклад;
	РегламентированныйУчетСервер.УстановитьВидимостьУпрУчета(ЭтаФорма);
	
	Если  ТранзитныйСклад Тогда
		ЭтаФорма.Элементы.СчетУчетаВРознице.Видимость = Ложь;
		ЭтаФорма.Элементы.СчетУчетаВРозницеРегл.Видимость  = Ложь;
		ЭтаФорма.Элементы.СчетУчетаНаценки.Видимость = Ложь;
		ЭтаФорма.Элементы.СчетУчетаНаценкиРегл.Видимость  = Ложь;
	КонецЕсли;

	
КонецПроцедуры // ПриСозданииНаСервере()

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если НЕ ЭтоРозницаСуммовойУчет И Не ТранзитныйСклад = Истина Тогда
		Отказ = Истина;
		ПоказатьПредупреждение(, НСтр("ka='აღრიცხვის ანგარიშების რედაქტირება ხდება მხოლოდ თანხობრივი აღრიცხვის მქონე საცალო ვაჭრობისთვის!';ru='Счета учетов редактируются только для розницы с суммовым учетом!';en='for bookkeeping edited only for retailers with the accrual basis, taking into account!'"));
	КонецЕсли;
	
	Если  ТранзитныйСклад Тогда
		ЭтаФорма.Элементы.СчетУчетаНаценки.Видимость = Ложь;
		ЭтаФорма.Элементы.СчетУчетаНаценкиРегл.Видимость  = Ложь;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

