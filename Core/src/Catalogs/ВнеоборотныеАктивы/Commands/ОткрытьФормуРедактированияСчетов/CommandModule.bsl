
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [7 августа 2023]  НАЧАЛО
	//СтруктураПараметров = ПолучитьСтруктуруПараметров(ПараметрКоманды);
	Если ТипЗнч(ПараметрыВыполненияКоманды.Источник) = Тип("УправляемаяФорма") Тогда
	
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("Ссылка", ПараметрыВыполненияКоманды.Источник.Объект.Ссылка);
		СтруктураПараметров.Вставить("ТипВнеоборотныеАктивы", ПараметрыВыполненияКоманды.Источник.Объект.ТипВнеоборотныеАктивы);
		СтруктураПараметров.Вставить("СчетУчета", ПараметрыВыполненияКоманды.Источник.Объект.СчетУчета);
		СтруктураПараметров.Вставить("СчетАмортизации", ПараметрыВыполненияКоманды.Источник.Объект.СчетАмортизации);
		СтруктураПараметров.Вставить("СчетУчетаРегл", ПараметрыВыполненияКоманды.Источник.Объект.СчетУчетаРегл);
		СтруктураПараметров.Вставить("СчетАмортизацииРегл", ПараметрыВыполненияКоманды.Источник.Объект.СчетАмортизацииРегл);
	
	Иначе
	
		СтруктураПараметров = ПолучитьСтруктуруПараметров(ПараметрКоманды);
	
	КонецЕсли; 
	// © Шишка В.В. [7 августа 2023]  КОНЕЦ
	//--------------------------------------------------------------------------
	ОткрытьФорму(
		"Справочник.ВнеоборотныеАктивы.Форма.ФормаРедактированияСчетовУчета",
		СтруктураПараметров,
		ПараметрыВыполненияКоманды.Источник,
		ПараметрыВыполненияКоманды.Уникальность,
		ПараметрыВыполненияКоманды.Окно,
		ПараметрыВыполненияКоманды.НавигационнаяСсылка
	);
	
КонецПроцедуры



&НаСервере
Функция ПолучитьСтруктуруПараметров(ПараметрКоманды)
	
	СтруктураПараметров = Новый Структура(
		"СчетУчета, СчетАмортизации, Ссылка, СчетУчетаРегл, СчетАмортизацииРегл",
		ПараметрКоманды.СчетУчета, ПараметрКоманды.СчетАмортизации, ПараметрКоманды.Ссылка, ПараметрКоманды.СчетУчетаРегл, ПараметрКоманды.СчетАмортизацииРегл);
		
	Возврат СтруктураПараметров;
	
КонецФункции
