

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.ОбластьОграничения.РежимВыбораИзСписка = Истина;
	Элементы.ОбластьОграничения.СписокВыбора.Добавить(Перечисления.ВариантыОбластейОграниченияСкидокНаценок.ВСтроке);	
	Объект.ОбластьОграничения = Перечисления.ВариантыОбластейОграниченияСкидокНаценок.ВСтроке;		
	Объект.КритерийОграничения =НСтр("ru = 'Срок Годности'; ka = 'ვარგისიანობის ვადა'");
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ЗаполнитьПризнакиВТЧ();
	
	ТипПолучателяСкидкиПредыдущий = ТипПолучателяСкидки;
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакиВТЧ()

	
	Для Каждого ТекущаяСтрока Из Объект.Скиди Цикл
		ТекущаяСтрока.ХарактеристикиИспользуются = ТекущаяСтрока.Номенклатура.ИспользоватьХарактеристики;
		ТекущаяСтрока.ЭтоГруппа = ТекущаяСтрока.Номенклатура.ЭтоГруппа;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	ОбновитьАвтонаименование(Модифицированность);
	РС_ОбщегоНазначенияКлиент.ПроверкаМодифицированостиВопрос(Объект.Ссылка, Модифицированность, Отказ);//Паганини
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ЗаполнитьПризнакиВТЧ();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьГруппу(Команда)
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ДобавитьГруппуНоменклатурыЗавершение", ЭтотОбъект);
	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбораГруппы",, ЭтотОбъект,,,, ОповещениеОЗакрытии);
	
КонецПроцедуры


&НаКлиенте
Процедура РежимВыбораГруппИЭлементов(Команда)
	
	Если Элементы.СкидиНоменклатура.ВыборГруппИЭлементов = ГруппыИЭлементы.Элементы Тогда 
		Элементы.СкидиНоменклатура.ВыборГруппИЭлементов =   ГруппыИЭлементы.Группы ;
		Элементы.СкидиНоменклатура.ПодсказкаВвода = НСтр("ka='ნომენკლატურა(ჯგუფი)';ru=' Номенклатура(группа)'");
		Элементы.СкидиРежимВыбораГруппИЭлементов.Картинка  = БиблиотекаКартинок.РежимВыбораГрупп;
		Объект.Естьруппа = Истина;
		Объект.Скиди.Очистить();
	Иначе 
		Элементы.СкидиНоменклатура.ВыборГруппИЭлементов =   ГруппыИЭлементы.Элементы ;
		Элементы.СкидиНоменклатура.ПодсказкаВвода = НСтр("ka='ნომენკლატურა';ru=' Номенклатура'");
		Элементы.СкидиРежимВыбораГруппИЭлементов.Картинка  = БиблиотекаКартинок.РежимВыбораЭлементов;
		Объект.Естьруппа = Ложь;
		Объект.Скиди.Очистить();	
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ДобавитьГруппуНоменклатурыЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(РезультатЗакрытия) Тогда
		НоваяСтрока = Объект.Скиди.Добавить();
		НоваяСтрока.Номенклатура = РезультатЗакрытия;
		Элементы.Скиди.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьАвтонаименование(Обновить = Истина)
	
	Если Не ЗначениеЗаполнено(Объект.Наименование) ИЛИ (Обновить И ИспользуетсяАвтоНаименование И Не НаименованиеИзмененоПользователем) Тогда
		Объект.Наименование = СформироватьАвтоНаименованиеНаКлиенте();
		ИспользуетсяАвтоНаименование = Истина;
	КонецЕсли;
	
КонецПроцедуры

