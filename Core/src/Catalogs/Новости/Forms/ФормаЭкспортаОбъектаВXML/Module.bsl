#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ЭтотОбъект.ПредставлениеXML = Параметры.ПредставлениеXML;

	ЭтотОбъект.КартинкаФайлЗаписан = БиблиотекаКартинок.Записать;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаЗаписать(Команда)

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = НСтр("ka='Выберите файл, куда записать содержимое XML';ru='Выберите файл, куда записать содержимое XML';en='Select the file where to write the contents of the XML'");
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Расширение = "xml";
	Диалог.Фильтр = НСтр("ka='Файл xml (*.xml)|*.xml';ru='Файл xml (*.xml)|*.xml';en='File xml (* .xml) | * .xml'");
	Если Диалог.Выбрать() Тогда
		ИмяФайла = Диалог.ПолноеИмяФайла;
	Иначе
		Возврат;
	КонецЕсли;

	Если НЕ ПустаяСтрока(ИмяФайла) Тогда

		Если ПустаяСтрока(ЭтотОбъект.ПредставлениеXML) Тогда

			ТекстСообщения = НСтр("ka='Текст пустой. Нечего сохранять.';ru='Текст пустой. Нечего сохранять.';en='The text is empty. There is nothing to save.'");
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = ТекстСообщения;
			Сообщение.Поле  = "ПредставлениеXML"; // Идентификатор.
			Сообщение.УстановитьДанные(ЭтотОбъект);
			Сообщение.Сообщить();

		Иначе

			ЗаписьТекста = Новый ЗаписьТекста(ИмяФайла, "UTF-8", Символы.ПС, Ложь, Символы.ПС);
				ЗаписьТекста.Записать(ЭтотОбъект.ПредставлениеXML);
			ЗаписьТекста.Закрыть();

			ПоказатьОповещениеПользователя(
				НСтр("ka='ფაილი ჩაწერილია.';ru='Файл записан.';en='recorded file.'"),
				"file://" + СтрЗаменить(ИмяФайла, "\", "/"),
				ИмяФайла,
				ЭтотОбъект.КартинкаФайлЗаписан);

		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти
