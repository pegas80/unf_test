	ИначеЕсли Тип = Перечисления.ТипыНачисленийИУдержаний.Удержание Тогда
		Формула						= "";
		
		Контрагент					= Неопределено;
		Договор						= Неопределено;
		ВидНалога					= Неопределено;
		ВидНалогаВыплат				= Неопределено;
		ПенсионныйНалогСотрудника	= Неопределено;
		ПенсионныйНалогОрганизации	= Неопределено;
		СтавкаПФ					= 0;
		СтавкаНДФЛ					= 0;
	Иначе
		Контрагент					= Неопределено;
		Договор						= Неопределено;
		СтавкаПФ					= 0;
		ПенсионныйНалогСотрудника	= Неопределено;
		ПенсионныйНалогОрганизации	= Неопределено;
		
		ВидНалога					= Неопределено;
		ВидНалогаВыплат				= Неопределено;
		СтавкаНДФЛ					= 0;
		ВидУдержанияНДФЛ			= Неопределено;
		ВидУдержанияПФ				= Неопределено;
	КонецЕсли;
	//_Паганини ПФ
КонецПроцедуры

ИстопльзоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ТекущаяДата());