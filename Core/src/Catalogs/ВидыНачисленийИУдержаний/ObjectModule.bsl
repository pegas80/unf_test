Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	//Если Тип <> Перечисления.ТипыНачисленийИУдержаний.Налог Тогда
	//	
	//	УправлениеНебольшойФирмойСервер.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "ВидНалога");
	//	
	//КонецЕсли;
	//
	//Если Тип = Перечисления.ТипыНачисленийИУдержаний.Удержание 
	//	ИЛИ Тип = Перечисления.ТипыНачисленийИУдержаний.Налог Тогда
	//	
	//	УправлениеНебольшойФирмойСервер.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "КодДоходаНДФЛ");
	//	
	//КонецЕсли;//Паганини
	
	//Паганини ПФ_
	Если Тип = Перечисления.ТипыНачисленийИУдержаний.Налог Тогда
		ПроверяемыеРеквизиты.Добавить("ВидНалога");
		ПроверяемыеРеквизиты.Добавить("ВидНалогаВыплат");
	ИначеЕсли Тип = Перечисления.ТипыНачисленийИУдержаний.УдержаниеПФ Тогда
		ПроверяемыеРеквизиты.Добавить("Контрагент");
		ПроверяемыеРеквизиты.Добавить("Договор");
		ПроверяемыеРеквизиты.Добавить("СтавкаПФ");
		ПроверяемыеРеквизиты.Добавить("ПенсионныйНалогСотрудника");
		ПроверяемыеРеквизиты.Добавить("ПенсионныйНалогОрганизации");
		ПроверяемыеРеквизиты.Добавить("СчетЗатратРегл");
	ИначеЕсли Тип = Перечисления.ТипыНачисленийИУдержаний.УдержаниеДляКонтрагента Тогда
		ПроверяемыеРеквизиты.Добавить("Контрагент");
		ПроверяемыеРеквизиты.Добавить("Договор");
	Иначе
		ПроверяемыеРеквизиты.Добавить("СчетЗатратРегл");
	КонецЕсли;
	//_Паганини ПФ
	
	//+++ Дмгг
	Если ИстопльзоватьТолькоРегламентированныйПланСчетов Тогда 
		
		УправлениеНебольшойФирмойСервер.УдалитьПроверяемыйРеквизит(ПроверяемыеРеквизиты, "СчетЗатрат");
		
	КонецЕсли;
	//-- Дмгг
	
КонецПроцедуры // ОбработкаПроверкиЗаполнения()

#КонецЕсли
Процедура ПередЗаписью(Отказ)
	
	Если ЭтотОбъект.ЭтоГруппа Тогда 
		Возврат;
	КонецЕсли;
	
	//Паганини ПФ_
	Если Тип = Перечисления.ТипыНачисленийИУдержаний.Налог Тогда
