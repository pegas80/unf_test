						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>გრძელი ტონა, აშშ (1,0160469 ტ)</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
