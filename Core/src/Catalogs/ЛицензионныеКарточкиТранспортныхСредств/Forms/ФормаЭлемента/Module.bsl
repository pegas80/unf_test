
#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура СформироватьНаименование()
	
	Объект.Наименование = Нстр("ru='Серия ';ka='Серия '") + Объект.СерияЛицензионнойКарты + Нстр("ru=' № ';ka=' № '") + Объект.НомерЛицензионнойКарты + Нстр("ru=' от ';ka='ვისგან'") + Формат(Объект.ДатаВыдачиЛицензионнойКарты, "ДФ=dd.MM.yyyy");
	
	Если ЗначениеЗаполнено(Объект.ВладелецЛицензии) Тогда
		
		Объект.Наименование = Объект.Наименование + Нстр("ru='. Владелец: ';ka='. Владелец: '") + Объект.ВладелецЛицензии;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

