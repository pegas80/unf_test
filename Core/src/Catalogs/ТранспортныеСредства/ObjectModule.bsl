
&Насервере
Процедура ПриЗаписи(Отказ)

Если Не Константы.КонтролУникалностиПоКодуТранспортныеСредства.Получить()= Истина Тогда	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТранспортныеСредства.Код,
		|	ТранспортныеСредства.Ссылка
		|ИЗ
		|	Справочник.ТранспортныеСредства КАК ТранспортныеСредства
		|ГДЕ
		|	ТранспортныеСредства.Код = &Код
		|	И ТранспортныеСредства.Ссылка <> &Ссылка";
	
	Запрос.УстановитьПараметр("Код", Код);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		 	Сообщение = Новый СообщениеПользователю;
           Сообщение.Текст = НСтр("ru='Код не уникален';ka='სარეგისტრაციო ნიშანი არა არის უნიკალური'");
           Сообщение.Сообщить();
           Отказ = Истина;

	КонецЕсли;
	

КонецЕсли;	
	
	
КонецПроцедуры

