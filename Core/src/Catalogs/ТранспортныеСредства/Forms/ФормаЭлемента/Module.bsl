	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	//Объект.Заказ = 
	пробег = ВыбратьПробег(Объект.Код);
	Если  пробег > 0 Тогда 
		Объект.Пробег = пробег;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ВыбратьПробег(ТранспортноеСредство)
	
	пробег = 0;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПробегСрезПоследних.Пробег КАК Пробег,
		|	ПробегСрезПоследних.ТранспортноеСредство
		|ИЗ
		|	РегистрСведений.Пробег.СрезПоследних КАК ПробегСрезПоследних
		|ГДЕ
		|	ПробегСрезПоследних.ТранспортноеСредство.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", ТранспортноеСредство);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		пробег = ВыборкаДетальныеЗаписи.Пробег;
	КонецЦикла;
	
	Возврат пробег;
	
КонецФункции

