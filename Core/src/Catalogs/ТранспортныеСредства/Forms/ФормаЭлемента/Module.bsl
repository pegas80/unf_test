&НаСервере
Процедура СоздатьПробег(Пробег)
	
	НовийПробег = РегистрыСведений.Пробег.СоздатьНаборЗаписей();
	НовийПробег.Прочитать();
	новий = НовийПробег.Добавить(); 
	новий.Период = ТекущаяДата();
	новий.Пробег = Пробег;
	новий.ТранспортноеСредство = Объект.Ссылка;
	НовийПробег.Записать(Истина);
КонецПроцедуры

