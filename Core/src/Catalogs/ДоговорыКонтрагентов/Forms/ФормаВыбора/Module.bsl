КонецПроцедуры
// Конец СтандартныеПодсистемы.Печать

#КонецОбласти

// Kuzmich, 12.08.2019, Использовать виды договоров
&НаСервере
Функция Константы_ИспользоватьВидыДоговоров_Получить()
	Возврат Константы.ИспользоватьВидыДоговоров.Получить();
КонецФункции // ()

&НаКлиенте
Процедура УстановитьДополнительныйОтборПоВидуДоговора()
	
	ДанныеВызывающегоОбъекта = Новый Структура("СсылкаНаДокумент,ТаблицаФормы,ИмяРеквизита");
	
	ТекСсылкаНаВызывающийОбъект = НЕОПРЕДЕЛЕНО;
	ТекТаблицаФормы = "";
	Если ТипЗНЧ(ВладелецФормы)=Тип("ПолеФормы") Тогда
		
		ДанныеВызывающегоОбъекта.ИмяРеквизита = ВладелецФормы.Имя;
		Попытка
			ДанныеВызывающегоОбъекта = ПолучитьДанныеВызывающегоОбъекта(ВладелецФормы,ДанныеВызывающегоОбъекта);
		Исключение
		КонецПопытки;
		
	КонецЕсли;
	ТекСсылкаНаВызывающийОбъект = ДанныеВызывающегоОбъекта.СсылкаНаДокумент;
	ТекТаблицаФормы = ДанныеВызывающегоОбъекта.ТаблицаФормы;	
	
	Если НЕ ТекСсылкаНаВызывающийОбъект = НЕОПРЕДЕЛЕНО Тогда
		
		ВладелецВсеНеУстановлены = ИСТИНА;
		
		ВладелецПокупатель = ИСТИНА;
		ВладелецПоставщик = ИСТИНА;
		ВладелецПрочиеОтношения = ИСТИНА;
		
		Если ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.АвансовыйОтчет") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ВводНачальныхОстатков") Тогда
			Если ТекТаблицаФормы="ЗапасыПереданные" ИЛИ ТекТаблицаФормы="ЗапасыПринятые" Тогда
				Возврат;
			ИначеЕсли ТекТаблицаФормы="РасчетыСПоставщиками" Тогда
				ВладелецПокупатель = ЛОЖЬ;
				ВладелецПоставщик = ИСТИНА;
				ВладелецПрочиеОтношения = ИСТИНА;
			ИначеЕсли ТекТаблицаФормы="РасчетыСПокупателями" Тогда
				ВладелецПокупатель = ИСТИНА;
				ВладелецПоставщик = ЛОЖЬ;
				ВладелецПрочиеОтношения = ИСТИНА;
			Иначе
				Возврат;
			КонецЕсли;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.Взаимозачет") Тогда
			Если ТекТаблицаФормы="Кредитор" Тогда
				ВладелецПокупатель = ЛОЖЬ;
				ВладелецПоставщик = ИСТИНА;
				ВладелецПрочиеОтношения = ИСТИНА;
			ИначеЕсли ТекТаблицаФормы="Дебитор" Тогда
				ВладелецПокупатель = ИСТИНА;
				ВладелецПоставщик = ЛОЖЬ;
				ВладелецПрочиеОтношения = ИСТИНА;
			Иначе
				ВладелецПокупатель = ИСТИНА;
				ВладелецПоставщик = ИСТИНА;
				ВладелецПрочиеОтношения = ИСТИНА;
			КонецЕсли;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ЗаданиеНаРаботу") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ЗаказПокупателя") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.КорректировкаПоступления") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.КорректировкаРеализации") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ОперацияПоПлатежнымКартам") Тогда
			//ВладелецПокупатель = ИСТИНА;
			//ВладелецПоставщик = ИСТИНА;
			//ВладелецПрочиеОтношения = ИСТИНА;
			Возврат;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ОтчетКомиссионера") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ОтчетКомитенту") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ОтчетОПереработке") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПередачаВА") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПоступлениеВКассу") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПоступлениеДСПлан") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда
			ВладелецПокупатель = ИСТИНА;
			ВладелецПоставщик = ЛОЖЬ;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПоступлениеНаСчет") Тогда
			Возврат;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПриходнаяНакладная") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПриходныйОрдер") Тогда
			ВладелецПокупатель = ЛОЖЬ;
			ВладелецПоставщик = ИСТИНА;
			ВладелецПрочиеОтношения = ИСТИНА;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.ПрочиеРасходы") Тогда
			Возврат;
		ИначеЕсли ТипЗНЧ(ТекСсылкаНаВызывающийОбъект)=Тип("ДокументСсылка.РасходДСПлан") Тогда
