Функция ПолучитьДанныеВызывающегоОбъекта(ЭлементФормы,ДанныеВызывающегоОбъекта)
	ПЕРЕМ РЕЗ;
	РЕЗ = ДанныеВызывающегоОбъекта;
	
	Если ТипЗНЧ(ЭлементФормы)=Тип("УправляемаяФорма") Тогда
		РЕЗ.СсылкаНаДокумент = ЭлементФормы.Объект.Ссылка;
	ИначеЕсли ТипЗНЧ(ЭлементФормы)=Тип("ТаблицаФормы") Тогда
		РЕЗ.ТаблицаФормы = ЭлементФормы.Имя; 
		РЕЗ = ПолучитьДанныеВызывающегоОбъекта(ЭлементФормы.Родитель,РЕЗ);
	Иначе	
		РЕЗ = ПолучитьДанныеВызывающегоОбъекта(ЭлементФормы.Родитель,РЕЗ);
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()
