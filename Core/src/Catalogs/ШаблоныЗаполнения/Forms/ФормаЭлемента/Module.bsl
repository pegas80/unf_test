&НаСервере
Процедура ВидимостьЭлементовПоВидуОперации()
	
	  ВидимостьДоговора = Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПокупателя 
	  ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПоставщика
	  ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Покупателю
	  ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Поставщику;
	  
	  ВидимостьВидНалога =  Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Налоги
	  ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Налоги;
	  
	  ВидимостьКорреспонденция =  Объект.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее
	  ИЛИ Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Прочее;
	  
	  Элементы.ЗаполнитьДоговор.Видимость = ВидимостьДоговора;
	  Элементы.ВидНалога.Видимость 		  = ВидимостьВидНалога;
	  Элементы.Корреспонденция.Видимость  = ВидимостьКорреспонденция;
	  Элементы.КорреспонденцияРегл.Видимость  = ВидимостьКорреспонденция;//Паганини

КонецПроцедуры 

&НаКлиенте
Процедура СкопироватьВСписок(Команда)
	
	СписокЗнч = ПолучитьСписокИзТеста();
	Если СписокЗнч.Количество() Тогда 
		
		ТекущиеДанные = Элементы.НастройкиОтбор.ТекущиеДанные;
		
		ЭлементыОтбора = НастройкиОтбор.Настройки.Отбор.Элементы;
		Для Каждого стр Из ЭлементыОтбора Цикл 
			Если стр.ЛевоеЗначение = ТекущиеДанные.ЛевоеЗначение Тогда 
				стр.ПравоеЗначение = СписокЗнч;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Функция  ПолучитьСписокИзТеста()
	
	Текст = "";
	Подсказка = "Введите текст напоминания";
	СписокЗнч = Новый СписокЗначений;
	
	Если ВвестиСтроку(Текст, Подсказка, 0, Истина) Тогда
		Пока  Найти(Текст, Символы.ПС)  > 0 Цикл 
			ДлинаТекст = СтрДлина(Текст);
			НомерСтр = Найти(Текст, Символы.ПС);
			врТекст = СокрЛП(Лев(Текст,НомерСтр));
			СписокЗнч.Добавить(врТекст);
			Текст = Прав(Текст,ДлинаТекст-НомерСтр);
		КонецЦикла;
		
		Если Не Текст ="" Тогда 
			СписокЗнч.Добавить(Текст);
		КонецЕсли;
		
	КонецЕсли;
	Возврат СписокЗнч; 
	
КонецФункции

&НаКлиенте
Процедура ВидОперацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если НЕ Объект.СсылкаИсточника = "ПеремещениеДС"  Тогда
		СтандартнаяОбработка = Ложь;
		
		ВидыПДР = ПолучитьСписокВидыОпераций();
		ВыбранныйЭлемент = ВыбратьИзСписка(ВидыПДР, Элемент,); 
		
		Если ВыбранныйЭлемент <> Неопределено Тогда
			УстановитьВидОпераций(ВыбранныйЭлемент.Значение);
		КонецЕсли;
		ВидимостьЭлементовПоВидуОперации();//Паганини
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокВидыОпераций()
	ВидыПДР = Новый СписокЗначений;
	Если  Объект.СсылкаИсточника = "ПоступлениеНаСчет"  Тогда
		
		ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПокупателя);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПоставщика);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеНаСчет.Прочее);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеНаСчет.Налоги);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийПоступлениеНаСчет.ПоступлениеОплатыПоКартам);//Паганини
		
	ИначеЕсли Объект.СсылкаИсточника = "РасходСоСчета" Тогда
		
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Поставщику);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Покупателю);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Прочее);
		ВидыПДР.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Налоги);
		
		
	КонецЕсли;
	
	Возврат ВидыПДР;
КонецФункции // ()

