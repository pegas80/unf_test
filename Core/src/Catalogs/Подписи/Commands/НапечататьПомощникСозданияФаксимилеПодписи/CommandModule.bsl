	СтруктураДополнительныхПараметров = Новый Структура("ЗаголовокФормы", Нстр("ka='Инструкция ""Как создать факсимиле подписи""';ru='Инструкция ""Как создать факсимиле подписи""';en='Guide ""How to create a facsimile of the signature""'"));
	
