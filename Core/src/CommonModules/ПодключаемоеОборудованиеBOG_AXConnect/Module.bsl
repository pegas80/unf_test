// ფუნქცია ბრძანების დასახელების მიხედვით გადასცემს მოწყობილობას შესაბამის ბრძანებას
// Функция получает, обрабатывает и перенаправляет на исполнение команду к драйверу
//
Функция ВыполнитьКоманду(Команда, ВходныеПараметры = Неопределено, ВыходныеПараметры = Неопределено, ОбъектДрайвера, Параметры, ПараметрыПодключения) Экспорт
	
	Результат = Истина;
	ВыходныеПараметры = Новый Массив;
	Попытка
		Идентификатор = Параметры.Идентификатор;	
	Исключение
		Идентификатор = Неопределено;
	КонецПопытки;
	
	Если Команда = "КопияЧека" Тогда 
		ПоследныйЧек = ВходныеПараметры.ПоследныйЧек;
	ИначеЕсли ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 0 Тогда 
		впСумма = ВходныеПараметры[0];
	Иначе 
		впСумма = 0;
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 1 Тогда 
		МетодОплаты = ВходныеПараметры[1];
	Иначе 
		//МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.Банк");
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 2 Тогда 
		ПериодРасрочки = ВходныеПараметры[2];
	Иначе 
		ПериодРасрочки = 0;
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 3 Тогда 
		СуммаДляВозврата = ВходныеПараметры[3];
	Иначе 
		СуммаДляВозврата = 0;
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 4 Тогда 
		НомерСсылкы = ВходныеПараметры[4];
	Иначе 
		НомерСсылкы = "";
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 5 Тогда 
		КодАвторизации 			= ВходныеПараметры[5];
	Иначе 
		КодАвторизации = "";
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 6 Тогда 
		ВидОплатыДляВозврата 	= ВходныеПараметры[6];
	Иначе 
		ВидОплатыДляВозврата 	= "";
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 7 Тогда 
		КодОперацииЭС 	= ВходныеПараметры[7];
	Иначе 
		КодОперацииЭС 	= "";
	КонецЕсли;
	
	Если ВходныеПараметры <> Неопределено И ВходныеПараметры.Количество() > 8 Тогда 
		 CashbackAmount	= ВходныеПараметры[8];
	Иначе 
		 CashbackAmount	= 0;
	КонецЕсли;

	ВходныеПараметры = ВозвратВходныеПараметры(Идентификатор, впСумма, МетодОплаты, ПериодРасрочки, СуммаДляВозврата, НомерСсылкы, КодАвторизации, ВидОплатыДляВозврата, КодОперацииЭС, CashbackAmount);
	
	Если Команда = "PrintSlipOnTerminal" Тогда
		Результат = ПечатьКвитанцийНаТерминале(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
		
	ИначеЕсли Команда = "ПолучитьВерсиюДрайвера" Тогда
		
		Результат = ПолучитьВерсиюДрайвера(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "AuthorizeSales" Тогда
		
		Результат = AuthorizeSales(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "AuthorizeRefund" Тогда
		
		Результат = AuthorizeRefund(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "AuthorizeVoid" Тогда
		
		Результат = AuthorizeVoid(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "КраткийОтчет"  Тогда
		
		Результат = КраткийОтчет(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "ПолныйОтчет" Тогда
		
		Результат = ПолныйОтчет(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "КопияЧека" Тогда
		
		Результат = КопияЧека(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры, ПоследныйЧек);
		
	ИначеЕсли Команда = "ПроверкаСоеденений" Тогда
		
		Результат = ПроверкаСоеденений(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	ИначеЕсли Команда = "ИтогиДняПоКартам" Или Команда = "Settlement" Тогда
		
		Результат = ИтогиДняПоКартам(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// ფუნქცია აბრუნებს მოწყობილობის დრიავერის ვერსიას
// Функция возвращает версию установленного драйвера
//
Функция ПолучитьВерсиюДрайвера(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры)

	Результат = Истина;

	ВыходныеПараметры.Добавить(НСтр("ka='დაყენებულია';ru='Установлен'"));
	ВыходныеПараметры.Добавить(НСтр("ka='არ არის განსაზღვრული';ru='Не определена'"));

	Попытка
		Версия = ОбъектДрайвера.ПолучитьНомерВерсии();
		ВыходныеПараметры[1] = Версия;
		// Дополнительные параметры
		ВыходныеПараметры.Добавить(ПолучитьВерсиюВнешнейКомпоненты());
		ВыходныеПараметры.Добавить(ВерсияСтрокаВЧисло(Версия));
		ВыходныеПараметры.Добавить(ВерсияСтрокаВЧисло(ПолучитьВерсиюВнешнейКомпоненты()));
	Исключение
		ВыходныеПараметры[1] = ПолучитьВерсиюВнешнейКомпоненты();
		
	КонецПопытки;

	Возврат Результат;

КонецФункции

// მოწყობილობასთან კავშირის გაწყვეტა
// Функция осуществляет отключение устройства.
//
// Параметры:
//  ОбъектДрайвера - <*>
//         - ОбъектДрайвера драйвера торгового оборудования.
//
// Возвращаемое значение:
//  <Булево> - Результат работы функции.
//
Функция ОтключитьУстройство(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт

	Результат = Ложь;

	// Обязательные выходные
	ВыходныеПараметры = Новый Массив();

	Попытка
		ОтключитьсяОтФР(ОбъектДрайвера, 0);
		Результат = Истина;
	Исключение
		ВыходныеПараметры.Добавить(999);
		ВыходныеПараметры.Добавить("");
		Результат = Ложь;
	КонецПопытки;	

	Возврат Результат;

КонецФункции

// ფისკალურთან კავშირის შეწყვეტა
//
// პარამეტრები:
//  Объект       - объект подключенного торгового оборудования
//  НомерЛУ      - номер логического устройства с которым связан объект
//
//
Процедура ОтключитьсяОтФР(Объект, НомерЛУ = 0)

	// Принудительное закрытие сеанса обмена, если он был открыт
	Объект.Disconnect();
	
КонецПроцедуры

Функция AuthorizeSales(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)

	мТипТранзакции = "Оплата";
	
    TerminalID = Параметры.TerminalID;
    TerminalAlias = Параметры.TerminalAlias;
    ИспользоватьTranslinkДляТерминала = Параметры.ИспользоватьTranslinkДляТерминала;
	Сумма = ВходныеПараметры.Сумма;
	КодОперации = Неопределено;
	КодRRN = Неопределено;
	КодАвторизации = ВходныеПараметры.КодАвторизации;
	//COMПортФР = Параметры.Порт;
	COMПортФР = "";
	СписокСтрокСлипЧека = Новый Структура;
	МетодОплаты = ВходныеПараметры.МетодОплаты;
	мRequest = ВходныеПараметры.мRequest;
	мRequest.TerminalID = TerminalID;  
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias;  
	КонецЕсли;

	мМассив = ВходныеПараметры.мМассив;
	ПериодРасрочки = ВходныеПараметры.ПериодРасрочки;
	CashbackAmount = ВходныеПараметры.CashbackAmount;
	
	СуммаВременная = Неопределено;
	
	КодКарты       = Неопределено;
	СсылочныйНомер = Неопределено;
	НомерЧека      = Неопределено;
	СлипЧек = Неопределено;
	
	Ответ = "";
	Результат = ОплатитьПлатежнойКартой(ОбъектДрайвера, TerminalID, СтрЗаменить(Формат(Сумма + CashbackAmount,"ЧДЦ=2; ЧРД=,; ЧГ="),",",""), КодRRN, КодАвторизации,  СписокСтрокСлипЧека, КодОперации, COMПортФР, МетодОплаты, мRequest, мМассив, ПериодРасрочки, TerminalAlias, СтрЗаменить(Формат(CashbackAmount,"ЧДЦ=2; ЧРД=,; ЧН=0; ЧГ="),",",""), ИспользоватьTranslinkДляТерминала,Ответ);
	
	Если Результат Тогда
		
		СсылочныйНомер = СписокСтрокСлипЧека.НомерСсылкы;
		КодАвторизации = СписокСтрокСлипЧека.КодАвторизации;
		
		//ВыходныеПараметры.Добавить("****************");
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерКарты);
		ВыходныеПараметры.Добавить(СсылочныйНомер);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
		ВыходныеПараметры.Добавить(Новый Массив());
		ВыходныеПараметры[3].Добавить("СлипЧек");
		ВыходныеПараметры[3].Добавить(СписокСтрокСлипЧека.СлипОтХоста);
		ВыходныеПараметры.Добавить(КодАвторизации);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
	Иначе
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерКарты);
		ВыходныеПараметры.Добавить(Ответ);
		
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
		ВыходныеПараметры.Добавить(Новый Массив());
		ВыходныеПараметры[3].Добавить("СлипЧек");
		ВыходныеПараметры[3].Добавить(СписокСтрокСлипЧека.СлипОтХоста);
		ВыходныеПараметры.Добавить(КодАвторизации);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
		
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

