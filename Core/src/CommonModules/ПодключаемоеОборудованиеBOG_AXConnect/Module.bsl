// ფუნქცია გარდაქმნის ვერსიის სტრიქონულ მნიშვნელობას რიცხვით მნიშვნელობად
// Функция преобразует строковое представление версии (с тремя точками) к числовому (пригодному для сравнения)
Функция ВерсияСтрокаВЧисло(ВерсияСтрока) 
	
	Попытка
		Версия = ВерсияСтрока;
		Результат = Число(Лев(Версия, Найти(Версия, ".")-1));
		Версия = Сред(Версия, Найти(Версия, ".") + 1);
		Результат = Результат*100 + Число(Лев(Версия, Найти(Версия, ".")-1));
		Версия = Сред(Версия, Найти(Версия, ".") + 1);
		Результат = Результат*100 + Число(Лев(Версия, Найти(Версия, ".")-1));
		Версия = Сред(Версия, Найти(Версия, ".") + 1);
		Результат = Результат*100 + Число(Версия);
	Исключение
		Возврат 0;
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ОплатитьПлатежнойКартой(Объект, TerminalID, Сумма, КодRRN, КодАвторизации,  СписокСтрокСлипЧека,КодОперации, COMПортФР, МетодОплаты = Неопределено, мRequest, мМассив, ПериодРасрочки = Неопределено, TerminalAlias, CashbackAmount, ИспользоватьTranslinkДляТерминала,Ответ) 
 
	Ответ = "";
	мRequest.OperatorID = "";
	//мRequest.ComPort = COMПортФР; 
	мRequest.OperatorName = ""; 
	мRequest.Amount = СтрЗаменить(Формат(Сумма,"ЧГ=0"),",","");
	мRequest.CurrencyCode = "981"; 
	мRequest.InstallmentPayments = ПериодРасрочки; 
	мRequest.InstallmentType = ""; 	
	впSelected = Неопределено;
	//мRequest.TerminalID = "";               	       	

	Результат = Объект.NewBonusTender(СтрокаДляТерминала(мRequest), Ответ);  	
	
	Если Результат И Сред(Ответ, 1, Найти(Ответ,";")-1) = "Select currency" Тогда 
		впМассив = ПолучитьВалютыДляВыбор(Ответ);
		впФорма = ПолучитьФорму("ОбщаяФорма.ФормаСписокОплат_AXConnect");
		
		Для Каждого Строка Из впМассив Цикл 
			НовСтрока = впФорма.ЭквайринговыхТерминалов.Добавить();	
			НовСтрока.ВидОплаты = Строка; 	
		КонецЦикла;
		
		Если МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.РасрочкаТерминала") Тогда 
			впSelected = впМассив[0];
		Иначе 
			впSelected = впФорма.ОткрытьМодально();
		КонецЕсли;
	
		мRequest.Selected = впSelected;
		Результат = Объект.Selected(СтрокаДляТерминала(мRequest), Ответ);
		
		Если впSelected = Неопределено Тогда 
			//Возврат "გადახდა შეწყვეტილია.";
			Возврат Ложь;
		КонецЕсли;

	КонецЕсли;	
	
	Если НЕ Результат Тогда          			
		
		мТипТранзакции = "Отказ";
		
		Попытка
			СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "გადახდა", мRequest, впSelected);
			Ответ = Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
	
		//Возврат "შეცდომა ("+ Ответ +").";		
		Возврат Ложь;
	Иначе 
		СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "გადახდა", мRequest, впSelected);
	КонецЕсли;
	
	

	Возврат Истина;

КонецФункции

Функция ОтменитьПлатежаПоПлатежнойКарте(Объект, TerminalID, Сумма, СуммаДляВозврата, КодRRN, КодАвторизации,  СписокСтрокСлипЧека,КодОперации, COMПортФР, МетодОплаты = Неопределено, мRequest, мМассив, НомерСсылкы = "", ВидОплатыДляВозврата, TerminalAlias, ИспользоватьTranslinkДляТерминала) 
 
	Ответ = "";
	
	мRequest.OperatorID = "";
	мRequest.OperatorName = ""; 
	мRequest.Amount = СтрЗаменить(Формат(Сумма,"ЧГ=0"),",","");
	мRequest.CurrencyCode = "981";
	мRequest.AdditionalAmount = СтрЗаменить(Формат(СуммаДляВозврата,"ЧГ=0"),",","");
	мRequest.ReferenceNumber = НомерСсылкы;
	впCOMПортФР = ?(ЗначениеЗаполнено(COMПортФР), COMПортФР, 0);
	мRequest.ComPort = впCOMПортФР;	
	мRequest.InstallmentPayments = 0; 
	мRequest.InstallmentType = "CREDIT"; 
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias;	
	КонецЕсли;

	впSelected = Неопределено;	
	
	//мRequest.OperationCode = "4";	
	
	Если МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаMR") Тогда 
		мRequest.CurrencyCode = "102"; 
		Результат = Объект.NewCreditTenderWithCurrency(СтрокаДляТерминала(мRequest), Ответ);
	ИначеЕсли МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаExpress") Тогда 
		мRequest.CurrencyCode = "EXP"; 
		Результат = Объект.NewCreditTenderWithCurrency(СтрокаДляТерминала(мRequest), Ответ);
	ИначеЕсли МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаPlus") Тогда 
		мRequest.CurrencyCode = "PLS"; 
		Результат = Объект.NewCreditTenderWithCurrency(СтрокаДляТерминала(мRequest), Ответ);
	ИначеЕсли МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаScool") Тогда 
		мRequest.CurrencyCode = "SCL"; 
		Результат = Объект.NewCreditTenderWithCurrency(СтрокаДляТерминала(мRequest), Ответ);
	Иначе
		Результат = Объект.NewCreditTenderWithCurrency(СтрокаДляТерминала(мRequest), Ответ);
	КонецЕсли;
	
	Если Результат И Сред(Ответ, 1, Найти(Ответ,";")-1) = "Select currency" Тогда 
		впМассив = ПолучитьВалютыДляВыбор(Ответ);		
		впВидОплатыПродажи = Сред(ВидОплатыДляВозврата, 1, Найти(ВидОплатыДляВозврата,"-")-2);
		
		Для Каждого Строка Из впМассив Цикл 
			
			Если Найти(Строка,впВидОплатыПродажи) <> Неопределено И Найти(Строка,впВидОплатыПродажи) > 0 Тогда  
				впSelected = Строка;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
				
		мRequest.Selected = впSelected;
		Результат = Объект.Selected(СтрокаДляТерминала(мRequest), Ответ);
		
		Если впSelected = Неопределено Тогда 
			//Возврат "დაბრუნება შეწყვეტილია.";
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;		
	
	
	
	Если НЕ Результат Тогда          			
		
		мТипТранзакции = "Отказ";
		
		Попытка
			СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "დაბრუნება", мRequest, впSelected);
			Ответ = Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
	
		//Возврат "შეცდომა ("+ Ответ +").";		
		Возврат Ложь;
	Иначе 
		СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "დაბრუნება", мRequest, впSelected);
	КонецЕсли;
			
	Возврат Истина;

КонецФункции

Функция УдалитьПлатежаПоПлатежнойКарте(Объект, СписокСтрокСлипЧека, TerminalID, OperationID, мRequest, мМассив, TerminalAlias, ИспользоватьTranslinkДляТерминала)
	
	Ответ = "";
	мRequest.OperatorID = "";
	мRequest.OperatorName = ""; 
	мRequest.OperationID = OperationID; 
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias; 
	КонецЕсли;

	Результат = Объект.NewVoid(СтрокаДляТерминала(мRequest), Ответ);
	
	Если НЕ Результат Тогда          			
		мТипТранзакции = "Отказ";
		
		Попытка
			СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "გადახდა", мRequest);
			Ответ = Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
	
		//Возврат "შეცდომა ("+ Ответ +").";	
		Возврат Ложь;
		
	иначе
		СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "დაბრუნება", мRequest);
		
		Если Не ЗначениеЗаполнено(мRequest.ReceiptData) Тогда 
			//Возврат "შეცდომა ("+"ვერ მოხერხდა ტრანზაქციის გაუქმება. Wrong card!"+").";	
			Сообщить("შეცდომა ("+"ვერ მოხერხდა ტრანზაქციის გაუქმება. Wrong card!"+").");
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Истина;
	
	
КонецФункции

Процедура ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, Операция, мRequest, ВидОплатыДляВозврата = "") 
	
	СписокСтрокСлипЧека.Вставить("Сумма",								мRequest.Amount);
	СписокСтрокСлипЧека.Вставить("ИдентификаторОперацииНаТерминале",	мRequest.CheckNumber);
	СписокСтрокСлипЧека.Вставить("ВремяОперацииНаТерминале",			мRequest.TerminalDateTime);	
	СписокСтрокСлипЧека.Вставить("ИдентификаторТерминала",				мRequest.TerminalID);
	СписокСтрокСлипЧека.Вставить("КодАвторизации",						мRequest.AuthorizationCode);
	СписокСтрокСлипЧека.Вставить("КодОтветаХоста",						мRequest.ResponseCodeHost);
	СписокСтрокСлипЧека.Вставить("НомерСсылкы",							мRequest.ReferenceNumber);
	СписокСтрокСлипЧека.Вставить("НомерКарты",							мRequest.PAN);
	СписокСтрокСлипЧека.Вставить("ОписаниеОтветаХоста",					Кодировка(мRequest.TextResponse));
	СписокСтрокСлипЧека.Вставить("Операция",							Операция);
	СписокСтрокСлипЧека.Вставить("СлипОтХоста",							Кодировка(мRequest.ReceiptData));
	СписокСтрокСлипЧека.Вставить("ВидОплатыДляВозврата",				ВидОплатыДляВозврата);
	СписокСтрокСлипЧека.Вставить("КодОперацииЭС",				        мRequest.OperationID);
	
КонецПроцедуры

