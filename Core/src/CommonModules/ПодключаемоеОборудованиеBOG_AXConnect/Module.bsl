// მოწყობილობასთან დაკავშირება
// Функция представляет реализацию операции "Подключить".
//
// Параметры
//  Модель   - <СправочникСсылка.ТорговоеОборудование>
//           - Модель подключаемого торгового оборудования.
//
//  НомерЛУ  - <Число>
//           - Номер логического устройства.
//
//  Объект   - <НеизвестныйОбъект>
//           - Выходной параметр; созданный объект драйвера.
//
// Возвращаемое значение:
//  <Строка> – Описание произошедшей ошибки или пустая строка в случае успеха.
//
Функция ПодключитьУстройство(Объект, Параметры, ПараметрыПодключения, ВыходныеПараметры) Экспорт
	
	//КассаККМ = ПараметрыПодключения.КассаККМ;
	
	COMПорт = "";
	//COMПорт	= ?(Параметры.Порт = 0, "", "COM" + Параметры.Порт);
	TerminalID	= Параметры.TerminalID;
	TerminalAlias	= Параметры.TerminalAlias;
	ИспользоватьTranslinkДляТерминала	= Параметры.ИспользоватьTranslinkДляТерминала;
	
	мRequest = ВозвратмRequest();
	мМассив = ВозвратмМассив();

	Результат = ТестУстройства(Объект, TerminalID, COMПорт, мRequest, мМассив, TerminalAlias, ИспользоватьTranslinkДляТерминала);
	
	ВыходныеПараметры = Новый Массив;                                           
	млЭС = Новый Структура;    
	
	млЭС.Вставить("Объект", 	Объект);
	млЭС.Вставить("Модель", 	""); 
	млЭС.Вставить("НомерЛУ", 	1);
	//млЭС.Вставить("порт", 		Параметры.Порт);
	млЭС.Вставить("Скорость", 	Параметры.Скорость);
	//млЭС.Вставить("КассаККМ", 	КассаККМ);
	млЭС.Вставить("TerminalID", TerminalID);
	млЭС.Вставить("TerminalAlias", TerminalAlias);
	млЭС.Вставить("ИспользоватьTranslinkДляТерминала", ИспользоватьTranslinkДляТерминала);
	
	ВыходныеПараметры.Добавить("");
	ВыходныеПараметры.Добавить(Результат);
	ВыходныеПараметры.Добавить(мRequest);
	ВыходныеПараметры.Добавить(мМассив);
	ВыходныеПараметры.Добавить(млЭС);
	
	Если Результат = "" Тогда 
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции // ОперацияПодключить()

Функция ТестУстройства(Объект,TerminalID, COMПортФР, мRequest, мМассив, TerminalAlias, ИспользоватьTranslinkДляТерминала)
	
	Ответ = "";
	мRequest.TerminalID = TerminalID;
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias;
	КонецЕсли;

	Если ЗначениеЗаполнено(COMПортФР) И ТипЗнч(COMПортФР) = Тип("Строка") Тогда 
		впCOMПортФР = Число(Прав(COMПортФР, СтрДлина(COMПортФР) - 3));
	ИначеЕсли ЗначениеЗаполнено(COMПортФР) И ТипЗнч(COMПортФР) = Тип("Число") Тогда 
		впCOMПортФР = COMПортФР;
	Иначе 
		впCOMПортФР = 0;
	КонецЕсли;
	
	мRequest.ComPort = впCOMПортФР;

	Результат = Объект.TestConnect(СтрокаДляТерминала(мRequest), Ответ);

	Если Не Результат Тогда          			
		мТипТранзакции = "Отказ";
		Возврат Ответ; 
	КонецЕсли;
		
	Возврат "";
	
	  
КонецФункции

