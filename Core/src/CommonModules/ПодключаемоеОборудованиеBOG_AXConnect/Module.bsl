Функция КраткийОтчет(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	Ответ = "";
	СписокСтрокСлипЧека = Новый Структура;
	
	//COMПортФР = Параметры.Порт;
	COMПортФР = "";
	
	мRequest = ВходныеПараметры.мRequest;
	мМассив = ВходныеПараметры.мМассив;
		
	впCOMПортФР = ?(ЗначениеЗаполнено(COMПортФР), COMПортФР, 0);
	
	мRequest.ComPort = впCOMПортФР;
		
	Ответ = "";
	мRequest.OperatorID = "";
	мRequest.OperatorName = ""; 
	
	Если Параметры.ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = Параметры.TerminalAlias; 
	КонецЕсли;
	
	Результат = ОбъектДрайвера.PrintTotals(СтрокаДляТерминала(мRequest), Ответ);
	
	
	Если НЕ Результат Тогда          			
		
		мТипТранзакции = "Отказ";
		
		Попытка
			СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(ОбъектДрайвера, СписокСтрокСлипЧека, "გადახდა", мRequest);
			Ответ = Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
		
		//Возврат "შეცდომა ("+ Ответ +").";		
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
		ВыходныеПараметры.Добавить(Ответ);

		
		Возврат Ложь;
	Иначе 
		СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(ОбъектДрайвера, СписокСтрокСлипЧека, "დაბრუნება", мRequest);
	КонецЕсли;
		
	ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);

	Возврат Истина;

КонецФункции

