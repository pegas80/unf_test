	СоответствиеКодировки.Вставить(Строка(Число("1103")),"მ");
	СоответствиеКодировки.Вставить(Строка(Число("1102")),"ნ");
	СоответствиеКодировки.Вставить(Строка(Число("1082")),"ო");
	СоответствиеКодировки.Вставить(Строка(Число("1083")),"პ");
	//СоответствиеКодировки.Вставить(""","ჟ");
	СоответствиеКодировки.Вставить(Строка(Число("1076")),"რ");
	СоответствиеКодировки.Вставить(Строка(Число("1086")),"ს");
	СоответствиеКодировки.Вставить(Строка(Число("1077")),"ტ");
	СоответствиеКодировки.Вставить(Строка(Число("1080")),"უ");
	СоответствиеКодировки.Вставить(Строка(Число("1088")),"ფ");
	СоответствиеКодировки.Вставить(Строка(Число("1071")),"ქ");
	СоответствиеКодировки.Вставить(Строка(Число("1075")),"ღ");
	СоответствиеКодировки.Вставить(Строка(Число("1079")),"ყ");
	СоответствиеКодировки.Вставить(Строка(Число("1085")),"შ");
	СоответствиеКодировки.Вставить(Строка(Число("1098")),"ჩ");
	СоответствиеКодировки.Вставить(Строка(Число("1099")),"ც");
	//СоответствиеКодировки.Вставить("ძ""," ");
	СоответствиеКодировки.Вставить(Строка(Число("1073")),"წ");
	СоответствиеКодировки.Вставить(Строка(Число("1072")),"ჭ");
	СоответствиеКодировки.Вставить(Строка(Число("1097")),"ხ");
	СоответствиеКодировки.Вставить(Строка(Число("1092")),"ჯ");
	//СоответствиеКодировки.Вставить(""","ჰ");
	
	
	НаименованиеДляДисплПок = "";	
	
	Строка = СтрЗаменить( Строка,"\r\n",Символы.ПС);
	
	Для Счт = 1 По СтрДлина(Строка) Цикл
		РусСимвол = Сред(Строка, Счт, 1);
		
		Если КодСимвола(РусСимвол)>= 1040 И КодСимвола(РусСимвол) <= 1103  Тогда 
			Символ = СоответствиеКодировки[Строка(КодСимвола(РусСимвол))];
			Если Символ = "" Тогда 
				Символ = РусСимвол;
			КонецЕсли;
		Иначе                                            
			Символ = РусСимвол;
		КонецЕсли;
		
		НаименованиеДляДисплПок = НаименованиеДляДисплПок + Символ; 
		
	КонецЦикла;
	
	
	Возврат  НаименованиеДляДисплПок;
	
КонецФункции

Процедура СтрокаОтТерминала(СтрокаОтТерминала, мRequest, мМассив)
	
	П = 0;	
	
	СохрСтрока = СтрокаОтТерминала;
	
	Пока Найти(СтрокаОтТерминала,";") И П < мМассив.Количество() Цикл 
		Инд = Найти(СтрокаОтТерминала,";");
		мRequest[мМассив[П]] = Лев(СтрокаОтТерминала,Инд-1);
		СтрокаОтТерминала = Сред(СтрокаОтТерминала,Инд+1);
		П = П +1;
	КонецЦикла;
	
	Попытка      		
		
		МассивСтрок = СтрРазделить(СохрСтрока,Символы.ПС,Истина);
		
		Для Каждого СтрокаТекста Из МассивСтрок Цикл    				
			
			СтрФрагмент = ("ბარათი:  ");	
			ИндексФрагмента = Найти(СтрокаТекста,"ბარათი: ");	
			
			Если ИндексФрагмента > 0 Тогда  					
				
				МассивСтрокаТекста = СтрРазделить(СтрокаТекста," ");
				
				Если Не ЗначениеЗаполнено(мRequest.PAN)  Тогда  
					мRequest.PAN = МассивСтрокаТекста[МассивСтрокаТекста.Количество()-1];
				КонецЕсли;
			КонецЕсли;
			
			СтрФрагмент = ("ქვითარი:  ");	
			ИндексФрагмента = Найти(СтрокаТекста,"ქვითარი: ");	
			Если ИндексФрагмента > 0 Тогда  					
				
				МассивСтрокаТекста = СтрРазделить(СтрокаТекста," ");
				
				Если Не ЗначениеЗаполнено(мRequest.CheckNumber)  Тогда  
					мRequest.CheckNumber = МассивСтрокаТекста[МассивСтрокаТекста.Количество()-1];
				КонецЕсли;
			КонецЕсли;
			
			
		КонецЦикла;    		
		
		
	Исключение
		
	КонецПопытки;
	
КонецПроцедуры

Функция СтрокаДляТерминала(мRequest)
	
	впСтрокаДлаТерминала = "";
	
	Для Каждого Эл Из мRequest Цикл 
		впСтрокаДлаТерминала = впСтрокаДлаТерминала + Эл.Значение +";";
	КонецЦикла;
	
	//впСтрокаДлаТерминала = Лев(впСтрокаДлаТерминала,СтрДлина(впСтрокаДлаТерминала)-1);
	
	Возврат впСтрокаДлаТерминала;
		
КонецФункции

