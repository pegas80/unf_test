	Параметры.Вставить("МетодОплаты"        ,МетодОплаты); 
	Параметры.Вставить("ПериодРасрочки"     ,ПериодРасрочки); 
	Параметры.Вставить("СуммаДляВозврата"   ,СуммаДляВозврата); 
	Параметры.Вставить("ВидОплатыДляВозврата"   ,ВидОплатыДляВозврата); 
	Параметры.Вставить("КодОперацииЭС"   ,КодОперацииЭС); 
	Параметры.Вставить("CashbackAmount"   ,CashbackAmount); 
	
	Для Каждого впСтрокаЭС Из глПодключаемоеОборудование.ПараметрыПодключенияПО Цикл 
		Если впСтрокаЭС.Ссылка = Идентификатор Тогда 
			Параметры.Вставить("мRequest", впСтрокаЭС.мRequest);  
			Параметры.Вставить("мМассив" , впСтрокаЭС.мМассив); 
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Параметры;
	
КонецФункции

Функция ПолучитьВалютыДляВыбор(СтрокаОтвета)
	
	впМассивВалют = Новый Массив;
	СтрокаОтвета = Сред(СтрокаОтвета,Найти(СтрокаОтвета,";")+1);
	впСтрока = СтрокаОтвета;
	
	Пока СтрокаОтвета <> "" Цикл 
		
		Если Найти(СтрокаОтвета,";") > 0 Тогда 
			впСтрока = Лев(СтрокаОтвета,Найти(СтрокаОтвета,";")-1);
			СтрокаОтвета = Сред(СтрокаОтвета,Найти(СтрокаОтвета,";")+1);
		Иначе
			впСтрока = СтрокаОтвета;
			СтрокаОтвета = "";
		КонецЕсли;
		
		Если впСтрока <> "" Тогда 
			впМассивВалют.Добавить(впСтрока);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат впМассивВалют;	
	
КонецФункции

