	КонецЕсли;
	
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ПрочиеРасчеты); // Прочие расчеты.
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Покупателю);
	
	Если ПолучитьФункциональнуюОпцию("КредитыИЗаймы") Тогда
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам); // Прочие расчеты.
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ВыдачаКредитаКонтрагенту); // Прочие расчеты
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику); // Прочие расчеты.
	КонецЕсли;
	
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Прочее); // Прочее.
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику); // Подотчетнику.
	
	Если ПолучитьФункциональнуюОпцию("ВестиУчетРасчетовСБанкомЭквайрером") Тогда
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты); // Эквайринг
	КонецЕсли;
	
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.Налоги); // Налоги.
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ПенсионномуФонду, НСТР("ka='საპენსიო ფონდში';ru='Пенсионному фонду';en='pension Fund'")); // Паганини ПФ
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.СнятиеНаличных);
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходСоСчета.ПереводНаДругойСчет);
	
	Возврат СписокОпераций;
	
КонецФункции

Функция ПолучитьСписокВидовОперацийРасходДСКасса() Экспорт
	
	СписокОпераций = Новый СписокЗначений();
	
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.Поставщику, "Поставщику");
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.НаРасходы, "На расходы");
	// Зарплата по ведомости
	Если Константы.ФункциональнаяОпцияИспользоватьПодсистемуЗарплата.Получить() Тогда
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.Зарплата, "Зарплата по ведомости");
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.ЗарплатаСотруднику, "Зарплата сотруднику");
	КонецЕсли;
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.ПрочиеРасчеты, "Прочему контрагенту (учредителю)"); // Прочие расчеты.
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.Покупателю, "Покупателю (возврат)");
	Если ПолучитьФункциональнуюОпцию("КредитыИЗаймы") Тогда
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.РасчетыПоКредитам, "Возврат кредита"); // Прочие расчеты.
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.ВыдачаЗаймаСотруднику); // Прочие расчеты.
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.ВыдачаКредитаКонтрагенту); // Прочие расчеты.
	КонецЕсли;
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.Прочее, "Прочий расход"); // Прочее.
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.Подотчетнику); // Подотчетнику.
	Если Константы.ФункциональнаяОпцияУчетРозничныхПродаж.Получить() Тогда
		СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.ПеремещениеВКассуККМ); // Эквайринг
	КонецЕсли;
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.Налоги, "Налоги"); // Налоги.
	СписокОпераций.Добавить(Перечисления.ВидыОперацийРасходИзКассы.ВзносНаличнымиВБанк, "Наличные в банк"); // Наличные в банк.
	
	Возврат СписокОпераций;
	
КонецФункции

#КонецОбласти

#Область ХозяйственныеОперацииПоступленияИСписания

Функция ПолучитьСписокХозОперацийПоступленияДС() Экспорт
	
	СписокОпераций = Новый СписокЗначений();
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ОтПокупателя, НСтр("ka='მყიდველისგან';ru='От покупателя';en=''"));
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Прочее, НСтр("ka='სხვა შემოსვლა';ru='Прочее поступление';en=''")); // Прочее.
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ОтПоставщика, НСтр("ka='მომწოდებლისგან (დაბრუნება)';ru='От поставщика (возврат)';en=''"));
	
	Если ПолучитьФункциональнуюОпцию("КредитыИЗаймы") Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.РасчетыПоКредитам, НСтр("ka='კრედიტის მიღება';ru='Расчеты по кредитам';en=''")); // Прочие расчеты.
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ВозвратЗаймаСотрудником, НСтр("ka='თანამშრომლის მიერ სესხის დაფარვა';ru='Возврат займа сотрудником';en=''")); // Прочие расчеты.
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("УчетВалютныхОпераций") Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ПокупкаВалюты, НСтр("ka='ვალუტის ყიდვა';ru='Покупка валюты';en=''"));
	КонецЕсли;
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ПрочиеРасчеты, НСтр("ka='სხვა ხარჯები';ru='Прочие расчеты';en=''")); // Прочие расчеты.
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ОтПодотчетника, НСтр("ka='საქვეანგარიშო პირისგან';ru='От подотчетника';en=''"));
	
	Если ПолучитьФункциональнуюОпцию("ВестиУчетРасчетовСБанкомЭквайрером") Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ПоступлениеОплатыПоКартам, НСтр("ka='ექვაირერის ანგარიშგება';ru='Эквайринг';en=''")); // Эквайринг
	КонецЕсли;
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Налоги, НСтр("ka='გადასახადები';ru='Налоги';en=''"));
	
	Если ПолучитьФункциональнуюОпцию("УчетРозничныхПродаж") Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.РозничнаяВыручка, НСтр("ka='საცალო გაყიდვიდან მიღებული შემოსავალი';ru='Розничная выручка';en=''"));
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.РозничнаяВыручкаСуммовойУчет, НСтр("ka='საცალო გაყიდვიდან მიღებული შემოსავალი (თანხობრივი აღრიცხვა)';ru='Розничная вырчка (суммовой учет)';en=''"));
	КонецЕсли;
	
	Возврат СписокОпераций;
	
КонецФункции

Функция ПолучитьСписокХОзОперацийРасходДС() Экспорт
	
	СписокОпераций = Новый СписокЗначений();
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Поставщику,НСтр("ka='მომწოდებელს';ru='Поставщику';en=''") );
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.НаРасходы,НСтр("ka='დასახარჯად';ru='На расходы';en=''") );
	
	// Зарплата по ведомости
	Если Константы.ФункциональнаяОпцияИспользоватьПодсистемуЗарплата.Получить() Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Зарплата,НСтр("ka='ხელფასი უწყისის მიხედვით';ru='Зарплата по ведомости';en=''") );
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ЗарплатаСотруднику,НСтр("ka='ხელფასი';ru='Зарплата сотруднику';en=''") );
	КонецЕсли;
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ПрочиеРасчеты, НСтр("ka='სხვა კონტრაგენტს (დამფუძნებელს)';ru='Прочие расчеты';en=''") ); // Прочие расчеты.
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Покупателю, НСтр("ka='მყიდველს (დაბრუნება)';ru='Покупателю (возврат)';en=''"));
	
	Если ПолучитьФункциональнуюОпцию("КредитыИЗаймы") Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.РасчетыПоКредитам, НСтр("ka='კრედიტის დაბრუნება';ru='Расчеты по кредитам';en=''")); // Прочие расчеты.
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ВыдачаЗаймаСотруднику, НСтр("ka='თანამშრომლისთვის სესხის გაცემა';ru='Выдача займа сотруднику';en=''")); // Прочие расчеты.
	КонецЕсли;
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Прочее, НСтр("ka='სხვა ხარჯები';ru='Прочий расход';en=''")); // Прочее.
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Подотчетнику, НСтр("ka='ანგარიშვალდებულ პირს';ru='Подотчетнику';en=''")); // Подотчетнику.
	
	Если ПолучитьФункциональнуюОпцию("ВестиУчетРасчетовСБанкомЭквайрером") Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ВозвратОплатыНаПлатежныеКарты, НСтр("ka='ექვაირერის ანგარიშგება';ru='Отчет эквайрера';en=''")); // Эквайринг
	КонецЕсли;
	
	СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.Налоги, НСтр("ka='გადასახადები';ru='Налоги';en=''")); // Налоги.
	
	Если Константы.ФункциональнаяОпцияУчетРозничныхПродаж.Получить() Тогда
		СписокОпераций.Добавить(Справочники.ХозяйственныеОперации.ПеремещениеВКассуККМ, НСтр("ka='ანგარიშიდან სალაროში';ru='Перемещение в кассу ККМ';en=''"));
	КонецЕсли;
	
	Возврат СписокОпераций;
	
КонецФункции

Функция ПолучитьСписокХОзОперацийПеремещениеДС() Экспорт
	
	СписокОпераций = Новый СписокЗначений();

	СписокОпераций.Добавить(Перечисления.ВидыОперацийПеремещенияДС.КассаБанк);
    СписокОпераций.Добавить(Перечисления.ВидыОперацийПеремещенияДС.БанкКасса);
	СписокОпераций.Добавить(Перечисления.ВидыОперацийПеремещенияДС.БанкБанк);
	СписокОпераций.Добавить(Перечисления.ВидыОперацийПеремещенияДС.КассаКасса);

	Возврат СписокОпераций;
	
КонецФункции


Функция ПолучитьЧистуюТаблицуИтоговДляЖурналаДокументов() Экспорт

	ТаблицаИтогов = Новый ТаблицаЗначений;
	ТаблицаИтогов.Колонки.Добавить("Показатель");
	ТаблицаИтогов.Колонки.Добавить("Значение");
	
	// Начальный остаток
	СтрокаИтогов = ТаблицаИтогов.Добавить();
	СтрокаИтогов.Показатель =  НСтр("ka='დღის დასაწყისი';ru='Начало дня';en='Beginning of the day'");
	СтрокаИтогов.Значение = 0;
	
	// Начальный остаток
	СтрокаИтогов = ТаблицаИтогов.Добавить();
	СтрокаИтогов.Показатель =  НСтр("ka='შემოსავალი';ru='Поступило';en='coming'");
	СтрокаИтогов.Значение = 0;
	
	// Начальный остаток
	СтрокаИтогов = ТаблицаИтогов.Добавить();
	СтрокаИтогов.Показатель =  НСтр("ka='გასავალი';ru='Списано';en='consumption'");
	СтрокаИтогов.Значение = 0;
	
	// Начальный остаток
	СтрокаИтогов = ТаблицаИтогов.Добавить();
	СтрокаИтогов.Показатель =  НСтр("ka='დღის დასასრული';ru='Конец дня';en='End of the day'");
	СтрокаИтогов.Значение = 0;
	
	Возврат ТаблицаИтогов;
	
КонецФункции	

