			ЭлНакладная.ГрузоПолучатель 		= ?(ЭтаДистрибуция Или ИспользоватьАдресИзДоговораДляТТН, АдресПоДоговору,АдресКонтрагента);
			ЭлНакладная.АдресДоставки 			= Договор.Адрес;	
			ЭлНакладная.Водитель			 	= Договор.Водитель;
			ЭлНакладная.НомерУдостоверения   	= Договор.Водитель.ИНН;
			
			ЭлНакладная.Товары.Загрузить(ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицуРеализации(МассивДокументовОснования));
		Иначе
			ЭлНакладная.ТипТН 					= Перечисления.РС_ТипыТН.ВозвратОтПокупателя;
			ЭлНакладная.ГрузоОтправитель 		= ДокументТТН.Контрагент;
			ЭлНакладная.АдресОтправки	 		= ?(ЭтаДистрибуция Или ИспользоватьАдресИзДоговораДляТТН, АдресПоДоговору,АдресКонтрагента);
			ЭлНакладная.Грузополучатель			= ДокументТТН.Организация;			
			ЭлНакладная.АдресДоставки   		= УправлениеНебольшойФирмойСервер.ПолучитьКонтактнуюИнформацию(ДокументВизита.СтруктурнаяЕдиница, Справочники.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы);			
			ЭлНакладная.Водитель			 	= Договор.Водитель;
			ЭлНакладная.НомерУдостоверения   	= Договор.Водитель.ИНН;
			
			//ПМ++ Глухов 11.04.21
			ЗаполнитьВодителяИТранспортноеСредствоПриВозврате(ДокументВизита, ЭлНакладная, ЭлНакладная.ГрузоОтправитель);
			//ПМ--
			
			ЭлНакладная.Товары.Загрузить(ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицуВозврата(МассивДокументовОснования));
		КонецЕсли;
		
		Организация_СоответствиеНоменклатур = ДокументТТН.Организация.СоответствиеНоменклатур;
		ЭлНакладная.ТоварыЭлНакладных.Очистить();
		
		//СформироватьТаблицуЭлНакладных
		Для каждого СтрТаб Из ЭлНакладная.Товары  Цикл
			СтрЭлНТаб = ЭлНакладная.ТоварыЭлНакладных.Добавить();
			Если Не ЗначениеЗаполнено(СтрТаб.Номенклатура) Тогда 
				Продолжить;
			КонецЕсли;
			СтрЭлНТаб.ID       = 0;//СтрТаб.НомерСтроки-1 Паганини
			СтрЭлНТаб.W_NAME   = РС_ОбщегоНазначения.ПредставлениеНоменклатуры(СтрТаб.Номенклатура,СтрТаб.Характеристика,СтрТаб.Партия);
			СтрЭлНТаб.UNIT_ID  = СтрТаб.ЕдиницаИзмерения.КодДляНалоговой;
			СтрЭлНТаб.UNIT_TXT = СтрТаб.ЕдиницаИзмерения.Наименование;
			СтрЭлНТаб.QUANTITY = СтрТаб.Количество;
			СтрЭлНТаб.PRICE	   = СтрТаб.Цена;
			СтрЭлНТаб.STATUS   = "1";
			СтрЭлНТаб.AMOUNT   = СтрТаб.Сумма;
			Если Организация_СоответствиеНоменклатур = Перечисления.СоответствияНоменклатуры.ПоАртикулу Тогда 
				СтрЭлНТаб.BAR_CODE = СтрТаб.Номенклатура.Артикул;
			ИначеЕсли Организация_СоответствиеНоменклатур = Перечисления.СоответствияНоменклатуры.ПоШтрихкоду Тогда 
				СтрЭлНТаб.BAR_CODE = СтрТаб.Номенклатура.ОсновнойШтрихКод;
			ИначеЕсли Организация_СоответствиеНоменклатур = Перечисления.СоответствияНоменклатуры.ПоХарактеристике Тогда
				СтрЭлНТаб.BAR_CODE = ПолучитьКодХарактеристики(СтрТаб);	
			Иначе
				СтрЭлНТаб.BAR_CODE = СтрТаб.Номенклатура.Код;
			КонецЕсли;
			СтрЭлНТаб.A_ID     = 0;//Акциз
			Если СтрТаб.СтавкаНДС.НеОблагается Тогда
				СтрЭлНТаб.VAT_TYPE = 2;
			ИначеЕсли СтрТаб.СтавкаНДС.Ставка = 0 Тогда
				СтрЭлНТаб.VAT_TYPE = 1;
			ИначеЕсли СтрТаб.СтавкаНДС.Ставка = 18 Тогда
				СтрЭлНТаб.VAT_TYPE = 0;
			КонецЕсли;
			СтрЭлНТаб.QUANTITY_EXT =  СтрТаб.Количество;
		КонецЦикла;
		
		//СформироватьТаблицуШапкаRS
		TRANS_ID = 0;
		TRANS_TXT = "";
		документы.РС_ЭлектроннаяНакладная.ПолучитьВидТранспортировкиЭл(ЭлНакладная.ТипТН, ЭлНакладная.ВидТранспортировки, "", "", TRANS_ID, TRANS_TXT);
		СтатусыОперацииТН = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьСтатусОперацииТН();
		
		СтрукПар = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИнициализацияОтправкиТН(Новый Структура, ЭлНакладная.Организация);
		Если ТипЗнч(СтрукПар) = Тип("Строка") Тогда 
			Возврат СтрукПар;
		КонецЕсли;
		seller_un_id 	= СтрукПар.un_id;
		
		ЭлНакладная.ШапкаRS.Очистить();

		//ID
		СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
		СтрШапкаRS.ИмяПараметраRS = "ID"; 
		СтрШапкаRS.ЗначениеПараметраRS = ЭлНакладная.ID_ТН; 
		
		//STATUS
		СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
		СтрШапкаRS.ИмяПараметраRS = "STATUS"; 
		СтрШапкаRS.ЗначениеПараметраRS =?(ЗначениеЗаполнено(ЭлНакладная.СтатусТН),СтатусыОперацииТН[ЭлНакладная.СтатусТН],0); 

		//TYPE
		СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
		СтрШапкаRS.ИмяПараметраRS = "TYPE"; 
		СтрШапкаRS.ЗначениеПараметраRS = документы.РС_ЭлектроннаяНакладная.ОпределитьТипТН(ЭлНакладная.ТипТН); 
		
		//ACTIVATE_DATE
		СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
		СтрШапкаRS.ИмяПараметраRS = "ACTIVATE_DATE"; 
		СтрШапкаRS.ЗначениеПараметраRS = ЭлНакладная.ДатаНачалаТранспортировки; 
		
		//BUYER
		Если ЭлНакладная.ТипТН =  Перечисления.РС_ТипыТН.ВозвратОтПокупателя Тогда 
			ГрузоОтправитель = ЭлНакладная.ГрузоОтправитель;
			//BUYER_TIN
			СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
			СтрШапкаRS.ИмяПараметраRS = "BUYER_TIN"; 
			СтрШапкаRS.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(ГрузоОтправитель), СокрЛП(ГрузоОтправитель.ИНН), ""); 
			
			//CHEK_BUYER_TIN
			СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
			СтрШапкаRS.ИмяПараметраRS = "CHEK_BUYER_TIN"; 
			СтрШапкаRS.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(ГрузоОтправитель), ?(ГрузоОтправитель.ЯвляетсяНеРезидентом,0,1), 0); 
			//BUYER_NAME
			СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
			СтрШапкаRS.ИмяПараметраRS = "BUYER_NAME"; 
			СтрШапкаRS.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(ГрузоОтправитель), ГрузоОтправитель.Наименование, ""); 
		Иначе 
			Грузополучатель = ЭлНакладная.Грузополучатель;
			//BUYER_TIN
			СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
			СтрШапкаRS.ИмяПараметраRS = "BUYER_TIN"; 
			СтрШапкаRS.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(Грузополучатель), СокрЛП(Грузополучатель.ИНН), ""); 
			
			//CHEK_BUYER_TIN
			СтрШапкаRS = ЭлНакладная.ШапкаRS.Добавить();
			СтрШапкаRS.ИмяПараметраRS = "CHEK_BUYER_TIN"; 
			СтрШапкаRS.ЗначениеПараметраRS = ?(ЗначениеЗаполнено(Грузополучатель), ?(Грузополучатель.ЯвляетсяНеРезидентом,0,1), 0); 
			//BUYER_NAME
