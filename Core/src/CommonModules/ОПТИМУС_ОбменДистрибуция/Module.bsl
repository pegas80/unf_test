		ЭлНакладная.Записать();
		
		
		Возврат "";
	Исключение
		Возврат НСтр("ka='რეგისტრის განახლების შეცდომა სატრანსპორტო-სასაქონლო ზედნადებები გამოწერილი';ru='Ошибка обновления регистра ТТНВыписанные';en='Error updating register TTNVypisannye'")
	КонецПопытки;
	
