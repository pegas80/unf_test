Функция ПолучитьРезультатОтчета(УзелОбмена, ИмяОтчета, ВариантОтчета, Знач ДатаНачала, Знач ДатаОкончания, ДанныеОбмена) Экспорт
	
	ЗначениеДляВозврата = СоздатьОбъект("DataWithAnswer");
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ДанныеОбмена.Получить());
	
	ТипОбъектаXDTO = ФабрикаXDTO.Тип("http://www.optimus.ge/SB/DistributionExchange", "Objects");
	
	Объекты = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
	
	//ЗагрузитьОбъекты(УзелОбмена, Объекты);
	ЧтениеXML.Закрыть();
	Попытка
	  Если Объекты.objects.Количество()>0 Тогда
			Идентификатор = Новый УникальныйИдентификатор(Объекты.objects[0].id);
			Договор = Справочники.ДоговорыКонтрагентов.ПолучитьСсылку(Идентификатор);
		Иначе
			Договор=Неопределено;
		КонецЕсли; 
		ДатаНачала=XMLЗначение(Тип("Дата"),ДатаНачала);
		ДатаОкончания=XMLЗначение(Тип("Дата"),ДатаОкончания);	
		
		от=Отчеты[ИмяОтчета].Создать();
		
		ПараметрыОтчета=Новый Структура("ВариантОтчета,ДатаНачала,ДатаОкончания,Договор,ТорговыйПредставитель",ВариантОтчета,ДатаНачала,ДатаОкончания,Договор,ПолучитьТорговогоПредставительяИзУзлаОбмена(УзелОбмена));
		ТабДок=от.ПолучитьРезультат(ПараметрыОтчета);
		
		Если ТипЗнч(ТабДок)=Тип("ТабличныйДокумент") Тогда
			ПутьФайлаСервер = ПолучитьИмяВременногоФайла("MXL");
			ТабДок.Записать(ПутьФайлаСервер, ТипФайлаТабличногоДокумента.MXL);
			ДДФайла = Новый ДвоичныеДанные(ПутьФайлаСервер);
			ЗначениеДляВозврата.Data = Новый ХранилищеЗначения(ДДФайла, Новый СжатиеДанных(9));
		Иначе
			ЗначениеДляВозврата.Answer=ТабДок;
		КонецЕсли; 
	Исключение
	  ЗначениеДляВозврата.Answer=ОписаниеОшибки();
		Возврат ЗначениеДляВозврата;
	КонецПопытки;
	
	Попытка
		УдалитьФайлы(ПутьФайлаСервер);
	Исключение
	КонецПопытки;
	
		
	Возврат ЗначениеДляВозврата;
КонецФункции

Функция ПолучитьТорговогоПредставительяИзУзлаОбмена(УзелОбмена) Экспорт
	СтруктураОтбора = УзелОбмена.ХранилищеОтбораСхемыОбмена.Получить();
	СтруктураОтвета=Новый Структура("ВидСравнения,ПравоеЗначение",СтруктураОтбора.ТорговыйПредставитель.ВидСравнения,СтруктураОтбора.ТорговыйПредставитель.ПравоеЗначение);
	Возврат СтруктураОтвета;
КонецФункции // ПолучитьТорговогоПредставительяИзУзлаОбмена()
 
Функция УстановитьПараметрыОтчета(КомпоновщикНастроек, ПараметрыОтчета) Экспорт
	Если ПараметрыОтчета.Свойство("Договор") И ЗначениеЗаполнено(ПараметрыОтчета.Договор) Тогда
		Для каждого стр Из КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
			Если стр.ЛевоеЗначение=Новый ПолеКомпоновкиДанных("Договор") Тогда
				стр.ПравоеЗначение=ПараметрыОтчета.Договор;
				стр.Использование=Истина;
				Прервать;
			КонецЕсли; 
		КонецЦикла;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ТорговыйПредставитель") И ЗначениеЗаполнено(ПараметрыОтчета.ТорговыйПредставитель) Тогда
		Для каждого стр Из КомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
			Если стр.ЛевоеЗначение=Новый ПолеКомпоновкиДанных("Договор.ТорговыйПредставитель") Тогда				
				стр.ВидСравнения=ПараметрыОтчета.ТорговыйПредставитель.ВидСравнения;
				стр.ПравоеЗначение=ПараметрыОтчета.ТорговыйПредставитель.ПравоеЗначение;
				стр.Использование=Истина;
				Прервать;
			КонецЕсли; 
		КонецЦикла;
	КонецЕсли;
	
	НастройкиКомпоновки = КомпоновщикНастроек.ПолучитьНастройки();
	
	Параметр = НастройкиКомпоновки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("СтПериод"));
	Если Параметр <> Неопределено Тогда
	  Параметр.Значение.ДатаНачала=ПараметрыОтчета.ДатаНачала;
		Параметр.Значение.ДатаОкончания=ПараметрыОтчета.ДатаОкончания;
	  Параметр.Использование = Истина;
	КонецЕсли;
	Возврат НастройкиКомпоновки;
КонецФункции
 

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ РЕГИСТРАЦИИ ДЛЯ ОБМЕНА

// Регистрация изменений справочника для обмена
//
Процедура ОПТИМУС_ЗарегистрироватьИзмененияСправочникаДляОбменаОПТИМУС_ДистрибуцияПередЗаписью(Источник, Отказ) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ОПТИМУС_Дистрибуция") Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Источник.ЭтоНовый() Тогда
		Источник.ДополнительныеСвойства.Вставить("ТребуетсяПроверитьРегистрацию", Истина);
	Иначе	
		Источник.ДополнительныеСвойства.Вставить("ВозможноУдалениеРегистрацииИзменений", Истина);
		ВыборочнаяРегистрацияОбъекта(Источник, Отказ, "ОПТИМУС_Дистрибуция");
	КонецЕсли;

КонецПроцедуры

