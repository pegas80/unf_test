//Процедура записывает остатки
//
Процедура ЗаписатьОстатки(ВозвращаемыйСписок, УзелОбмена, НужныеНоменклатуры, НужныеСклады) Экспорт
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ЗапасыОстатки.Номенклатура,
		|	ЗапасыОстатки.КоличествоОстаток
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(
		|			,
		|			СтруктурнаяЕдиница В (&СтруктурнаяЕдиница)
		|				И ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
		|				И Номенклатура В (&НужныеНоменклатуры)) КАК ЗапасыОстатки"
	);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", НужныеСклады);
	Запрос.УстановитьПараметр("НужныеНоменклатуры", НужныеНоменклатуры);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПередаваемыйОбъект = СоздатьОбъект("Remains");

	Пока Выборка.Следующий() Цикл
		ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
		ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
		Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
			ДобавляемаяСтрока.Nomenclature = ПолучитьОбъектXDTO(Выборка.Номенклатура.ПолучитьОбъект());
		Конецесли;
		ДобавляемаяСтрока.Quantity = Выборка.КоличествоОстаток;
		ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
	КонецЦикла;
	
	ВозвращаемыйСписок.objects.Добавить(ПередаваемыйОбъект);
	
КонецПроцедуры

//Процедура записывает расчеты с покупателями
//
Процедура ЗаписатьРасчетыСПокупателями(ВозвращаемыйСписок, УзелОбмена, НужныеКонтрагенты, НужныеДоговоры) Экспорт
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	РасчетыСПокупателямиОстатки.Контрагент,
		|	ВЫБОР
		|		КОГДА НЕ РасчетыСПокупателямиОстатки.Документ ЕСТЬ NULL 
		|			ТОГДА РасчетыСПокупателямиОстатки.Документ.Дата
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК Дата,
		|	РасчетыСПокупателямиОстатки.СуммаОстаток КАК Сумма,
		|	ВЫБОР
		|		КОГДА НЕ РасчетыСПокупателямиОстатки.Документ ЕСТЬ NULL 
		|			ТОГДА РасчетыСПокупателямиОстатки.Документ.Номер
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК Номер,
		|	РасчетыСПокупателямиОстатки.Договор
		|ИЗ
		|	РегистрНакопления.РасчетыСПокупателями.Остатки(
		|			,
		|			Контрагент В (&НужныеКонтрагенты)
		|				И Договор В (&НужныеДоговоры)) КАК РасчетыСПокупателямиОстатки"
	);
	
	Запрос.УстановитьПараметр("НужныеКонтрагенты", НужныеКонтрагенты);
	Запрос.УстановитьПараметр("НужныеДоговоры", НужныеДоговоры);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПередаваемыйОбъект = СоздатьОбъект("Payable");

	Пока Выборка.Следующий() Цикл
		ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
		ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
		Если ЗначениеЗаполнено(Выборка.Контрагент) Тогда
			ДобавляемаяСтрока.Contactor = ПолучитьОбъектXDTO(Выборка.Контрагент.ПолучитьОбъект());
		Конецесли;
		Если ЗначениеЗаполнено(Выборка.Договор) Тогда
			ДобавляемаяСтрока.Contract = ПолучитьОбъектXDTO(Выборка.Договор.ПолучитьОбъект());
		Конецесли;
		ДобавляемаяСтрока.Total = Выборка.Сумма;
		ДобавляемаяСтрока.Document = Формат(Выборка.Дата, "ДФ=yyyy-MM-dd") + "   " + Строка(Выборка.Номер);
		ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
	КонецЦикла;
	
	ВозвращаемыйСписок.objects.Добавить(ПередаваемыйОбъект);
	
КонецПроцедуры

// Процедура записывает префикс
//
Процедура ЗаписатьПрефикс(ВозвращаемыйСписок, УзелОбмена) Экспорт
	
	Префикс = СоздатьОбъект("ObjPrefix");
	Префикс.Prefix = УзелОбмена.ПрефиксДокументов;
	
	ВозвращаемыйСписок.objects.Добавить(Префикс);
	
КонецПроцедуры

// Процедура записывает константы
//
Процедура ЗаписатьКонстанты(ВозвращаемыйСписок, УзелОбмена) Экспорт
	
	КонстантыДляОтправления = СоздатьОбъект("ObjConstants");
	КонстантыДляОтправления.UseRealisationAndReturn  = УзелОбмена.ИспользоватьРеализациюИВозвратПриВизите;
	КонстантыДляОтправления.UseOrderAndOrderOnReturn = УзелОбмена.ИспользоватьЗаказИЗаказНаВозвратПриВизите;
	КонстантыДляОтправления.ShowRemains    = УзелОбмена.ПоказыватьОстаткиВПодборе;
	КонстантыДляОтправления.ChangePrices   = УзелОбмена.РедактироватьЦены;
	КонстантыДляОтправления.UseDiscounts   = УзелОбмена.ИспользоватьСкидки;
	КонстантыДляОтправления.ControlRemains = УзелОбмена.КонтролироватьОстаткиПриПроведении;
	КонстантыДляОтправления.Cash		   = ПолучитьОстатокКасси(УзелОбмена.Касса);
	

	ВозвращаемыйСписок.objects.Добавить(КонстантыДляОтправления);
	
КонецПроцедуры

Функция ПолучитьНужныеНоменклатуры(УзелОбмена)
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ПометкаУдаления = ЛОЖЬ";

    Выгрузка = Запрос.Выполнить().Выгрузить();
		
	СтруктураОписанияОбъекта = ПолучитьСтруктуруОписанияОбъекта(Метаданные.Справочники.Номенклатура, Ложь);
	
	НужныеНоменклатуры = ОбъектПодлежитРегистрацииВУзле(Выгрузка[0].Ссылка.ПолучитьОбъект(), СтруктураОписанияОбъекта, УзелОбмена, Выгрузка).ВыгрузитьКолонку("Ссылка");
	
	Возврат НужныеНоменклатуры;
	
КонецФункции

