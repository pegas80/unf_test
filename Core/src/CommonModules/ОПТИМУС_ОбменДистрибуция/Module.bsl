Функция ОперацияНапечататьТТН(УзелОбмена, ДанныеОбмена, ЭтоВозврат) Экспорт
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ДанныеОбмена.Получить());
	
	ТипОбъектаXDTO = ФабрикаXDTO.Тип("http://www.optimus.ge/SB/DistributionExchange", "Objects");
	
	Объекты = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
	
	ЗагрузитьОбъекты(УзелОбмена, Объекты);
	ЧтениеXML.Закрыть();
	
	Идентификатор = Новый УникальныйИдентификатор(Объекты.objects[0].id);
	ДокументСсылка = Документы.Визит.ПолучитьСсылку(Идентификатор);
	
	Возврат ВыполнитьОперациюНапечататьТТН(ДокументСсылка, ЭтоВозврат);
	
КонецФункции

