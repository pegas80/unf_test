// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ ВЫГРУЗКИ

// Функция выполняет проверку того, что данные нужно переносить в данный узел
//
// Параметры:
//  Данные	– Объект, набор записей,... который нужно проверить.
//			То, что переносится везде, не обрабатывается
//  УзелОбмена - узел плана обмена, куда осуществляется перенос
//
// Возвращаемое значение:
//  Перенос - булево, если Истина - необходимо выполнять перенос, 
//			  иначе - перенос выполнять не нужно
//
Функция НуженПереносДанных(Данные, УзелОбмена, НужныеКонтрагенты,НужныеДоговоры) Экспорт
	
	Перенос = Истина;
	
	Если Не ТипЗнч(Данные) = Тип("СправочникСсылка.Номенклатура") И
		 Не ТипЗнч(Данные) = Тип("СправочникОбъект.Номенклатура") И
		 Не ТипЗнч(Данные) = Тип("СправочникСсылка.ВидыЦен") И
		 Не ТипЗнч(Данные) = Тип("СправочникОбъект.ВидыЦен") И
		 Не ТипЗнч(Данные) = Тип("СправочникСсылка.Контрагенты") И
		 Не ТипЗнч(Данные) = Тип("СправочникОбъект.Контрагенты") И
		 Не ТипЗнч(Данные) = Тип("СправочникСсылка.ДоговорыКонтрагентов") И
		 Не ТипЗнч(Данные) = Тип("СправочникОбъект.ДоговорыКонтрагентов") И
		 Не ТипЗнч(Данные) = Тип("РегистрСведенийНаборЗаписей.ЦеныНоменклатуры") Тогда
		Перенос = Ложь;
	КонецЕсли;
	
	
	Если (ТипЗнч(Данные) = Тип("СправочникСсылка.ВидыЦен") Или
		  ТипЗнч(Данные) = Тип("СправочникОбъект.ВидыЦен")) И
		 Не Данные.ЦенаВключаетНДС Тогда
		Перенос = Ложь;
	КонецЕсли;
	
	
	Если ТипЗнч(Данные) = Тип("СправочникСсылка.Контрагенты") Или
		 ТипЗнч(Данные) = Тип("СправочникОбъект.Контрагенты") Тогда
		Если НужныеКонтрагенты.Найти(Данные.Ссылка) = Неопределено Тогда
			Перенос = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Данные) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Или
		 ТипЗнч(Данные) = Тип("СправочникОбъект.ДоговорыКонтрагентов") Тогда
		Если НужныеДоговоры.Найти(Данные.Ссылка) = Неопределено Тогда
			Перенос = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	
	Возврат Перенос;
	
КонецФункции // НуженПереносДанных()

// Процедура записывает данные в формат XML
// Процедура анализирует переданный объект данных и на основе этого анализа
// записывает его определенным образом в формат XML
//
// Параметры:
//  ЗаписьXML	- объект, записывающий XML данные
//  Данные 		- данные, подлежащие записи в формат XML
//
Процедура ЗаписатьДанные(ВозвращаемыйСписок, Данные, НужныеНоменклатуры) Экспорт
	
	ОбъектXDTO = ПолучитьОбъектXDTO(Данные, НужныеНоменклатуры);
	Если ОбъектXDTO <> Неопределено Тогда
		ВозвращаемыйСписок.objects.Добавить(ОбъектXDTO);
	КонецЕсли;
	
КонецПроцедуры // ЗаписатьДанные()

// Получает объект XDTO из переданного объекта конфигурации.
//
Функция ПолучитьОбъектXDTO(Данные, НужныеНоменклатуры = Неопределено)
	
	ПередаваемыйОбъект = Неопределено;
	
	Если ТипЗнч(Данные) = Тип("СправочникОбъект.Номенклатура")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.Номенклатура") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatItems");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;

		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group = ПолучитьОбъектXDTO(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
			ПередаваемыйОбъект.Disabled = Данные.Неактивен;
		КонецЕсли;
		ПередаваемыйОбъект.Article = Данные.Артикул;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ВидыЦен")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.ВидыЦен") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatPriceTypes");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group = ПолучитьОбъектXDTO(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.Контрагенты")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatContactors");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group = ПолучитьОбъектXDTO(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
		КонецЕсли;
		
		ПередаваемыйОбъект.INN = Строка(Данные.Ссылка.ИНН);
		
		ПередаваемыйОбъект.Tel = "";
		Для Каждого ТекСтрока Из Данные.КонтактнаяИнформация Цикл
			Если ТекСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				ПередаваемыйОбъект.Tel = ТекСтрока.Представление;
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ДоговорыКонтрагентов")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatContracts");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		ПередаваемыйОбъект.Blocked = Данные.Заблокировано;
		ПередаваемыйОбъект.Disabled = Данные.Неактивен;
		ПередаваемыйОбъект.Limit = Данные.Ссылка.Лимит;
		
		Если ЗначениеЗаполнено(Данные.Владелец) Тогда
			ПередаваемыйОбъект.Owner = ПолучитьОбъектXDTO(Данные.Владелец);
		Конецесли;
		Если ЗначениеЗаполнено(Данные.ВидЦен) Тогда
			ПередаваемыйОбъект.PriceType = ПолучитьОбъектXDTO(Данные.ВидЦен);
		Конецесли;
		
		Строка = "";		
		Для Каждого СтрокаТаблицы Из Данные.ГрафикПосещения Цикл
			Если СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Понедельник Тогда
				Строка = Строка + "1";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Вторник Тогда
				Строка = Строка + "2";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Среда Тогда
				Строка = Строка + "3";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Четверг Тогда
				Строка = Строка + "4";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Пятница Тогда
				Строка = Строка + "5";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Суббота Тогда
				Строка = Строка + "6";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Воскресенье Тогда
				Строка = Строка + "7";
			КонецЕсли
		КонецЦикла;
		ПередаваемыйОбъект.Schedule = Строка;
		
		
		//ВидыЦен  CatPriceTypes
		Если ЗначениеЗаполнено(Данные.ВидЦен) Тогда
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatPriceTypes").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			ДобавляемаяСтрока.CatPriceType = ПолучитьОбъектXDTO(Данные.ВидЦен);
			ПередаваемыйОбъект.CatPriceTypes.Добавить(ДобавляемаяСтрока);
		Конецесли;
		
		Для Каждого  СтрокаТаблицы Из Данные.ВидыЦен Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatPriceTypes").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			Если ЗначениеЗаполнено(СтрокаТаблицы.ВидЦен) Тогда
				ДобавляемаяСтрока.CatPriceType = ПолучитьОбъектXDTO(СтрокаТаблицы.ВидЦен);
				ПередаваемыйОбъект.CatPriceTypes.Добавить(ДобавляемаяСтрока);
			Конецесли;
		КонецЦикла;
		//ВидыЦен CatPriceTypes
		
		//ВидыСкидокНаценок CatDiscounts 
		Если ЗначениеЗаполнено(Данные.ВидСкидкиНаценки) Тогда
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatDiscounts").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			ДобавляемаяСтрока.CatDiscount = ПолучитьОбъектXDTO(Данные.ВидСкидкиНаценки);
			ПередаваемыйОбъект.CatDiscounts.Добавить(ДобавляемаяСтрока);
		Конецесли;
		Для Каждого  СтрокаТаблицы Из Данные.ВидыСкидокНаценок Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatDiscounts").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);			Если ЗначениеЗаполнено(СтрокаТаблицы.ВидСкидкиНаценки) Тогда
				ДобавляемаяСтрока.CatDiscount = ПолучитьОбъектXDTO(СтрокаТаблицы.ВидСкидкиНаценки);
			Конецесли;
			ПередаваемыйОбъект.CatDiscounts.Добавить(ДобавляемаяСтрока);
		КонецЦикла;
		//ВидыСкидокНаценок CatDiscounts
		
		ПередаваемыйОбъект.Address = "";
		ПередаваемыйОбъект.Tel = "";
		Для Каждого ТекСтрока Из Данные.КонтактнаяИнформация Цикл
			Если ТекСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
				ПередаваемыйОбъект.Address = ТекСтрока.Представление;
			КонецЕсли;
			Если ТекСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				ПередаваемыйОбъект.Tel = ТекСтрока.Представление;
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("РегистрСведенийНаборЗаписей.ЦеныНоменклатуры") Тогда
		
		Если Данные.Количество() = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		ВыгрузкаРегистра = Данные.Выгрузить();
		
		Если Не ЗначениеЗаполнено(ВыгрузкаРегистра[0].Номенклатура) Или
			 Не ЗначениеЗаполнено(ВыгрузкаРегистра[0].ВидЦен) Или
			 ЗначениеЗаполнено(ВыгрузкаРегистра[0].Характеристика) Или
			 НужныеНоменклатуры.Найти(ВыгрузкаРегистра[0].Номенклатура) = Неопределено Тогда
			Возврат Неопределено; 
		КонецЕсли;
		
		ПередаваемыйОбъект = СоздатьОбъект("Prices");
		
		ПередаваемыйОбъект.Nomenclature = ПолучитьОбъектXDTO(ВыгрузкаРегистра[0].Номенклатура);
		ПередаваемыйОбъект.PriceType = ПолучитьОбъектXDTO(ВыгрузкаРегистра[0].ВидЦен);
		ПередаваемыйОбъект.Date = ВыгрузкаРегистра[0].Период;
		ПередаваемыйОбъект.Price = ВыгрузкаРегистра[0].Цена;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("УдалениеОбъекта") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("ObjectDeletion");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		
		Если ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.Номенклатура") Тогда
			ПередаваемыйОбъект.Type = "CatItems";
		ИначеЕсли ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.ВидыЦен") Тогда
			ПередаваемыйОбъект.Type = "CatPriceTypes";
		ИначеЕсли ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
			ПередаваемыйОбъект.Type = "CatContactors";
		ИначеЕсли ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			ПередаваемыйОбъект.Type = "CatContracts";
		КонецЕсли;
		
	КонецЕсли;		
	
	Возврат ПередаваемыйОбъект;
	
КонецФункции // ПолучитьОбъектXDTO()




