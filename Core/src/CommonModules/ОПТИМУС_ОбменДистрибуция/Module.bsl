//Ищем водителя, который ранее доставил товары этому контрагенту. Значит он же заберет товары при возврате
Процедура ЗаполнитьВодителяИТранспортноеСредствоПриВозврате(ДокументВизита, ЭлНакладная, ГрузоПолучатель, ТипДокумента="ПеремещениеЗапасов") Экспорт
	ЭлНакладная.ТранспортноеСредство = ДокументВизита.ТранспортноеСредство;
	ЭлНакладная.ГосНомерАвтомобиля	 = ДокументВизита.ТранспортноеСредство.Код;
	ЭлНакладная.Водитель	 	= ЭлНакладная.ТранспортноеСредство.ОсновнойВодитель;
	ЭлНакладная.НомерУдостоверения	 	= ЭлНакладная.Водитель.ИНН;
	Возврат;

	Запрос=Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РС_ЭлектроннаяНакладная.ТранспортноеСредство,
	|	РС_ЭлектроннаяНакладная.ГосНомерАвтомобиля,
	|	РС_ЭлектроннаяНакладная.ГосНомерПрицепа,
	|	РС_ЭлектроннаяНакладная.Водитель,
	|	РС_ЭлектроннаяНакладная.НомерУдостоверения,
	|	РС_ЭлектроннаяНакладная.Дата КАК Дата
	|ИЗ
	|	Документ.РС_ЭлектроннаяНакладная КАК РС_ЭлектроннаяНакладная
	|ГДЕ
	|	НЕ РС_ЭлектроннаяНакладная.ПометкаУдаления
	|	И РС_ЭлектроннаяНакладная.Дата МЕЖДУ &ДатаНач И &ДатаКон
	|	И РС_ЭлектроннаяНакладная.Организация = &Организация
	|	И РС_ЭлектроннаяНакладная.ГрузоПолучатель = &ГрузоПолучатель
	|	И РС_ЭлектроннаяНакладная.Ссылка <> &Ссылка
	|	И РС_ЭлектроннаяНакладная.Водитель <> ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
	|	И 1 = 1
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	Запрос.Текст=СтрЗаменить(Запрос.Текст,"1 = 1","РС_ЭлектроннаяНакладная.ДокументыОснования.ДокументОснование ССЫЛКА Документ."+ТипДокумента);

	Запрос.УстановитьПараметр("Ссылка",ЭлНакладная.Ссылка);
	Запрос.УстановитьПараметр("ДатаНач",НачалоДня(ЭлНакладная.Дата));
	Запрос.УстановитьПараметр("ДатаКон",ЭлНакладная.Дата);
	Запрос.УстановитьПараметр("Организация",ЭлНакладная.Организация);
	Запрос.УстановитьПараметр("ГрузоПолучатель",ГрузоПолучатель);
	Выборка=Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.Водитель) Тогда
			ЗаполнитьЗначенияСвойств(ЭлНакладная,Выборка,"Водитель,НомерУдостоверения");
		КонецЕсли;	
		Если ЗначениеЗаполнено(Выборка.ТранспортноеСредство) Тогда
			ЗаполнитьЗначенияСвойств(ЭлНакладная,Выборка,"ТранспортноеСредство,ГосНомерАвтомобиля,ГосНомерПрицепа");
		КонецЕсли;	
	КонецЕсли; 	
КонецПроцедуры // ПолучитьВодителяИТранспортноеСредствоПриВозврате()
 
