		Если ДокументПрихода = Неопределено Тогда
			Возврат НСтр("ka='შემოსვლის ზედნადების დოკუმენტი ვერ მოიძებნა. ხელახლა სცადეთ ვიზიტის დოკუმენტის გატარება სერვერზე';ru='Не найден документ приходной накладной. Попробуйте сначала провести документ визита на сервере';en='Document not found a credit note. Try to first conduct a visit to the document on the server'")
		КонецЕсли;
		
		ЭлНакладная = Неопределено;
		Результат = ОбновитьТТНВыписанные(ДокументВизита, ДокументПрихода, ,ЭлНакладная);
		Если Не ПустаяСтрока(Результат) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Результат = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбработатьОперациюТН("ОтменитьТН", ЭлНакладная.Ссылка);
		Если Не Результат = 0 Тогда 
			Возврат НСтр("ka='შეცდომა სასაქონლო ზედნადების გაუქმებისას';ru='Ошибка при отмене ТТН';en='Error cases Waybill'") + ": " + Результат;
		КонецЕсли;
		
		Возврат НСтр("ka='RS.GE-ს სერვისთან მუშაობა დასრულებულია';ru='Работа с сервисом RS.GE завершена';en='Working with service RS.GE completed'") + ПолучитьСтрокуНомераТТННалоговой(ДокументПрихода);
	КонецЕсли;
	
КонецФункции


Функция ПолучитьДокументРасхода(ДокументВизита,Проведен = Истина)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РасходнаяНакладная.Ссылка
		|ИЗ
		|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
		|ГДЕ
		|	РасходнаяНакладная.ДокументВизита = &ДокументВизита" + ?(Проведен,"
		|	И РасходнаяНакладная.Проведен = ИСТИНА","");

	Запрос.УстановитьПараметр("ДокументВизита", ДокументВизита);

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Возврат Неопределено;
	
КонецФункции

Функция ПолучитьДокументПеремещения(ДокументРасхода)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПеремещениеЗапасов.Ссылка
		|ИЗ
		|	Документ.ПеремещениеЗапасов КАК ПеремещениеЗапасов
		|ГДЕ
		|	ПеремещениеЗапасов.Проведен = ИСТИНА
		|	И ПеремещениеЗапасов.Организация = &Организация
		|	И ПеремещениеЗапасов.СтруктурнаяЕдиницаПолучатель = &СтруктурнаяЕдиницаПолучатель
		|	И ПеремещениеЗапасов.Дата <= &Дата
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПеремещениеЗапасов.Дата УБЫВ";

	Запрос.УстановитьПараметр("Организация", ДокументРасхода.Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиницаПолучатель", ДокументРасхода.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Возврат Неопределено;
	
КонецФункции

