// Возвращает структуру, содержащую имя таблицы для выборки и массив полей, которые нужно выбрать
//
// Параметры:
//  ОбъектМетаданных - объект метаданных, структуру описания которого требуется получить
//  Изменения - признак того, что в качестве таблицы для выборки выступает таблица изменений
//
// Возвращаемое значение:
//  Структура, содержащая описание объекта метаданных
//
Функция ПолучитьСтруктуруОписанияОбъекта(ОбъектМетаданных, Изменения = Ложь) Экспорт

	Если Метаданные.Константы.Содержит(ОбъектМетаданных) Тогда
		ИмяКласса = "Константы";
		ИмяТаблицы = "Константы";
	ИначеЕсли Метаданные.Справочники.Содержит(ОбъектМетаданных) Тогда
		ИмяКласса = "Справочники";
		ИмяТаблицы = "Справочник." + ОбъектМетаданных.Имя;
	ИначеЕсли Метаданные.Документы.Содержит(ОбъектМетаданных) Тогда
		ИмяКласса = "Документы";
		ИмяТаблицы = "Документ." + ОбъектМетаданных.Имя;
	ИначеЕсли Метаданные.РегистрыСведений.Содержит(ОбъектМетаданных) Тогда
		ИмяКласса = "РегистрыСведений";
		ИмяТаблицы = "РегистрСведений." + ОбъектМетаданных.Имя;
	КонецЕсли;	
	
	// Если требуется только выборка изменений, то выбирать необходимо по таблицам изменений
	Если Изменения Тогда
		ИмяТаблицы = ИмяТаблицы + ".Изменения";
	КонецЕсли;
	
	СтруктураОписания = Новый Структура();
	СтруктураОписания.Вставить("ИмяКласса", ИмяКласса);
	СтруктураОписания.Вставить("ИмяОбъекта", ОбъектМетаданных.Имя);
	СтруктураОписания.Вставить("ИмяТаблицы", ИмяТаблицы);
	
	Возврат СтруктураОписания;

КонецФункции

// Выполняет выборочную регистрацию изменений, с учетом правил обмена
//
// Параметры:
//  Объект - объект, изменения которого регистрируются
//  Отказ - отказ от записи объекта
//  ИмяПланаОбмена - имя используемого плана обмена
//
Процедура ВыборочнаяРегистрацияОбъекта(Объект, Отказ, ИмяПланаОбмена, УзелОбмена = Неопределено)
	
	// Если при записи объекта был произведен отказ, то дальнейшего анализа не требуется -
	// никаких изменений не будет
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	МетаданныеОбъекта = Объект.Метаданные();
	
	// Если объект не входит в состав плана обмена, то регистрировать нечего
	Если Не Метаданные.ПланыОбмена[ИмяПланаОбмена].Состав.Содержит(МетаданныеОбъекта) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураОписанияОбъекта = ПолучитьСтруктуруОписанияОбъекта(МетаданныеОбъекта, Ложь);
	
	ВыборкаУзлов = ПланыОбмена[ИмяПланаОбмена].Выбрать();

	Пока ВыборкаУзлов.Следующий() Цикл
		
		Если Не УзелОбмена = Неопределено И
			 Не ВыборкаУзлов.Ссылка = УзелОбмена Тогда
			Продолжить;
		КонецЕсли;

		Если Объект.ОбменДанными.Загрузка Тогда
			Если Объект.ОбменДанными.Отправитель = ВыборкаУзлов.Ссылка Тогда
				// Для узла, по которому пришли изменения, их регистрировать не нужно
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ВыборкаУзлов.Ссылка <> ПланыОбмена[ИмяПланаОбмена].ЭтотУзел() Тогда
			
			НеРегистрироватьИзменения = Ложь;
			Если Объект.ДополнительныеСвойства.Свойство("НеРегистрироватьИзменения", НеРегистрироватьИзменения) Тогда
				Если НеРегистрироватьИзменения Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Если ОбъектПодлежитРегистрацииВУзле(Объект, СтруктураОписанияОбъекта, ВыборкаУзлов.Ссылка) Тогда
				Если УзелОбмена = Неопределено Тогда
					Объект.ОбменДанными.Получатели.Добавить(ВыборкаУзлов.Ссылка);
				Иначе
					ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, Объект);
				КонецЕсли;
			Иначе
				Если УзелОбмена = Неопределено Тогда
					ВозможноУдалениеРегистрацииИзменений = Ложь;
					Если Объект.ДополнительныеСвойства.Свойство("ВозможноУдалениеРегистрацииИзменений", ВозможноУдалениеРегистрацииИзменений) Тогда
						Если ВозможноУдалениеРегистрацииИзменений Тогда
							ПланыОбмена.УдалитьРегистрациюИзменений(ВыборкаУзлов.Ссылка, Объект);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

// Проверяет, подлежит ли объект регистрации в указанном узле обмена
//
// Параметры:
//  Объект - объект, изменения которого регистрируются
//  СтруктураОписанияОбъекта - Структура, содержащая описание объекта
//  УзелОбмена - узел плана обмена, для которого проверяется необходимость регистрации
//
Функция ОбъектПодлежитРегистрацииВУзле(Объект, СтруктураОписанияОбъекта, УзелОбмена, ТаблицаДанныхОбъекта = Неопределено)
	
	ИмяКласса = СтруктураОписанияОбъекта.ИмяКласса;
	ИмяОбъекта = СтруктураОписанияОбъекта.ИмяОбъекта;
	
	Если ИмяКласса = "Константы" Тогда
		// Для констант никаких условий отбора не задается, поэтому изменения регистрируем всегда
		Возврат Истина;
	Иначе
		
		МассивПолей = ПолучитьМассивПолейОтбораДляОбъекта(ИмяКласса, ИмяОбъекта);
		
		Если ИмяКласса = "Справочники" ИЛИ ИмяКласса = "Документы" Тогда
			
			Если МассивПолей.Найти("Ссылка") = Неопределено Тогда
				МассивПолей.Добавить("Ссылка");
			КонецЕсли;
			
			Если ТаблицаДанныхОбъекта = Неопределено Тогда
				ТаблицаДанныхОбъекта = Новый ТаблицаЗначений();
				Для Каждого Поле из МассивПолей Цикл
					ТаблицаДанныхОбъекта.Колонки.Добавить(Поле);
				КонецЦикла;
			КонецЕсли;
			
			СтруктураРеквизитовОбъекта = Новый Структура();
			
			СтрокаТаблицы = ТаблицаДанныхОбъекта.Добавить();
			Для Каждого Поле из МассивПолей Цикл
				СтрокаТаблицы[Поле] = Объект[Поле];
				СтруктураРеквизитовОбъекта.Вставить(Поле, Объект[Поле]);
			КонецЦикла;
		
			Возврат ОПТИМУС_ОбменДистрибуция_ВыборочнаяРегистрация.ТребуетсяРегистрацияИзмененийОбъекта(СтруктураРеквизитовОбъекта, СтруктураОписанияОбъекта, МассивПолей, ТаблицаДанныхОбъекта, УзелОбмена);
			
		ИначеЕсли ИмяКласса = "РегистрыСведений" Тогда
			
			Возврат Истина;
			
		КонецЕсли;
		
	КонецЕсли;	
	
	Возврат Ложь;
	
КонецФункции


// Процедура регистрирует изменения, для всех данных, входящих в состав плана обмена
// Параметры:
//  УзелОбмена - узел плана обмена, для которого регистрируются изменения
Процедура ЗарегистрироватьИзмененияДанных(УзелОбмена) Экспорт
	
	СоставПланаОбмена = УзелОбмена.Метаданные().Состав;
	Для каждого ЭлементСоставаПланаОбмена Из СоставПланаОбмена Цикл
		Если ЭлементСоставаПланаОбмена.АвтоРегистрация = АвтоРегистрацияИзменений.Разрешить Тогда
			ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, ЭлементСоставаПланаОбмена.Метаданные);
		Иначе
			СтруктуруОписанияОбъекта = ПолучитьСтруктуруОписанияОбъекта(ЭлементСоставаПланаОбмена.Метаданные);
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	Мета.Ссылка
				|ИЗ
				|	Справочник.Номенклатура КАК Мета
				|ГДЕ
				|	Мета.ПометкаУдаления = ЛОЖЬ";
				
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "Справочник.Номенклатура", СтруктуруОписанияОбъекта.ИмяТаблицы);

			Результат = Запрос.Выполнить();

			ВыборкаДетальныеЗаписи = Результат.Выбрать();

			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ВыборочнаяРегистрацияОбъекта(ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект(), Ложь, "ОПТИМУС_Дистрибуция", УзелОбмена);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры // ЗарегистрироватьИзмененияДанных()

Процедура НачальнаяРегистрацияИзменений(УзлыОбмена) Экспорт
	
	Для Каждого УзелОбмена Из УзлыОбмена Цикл
		Если Не УзелОбмена = ПланыОбмена.ОПТИМУС_Дистрибуция.ЭтотУзел() Тогда
			ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена);
			ЗарегистрироватьИзмененияДанных(УзелОбмена);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция СформироватьСКДНаСервере(УзелОбмена,ПольныйОбмен)
	Если ПольныйОбмен Тогда 
		СхемаКомпоновкиДанных = Отчеты.ОПТИМУС_АнализОбменаДистрибуция.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
		КомпоновщикНастроек =  СхемаКомпоновкиДанных.ВариантыНастроек.Основной;
		Настройки = КомпоновщикНастроек.Настройки;
		
	Иначе 
		ОтчетыСКД = Отчеты.ОПТИМУС_АнализОбменаДистрибуцияИзменения.Создать();
		СхемаКомпоновкиДанных = ОтчетыСКД.СхемаКомпоновкиДанных;
		КомпоновщикНастроек =  ОтчетыСКД.КомпоновщикНастроек;
		Настройки = ОтчетыСКД.КомпоновщикНастроек.Настройки;
	КонецЕсли;
	
	Если ПольныйОбмен Тогда 
		УстановитьПараметрыСКД(УзелОбмена,Настройки);
	Иначе 
		УстановитьПараметрыСКД_Изменения(УзелОбмена,Настройки)
	КонецЕсли;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	// Построение таблицы значений.
	Процессор = Новый ПроцессорКомпоновкиДанных;
	Процессор.Инициализировать(МакетКомпоновкиДанных);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений();
	ИсходныеДанные = Новый ДеревоЗначений;
	ПроцессорВывода.УстановитьОбъект(ИсходныеДанные);
	ПроцессорВывода.Вывести(Процессор);
	Возврат ИсходныеДанные;
	
КонецФункции

Процедура УстановитьПараметрыСКД(УзелОбмена,Настройки)
	врУзелОбмена = УзелОбмена;
	Если Не ЗначениеЗаполнено(врУзелОбмена) Тогда 
		Возврат;
	КонецЕсли; 	
	
	СтруктураОтбораСхемыОбмена = врУзелОбмена.ХранилищеОтбораСхемыОбмена.Получить();
	НастройкиСКД = Настройки;
	ЭлементыОтбораСКД = НастройкиСКД.Отбор.Элементы;
	ЭлементыОтбораСКД.Очистить();
	
	Для Каждого стр Из СтруктураОтбораСхемыОбмена Цикл 
		новыйЭлСКД = ЭлементыОтбораСКД.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЗаполнитьЗначенияСвойств(новыйЭлСКД,стр.значение);
		//Если стр.Ключ =  "Склад" Тогда 
		//	новыйЭлСКД.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("СтруктурнаяЕдиница"); 
		//КонецЕсли;
	КонецЦикла;
	
	Если Константы.ИспользоватьНесколькоОрганизаций.Получить() Тогда 
		новыйЭлСКД = ЭлементыОтбораСКД.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		новыйЭлСКД.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Организация");
		новыйЭлСКД.Использование  = Истина;
		новыйЭлСКД.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		новыйЭлСКД.ПравоеЗначение = врУзелОбмена.Организация;
	КонецЕсли;
	
	новыйЭлСКД = ЭлементыОтбораСКД.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	новыйЭлСКД.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("СкладВозврата");
	новыйЭлСКД.Использование  = Истина;
	новыйЭлСКД.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	новыйЭлСКД.ПравоеЗначение = врУзелОбмена.СтруктурнаяЕдиницаДляВозврата;

	ВыгружатьТолькоОстатки=Новый ПараметрКомпоновкиДанных("ВыгружатьТолькоОстатки");
	ВыгружатьТолькоОстатки=НастройкиСКД.ПараметрыДанных.НайтиЗначениеПараметра(ВыгружатьТолькоОстатки);

	Если ВыгружатьТолькоОстатки<>Неопределено Тогда
		НастройкиСКД.ПараметрыДанных.УстановитьЗначениеПараметра("ВыгружатьТолькоОстатки",УзелОбмена.ВыгружатьТолькоОстатки);		
	КонецЕсли; 
	//Если УзелОбмена.ВыгружатьТолькоОстатки Тогда
		//новыйЭлСКД = ЭлементыОтбораСКД.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		//новыйЭлСКД.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("КоличествоОстаток");
		//новыйЭлСКД.Использование  = Истина;
		//новыйЭлСКД.ВидСравнения   = ВидСравненияКомпоновкиДанных.Больше;
		//новыйЭлСКД.ПравоеЗначение = 0;
	//КонецЕсли; 
КонецПроцедуры


Процедура УстановитьПараметрыСКД_Изменения(УзелОбмена,Настройки)
	врУзелОбмена = УзелОбмена;
	Если Не ЗначениеЗаполнено(врУзелОбмена) Тогда 
		Возврат;
	КонецЕсли; 	
	
	СтруктураОтбораСхемыОбмена = врУзелОбмена.ХранилищеОтбораСхемыОбмена.Получить();
	НастройкиСКД = Настройки;
	
	ПараметрСКД = Настройки.ПараметрыДанных.Элементы.Найти("Узел");
	ПараметрСКД.Использование = Истина;
	ПараметрСКД.Значение = врУзелОбмена;

	Для Каждого стр Из СтруктураОтбораСхемыОбмена Цикл 
		ПараметрСКД = Настройки.ПараметрыДанных.Элементы.Найти(стр.Ключ);
		ПараметрСКД.Использование = Истина;
		ПараметрСКД.Значение = стр.Значение.ПравоеЗначение;
	КонецЦикла;
	
	ПараметрСКД = Настройки.ПараметрыДанных.Элементы.Найти("Организация");
	ПараметрСКД.Использование = Истина;
	ПараметрСКД.Значение	  = врУзелОбмена.Организация;
	
	ПараметрСКД = Настройки.ПараметрыДанных.Элементы.Найти("НесколькоОрганизация");
	ПараметрСКД.Использование = Истина;
	//Паганини_
	ПараметрСКД.Значение	  = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьНесколькоОрганизаций");
								//Константы.ФункциональнаяОпцияУчетПоНесколькимОрганизациям.Получить();
	//_Паганини
	
	
	ПараметрСКД = Настройки.ПараметрыДанных.Элементы.Найти("СкладВотврата");
	ПараметрСКД.Использование = Истина;
	ПараметрСКД.Значение	  = врУзелОбмена.СтруктурнаяЕдиницаДляВозврата;

КонецПроцедуры

Процедура ЗаписатьДанныеСКД(ВозвращаемыйСписок, Данные,стрДанные) Экспорт
	
	ОбъектXDTO = ПолучитьОбъектXDTO_СКД(Данные,стрДанные);
	Если ОбъектXDTO <> Неопределено Тогда
		ВозвращаемыйСписок.objects.Добавить(ОбъектXDTO);
	КонецЕсли;
	
КонецПроцедуры // ЗаписатьДанные()

Функция ПолучитьОбъектXDTO_СКД(Данные,СтрокаДанные=Неопределено)
	
	ПередаваемыйОбъект = Неопределено;
	
	Если ТипЗнч(Данные) = Тип("СправочникОбъект.Номенклатура")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.Номенклатура") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatItems");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;

		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group =ПолучитьОбъектXDTO_СКД(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
			ПередаваемыйОбъект.Disabled = Данные.Неактивен;
		КонецЕсли;
		ПередаваемыйОбъект.Article = Данные.Артикул;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ВидыЦен")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.ВидыЦен") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatPriceTypes");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group =ПолучитьОбъектXDTO_СКД(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ВидыСкидокНаценок")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.ВидыСкидокНаценок") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatDiscounts");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		
		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group =ПолучитьОбъектXDTO_СКД(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.Percent	   = Данные.Процент;
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.Контрагенты")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.Контрагенты") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatContactors");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		Если ЗначениеЗаполнено(Данные.Родитель) Тогда
			ПередаваемыйОбъект.Group =ПолучитьОбъектXDTO_СКД(Данные.Родитель);
		КонецЕсли;
		Если Данные.ЭтоГруппа Тогда
			ПередаваемыйОбъект.ThisIsGroup = Истина;
			Возврат ПередаваемыйОбъект;
		Иначе
			ПередаваемыйОбъект.ThisIsGroup = Ложь;
		КонецЕсли;
		
		ПередаваемыйОбъект.INN = Строка(Данные.Ссылка.ИНН);
		
		ПередаваемыйОбъект.Tel = "";
		Для Каждого ТекСтрока Из Данные.КонтактнаяИнформация Цикл
			Если ТекСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
				ПередаваемыйОбъект.Tel = ТекСтрока.Представление;
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("СправочникОбъект.ДоговорыКонтрагентов")
		ИЛИ ТипЗнч(Данные) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("CatContracts");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		ПередаваемыйОбъект.Name = Данные.Наименование;
		ПередаваемыйОбъект.DeletionMark = Данные.ПометкаУдаления;
		ПередаваемыйОбъект.Blocked = Данные.Заблокировано;
		ПередаваемыйОбъект.Disabled = Данные.Неактивен;
		ПередаваемыйОбъект.Limit = Данные.Лимит;
		
		Если ЗначениеЗаполнено(Данные.Владелец) Тогда
			ПередаваемыйОбъект.Owner =ПолучитьОбъектXDTO_СКД(Данные.Владелец);
		Конецесли;
		Если ЗначениеЗаполнено(Данные.ВидЦен) Тогда
			ПередаваемыйОбъект.PriceType =ПолучитьОбъектXDTO_СКД(Данные.ВидЦен);
		Конецесли;
		
		Если ЗначениеЗаполнено(Данные.ВидСкидкиНаценки) Тогда
			ПередаваемыйОбъект.DiscountType =ПолучитьОбъектXDTO_СКД(Данные.ВидСкидкиНаценки);
		Конецесли;
		
		Строка = "";		
		Для Каждого СтрокаТаблицы Из Данные.ГрафикПосещения Цикл
			Если СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Понедельник Тогда
				Строка = Строка + "1";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Вторник Тогда
				Строка = Строка + "2";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Среда Тогда
				Строка = Строка + "3";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Четверг Тогда
				Строка = Строка + "4";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Пятница Тогда
				Строка = Строка + "5";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Суббота Тогда
				Строка = Строка + "6";
			ИначеЕсли СтрокаТаблицы.ДеньНедели = Перечисления.ДниНедели.Воскресенье Тогда
				Строка = Строка + "7";
			КонецЕсли
		КонецЦикла;
		ПередаваемыйОбъект.Schedule = Строка;
		
		ПередаваемыйОбъект.Address = Данные.Адрес;
		ПередаваемыйОбъект.Tel = "";
		
		//ВидыЦен  CatPriceTypes
		Если ЗначениеЗаполнено(Данные.ВидЦен) Тогда
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatPriceTypes").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			ДобавляемаяСтрока.CatPriceType = ПолучитьОбъектXDTO(Данные.ВидЦен);
			ПередаваемыйОбъект.CatPriceTypes.Добавить(ДобавляемаяСтрока);
		Конецесли;
		
		Для Каждого  СтрокаТаблицы Из Данные.ВидыЦен Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatPriceTypes").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			Если ЗначениеЗаполнено(СтрокаТаблицы.ВидЦен) Тогда
				ДобавляемаяСтрока.CatPriceType = ПолучитьОбъектXDTO(СтрокаТаблицы.ВидЦен);
			Конецесли;
			ПередаваемыйОбъект.CatPriceTypes.Добавить(ДобавляемаяСтрока);
		КонецЦикла;
		//ВидыЦен CatPriceTypes
		
		//ВидыСкидокНаценок CatDiscounts 
		Если ЗначениеЗаполнено(Данные.ВидСкидкиНаценки) Тогда
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatDiscounts").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			ДобавляемаяСтрока.CatDiscount = ПолучитьОбъектXDTO_СКД(Данные.ВидСкидкиНаценки);
			ПередаваемыйОбъект.CatDiscounts.Добавить(ДобавляемаяСтрока);
		Конецесли;
		Для Каждого  СтрокаТаблицы Из Данные.ВидыСкидокНаценок Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("CatDiscounts").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			Если ЗначениеЗаполнено(СтрокаТаблицы.ВидСкидкиНаценки) Тогда
				ДобавляемаяСтрока.CatDiscount = ПолучитьОбъектXDTO_СКД(СтрокаТаблицы.ВидСкидкиНаценки);
			Конецесли;
			ПередаваемыйОбъект.CatDiscounts.Добавить(ДобавляемаяСтрока);
		КонецЦикла;
		//ВидыСкидокНаценок CatDiscounts
		
		
		//Для Каждого ТекСтрока Из Данные.КонтактнаяИнформация Цикл
		//	Если ТекСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес Тогда
		//		ПередаваемыйОбъект.Address = ТекСтрока.Представление;
		//	КонецЕсли;
		//	Если ТекСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
		//		ПередаваемыйОбъект.Tel = ТекСтрока.Представление;
		//	КонецЕсли;
		//КонецЦикла;

		
	ИначеЕсли Данные = "Взаиморасчети" Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("Payable");
		
		ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
		ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
		Если ЗначениеЗаполнено(СтрокаДанные.Контрагент) Тогда
			ДобавляемаяСтрока.Contactor = ПолучитьОбъектXDTO(СтрокаДанные.Контрагент.ПолучитьОбъект());
		Конецесли;
		Если ЗначениеЗаполнено(СтрокаДанные.Договор) Тогда
			ДобавляемаяСтрока.Contract = ПолучитьОбъектXDTO(СтрокаДанные.Договор.ПолучитьОбъект());
		Конецесли;
		ДобавляемаяСтрока.Total = СтрокаДанные.Сумма;
		ДобавляемаяСтрока.Document = Формат(СтрокаДанные.Дата, "ДФ=yyyy-MM-dd") + "   " + Строка(СтрокаДанные.Номер);
		ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
		
		
	ИначеЕсли Данные = "Остатки" Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("ReturnRemains");
		
		ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
		ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
		Если ЗначениеЗаполнено(СтрокаДанные.Номенклатура) Тогда
			ДобавляемаяСтрока.Nomenclature = ПолучитьОбъектXDTO(СтрокаДанные.Номенклатура.ПолучитьОбъект());
		Конецесли;
		ДобавляемаяСтрока.Quantity = СтрокаДанные.КоличествоОстаток;
		ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
		
	ИначеЕсли Данные = "Остатки" Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("Remains");
		
		ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
		ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
		Если ЗначениеЗаполнено(СтрокаДанные.Номенклатура) Тогда
			ДобавляемаяСтрока.Nomenclature = ПолучитьОбъектXDTO(СтрокаДанные.Номенклатура.ПолучитьОбъект());
		Конецесли;
		ДобавляемаяСтрока.Quantity = СтрокаДанные.КоличествоОстаток;
		ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
		
	ИначеЕсли Данные = "Цены" Тогда

		ПередаваемыйОбъект = СоздатьОбъект("Prices");
		
		ПередаваемыйОбъект.Nomenclature = ПолучитьОбъектXDTO_СКД(СтрокаДанные.Номенклатура);
		ПередаваемыйОбъект.PriceType    = ПолучитьОбъектXDTO_СКД(СтрокаДанные.ВидЦен);
		ПередаваемыйОбъект.Date  		= СтрокаДанные.Период;
		ПередаваемыйОбъект.Price		= СтрокаДанные.Цена;
		
	ИначеЕсли ТипЗнч(Данные) = Тип("УдалениеОбъекта") Тогда
		
		ПередаваемыйОбъект = СоздатьОбъект("ObjectDeletion");
		ПередаваемыйОбъект.Id = Строка(Данные.Ссылка.УникальныйИдентификатор());
		
	Если ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.Номенклатура") Тогда
			ПередаваемыйОбъект.Type = "CatItems";
		ИначеЕсли ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.ВидыЦен") Тогда
			ПередаваемыйОбъект.Type = "CatPriceTypes";
		ИначеЕсли ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
			ПередаваемыйОбъект.Type = "CatContactors";
		ИначеЕсли ТипЗнч(Данные.Ссылка) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
			ПередаваемыйОбъект.Type = "CatContracts";
		КонецЕсли;
		
	КонецЕсли;		
	
	Возврат ПередаваемыйОбъект;
	
КонецФункции // ПолучитьОбъектXDTO()


Процедура ЗаписатьДанныеСКД_ОстаткиВзаиморасчети(МассивОстатки, МассивОстаткиВозвратов, МассивВзаиморасчети,ВозвращаемыйСписок) Экспорт 
	
	//--Остатки	
	Если МассивОстатки.Количество() Тогда 
		ПередаваемыйОбъект = СоздатьОбъект("Remains");
		
		Для Каждого  Выборка Из МассивОстатки Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
				ДобавляемаяСтрока.Nomenclature = ПолучитьОбъектXDTO(Выборка.Номенклатура.ПолучитьОбъект());
			Конецесли;
			ДобавляемаяСтрока.Quantity = Выборка.КоличествоОстаток;
			ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
		КонецЦикла;
		
		ВозвращаемыйСписок.objects.Добавить(ПередаваемыйОбъект);
	КонецЕсли;	
	
	Если МассивОстаткиВозвратов.Количество() Тогда 
		ПередаваемыйОбъект = СоздатьОбъект("ReturnRemains");
		
		Для Каждого  Выборка Из МассивОстаткиВозвратов Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			Если ЗначениеЗаполнено(Выборка.Номенклатура) Тогда
				ДобавляемаяСтрока.Nomenclature = ПолучитьОбъектXDTO(Выборка.Номенклатура.ПолучитьОбъект());
			Конецесли;
			ДобавляемаяСтрока.Quantity = Выборка.КоличествоОстаток;
			ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
		КонецЦикла;
		
		ВозвращаемыйСписок.objects.Добавить(ПередаваемыйОбъект);
	КонецЕсли;	
	
	
	//--Взаиморасчети
	Если МассивВзаиморасчети.Количество() Тогда 
		ПередаваемыйОбъект = СоздатьОбъект("Payable");
		
		Для Каждого  Выборка Из МассивВзаиморасчети Цикл
			ДобавляемаяСтрокаТип = ПередаваемыйОбъект.Свойства().Получить("Item").Тип;
			ДобавляемаяСтрока = ФабрикаXDTO.Создать(ДобавляемаяСтрокаТип);
			Если ЗначениеЗаполнено(Выборка.Контрагент) Тогда
				ДобавляемаяСтрока.Contactor = ПолучитьОбъектXDTO_СКД(Выборка.Контрагент.ПолучитьОбъект());
			Конецесли;
			Если ЗначениеЗаполнено(Выборка.Договор) Тогда
				ДобавляемаяСтрока.Contract = ПолучитьОбъектXDTO_СКД(Выборка.Договор.ПолучитьОбъект());
			Конецесли;
			ДобавляемаяСтрока.Total = Выборка.Сумма;
			ДобавляемаяСтрока.Document = Формат(Выборка.Дата, "ДФ=yyyy-MM-dd") + "   " + Строка(Выборка.Номер);
			ПередаваемыйОбъект.Item.Добавить(ДобавляемаяСтрока);
		КонецЦикла;
		
		ВозвращаемыйСписок.objects.Добавить(ПередаваемыйОбъект);
	КонецЕсли;	
	

КонецПроцедуры


Функция ОперацияФормироватьОтчетаДляКПК(УзелОбмена, ДанныеОбмена) Экспорт
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ДанныеОбмена.Получить());
	
	ТипОбъектаXDTO = ФабрикаXDTO.Тип("http://www.optimus.ge/SB/DistributionExchange", "Objects");
	
	Объекты = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
	
	ЗагрузитьОбъекты(УзелОбмена, Объекты);
	ЧтениеXML.Закрыть();
	
	Идентификатор = Новый УникальныйИдентификатор(Объекты.objects[0].id);
	Договор = Справочники.ДоговорыКонтрагентов.ПолучитьСсылку(Идентификатор);
	
	Возврат ФормироватьОтчетаДляКПК(Договор);
	
КонецФункции

Функция ФормироватьОтчетаДляКПК(Договор) Экспорт
	
	ЗначениеДляВозврата = СоздатьОбъект("DataWithAnswer");
	
	// Отчет Задолженности
	СхемаКомпоновкиДанных = Отчеты.ОПТИМУС_ЗадолженностиПоИнтервалам.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	КомпоновщикНастроек =  СхемаКомпоновкиДанных.ВариантыНастроек.ВариантДляОбмена;
	Настройки = КомпоновщикНастроек.Настройки;
	
	УстановитьПараметрыСКДДолг(Настройки,Договор);
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	// Построение таблицы значений.
	Процессор = Новый ПроцессорКомпоновкиДанных;
	Процессор.Инициализировать(МакетКомпоновкиДанных);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений();
	ИсходныеДанные = Новый ТаблицаЗначений;
	ПроцессорВывода.УстановитьОбъект(ИсходныеДанные);
	ПроцессорВывода.Вывести(Процессор);
	
	ЗначениеДляВозврата.Data = Новый ХранилищеЗначения(ИсходныеДанные, Новый СжатиеДанных(9));
	Возврат ЗначениеДляВозврата;
	
КонецФункции

Процедура УстановитьПараметрыСКДДолг(Настройки,Договор)
	
	ПараметрыДанных = Настройки.ПараметрыДанных.Элементы;
	
	Пар =ПараметрыДанных.Найти("Период");
	Если НЕ   Пар =  Неопределено  Тогда
		Пар.Использование  = Истина;
		Пар.Значение  =  КонецДня(ТекущаяДата()); 
	КонецЕсли;

	Пар =ПараметрыДанных.Найти("СсылкаНаИнтервал");
	Если НЕ   Пар =  Неопределено  Тогда
		Пар.Использование  = Истина;
		Пар.Значение  =  Справочники.ОПТИМУС_ИнтервалиДляОтчетов.НайтиПоКоду("000000001"); 
	КонецЕсли;

	Пар =ПараметрыДанных.Найти("СНаступающимиЗадолженностьями");
	Если НЕ   Пар =  Неопределено  Тогда
		Пар.Использование  = Истина;
		Пар.Значение  =  Истина; 
	КонецЕсли;

	Отбор = Настройки.Отбор.Элементы;
	
	Для каждого Элемент из Отбор Цикл
		Если Элемент.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Договор") Тогда
			Элемент.ПравоеЗначение = Договор;
			Элемент.Использование  = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьОстатокКасси(Касса)
	ОстатокКасси = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ДенежныеСредстваОстатки.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ДенежныеСредства.Остатки(, БанковскийСчетКасса = &Касса) КАК ДенежныеСредстваОстатки";
	Запрос.УстановитьПараметр("Касса", Касса);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		ОстатокКасси = Выборка.СуммаОстаток;
	КонецЕсли;
	
	Возврат ОстатокКасси;
	
КонецФункции