// ПРОЦЕДУРЫ И ФУНКЦИИ ДЛЯ RS.GE

Функция ОперацияRSGE(УзелОбмена, ДанныеОбмена, ЭтоВозврат) Экспорт
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ДанныеОбмена.Получить());
	
	ТипОбъектаXDTO = ФабрикаXDTO.Тип("http://www.optimus.ge/SB/DistributionExchange", "Objects");
	
	Объекты = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
	
	ЗагрузитьОбъекты(УзелОбмена, Объекты);
	ЧтениеXML.Закрыть();
	
	Идентификатор = Новый УникальныйИдентификатор(Объекты.objects[0].id);
	ДокументСсылка = Документы.Визит.ПолучитьСсылку(Идентификатор);
	
	Возврат ВыполнитьОперациюRSGE(ДокументСсылка, ЭтоВозврат);
	
КонецФункции

Функция ОперацияОтменаRSGE(УзелОбмена, ДанныеОбмена, ЭтоВозврат) Экспорт
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(ДанныеОбмена.Получить());
	
	ТипОбъектаXDTO = ФабрикаXDTO.Тип("http://www.optimus.ge/SB/DistributionExchange", "Objects");
	
	Объекты = ФабрикаXDTO.ПрочитатьXML(ЧтениеXML, ТипОбъектаXDTO);
	
	ЗагрузитьОбъекты(УзелОбмена, Объекты);
	ЧтениеXML.Закрыть();
	
	Идентификатор = Новый УникальныйИдентификатор(Объекты.objects[0].id);
	ДокументСсылка = Документы.Визит.ПолучитьСсылку(Идентификатор);
	
	Возврат ВыполнитьОтменуТТН(ДокументСсылка, ЭтоВозврат);
	
КонецФункции

Функция ВыполнитьОперациюRSGE(ДокументВизита, ЭтоВозврат) Экспорт 
	
	Если Не ЭтоВозврат Тогда
		ДокументРасхода = ПолучитьДокументРасхода(ДокументВизита);
		
		Если ДокументРасхода = Неопределено Тогда
			Возврат НСтр("ka='გასავლის ზედნადების დოკუმენტი ვერ მოიძებნა. ხელახლა სცადეთ ვიზიტის დოკუმენტის გატარება სერვერზე';ru='Не найден документ расходной накладной. Попробуйте сначала провести документ визита на сервере';en='Document not found the expenditure invoice. Try to first conduct a visit to the document on the server'")
		КонецЕсли;
		
		ДокументПеремещения = ПолучитьДокументПеремещения(ДокументРасхода);
		
		Если ДокументПеремещения = Неопределено Тогда
			Возврат НСтр("ka='მარაგების დისტრიბუციის დოკუმენტი ვერ მოიძებნა.';ru='Не найден документ дистрибуций запасов.';en='Unable to find the document distributions stocks.'")
		КонецЕсли;
		
		ЭлНакладная = Неопределено;
		Результат = ОбновитьТТНВыписанные(ДокументВизита, ДокументРасхода, ДокументПеремещения, ЭлНакладная);
		Если Не ПустаяСтрока(Результат) Тогда
			Возврат Результат;
		КонецЕсли;
		
		Результат = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбработатьОперациюТН("СоздатьТН", ЭлНакладная.Ссылка);
		Если Не Результат = 0 Тогда 
			Возврат НСтр("ka='შეცდომა სატრანსპორტო-სასაქონლო ზედნადების ჩატვირთვისას';ru='Ошибка при загрузке ТТН';en='Error loading Waybill'") + ": " + Результат;
		КонецЕсли;
		
		Результат = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбработатьОперациюТН("ЗавершитьТН", ЭлНакладная.Ссылка);
		Если Не Результат = 0 Тогда 
			Возврат НСтр("ka='შეცდომა სატრანსპორტო-სასაქონლო ზედნადების დახურვისას';ru='Ошибка при закрытый ТТН';en='Error closing Waybill'") + ": " + Результат;
		КонецЕсли;
		
		Возврат НСтр("ka='RS.GE-ს სერვისთან მუშაობა დასრულებულია';ru='Работа с сервисом RS.GE завершена';en='Working with service RS.GE completed'") + ПолучитьСтрокуНомераТТННалоговой(ДокументРасхода);
	Иначе
		ДокументПрихода = ПолучитьДокументПрихода(ДокументВизита);
		
		Если ДокументПрихода = Неопределено Тогда
			Возврат НСтр("ka='შემოსვლის ზედნადების დოკუმენტი ვერ მოიძებნა. ხელახლა სცადეთ ვიზიტის დოკუმენტის გატარება სერვერზე';ru='Не найден документ приходной накладной. Попробуйте сначала провести документ визита на сервере';en='Document not found a credit note. Try to first conduct a visit to the document on the server'")
		КонецЕсли;
		 
		ЭлНакладная = Неопределено;
		Результат = ОбновитьТТНВыписанные(ДокументВизита, ДокументПрихода, , ЭлНакладная);
		Если Не ПустаяСтрока(Результат) Тогда
			Возврат Результат;
		КонецЕсли;
		
		АктивироватьТТН = Истина;
		Если ЭлНакладная.СтатусТН =  Перечисления.РС_СтатусыТН.Активная Тогда 		
			АктивироватьТТН = Ложь;
		КонецЕсли;
		
		Результат = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбработатьОперациюТН("СоздатьТН", ЭлНакладная.Ссылка);;
		Если Не Результат = 0 Тогда
			Возврат НСтр("ka='შეცდომა სატრანსპორტო-სასაქონლო ზედნადების ჩატვირთვისას';ru='Ошибка при загрузке ТТН';en='Error loading Waybill'") + ": " + Результат;
		КонецЕсли;      
		
		Если АктивироватьТТН Тогда 
			Результат = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбработатьОперациюТН("АктивироватьТН", ЭлНакладная.Ссылка);
			Если Не Результат = 0 Тогда 
				Возврат НСтр("ka='შეცდომა სატრანსპორტო-სასაქონლო ზედნადების აქტივაციის დროს';ru='Ошибка при активации ТТН';en='Error during activation Waybill'") + ": " + Результат;
			КонецЕсли;
		КонецЕсли;
		
		Возврат НСтр("ka='RS.GE-ს სერვისთან მუშაობა დასრულებულია';ru='Работа с сервисом RS.GE завершена';en='Working with service RS.GE completed'") + ПолучитьСтрокуНомераТТННалоговой(ДокументПрихода);
		
	КонецЕсли;
	
КонецФункции

Функция ВыполнитьОтменуТТН(ДокументВизита, ЭтоВозврат) Экспорт 
	
