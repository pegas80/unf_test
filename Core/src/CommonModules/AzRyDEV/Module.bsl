КонецПроцедуры

Функция ПолучитьСтруктуруПроектаДокумента(Ссылка) Экспорт

	Ответ = ПроектДокумента(Ссылка);
	Если Ответ = Неопределено Тогда
		Возврат "{}";
	Иначе 	
		Возврат Новый Структура("ID, Key, Type, Name", Ответ.AzRyTempoObjectID, Ответ.AzRyTempoObjectKey, Строка(Ответ.AzRyTempoObjectType), Ответ.AzRyTempoObjectName);
	КонецЕсли; 

КонецФункции

// Основная функция - возвращает проект документа
Функция ПроектДокумента(Ссылка) Экспорт
	
	Проекты = ПроектыДокумента(Ссылка);
	
	Если Проекты = Неопределено ИЛИ Проекты.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Если найдено несколько разных проектов - это может быть ошибкой
	Если Проекты.Количество() > 1 И Константы.AzRyОстанавливатьОбменПриНесколькихПроектахВДокументе.Получить() Тогда
		// Можно добавить логирование или вызов исключения
		Сообщение = НСтр(
		"ru='В документе найдено несколько проектов!';" +
		"en='Multiple projects were found in the document!';" +
		"ka='დოკუმენტში აღმოჩენილია რამდენიმე პროექტი!'"
		);			
		ВызватьИсключение(Сообщение); 
	КонецЕсли;
	
	Возврат Проекты[0].Проект;
	
КонецФункции

// Возвращает таблицу значений со всеми уникальными проектами документа
Функция ПроектыДокумента(Ссылка) Экспорт
	
	ТекстЗапроса = ПостроитьЗапросПроектов(Ссылка);
	
	Если ТекстЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
	| ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВложенныйЗапрос.Проект КАК Проект
	| ИЗ
	|	(" + ТекстЗапроса + ") КАК ВложенныйЗапрос";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Попытка
		РезультатЗапроса = Запрос.Выполнить();
	Исключение
		// Логирование ошибки выполнения запроса
		ТекстОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации(
			"ПроектДокумента.Ошибка",
			УровеньЖурналаРегистрации.Ошибка,
			,
			Ссылка,
			"Ошибка получения проектов документа: " + ТекстОшибки
		);
		Возврат Неопределено;
	КонецПопытки;
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

// Построение текста запроса для поиска проектов в табличных частях
Функция ПостроитьЗапросПроектов(Ссылка)
	
	// Проверка входящего параметра
	Если Ссылка = Неопределено ИЛИ Ссылка.Пустая() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МетаданныеДокумента = Ссылка.Метаданные();
	ДокументИмя = МетаданныеДокумента.Имя;
	
	МассивЗапросов = Новый Массив;
	
	// Формирование запроса по всем табличным частям с реквизитом "Проект"
	Для каждого ТабличнаяЧасть Из МетаданныеДокумента.ТабличныеЧасти Цикл
		
		Если НЕ СодержитРеквизитПроект(ТабличнаяЧасть) Тогда
			Продолжить;
		КонецЕсли;
		
		ТекстПодзапроса = "
		| ВЫБРАТЬ
		|	ТабЧасть.Проект КАК Проект
		| ИЗ
		|	Документ." + ДокументИмя + "." + ТабличнаяЧасть.Имя + " КАК ТабЧасть
		| ГДЕ
		|	ТабЧасть.Ссылка = &Ссылка
		|	И ТабЧасть.Проект <> ЗНАЧЕНИЕ(Справочник.Проекты.ПустаяСсылка)";
		
		МассивЗапросов.Добавить(ТекстПодзапроса);
		
	КонецЦикла;
	
	// Если не найдено ни одной подходящей табличной части
	Если МассивЗапросов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Объединение всех подзапросов
	Возврат СтрСоединить(МассивЗапросов, "
	| ОБЪЕДИНИТЬ ВСЕ
	|");
	
КонецФункции

// Проверка наличия реквизита "Проект" в табличной части
Функция СодержитРеквизитПроект(ТабличнаяЧасть)
	
	Возврат (ТабличнаяЧасть.Реквизиты.Найти("Проект") <> Неопределено);
	
КонецФункции

// Альтернативный вариант: проверка через объект документа (без запросов)
Функция ПроектДокументаБезЗапроса(Ссылка) Экспорт
	
	Если Ссылка = Неопределено ИЛИ Ссылка.Пустая() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДокументОбъект = Ссылка.ПолучитьОбъект();
	
	Если ДокументОбъект = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МножествоПроектов = Новый Массив;
	
	Для каждого ТабличнаяЧасть Из Ссылка.Метаданные().ТабличныеЧасти Цикл
		
		Если НЕ СодержитРеквизитПроект(ТабличнаяЧасть) Тогда
			Продолжить;
		КонецЕсли;
		
		КоллекцияСтрок = ДокументОбъект[ТабличнаяЧасть.Имя];
		
		Для каждого Строка Из КоллекцияСтрок Цикл
			
			Если НЕ Строка.Проект.Пустая() И МножествоПроектов.Найти(Строка.Проект) = Неопределено Тогда
				МножествоПроектов.Добавить(Строка.Проект);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если МножествоПроектов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат МножествоПроектов[0];
	
КонецФункции