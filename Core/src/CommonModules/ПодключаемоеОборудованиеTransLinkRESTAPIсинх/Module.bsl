#Область ИтогиДняПоКартам
Функция ИтогиДняПоКартам(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	СписокСтрокСлипЧека = TransLinkRESTAPI.СоздатьСтрокиСлипЧека();
	
	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("Сумма", 0);
	ДанныеДокумента.Вставить("СуммаВозврата", 0);
	ТипОперации = TransLinkRESTAPI.posOperation_NOOPERATION();
	ДанныеДокумента.Вставить("posOperation", ТипОперации);
	
		
	РезультатОбработки1 = TransLinkRESTAPI.КомандаТерминалу_UNLOCKDEVICE(ДанныеДокумента, Параметры);	
	
	//РезультатСобытия = TransLinkRESTAPI.ПолучитьСобытиеОтТерминала_RestX(ВходныеПараметры, Параметры);
			
	
	РезультатОбработки = TransLinkRESTAPI.КомандаТерминалу_CLOSEDAY(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
	//РезультатОбработки2 =TransLinkRESTAPI.КомандаТерминалу_PRINTTOTALS(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);	
	
	ПолученныеСобытия = ПолучитьВсеСобытияОтТерминала(Параметры, "Ожидаем завершения транзакции");
    ОбработаемСобытияОтТерминала(ПолученныеСобытия, СписокСтрокСлипЧека, Параметры, "Ожидаем завершения транзакции");	
	Если ПолученныеСобытия.Получить("ONPRINT")<>Неопределено тогда
		СписокСтрокСлипЧека.Результат = истина;	
	ИначеЕсли ПолученныеСобытия.Получить("CANCEL")<>Неопределено тогда
		СписокСтрокСлипЧека.ПричинаОтмены = 
		"" + Параметры.TerminalAlias + "
		|Операция отменена оператором. Возможно в терминале имеются не закрытые документы. 
		|Закройте документы и повторите операцию.";
	КонецЕсли;	

	РезультатОбработки1 = TransLinkRESTAPI.КомандаТерминалу_LOCKDEVICE(Параметры);	
	
	
	Результат = РезультатОбработки.ОТВЕТ.Выполнен;	
	
	Если не ЗначениеЗаполнено(СписокСтрокСлипЧека.СлипОтХоста) ТОгда 
		СписокСтрокСлипЧека.СлипОтХоста = 
		"CLOSEDAY-operatiopn.
		|Result: " +  РезультатОбработки.TypeResult.resultCode + "
		|" +  РезультатОбработки.TypeResult.resultMessage + "
		|Time :" +  РезультатОбработки.TypeResult.resultTime;
	КонецЕсли;
	
	МассивСлипЧека = Новый Массив;
	МассивСлипЧека.Добавить("Слип-чек");    //0
	Если СписокСтрокСлипЧека.Результат Тогда
		МассивСлипЧека.Добавить(СписокСтрокСлипЧека.СлипОтХоста); //1 
	Иначе     
		МассивСлипЧека.Добавить(СписокСтрокСлипЧека.ПричинаОтмены); //1 
	КонецЕсли;	
	
	ВыходныеПараметры.Добавить(МассивСлипЧека); //0
	ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ПричинаОтмены); //1

	Возврат СписокСтрокСлипЧека.Результат;
	
КонецФункции

