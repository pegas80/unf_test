////////////////////////////////////////////////////////////////
#Область ПолучитьВерсиюДрайвера
// ფუნქცია აბრუნებს მოწყობილობის დრიავერის ვერსიას
// Функция возвращает версию установленного драйвера
//
Функция ПолучитьВерсиюДрайвера(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	Результат = Ложь;
	
	Если НЕ TransLinkRESTAPI.ПолученТокен(Параметры) Тогда
		СтруктураПодключение = TransLinkRESTAPI.КомандаТерминалу_OPENPOS(Параметры); 
	КонецЕсли;	
	
	Драйвера_Имя = "Не задан";
	Драйвер_Версия = "Не опреелена";
	
	СтруктураОтвета = TransLinkRESTAPI.КомандаТерминалу_GETSOFTWAREVERSION(Параметры);
	
	ТелоОтветаДанные = СтруктураОтвета.ОТВЕТ.ТелоОтветаДанные;
	Если ТипЗнч(ТелоОтветаДанные) = Тип("Структура") Тогда
		ТелоОтветаДанные.Свойство("CompatibleApiVersions", Драйвер_Версия);
		Если ТипЗнч(Драйвер_Версия) = Тип("Массив") тогда
			Драйвер_Версия = TransLinkRESTAPI.МассивВСтроку(Драйвер_Версия);
		КонецЕсли;	
		ТелоОтветаДанные.Свойство("ReleaseVersion", Драйвера_Имя);
	КонецЕсли;
	
	//УстройствоОтключено = ОтключитьУстройство(ОбъектДрайвера, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
	Результат = Истина;
		
		
	//СтруктураОтветаGETPOSSTATUS = TransLinkRESTAPI.КомандаТерминалу_GETPOSSTATUS(Параметры);
		
    ВыходныеПараметры.Добавить(Драйвера_Имя);
	ВыходныеПараметры.Добавить(Драйвер_Версия);
	ВыходныеПараметры.Добавить(Драйвер_Версия);
	
	Возврат Результат;
   
КонецФункции

#КонецОбласти //ПолучитьВерсиюДрайвера

