Функция ОтменитьПлатежаПоПлатежнойКарте_ActiveX(Объект, TerminalID, Сумма, СуммаДляВозврата, КодRRN, КодАвторизации,  СписокСтрокСлипЧека,КодОперации, COMПортФР, МетодОплаты = Неопределено, мRequest, мМассив, НомерСсылкы = "", ВидОплатыДляВозврата, TerminalAlias, ИспользоватьTranslinkДляТерминала) 
 
	Ответ = "";
	
	мRequest.OperatorID = "";
	мRequest.OperatorName = ""; 
	мRequest.Amount = СтрЗаменить(Формат(Сумма,"ЧГ=0"),",","");
	мRequest.CurrencyCode = "981";
	мRequest.AdditionalAmount = СтрЗаменить(Формат(СуммаДляВозврата,"ЧГ=0"),",","");
	мRequest.ReferenceNumber = НомерСсылкы;
	впCOMПортФР = ?(ЗначениеЗаполнено(COMПортФР), COMПортФР, 0);
	мRequest.ComPort = впCOMПортФР;	
	мRequest.InstallmentPayments = 0; 
	мRequest.InstallmentType = "CREDIT"; 
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias;	
	КонецЕсли;

	впSelected = Неопределено;	
	
	//мRequest.OperationCode = "4";	
	
	Если МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаMR") Тогда 
		мRequest.CurrencyCode = "102"; 
		Результат = Объект.NewCreditTenderWithCurrency(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
	ИначеЕсли МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаExpress") Тогда 
		мRequest.CurrencyCode = "EXP"; 
		Результат = Объект.NewCreditTenderWithCurrency(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
	ИначеЕсли МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаPlus") Тогда 
		мRequest.CurrencyCode = "PLS"; 
		Результат = Объект.NewCreditTenderWithCurrency(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
	ИначеЕсли МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.ОплатаБаламиТерминалаScool") Тогда 
		мRequest.CurrencyCode = "SCL"; 
		Результат = Объект.NewCreditTenderWithCurrency(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
	Иначе
		Результат = Объект.NewCreditTenderWithCurrency(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
	КонецЕсли;
	
	Если Результат И Сред(Ответ, 1, Найти(Ответ,";")-1) = "Select currency" Тогда 
		впМассив = ПолучитьВалютыДляВыбор(Ответ);		
		впВидОплатыПродажи = Сред(ВидОплатыДляВозврата, 1, Найти(ВидОплатыДляВозврата,"-")-2);
		
		Для Каждого Строка Из впМассив Цикл 
			
			Если Найти(Строка,впВидОплатыПродажи) <> Неопределено И Найти(Строка,впВидОплатыПродажи) > 0 Тогда  
				впSelected = Строка;
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
				
		мRequest.Selected = впSelected;
		Результат = Объект.Selected(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
		
		Если впSelected = Неопределено Тогда 
			//Возврат "დაბრუნება შეწყვეტილია.";
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;		
	
	
	
	Если НЕ Результат Тогда          			
		
		мТипТранзакции = "Отказ";
		
		Попытка
			TransLinkRESTAPI.СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "დაბრუნება", мRequest, впSelected);
			Ответ = TransLinkRESTAPI.Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
	
		//Возврат "შეცდომა ("+ Ответ +").";		
		Возврат Ложь;
	Иначе 
		TransLinkRESTAPI.СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "დაბრუნება", мRequest, впSelected);
	КонецЕсли;
			
	Возврат Истина;

КонецФункции
