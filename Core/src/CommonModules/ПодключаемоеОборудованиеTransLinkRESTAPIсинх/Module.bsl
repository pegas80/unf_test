#Область AuthorizeVoid

Функция AuthorizeVoid(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	СписокСтрокСлипЧека = TransLinkRESTAPI.СоздатьСтрокиСлипЧека();
	
	СуммаДокумента = ВходныеПараметры[0];
	СсылочныйНомер = ВходныеПараметры[1]; 
	НомерЧека = ?(ВходныеПараметры.Количество()>=3,ВходныеПараметры[2],"");
	
	СуммаДокументаОснования = СуммаДокумента; 
	
	Если Лев(СсылочныйНомер,1)="{" ТОгда
		СтруктураВозврата = TransLinkRESTAPI.ИзJSON_в_Данные1с(СсылочныйНомер);
		СуммаДокументаОснования = СтруктураВозврата.ИзначальнаяСумма;
		СсылочныйНомер = СтруктураВозврата.СсылочныйНомер;
	КонецЕсли;	
	
	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("Сумма", СуммаДокумента);
	ДанныеДокумента.Вставить("operationId", СсылочныйНомер);
	ДанныеДокумента.Вставить("posOperation", TransLinkRESTAPI.posOperation_NOOPERATION());
	СписокСтрокСлипЧека.Вставить("ДанныеДокумента", ДанныеДокумента); 
	
	РезультатОбработки = TransLinkRESTAPI.КомандаТерминалу_UNLOCKDEVICE(ДанныеДокумента, Параметры);	
	
	Если СуммаДокумента = СуммаДокументаОснования Тогда
		РезультатVOID = TransLinkRESTAPI.КомандаТерминалу_VOID(ДанныеДокумента, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
	Иначе     
		ДанныеДокумента.Вставить("СуммаПервоначальная", СуммаДокументаОснования);
		РезультатVOID = TransLinkRESTAPI.КомандаТерминалу_VOIDPARTIAL(ДанныеДокумента, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
	КонецЕсли;	

	//Ждем пока пройдет обмен с банком
	ПолученныеСобытия = ПолучитьВсеСобытияОтТерминала(Параметры, "Ожидаем завершения транзакции");
    ОбработаемСобытияОтТерминала(ПолученныеСобытия, СписокСтрокСлипЧека, Параметры, "Ожидаем завершения транзакции");	
	
	//Завершили операци. Блокируем POS
	РезультатОбработкиLOCKDEVICE = TransLinkRESTAPI.КомандаТерминалу_LOCKDEVICE(Параметры);	
						
	НомерЧека = "";
	Если не ЗначениеЗаполнено(СписокСтрокСлипЧека.СлипОтХоста) тогда
		СписокСтрокСлипЧека.СлипОтХоста = 
		"Печатная форма чека документа                                                     
		|Возврат по операции " + НомерЧека + " " + СписокСтрокСлипЧека.state + "
		|на сумму " + ДанныеДокумента.Сумма + " не сформировался
		|по причине " + СписокСтрокСлипЧека.ПричинаОтмены + "
		|";
	КонецЕсли;	
	
	Если СписокСтрокСлипЧека.Результат Тогда   
		МассивСлипчека = Новый Массив();
		МассивСлипчека.Добавить("СлипЧек");
		МассивСлипчека.Добавить(СписокСтрокСлипЧека.СлипОтХоста);
			
		ВыходныеПараметры.Добавить("****************"); //0
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ПричинаОтмены);              //1
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерЧекаЭТ);          //2
		ВыходныеПараметры.Добавить(МассивСлипчека); //3
		
	Иначе
		МассивСлипчека = Новый Массив();
		МассивСлипчека.Добавить("СлипЧек");
		МассивСлипчека.Добавить(СписокСтрокСлипЧека.ПричинаОтмены);
	
		ВыходныеПараметры.Добавить(); //0
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ПричинаОтмены); //1
	КонецЕсли;
	
	Возврат СписокСтрокСлипЧека.Результат;

КонецФункции

Функция УдалитьПлатежаПоПлатежнойКарте(Объект, СписокСтрокСлипЧека, TerminalID, OperationID, мRequest, мМассив, TerminalAlias, ИспользоватьTranslinkДляТерминала)
	
	Ответ = "";
	мRequest.OperatorID = "";
	мRequest.OperatorName = ""; 
	мRequest.OperationID = OperationID; 
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias; 
	КонецЕсли;

	Результат = Объект.NewVoid(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
	
	Если НЕ Результат Тогда          			
		мТипТранзакции = "Отказ";
		
		Попытка
			TransLinkRESTAPI.СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "გადახდა", мRequest);
			Ответ = TransLinkRESTAPI.Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
	
		//Возврат "შეცდომა ("+ Ответ +").";	
		Возврат Ложь;
		
	иначе
		TransLinkRESTAPI.СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "დაბრუნება", мRequest);
		
		Если Не ЗначениеЗаполнено(мRequest.ReceiptData) Тогда 
			//Возврат "შეცდომა ("+"ვერ მოხერხდა ტრანზაქციის გაუქმება. Wrong card!"+").";	
			Сообщить("შეცდომა ("+"ვერ მოხერხდა ტრანზაქციის გაუქმება. Wrong card!"+").");
			Возврат Ложь;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Истина;
	
	
КонецФункции


#КонецОбласти

Функция CloseDoc(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	Результат = Ложь;
	СписокСтрокСлипЧека = TransLinkRESTAPI.СоздатьСтрокиСлипЧека();
	
	Если не TransLinkRESTAPI.ПолученТокен(Параметры) Тогда
		TransLinkRESTAPI.КомандаТерминалу_OPENPOS(Параметры);
	КонецЕсли;	
	
	Если TransLinkRESTAPI.ПолученТокен(Параметры) Тогда
		
			
		ДанныеДокумента = Новый Структура;
		ДанныеДокумента.Вставить("Сумма", 0);
		ДанныеДокумента.Вставить("posOperation", TransLinkRESTAPI.posOperation_NOOPERATION());
		
		СписокСтрокСлипЧека.Вставить("ДанныеДокумента", ДанныеДокумента); 
		
		РезультатОбработки = TransLinkRESTAPI.КомандаТерминалу_UNLOCKDEVICE(ДанныеДокумента, Параметры);	
		
		
		
		МассивОпераций = Новый Массив;
		МассивОпераций.Добавить(ВходныеПараметры.СсылочныйНомер);
		
		ПараметрыКомандыТерминала = Новый Структура;
		ПараметрыКомандыТерминала.Вставить("operations", МассивОпераций); 
		ПараметрыКомандыТерминала.Вставить("documentNr", ВходныеПараметры.НомерЧека); 
		
		//Закроем документ на POS
		РезультатОбработкиCLOSEDOC = TransLinkRESTAPI.КомандаТерминалу_CLOSEDOC(ПараметрыКомандыТерминала, Параметры);	
		
		Если РезультатОбработкиCLOSEDOC.TypeResult.resultCode = "OK" Тогда
			Результат = Истина;
			СписокСтрокСлипЧека.ПричинаОтмены = "";
		Иначе
			СписокСтрокСлипЧека.ПричинаОтмены = РезультатОбработкиCLOSEDOC.TypeResult.resultMessage;
		КонецЕсли;	
		
		РезультатОбработки_LOCKDEVICE = TransLinkRESTAPI.КомандаТерминалу_LOCKDEVICE(Параметры);	
	Иначе
		СписокСтрокСлипЧека.ПричинаОтмены = "Не авторизован.";
	КонецЕсли;
	
	
	ВыходныеПараметры.Добавить(999);
	ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ПричинаОтмены);
	
	Возврат Результат;
	
КонецФункции

