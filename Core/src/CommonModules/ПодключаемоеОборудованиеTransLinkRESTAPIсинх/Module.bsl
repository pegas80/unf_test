	СписокСтрокСлипЧека.Вставить("КодОтветаХоста",						мRequest.ResponseCodeHost);
	СписокСтрокСлипЧека.Вставить("НомерСсылкы",							мRequest.ReferenceNumber);
	СписокСтрокСлипЧека.Вставить("НомерКарты",							мRequest.PAN);
	СписокСтрокСлипЧека.Вставить("ОписаниеОтветаХоста",					TransLinkRESTAPI.Кодировка(мRequest.TextResponse));
	СписокСтрокСлипЧека.Вставить("Операция",							Операция);
	СписокСтрокСлипЧека.Вставить("СлипОтХоста",							TransLinkRESTAPI.Кодировка(мRequest.ReceiptData));
	СписокСтрокСлипЧека.Вставить("ВидОплатыДляВозврата",				ВидОплатыДляВозврата);
	СписокСтрокСлипЧека.Вставить("КодОперацииЭС",				        мRequest.OperationID);
	
