Функция КраткийОтчет(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	СписокСтрокСлипЧека = TransLinkRESTAPI.СоздатьСтрокиСлипЧека();

	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("Сумма", 0);
	ДанныеДокумента.Вставить("СуммаВозврата", 0);
	ТипОперации = TransLinkRESTAPI.posOperation_NOOPERATION();
	ДанныеДокумента.Вставить("posOperation", ТипОперации);
	
	РезультатОбработки1 = TransLinkRESTAPI.КомандаТерминалу_UNLOCKDEVICE(ДанныеДокумента, Параметры);	
	
	РезультатОтвета = TransLinkRESTAPI.КомандаТерминалу_PRINTTOTALS(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
	
	
	ПолученныеСобытия = ПолучитьВсеСобытияОтТерминала(Параметры, "Ожидаем завершения транзакции");
    ОбработаемСобытияОтТерминала(ПолученныеСобытия, СписокСтрокСлипЧека, Параметры, "Ожидаем завершения транзакции");	
	Если ПолученныеСобытия.Получить("ONPRINT")<>Неопределено тогда
		СписокСтрокСлипЧека.Результат = истина;	
	КонецЕсли;
	
	
	//Если РезультатОтвета.TypeResult.resultCode = TransLinkRESTAPI.TypeResult_OK() Тогда 
	//	//Ждем, пока пользователь получит ответ
