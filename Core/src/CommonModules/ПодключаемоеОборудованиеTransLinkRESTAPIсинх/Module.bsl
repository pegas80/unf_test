#Область AuthorizeSales

Функция AuthorizeSales(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)
	
	ДанныеДокумента = Новый Структура;
	ДанныеДокумента.Вставить("Сумма", ВходныеПараметры[0]);
	ДанныеДокумента.Вставить("СуммаВозврата", 0);
	ДанныеДокумента.Вставить("posOperation", TransLinkRESTAPI.posOperation_AUTHORIZE());
	
    Результат = ЗапустимПроцедуруРаботыСТерминалом(ДанныеДокумента, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры );
	
	Возврат Результат;
	
КонецФункции

Процедура ОбработаемСобытияОтТерминала(ПолученныеСобытия, СписокСтрокСлипЧека, Параметры, СтрокаСообщенияОжижания)
	
	//Обрабатываем результат
	eventType = ПолученныеСобытия.Получить("CANCEL");
	Если eventType<>Неопределено Тогда 
		СписокСтрокСлипЧека.ПричинаОтмены = "Операция отменена оператором";
		//Возврат;
	КонецЕсли;
	
	eventType = ПолученныеСобытия.Получить("ONCARD");
	Если eventType<>Неопределено Тогда 
		СписокСтрокСлипЧека.КартаПредоставлена = Истина;
		СписокСтрокСлипЧека.КартаДействительна = eventType.properties.allowAuthorize;
		СписокСтрокСлипЧека.НомерКарты = eventType.properties.PAN;
		Если СписокСтрокСлипЧека.КартаДействительна = Ложь Тогда
	    	СписокСтрокСлипЧека.ПричинаОтмены = "Карта не действительна.";
		КонецЕсли;	
	КонецЕсли;					
			
	
	eventType = ПолученныеСобытия.Получить("ONCARDREMOVE");
	Если eventType<>Неопределено Тогда    
		СписокСтрокСлипЧека.КартаПредоставлена = Ложь;
		СписокСтрокСлипЧека.ПричинаОтмены = "Карта не представлена.";
	КонецЕсли;
	
	
	
	//получена печатная форма чека
	eventType = ПолученныеСобытия.Получить("ONPRINT");	
	Если eventType<>Неопределено Тогда
		СписокСтрокСлипЧека.СлипОтХоста = eventType.properties.receiptText; 
	КонецЕсли;
	
	//Получено состояние транзакции
	eventType = ПолученныеСобытия.Получить("ONTRNSTATUS");	
	Если eventType<>Неопределено Тогда
		СписокСтрокСлипЧека.state  = eventType.properties.state;
		
		TransLinkRESTAPI.ЗаполнитьСписокСтрокСлипЧекаПоСтатусуТерминала(СписокСтрокСлипЧека, eventType, Параметры);
		
			
		//ВходныеПараметры.Вставить("параметрыКоманды", ПараметрыКомандыТерминала);
		
			
		СписокСтрокСлипЧека.Результат = (СписокСтрокСлипЧека.state = "Approved");
		Если не СписокСтрокСлипЧека.Результат Тогда
			СписокСтрокСлипЧека.ПричинаОтмены = "статус транзакции " + СписокСтрокСлипЧека.state;
		ИначеЕсли ЗначениеЗаполнено(eventType.properties.documentNr) Тогда 
			
			МассивОпераций = Новый Массив;
			МассивОпераций.Добавить(СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
			
			
			ПараметрыКомандыТерминала = Новый Структура;
			ПараметрыКомандыТерминала.Вставить("operations", МассивОпераций); 
			ПараметрыКомандыТерминала.Вставить("documentNr", eventType.properties.documentNr); 
			//Закроем документ на POS
			РезультатОбработкиCLOSEDOC = TransLinkRESTAPI.КомандаТерминалу_CLOSEDOC(ПараметрыКомандыТерминала, Параметры);	
			
		КонецЕсли;	
		
	КонецЕсли;
	
	Если Параметры.Отладка Тогда
		Сообщить(СтрокаСообщенияОжижания);
		Сообщить("Получено событий "+ ПолученныеСобытия.Количество());	
		Для каждого ЭлементСобытия из ПолученныеСобытия Цикл
			Сообщить("  " + ЭлементСобытия.Ключ);	
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

Функция ПолучитьВсеСобытияОтТерминала(Параметры, СтрокаСообщенияОжидания)
	
	ПолученыДанные = Новый Соответствие;
	//Получим одно из ключевых событий
	Пока 
		ПолученыДанные.Получить("ONCARD")=Неопределено 
		и ПолученыДанные.Получить("ONCARDREMOVE")=Неопределено 
		и ПолученыДанные.Получить("ONPRINT")=Неопределено 
		и ПолученыДанные.Получить("ONTRNSTATUS")=Неопределено 
		и ПолученыДанные.Получить("CANCEL")=Неопределено //Если нажали отмену
		Цикл             
	
		РезультатСобытия = ОжидаемСобытияОтТерминала(Параметры, СтрокаСообщенияОжидания);
		eventType = РезультатСобытия.eventType;
		
		eventName = eventType.eventName;
		
		ПолученыДанные.Вставить(eventName, eventType); 

	    Если Параметры.Отладка ТОгда
			Сообщить("Возникло событие1 " + eventName);
		КонецЕсли;	
			
	КонецЦикла;                                                                                
	
	НомерСобытия = ПолученыДанные.Количество();
	
	//Прочитать остальные события, чтобы очередь стала пустая
	Пока Истина Цикл
		НомерСобытия = НомерСобытия + 1;
		
		РезультатСобытия = ОжидаемСобытияОтТерминала(Параметры, "Получаем остальные события " + НомерСобытия,,Истина);	
		
		eventType = РезультатСобытия.eventType;
		eventName = eventType.eventName;
		
		Если eventName = Null или eventName = Неопределено Тогда
			Прервать;	
		Иначе     
			ПолученыДанные.Вставить(eventName, eventType); 
			Если Параметры.Отладка ТОгда
				Сообщить("Возникло событие1 " + eventName);			
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	
	Возврат ПолученыДанные;
	
КонецФункции		
		
	

Функция ЗапустимПроцедуруРаботыСТерминалом(ДанныеДокумента, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры )
	
	СписокСтрокСлипЧека = TransLinkRESTAPI.СоздатьСтрокиСлипЧека();
	ДанныеДокумента.Вставить("documentNr", TransLinkRESTAPI.ПолучитьПроизвольныйНомерДокументаСтрокой()); 
	СписокСтрокСлипЧека.Вставить("ДанныеДокумента", ДанныеДокумента);
	СписокСтрокСлипЧека.Вставить("НомерЧекаЭТ", ДанныеДокумента.documentNr);
	
	//разблокировку POS, для выполнения последующих операций
	РезультатОбработки = TransLinkRESTAPI.КомандаТерминалу_UNLOCKDEVICE(ДанныеДокумента, Параметры);	
	
	//Ждем, пока пользователь оплатит или откажется
	ПолученныеСобытия = ПолучитьВсеСобытияОтТерминала(Параметры, "Ожидаем прикладывания карты");
    ОбработаемСобытияОтТерминала(ПолученныеСобытия, СписокСтрокСлипЧека, Параметры, "Ожидаем прикладывания карты");	
	
	//Если СписокСтрокСлипЧека.КартаПредоставлена Тогда
	//	Если СписокСтрокСлипЧека.КартаДействительна Тогда               
			
			//Отправляем запрос в банк на подтверждение
			РезультатКомандыОперации = TransLinkRESTAPI.КомандаТерминалуНачатьДействие(ДанныеДокумента, ВходныеПараметры, Параметры);	
			
			ПолученныеСобытия = ПолучитьВсеСобытияОтТерминала(Параметры, "Ожидаем завершения транзакции");
   			ОбработаемСобытияОтТерминала(ПолученныеСобытия, СписокСтрокСлипЧека, Параметры, "Ожидаем завершения транзакции");	
	
	//	КонецЕсли;
		
	//КонецЕсли;	
	
	//Завершили операци. Блокируем POS
	РезультатОбработкиLOCKDEVICE = TransLinkRESTAPI.КомандаТерминалу_LOCKDEVICE(Параметры);	
						
	
	Тестируем = Ложь;
	Если Тестируем ТОгда
		РезультатСобытияONTRNSTATUS = ПолучитьТекстФайла("D:\TEMP\ответ о статусе документа.txt");
		//ЗаполнитьСписокСтрокСлипЧекаПоСтатусуТерминала(СписокСтрокСлипЧека, РезультатСобытияONTRNSTATUS.eventType, Параметры, ДанныеДокумента.posOperation);
		
	КонецЕсли;
	
	//СсылочныйНомер = ИдентификаторОперации; //СписокСтрокСлипЧека.НомерСсылкы;
	
	Если не ЗначениеЗаполнено(СписокСтрокСлипЧека.СлипОтХоста) тогда
		СписокСтрокСлипЧека.СлипОтХоста = 
		"Печатная форма чека документа 
		|на сумму " + ДанныеДокумента + " не сформировался
		|по причине " + СписокСтрокСлипЧека.ПричинаОтмены + "
		|";
	КонецЕсли;	
	
	КодАвторизации = СписокСтрокСлипЧека.КодАвторизации;
	
	Если СписокСтрокСлипЧека.Результат Тогда
			
		//ВыходныеПараметры.Добавить("****************");
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерКарты); //0
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.СсылочныйНомер);  //1
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерЧекаЭТ); //2
		ВыходныеПараметры.Добавить(Новый Массив()); //3
		ВыходныеПараметры[3].Добавить("СлипЧек");
		ВыходныеПараметры[3].Добавить(СписокСтрокСлипЧека.СлипОтХоста);
		ВыходныеПараметры.Добавить(КодАвторизации);  //4
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
	Иначе
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерКарты);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ПричинаОтмены);
		
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
		ВыходныеПараметры.Добавить(Новый Массив());
		ВыходныеПараметры[3].Добавить("СлипЧек");
		ВыходныеПараметры[3].Добавить(СписокСтрокСлипЧека.СлипОтХоста);
		ВыходныеПараметры.Добавить(КодАвторизации);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
		
	КонецЕсли;
	
	Возврат СписокСтрокСлипЧека.Результат;
		
КонецФункции	


Функция ОжидаемСобытияОтТерминала(Параметры, СтрокаСообщения="", БесконечныйЦикл = Истина, ПрерватьсяНаПустомСобытии = Ложь)
	
	Результат = Неопределено;
	РезультатПолучен = Ложь;

	ВремяОжиданияКарты = Параметры.ВремяОжиданияКарты;
	ПредлагатьПовторитьОперациюОжидания = Параметры.ПредлагатьПовторитьОперациюОжидания;
	
	Если ВремяОжиданияКарты = 0 Тогда
		ВремяОжиданияКарты = 30;
	КонецЕсли;	      
	
	ДатаОкончания = ТекущаяДата() + ВремяОжиданияКарты;
	
	Пока РезультатПолучен = Ложь Цикл
		ТекстСообщения = 
		"" + Параметры.TerminalAlias + "
		|" + СтрокаСообщения + "
		|";
		ФормаЗаставка =	ОткрытьФорму("ОбщаяФорма.ДлительнаяОперация",
			Новый Структура("ИдентификаторЗадания, ТекстСообщения", Неопределено, ТекстСообщения), 
			Неопределено);

		ТекДата = ТекущаяДата(); 
		
		Пока Истина Цикл
			
			МенеджерОборудованияКлиент.Пауза(1);
			
			РезультатСобытия = TransLinkRESTAPI.ПолучитьСобытиеОтТерминала_RestX(Параметры);
			
			eventName = "";
			Если ЗначениеЗаполнено(РезультатСобытия.eventType.eventName) Тогда
				РезультатСобытия.eventType.Свойство("eventName", eventName);

			ИначеЕсли ПрерватьсяНаПустомСобытии тогда
				РезультатПолучен = Истина; 
				Результат = РезультатСобытия;
				прервать;
				//Возврат Результат;
				
			КонецЕсли;	
			
			Если ЗначениеЗаполнено(eventName) Тогда                                                       
				РезультатПолучен = Истина; 
				Результат = РезультатСобытия;
				Прервать;
			КонецЕсли;
			
			ТекДата = ТекущаяДата();
			Если ТекДата > ДатаОкончания Тогда
				//Сообщить("Закончилось время ожидания");
				Прервать;
			КонецЕсли;
			
		КонецЦикла;
		
		ФормаЗаставка.Закрыть();
		
		Если не РезультатПолучен Тогда                                                                                  
			КнопкаПоУмолчанию = КодВозвратаДиалога.Да;			
			Если БесконечныйЦикл = Ложь ТОгда
				КнопкаПоУмолчанию = КодВозвратаДиалога.Нет;			
			КонецЕсли;
			
			РезультатОтветаПродолжить = КодВозвратаДиалога.Нет;
			Если ПредлагатьПовторитьОперациюОжидания = Истина Тогда			
				РезультатОтветаПродолжить = Вопрос("Повторить ожидание?",РежимДиалогаВопрос.ДаНет,10,,Параметры.TerminalAlias,КнопкаПоУмолчанию);
			КонецЕсли;
			
			Если РезультатОтветаПродолжить = КодВозвратаДиалога.Нет ТОгда
				Результат = РезультатСобытия;
				РезультатСобытия.eventType.eventName = "CANCEL";
				//РезультатСобытия.eventType.eventMessage = "Отменено оператором.";
				прервать; 
			Иначе
				ДатаОкончания = ТекущаяДата() + ВремяОжиданияКарты;
			КонецЕсли;	
		КонецЕсли;	
		
	КонецЦикла;	
	
	Возврат Результат;
	
КонецФункции	

Функция AuthorizeSales_ActiveX(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры)

	мТипТранзакции = "Оплата";
	
    TerminalID = Параметры.TerminalID;
    TerminalAlias = Параметры.TerminalAlias;
    ИспользоватьTranslinkДляТерминала = Ложь;
	Параметры.Свойство("ИспользоватьTranslinkДляТерминала",ИспользоватьTranslinkДляТерминала);  //Малышев 2024-07-24
	Сумма = ВходныеПараметры.Сумма;
	КодОперации = Неопределено;
	КодRRN = Неопределено;
	КодАвторизации = ВходныеПараметры.КодАвторизации;
	COMПортФР = Параметры.Порт;
	//COMПортФР = "";
	СписокСтрокСлипЧека = Новый Структура;
	МетодОплаты = ВходныеПараметры.МетодОплаты;
	мRequest = ВходныеПараметры.мRequest;
	мRequest.TerminalID = TerminalID;  
	
	Если ИспользоватьTranslinkДляТерминала Тогда 
		мRequest.TerminalAlias = TerminalAlias;  
	КонецЕсли;

	мМассив = ВходныеПараметры.мМассив;
	ПериодРасрочки = ВходныеПараметры.ПериодРасрочки;
	CashbackAmount = ВходныеПараметры.CashbackAmount;
	
	СуммаВременная = Неопределено;
	
	КодКарты       = Неопределено;
	СсылочныйНомер = Неопределено;
	НомерЧека      = Неопределено;
	СлипЧек = Неопределено;
	
	Ответ = "";
	Результат = ОплатитьПлатежнойКартой_ActiveX(ОбъектДрайвера, TerminalID, СтрЗаменить(Формат(Сумма + CashbackAmount,"ЧДЦ=2; ЧРД=,; ЧГ="),",",""), КодRRN, КодАвторизации,  СписокСтрокСлипЧека, КодОперации, COMПортФР, МетодОплаты, мRequest, мМассив, ПериодРасрочки, TerminalAlias, СтрЗаменить(Формат(CashbackAmount,"ЧДЦ=2; ЧРД=,; ЧН=0; ЧГ="),",",""), ИспользоватьTranslinkДляТерминала,Ответ);
	
	Если Результат Тогда
		
		СсылочныйНомер = СписокСтрокСлипЧека.НомерСсылкы;
		КодАвторизации = СписокСтрокСлипЧека.КодАвторизации;
		
		//ВыходныеПараметры.Добавить("****************");
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерКарты);
		ВыходныеПараметры.Добавить(СсылочныйНомер);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
		ВыходныеПараметры.Добавить(Новый Массив());
		ВыходныеПараметры[3].Добавить("СлипЧек");
		ВыходныеПараметры[3].Добавить(СписокСтрокСлипЧека.СлипОтХоста);
		ВыходныеПараметры.Добавить(КодАвторизации);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
	Иначе
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.НомерКарты);
		ВыходныеПараметры.Добавить(Ответ);
		
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека.ИдентификаторОперацииНаТерминале);
		ВыходныеПараметры.Добавить(Новый Массив());
		ВыходныеПараметры[3].Добавить("СлипЧек");
		ВыходныеПараметры[3].Добавить(СписокСтрокСлипЧека.СлипОтХоста);
		ВыходныеПараметры.Добавить(КодАвторизации);
		ВыходныеПараметры.Добавить(СписокСтрокСлипЧека);
		
		
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

Функция ОплатитьПлатежнойКартой_ActiveX(Объект, TerminalID, Сумма, КодRRN, КодАвторизации,  СписокСтрокСлипЧека,КодОперации, COMПортФР, МетодОплаты = Неопределено, мRequest, мМассив, ПериодРасрочки = Неопределено, TerminalAlias, CashbackAmount, ИспользоватьTranslinkДляТерминала,Ответ) 
 
	Ответ = "";
	мRequest.OperatorID = "";
	мRequest.OperatorName = ""; 
	мRequest.Amount = СтрЗаменить(Формат(Сумма,"ЧГ=0"),",","");
	мRequest.CurrencyCode = "981"; 
	мRequest.InstallmentPayments = ПериодРасрочки; 
	мRequest.InstallmentType = ""; 	
	впSelected = Неопределено;
	//мRequest.TerminalID = "";               	       	
    //мRequest.ComPort = COMПортФР; 
	
	Результат = Объект.NewBonusTender(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);  	
	
	Если Результат И Сред(Ответ, 1, Найти(Ответ,";")-1) = "Select currency" Тогда 
		впМассив = ПолучитьВалютыДляВыбор(Ответ);
		впФорма = ПолучитьФорму("ОбщаяФорма.ФормаСписокОплат_AXConnect");
		
		Для Каждого Строка Из впМассив Цикл 
			НовСтрока = впФорма.ЭквайринговыхТерминалов.Добавить();	
			НовСтрока.ВидОплаты = Строка; 	
		КонецЦикла;
		
		Если МетодОплаты = ПредопределенноеЗначение("Перечисление.МетодыОплаты.РасрочкаТерминала") Тогда 
			впSelected = впМассив[0];
		Иначе 
			впSelected = впФорма.ОткрытьМодально();
		КонецЕсли;
	
		мRequest.Selected = впSelected;
		Результат = Объект.Selected(TransLinkRESTAPI.СтрокаДляТерминала(мRequest), Ответ);
		
		Если впSelected = Неопределено Тогда 
			//Возврат "გადახდა შეწყვეტილია.";
			Возврат Ложь;
		КонецЕсли;

	КонецЕсли;	
	
	Если НЕ Результат Тогда          			
		
		мТипТранзакции = "Отказ";
		
		Попытка
			TransLinkRESTAPI.СтрокаОтТерминала(Ответ, мRequest, мМассив);
			ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "გადახდა", мRequest, впSelected);
			Ответ = TransLinkRESTAPI.Кодировка(мRequest.TextResponse);
		Исключение
		КонецПопытки;
	
		//Возврат "შეცდომა ("+ Ответ +").";		
		Возврат Ложь;
	Иначе 
		TransLinkRESTAPI.СтрокаОтТерминала(Ответ, мRequest, мМассив);
		ПолучитьСтрокиСлипЧека(Объект, СписокСтрокСлипЧека, "გადახდა", мRequest, впSelected);
	КонецЕсли;
	
	Возврат Истина;

