КонецПроцедуры

// Функция создает файл с командами для передачи на фискальный принтер
//
// Параметры:
//  Параметры   - Настройки для подключённого оборудования
//
// Возвращаемое значение:
//  <Булево> - Результат работы функции.
//
Функция СоздатьКоммандныйФайл(Параметры, МассивСКомандами, СтрокаЛога)
	Результат = Ложь;
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	
	//{R&K, ltd - Москаленко А.В.(21.10.2015)
	// 
	//R&K, ltd}
	
	
	Для Каждого Эл Из МассивСКомандами Цикл
		ТекстовыйДокумент.ДобавитьСтроку(Эл);		
	КонецЦикла;
	Попытка
		// Если это печать чека и нужно получать ответ от ФС
		Если Параметры.ВыполняемаяКоманда = "PrintReceipt" И Параметры.Свойство("ПолучатьОтветОтФС") И Параметры.ПолучатьОтветОтФС Тогда 
			Результат = Ложь;
			
			Попытка
				ПереместитьФайл(Параметры.КаталогСДаннымиЧеков +  Параметры.ИмяФайлаОтвета
									, Параметры.КаталогСДаннымиЧеков + "__PreDeletion__" + Формат(ТекущаяДата(),"ДФ=yyyyMMdd_HHmmss") + "_" +  Параметры.ИмяФайлаОтвета);
			Исключение
			КонецПопытки;
			
			ТекстовыйДокумент.Записать(Параметры.КаталогСДаннымиЧеков + Параметры.ИмяФайла);
			
			ФормаОбработки = ПолучитьФорму("Обработка.ОПТИМУС_ПечатьФискальныхЧеков.Форма.ФормаПечатьФискальногоЧека", Новый Структура("НастройкиФС", Параметры));
			
			ОтветФормы = ФормаОбработки.ОткрытьМодально();
			Результат = (ОтветФормы <> Неопределено) И (Не ОтветФормы.ОшибкаОперации);
			
			// Если файл был сформирован при работе то переименуем его
			Если (ОтветФормы <> Неопределено) И ОтветФормы.ФайлСуществует Тогда 
				ПереместитьФайл(Параметры.КаталогСДаннымиЧеков +  Параметры.ИмяФайлаОтвета
									, Параметры.КаталогСДаннымиЧеков + Формат(ТекущаяДата(),"ДФ=yyyyMMdd_HHmmss") + "_" +  Параметры.ИмяФайлаОтвета);
			КонецЕсли;
		Иначе
			// просто печатаем что пришло и ответа не ждём
			
			//{R&K, ltd - Москаленко А.В.(21.10.2015)
			//ТекстовыйДокумент.Записать(Параметры.КаталогСДаннымиЧеков + Параметры.ИмяФайла);
			//нужно записать файл в формате аски
			ТекстовыйДокумент.Записать(Параметры.КаталогСДаннымиЧеков + Параметры.ИмяФайла, КодировкаТекста.ANSI);

			//R&K, ltd}
			
			Результат = Истина;
		КонецЕсли;		
	Исключение
		ОписаниеОшибки = ИнформацияОбОшибке();
		СтрокаЛога = СтрокаЛога
		+ Символы.ПС + ?(ОписаниеОшибки.Причина = Неопределено, ОписаниеОшибки.Описание ,ОписаниеОшибки.Причина.Описание);
	КонецПопытки;
Возврат Результат;
КонецФункции

// Печать чека ККМ на обычном принтере
Процедура ПечатьНаПринтерЧекККМ(ВходныеПараметры = Неопределено, ВыходныеПараметры = Неопределено, Параметры, ПараметрыПодключения)
	// Если для фискального регистратора установлен параметр печати чека на обычном принтере и пробитие фискального чека было удачно напечатаем чек на обычном принтере
	Если Параметры.ПечататьНаОбычныйПринтер Тогда 
		Попытка
			МассивПараметров = Новый Массив();
			МассивПараметров.Добавить(ПредопределенноеЗначение("Документ.ЧекККМ.ПустаяСсылка"));
			Структура = Новый Структура("ДанныеЧека, Параметры,", ВходныеПараметры, Параметры);
			УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер("Обработка.ОПТИМУС_ПечатьФискальныхЧеков", "ЧекККМ", МассивПараметров, Структура);
		Исключение
			ОписаниеОшибки = ИнформацияОбОшибке();
			ОшибкаПриПечати = ?(ОписаниеОшибки.Причина = Неопределено, ОписаниеОшибки.Описание ,ОписаниеОшибки.Причина.Описание);
			Сообщить(ОшибкаПриПечати);
		КонецПопытки;
	КонецЕсли;	
КонецПроцедуры

