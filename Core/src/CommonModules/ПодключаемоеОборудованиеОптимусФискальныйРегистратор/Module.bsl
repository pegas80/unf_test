		Исключение
			ОписаниеОшибки = ИнформацияОбОшибке();
			ОшибкаПриПечати = ?(ОписаниеОшибки.Причина = Неопределено, ОписаниеОшибки.Описание ,ОписаниеОшибки.Причина.Описание);
			Сообщить(ОшибкаПриПечати);
		КонецПопытки;
	КонецЕсли;	
КонецПроцедуры


