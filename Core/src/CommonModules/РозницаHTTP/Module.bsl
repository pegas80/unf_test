			РЕЗ.Описание = "Internal processing error";
		КонецПопытки;
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = OptionCode;
		РЕЗ.Описание = "Product not found";		
		
