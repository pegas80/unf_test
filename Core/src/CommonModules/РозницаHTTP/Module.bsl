	ПоУмолчанию = Справочники.ПараметрыДляОбменаДаннымиРозницаHTTP.ПоУмолчанию;
	
	РЕЗ = Новый Структура("ВсеПравильно",ИСТИНА);
	РЕЗ.Вставить("Автор",ПоУмолчанию.Автор);
	РЕЗ.Вставить("Организация",ПоУмолчанию.Организация);
	РЕЗ.Вставить("ВалютаРасчетов",ПоУмолчанию.ВалютаРасчетов);
