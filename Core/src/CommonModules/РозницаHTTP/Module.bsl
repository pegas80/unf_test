Функция УдалитьНоменклатуру(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("OptionCode");
	ЗначениеПараметра = СокрЛП(ЗначениеПараметра);
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
