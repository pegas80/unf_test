#Область СлужебныеПроцедурыИФункции
Процедура СформироватьДеревоJSON(ЧтениеJSON, Дерево) ЭКСПОРТ
    
    ИмяСвойства = НЕОПРЕДЕЛЕНО;
	
    Пока ЧтениеJSON.Прочитать() Цикл
        TипJSON = ЧтениеJSON.ТипТекущегоЗначения;
        
        Если TипJSON = ТипЗначенияJSON.НачалоОбъекта ИЛИ TипJSON = ТипЗначенияJSON.НачалоМассива Тогда
			
			НовыйОбъект = ?(TипJSON = ТипЗначенияJSON.НачалоОбъекта, Новый Соответствие, Новый Массив);
			
			Если Дерево = НЕОПРЕДЕЛЕНО Тогда
                Дерево = НовыйОбъект;
				СформироватьДеревоJSON(ЧтениеJSON, Дерево);
			Иначе
				Если ТипЗнч(Дерево) = Тип("Массив") Тогда
	                Дерево.Добавить(НовыйОбъект);
					СформироватьДеревоJSON(ЧтениеJSON, НовыйОбъект);
				Иначе
					Если ТипЗнч(Дерево) = Тип("Соответствие") И ЗначениеЗаполнено(ИмяСвойства) Тогда
						Дерево.Вставить(ИмяСвойства, НовыйОбъект);
						СформироватьДеревоJSON(ЧтениеJSON, НовыйОбъект);
					Иначе
						Дерево = НовыйОбъект;
						СформироватьДеревоJSON(ЧтениеJSON, Дерево);
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли TипJSON = ТипЗначенияJSON.ИмяСвойства Тогда
			
            ИмяСвойства = ЧтениеJSON.ТекущееЗначение;
			
			Если Дерево = НЕОПРЕДЕЛЕНО Тогда
				Дерево = Новый Соответствие;
			КонецЕсли;
			
		ИначеЕсли TипJSON = ТипЗначенияJSON.Число ИЛИ TипJSON = ТипЗначенияJSON.Строка ИЛИ TипJSON = ТипЗначенияJSON.Булево ИЛИ TипJSON = ТипЗначенияJSON.Null Тогда
			
            Если ТипЗнч(Дерево) = Тип("Массив") Тогда
                Дерево.Добавить(ЧтениеJSON.ТекущееЗначение);
            ИначеЕсли ТипЗнч(Дерево) = Тип("Соответствие") Тогда
                Дерево.Вставить(ИмяСвойства, ЧтениеJSON.ТекущееЗначение);
			КонецЕсли;
			
		Иначе
			
            Возврат;
			
        КонецЕсли;
    КонецЦикла;
    
КонецПроцедуры

Функция ДатаJSON(Date) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = НЕОПРЕДЕЛЕНО;
	
	Попытка
		РЕЗ = ПрочитатьДатуJSON(Date, ФорматДатыJSON.ISO);
	Исключение
		Попытка
			РЕЗ = ПрочитатьДатуJSON(Date, ФорматДатыJSON.JavaScript);
		Исключение
			Попытка
				РЕЗ = ПрочитатьДатуJSON(Date, ФорматДатыJSON.Microsoft);
			Исключение
				РЕЗ = НЕОПРЕДЕЛЕНО;
			КонецПопытки;
		КонецПопытки;
	КонецПопытки;

	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиИлиСоздатьДополнительныйРеквизит(Заголовок,НаборыДополнительныхРеквизитовИСведений,ТекОписаниеТипа) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	РЕЗ=НЕОПРЕДЕЛЕНО;
	
	Если НЕ ЗначениеЗаполнено(НаборыДополнительныхРеквизитовИСведений) Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	Если НЕ НаборыДополнительныхРеквизитовИСведений.Используется Тогда
		Попытка
			НаборыДополнительныхРеквизитовИСведенийОбъект = НаборыДополнительныхРеквизитовИСведений.ПолучитьОбъект();
			НаборыДополнительныхРеквизитовИСведенийОбъект.Используется = ИСТИНА;
			НаборыДополнительныхРеквизитовИСведенийОбъект.Записать();
		Исключение
		КонецПопытки;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ДополнительныеРеквизитыИСведения.Ссылка КАК ТекДопРеквизит
	               |ИЗ
	               |	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	               |ГДЕ
	               |	ДополнительныеРеквизитыИСведения.Заголовок = &Заголовок
	               |	И ДополнительныеРеквизитыИСведения.НаборСвойств = &НаборСвойств";
	
	Запрос.УстановитьПараметр("Заголовок", Заголовок);
	Запрос.УстановитьПараметр("НаборСвойств", НаборыДополнительныхРеквизитовИСведений);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РЕЗ = ВыборкаДетальныеЗаписи.ТекДопРеквизит;
	КонецЦикла;
	
	Если РЕЗ=НЕОПРЕДЕЛЕНО Тогда	
		РЕЗ = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.СоздатьЭлемент();
		РЕЗ.Наименование = Заголовок;
		РЕЗ.ТипЗначения = ТекОписаниеТипа;
		РЕЗ.Виден = ИСТИНА;
		РЕЗ.Доступен = ИСТИНА;
		РЕЗ.Заголовок = Заголовок;
		РЕЗ.НаборСвойств = НаборыДополнительныхРеквизитовИСведений;
		РЕЗ.Комментарий = Заголовок;
		РЕЗ.Записать();
	КонецЕсли;
	
	СтруктураПоиска = Новый Структура("Свойство", РЕЗ.Ссылка);
	МассивСтрок = НаборыДополнительныхРеквизитовИСведений.ДополнительныеРеквизиты.НайтиСтроки(СтруктураПоиска);
	Если МассивСтрок.Количество()=0 Тогда
		НаборыДополнительныхРеквизитовИСведений_Объект=НаборыДополнительныхРеквизитовИСведений.ПолучитьОбъект();
		стрТаб_ДополнительныеРеквизиты=НаборыДополнительныхРеквизитовИСведений_Объект.ДополнительныеРеквизиты.Добавить();
		стрТаб_ДополнительныеРеквизиты.Свойство=РЕЗ.Ссылка;
		НаборыДополнительныхРеквизитовИСведений_Объект.Записать();
	КонецЕсли;			
	
	Возврат РЕЗ.Ссылка;
КонецФункции

Процедура УстановитьДополнительныйРеквизит(ТекОбъект, СвойствоДополнительногоРеквизита, ЗначениеДополнительногоРеквизита) ЭКСПОРТ

	СтрукутраПоиска = Новый Структура("Свойство", СвойствоДополнительногоРеквизита);
	МассивСтрок = ТекОбъект.ДополнительныеРеквизиты.НайтиСтроки(СтрукутраПоиска);
	Если МассивСтрок.Количество()=0 Тогда
		СтрДополнительныеРеквизиты = ТекОбъект.ДополнительныеРеквизиты.Добавить();
		СтрДополнительныеРеквизиты.Свойство = СвойствоДополнительногоРеквизита;
	Иначе
		СтрДополнительныеРеквизиты = МассивСтрок[0];
	КонецЕсли;
	СтрДополнительныеРеквизиты.Значение = ЗначениеДополнительногоРеквизита;

КонецПроцедуры

Функция НайтиЗначениеДополнительногоРеквизита(ТекОбъект, СвойствоДополнительногоРеквизита) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НЕ ТекОбъект.Метаданные().ТабличныеЧасти.Найти("ДополнительныеРеквизиты")=НЕОПРЕДЕЛЕНО Тогда
		Для каждого СтрДополнительныеРеквизиты Из ТекОбъект["ДополнительныеРеквизиты"] Цикл
			Если СтрДополнительныеРеквизиты.Свойство = СвойствоДополнительногоРеквизита Тогда
				РЕЗ = СтрДополнительныеРеквизиты.Значение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция СтруктураДополнительныхРеквизитов(НаборыДополнительныхРеквизитовИСведений) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы Тогда
	    РЕЗ = Новый Структура("SurplusSubdivision, SurplusInventorySubdivision, WriteОffSubdivision, WriteОffUniformSubdivision, WriteОffUtilizationSubdivision, WriteОffInventorySubdivision, SaleSubdivision");
		
		РЕЗ.SurplusSubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Surplus subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
		РЕЗ.SurplusInventorySubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Surplus (Inventory) subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
		РЕЗ.WriteОffSubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Write-off subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
		РЕЗ.WriteОffUniformSubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Write-off (Uniform) subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
		РЕЗ.WriteОffUtilizationSubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Write-off (Utilization) subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
		РЕЗ.WriteОffInventorySubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Write-off (Inventory) subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
		РЕЗ.SaleSubdivision  = НайтиИлиСоздатьДополнительныйРеквизит("Sale subdivision",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы"));
		
	Иначе	
		РЕЗ = Новый Структура("DocRef, DocNumber, DocDate");
		
		РЕЗ.DocRef = НайтиИлиСоздатьДополнительныйРеквизит("DocRef",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		
		РЕЗ.DocNumber = НайтиИлиСоздатьДополнительныйРеквизит("DocNumber",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		
		РЕЗ.DocDate = НайтиИлиСоздатьДополнительныйРеквизит("DocDate",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		
		Если НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер
			ИЛИ НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер
			Тогда
			
			TransferNumber = НайтиИлиСоздатьДополнительныйРеквизит("TransferNumber",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
			РЕЗ.Вставить("TransferNumber",TransferNumber);
			
		КонецЕсли;
		
		Если (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная)
			ИЛИ (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеВКассу)
			ИЛИ (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеНаСчет)
			ИЛИ (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходИзКассы)
			ИЛИ (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов)
			Тогда
			
			BaseRef = НайтиИлиСоздатьДополнительныйРеквизит("BaseRef",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
			РЕЗ.Вставить("BaseRef",BaseRef);
			
			BaseNumber = НайтиИлиСоздатьДополнительныйРеквизит("BaseNumber",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
			РЕЗ.Вставить("BaseNumber",BaseNumber);
			
		КонецЕсли;
		
		Если (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная) Тогда
			
			BaseDoc = НайтиИлиСоздатьДополнительныйРеквизит("BaseDoc",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("ДокументСсылка.РасходнаяНакладная"));
			РЕЗ.Вставить("BaseDoc",BaseDoc);
			
		КонецЕсли;
		
		Если (НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов) Тогда
		
			Type = НайтиИлиСоздатьДополнительныйРеквизит("Type",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("СправочникСсылка.ЗначенияСвойствОбъектов"));
			Оrdinary1 = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary1",ИСТИНА,,Type);
			Если НЕ ЗначениеЗаполнено(Оrdinary1) Тогда
				Оrdinary1 = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
				Оrdinary1.Наименование = "Оrdinary1";
				Оrdinary1.Владелец = Type.Ссылка;
				Оrdinary1.Записать();
			КонецЕсли;
			Оrdinary2 = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary2",ИСТИНА,,Type);
			Если НЕ ЗначениеЗаполнено(Оrdinary2) Тогда
				Оrdinary2 = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
				Оrdinary2.Наименование = "Оrdinary2";
				Оrdinary2.Владелец = Type.Ссылка;
				Оrdinary2.Записать();
			КонецЕсли;
			AdjustmentMinus = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""-""",ИСТИНА,,Type);
			Если НЕ ЗначениеЗаполнено(AdjustmentMinus) Тогда
				AdjustmentMinus = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
				AdjustmentMinus.Наименование = "Adjustment""-""";
				AdjustmentMinus.Владелец = Type.Ссылка;
				AdjustmentMinus.Записать();
			КонецЕсли;
			AdjustmentPlus = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""+""",ИСТИНА,,Type);
			Если НЕ ЗначениеЗаполнено(AdjustmentPlus) Тогда
				AdjustmentPlus = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
				AdjustmentPlus.Наименование = "Adjustment""+""";
				AdjustmentPlus.Владелец = Type.Ссылка;
				AdjustmentPlus.Записать();
			КонецЕсли;
			
			
		    РЕЗ.Вставить("Type",Type);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ПолучитьНастройкиПоУмолчанию() ЭКСПОРТ
