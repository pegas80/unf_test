#Область Номенклатура
Функция СоздатьНоменклатуру(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	OptionCode = СоответствиеОбъекта.Получить("OptionCode");
	Description = СоответствиеОбъекта.Получить("Description");
	OriginCode = СоответствиеОбъекта.Получить("OriginCode");
	OriginDescription = СоответствиеОбъекта.Получить("OriginDescription");
	ProductType = СоответствиеОбъекта.Получить("ProductType");
	ProductTypeDescription = СоответствиеОбъекта.Получить("ProductTypeDescription");
	GenderCode = СоответствиеОбъекта.Получить("GenderCode");
	GenderDescription = СоответствиеОбъекта.Получить("GenderDescription");
	SeasonCode = СоответствиеОбъекта.Получить("SeasonCode");
	ContentCode = СоответствиеОбъекта.Получить("ContentCode");
	ContentDescription = СоответствиеОбъекта.Получить("ContentDescription");
	VatValue = СоответствиеОбъекта.Получить("VatValue");
	Category = СоответствиеОбъекта.Получить("Category");
	
	Если НЕ ЗначениеЗаполнено(OptionCode) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = OptionCode;
		РЕЗ.Описание = "Incorrect option code";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	OptionCode = СокрЛП(OptionCode);
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Номенклатура.Ссылка
	               |ИЗ
