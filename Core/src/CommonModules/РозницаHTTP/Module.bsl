			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, НЕОПРЕДЕЛЕНО, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			ТекДок.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю");
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.Контрагент = ТекКонтрагент;
			ТекДок.Договор = ТекДоговор;
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			
			// Дозаполняем данные			
			ТекДок.Предоплата.Очистить();
			ТекДок.ФактурыАвансов.Очистить();
			ТекДок.ТранспортныеСредства.Очистить();
			ТекДок.ДокументОснование = Неопределено;
			
			СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
			ПодразделениеПродажи = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы.SaleSubdivision);
			Если ЗначениеЗаполнено(ПодразделениеПродажи) Тогда
				ТекДок.Подразделение = ПодразделениеПродажи;
			КонецЕсли;
			
			//ТекДок.ВалютаДокумента = ТекДоговор.ВалютаРасчетов;
			ТекДок.ВалютаДокумента = ТекВалюта;
						
			//Данные по договору
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДокумента));
			ТекДок.Курс      = ВалютаРасчетовКурсКратность.Курс;
			ТекДок.Кратность = ВалютаРасчетовКурсКратность.Кратность;
			
			ТекДок.ПодписьРуководителя = ТекДок.Организация.ПодписьРуководителя;
			ТекДок.ПодписьГлавногоБухгалтера = ТекДок.Организация.ПодписьГлавногоБухгалтера;
			ТекДок.ИспользоватьФаксимиле = ПодписьДокументовУНФ.НадоВключитьФаксимиле(ТекДок.Организация, "РасходнаяНакладная");
			ТекДок.ПодписьКладовщика = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДок.СтруктурнаяЕдиница, "ПодписьМол");
			
			ТекДок.ОснованиеПечати = Нстр("ka='Договор: ';ru='Договор: '") + Строка(ТекДок.Договор);
			
			ТекДок.НалогообложениеНДС = ТекДок.Контрагент.НалогообложениеНДС;
			Если ТекДок.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда 
				ТекДок.ОсновнаяСтавкаНДС = Справочники.СтавкиНДС.БезНДС;
			ИначеЕсли ТекДок.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
				ТекДок.ОсновнаяСтавкаНДС = Справочники.СтавкиНДС.НДС18;
			Иначе 
				ТекДок.ОсновнаяСтавкаНДС = Справочники.СтавкиНДС.НДС0;
			КонецЕсли;
			ТекДок.НДСВключатьВСтоимость = ИСТИНА;
			//ТекДок.СуммаВключаетНДС = ?(ЗначениеЗаполнено(ТекДок.Договор.ВидЦен), ТекДок.Договор.ВидЦен.ЦенаВключаетНДС, Неопределено);
			ТекДок.СуммаВключаетНДС = ИСТИНА;
			ТекДок.ДисконтнаяКарта = ПредопределенноеЗначение("Справочник.ДисконтныеКарты.ПустаяСсылка");
			ТекДок.ПроцентСкидкиПоДисконтнойКарте = 0;
			ТекДок.ВидЦен = ТекДок.Договор.ВидЦен;
			ТекДок.ВидСкидкиНаценки = ТекДок.Договор.ВидСкидкиНаценки;
				
			// Заполнение предоплаты
			ТекДок.Предоплата.Очистить();
			Если ЗаполнитьПредоплату Тогда
				ТекДок.ЗаполнитьПредоплату();
			КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;
								
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Price = СоответствиеОбъекта.Получить("Price");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				Sum = СоответствиеОбъекта.Получить("Sum");
				VatValue = СоответствиеОбъекта.Получить("VatValue");
				VatSum = СоответствиеОбъекта.Получить("VatSum");
				Discount = СоответствиеОбъекта.Получить("Discount");
				
				ТекКоличество = 0;
				ТекЦена = 0;
				ТекСумма = 0;
				ТекСуммаНДС = 0;
				ТекСтавкаНДС = НЕОПРЕДЕЛЕНО;
				ТекСуммаСкидки = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Price)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Price),"null")=0 Тогда
						ТекЦена = Число(Price);
					Иначе
						ТекЦена = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Price)=Тип("Число") Тогда
					ТекЦена = Price;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid price";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Price);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
						ТекСумма = Число(Sum);
					Иначе
						ТекСумма = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
					ТекСумма = Sum;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid sum";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Sum);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если НЕ VatSum = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(VatSum)=Тип("Строка") Тогда
						Если СтрНайти(НРЕГ(VatSum),"null")=0 Тогда
							ТекСуммаНДС = Число(VatSum);
						Иначе
							ТекСуммаНДС = 0;
						КонецЕсли;
					ИначеЕсли ТипЗНЧ(VatSum)=Тип("Число") Тогда
						ТекСуммаНДС = VatSum;
					Иначе
						СтруктураОшибки = ПолучитьСтруктуруОшибки();
						
						СтруктураОшибки.Message = "Invalid VatSum";
						СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
						СтруктураОшибки.Вставить("Value",VatSum);
						
						МассивОшибок.Добавить(СтруктураОшибки);
					КонецЕсли;
					
					ТекСтавкаНДС = НайтиСтавкуНДС(VatValue);	
					
				КонецЕсли;
								
				Если ТипЗНЧ(Discount)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Discount),"null")=0 Тогда
						ТекСуммаСкидки = Число(Discount);
					Иначе
						ТекСуммаСкидки = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Discount)=Тип("Число") Тогда
					ТекСуммаСкидки = Discount;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid discount";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Discount);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				СтрокаТабличнойЧасти.Цена = ТекЦена;
				
				ТекСуммаВычисленная = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
				Если НЕ ТекСуммаВычисленная = ТекСумма Тогда
					ТекСуммаСкидки = ТекСуммаВычисленная - ТекСумма;
					ТекСумма = ТекСуммаВычисленная;
				КонецЕсли;
				
				Если ТекСумма>0 Тогда
					Если ТекСумма>ТекСуммаСкидки Тогда
						СтрокаТабличнойЧасти.Сумма = ТекСумма - ТекСуммаСкидки;
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = (ТекСуммаСкидки*100)/ТекСумма;
					Иначе
						СтрокаТабличнойЧасти.Сумма = 0;
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 100;
					КонецЕсли;
				КонецЕсли;
				
				СтрокаТабличнойЧасти.СтавкаНДС = ТекСтавкаНДС;
				СтрокаТабличнойЧасти.СуммаНДС = ТекСуммаНДС;
				
				// Дозаполняем данные в строке
				СтрокаТабличнойЧасти.ТипНоменклатурыЗапас = СтрокаТабличнойЧасти.Номенклатура.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Запас");
				СтрокаТабличнойЧасти.Вес = СтрокаТабличнойЧасти.Номенклатура.Вес * СтрокаТабличнойЧасти.Количество;
				СтрокаТабличнойЧасти.Объем = СтрокаТабличнойЧасти.Номенклатура.Объем * СтрокаТабличнойЧасти.Количество;
				
				СчетУчетаВыручкиОтПродажРегл = СтрокаТабличнойЧасти.Номенклатура.НаправлениеДеятельности.СчетУчетаВыручкиОтПродажРегл;
				Если НЕ ЗначениеЗаполнено(СчетУчетаВыручкиОтПродажРегл) Тогда
					СчетУчетаВыручкиОтПродажРегл = Справочники.НаправленияДеятельности.ОсновноеНаправление.СчетУчетаВыручкиОтПродажРегл;
				КонецЕсли;
				СтрокаТабличнойЧасти.СчетУчетаВыручкиОтПродажРегл = СчетУчетаВыручкиОтПродажРегл;
				
				Если СтрокаТабличнойЧасти.Сумма>0 Тогда
					СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(ТекДок.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
				КонецЕсли;
				
				Если НЕ НаправлениеДеятельности=НЕОПРЕДЕЛЕНО Тогда
					СтрокаТабличнойЧасти.НаправлениеДеятельности = НаправлениеДеятельности;
					
					СчетУчетаВыручкиОтПродажРегл = СтрокаТабличнойЧасти.НаправлениеДеятельности.СчетУчетаВыручкиОтПродажРегл;
					Если НЕ ЗначениеЗаполнено(СчетУчетаВыручкиОтПродажРегл) Тогда
						СчетУчетаВыручкиОтПродажРегл = Справочники.НаправленияДеятельности.ОсновноеНаправление.СчетУчетаВыручкиОтПродажРегл;
					КонецЕсли;	
					СтрокаТабличнойЧасти.СчетУчетаВыручкиОтПродажРегл = СчетУчетаВыручкиОтПродажРегл;
				КонецЕсли;
			КонецЦикла;
			
			// Проверка остатков
			РЕЗ = ПолучитьМассивОшибокПоОстаткам(ТекДок,ТекДок.СтруктурнаяЕдиница,РЕЗ,МассивОшибок);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
						
			// Проводим
			ОписаниеУспешногоПроведения = "Doc sale created successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
			СтрокаОшибок = РЕЗ.Описание;
			// Получаем оплату наличными
			Если РЕЗ.Результат Тогда
				Если НЕ CashIncomeOrder = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(CashIncomeOrder) = Тип("Массив") Тогда
						
						Для Каждого ТекCashIncomeOrder из CashIncomeOrder Цикл
							
							Если ТекCashIncomeOrder.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("Ref",Ref);
							КонецЕсли;
							
							Если ТекCashIncomeOrder.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("Number",Number);
							КонецЕсли;
							
							Если ТекCashIncomeOrder.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("Date",Date+1);
							КонецЕсли;
							
							Если ТекCashIncomeOrder.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("PartnerCIN",PartnerCIN);
							КонецЕсли;
							
							Если ТекCashIncomeOrder.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("WarehouseCode",WarehouseCode);
							КонецЕсли;
							
							Если ТекCashIncomeOrder.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("Currency",Currency);
							КонецЕсли;
							
							Если ТекCashIncomeOrder.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashIncomeOrder.Вставить("Description",Description);
							КонецЕсли;
							
							РЕЗ = СоздатьИлиОбновитьПоступлениеВКассуИзРасходнойНакладной(РЕЗ,ТекCashIncomeOrder,Ref);
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Cash income order: " + РЕЗ.Описание;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе	

						Если CashIncomeOrder.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("Ref",Ref);
						КонецЕсли;
						
						Если CashIncomeOrder.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("Number",Number);
						КонецЕсли;
						
						Если CashIncomeOrder.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("Date",Date+1);
						КонецЕсли;
						
						Если CashIncomeOrder.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("PartnerCIN",PartnerCIN);
						КонецЕсли;
						
						Если CashIncomeOrder.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("WarehouseCode",WarehouseCode);
						КонецЕсли;
						
						Если CashIncomeOrder.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("Currency",Currency);
						КонецЕсли;
						
						Если CashIncomeOrder.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
							CashIncomeOrder.Вставить("Description",Description);
						КонецЕсли;
						
						РЕЗ = СоздатьИлиОбновитьПоступлениеВКассуИзРасходнойНакладной(РЕЗ,CashIncomeOrder,Ref);
						
						Если НЕ РЕЗ.Результат Тогда
							РЕЗ.Описание = СтрокаОшибок + "; Cash income order: " + РЕЗ.Описание;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли;
			
			// Получаем оплату безналом
			Если РЕЗ.Результат Тогда
				Если НЕ ReceivingMoneyOnAccount = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(ReceivingMoneyOnAccount) = Тип("Массив") Тогда
						
						Для Каждого ТекReceivingMoneyOnAccount из ReceivingMoneyOnAccount Цикл
							
							Если ТекReceivingMoneyOnAccount.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("Ref",Ref);
							КонецЕсли;
							
							Если ТекReceivingMoneyOnAccount.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("Number",Number);
							КонецЕсли;
							
							Если ТекReceivingMoneyOnAccount.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("Date",Date+1);
							КонецЕсли;
							
							Если ТекReceivingMoneyOnAccount.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("PartnerCIN",PartnerCIN);
							КонецЕсли;
							
							Если ТекReceivingMoneyOnAccount.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("WarehouseCode",WarehouseCode);
							КонецЕсли;
							
							Если ТекReceivingMoneyOnAccount.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("Currency",Currency);
							КонецЕсли;
							
							Если ТекReceivingMoneyOnAccount.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
								ТекReceivingMoneyOnAccount.Вставить("Description",Description);
							КонецЕсли;
							
							РЕЗ = СоздатьИлиОбновитьПоступлениеНаСчетИзРасходнойНакладной(РЕЗ,ТекReceivingMoneyOnAccount,Ref);
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Receiving мoney оn account: " + РЕЗ.Описание;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе	

						Если ReceivingMoneyOnAccount.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("Ref",Ref);
						КонецЕсли;
						
						Если ReceivingMoneyOnAccount.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("Number",Number);
						КонецЕсли;
						
						Если ReceivingMoneyOnAccount.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("Date",Date+1);
						КонецЕсли;
						
						Если ReceivingMoneyOnAccount.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("PartnerCIN",PartnerCIN);
						КонецЕсли;
						
						Если ReceivingMoneyOnAccount.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("WarehouseCode",WarehouseCode);
						КонецЕсли;
						
						Если ReceivingMoneyOnAccount.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("Currency",Currency);
						КонецЕсли;
						
						Если ReceivingMoneyOnAccount.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
							ReceivingMoneyOnAccount.Вставить("Description",Description);
						КонецЕсли;
						
						РЕЗ = СоздатьИлиОбновитьПоступлениеНаСчетИзРасходнойНакладной(РЕЗ,ReceivingMoneyOnAccount,Ref);
						
						Если НЕ РЕЗ.Результат Тогда
							РЕЗ.Описание = СтрокаОшибок + "; Receiving мoney оn account: " + РЕЗ.Описание;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли;
			
			// Возврат товаров
			Если РЕЗ.Результат Тогда
				Если НЕ Return_ = НЕОПРЕДЕЛЕНО Тогда
				
					Если ТипЗНЧ(Return_) = Тип("Массив") Тогда
						
						Для Каждого ТекReturn_ из Return_ Цикл
							
							Если Return_.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Ref",Ref);
							КонецЕсли;
							
							Если Return_.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Number",Number);
							КонецЕсли;
							
							Если Return_.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Date",Date+1);
							КонецЕсли;
							
							Если Return_.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("PartnerCIN",PartnerCIN);
							КонецЕсли;
							
							Если Return_.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("WarehouseCode",WarehouseCode);
							КонецЕсли;
							
							Если Return_.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Currency",Currency);
							КонецЕсли;
							
							Если Return_.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Description",Description);
							КонецЕсли;
							
							Если Return_.Получить("PartnerType")=НЕОПРЕДЕЛЕНО Тогда
								Если ЗначениеЗаполнено(PartnerType) Тогда
									Return_.Вставить("PartnerType",PartnerType);
								КонецЕсли;
							КонецЕсли;
							
							РЕЗ = СоздатьИлиОбновитьВозвратТоваровОтПокупателяИзРасходнойНакладной(РЕЗ,ТекReturn_,Ref);
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Return of goods: " + РЕЗ.Описание;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе	

						Если Return_.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Ref",Ref);
						КонецЕсли;
						
						Если Return_.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Number",Number);
						КонецЕсли;
						
						Если Return_.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Date",Date+1);
						КонецЕсли;
						
						Если Return_.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("PartnerCIN",PartnerCIN);
						КонецЕсли;
						
						Если Return_.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("WarehouseCode",WarehouseCode);
						КонецЕсли;
						
						Если Return_.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Currency",Currency);
						КонецЕсли;
						
						Если Return_.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Description",Description);
						КонецЕсли;
						
						Если Return_.Получить("PartnerType")=НЕОПРЕДЕЛЕНО Тогда
							Если ЗначениеЗаполнено(PartnerType) Тогда
								Return_.Вставить("PartnerType",PartnerType);
							КонецЕсли;
						КонецЕсли;
						
						РЕЗ = СоздатьИлиОбновитьВозвратТоваровОтПокупателяИзРасходнойНакладной(РЕЗ,Return_,Ref);
						
						Если НЕ РЕЗ.Результат Тогда
							РЕЗ.Описание = СтрокаОшибок + "; Return of goods: " + РЕЗ.Описание;
						КонецЕсли;
						
					КонецЕсли;
				
				КонецЕсли;
			КонецЕсли;
			
			Если РЕЗ.Результат Тогда
				РЕЗ.Описание = "Doc sale created successfully";
				ЗафиксироватьТранзакцию()
			Иначе
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Описание = СтрЗаменить(РЕЗ.Описание,"Doc sale created successfully","Creating sales doc: error");
			КонецЕсли;
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc sale already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьРасходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	PartnerCIN = СоответствиеОбъекта.Получить("PartnerCIN");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	CashIncomeOrder = СоответствиеОбъекта.Получить("CashIncomeOrder");
	ReceivingMoneyOnAccount = СоответствиеОбъекта.Получить("ReceivingMoneyOnAccount");
	Return_ = СоответствиеОбъекта.Получить("Return");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	НаправлениеДеятельности=НЕОПРЕДЕЛЕНО;
	PartnerType = СоответствиеОбъекта.Получить("PartnerType");
	Если ЗначениеЗаполнено(PartnerType) Тогда
		РЕЗ = ПолучитьНаправлениеДеятельности(PartnerType,РЕЗ);
		Если РЕЗ.Результат Тогда
			НаправлениеДеятельности = РЕЗ.ВозвращаемоеЗначение;
		Иначе	
			Возврат РЕЗ;
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьПредоплату = ЛОЖЬ;
	AdvancePayment = СоответствиеОбъекта.Получить("AdvancePayment");
	Если ТипЗНЧ(AdvancePayment)=Тип("Булево") Тогда
		ЗаполнитьПредоплату = AccountingEntry;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
	               |ГДЕ
	               |	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
						
		// Ищем контрагента				
		ТекКонтрагент = НайтиКонтрагентаПоИНН(СокрЛП(PartnerCIN));
		
		Если ТекКонтрагент = НЕОПРЕДЕЛЕНО Тогда
		
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = PartnerCIN;
			РЕЗ.Описание = "Partner not found";
			
		Иначе
			
			Если ЗначениеЗаполнено(ТекКонтрагент.ДоговорПоУмолчанию) Тогда
				ТекДоговор = ТекКонтрагент.ДоговорПоУмолчанию;
				Если ((НЕ ТекДоговор.Покупатель) И (Константы.ИспользоватьВидыДоговоров.Получить())) ИЛИ (НЕ ТекДоговор.ВалютаРасчетов = ТекВалюта.Ссылка) Тогда
					ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,ИСТИНА);
				КонецЕсли;
			Иначе
				ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,ИСТИНА);
			КонецЕсли;
						
		КонецЕсли;
		
		//Ищем Склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
			
			ТекДок.Дата = ДатаДокумента;
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			ТекДок.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю");
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.Контрагент = ТекКонтрагент;
			ТекДок.Договор = ТекДоговор;
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			
			// Дозаполняем данные			
			ТекДок.Предоплата.Очистить();
			ТекДок.ФактурыАвансов.Очистить();
			ТекДок.ТранспортныеСредства.Очистить();
			ТекДок.ДокументОснование = Неопределено;
			
			СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
			ПодразделениеПродажи = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы.SaleSubdivision);
			Если ЗначениеЗаполнено(ПодразделениеПродажи) Тогда
				ТекДок.Подразделение = ПодразделениеПродажи;
			КонецЕсли;
			
			//ТекДок.ВалютаДокумента = ТекДоговор.ВалютаРасчетов;
			ТекДок.ВалютаДокумента = ТекВалюта;
						
			//Данные по договору
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДокумента));
			ТекДок.Курс      = ВалютаРасчетовКурсКратность.Курс;
			ТекДок.Кратность = ВалютаРасчетовКурсКратность.Кратность;
			
			ТекДок.ПодписьРуководителя = ТекДок.Организация.ПодписьРуководителя;
			ТекДок.ПодписьГлавногоБухгалтера = ТекДок.Организация.ПодписьГлавногоБухгалтера;
			ТекДок.ИспользоватьФаксимиле = ПодписьДокументовУНФ.НадоВключитьФаксимиле(ТекДок.Организация, "РасходнаяНакладная");
			ТекДок.ПодписьКладовщика = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекДок.СтруктурнаяЕдиница, "ПодписьМол");
			
			ТекДок.ОснованиеПечати = Нстр("ka='Договор: ';ru='Договор: '") + Строка(ТекДок.Договор);
			
			ТекДок.НалогообложениеНДС = ТекДок.Контрагент.НалогообложениеНДС;
			Если ТекДок.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда 
				ТекДок.ОсновнаяСтавкаНДС = Справочники.СтавкиНДС.БезНДС;
			ИначеЕсли ТекДок.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
				ТекДок.ОсновнаяСтавкаНДС = Справочники.СтавкиНДС.НДС18;
			Иначе 
				ТекДок.ОсновнаяСтавкаНДС = Справочники.СтавкиНДС.НДС0;
			КонецЕсли;
