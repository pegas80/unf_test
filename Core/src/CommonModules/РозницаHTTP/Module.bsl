	//РЕЗ.Вставить("ПодразделениеКассаККМ",ПоУмолчанию.УдалитьПодразделениеКассаККМ);
	//РЕЗ.Вставить("СтатьяКассаККМ",ПоУмолчанию.УдалитьСтатьяКассаККМ);
	РЕЗ.Вставить("СтатьиДвиженияДенежныхСредств_ПеремещениеДС",ПоУмолчанию.СтатьиДвиженияДенежныхСредств_ПеремещениеДС);
	
