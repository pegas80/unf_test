Функция НайтиСтавкуНДС(VatValue)
	ПЕРЕМ РЕЗ;
	
	РЕЗ = НЕОПРЕДЕЛЕНО;

	Если НЕ VatValue = НЕОПРЕДЕЛЕНО Тогда
		Если VatValue = "18" ИЛИ VatValue = 18 Тогда
			РЕЗ = Справочники.СтавкиНДС.НДС18;
		ИначеЕсли VatValue = "0" ИЛИ VatValue = "00" ИЛИ VatValue = 0 Тогда
			РЕЗ = Справочники.СтавкиНДС.НДС0;
		Иначе
			VatValue = СокрЛП(Строка(VatValue));
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	СтавкиНДС.Ссылка
			|ИЗ
			|	Справочник.СтавкиНДС КАК СтавкиНДС
			|ГДЕ
			|	СтавкиНДС.Наименование ПОДОБНО &Наименование";
			
			Запрос.УстановитьПараметр("Наименование", VatValue+"%");
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Если РезультатЗапроса.Пустой() Тогда
				
				Запрос.УстановитьПараметр("Наименование", VatValue);
				
				Запрос.Выполнить();
				
				Если РезультатЗапроса.Пустой() Тогда
					
					РЕЗ = Справочники.СтавкиНДС.ПустаяСсылка();
					
				Иначе
					
					ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
					
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
						РЕЗ = ВыборкаДетальныеЗаписи.Ссылка;
					КонецЦикла;
					
				КонецЕсли;
			
			Иначе	
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					РЕЗ = ВыборкаДетальныеЗаписи.Ссылка;
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

	Возврат РЕЗ;
КонецФункции // ()

Функция ПолучитьСтруктураДляВозврата(СтруктураДляВозврата=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;

	Если НЕ ТипЗНЧ(СтруктураДляВозврата)=Тип("Структура") Тогда
		РЕЗ = Новый Структура("Результат,ВозвращаемоеЗначение,Описание",ИСТИНА,"","");
	Иначе
		РЕЗ = СтруктураДляВозврата;
		РЕЗ.Вставить("Результат",ИСТИНА);
		РЕЗ.Вставить("ВозвращаемоеЗначение",НЕОПРЕДЕЛЕНО);
		РЕЗ.Вставить("Описание","");
	КонецЕсли;

	Возврат РЕЗ;
КонецФункции // ()

Функция ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	// Ищем существующие
	Запрос = Новый Запрос;
	Запрос.Текст = СтрокаТекстаЗапроса;
	
	Запрос.УстановитьПараметр("ТекПараметр", ЗначениеПараметра);
	Если НЕ ДопПараметр=НЕОПРЕДЕЛЕНО Тогда
		Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = СтрокаОтветаОбъектНеНайден;
		
	Иначе
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		КонецЦикла;
		//ТекОбъект.ОбменДанными.Загрузка = ИСТИНА;
		
		НачатьТранзакцию();
		Попытка
			//ТекОбъект.Записать();
			ТекОбъект.УстановитьПометкуУдаления(ИСТИНА);
			
			ЗафиксироватьТранзакцию();
			
			РЕЗ.Результат = ИСТИНА;
			РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
			РЕЗ.Описание = СтрокаОтветаДляУдачногоРезультата;
		Исключение
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
			РЕЗ.Описание = "Internal processing error";		
		КонецПопытки;		
		
	КонецЕсли;	
	
	Возврат РЕЗ;
КонецФункции

Функция ПолучитьСтруктуруОшибки()
	Возврат Новый Структура("IsSuccess,Message,ProductOptionCode,Value",ЛОЖЬ,"","","");
КонецФункции // ()

Функция ПопыткаПровестиДокумент(ТекДок,Ref,СтруктураДляВозврата,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции=ЛОЖЬ,ЗаписыватьПриОшибках=ЛОЖЬ,ОписаниеДляМассиваОшибок="", НеПроводить=ЛОЖЬ)
	//Если НЕ ЗначениеЗаполнено(СтруктураДляВозврата) Тогда
	//	РЕЗ = ПолучитьСтруктураДляВозврата(НЕОПРЕДЕЛЕНО);	
	//КонецЕсли;
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Если НеПроводить Тогда
		
		Попытка
			Если МассивОшибок.Количество()>0 Тогда
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = МассивОшибок;
				Если СтрДлина(СокрЛП(ОписаниеДляМассиваОшибок))>0 Тогда
					РЕЗ.Описание = ОписаниеДляМассиваОшибок;
				Иначе	
					РЕЗ.Описание = "Internal processing error";
				КонецЕсли;
				
				Если ЗаписыватьПриОшибках Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
				КонецЕсли;
			Иначе
				ТекДок.Записать(РежимЗаписиДокумента.Запись);
				
				РЕЗ.Результат = ИСТИНА;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = ОписаниеУспешногоПроведения;
			КонецЕсли;
			
			Если ФиксироватьТранзакции Тогда
				ЗафиксироватьТранзакцию();
			КонецЕсли;
		Исключение
			РЕЗ.Результат = ЛОЖЬ;
			Если МассивОшибок.Количество()>0 Тогда
				РЕЗ.ВозвращаемоеЗначение = МассивОшибок;
			Иначе
				РЕЗ.ВозвращаемоеЗначение = Ref;
			КонецЕсли;
			РЕЗ.Описание = "Internal processing error";
			
			Если ФиксироватьТранзакции Тогда
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
			КонецЕсли;
		КонецПопытки;
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Попытка
		Если МассивОшибок.Количество()>0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = МассивОшибок;
			Если СтрДлина(СокрЛП(ОписаниеДляМассиваОшибок))>0 Тогда
				РЕЗ.Описание = ОписаниеДляМассиваОшибок;
			Иначе	
				РЕЗ.Описание = "Internal processing error";
			КонецЕсли;
			
			Если ЗаписыватьПриОшибках Тогда
				ТекДок.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;
		Иначе
			ТекДок.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
			
			РЕЗ.Результат = ИСТИНА;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = ОписаниеУспешногоПроведения;
		КонецЕсли;
		
		Если ФиксироватьТранзакции Тогда
			ЗафиксироватьТранзакцию();
		КонецЕсли;
	Исключение
		РЕЗ.Результат = ЛОЖЬ;
		Если МассивОшибок.Количество()>0 Тогда
			РЕЗ.ВозвращаемоеЗначение = МассивОшибок;
		Иначе
			РЕЗ.ВозвращаемоеЗначение = Ref;
		КонецЕсли;
		РЕЗ.Описание = "Internal processing error";
		
		Если ФиксироватьТранзакции Тогда
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
		КонецЕсли;
	КонецПопытки;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция ПолучитьМассивОшибокПоОстаткам(ТекДок,ТекСтруктурнаяЕдиница,РЕЗ,МассивОшибок)
	Если НЕ ЗначениеЗаполнено(РЕЗ) Тогда
		РЕЗ = ПолучитьСтруктураДляВозврата(НЕОПРЕДЕЛЕНО);
		РЕЗ.Результат = ИСТИНА;
	КонецЕсли;
		
	Если НЕ (ТипЗНЧ(МассивОшибок)=Тип("Массив")) Тогда		
		МассивОшибок = Новый Массив();
	КонецЕсли;
	
	Если ТекСтруктурнаяЕдиница.КонтролироватьОстатки Тогда
		РЕЗ.Результат = ИСТИНА;
		Возврат РЕЗ;
	КонецЕсли;
	
	ТабЗапасы = ТекДок.Запасы.Выгрузить();
	ТабЗапасы.Свернуть("Номенклатура,ЕдиницаИзмерения","Количество");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТабЗапасы.Номенклатура КАК Номенклатура,
	|	ТабЗапасы.Количество КАК Количество
	|ПОМЕСТИТЬ ТАБ_Запасы
	|ИЗ
	|	&ТабЗапасы КАК ТабЗапасы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗапасыНаСкладахОстатки.Номенклатура,
	|	ЗапасыНаСкладахОстатки.КоличествоОстаток
	|ПОМЕСТИТЬ ТАБ_Остатки
	|ИЗ
	|	РегистрНакопления.ЗапасыНаСкладах.Остатки(
	|			&ТекДата,
	|			Организация = &Организация
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И Номенклатура В
	|					(ВЫБРАТЬ
	|						ТАБ_Запасы.Номенклатура КАК Номенклатура
	|					ИЗ
	|						ТАБ_Запасы)) КАК ЗапасыНаСкладахОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТАБ_Запасы.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ТАБ_Остатки.КоличествоОстаток, 0) - ТАБ_Запасы.Количество КАК Остаток
	|ИЗ
	|	ТАБ_Запасы КАК ТАБ_Запасы
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТАБ_Остатки КАК ТАБ_Остатки
	|		ПО ТАБ_Запасы.Номенклатура = ТАБ_Остатки.Номенклатура";
	
	Запрос.УстановитьПараметр("Организация", ТекДок.Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", ТекСтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("ТабЗапасы", ТабЗапасы);
	Запрос.УстановитьПараметр("ТекДата", ТекДок.МоментВремени());
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.Остаток<0 Тогда
			СтруктураОшибки = ПолучитьСтруктуруОшибки();
			
			СтруктураОшибки.Message = "Not enough balances in the departure warehouse";
			СтруктураОшибки.Вставить("ProductOptionCode",ВыборкаДетальныеЗаписи.Номенклатура.Артикул);
			СтруктураОшибки.Вставить("Value",ВыборкаДетальныеЗаписи.Номенклатура.Артикул);
			
			МассивОшибок.Добавить(СтруктураОшибки);
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = МассивОшибок;
		РЕЗ.Описание = "Not enough balances in the departure warehouse";
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиИлиСоздатьКассу(СтруктураДляВозврата,ТекНаименование,ТекВалюта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекНаименование;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ТекКассаСсылка = НЕОПРЕДЕЛЕНО;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Кассы.Ссылка
		|ИЗ
		|	Справочник.Кассы КАК Кассы
		|ГДЕ
		|	Кассы.Наименование = &Наименование
		|	И Кассы.ВалютаПоУмолчанию = &ВалютаПоУмолчанию";
	
	Запрос.УстановитьПараметр("ВалютаПоУмолчанию", ТекВалюта);
	Запрос.УстановитьПараметр("Наименование", ТекНаименование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТекКассаСсылка = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТекКассаСсылка) Тогда
		ТекКасса = ТекКассаСсылка.ПолучитьОбъект();
		ТекКасса.ОбменДанными.Загрузка = ИСТИНА;
		Если ТекКасса.ПометкаУдаления Тогда
			ТекКасса.Записать(РежимЗаписиДокумента.Запись);
			ТекКасса.УстановитьПометкуУдаления(ЛОЖЬ);	
		КонецЕсли;		
	Иначе
		ТекКасса = Справочники.Кассы.СоздатьЭлемент();
		ТекКасса.ОбменДанными.Загрузка = ИСТИНА;
		
		ТекКасса.Наименование = ТекНаименование;
		ТекКасса.ВалютаПоУмолчанию = ТекВалюта;
		//ТекКасса.СчетУчета = НастройкиПоУмолчанию.СчетУчетаКасса;
		ТекКасса.СчетУчетаРегл = НастройкиПоУмолчанию.СчетУчетаРеглКасса;
		
		ТекКасса.Записать();
		
		ТекКассаСсылка = ТекКасса.Ссылка;
	КонецЕсли;
	
	РЕЗ.Результат = ИСТИНА;
	РЕЗ.ВозвращаемоеЗначение = ТекКассаСсылка;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиИлиСоздатьБанковскийСчет(СтруктураДляВозврата,ТекНомер,ТекБанкКод,ТекВалюта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекНомер+", "+ТекБанкКод;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ТекБанк = НЕОПРЕДЕЛЕНО;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Банки.Ссылка
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	Банки.Код = &Код
		|	И НЕ Банки.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Код", ТекБанкКод);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТекБанк = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Если ТекБанк = НЕОПРЕДЕЛЕНО Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекБанкКод;
		РЕЗ.Описание = "Bank not found";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ТекБанковскийСчетСсылка = НЕОПРЕДЕЛЕНО;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	БанковскиеСчета.Ссылка
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	БанковскиеСчета.НомерСчета = &НомерСчета
		|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаДенежныхСредств
		|	И БанковскиеСчета.Банк = &Банк";
	
	Запрос.УстановитьПараметр("ВалютаДенежныхСредств", ТекВалюта);
	Запрос.УстановитьПараметр("НомерСчета", ТекНомер);
	Запрос.УстановитьПараметр("Банк", ТекБанк);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТекБанковскийСчетСсылка = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ТекБанковскийСчетСсылка) Тогда
		ТекБанковскийСчет = ТекБанковскийСчетСсылка.ПолучитьОбъект();
		ТекБанковскийСчет.ОбменДанными.Загрузка = ИСТИНА;
		Если ТекБанковскийСчет.ПометкаУдаления Тогда
			ТекБанковскийСчет.Записать(РежимЗаписиДокумента.Запись);
			ТекБанковскийСчет.УстановитьПометкуУдаления(ЛОЖЬ);	
		КонецЕсли;		
	Иначе
		ТекБанковскийСчет = Справочники.БанковскиеСчета.СоздатьЭлемент();
		ТекБанковскийСчет.ОбменДанными.Загрузка = ИСТИНА;
		
		ТекБанковскийСчет.НомерСчета = ТекНомер;
		ТекБанковскийСчет.Банк = ТекБанк.Ссылка;
		ТекБанковскийСчет.ВалютаДенежныхСредств = ТекВалюта;
