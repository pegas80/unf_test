Функция СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,ЭтоПокупатель=ЛОЖЬ,ЭтоПоставщик=ЛОЖЬ) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = НЕОПРЕДЕЛЕНО;
	
	Попытка
		Если НЕ ТипЗНЧ(ТекКонтрагент.Ссылка) = Тип("СправочникСсылка.Контрагенты") Тогда
			Возврат РЕЗ;
		КонецЕсли;
	Исключение
		Возврат РЕЗ;
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ТекВалюта) Тогда
	    ВалютаРасчетов = ТекВалюта;
	Иначе
		ВалютаРасчетов = НастройкиПоУмолчанию.ВалютаРасчетов;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ЗапросТекст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДоговорыКонтрагентов.Ссылка
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Владелец = &Владелец
		|	И ДоговорыКонтрагентов.ВалютаРасчетов = &ВалютаРасчетов
		|	И НЕ ДоговорыКонтрагентов.Неактивен
		|	И НЕ ДоговорыКонтрагентов.ПометкаУдаления";
	Если Константы.ИспользоватьВидыДоговоров.Получить() Тогда
		Если ЭтоПокупатель Тогда
			ЗапросТекст = ЗапросТекст + "	И ДоговорыКонтрагентов.Покупатель";
		КонецЕсли;
		Если ЭтоПоставщик Тогда
			ЗапросТекст = ЗапросТекст + "	И ДоговорыКонтрагентов.Поставщик";
		КонецЕсли;		
	КонецЕсли;	

	
	Запрос.Текст = ЗапросТекст;
	
	Запрос.УстановитьПараметр("Владелец", ТекКонтрагент.Ссылка);
	Запрос.УстановитьПараметр("ВалютаРасчетов", ВалютаРасчетов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РЕЗ = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Если НЕ РЕЗ = НЕОПРЕДЕЛЕНО Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекДоговор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
	ТекДоговор.ОбменДанными.Загрузка = ИСТИНА;
	
	ТекДоговор.УстановитьНовыйКод();
	
	ЗаполнитьЗначенияСвойств(ТекДоговор,НастройкиПоУмолчанию);
	
	ТекДоговор.Владелец = ТекКонтрагент.Ссылка;
	ТекДоговор.Наименование = "Default_"+СокрЛП(ВалютаРасчетов.Наименование);
	ТекДоговор.Покупатель = ИСТИНА;
	ТекДоговор.Поставщик = ИСТИНА;
	ТекДоговор.ВалютаРасчетов = ВалютаРасчетов;
	
	Попытка
		ТекДоговор.Записать();
		РЕЗ = ТекДоговор.Ссылка;
	Исключение
		РЕЗ = НЕОПРЕДЕЛЕНО;
	КонецПопытки;
		
	Возврат РЕЗ;
КонецФункции // ()

