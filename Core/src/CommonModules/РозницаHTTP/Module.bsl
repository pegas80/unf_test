#Область ПоступлениеВКассу
Функция СоздатьПоступлениеВКассу(СтруктураДляВозврата,СоответствиеОбъекта,РасходнаяНакладнаяRef,ОтчетОРозничныхПродажахRef,ТекНалогообложениеНДС=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	CashDeskCode = СоответствиеОбъекта.Получить("CashDeskCode");
	CashDesk = СоответствиеОбъекта.Получить("CashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Sum = СоответствиеОбъекта.Получить("Sum");
	VatValue = СоответствиеОбъекта.Получить("VatValue");
	VatSum = СоответствиеОбъекта.Получить("VatSum");
	Description = СоответствиеОбъекта.Получить("Description");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref of cash income order";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ CashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(CashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(CashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ CashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,CashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(CashDeskCode = НЕОПРЕДЕЛЕНО,Ref,CashDeskCode);
		РЕЗ.Описание = "CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
		Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
			ТекСумма = Число(Sum);
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash income order";
		
			Возврат РЕЗ;
		КонецЕсли;
	ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
		ТекСумма = Sum;
		Если ТекСумма = 0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash income order";
			
			Возврат РЕЗ;
		КонецЕсли;
	Иначе
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect sum of cash income order";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекСуммаНДС = НЕОПРЕДЕЛЕНО;
	ТекСтавкаНДС = НЕОПРЕДЕЛЕНО;
	Если НЕ VatSum = НЕОПРЕДЕЛЕНО Тогда
		
		Если ТипЗНЧ(VatSum)=Тип("Строка") Тогда
			Если СтрНайти(НРЕГ(VatSum),"null")=0 Тогда
				ТекСуммаНДС = Число(VatSum);
			Иначе
				ТекСуммаНДС = 0;
			КонецЕсли;
		//ИначеЕсли ТипЗНЧ(VatSum)=Тип("Число") Тогда
		//	ТекСуммаНДС = VatSum;
		Иначе
			ТекСуммаНДС = VatSum;
		КонецЕсли;
		Если НЕ ТипЗНЧ(ТекСуммаНДС)=Тип("Число") Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Invalid VatSum of cash income order";
			
			Возврат РЕЗ;
		КонецЕсли;
		
		ТекСтавкаНДС = НайтиСтавкуНДС(VatValue);
		Если ТекСтавкаНДС = НЕОПРЕДЕЛЕНО Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Invalid VatValue of cash income order";
			
			Возврат РЕЗ;
		КонецЕсли;
		
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеВКассу);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПоступлениеВКассуДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПоступлениеВКассу.ДополнительныеРеквизиты КАК ПоступлениеВКассуДополнительныеРеквизиты
	               |ГДЕ
	               |	ПоступлениеВКассуДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПоступлениеВКассуДополнительныеРеквизиты.Свойство = &ДопПараметр
	               |	И ПоступлениеВКассуДополнительныеРеквизиты.Ссылка.Касса = &Касса";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	Запрос.УстановитьПараметр("Касса", ТекКасса);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		// Создаём документ
		ТекДок = Документы.ПоступлениеВКассу.СоздатьДокумент();
		
		ТекДок.Дата = ДатаДокумента;
		ТекДок.УстановитьНовыйНомер();
		
		ТекДок.РасшифровкаПлатежа.Очистить();
		
		//Ищем документ-основание
		ДанныеЗаполнения = НЕОПРЕДЕЛЕНО;
		
		ЗапросДанныеЗаполнения = Новый Запрос;
		Если ЗначениеЗаполнено(РасходнаяНакладнаяRef) Тогда
			СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
			ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
			
			ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
			|ГДЕ
			|	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
			|	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
			
			ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", РасходнаяНакладнаяRef);
			ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
			
			ДокОснованияRef = РасходнаяНакладнаяRef;
		ИначеЕсли ЗначениеЗаполнено(ОтчетОРозничныхПродажахRef) Тогда
			СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОтчетОРозничныхПродажах);
			ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
			
			ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ОтчетОРозничныхПродажахДополнительныеРеквизиты.Ссылка
			|ИЗ
			|	Документ.ОтчетОРозничныхПродажах.ДополнительныеРеквизиты КАК ОтчетОРозничныхПродажахДополнительныеРеквизиты
			|ГДЕ
			|	ОтчетОРозничныхПродажахДополнительныеРеквизиты.Значение = &ТекПараметр
			|	И ОтчетОРозничныхПродажахДополнительныеРеквизиты.Свойство = &ДопПараметр";
			
			ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", ОтчетОРозничныхПродажахRef);
			ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
			
			ДокОснованияRef = ОтчетОРозничныхПродажахRef;
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash income order not found";
			
			Возврат РЕЗ;
		КонецЕсли;
		
		ЗапросДанныеЗаполнения.Выполнить();
		РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
		ВыборкаДанныеЗаполнения = РезультатЗапросаДанныеЗаполнения.Выбрать();
		Пока ВыборкаДанныеЗаполнения.Следующий() Цикл
			ДанныеЗаполнения = ВыборкаДанныеЗаполнения.Ссылка;
			
			РасходнаяНакладнаяNumber = ДанныеЗаполнения.Номер;
		КонецЦикла;
		
		Если ДанныеЗаполнения = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash income order not found";
			
			Возврат РЕЗ;
		Иначе
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплату")] = "ЗаполнитьПоСчетуНаОплату";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПоступлениеДСПлан")] = "ЗаполнитьПоПоступлениюДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеДСПлан")] = "ЗаполнитьПоПеремещениюДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходнаяНакладная")] = "ЗаполнитьПоРасходнойНакладной";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетОРозничныхПродажах")] = "ЗаполнитьПоОтчетуОРозничныхПродажах";
			СтратегияЗаполнения[Тип("ДокументСсылка.АктВыполненныхРабот")] = "ЗаполнитьПоАктуВыполненныхРабот";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПередачаВА")] = "ЗаполнитьПоПередачеВА";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.ДоговорКредитаИЗайма")] = "ЗаполнитьПоДоговоруКредитаЗайма";
			СтратегияЗаполнения[Тип("ДокументСсылка.НачисленияПоКредитамИЗаймам")] = "ЗаполнитьПоНачисленияПоКредитамИЗаймам";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриемИПередачаВРемонт")] = "ЗаполнитьПоПриемуВРемонт";
			
			Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПеремещениеДСПлан") Тогда
				ИсключаяСвойства = "Касса, АналитикаПрочихДоходовИРасходов";
			Иначе
				ИсключаяСвойства = "АналитикаПрочихДоходовИРасходов";
			КонецЕсли;
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДанныеЗаполнения, СтратегияЗаполнения, ИсключаяСвойства);
			
			Если ЗначениеЗаполнено(ТекДок.Контрагент.НаименованиеПолное) Тогда
				ТекДок.ПринятоОт = ТекДок.Контрагент.НаименованиеПолное;
			Иначе
				ТекДок.ПринятоОт = ТекДок.Контрагент.Наименование;
			КонецЕсли;
			
			ТекДок.НалогообложениеНДС = НЕОПРЕДЕЛЕНО;
			Если ЗначениеЗаполнено(ТекДок.Контрагент) Тогда
				ТекДок.НалогообложениеНДС = ТекДок.Контрагент.НалогообложениеНДС;
			ИначеЕсли ЗначениеЗаполнено(ТекНалогообложениеНДС) Тогда
				ТекДок.НалогообложениеНДС = ТекНалогообложениеНДС;
			Иначе
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецЕсли;
			
			ТекДок.ВалютаДенежныхСредств = ТекВалюта;
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДенежныхСредств));
			ТекДок.Курс      = ВалютаРасчетовКурсКратность.Курс;
			ТекДок.Кратность = ВалютаРасчетовКурсКратность.Кратность;
			
			ТекДок.Касса = ТекКасса;
			ТекДок.ПодписьКассира = ТекДок.Касса.ПодписьКассира;
			
			// Изменяем табличную часть
			МассивОшибок = Новый Массив();
			Если ТекДок.РасшифровкаПлатежа.Количество()>0 Тогда
				
				СтрокаТабличнойЧасти = ТекДок.РасшифровкаПлатежа[0];
				СтрокаТабличнойЧасти.Курс = ТекДок.Курс;
				СтрокаТабличнойЧасти.Кратность = ТекДок.Кратность;
				
				СтрокаТабличнойЧасти.СуммаПлатежа = Sum;
				СтрокаТабличнойЧасти.СуммаРасчетов = Sum;
				
				Если ТекСтавкаНДС = НЕОПРЕДЕЛЕНО Тогда
					ТекСтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
					СтрокаТабличнойЧасти.СуммаНДС = СтрокаТабличнойЧасти.СуммаПлатежа - (СтрокаТабличнойЧасти.СуммаПлатежа) / ((ТекСтавкаНДС + 100) / 100);
				Иначе
					СтрокаТабличнойЧасти.СтавкаНДС = ТекСтавкаНДС;
					СтрокаТабличнойЧасти.СуммаНДС = ТекСуммаНДС;
				КонецЕсли;
				
				СписокДляУдаления = Новый СписокЗначений();
				Для каждого СтрРасшифровкаПлатежа Из ТекДок.РасшифровкаПлатежа Цикл
					Если НЕ СтрРасшифровкаПлатежа = СтрокаТабличнойЧасти Тогда
						СписокДляУдаления.Добавить(СтрРасшифровкаПлатежа);
					КонецЕсли; 
				КонецЦикла;
				
				Для каждого СтрСписокДляУдаления Из СписокДляУдаления Цикл
					ТекДок.РасшифровкаПлатежа.Удалить(СтрСписокДляУдаления.Значение);
				КонецЦикла;
				
			Иначе
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Incorrect tabular section";
				
				Возврат РЕЗ;
				
			КонецЕсли;
		КонецЕсли;
		
		ТекДок.СуммаДокумента = ТекДок.РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		ТекДок.Автор = НастройкиПоУмолчанию.Автор;
		ТекДок.Комментарий = Description;
		
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,ДокОснованияRef);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,РасходнаяНакладнаяNumber);
		
		// Проводим
		ОписаниеУспешногоПроведения = "Doc cash income order created successfully";
		ЗаписыватьПриОшибках=ЛОЖЬ;
		ОписаниеДляМассиваОшибок="";
		ФиксироватьТранзакции=ЛОЖЬ;
		РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc cash income order already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьПоступлениеВКассу(СтруктураДляВозврата,СоответствиеОбъекта,РасходнаяНакладнаяRef,ОтчетОРозничныхПродажахRef,ТекНалогообложениеНДС=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	CashDeskCode = СоответствиеОбъекта.Получить("CashDeskCode");
	CashDesk = СоответствиеОбъекта.Получить("CashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Sum = СоответствиеОбъекта.Получить("Sum");
	VatValue = СоответствиеОбъекта.Получить("VatValue");
	VatSum = СоответствиеОбъекта.Получить("VatSum");
	Description = СоответствиеОбъекта.Получить("Description");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref of cash income order";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ CashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(CashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(CashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ CashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,CashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(CashDeskCode = НЕОПРЕДЕЛЕНО,Ref,CashDeskCode);
		РЕЗ.Описание = "CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
		Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
			ТекСумма = Число(Sum);
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash income order";
		
			Возврат РЕЗ;
		КонецЕсли;
	ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
		ТекСумма = Sum;
		Если ТекСумма = 0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash income order";
			
			Возврат РЕЗ;
		КонецЕсли;
	Иначе
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect sum of cash income order";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекСуммаНДС = НЕОПРЕДЕЛЕНО;
	ТекСтавкаНДС = НЕОПРЕДЕЛЕНО;
	Если НЕ VatSum = НЕОПРЕДЕЛЕНО Тогда
		
		Если ТипЗНЧ(VatSum)=Тип("Строка") Тогда
			Если СтрНайти(НРЕГ(VatSum),"null")=0 Тогда
				ТекСуммаНДС = Число(VatSum);
			Иначе
				ТекСуммаНДС = 0;
			КонецЕсли;
		//ИначеЕсли ТипЗНЧ(VatSum)=Тип("Число") Тогда
		//	ТекСуммаНДС = VatSum;
		Иначе
			ТекСуммаНДС = VatSum;
		КонецЕсли;
		Если НЕ ТипЗНЧ(ТекСуммаНДС)=Тип("Число") Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Invalid VatSum of cash income order";
			
			Возврат РЕЗ;
		КонецЕсли;
		
		ТекСтавкаНДС = НайтиСтавкуНДС(VatValue);
		Если ТекСтавкаНДС = НЕОПРЕДЕЛЕНО Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Invalid VatValue of cash income order";
			
			Возврат РЕЗ;
		КонецЕсли;
		
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеВКассу);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПоступлениеВКассуДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПоступлениеВКассу.ДополнительныеРеквизиты КАК ПоступлениеВКассуДополнительныеРеквизиты
	               |ГДЕ
	               |	ПоступлениеВКассуДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПоступлениеВКассуДополнительныеРеквизиты.Свойство = &ДопПараметр
	               |	И ПоступлениеВКассуДополнительныеРеквизиты.Ссылка.Касса = &Касса";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	Запрос.УстановитьПараметр("Касса", ТекКасса);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		НачатьТранзакцию();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		КонецЦикла;
		
		// Убираем пометку удаления
		Попытка
			Если ТекДок.ПометкаУдаления Тогда
				ТекДок.Записать(РежимЗаписиДокумента.Запись);
				ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
			КонецЕсли;
		Исключение
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Internal processing error";
			
			Возврат РЕЗ;
		КонецПопытки;
		
		ТекДок.Дата = ДатаДокумента;
		
		ТекДок.РасшифровкаПлатежа.Очистить();
		
		//Ищем документ-основание
		ДанныеЗаполнения = НЕОПРЕДЕЛЕНО;
		
		ЗапросДанныеЗаполнения = Новый Запрос;
		Если ЗначениеЗаполнено(РасходнаяНакладнаяRef) Тогда
			СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
			ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
			
			ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
			|ИЗ
			|	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
			|ГДЕ
			|	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
			|	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
			
			ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", РасходнаяНакладнаяRef);
			ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
			
			ДокОснованияRef = РасходнаяНакладнаяRef;
		ИначеЕсли ЗначениеЗаполнено(ОтчетОРозничныхПродажахRef) Тогда
			СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОтчетОРозничныхПродажах);
			ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
			
			ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ОтчетОРозничныхПродажахДополнительныеРеквизиты.Ссылка
			|ИЗ
			|	Документ.ОтчетОРозничныхПродажах.ДополнительныеРеквизиты КАК ОтчетОРозничныхПродажахДополнительныеРеквизиты
			|ГДЕ
			|	ОтчетОРозничныхПродажахДополнительныеРеквизиты.Значение = &ТекПараметр
			|	И ОтчетОРозничныхПродажахДополнительныеРеквизиты.Свойство = &ДопПараметр";
			
			ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", ОтчетОРозничныхПродажахRef);
			ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
			
			ДокОснованияRef = ОтчетОРозничныхПродажахRef;
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash income order not found";
			
			Возврат РЕЗ;
		КонецЕсли;
		
		ЗапросДанныеЗаполнения.Выполнить();
		РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
		ВыборкаДанныеЗаполнения = РезультатЗапросаДанныеЗаполнения.Выбрать();
		Пока ВыборкаДанныеЗаполнения.Следующий() Цикл
			ДанныеЗаполнения = ВыборкаДанныеЗаполнения.Ссылка;
			
			РасходнаяНакладнаяNumber = ДанныеЗаполнения.Номер;
		КонецЦикла;
		
		Если ДанныеЗаполнения = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash income order not found";
			
			Возврат РЕЗ;
		Иначе
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплату")] = "ЗаполнитьПоСчетуНаОплату";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПоступлениеДСПлан")] = "ЗаполнитьПоПоступлениюДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеДСПлан")] = "ЗаполнитьПоПеремещениюДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходнаяНакладная")] = "ЗаполнитьПоРасходнойНакладной";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетОРозничныхПродажах")] = "ЗаполнитьПоОтчетуОРозничныхПродажах";
			СтратегияЗаполнения[Тип("ДокументСсылка.АктВыполненныхРабот")] = "ЗаполнитьПоАктуВыполненныхРабот";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПередачаВА")] = "ЗаполнитьПоПередачеВА";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.ДоговорКредитаИЗайма")] = "ЗаполнитьПоДоговоруКредитаЗайма";
			СтратегияЗаполнения[Тип("ДокументСсылка.НачисленияПоКредитамИЗаймам")] = "ЗаполнитьПоНачисленияПоКредитамИЗаймам";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриемИПередачаВРемонт")] = "ЗаполнитьПоПриемуВРемонт";
			
			Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПеремещениеДСПлан") Тогда
				ИсключаяСвойства = "Касса, АналитикаПрочихДоходовИРасходов";
			Иначе
				ИсключаяСвойства = "АналитикаПрочихДоходовИРасходов";
			КонецЕсли;
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДанныеЗаполнения, СтратегияЗаполнения, ИсключаяСвойства);
			
			Если ЗначениеЗаполнено(ТекДок.Контрагент.НаименованиеПолное) Тогда
				ТекДок.ПринятоОт = ТекДок.Контрагент.НаименованиеПолное;
			Иначе
				ТекДок.ПринятоОт = ТекДок.Контрагент.Наименование;
			КонецЕсли;
			
			ТекДок.НалогообложениеНДС = НЕОПРЕДЕЛЕНО;
			Если ЗначениеЗаполнено(ТекДок.Контрагент) Тогда
				ТекДок.НалогообложениеНДС = ТекДок.Контрагент.НалогообложениеНДС;
			ИначеЕсли ЗначениеЗаполнено(ТекНалогообложениеНДС) Тогда
				ТекДок.НалогообложениеНДС = ТекНалогообложениеНДС;
			Иначе
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецЕсли;
			
			ТекДок.ВалютаДенежныхСредств = ТекВалюта;
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДенежныхСредств));
			ТекДок.Курс      = ВалютаРасчетовКурсКратность.Курс;
			ТекДок.Кратность = ВалютаРасчетовКурсКратность.Кратность;
			
			ТекДок.Касса = ТекКасса;
			ТекДок.ПодписьКассира = ТекДок.Касса.ПодписьКассира;
			
			// Изменяем табличную часть
			МассивОшибок = Новый Массив();
			Если ТекДок.РасшифровкаПлатежа.Количество()>0 Тогда
				
				СтрокаТабличнойЧасти = ТекДок.РасшифровкаПлатежа[0];
				СтрокаТабличнойЧасти.Курс = ТекДок.Курс;
				СтрокаТабличнойЧасти.Кратность = ТекДок.Кратность;
				
				СтрокаТабличнойЧасти.СуммаПлатежа = Sum;
				СтрокаТабличнойЧасти.СуммаРасчетов = Sum;
				
				Если ТекСтавкаНДС = НЕОПРЕДЕЛЕНО Тогда
					ТекСтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
					СтрокаТабличнойЧасти.СуммаНДС = СтрокаТабличнойЧасти.СуммаПлатежа - (СтрокаТабличнойЧасти.СуммаПлатежа) / ((ТекСтавкаНДС + 100) / 100);
				Иначе
					СтрокаТабличнойЧасти.СтавкаНДС = ТекСтавкаНДС;
					СтрокаТабличнойЧасти.СуммаНДС = ТекСуммаНДС;
				КонецЕсли;
				
				СписокДляУдаления = Новый СписокЗначений();
				Для каждого СтрРасшифровкаПлатежа Из ТекДок.РасшифровкаПлатежа Цикл
					Если НЕ СтрРасшифровкаПлатежа = СтрокаТабличнойЧасти Тогда
						СписокДляУдаления.Добавить(СтрРасшифровкаПлатежа);
					КонецЕсли; 
				КонецЦикла;
				
				Для каждого СтрСписокДляУдаления Из СписокДляУдаления Цикл
					ТекДок.РасшифровкаПлатежа.Удалить(СтрСписокДляУдаления.Значение);
				КонецЦикла;
				
			Иначе
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Incorrect tabular section";
				
				Возврат РЕЗ;
				
			КонецЕсли;
		КонецЕсли;
		
		ТекДок.СуммаДокумента = ТекДок.РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		ТекДок.Автор = НастройкиПоУмолчанию.Автор;
		ТекДок.Комментарий = Description;
		
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,ДокОснованияRef);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,РасходнаяНакладнаяNumber);
		
		// Проводим
		ОписаниеУспешногоПроведения = "Doc cash income order updated successfully";
		ЗаписыватьПриОшибках=ЛОЖЬ;
		ОписаниеДляМассиваОшибок="";
		ФиксироватьТранзакции=ИСТИНА;
		РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc cash income order not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

