Функция СоздатьОприходованиеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта, НастройкиПоУмолчанию, СчетКоррекспорденцииРегл, Подразделение=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	//НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	//Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	//
	//	РЕЗ.Результат = ЛОЖЬ;
	//	РЕЗ.ВозвращаемоеЗначение = Ref;
	//	РЕЗ.Описание = "Incorrect default settings";
	//	
	//	Возврат РЕЗ;
	//
	//КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОприходованиеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ОприходованиеЗапасовДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ОприходованиеЗапасов.ДополнительныеРеквизиты КАК ОприходованиеЗапасовДополнительныеРеквизиты
	               |ГДЕ
	               |	ОприходованиеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ОприходованиеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		//Ищем склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			ТекДок = Документы.ОприходованиеЗапасов.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.ИнвентаризацияЗапасов")] = "ЗаполнитьПоИнвентаризацииЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходномуОрдеру";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриемИПередачаВРемонт")] = "ЗаполнитьПоПриемИПередачаВРемонт";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, НЕОПРЕДЕЛЕНО, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
					
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			ТекДок.ПодписьКладовщика = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			
			ТекДок.Корреспонденция = ПланыСчетов.Управленческий.ПрочиеДоходы;
			ТекДок.КорреспонденцияРегл = СчетКоррекспорденцииРегл;
			РегламентированныйУчетСервер.УстановитьУпрСчетИзПланаСчетовХозрасчетный(ТекДок.КорреспонденцияРегл, ТекДок.Корреспонденция);
			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				ТекДок.Подразделение = Подразделение;
			КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
				БухОстатки = ПолучитьОстаткиТовараПоБухСчетам(СтрокаТабличнойЧасти.Номенклатура,ТекСклад,ТекДок.Дата);
				Если БухОстатки.Цена>0 Тогда
					СтрокаТабличнойЧасти.Цена = БухОстатки.Цена;
				КонецЕсли;
				
				//Если ЗначениеЗаполнено(ТекДок.ВидЦен) И СтрокаТабличнойЧасти.Цена=0 Тогда
				//	
				//	СтруктураДанные = Новый Структура();
				//	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
				//	СтруктураДанные.Вставить("ДатаОбработки", ТекДок.Дата);
				//	СтруктураДанные.Вставить("Организация", ТекДок.Организация);
				//	СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
				//	СтруктураДанные.Вставить("ВидЦен", ТекДок.ВидЦен);
				//	СтруктураДанные.Вставить("Коэффициент", 1);
				//	
				//	СтруктураДанные.Вставить("ВалютаДокумента", Константы.ВалютаУчета.Получить());
				//	Цена = УправлениеНебольшойФирмойСервер.ПолучитьЦенуНоменклатурыПоВидуЦен(СтруктураДанные);
				//	СтруктураДанные.Вставить("Цена", Цена);
				//	
				//	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
				//	
				//КонецЕсли;
				
				Если СтрокаТабличнойЧасти.Цена=0 Тогда
					
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Cost of goods is not determined";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
					
				Иначе
					
					СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
					
				КонецЕсли;
				
			КонецЦикла;
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
			
			// Проводим
			ОписаниеУспешногоПроведения = "Doc surplus created successfully";
			ЗаписыватьПриОшибках=ИСТИНА;
			ОписаниеДляМассиваОшибок="Doc surplus has been created successfully but not posted";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc surplus already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьОприходованиеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта, НастройкиПоУмолчанию, СчетКоррекспорденцииРегл=НЕОПРЕДЕЛЕНО, Подразделение=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	//НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	//Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	//
	//	РЕЗ.Результат = ЛОЖЬ;
	//	РЕЗ.ВозвращаемоеЗначение = Ref;
	//	РЕЗ.Описание = "Incorrect default settings";
	//	
	//	Возврат РЕЗ;
	//
	//КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОприходованиеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ОприходованиеЗапасовДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ОприходованиеЗапасов.ДополнительныеРеквизиты КАК ОприходованиеЗапасовДополнительныеРеквизиты
	               |ГДЕ
	               |	ОприходованиеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ОприходованиеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		//Ищем склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
			
			ТекДок.Дата = ДатаДокумента;
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
						
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;

			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			ТекДок.ПодписьКладовщика = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			
			Если ЗначениеЗаполнено(СчетКоррекспорденцииРегл) Тогда
				ТекДок.Корреспонденция = ПланыСчетов.Управленческий.ПрочиеДоходы;
				ТекДок.КорреспонденцияРегл = СчетКоррекспорденцииРегл;
				РегламентированныйУчетСервер.УстановитьУпрСчетИзПланаСчетовХозрасчетный(ТекДок.КорреспонденцияРегл, ТекДок.Корреспонденция);	
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				ТекДок.Подразделение = Подразделение;
			КонецЕсли;
		
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
					
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
				БухОстатки = ПолучитьОстаткиТовараПоБухСчетам(СтрокаТабличнойЧасти.Номенклатура,ТекСклад,ТекДок.Дата);
				Если БухОстатки.Цена>0 Тогда
					СтрокаТабличнойЧасти.Цена = БухОстатки.Цена;
				КонецЕсли;
				
				//Если ЗначениеЗаполнено(ТекДок.ВидЦен) И СтрокаТабличнойЧасти.Цена=0 Тогда
				//	
				//	СтруктураДанные = Новый Структура();
				//	СтруктураДанные.Вставить("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
				//	СтруктураДанные.Вставить("ДатаОбработки", ТекДок.Дата);
				//	СтруктураДанные.Вставить("Организация", ТекДок.Организация);
				//	СтруктураДанные.Вставить("Характеристика", СтрокаТабличнойЧасти.Характеристика);
				//	СтруктураДанные.Вставить("ВидЦен", ТекДок.ВидЦен);
				//	СтруктураДанные.Вставить("Коэффициент", 1);
				//	
				//	СтруктураДанные.Вставить("ВалютаДокумента", Константы.ВалютаУчета.Получить());
				//	Цена = УправлениеНебольшойФирмойСервер.ПолучитьЦенуНоменклатурыПоВидуЦен(СтруктураДанные);
				//	СтруктураДанные.Вставить("Цена", Цена);
				//	
				//	СтрокаТабличнойЧасти.Цена = СтруктураДанные.Цена;
				//	
				//КонецЕсли;
				
				Если СтрокаТабличнойЧасти.Цена=0 Тогда
					
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Cost of goods is not determined";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
					
				Иначе
					
					СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
					
				КонецЕсли;
				
			КонецЦикла;
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
			
			// Проводим
			ОписаниеУспешногоПроведения = "Doc surplus updated successfully";
			ЗаписыватьПриОшибках=ИСТИНА;
			ОписаниеДляМассиваОшибок="Doc surplus has been updated successfully but not posted";
			ФиксироватьТранзакции=ИСТИНА;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc surplus not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьОприходованиеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОприходованиеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ОприходованиеЗапасовДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.ОприходованиеЗапасов.ДополнительныеРеквизиты КАК ОприходованиеЗапасовДополнительныеРеквизиты
	                      |ГДЕ
	                      |	ОприходованиеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И ОприходованиеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc surplus deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc surplus not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
