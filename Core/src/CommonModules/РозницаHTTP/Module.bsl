Функция СоздатьСписаниеЗапасовНедостача(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
			
	КонецЕсли;
	
	//Ищем склад
	ТекСклад = НЕОПРЕДЕЛЕНО;
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Если РЕЗ.Результат Тогда
		ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
		Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
			РЕЗ.Описание = "Warehouse not found";
		КонецЕсли;
	КонецЕсли;
	
	Если РЕЗ.Результат Тогда
		СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
		Подразделение = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов.WriteОffSubdivision);
		
		РЕЗ = СоздатьСписаниеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта,НастройкиПоУмолчанию,НастройкиПоУмолчанию.КорреспонденцияРеглСписаниеЗапасов,Подразделение);
	КонецЕсли;
		
	Возврат РЕЗ;
