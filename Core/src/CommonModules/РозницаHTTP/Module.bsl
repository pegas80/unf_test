Функция СоздатьИлиОбновитьПоступлениеВКассуИзРасходнойНакладной(СтруктураДляВозврата,СоответствиеОбъекта,Ref) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);

	РеквизитовПоступлениеВКассуRef = СоответствиеОбъекта.Получить("Ref");
	CashDeskCode = СоответствиеОбъекта.Получить("CashDeskCode");
	CashDesk = СоответствиеОбъекта.Получить("CashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ CashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(CashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(CashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ CashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,CashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(CashDeskCode = НЕОПРЕДЕЛЕНО,Ref,CashDeskCode);
		РЕЗ.Описание = "CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитовПоступлениеВКассу = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеВКассу);
	ДопПараметрПоступлениеВКассу = СтруктураДополнительныхРеквизитовПоступлениеВКассу.DocRef;
	
	ЗапросПоступлениеВКассу = Новый Запрос;
	ЗапросПоступлениеВКассу.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	                                |	ПоступлениеВКассуДополнительныеРеквизиты.Ссылка
	                                |ИЗ
	                                |	Документ.ПоступлениеВКассу.ДополнительныеРеквизиты КАК ПоступлениеВКассуДополнительныеРеквизиты
	                                |ГДЕ
	                                |	ПоступлениеВКассуДополнительныеРеквизиты.Значение = &ТекПараметр
	                                |	И ПоступлениеВКассуДополнительныеРеквизиты.Свойство = &ДопПараметр
	                                |	И ПоступлениеВКассуДополнительныеРеквизиты.Ссылка.Касса = &Касса";
	
	ЗапросПоступлениеВКассу.УстановитьПараметр("ТекПараметр", РеквизитовПоступлениеВКассуRef);
	ЗапросПоступлениеВКассу.УстановитьПараметр("ДопПараметр", ДопПараметрПоступлениеВКассу);
	ЗапросПоступлениеВКассу.УстановитьПараметр("Касса", ТекКасса);
	РезультатЗапросаПоступлениеВКассу = ЗапросПоступлениеВКассу.Выполнить();
	Если РезультатЗапросаПоступлениеВКассу.Пустой() Тогда
		РЕЗ = СоздатьПоступлениеВКассу(РЕЗ,СоответствиеОбъекта,Ref,НЕОПРЕДЕЛЕНО);
	Иначе
		РЕЗ = ОбновитьПоступлениеВКассу(РЕЗ,СоответствиеОбъекта,Ref,НЕОПРЕДЕЛЕНО);
	КонецЕсли;	

	Возврат РЕЗ;
КонецФункции // ()
#КонецОбласти

#Область РасходИзКассы
Функция СоздатьРасходИзКассы(СтруктураДляВозврата,СоответствиеОбъекта,ПриходнаяНакладнаяRef,ТекНалогообложениеНДС=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	CashDeskCode = СоответствиеОбъекта.Получить("CashDeskCode");
	CashDesk = СоответствиеОбъекта.Получить("CashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Sum = СоответствиеОбъекта.Получить("Sum");
	Description = СоответствиеОбъекта.Получить("Description");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref of cash expense order";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ CashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(CashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(CashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ CashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,CashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(CashDeskCode = НЕОПРЕДЕЛЕНО,Ref,CashDeskCode);
		РЕЗ.Описание = "CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
		Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
			ТекСумма = Число(Sum);
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash expense order";
		
			Возврат РЕЗ;
		КонецЕсли;
	ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
		ТекСумма = Sum;
		Если ТекСумма = 0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash expense order";
			
			Возврат РЕЗ;
		КонецЕсли;
	Иначе
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect sum of cash expense order";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходИзКассы);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасходИзКассыДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.РасходИзКассы.ДополнительныеРеквизиты КАК РасходИзКассыДополнительныеРеквизиты
	               |ГДЕ
	               |	РасходИзКассыДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И РасходИзКассыДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		// Создаём документ
		ТекДок = Документы.РасходИзКассы.СоздатьДокумент();
		
		ТекДок.Дата = ДатаДокумента;
		ТекДок.УстановитьНовыйНомер();
		
		ТекДок.РасшифровкаПлатежа.Очистить();
		
		//Ищем документ-основание
		ДанныеЗаполнения = НЕОПРЕДЕЛЕНО;
		
		ЗапросДанныеЗаполнения = Новый Запрос;
		Если ЗначениеЗаполнено(ПриходнаяНакладнаяRef) Тогда
			СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
			ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
			
			ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
			|ИЗ
			|	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
			|ГДЕ
			|	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
			|	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
			
			ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", ПриходнаяНакладнаяRef);
			ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
			
			ДокОснованияRef = ПриходнаяНакладнаяRef;
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash expense order not found";
			
			Возврат РЕЗ;
		КонецЕсли;
		
		ЗапросДанныеЗаполнения.Выполнить();
		РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
		ВыборкаДанныеЗаполнения = РезультатЗапросаДанныеЗаполнения.Выбрать();
		Пока ВыборкаДанныеЗаполнения.Следующий() Цикл
			ДанныеЗаполнения = ВыборкаДанныеЗаполнения.Ссылка;
			
			ПриходнаяНакладнаяNumber = ДанныеЗаполнения.Номер;
		КонецЦикла;
		
		Если ДанныеЗаполнения = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash expense order not found";
			
			Возврат РЕЗ;
		Иначе
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходДСПлан")] = "ЗаполнитьПоРасходДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеДСПлан")] = "ЗаполнитьПоПеремещениеДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнаяНакладная";
			СтратегияЗаполнения[Тип("ДокументСсылка.ДополнительныеРасходы")] = "ЗаполнитьПоДополнительныеРасходы";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетКомиссионера")] = "ЗаполнитьПоОтчетКомиссионера";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетКомитенту")] = "ЗаполнитьПоОтчетКомитенту";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказПоставщику";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплатуПоставщика")] = "ЗаполнитьПоСчетНаОплатуПоставщика";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПлатежнаяВедомость")] = "ЗаполнитьПоПлатежнаяВедомость";
			СтратегияЗаполнения[Тип("ДокументСсылка.НачислениеНалогов")] = "ЗаполнитьПоНачислениеНалогов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ДоговорКредитаИЗайма")] = "ЗаполнитьПоДоговоруКредитаЗайма";
			СтратегияЗаполнения[Тип("ДокументСсылка.НачисленияПоКредитамИЗаймам")] = "ЗаполнитьПоНачисленияПоКредитамИЗаймам";
			СтратегияЗаполнения[Тип("ДокументСсылка.АвансовыйОтчет")] = "ЗаполнитьПоАвансовыйОтчет";
			
			Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПеремещениеДСПлан") Тогда
				ИсключаяСвойства = "Касса, АналитикаПрочихДоходовИРасходов";
			Иначе
				ИсключаяСвойства = "АналитикаПрочихДоходовИРасходов";
			КонецЕсли;
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДанныеЗаполнения, СтратегияЗаполнения, ИсключаяСвойства);			
			
			Если ЗначениеЗаполнено(ТекДок.Контрагент.НаименованиеПолное) Тогда
				ТекДок.Выдать = ТекДок.Контрагент.НаименованиеПолное;
			Иначе
				ТекДок.Выдать = ТекДок.Контрагент.Наименование;
			КонецЕсли;
			
			ТекДок.НалогообложениеНДС = НЕОПРЕДЕЛЕНО;
			Если ЗначениеЗаполнено(ТекДок.Контрагент) Тогда
				ТекДок.НалогообложениеНДС = ТекДок.Контрагент.НалогообложениеНДС;
			ИначеЕсли ЗначениеЗаполнено(ТекНалогообложениеНДС) Тогда
				ТекДок.НалогообложениеНДС = ТекНалогообложениеНДС;
			Иначе
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецЕсли;
			
			ТекДок.ВалютаДенежныхСредств = ТекВалюта;
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДенежныхСредств));
			ТекКурс      = ВалютаРасчетовКурсКратность.Курс;
			ТекКратность = ВалютаРасчетовКурсКратность.Кратность;
			
			ТекДок.Касса = ТекКасса;
			
			// Изменяем табличную часть
			МассивОшибок = Новый Массив();
			Если ТекДок.РасшифровкаПлатежа.Количество()>0 Тогда
				
				СтрокаТабличнойЧасти = ТекДок.РасшифровкаПлатежа[0];
				СтрокаТабличнойЧасти.Курс = ТекКурс;
				СтрокаТабличнойЧасти.Кратность = ТекКратность;
				
				СтрокаТабличнойЧасти.СуммаПлатежа = Sum;
				СтрокаТабличнойЧасти.СуммаРасчетов = Sum;
				
				ТекСтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
				СтрокаТабличнойЧасти.СуммаНДС = СтрокаТабличнойЧасти.СуммаПлатежа - (СтрокаТабличнойЧасти.СуммаПлатежа) / ((ТекСтавкаНДС + 100) / 100);
				
			Иначе
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Incorrect tabular section";
				
				Возврат РЕЗ;
				
			КонецЕсли;
		КонецЕсли;
		
		ТекДок.СуммаДокумента = ТекДок.РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		ТекДок.Автор = НастройкиПоУмолчанию.Автор;
		ТекДок.Комментарий = Description;
		
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,ДокОснованияRef);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,ПриходнаяНакладнаяNumber);
		
		// Проводим
		ОписаниеУспешногоПроведения = "Doc cash expense order created successfully";
		ЗаписыватьПриОшибках=ЛОЖЬ;
		ОписаниеДляМассиваОшибок="";
		ФиксироватьТранзакции=ЛОЖЬ;
		РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc cash expense order already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьРасходИзКассы(СтруктураДляВозврата,СоответствиеОбъекта,ПриходнаяНакладнаяRef,ТекНалогообложениеНДС=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	CashDeskCode = СоответствиеОбъекта.Получить("CashDeskCode");
	CashDesk = СоответствиеОбъекта.Получить("CashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Sum = СоответствиеОбъекта.Получить("Sum");
	Description = СоответствиеОбъекта.Получить("Description");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref of cash expense order";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ CashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(CashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(CashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ CashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,CashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(CashDeskCode = НЕОПРЕДЕЛЕНО,Ref,CashDeskCode);
		РЕЗ.Описание = "CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
		Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
			ТекСумма = Число(Sum);
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash expense order";
		
			Возврат РЕЗ;
		КонецЕсли;
	ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
		ТекСумма = Sum;
		Если ТекСумма = 0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of cash expense order";
			
			Возврат РЕЗ;
		КонецЕсли;
	Иначе
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect sum of cash expense order";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходИзКассы);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасходИзКассыДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.РасходИзКассы.ДополнительныеРеквизиты КАК РасходИзКассыДополнительныеРеквизиты
	               |ГДЕ
	               |	РасходИзКассыДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И РасходИзКассыДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		НачатьТранзакцию();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		КонецЦикла;
		
		// Убираем пометку удаления
		Попытка
			Если ТекДок.ПометкаУдаления Тогда
				ТекДок.Записать(РежимЗаписиДокумента.Запись);
				ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
			КонецЕсли;
		Исключение
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Internal processing error";
			
			Возврат РЕЗ;
		КонецПопытки;
		
		ТекДок.Дата = ДатаДокумента;
		
		ТекДок.РасшифровкаПлатежа.Очистить();
		
		//Ищем документ-основание
		ДанныеЗаполнения = НЕОПРЕДЕЛЕНО;
		
		ЗапросДанныеЗаполнения = Новый Запрос;
		Если ЗначениеЗаполнено(ПриходнаяНакладнаяRef) Тогда
			СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
			ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
			
			ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			|	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
			|ИЗ
			|	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
			|ГДЕ
			|	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
			|	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
			
			ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", ПриходнаяНакладнаяRef);
			ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
			
			ДокОснованияRef = ПриходнаяНакладнаяRef;
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash expense order not found";
			
			Возврат РЕЗ;
		КонецЕсли;
		
		ЗапросДанныеЗаполнения.Выполнить();
		РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
		ВыборкаДанныеЗаполнения = РезультатЗапросаДанныеЗаполнения.Выбрать();
		Пока ВыборкаДанныеЗаполнения.Следующий() Цикл
			ДанныеЗаполнения = ВыборкаДанныеЗаполнения.Ссылка;
			
			ПриходнаяНакладнаяNumber = ДанныеЗаполнения.Номер;
		КонецЦикла;
		
		Если ДанныеЗаполнения = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A document base of cash expense order not found";
			
			Возврат РЕЗ;
		Иначе
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходДСПлан")] = "ЗаполнитьПоРасходДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеДСПлан")] = "ЗаполнитьПоПеремещениеДСПлан";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнаяНакладная";
			СтратегияЗаполнения[Тип("ДокументСсылка.ДополнительныеРасходы")] = "ЗаполнитьПоДополнительныеРасходы";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетКомиссионера")] = "ЗаполнитьПоОтчетКомиссионера";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетКомитенту")] = "ЗаполнитьПоОтчетКомитенту";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказПоставщику";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплатуПоставщика")] = "ЗаполнитьПоСчетНаОплатуПоставщика";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПлатежнаяВедомость")] = "ЗаполнитьПоПлатежнаяВедомость";
			СтратегияЗаполнения[Тип("ДокументСсылка.НачислениеНалогов")] = "ЗаполнитьПоНачислениеНалогов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ДоговорКредитаИЗайма")] = "ЗаполнитьПоДоговоруКредитаЗайма";
			СтратегияЗаполнения[Тип("ДокументСсылка.НачисленияПоКредитамИЗаймам")] = "ЗаполнитьПоНачисленияПоКредитамИЗаймам";
			СтратегияЗаполнения[Тип("ДокументСсылка.АвансовыйОтчет")] = "ЗаполнитьПоАвансовыйОтчет";
			
			Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПеремещениеДСПлан") Тогда
				ИсключаяСвойства = "Касса, АналитикаПрочихДоходовИРасходов";
			Иначе
				ИсключаяСвойства = "АналитикаПрочихДоходовИРасходов";
			КонецЕсли;
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДанныеЗаполнения, СтратегияЗаполнения, ИсключаяСвойства);
			
			Если ЗначениеЗаполнено(ТекДок.Контрагент.НаименованиеПолное) Тогда
				ТекДок.Выдать = ТекДок.Контрагент.НаименованиеПолное;
			Иначе
				ТекДок.Выдать = ТекДок.Контрагент.Наименование;
			КонецЕсли;
			
			ТекДок.НалогообложениеНДС = НЕОПРЕДЕЛЕНО;
			Если ЗначениеЗаполнено(ТекДок.Контрагент) Тогда
				ТекДок.НалогообложениеНДС = ТекДок.Контрагент.НалогообложениеНДС;
			ИначеЕсли ЗначениеЗаполнено(ТекНалогообложениеНДС) Тогда
				ТекДок.НалогообложениеНДС = ТекНалогообложениеНДС;
			Иначе
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецЕсли;
			
			ТекДок.ВалютаДенежныхСредств = ТекВалюта;
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДенежныхСредств));
			ТекКурс      = ВалютаРасчетовКурсКратность.Курс;
			ТекКратность = ВалютаРасчетовКурсКратность.Кратность;
			
			ТекДок.Касса = ТекКасса;
			
			// Изменяем табличную часть
			МассивОшибок = Новый Массив();
			Если ТекДок.РасшифровкаПлатежа.Количество()>0 Тогда
				
				СтрокаТабличнойЧасти = ТекДок.РасшифровкаПлатежа[0];
				СтрокаТабличнойЧасти.Курс = ТекКурс;
				СтрокаТабличнойЧасти.Кратность = ТекКратность;
				
				СтрокаТабличнойЧасти.СуммаПлатежа = Sum;
				СтрокаТабличнойЧасти.СуммаРасчетов = Sum;
				
				ТекСтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
				СтрокаТабличнойЧасти.СуммаНДС = СтрокаТабличнойЧасти.СуммаПлатежа - (СтрокаТабличнойЧасти.СуммаПлатежа) / ((ТекСтавкаНДС + 100) / 100);
				
			Иначе
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Incorrect tabular section";
				
				Возврат РЕЗ;
				
			КонецЕсли;
		КонецЕсли;
		
		ТекДок.СуммаДокумента = ТекДок.РасшифровкаПлатежа.Итог("СуммаПлатежа");
		
		ТекДок.Автор = НастройкиПоУмолчанию.Автор;
		ТекДок.Комментарий = Description;
		
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,ДокОснованияRef);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,ПриходнаяНакладнаяNumber);
		
		// Проводим
		ОписаниеУспешногоПроведения = "Doc cash expense order updated successfully";
		ЗаписыватьПриОшибках=ЛОЖЬ;
		ОписаниеДляМассиваОшибок="";
		ФиксироватьТранзакции=ИСТИНА;
		РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc cash expense order not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

