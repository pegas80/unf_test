Процедура ОбработатьДеревоСтруктурыПодчиненности(ТекСтрока,МассивРезультатов,ТекСсылка,мУжеВСписке)

	СтруктураДанных = ОбработатьДанныеДляСтруктурыПодчиненности(ТекСтрока,ТекСсылка);
	
	Если мУжеВСписке[ТекСтрока.Ссылка] = Неопределено Тогда
		МассивРезультатов.Добавить(СтруктураДанных);
		мУжеВСписке.Вставить(ТекСтрока.Ссылка, Истина);
	КонецЕсли;
	
	Для каждого СтрокаДерева Из ТекСтрока.Строки Цикл
	
		ОбработатьДеревоСтруктурыПодчиненности(СтрокаДерева,МассивРезультатов,ТекСсылка,мУжеВСписке);
		
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьДокументПоСсылке(СтруктураДляВозврата,ТекСсылка) ЭКСПОРТ

	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	// Ищем исходный документ
	Попытка
	
		ТекУникальныйИдентификатор = Новый УникальныйИдентификатор(ТекСсылка);
	
	Исключение
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекСсылка;
		РЕЗ.Описание = "Invalid reference";
		
		Возврат РЕЗ;
	
	КонецПопытки;
	
	СсылкаНаДокумент = НЕОПРЕДЕЛЕНО;
	ДокументОбъект = НЕОПРЕДЕЛЕНО;
	
	Для каждого ТекМенеджерДокументов Из Документы Цикл
	
		СсылкаНаДокумент = ТекМенеджерДокументов.ПолучитьСсылку(ТекУникальныйИдентификатор);
		ДокументОбъект = СсылкаНаДокумент.ПолучитьОбъект();
		Если НЕ ДокументОбъект = НЕОПРЕДЕЛЕНО Тогда
			Прервать;
		КонецЕсли;
	
	КонецЦикла;
	
	Если ДокументОбъект = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекСсылка;
		РЕЗ.Описание = "Reference not found";
		
		// Ищем по дополнительному реквизиту
		СтруктураДополнительныхРеквизитовПриходнаяНакладная = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
		ДопПараметрПриходнаяНакладная = СтруктураДополнительныхРеквизитовПриходнаяНакладная.DocRef;
		
		СтруктураДополнительныхРеквизитовПеремещениеЗапасов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
		ДопПараметрПеремещениеЗапасов = СтруктураДополнительныхРеквизитовПеремещениеЗапасов.DocRef;
		
		СтруктураДополнительныхРеквизитовПриходныйОрдер = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер);
		ДопПараметрПриходныйОрдер = СтруктураДополнительныхРеквизитовПриходныйОрдер.DocRef;
		
		СтруктураДополнительныхРеквизитовРасходныйОрдер = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер);
		ДопПараметрРасходныйОрдер = СтруктураДополнительныхРеквизитовРасходныйОрдер.DocRef;
		
		СтруктураДополнительныхРеквизитовОприходованиеЗапасов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОприходованиеЗапасов);
		ДопПараметрОприходованиеЗапасов = СтруктураДополнительныхРеквизитовОприходованиеЗапасов.DocRef;
		
		СтруктураДополнительныхРеквизитовСписаниеЗапасов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_СписаниеЗапасов);
		ДопПараметрСписаниеЗапасов = СтруктураДополнительныхРеквизитовСписаниеЗапасов.DocRef;
		
		СтруктураДополнительныхРеквизитовРасходнаяНакладная = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
		ДопПараметрРасходнаяНакладная = СтруктураДополнительныхРеквизитовРасходнаяНакладная.DocRef;
		
		СтруктураДополнительныхРеквизитовОтчетОРозничныхПродажах = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ОтчетОРозничныхПродажах);
		ДопПараметрОтчетОРозничныхПродажах = СтруктураДополнительныхРеквизитовОтчетОРозничныхПродажах.DocRef;
		
		СтруктураДополнительныхРеквизитовПоступлениеВКассу = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеВКассу);
		ДопПараметрПоступлениеВКассу = СтруктураДополнительныхРеквизитовПоступлениеВКассу.DocRef;
		
		СтруктураДополнительныхРеквизитовРасходИзКассы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходИзКассы);
		ДопПараметрРасходИзКассы = СтруктураДополнительныхРеквизитовРасходИзКассы.DocRef;
		
		СтруктураДополнительныхРеквизитовПоступлениеНаСчет = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеНаСчет);
		ДопПараметрПоступлениеНаСчет = СтруктураДополнительныхРеквизитовПоступлениеНаСчет.DocRef;
		
