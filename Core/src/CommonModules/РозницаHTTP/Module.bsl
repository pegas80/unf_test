#Область Контрагенты
Функция СоздатьКонтрагента(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	CIN = СоответствиеОбъекта.Получить("CIN");
	Name = СоответствиеОбъекта.Получить("Name");
	FullName = СоответствиеОбъекта.Получить("FullName");
	PartnerGroup = СоответствиеОбъекта.Получить("PartnerGroup");
	PartnerGroupCode = СоответствиеОбъекта.Получить("PartnerGroupCode");
	Description = СоответствиеОбъекта.Получить("Description");
	PartnerType = СоответствиеОбъекта.Получить("PartnerType");
	Currency = СоответствиеОбъекта.Получить("Currency");
	
	Если НЕ ЗначениеЗаполнено(CIN) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = CIN;
		РЕЗ.Описание = "Incorrect CIN";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = CIN;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	Контрагенты.Ссылка
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	НЕ Контрагенты.ЭтоГруппа
	               |	И Контрагенты.ИНН = &ТекПараметр";
	
	Запрос.УстановитьПараметр("ТекПараметр", CIN);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		НачатьТранзакцию();
		
		ГруппаКонтрагентов = НЕОПРЕДЕЛЕНО; // Ищем группу товаров по наименованию
		Если НЕ PartnerGroup = НЕОПРЕДЕЛЕНО Тогда
			
			PartnerGroup = СокрЛП(Строка(PartnerGroup));
		
			Если СтрДлина(PartnerGroup)>0 Тогда
			
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				               |	Контрагенты.Ссылка
				               |ИЗ
				               |	Справочник.Контрагенты КАК Контрагенты
				               |ГДЕ
				               |	Контрагенты.Наименование = &PartnerGroup
				               |	И Контрагенты.ЭтоГруппа";
				
				Запрос.УстановитьПараметр("PartnerGroup", PartnerGroup);
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					ГруппаКонтрагентов = ВыборкаДетальныеЗаписи.Ссылка;
				КонецЦикла;
				
				Если НЕ ЗначениеЗаполнено(ГруппаКонтрагентов) Тогда
				
					ГруппаКонтрагентов = Справочники.Контрагенты.СоздатьГруппу();
					//ГруппаКонтрагентов.ОбменДанными.Загрузка = ИСТИНА;
					ГруппаКонтрагентов.Наименование = СокрЛП(PartnerGroup);
					Попытка
						ГруппаКонтрагентов.Записать();
					Исключение
					КонецПопытки;
				
				КонецЕсли;
			
			КонецЕсли;
		
		КонецЕсли;
		
		// Создаем элемент справочника Контрагенты;
		ТекКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
		ТекКонтрагент.ОбменДанными.Загрузка = ИСТИНА;
		
		ТекКонтрагент.УстановитьНовыйКод();
		ТекКонтрагент.Наименование = СокрЛП(Name);
		ТекКонтрагент.НаименованиеПолное = СокрЛП(FullName);
		ТекКонтрагент.Родитель = ГруппаКонтрагентов;
		ТекКонтрагент.ИНН = CIN;
		ТекКонтрагент.Комментарий = Description+"; PartnerType="+СокрЛП(Строка(PartnerType));
		ТекКонтрагент.Покупатель = ИСТИНА;
		ТекКонтрагент.Поставщик = ИСТИНА;
		ТекКонтрагент.ВестиРасчетыПоДоговорам = ИСТИНА;
		ТекКонтрагент.ВестиРасчетыПоДокументам = ИСТИНА;
		ТекКонтрагент.ВестиРасчетыПоЗаказам = ИСТИНА;
		ТекКонтрагент.ВестиУчетОплатыПоСчетам = ИСТИНА;
		
		ТекКонтрагент.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС");
		Если ЗначениеЗаполнено(PartnerType) Тогда // Пожалуй эта проверка лишняя
			Если PartnerType=2 Тогда
				ТекКонтрагент.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС");
			Иначе//Если PartnerType=3 Тогда
				ТекКонтрагент.ВидКонтрагента = ПредопределенноеЗначение("Перечисление.ВидыКонтрагентов.ЮридическоеЛицо");
			КонецЕсли;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ТекКонтрагент,НастройкиПоУмолчанию);
		
		Попытка
			ТекКонтрагент.Записать();
			
			//ЗафиксироватьТранзакцию();
			
			РЕЗ.Результат = ИСТИНА;
			РЕЗ.ВозвращаемоеЗначение = CIN;
			РЕЗ.Описание = "Partner created successfully";
		Исключение
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = CIN;
			РЕЗ.Описание = "Internal processing error";
			
			Возврат РЕЗ;
		КонецПопытки;
		
		// Создаем договор по умолчанию
		Если РЕЗ.Результат Тогда
		
			ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,ИСТИНА,ИСТИНА);
			Если ТекДоговор = НЕОПРЕДЕЛЕНО Тогда
			
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = CIN;
				РЕЗ.Описание = "Internal processing error";
				
			Иначе
				
				Попытка
					
					ТекКонтрагент.ДоговорПоУмолчанию = ТекДоговор.ссылка;
					ТекКонтрагент.Записать();
					
					ЗафиксироватьТранзакцию();
					
					РЕЗ.Результат = ИСТИНА;
					РЕЗ.ВозвращаемоеЗначение = CIN;
					РЕЗ.Описание = "Partner created successfully";
				Исключение
					
					Если ТранзакцияАктивна() Тогда
						ОтменитьТранзакцию();
					КонецЕсли;
					
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = CIN;
					РЕЗ.Описание = "Internal processing error";			
				КонецПопытки;
			КонецЕсли;
		
		КонецЕсли;
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = CIN;
		РЕЗ.Описание = "Partner already exist";		
		
	КонецЕсли;	
	
	Возврат РЕЗ;
КонецФункции

