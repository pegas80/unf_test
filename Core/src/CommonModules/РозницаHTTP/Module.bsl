Функция УдалитьКонтрагента(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("CIN");
	ЗначениеПараметра = СокрЛП(ЗначениеПараметра);
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect CIN";
		
		Возврат РЕЗ;
	
	КонецЕсли;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	Контрагенты.Ссылка
	                      |ИЗ
	                      |	Справочник.Контрагенты КАК Контрагенты
	                      |ГДЕ
	                      |	НЕ Контрагенты.ЭтоГруппа
	                      |	И Контрагенты.ИНН = &ТекПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Partner deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Partner not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден);
	
	Возврат РЕЗ;
КонецФункции

Функция ПолучитьРозничногоПокупателя() ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(НЕОПРЕДЕЛЕНО);
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		//РЕЗ.ВозвращаемоеЗначение = "";
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
		
	Иначе
		
		ТекРозничныйКонтрагент = НЕОПРЕДЕЛЕНО;
		
		ТекОрганизация = НастройкиПоУмолчанию.Организация;
		УчетнаяПолитика = РегистрыСведений.УчетнаяПолитикаРегл.ПолучитьПоследнее(ТекущаяДата(),Новый Структура("Организация", ТекОрганизация));
		Если УчетнаяПолитика.Свойство("РозничныйКонтрагент",ТекРозничныйКонтрагент) Тогда
			Если ЗначениеЗаполнено(ТекРозничныйКонтрагент) Тогда
				Если СтрДлина(СокрЛП(ТекРозничныйКонтрагент.ИНН))=0 Тогда
					РЕЗ.Результат = ЛОЖЬ;
					//РЕЗ.ВозвращаемоеЗначение = "";
					РЕЗ.Описание = "Retail customer CIN not found";
				Иначе
					РозничныйКонтрагентСоответствие = Новый Соответствие();
					РозничныйКонтрагентСоответствие.Вставить("CIN",ТекРозничныйКонтрагент.ИНН);
					РозничныйКонтрагентСоответствие.Вставить("Name",ТекРозничныйКонтрагент.Наименование);
					РозничныйКонтрагентСоответствие.Вставить("FullName",ТекРозничныйКонтрагент.НаименованиеПолное);
					РозничныйКонтрагентСоответствие.Вставить("PartnerGroup",ТекРозничныйКонтрагент.Родитель.Наименование);
					РозничныйКонтрагентСоответствие.Вставить("PartnerGroupCode",ТекРозничныйКонтрагент.Родитель.Код);
					РозничныйКонтрагентСоответствие.Вставить("Description",ТекРозничныйКонтрагент.Комментарий);
					РозничныйКонтрагентСоответствие.Вставить("PartnerType",1);
					
					РЕЗ.Результат = ИСТИНА;
					РЕЗ.ВозвращаемоеЗначение = РозничныйКонтрагентСоответствие;
					РЕЗ.Описание = "Retail customer found successfully";	
				КонецЕсли;				
			КонецЕсли;
			
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			//РЕЗ.ВозвращаемоеЗначение = "";
			РЕЗ.Описание = "Retail customer not found";
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()
#КонецОбласти

#Область ПриходнаяНакладная
Функция СоздатьПриходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта,РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО, ТекОперация=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	PartnerCIN = СоответствиеОбъекта.Получить("PartnerCIN");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Import = СоответствиеОбъекта.Получить("Import");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	CashExpenseOrder = СоответствиеОбъекта.Получить("CashExpenseOrder");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	НаправлениеДеятельности=НЕОПРЕДЕЛЕНО;
	PartnerType = СоответствиеОбъекта.Получить("PartnerType");
	Если ЗначениеЗаполнено(PartnerType) Тогда
		РЕЗ = ПолучитьНаправлениеДеятельности(PartnerType,РЕЗ);
		Если РЕЗ.Результат Тогда
			НаправлениеДеятельности = РЕЗ.ВозвращаемоеЗначение;
		Иначе	
			Возврат РЕЗ;
		КонецЕсли;
	КонецЕсли;
	
	InvoiceNumber = СоответствиеОбъекта.Получить("InvoiceNumber");
	InvoiceDate = СоответствиеОбъекта.Получить("InvoiceDate");	
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
	               |ГДЕ
	               |	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		// Ищем контрагента				
		ТекКонтрагент = НайтиКонтрагентаПоИНН(СокрЛП(PartnerCIN));
		
		Если ТекКонтрагент = НЕОПРЕДЕЛЕНО Тогда
		
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = PartnerCIN;
			РЕЗ.Описание = "Partner not found";
			
		Иначе
			
			Если ЗначениеЗаполнено(ТекКонтрагент.ДоговорПоУмолчанию) Тогда
				ТекДоговор = ТекКонтрагент.ДоговорПоУмолчанию;
				Если ((НЕ ТекДоговор.Поставщик) И (Константы.ИспользоватьВидыДоговоров.Получить())) ИЛИ (НЕ ТекДоговор.ВалютаРасчетов = ТекВалюта.Ссылка) Тогда
					ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,,ИСТИНА);
				КонецЕсли;
			Иначе
				ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,,ИСТИНА);
			КонецЕсли;
						
		КонецЕсли;
		
		//Ищем Склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			
			РасходнаяНакладнаяNumber = НЕОПРЕДЕЛЕНО;
			ДанныеЗаполнения = НЕОПРЕДЕЛЕНО;
			Если НЕ РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО Тогда
				
				СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
				ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
				
				ЗапросДанныеЗаполнения = Новый Запрос();
				ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				|	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
				|ИЗ
				|	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
				|ГДЕ
				|	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
				|	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
				
				ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", РасходнаяНакладнаяRef);
				ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
				
				ЗапросДанныеЗаполнения.Выполнить();
				РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
				ВыборкаДанныеЗаполнения = РезультатЗапросаДанныеЗаполнения.Выбрать();
				Пока ВыборкаДанныеЗаполнения.Следующий() Цикл
					ДанныеЗаполнения = ВыборкаДанныеЗаполнения.Ссылка;
					
					РасходнаяНакладнаяNumber = ДанныеЗаполнения.Номер;
				КонецЦикла;	
				
			КонецЕсли;			
			
			НачатьТранзакцию();
			
			ТекДок = Документы.ПриходнаяНакладная.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходнаяНакладная")] = "ЗаполнитьПоРасходнойНакладной";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказуПоставщику";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходномуОрдеру";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплатуПоставщика")] = "ЗаполнитьПоСчетуНаОплатуПоставщика";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплату")] = "ЗаполнитьПоСчетуНаОплатуВозврат";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЧекККМ")] = "ЗаполнитьПоЧекуККМ";
			СтратегияЗаполнения[Тип("ДокументСсылка.ТТНВходящаяЕГАИС")] = "ЗаполнитьПоНакладнойЕГАИС";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриемИПередачаВРемонт")] = "ЗаполнитьПоПриемуВРемонт";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДанныеЗаполнения, СтратегияЗаполнения);
			
			Если НЕ ЗначениеЗаполнено(ТекДок.ВидОперации) Тогда
				Если РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО Тогда
					ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
				Иначе
					ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя;
				КонецЕсли;
			КонецЕсли;
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,РасходнаяНакладнаяRef);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,РасходнаяНакладнаяNumber);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			//ТекДок.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика");
			Если ЗначениеЗаполнено(ТекОперация) Тогда
				Если ТипЗНЧ(ТекОперация) = Тип("ПеречислениеСсылка.ВидыОперацийПриходнаяНакладная") Тогда
					ТекДок.ВидОперации = ТекОперация;
				КонецЕсли;
			КонецЕсли;
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.Контрагент = ТекКонтрагент;
			ТекДок.Договор = ТекДоговор;
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			
			Если НЕ Import = НЕОПРЕДЕЛЕНО Тогда
				Если Import Тогда
					ТекДок.Импорт = ИСТИНА;
				КонецЕсли;
			КонецЕсли;
			
			// Дозаполняем данные			
			ТекДок.Предоплата.Очистить();
			ТекДок.ФактурыАвансов.Очистить();
			//ТекДок.ДокументОснование = Неопределено;
			
			//ТекДок.ВалютаДокумента = ТекДоговор.ВалютаРасчетов;
			ТекДок.ВалютаДокумента = ТекВалюта;
						
			//Данные по договору
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДокумента));
			ТекДок.Курс      = ВалютаРасчетовКурсКратность.Курс;
			ТекДок.Кратность = ВалютаРасчетовКурсКратность.Кратность;
			
			СуммаВключаетНДС = ?(ЗначениеЗаполнено(ТекДоговор.ВидЦенКонтрагента), ТекДоговор.ВидЦенКонтрагента.ЦенаВключаетНДС, Неопределено);
			Если НЕ СуммаВключаетНДС = Неопределено Тогда
				ТекДок.СуммаВключаетНДС = СуммаВключаетНДС;
			КонецЕсли;
			
			ТекДок.ВидЦенКонтрагента = ТекДоговор.ВидЦенКонтрагента;
			Если ЗначениеЗаполнено(ТекДок.ВидЦенКонтрагента) Тогда
				ТекДок.РегистрироватьЦеныПоставщика = Истина;
			КонецЕсли;
			
			// Данные по организации
			Если ПолучитьФункциональнуюОпцию("ФункциональнаяОпцияИспользоватьИсториюНалогообложенияКонтрагентов") Тогда
				НалогообложениеСтавка = РегистрыСведений.НалогообложениеКонтрагентов.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Контрагент,Договор", ТекДок.Контрагент, ТекДок.Договор));
			Иначе
				НалогообложениеСтавка = Новый Структура("НалогообложениеНДС",ТекДок.Контрагент.НалогообложениеНДС);
			КонецЕсли;
			ТекДок.НалогообложениеНДС = НалогообложениеСтавка.НалогообложениеНДС;
			Если ТекДок.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
				ТекДок.ВидНалогаНДС = ТекДок.Организация.ВидНалогаНДС;
			КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Price = СоответствиеОбъекта.Получить("Price");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				Sum = СоответствиеОбъекта.Получить("Sum");
				VatValue = СоответствиеОбъекта.Получить("VatValue");
				VatSum = СоответствиеОбъекта.Получить("VatSum");
				Discount = СоответствиеОбъекта.Получить("Discount");
				
				ТекКоличество = 0;
				ТекЦена = 0;
				ТекСумма = 0;
				ТекСуммаНДС = 0;
				ТекСтавкаНДС = НЕОПРЕДЕЛЕНО;
				ТекСуммаСкидки = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Price)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Price),"null")=0 Тогда
						ТекЦена = Число(Price);
					Иначе
						ТекЦена = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Price)=Тип("Число") Тогда
					ТекЦена = Price;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid price";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Price);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
						ТекСумма = Число(Sum);
					Иначе
						ТекСумма = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
					ТекСумма = Sum;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid sum";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Sum);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если НЕ VatSum = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(VatSum)=Тип("Строка") Тогда
						Если СтрНайти(НРЕГ(VatSum),"null")=0 Тогда
							ТекСуммаНДС = Число(VatSum);
						Иначе
							ТекСуммаНДС = 0;
						КонецЕсли;
					ИначеЕсли ТипЗНЧ(VatSum)=Тип("Число") Тогда
						ТекСуммаНДС = VatSum;
					Иначе
						СтруктураОшибки = ПолучитьСтруктуруОшибки();
						
						СтруктураОшибки.Message = "Invalid VatSum";
						СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
						СтруктураОшибки.Вставить("Value",VatSum);
						
						МассивОшибок.Добавить(СтруктураОшибки);
					КонецЕсли;
					
					ТекСтавкаНДС = НайтиСтавкуНДС(VatValue);	
					
				КонецЕсли;
				
				Если НЕ Discount = НЕОПРЕДЕЛЕНО Тогда
					Если ТипЗНЧ(Discount)=Тип("Строка") Тогда
						Если СтрНайти(НРЕГ(Discount),"null")=0 Тогда
							ТекСуммаСкидки = Число(Discount);
						Иначе
							ТекСуммаСкидки = 0;
						КонецЕсли;
					ИначеЕсли ТипЗНЧ(Discount)=Тип("Число") Тогда
						ТекСуммаСкидки = Discount;
					Иначе
						СтруктураОшибки = ПолучитьСтруктуруОшибки();
						
						СтруктураОшибки.Message = "Invalid discount";
						СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
						СтруктураОшибки.Вставить("Value",Discount);
						
						МассивОшибок.Добавить(СтруктураОшибки);
					КонецЕсли;	
				КонецЕсли;
				
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				СтрокаТабличнойЧасти.Цена = ТекЦена;

				ТекСуммаВычисленная = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
				Если НЕ ТекСуммаВычисленная = ТекСумма Тогда
					ТекСуммаСкидки = ТекСуммаВычисленная - ТекСумма;
					ТекСумма = ТекСуммаВычисленная;
				КонецЕсли;
				
				Если ТекСумма>0 Тогда
					Если ТекСумма>ТекСуммаСкидки Тогда
						СтрокаТабличнойЧасти.Сумма = ТекСумма - ТекСуммаСкидки;
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = (ТекСуммаСкидки*100)/ТекСумма;
					Иначе
						СтрокаТабличнойЧасти.Сумма = 0;
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 100;
					КонецЕсли;
				КонецЕсли;
				СтрокаТабличнойЧасти.СтавкаНДС = ТекСтавкаНДС;
				СтрокаТабличнойЧасти.СуммаНДС = ТекСуммаНДС;
				
				// Дозаполняем данные в строке
				СтрокаТабличнойЧасти.НомерГТД = Неопределено;
				СтрокаТабличнойЧасти.Содержание = "";
				СтрокаТабличнойЧасти.НеобходимостьВводаАкцизнойМарки = СтрокаТабличнойЧасти.Номенклатура.ВидАлкогольнойПродукции.Маркируемый;
				
				СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(ТекДок.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
				
				Если НЕ НаправлениеДеятельности=НЕОПРЕДЕЛЕНО Тогда
					СтрокаТабличнойЧасти.НаправлениеДеятельности = НаправлениеДеятельности;
				КонецЕсли;
				
				// Обработка возврата товаров
				Если ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя И ЗначениеЗаполнено(ТекДок.ДокументОснование) Тогда
						
	 				ЗапросДляСебестоимостиПоВозврату = Новый Запрос;
					ЗапросДляСебестоимостиПоВозврату.Текст = 
						"ВЫБРАТЬ
						|	Запасы.Номенклатура,
						|	СУММА(Запасы.Количество) КАК Количество,
						|	СУММА(Запасы.Сумма) КАК Сумма
						|ИЗ
						|	РегистрНакопления.Запасы КАК Запасы
						|ГДЕ
						|	Запасы.Регистратор = &ДокументОснование
						|	И Запасы.Номенклатура = &Номенклатура
						|	И Запасы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
						|
						|СГРУППИРОВАТЬ ПО
						|	Запасы.Номенклатура";
					
					ЗапросДляСебестоимостиПоВозврату.УстановитьПараметр("ДокументОснование", ТекДок.ДокументОснование);
					ЗапросДляСебестоимостиПоВозврату.УстановитьПараметр("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
					
					РезультатЗапросаДляСебестоимостиПоВозврату = ЗапросДляСебестоимостиПоВозврату.Выполнить();
					
					ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату = РезультатЗапросаДляСебестоимостиПоВозврату.Выбрать();
					
					Пока ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Следующий() Цикл
						Если СтрокаТабличнойЧасти.Количество >= ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Количество Тогда
							СтрокаТабличнойЧасти.Себестоимость = ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Сумма;
						Иначе
							СтрокаТабличнойЧасти.Себестоимость = (ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Сумма * СтрокаТабличнойЧасти.Количество) / ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Количество;
						КонецЕсли;
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
			// Обработка возврата товаров
			Если ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя И ЗначениеЗаполнено(ТекДок.ДокументОснование) Тогда
				УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseDoc,ТекДок.ДокументОснование);
				ТекДок.ДокументОснование = НЕОПРЕДЕЛЕНО;
				
				СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
				ПодразделениеПродажи = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы.SaleSubdivision);
				Если ЗначениеЗаполнено(ПодразделениеПродажи) Тогда
					ТекДок.Подразделение = ПодразделениеПродажи;
				КонецЕсли;
			КонецЕсли;
			
			ТекДок.НомерВходящегоДокумента = InvoiceNumber;
			ТекДок.ДатаВходящегоДокумента = ДатаJSON(InvoiceDate);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
			
			// Проводим
			ОписаниеУспешногоПроведения = "Doc purchase created successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
			СтрокаОшибок = РЕЗ.Описание;
			// Получаем возврат наличных из кассы
			Если РЕЗ.Результат Тогда
				Если НЕ CashExpenseOrder = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(CashExpenseOrder) = Тип("Массив") Тогда
						
						Для Каждого ТекCashExpenseOrder из CashExpenseOrder Цикл
							
							Если ТекCashExpenseOrder.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Ref",Ref);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Number",Number);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Date",Date+1);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("PartnerCIN",PartnerCIN);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("WarehouseCode",WarehouseCode);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Currency",Currency);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Description",Description);
							КонецЕсли;
							
							РЕЗ = СоздатьИлиОбновитьРасходИзКассыИзПриходнойНакладной(РЕЗ,ТекCashExpenseOrder,Ref);
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Cash expense order: " + РЕЗ.Описание;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе	

						Если CashExpenseOrder.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Ref",Ref);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Number",Number);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Date",Date+1);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("PartnerCIN",PartnerCIN);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("WarehouseCode",WarehouseCode);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Currency",Currency);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Description",Description);
						КонецЕсли;
						
						РЕЗ = СоздатьИлиОбновитьРасходИзКассыИзПриходнойНакладной(РЕЗ,CashExpenseOrder,Ref);
						
						Если НЕ РЕЗ.Результат Тогда
							РЕЗ.Описание = СтрокаОшибок + "; Cash expense order: " + РЕЗ.Описание;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли;
			
			Если РЕЗ.Результат Тогда
				РЕЗ.Описание = "Doc purchase created successfully";
				ЗафиксироватьТранзакцию()
			Иначе
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Описание = СтрЗаменить(РЕЗ.Описание,"Doc purchase created successfully","Creating purchases doc: error");
			КонецЕсли;
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc purchase already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьПриходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта,РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО, ТекОперация=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	PartnerCIN = СоответствиеОбъекта.Получить("PartnerCIN");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Import = СоответствиеОбъекта.Получить("Import");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	CashExpenseOrder = СоответствиеОбъекта.Получить("CashExpenseOrder");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	НаправлениеДеятельности=НЕОПРЕДЕЛЕНО;
	PartnerType = СоответствиеОбъекта.Получить("PartnerType");
	Если ЗначениеЗаполнено(PartnerType) Тогда
		РЕЗ = ПолучитьНаправлениеДеятельности(PartnerType,РЕЗ);
		Если РЕЗ.Результат Тогда
			НаправлениеДеятельности = РЕЗ.ВозвращаемоеЗначение;
		Иначе	
			Возврат РЕЗ;
		КонецЕсли;
	КонецЕсли;
	
	InvoiceNumber = СоответствиеОбъекта.Получить("InvoiceNumber");
	InvoiceDate = СоответствиеОбъекта.Получить("InvoiceDate");
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
	               |ГДЕ
	               |	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
						
		// Ищем контрагента				
		ТекКонтрагент = НайтиКонтрагентаПоИНН(СокрЛП(PartnerCIN));
		
		Если ТекКонтрагент = НЕОПРЕДЕЛЕНО Тогда
		
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = PartnerCIN;
			РЕЗ.Описание = "Partner not found";
			
		Иначе
			
			Если ЗначениеЗаполнено(ТекКонтрагент.ДоговорПоУмолчанию) Тогда
				ТекДоговор = ТекКонтрагент.ДоговорПоУмолчанию;
				Если ((НЕ ТекДоговор.Поставщик) И (Константы.ИспользоватьВидыДоговоров.Получить())) ИЛИ (НЕ ТекДоговор.ВалютаРасчетов = ТекВалюта.Ссылка) Тогда
					ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,,ИСТИНА);
				КонецЕсли;
			Иначе
				ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,,ИСТИНА);
			КонецЕсли;
						
		КонецЕсли;
		
		//Ищем Склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
			
			ТекДок.Дата = ДатаДокумента;
			
			РасходнаяНакладнаяNumber = НЕОПРЕДЕЛЕНО;
			ДанныеЗаполнения = НЕОПРЕДЕЛЕНО;
			Если НЕ РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО Тогда
				
				ТекДок.Запасы.Очистить(); // Очистим табличную часть, ибо придётся заполнять её заново.
				
				СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
				ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
				
				ЗапросДанныеЗаполнения = Новый Запрос();
				ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				|	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
				|ИЗ
				|	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
				|ГДЕ
				|	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
				|	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
				
				ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", РасходнаяНакладнаяRef);
				ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
				
				ЗапросДанныеЗаполнения.Выполнить();
				РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
				ВыборкаДанныеЗаполнения = РезультатЗапросаДанныеЗаполнения.Выбрать();
				Пока ВыборкаДанныеЗаполнения.Следующий() Цикл
					ДанныеЗаполнения = ВыборкаДанныеЗаполнения.Ссылка;
					
					РасходнаяНакладнаяNumber = ДанныеЗаполнения.Номер;
				КонецЦикла;
				
				СтратегияЗаполнения = Новый Соответствие;
				СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
				СтратегияЗаполнения[Тип("ДокументСсылка.РасходнаяНакладная")] = "ЗаполнитьПоРасходнойНакладной";
				СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
				СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказуПоставщику";
				СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходномуОрдеру";
				СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплатуПоставщика")] = "ЗаполнитьПоСчетуНаОплатуПоставщика";
				СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплату")] = "ЗаполнитьПоСчетуНаОплатуВозврат";
				СтратегияЗаполнения[Тип("ДокументСсылка.ЧекККМ")] = "ЗаполнитьПоЧекуККМ";
				СтратегияЗаполнения[Тип("ДокументСсылка.ТТНВходящаяЕГАИС")] = "ЗаполнитьПоНакладнойЕГАИС";
				СтратегияЗаполнения[Тип("ДокументСсылка.ПриемИПередачаВРемонт")] = "ЗаполнитьПоПриемуВРемонт";
				
				ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДанныеЗаполнения, СтратегияЗаполнения);
				
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(ТекДок.ВидОперации) Тогда
				Если РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО Тогда
					ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
				Иначе
					ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя;
				КонецЕсли;
			КонецЕсли;
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,РасходнаяНакладнаяRef);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,РасходнаяНакладнаяNumber);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			//ТекДок.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика");
			Если ЗначениеЗаполнено(ТекОперация) Тогда
				Если ТипЗНЧ(ТекОперация) = Тип("ПеречислениеСсылка.ВидыОперацийПриходнаяНакладная") Тогда
					ТекДок.ВидОперации = ТекОперация;
				КонецЕсли;
			КонецЕсли;
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.Контрагент = ТекКонтрагент;
			ТекДок.Договор = ТекДоговор;
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			
			Если НЕ Import = НЕОПРЕДЕЛЕНО Тогда
				Если Import Тогда
					ТекДок.Импорт = ИСТИНА;
				КонецЕсли;
			КонецЕсли;
			
			// Дозаполняем данные			
			ТекДок.Предоплата.Очистить();
			ТекДок.ФактурыАвансов.Очистить();
			//ТекДок.ДокументОснование = Неопределено;
			
			//ТекДок.ВалютаДокумента = ТекДоговор.ВалютаРасчетов;
			ТекДок.ВалютаДокумента = ТекВалюта;
						
			//Данные по договору
			ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Валюта", ТекДок.ВалютаДокумента));
			ТекДок.Курс      = ВалютаРасчетовКурсКратность.Курс;
			ТекДок.Кратность = ВалютаРасчетовКурсКратность.Кратность;
			
			СуммаВключаетНДС = ?(ЗначениеЗаполнено(ТекДоговор.ВидЦенКонтрагента), ТекДоговор.ВидЦенКонтрагента.ЦенаВключаетНДС, Неопределено);
			Если НЕ СуммаВключаетНДС = Неопределено Тогда
				ТекДок.СуммаВключаетНДС = СуммаВключаетНДС;
			КонецЕсли;
			
			ТекДок.ВидЦенКонтрагента = ТекДоговор.ВидЦенКонтрагента;
			Если ЗначениеЗаполнено(ТекДок.ВидЦенКонтрагента) Тогда
				ТекДок.РегистрироватьЦеныПоставщика = Истина;
			КонецЕсли;
			
			// Данные по организации
			Если ПолучитьФункциональнуюОпцию("ФункциональнаяОпцияИспользоватьИсториюНалогообложенияКонтрагентов") Тогда
				НалогообложениеСтавка = РегистрыСведений.НалогообложениеКонтрагентов.ПолучитьПоследнее(ТекДок.Дата, Новый Структура("Контрагент,Договор", ТекДок.Контрагент, ТекДок.Договор));
			Иначе
				НалогообложениеСтавка = Новый Структура("НалогообложениеНДС",ТекДок.Контрагент.НалогообложениеНДС);
			КонецЕсли;
			ТекДок.НалогообложениеНДС = НалогообложениеСтавка.НалогообложениеНДС;
			Если ТекДок.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС Тогда
				ТекДок.ВидНалогаНДС = ТекДок.Организация.ВидНалогаНДС;
			КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Price = СоответствиеОбъекта.Получить("Price");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				Sum = СоответствиеОбъекта.Получить("Sum");
				VatValue = СоответствиеОбъекта.Получить("VatValue");
				VatSum = СоответствиеОбъекта.Получить("VatSum");
				Discount = СоответствиеОбъекта.Получить("Discount");
				
				ТекКоличество = 0;
				ТекЦена = 0;
				ТекСумма = 0;
				ТекСуммаНДС = 0;
				ТекСтавкаНДС = НЕОПРЕДЕЛЕНО;
				ТекСуммаСкидки = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Price)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Price),"null")=0 Тогда
						ТекЦена = Число(Price);
					Иначе
						ТекЦена = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Price)=Тип("Число") Тогда
					ТекЦена = Price;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid price";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Price);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
						ТекСумма = Число(Sum);
					Иначе
						ТекСумма = 0;
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
					ТекСумма = Sum;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid sum";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Sum);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если НЕ VatSum = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(VatSum)=Тип("Строка") Тогда
						Если СтрНайти(НРЕГ(VatSum),"null")=0 Тогда
							ТекСуммаНДС = Число(VatSum);
						Иначе
							ТекСуммаНДС = 0;
						КонецЕсли;
					ИначеЕсли ТипЗНЧ(VatSum)=Тип("Число") Тогда
						ТекСуммаНДС = VatSum;
					Иначе
						СтруктураОшибки = ПолучитьСтруктуруОшибки();
						
						СтруктураОшибки.Message = "Invalid VatSum";
						СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
						СтруктураОшибки.Вставить("Value",VatSum);
						
						МассивОшибок.Добавить(СтруктураОшибки);
					КонецЕсли;
					
					ТекСтавкаНДС = НайтиСтавкуНДС(VatValue);	
					
				КонецЕсли;
				
				Если НЕ Discount = НЕОПРЕДЕЛЕНО Тогда
					Если ТипЗНЧ(Discount)=Тип("Строка") Тогда
						Если СтрНайти(НРЕГ(Discount),"null")=0 Тогда
							ТекСуммаСкидки = Число(Discount);
						Иначе
							ТекСуммаСкидки = 0;
						КонецЕсли;
					ИначеЕсли ТипЗНЧ(Discount)=Тип("Число") Тогда
						ТекСуммаСкидки = Discount;
					Иначе
						СтруктураОшибки = ПолучитьСтруктуруОшибки();
						
						СтруктураОшибки.Message = "Invalid discount";
						СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
						СтруктураОшибки.Вставить("Value",Discount);
						
						МассивОшибок.Добавить(СтруктураОшибки);
					КонецЕсли;	
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				СтрокаТабличнойЧасти.Цена = ТекЦена;
				
				ТекСуммаВычисленная = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
				Если НЕ ТекСуммаВычисленная = ТекСумма Тогда
					ТекСуммаСкидки = ТекСуммаВычисленная - ТекСумма;
					ТекСумма = ТекСуммаВычисленная;
				КонецЕсли;
				
				Если ТекСумма>0 Тогда
					Если ТекСумма>ТекСуммаСкидки Тогда
						СтрокаТабличнойЧасти.Сумма = ТекСумма - ТекСуммаСкидки;
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = (ТекСуммаСкидки*100)/ТекСумма;
					Иначе
						СтрокаТабличнойЧасти.Сумма = 0;
						СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = 100;
					КонецЕсли;
				КонецЕсли;
				СтрокаТабличнойЧасти.СтавкаНДС = ТекСтавкаНДС;
				СтрокаТабличнойЧасти.СуммаНДС = ТекСуммаНДС;
				
				// Дозаполняем данные в строке
				СтрокаТабличнойЧасти.НомерГТД = Неопределено;
				СтрокаТабличнойЧасти.Содержание = "";
				СтрокаТабличнойЧасти.НеобходимостьВводаАкцизнойМарки = СтрокаТабличнойЧасти.Номенклатура.ВидАлкогольнойПродукции.Маркируемый;
				
				СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(ТекДок.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
				
				Если НЕ НаправлениеДеятельности=НЕОПРЕДЕЛЕНО Тогда
					СтрокаТабличнойЧасти.НаправлениеДеятельности = НаправлениеДеятельности;
				КонецЕсли;
				
				// Обработка возврата товаров
				Если ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя И ЗначениеЗаполнено(ТекДок.ДокументОснование) Тогда
						
	 				ЗапросДляСебестоимостиПоВозврату = Новый Запрос;
					ЗапросДляСебестоимостиПоВозврату.Текст = 
						"ВЫБРАТЬ
						|	Запасы.Номенклатура,
						|	СУММА(Запасы.Количество) КАК Количество,
						|	СУММА(Запасы.Сумма) КАК Сумма
						|ИЗ
						|	РегистрНакопления.Запасы КАК Запасы
						|ГДЕ
						|	Запасы.Регистратор = &ДокументОснование
						|	И Запасы.Номенклатура = &Номенклатура
						|	И Запасы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
						|
						|СГРУППИРОВАТЬ ПО
						|	Запасы.Номенклатура";
					
					ЗапросДляСебестоимостиПоВозврату.УстановитьПараметр("ДокументОснование", ТекДок.ДокументОснование);
					ЗапросДляСебестоимостиПоВозврату.УстановитьПараметр("Номенклатура", СтрокаТабличнойЧасти.Номенклатура);
					
					РезультатЗапросаДляСебестоимостиПоВозврату = ЗапросДляСебестоимостиПоВозврату.Выполнить();
					
					ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату = РезультатЗапросаДляСебестоимостиПоВозврату.Выбрать();
					
					Пока ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Следующий() Цикл
						Если СтрокаТабличнойЧасти.Количество >= ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Количество Тогда
							СтрокаТабличнойЧасти.Себестоимость = ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Сумма;
						Иначе
							СтрокаТабличнойЧасти.Себестоимость = (ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Сумма * СтрокаТабличнойЧасти.Количество) / ВыборкаДетальныеЗаписиДляСебестоимостиПоВозврату.Количество;
						КонецЕсли;
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
			// Обработка возврата товаров
			Если ТекДок.ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя И ЗначениеЗаполнено(ТекДок.ДокументОснование) Тогда
				УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseDoc,ТекДок.ДокументОснование);
				ТекДок.ДокументОснование = НЕОПРЕДЕЛЕНО;
				
				СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
				ПодразделениеПродажи = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов_СтруктурныеЕдиницы.SaleSubdivision);
				Если ЗначениеЗаполнено(ПодразделениеПродажи) Тогда
					ТекДок.Подразделение = ПодразделениеПродажи;
				КонецЕсли;
			КонецЕсли;
			
			ТекДок.НомерВходящегоДокумента = InvoiceNumber;
			ТекДок.ДатаВходящегоДокумента = ДатаJSON(InvoiceDate);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
						
			// Проводим
			ОписаниеУспешногоПроведения = "Doc purchase updated successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
			СтрокаОшибок = РЕЗ.Описание;
			// Получаем возврат наличных из кассы
			Если РЕЗ.Результат Тогда
				Если НЕ CashExpenseOrder = НЕОПРЕДЕЛЕНО Тогда
					
					Если ТипЗНЧ(CashExpenseOrder) = Тип("Массив") Тогда
						
						Для Каждого ТекCashExpenseOrder из CashExpenseOrder Цикл
							
							Если ТекCashExpenseOrder.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Ref",Ref);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Number",Number);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Date",Date+1);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("PartnerCIN",PartnerCIN);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("WarehouseCode",WarehouseCode);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Currency",Currency);
							КонецЕсли;
							
							Если ТекCashExpenseOrder.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
								ТекCashExpenseOrder.Вставить("Description",Description);
							КонецЕсли;
							
							РЕЗ = СоздатьИлиОбновитьРасходИзКассыИзПриходнойНакладной(РЕЗ,ТекCashExpenseOrder,Ref);
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Cash expense order: " + РЕЗ.Описание;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе	

						Если CashExpenseOrder.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Ref",Ref);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Number",Number);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Date",Date+1);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("PartnerCIN",PartnerCIN);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("WarehouseCode",WarehouseCode);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Currency",Currency);
						КонецЕсли;
						
						Если CashExpenseOrder.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
							CashExpenseOrder.Вставить("Description",Description);
						КонецЕсли;
						
						РЕЗ = СоздатьИлиОбновитьРасходИзКассыИзПриходнойНакладной(РЕЗ,CashExpenseOrder,Ref);
						
						Если НЕ РЕЗ.Результат Тогда
							РЕЗ.Описание = СтрокаОшибок + "; Cash expense order: " + РЕЗ.Описание;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли;
			
			Если РЕЗ.Результат Тогда
				РЕЗ.Описание = "Doc purchase updated successfully";
				ЗафиксироватьТранзакцию()
			Иначе
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Описание = СтрЗаменить(РЕЗ.Описание,"Doc purchase updated successfully","Update purchases doc: error");
			КонецЕсли;
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc purchase not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьПриходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта,РасходнаяНакладнаяRef=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Удаляем расходы и кассы
	СтруктураДополнительныхРеквизитовРасходИзКассы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходИзКассы);
	ДопПараметрРасходИзКассы = СтруктураДополнительныхРеквизитовРасходИзКассы.BaseRef;
	
	ЗапросРасходИзКассы = Новый Запрос;
	ЗапросРасходИзКассы.Текст = "ВЫБРАТЬ
	                                |	РасходИзКассыДополнительныеРеквизиты.Ссылка
	                                |ИЗ
	                                |	Документ.РасходИзКассы.ДополнительныеРеквизиты КАК РасходИзКассыДополнительныеРеквизиты
	                                |ГДЕ
	                                |	РасходИзКассыДополнительныеРеквизиты.Значение = &ТекПараметр
	                                |	И РасходИзКассыДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	ЗапросРасходИзКассы.УстановитьПараметр("ТекПараметр", ЗначениеПараметра);
	ЗапросРасходИзКассы.УстановитьПараметр("ДопПараметр", ДопПараметрРасходИзКассы);
	РезультатЗапросаРасходИзКассы = ЗапросРасходИзКассы.Выполнить();
	ВыборкаРасходИзКассы = РезультатЗапросаРасходИзКассы.Выбрать();
	Пока ВыборкаРасходИзКассы.Следующий() Цикл
		
		ТекОбъект = ВыборкаРасходИзКассы.Ссылка.ПолучитьОбъект();
		
		ТекОбъект.УстановитьПометкуУдаления(ИСТИНА);
		
	КонецЦикла;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
	                      |ГДЕ
	                      |	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc purchase deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc purchase not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
#КонецОбласти

#Область ВозвратТоваровОтПокупателя
Функция СоздатьВозвратТоваровОтПокупателя(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
		
	ТекВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя");
	Ref = СоответствиеОбъекта.Получить("Ref");
	BaseRef = СоответствиеОбъекта.Получить("BaseRef");
	
	Если НЕ BaseRef=НЕОПРЕДЕЛЕНО Тогда
		
		СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
		ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
		
		ЗапросДанныеЗаполнения = Новый Запрос();
		ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
		|ИЗ
		|	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
		|ГДЕ
		|	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
		|	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
		ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", BaseRef);
		ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
				
		РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
		Если РезультатЗапросаДанныеЗаполнения.Пустой() Тогда
		
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A base-document not found";
			
		Иначе
			
			РЕЗ = СоздатьПриходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта,BaseRef,ТекВидОперации);
			Если РЕЗ.Описание = "Doc purchase created successfully" Тогда
				РЕЗ.Описание = "Doc return of goods created successfully";
			ИначеЕсли РЕЗ.Описание = "Doc purchase already exist" Тогда
				РЕЗ.Описание = "Doc return of goods already exist";
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "A base-document ref incorrect";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьВозвратТоваровОтПокупателя(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
		
	ТекВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя");
	Ref = СоответствиеОбъекта.Получить("Ref");
	BaseRef = СоответствиеОбъекта.Получить("BaseRef");
	
	Если НЕ BaseRef=НЕОПРЕДЕЛЕНО Тогда
		
		СтруктураДополнительныхРеквизитовДанныеЗаполнения = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
		ДопПараметрДанныеЗаполнения = СтруктураДополнительныхРеквизитовДанныеЗаполнения.DocRef;
		
		ЗапросДанныеЗаполнения = Новый Запрос();
		ЗапросДанныеЗаполнения.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
		|ИЗ
		|	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
		|ГДЕ
		|	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
		|	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
		ЗапросДанныеЗаполнения.УстановитьПараметр("ТекПараметр", BaseRef);
		ЗапросДанныеЗаполнения.УстановитьПараметр("ДопПараметр", ДопПараметрДанныеЗаполнения);
				
		РезультатЗапросаДанныеЗаполнения = ЗапросДанныеЗаполнения.Выполнить();
		Если РезультатЗапросаДанныеЗаполнения.Пустой() Тогда
		
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "A base-document not found";
			
		Иначе
			
			РЕЗ = ОбновитьПриходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта,BaseRef,ТекВидОперации);
			Если РЕЗ.Описание = "Doc purchase updated successfully" Тогда
				РЕЗ.Описание = "Doc return of goods updated successfully";
			ИначеЕсли РЕЗ.Описание = "Doc purchase not found" Тогда
				РЕЗ.Описание = "Doc return of goods not found";
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "A base-document ref incorrect";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьВозвратТоваровОтПокупателя(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Удаляем расходы и кассы
	СтруктураДополнительныхРеквизитовРасходИзКассы = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходИзКассы);
	ДопПараметрРасходИзКассы = СтруктураДополнительныхРеквизитовРасходИзКассы.BaseRef;
	
	ЗапросРасходИзКассы = Новый Запрос;
	ЗапросРасходИзКассы.Текст = "ВЫБРАТЬ
	                                |	РасходИзКассыДополнительныеРеквизиты.Ссылка
	                                |ИЗ
	                                |	Документ.РасходИзКассы.ДополнительныеРеквизиты КАК РасходИзКассыДополнительныеРеквизиты
	                                |ГДЕ
	                                |	РасходИзКассыДополнительныеРеквизиты.Значение = &ТекПараметр
	                                |	И РасходИзКассыДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	ЗапросРасходИзКассы.УстановитьПараметр("ТекПараметр", ЗначениеПараметра);
	ЗапросРасходИзКассы.УстановитьПараметр("ДопПараметр", ДопПараметрРасходИзКассы);
	РезультатЗапросаРасходИзКассы = ЗапросРасходИзКассы.Выполнить();
	ВыборкаРасходИзКассы = РезультатЗапросаРасходИзКассы.Выбрать();
	Пока ВыборкаРасходИзКассы.Следующий() Цикл
		
		ТекОбъект = ВыборкаРасходИзКассы.Ссылка.ПолучитьОбъект();
		
		ТекОбъект.УстановитьПометкуУдаления(ИСТИНА);
		
	КонецЦикла;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
	                      |ГДЕ
	                      |	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc return of goods deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc return of goods not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции

Функция СоздатьИлиОбновитьВозвратТоваровОтПокупателяИзРасходнойНакладной(СтруктураДляВозврата,СоответствиеОбъекта,Ref) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);

	РеквизитовПриходнаяНакладнаяRef = СоответствиеОбъекта.Получить("Ref");
	
	СтруктураДополнительныхРеквизитовПриходнаяНакладная = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
	ДопПараметрПоступлениеНаСчет = СтруктураДополнительныхРеквизитовПриходнаяНакладная.DocRef;
	
	ЗапросПоступлениеНаСчет = Новый Запрос;
	ЗапросПоступлениеНаСчет.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	|ИЗ
	|	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
	|ГДЕ
	|	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	|	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	ЗапросПоступлениеНаСчет.УстановитьПараметр("ТекПараметр", РеквизитовПриходнаяНакладнаяRef);
	ЗапросПоступлениеНаСчет.УстановитьПараметр("ДопПараметр", ДопПараметрПоступлениеНаСчет);
	РезультатЗапросаПоступлениеНаСчет = ЗапросПоступлениеНаСчет.Выполнить();
	Если РезультатЗапросаПоступлениеНаСчет.Пустой() Тогда
		РЕЗ = СоздатьПриходнуюНакладную(РЕЗ,СоответствиеОбъекта,Ref);
	Иначе
		РЕЗ = ОбновитьПриходнуюНакладную(РЕЗ,СоответствиеОбъекта,Ref);
	КонецЕсли;	

	Возврат РЕЗ;
КонецФункции // ()
#КонецОбласти

#Область ПеремещениеЗапасов
Функция СоздатьПеремещениеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	DepartureWarehouseCode = СоответствиеОбъекта.Получить("DepartureWarehouseCode");
	DepartureWarehouseAutoOrder = СоответствиеОбъекта.Получить("DepartureWarehouseAutoOrder");
	ReceiverWarehouseCode = СоответствиеОбъекта.Получить("ReceiverWarehouseCode");
	ReceiverWarehouseAutoOrder = СоответствиеОбъекта.Получить("ReceiverWarehouseAutoOrder");
	Description = СоответствиеОбъекта.Получить("Description");
	Type = СоответствиеОбъекта.Получить("Type");
	BaseRef = СоответствиеОбъекта.Получить("BaseRef");
	BaseNumber = СоответствиеОбъекта.Получить("BaseNumber");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ДокументОснование = НЕОПРЕДЕЛЕНО;
	Если ЗначениеЗаполнено(BaseRef) Тогда
		РЕЗ = ПолучитьДокументПоСсылке(СтруктураДляВозврата,СокрЛП(Строка(BaseRef)));
		Если РЕЗ.Результат Тогда
			ДокументОснование = РЕЗ.ВозвращаемоеЗначение;
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = BaseRef;
			РЕЗ.Описание = "Base document not found";
			
			Возврат РЕЗ;
		КонецЕсли;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
	               |ГДЕ
	               |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		//Ищем Склад-отправитель
		Если РЕЗ.Результат Тогда
			ТекСкладОтправитель = НайтиСклад(СокрЛП(DepartureWarehouseCode));
			Если ТекСкладОтправитель = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = DepartureWarehouseCode;
				РЕЗ.Описание = "Departure warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		//Ищем Склад-получатель
		Если РЕЗ.Результат Тогда
			ТекСкладПолучатель = НайтиСклад(СокрЛП(ReceiverWarehouseCode));
			Если ТекСкладОтправитель = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = ReceiverWarehouseCode;
				РЕЗ.Описание = "Receiver warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			
			НачатьТранзакцию();
		
			ТекДок = Документы.ПеремещениеЗапасов.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеПоЯчейкам")] = "ЗаполнитьПоПеремещениюПоЯчейкам";
			СтратегияЗаполнения[Тип("ДокументСсылка.СборкаЗапасов")] = "ЗаполнитьПоСборкеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказНаПроизводство")] = "ЗаполнитьПоЗаказуНаПроизводство";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходномуОрдеру";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнойНакладной";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.ВнутреннийЗаказ")] = "ЗаполнитьПоВнутреннийЗаказ";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениеЗапасов";
			
			ИсключаяСвойства = "ЗаказПокупателя";
			Если ТипЗНЧ(ДокументОснование)=Тип("ДокументСсылка.ПеремещениеЗапасов")
				ИЛИ ТипЗНЧ(ДокументОснование)=Тип("ДокументОбъект.ПеремещениеЗапасов")
				Тогда
				
				ТекМетаданные = ДокументОснование.Метаданные();
				Для каждого ТекРеквизит Из ТекМетаданные.Реквизиты Цикл
					ИсключаяСвойства = ИсключаяСвойства + "," + ТекРеквизит.Имя;
				КонецЦикла;
				
			КонецЕсли;
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДокументОснование, СтратегияЗаполнения, ИсключаяСвойства);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,BaseRef);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,BaseNumber);
			
			Если ЗначениеЗаполнено(Type) Тогда
				
				ТекType = НЕОПРЕДЕЛЕНО;
				
				Если ТипЗНЧ(Type)=Тип("Число") Тогда
					Если Type=1 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary1",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли Type=2 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary2",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли Type=3 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""-""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли Type=4 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""+""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Type)=Тип("Строка") Тогда
					Если (Type="Оrdinary1")ИЛИ(Type="Обычный1") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary1",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли (Type="Оrdinary2")ИЛИ(Type="Обычный2") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary2",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли (Type="Adjustment-")ИЛИ(Type="Корректировка-") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""-""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли (Type="Adjustment+")ИЛИ(Type="Корректировка+") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""+""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					КонецЕсли;
				КонецЕсли;
				
				Если ТекType = НЕОПРЕДЕЛЕНО Тогда
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Type;
					РЕЗ.Описание = "Incorrect transfer type";
				Иначе
					УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.Type,ТекType);				
				КонецЕсли;
				
			КонецЕсли;
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			ТекДок.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПеремещениеЗапасов.Перемещение");
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.СтруктурнаяЕдиница = ТекСкладОтправитель;
			ТекДок.СтруктурнаяЕдиницаПолучатель = ТекСкладПолучатель;
			
			ТекДок.ПодписьКладовщикаОтправил = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			ТекДок.ПодписьКладовщикаПолучил = ТекДок.СтруктурнаяЕдиницаПолучатель.ПодписьМОЛ;
			
			//Если ТекДок.СтруктурнаяЕдиницаПолучатель.ОрдерныйСклад И УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах") Тогда
			//	ТекДок.ЧерезТранзитныйСклад = ИСТИНА;
			//	ТекДок.СтруктурнаяЕдиницаКонечныйПолучатель = ТекДок.СтруктурнаяЕдиницаПолучатель;
			//	ТекДок.СтруктурнаяЕдиницаПолучатель 		= УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("СтруктурныеЕдиницы", "ТранзитныйСклад");
			//КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				СтрокаТабличнойЧасти.ВнеоборотныйАктив = ЛОЖЬ;
				
			КонецЦикла;
			
			// Проверка остатков
			РЕЗ = ПолучитьМассивОшибокПоОстаткам(ТекДок,ТекДок.СтруктурнаяЕдиница,РЕЗ,МассивОшибок);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
						
			// Проводим
			ОписаниеУспешногоПроведения = "Doc transfer created successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="Not enough balances in the departure warehouse";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
			СтрокаОшибок = РЕЗ.Описание;
			// Проверяем автоматическое создание расходного ордера
			Если РЕЗ.Результат Тогда
				Если ТекДок.СтруктурнаяЕдиница.ОрдерныйСклад Тогда
					Если НЕ DepartureWarehouseAutoOrder=НЕОПРЕДЕЛЕНО Тогда
						Если DepartureWarehouseAutoOrder Тогда
							
							СоответствиеОбъектаРасходныйОрдер = Новый Соответствие();
							СоответствиеОбъектаРасходныйОрдер.Вставить("Ref",Ref);
							СоответствиеОбъектаРасходныйОрдер.Вставить("Number",Number);
							СоответствиеОбъектаРасходныйОрдер.Вставить("Date",Date+1);
							СоответствиеОбъектаРасходныйОрдер.Вставить("TransferNumber",Number);
							СоответствиеОбъектаРасходныйОрдер.Вставить("OdrerWarehouseCode",DepartureWarehouseCode);
							СоответствиеОбъектаРасходныйОрдер.Вставить("Description",Description);
							СоответствиеОбъектаРасходныйОрдер.Вставить("TabularSection",Новый Массив());
							
							
							// Ищем существующий расходный ордер
							СтруктураДополнительныхРеквизитовРасходныйОрдер = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер);
							ДопПараметрРасходныйОрдер = СтруктураДополнительныхРеквизитовРасходныйОрдер.DocRef;
							
							ЗапросРасходныйОрдер = Новый Запрос;
							ЗапросРасходныйОрдер.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
							|	РасходныйОрдерДополнительныеРеквизиты.Ссылка
							|ИЗ
							|	Документ.РасходныйОрдер.ДополнительныеРеквизиты КАК РасходныйОрдерДополнительныеРеквизиты
							|ГДЕ
							|	РасходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
							|	И РасходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
							
							ЗапросРасходныйОрдер.УстановитьПараметр("ТекПараметр", Ref);
							ЗапросРасходныйОрдер.УстановитьПараметр("ДопПараметр", ДопПараметрРасходныйОрдер);
							РезультатЗапросаРасходныйОрдер = ЗапросРасходныйОрдер.Выполнить();
							Если РезультатЗапросаРасходныйОрдер.Пустой() Тогда
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = СоздатьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаРасходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							Иначе
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = ОбновитьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаРасходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							КонецЕсли;
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Income order: " + РЕЗ.Описание;
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			// Проверяем автоматическое создание приходного ордера
			Если РЕЗ.Результат Тогда
				Если ТекДок.СтруктурнаяЕдиницаПолучатель.ОрдерныйСклад Тогда
					Если НЕ ReceiverWarehouseAutoOrder=НЕОПРЕДЕЛЕНО Тогда
						Если ReceiverWarehouseAutoOrder Тогда
							
							СоответствиеОбъектаПриходныйОрдер = Новый Соответствие();
							СоответствиеОбъектаПриходныйОрдер.Вставить("Ref",Ref);
							СоответствиеОбъектаПриходныйОрдер.Вставить("Number",Number);
							СоответствиеОбъектаПриходныйОрдер.Вставить("Date",Date+1);
							СоответствиеОбъектаПриходныйОрдер.Вставить("TransferNumber",Number);
							СоответствиеОбъектаПриходныйОрдер.Вставить("OdrerWarehouseCode",ReceiverWarehouseCode);
							СоответствиеОбъектаПриходныйОрдер.Вставить("Description",Description);
							СоответствиеОбъектаПриходныйОрдер.Вставить("TabularSection",Новый Массив());
							
							
							// Ищем существующий приходный ордер
							СтруктураДополнительныхРеквизитовПриходныйОрдер = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер);
							ДопПараметрПриходныйОрдер = СтруктураДополнительныхРеквизитовПриходныйОрдер.DocRef;
							
							ЗапросПриходныйОрдер = Новый Запрос;
							ЗапросПриходныйОрдер.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
							|	ПриходныйОрдерДополнительныеРеквизиты.Ссылка
							|ИЗ
							|	Документ.ПриходныйОрдер.ДополнительныеРеквизиты КАК ПриходныйОрдерДополнительныеРеквизиты
							|ГДЕ
							|	ПриходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
							|	И ПриходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
							
							ЗапросПриходныйОрдер.УстановитьПараметр("ТекПараметр", Ref);
							ЗапросПриходныйОрдер.УстановитьПараметр("ДопПараметр", ДопПараметрПриходныйОрдер);
							РезультатЗапросаПриходныйОрдер = ЗапросПриходныйОрдер.Выполнить();
							Если РезультатЗапросаПриходныйОрдер.Пустой() Тогда
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = СоздатьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаПриходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							Иначе
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = ОбновитьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаРасходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							КонецЕсли;
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Expense order: " + РЕЗ.Описание;
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
						
			Если РЕЗ.Результат Тогда
				РЕЗ.Описание = "Doc transfer created successfully";
				ЗафиксироватьТранзакцию()
			Иначе
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Описание = СтрЗаменить(РЕЗ.Описание,"Doc transfer created successfully","Creating transfer doc: error");
			КонецЕсли;
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc transfer already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьПеремещениеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	DepartureWarehouseCode = СоответствиеОбъекта.Получить("DepartureWarehouseCode");
	DepartureWarehouseAutoOrder = СоответствиеОбъекта.Получить("DepartureWarehouseAutoOrder");
	ReceiverWarehouseCode = СоответствиеОбъекта.Получить("ReceiverWarehouseCode");
	ReceiverWarehouseAutoOrder = СоответствиеОбъекта.Получить("ReceiverWarehouseAutoOrder");
	Description = СоответствиеОбъекта.Получить("Description");
	Type = СоответствиеОбъекта.Получить("Type");
	BaseRef = СоответствиеОбъекта.Получить("BaseRef");
	BaseNumber = СоответствиеОбъекта.Получить("BaseNumber");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ДокументОснование = НЕОПРЕДЕЛЕНО;
	Если ЗначениеЗаполнено(BaseRef) Тогда
		РЕЗ = ПолучитьДокументПоСсылке(СтруктураДляВозврата,СокрЛП(Строка(BaseRef)));
		Если РЕЗ.Результат Тогда
			ДокументОснование = РЕЗ.ВозвращаемоеЗначение;
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = BaseRef;
			РЕЗ.Описание = "Base document not found";
			
			Возврат РЕЗ;
		КонецЕсли;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
	               |ГДЕ
	               |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		//Ищем Склад-отправитель
		Если РЕЗ.Результат Тогда
			ТекСкладОтправитель = НайтиСклад(СокрЛП(DepartureWarehouseCode));
			Если ТекСкладОтправитель = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = DepartureWarehouseCode;
				РЕЗ.Описание = "Departure warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		//Ищем Склад-получатель
		Если РЕЗ.Результат Тогда
			ТекСкладПолучатель = НайтиСклад(СокрЛП(ReceiverWarehouseCode));
			Если ТекСкладОтправитель = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = ReceiverWarehouseCode;
				РЕЗ.Описание = "Receiver warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
			
			ТекДок.Дата = ДатаДокумента;
			
			Если НЕ ДокументОснование = НЕОПРЕДЕЛЕНО Тогда
				
				СтратегияЗаполнения = Новый Соответствие;
				СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеПоЯчейкам")] = "ЗаполнитьПоПеремещениюПоЯчейкам";
				СтратегияЗаполнения[Тип("ДокументСсылка.СборкаЗапасов")] = "ЗаполнитьПоСборкеЗапасов";
				СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказНаПроизводство")] = "ЗаполнитьПоЗаказуНаПроизводство";
				СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходномуОрдеру";
				СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнойНакладной";
				СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
				СтратегияЗаполнения[Тип("ДокументСсылка.ВнутреннийЗаказ")] = "ЗаполнитьПоВнутреннийЗаказ";
				СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениеЗапасов";
				
				ИсключаяСвойства = "ЗаказПокупателя";
				Если ТипЗНЧ(ДокументОснование)=Тип("ДокументСсылка.ПеремещениеЗапасов")
					ИЛИ ТипЗНЧ(ДокументОснование)=Тип("ДокументОбъект.ПеремещениеЗапасов")
					Тогда
					
					ТекМетаданные = ДокументОснование.Метаданные();
					Для каждого ТекРеквизит Из ТекМетаданные.Реквизиты Цикл
						ИсключаяСвойства = ИсключаяСвойства + "," + ТекРеквизит.Имя;
					КонецЦикла;
					
				КонецЕсли;
				
				ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ДокументОснование, СтратегияЗаполнения, ИсключаяСвойства);	
				
			КонецЕсли;			
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseRef,BaseRef);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.BaseNumber,BaseNumber);
			
			Если ЗначениеЗаполнено(Type) Тогда
				
				ТекType = НЕОПРЕДЕЛЕНО;
				
				Если ТипЗНЧ(Type)=Тип("Число") Тогда
					Если Type=1 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary1",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли Type=2 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary2",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли Type=3 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""-""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли Type=4 Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""+""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					КонецЕсли;
				ИначеЕсли ТипЗНЧ(Type)=Тип("Строка") Тогда
					Если (Type="Оrdinary1")ИЛИ(Type="Обычный1") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary1",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли (Type="Оrdinary2")ИЛИ(Type="Обычный2") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Оrdinary2",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли (Type="Adjustment-")ИЛИ(Type="Корректировка-") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""-""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					ИначеЕсли (Type="Adjustment+")ИЛИ(Type="Корректировка+") Тогда
						ТекType = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Adjustment""+""",ИСТИНА,,СтруктураДополнительныхРеквизитов.Type);
					КонецЕсли;
				КонецЕсли;
				
				Если ТекType = НЕОПРЕДЕЛЕНО Тогда
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Type;
					РЕЗ.Описание = "Incorrect transfer type";
				Иначе
					УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.Type,ТекType);				
				КонецЕсли;
				
			КонецЕсли;
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			ТекДок.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПеремещениеЗапасов.Перемещение");
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.СтруктурнаяЕдиница = ТекСкладОтправитель;
			ТекДок.СтруктурнаяЕдиницаПолучатель = ТекСкладПолучатель;
			
			ТекДок.ПодписьКладовщикаОтправил = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			ТекДок.ПодписьКладовщикаПолучил = ТекДок.СтруктурнаяЕдиницаПолучатель.ПодписьМОЛ;
			
			//Если ТекДок.СтруктурнаяЕдиницаПолучатель.ОрдерныйСклад И УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьСтатусыВПеремещенииИВоВнутренныхЗаказах") Тогда
			//	ТекДок.ЧерезТранзитныйСклад = ИСТИНА;
			//	ТекДок.СтруктурнаяЕдиницаКонечныйПолучатель = ТекДок.СтруктурнаяЕдиницаПолучатель;
			//	ТекДок.СтруктурнаяЕдиницаПолучатель 		= УправлениеНебольшойФирмойПовтИсп.ПолучитьПредопределенноеЗначениеСправочника("СтруктурныеЕдиницы", "ТранзитныйСклад");
			//КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				СтрокаТабличнойЧасти.ВнеоборотныйАктив = ЛОЖЬ;
				
			КонецЦикла;
			
			// Проверка остатков
			РЕЗ = ПолучитьМассивОшибокПоОстаткам(ТекДок,ТекДок.СтруктурнаяЕдиница,РЕЗ,МассивОшибок);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
			
			// Проводим
			ОписаниеУспешногоПроведения = "Doc transfer updated successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="Not enough balances in the departure warehouse";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
			
			СтрокаОшибок = РЕЗ.Описание;
			// Проверяем автоматическое создание расходного ордера
			Если РЕЗ.Результат Тогда
				Если ТекДок.СтруктурнаяЕдиница.ОрдерныйСклад Тогда
					Если НЕ DepartureWarehouseAutoOrder=НЕОПРЕДЕЛЕНО Тогда
						Если DepartureWarehouseAutoOrder Тогда
							
							СоответствиеОбъектаРасходныйОрдер = Новый Соответствие();
							СоответствиеОбъектаРасходныйОрдер.Вставить("Ref",Ref);
							СоответствиеОбъектаРасходныйОрдер.Вставить("Number",Number);
							СоответствиеОбъектаРасходныйОрдер.Вставить("Date",Date+1);
							СоответствиеОбъектаРасходныйОрдер.Вставить("TransferNumber",Number);
							СоответствиеОбъектаРасходныйОрдер.Вставить("OdrerWarehouseCode",DepartureWarehouseCode);
							СоответствиеОбъектаРасходныйОрдер.Вставить("Description",Description);
							СоответствиеОбъектаРасходныйОрдер.Вставить("TabularSection",Новый Массив());
							
							
							// Ищем существующий расходный ордер
							СтруктураДополнительныхРеквизитовРасходныйОрдер = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер);
							ДопПараметрРасходныйОрдер = СтруктураДополнительныхРеквизитовРасходныйОрдер.DocRef;
							
							ЗапросРасходныйОрдер = Новый Запрос;
							ЗапросРасходныйОрдер.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
							|	РасходныйОрдерДополнительныеРеквизиты.Ссылка
							|ИЗ
							|	Документ.РасходныйОрдер.ДополнительныеРеквизиты КАК РасходныйОрдерДополнительныеРеквизиты
							|ГДЕ
							|	РасходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
							|	И РасходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
							
							ЗапросРасходныйОрдер.УстановитьПараметр("ТекПараметр", Ref);
							ЗапросРасходныйОрдер.УстановитьПараметр("ДопПараметр", ДопПараметрРасходныйОрдер);
							РезультатЗапросаРасходныйОрдер = ЗапросРасходныйОрдер.Выполнить();
							Если РезультатЗапросаРасходныйОрдер.Пустой() Тогда
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = СоздатьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаРасходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							Иначе
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = ОбновитьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаРасходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							КонецЕсли;
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Income order: " + РЕЗ.Описание;
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			// Проверяем автоматическое создание приходного ордера
			Если РЕЗ.Результат Тогда
				Если ТекДок.СтруктурнаяЕдиницаПолучатель.ОрдерныйСклад Тогда
					Если НЕ ReceiverWarehouseAutoOrder=НЕОПРЕДЕЛЕНО Тогда
						Если ReceiverWarehouseAutoOrder Тогда
							
							СоответствиеОбъектаПриходныйОрдер = Новый Соответствие();
							СоответствиеОбъектаПриходныйОрдер.Вставить("Ref",Ref);
							СоответствиеОбъектаПриходныйОрдер.Вставить("Number",Number);
							СоответствиеОбъектаПриходныйОрдер.Вставить("Date",Date+1);
							СоответствиеОбъектаПриходныйОрдер.Вставить("TransferNumber",Number);
							СоответствиеОбъектаПриходныйОрдер.Вставить("OdrerWarehouseCode",ReceiverWarehouseCode);
							СоответствиеОбъектаПриходныйОрдер.Вставить("Description",Description);
							СоответствиеОбъектаПриходныйОрдер.Вставить("TabularSection",Новый Массив());
							
							
							// Ищем существующий приходный ордер
							СтруктураДополнительныхРеквизитовПриходныйОрдер = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер);
							ДопПараметрПриходныйОрдер = СтруктураДополнительныхРеквизитовПриходныйОрдер.DocRef;
							
							ЗапросПриходныйОрдер = Новый Запрос;
							ЗапросПриходныйОрдер.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
							|	ПриходныйОрдерДополнительныеРеквизиты.Ссылка
							|ИЗ
							|	Документ.ПриходныйОрдер.ДополнительныеРеквизиты КАК ПриходныйОрдерДополнительныеРеквизиты
							|ГДЕ
							|	ПриходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
							|	И ПриходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
							
							ЗапросПриходныйОрдер.УстановитьПараметр("ТекПараметр", Ref);
							ЗапросПриходныйОрдер.УстановитьПараметр("ДопПараметр", ДопПараметрПриходныйОрдер);
							РезультатЗапросаПриходныйОрдер = ЗапросПриходныйОрдер.Выполнить();
							Если РезультатЗапросаПриходныйОрдер.Пустой() Тогда
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = СоздатьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаПриходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							Иначе
								ОчищатьТЧЗапасы=ЛОЖЬ;
								РЕЗ = ОбновитьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъектаРасходныйОрдер,ТекДок.Ссылка,ОчищатьТЧЗапасы);
							КонецЕсли;
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Expense order: " + РЕЗ.Описание;
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если РЕЗ.Результат Тогда
				РЕЗ.Описание = "Doc transfer updated successfully";
				ЗафиксироватьТранзакцию()
			Иначе
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Описание = СтрЗаменить(РЕЗ.Описание,"Doc transfer updated successfully","Update transfer doc: error");
			КонецЕсли;
			
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc transfer not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьПеремещениеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
	                      |ГДЕ
	                      |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc transfer deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc transfer not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
#КонецОбласти

#Область ПриходныйОрдер
Функция СоздатьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъекта,ПеремещениеОснование=НЕОПРЕДЕЛЕНО,ОчищатьТЧЗапасы=ИСТИНА) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	TransferNumber = СоответствиеОбъекта.Получить("TransferNumber");
	OdrerWarehouseCode = СоответствиеОбъекта.Получить("OdrerWarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПриходныйОрдерДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПриходныйОрдер.ДополнительныеРеквизиты КАК ПриходныйОрдерДополнительныеРеквизиты
	               |ГДЕ
	               |	ПриходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПриходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		//Ищем ордерный склад
		Если РЕЗ.Результат Тогда
			ТекОрдерныйСклад = НайтиСклад(СокрЛП(OdrerWarehouseCode));
			Если ТекОрдерныйСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
				
			ИначеЕсли НЕ ТекОрдерныйСклад.ОрдерныйСклад Тогда
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			
			// Создаём документ
			ТекДок = Документы.ПриходныйОрдер.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			// Ищем перемещение запасов как документ-основание
			ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО;
			Если ТипЗНЧ(ПеремещениеОснование)=Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
				Если ПеремещениеОснование.Проведен Тогда
					ПеремещениеЗапасовДокументОснование = ПеремещениеОснование;
				КонецЕсли;
			КонецЕсли;
			
			Если (ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО) И (ЗначениеЗаполнено(TransferNumber)) Тогда
				
				СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
				ДопПараметр_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование.DocNumber;
				
				Запрос_ПеремещениеЗапасовДокументОснование = Новый Запрос;
				Запрос_ПеремещениеЗапасовДокументОснование.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
				                                                   |ИЗ
				                                                   |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
				                                                   |ГДЕ
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
				                                                   |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
				
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ТекПараметр", TransferNumber);
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ДопПараметр", ДопПараметр_ПеремещениеЗапасовДокументОснование);
				РезультатЗапроса_ПеремещениеЗапасовДокументОснование = Запрос_ПеремещениеЗапасовДокументОснование.Выполнить().Выбрать();
				Пока РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Следующий() Цикл
					ПеремещениеЗапасовДокументОснование = РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Ссылка;
				КонецЦикла;
				
			КонецЕсли;
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходныйОрдер")] = "ЗаполнитьПоРасходныйОрдер";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнаяНакладная";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОприходованиеЗапасов")] = "ЗаполнитьПоОприходованиеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПересортицаЗапасов")] = "ЗаполнитьПоПересортицаЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетПереработчика")] = "ЗаполнитьПоОтчетПереработчика";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказПоставщику";
			СтратегияЗаполнения[Тип("ДокументСсылка.СборкаЗапасов")] = "ЗаполнитьПоСборкаЗапасов";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ПеремещениеЗапасовДокументОснование, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.TransferNumber,TransferNumber);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;

			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.ПодписьРуководителя = ТекДок.Организация.ПодписьРуководителя;
			
			ТекДок.СтруктурнаяЕдиница = ТекОрдерныйСклад;
			ТекДок.ПодписьКладовщика = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			Если ОчищатьТЧЗапасы Тогда
				ТекДок.Запасы.Очистить();
			КонецЕсли;
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
			КонецЦикла;

			// Проводим
			ОписаниеУспешногоПроведения = "Doc income order created successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc income order already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъекта,ПеремещениеОснование=НЕОПРЕДЕЛЕНО,ОчищатьТЧЗапасы=ИСТИНА) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	TransferNumber = СоответствиеОбъекта.Получить("TransferNumber");
	OdrerWarehouseCode = СоответствиеОбъекта.Получить("OdrerWarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПриходныйОрдерДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПриходныйОрдер.ДополнительныеРеквизиты КАК ПриходныйОрдерДополнительныеРеквизиты
	               |ГДЕ
	               |	ПриходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПриходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		//Ищем ордерный склад
		Если РЕЗ.Результат Тогда
			ТекОрдерныйСклад = НайтиСклад(СокрЛП(OdrerWarehouseCode));
			Если ТекОрдерныйСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
				
			ИначеЕсли НЕ ТекОрдерныйСклад.ОрдерныйСклад Тогда
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
						
			ТекДок.Дата = ДатаДокумента;
			
			// Ищем перемещение запасов как документ-основание
			ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО;
			Если ТипЗНЧ(ПеремещениеОснование)=Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
				Если ПеремещениеОснование.Проведен Тогда
					ПеремещениеЗапасовДокументОснование = ПеремещениеОснование;
				КонецЕсли;
			КонецЕсли;
			
			Если (ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО) И (ЗначениеЗаполнено(TransferNumber)) Тогда
				
				СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
				ДопПараметр_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование.DocNumber;
				
				Запрос_ПеремещениеЗапасовДокументОснование = Новый Запрос;
				Запрос_ПеремещениеЗапасовДокументОснование.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
				                                                   |ИЗ
				                                                   |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
				                                                   |ГДЕ
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
				                                                   |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
				
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ТекПараметр", TransferNumber);
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ДопПараметр", ДопПараметр_ПеремещениеЗапасовДокументОснование);
				РезультатЗапроса_ПеремещениеЗапасовДокументОснование = Запрос_ПеремещениеЗапасовДокументОснование.Выполнить().Выбрать();
				Пока РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Следующий() Цикл
					ПеремещениеЗапасовДокументОснование = РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Ссылка;
				КонецЦикла;
				
			КонецЕсли;
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходныйОрдер")] = "ЗаполнитьПоРасходныйОрдер";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнаяНакладная";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОприходованиеЗапасов")] = "ЗаполнитьПоОприходованиеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПересортицаЗапасов")] = "ЗаполнитьПоПересортицаЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетПереработчика")] = "ЗаполнитьПоОтчетПереработчика";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказПоставщику";
			СтратегияЗаполнения[Тип("ДокументСсылка.СборкаЗапасов")] = "ЗаполнитьПоСборкаЗапасов";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ПеремещениеЗапасовДокументОснование, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.TransferNumber,TransferNumber);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;

			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			ТекДок.ПодписьРуководителя = ТекДок.Организация.ПодписьРуководителя;
			
			ТекДок.СтруктурнаяЕдиница = ТекОрдерныйСклад;
			ТекДок.ПодписьКладовщика = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			Если ОчищатьТЧЗапасы Тогда
				ТекДок.Запасы.Очистить();
			КонецЕсли;
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
			КонецЦикла;			
						
			// Проводим
			ОписаниеУспешногоПроведения = "Doc income order updated successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ИСТИНА;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc income order not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьПриходныйОрдер(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходныйОрдер);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ПриходныйОрдерДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.ПриходныйОрдер.ДополнительныеРеквизиты КАК ПриходныйОрдерДополнительныеРеквизиты
	                      |ГДЕ
	                      |	ПриходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И ПриходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc income order deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc income order not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
#КонецОбласти

#Область РасходныйОрдер
Функция СоздатьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъекта,ПеремещениеОснование=НЕОПРЕДЕЛЕНО,ОчищатьТЧЗапасы=ИСТИНА) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	TransferNumber = СоответствиеОбъекта.Получить("TransferNumber");
	OdrerWarehouseCode = СоответствиеОбъекта.Получить("OdrerWarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасходныйОрдерДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.РасходныйОрдер.ДополнительныеРеквизиты КАК РасходныйОрдерДополнительныеРеквизиты
	               |ГДЕ
	               |	РасходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И РасходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		//Ищем ордерный склад
		Если РЕЗ.Результат Тогда
			ТекОрдерныйСклад = НайтиСклад(СокрЛП(OdrerWarehouseCode));
			Если ТекОрдерныйСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
				
			ИначеЕсли НЕ ТекОрдерныйСклад.ОрдерныйСклад Тогда
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			
			// Создаём документ
			ТекДок = Документы.РасходныйОрдер.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			// Ищем перемещение запасов как документ-основание
			ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО;
			Если ТипЗНЧ(ПеремещениеОснование)=Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
				Если ПеремещениеОснование.Проведен Тогда
					ПеремещениеЗапасовДокументОснование = ПеремещениеОснование;
				КонецЕсли;
			КонецЕсли;
			
			Если (ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО) И (ЗначениеЗаполнено(TransferNumber)) Тогда
				
				СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
				ДопПараметр_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование.DocNumber;
				
				Запрос_ПеремещениеЗапасовДокументОснование = Новый Запрос;
				Запрос_ПеремещениеЗапасовДокументОснование.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
				                                                   |ИЗ
				                                                   |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
				                                                   |ГДЕ
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
				                                                   |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
				
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ТекПараметр", TransferNumber);
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ДопПараметр", ДопПараметр_ПеремещениеЗапасовДокументОснование);
				РезультатЗапроса_ПеремещениеЗапасовДокументОснование = Запрос_ПеремещениеЗапасовДокументОснование.Выполнить().Выбрать();
				Пока РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Следующий() Цикл
					ПеремещениеЗапасовДокументОснование = РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Ссылка;
				КонецЦикла;
				
			КонецЕсли;
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетОПереработке")] = "ЗаполнитьПоОтчетОПереработке";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходнаяНакладная")] = "ЗаполнитьПоРасходнаяНакладная";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.СписаниеЗапасов")] = "ЗаполнитьПоСписаниеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПересортицаЗапасов")] = "ЗаполнитьПоПересортицаЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходныйОрдер";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПринятиеКУчетуВА")] = "ЗаполнитьПоПринятиеКУчетуВА";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ПеремещениеЗапасовДокументОснование, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.TransferNumber,TransferNumber);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;

			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			
			ТекДок.СтруктурнаяЕдиница = ТекОрдерныйСклад;
			ТекДок.ПодписьКладовщика = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			Если ОчищатьТЧЗапасы Тогда
				ТекДок.Запасы.Очистить();
			КонецЕсли;
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
			КонецЦикла;

			// Проводим
			ОписаниеУспешногоПроведения = "Doc expense order created successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc expense order already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъекта,ПеремещениеОснование=НЕОПРЕДЕЛЕНО,ОчищатьТЧЗапасы=ИСТИНА) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	TransferNumber = СоответствиеОбъекта.Получить("TransferNumber");
	OdrerWarehouseCode = СоответствиеОбъекта.Получить("OdrerWarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасходныйОрдерДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.РасходныйОрдер.ДополнительныеРеквизиты КАК РасходныйОрдерДополнительныеРеквизиты
	               |ГДЕ
	               |	РасходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И РасходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		//Ищем ордерный склад
		Если РЕЗ.Результат Тогда
			ТекОрдерныйСклад = НайтиСклад(СокрЛП(OdrerWarehouseCode));
			Если ТекОрдерныйСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
				
			ИначеЕсли НЕ ТекОрдерныйСклад.ОрдерныйСклад Тогда
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = OdrerWarehouseCode;
				РЕЗ.Описание = "Odrer warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
						
			ТекДок.Дата = ДатаДокумента;
			
			// Ищем перемещение запасов как документ-основание
			ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО;
			Если ТипЗНЧ(ПеремещениеОснование)=Тип("ДокументСсылка.ПеремещениеЗапасов") Тогда
				Если ПеремещениеОснование.Проведен Тогда
					ПеремещениеЗапасовДокументОснование = ПеремещениеОснование;
				КонецЕсли;
			КонецЕсли;
			
			Если (ПеремещениеЗапасовДокументОснование = НЕОПРЕДЕЛЕНО) И (ЗначениеЗаполнено(TransferNumber)) Тогда
				
				СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеЗапасов);
				ДопПараметр_ПеремещениеЗапасовДокументОснование = СтруктураДополнительныхРеквизитов_ПеремещениеЗапасовДокументОснование.DocNumber;
				
				Запрос_ПеремещениеЗапасовДокументОснование = Новый Запрос;
				Запрос_ПеремещениеЗапасовДокументОснование.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Ссылка
				                                                   |ИЗ
				                                                   |	Документ.ПеремещениеЗапасов.ДополнительныеРеквизиты КАК ПеремещениеЗапасовДополнительныеРеквизиты
				                                                   |ГДЕ
				                                                   |	ПеремещениеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
				                                                   |	И ПеремещениеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
				
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ТекПараметр", TransferNumber);
				Запрос_ПеремещениеЗапасовДокументОснование.УстановитьПараметр("ДопПараметр", ДопПараметр_ПеремещениеЗапасовДокументОснование);
				РезультатЗапроса_ПеремещениеЗапасовДокументОснование = Запрос_ПеремещениеЗапасовДокументОснование.Выполнить().Выбрать();
				Пока РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Следующий() Цикл
					ПеремещениеЗапасовДокументОснование = РезультатЗапроса_ПеремещениеЗапасовДокументОснование.Ссылка;
				КонецЦикла;
				
			КонецЕсли;
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.ОтчетОПереработке")] = "ЗаполнитьПоОтчетОПереработке";
			СтратегияЗаполнения[Тип("ДокументСсылка.РасходнаяНакладная")] = "ЗаполнитьПоРасходнаяНакладная";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.СписаниеЗапасов")] = "ЗаполнитьПоСписаниеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПересортицаЗапасов")] = "ЗаполнитьПоПересортицаЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеЗапасов")] = "ЗаполнитьПоПеремещениеЗапасов";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходныйОрдер")] = "ЗаполнитьПоПриходныйОрдер";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПринятиеКУчетуВА")] = "ЗаполнитьПоПринятиеКУчетуВА";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, ПеремещениеЗапасовДокументОснование, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.TransferNumber,TransferNumber);
			
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;

			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			
			ТекДок.СтруктурнаяЕдиница = ТекОрдерныйСклад;
			ТекДок.ПодписьКладовщика = ТекДок.СтруктурнаяЕдиница.ПодписьМОЛ;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			Если ОчищатьТЧЗапасы Тогда
				ТекДок.Запасы.Очистить();
			КонецЕсли;
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
			КонецЦикла;			
						
			// Проводим
			ОписаниеУспешногоПроведения = "Doc expense order updated successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок="";
			ФиксироватьТранзакции=ИСТИНА;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc expense order not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьРасходныйОрдер(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходныйОрдер);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	РасходныйОрдерДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.РасходныйОрдер.ДополнительныеРеквизиты КАК РасходныйОрдерДополнительныеРеквизиты
	                      |ГДЕ
	                      |	РасходныйОрдерДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И РасходныйОрдерДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc expense order deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc expense order not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
#КонецОбласти

#Область ОприходованиеЗапасов
Функция СоздатьОприходованиеЗапасовИзлишки(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
			
	КонецЕсли;
	
	//Ищем склад
	ТекСклад = НЕОПРЕДЕЛЕНО;
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Если РЕЗ.Результат Тогда
		ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
		Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
			РЕЗ.Описание = "Warehouse not found";
		КонецЕсли;
	КонецЕсли;
	
	Если РЕЗ.Результат Тогда
		СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
		Подразделение = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов.SurplusSubdivision);
		
		РЕЗ = СоздатьОприходованиеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта,НастройкиПоУмолчанию,НастройкиПоУмолчанию.КорреспонденцияРеглОприходованиеЗапасов,Подразделение);
	КонецЕсли;
		
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьОприходованиеЗапасовИзлишки(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
			
	КонецЕсли;
	
	//Ищем склад
	ТекСклад = НЕОПРЕДЕЛЕНО;
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Если РЕЗ.Результат Тогда
		ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
		Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
			РЕЗ.Описание = "Warehouse not found";
		КонецЕсли;
	КонецЕсли;
	
	Если РЕЗ.Результат Тогда
		СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
		Подразделение = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов.SurplusSubdivision);
		
		РЕЗ = ОбновитьОприходованиеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта,НастройкиПоУмолчанию,НастройкиПоУмолчанию.КорреспонденцияРеглОприходованиеЗапасов,Подразделение);
	КонецЕсли;
		
	Возврат РЕЗ;
КонецФункции

Функция СоздатьОприходованиеЗапасовИнвентаризация(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
			
	КонецЕсли;
	
	//Ищем склад
	ТекСклад = НЕОПРЕДЕЛЕНО;
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Если РЕЗ.Результат Тогда
		ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
		Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
			РЕЗ.Описание = "Warehouse not found";
		КонецЕсли;
	КонецЕсли;
	
	Если РЕЗ.Результат Тогда
		СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Справочник_СтруктурныеЕдиницы);
		Подразделение = НайтиЗначениеДополнительногоРеквизита(ТекСклад, СтруктураДополнительныхРеквизитов.SurplusInventorySubdivision);
		
		РЕЗ = СоздатьОприходованиеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта,НастройкиПоУмолчанию,НастройкиПоУмолчанию.КорреспонденцияРеглОприходованиеЗапасовИнвентаризация,Подразделение);
	КонецЕсли;
		
	Возврат РЕЗ;
КонецФункции

