			Запрос.УстановитьПараметр("Наименование", Category);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекНоменклатура.КатегорияНоменклатуры = ВыборкаДетальныеЗаписи.Ссылка;
			КонецЦикла;
			
			Если НЕ ЗначениеЗаполнено(ТекНоменклатура.КатегорияНоменклатуры) Тогда
			
				ТекКатегорияНоменклатуры = Справочники.КатегорииНоменклатуры.СоздатьЭлемент();
				ТекКатегорияНоменклатуры.Наименование = Category;
				ТекКатегорияНоменклатуры.Записать();
				
				ТекНоменклатура.КатегорияНоменклатуры = ТекКатегорияНоменклатуры.Ссылка;
				
			
			КонецЕсли;
			
		Иначе
			
			ТекНоменклатура.КатегорияНоменклатуры = Справочники.КатегорииНоменклатуры.БезКатегории;
			
		КонецЕсли;
		
		Попытка
			ТекНоменклатура.Записать();
			
			РЕЗ.Результат = ИСТИНА;
			РЕЗ.ВозвращаемоеЗначение = OptionCode;
			РЕЗ.Описание = "Product created successfully";
		Исключение			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = OptionCode;
			РЕЗ.Описание = "Internal processing error";			
		КонецПопытки;
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = OptionCode;
		РЕЗ.Описание = "Product already exist";		
		
	КонецЕсли;	
	
	Возврат РЕЗ;
КонецФункции

