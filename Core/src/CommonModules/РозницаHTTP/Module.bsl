Функция СоздатьСписаниеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта, НастройкиПоУмолчанию, СчетКоррекспорденцииРегл, Подразделение=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	//НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	//Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	//
	//	РЕЗ.Результат = ЛОЖЬ;
	//	РЕЗ.ВозвращаемоеЗначение = Ref;
	//	РЕЗ.Описание = "Incorrect default settings";
	//	
	//	Возврат РЕЗ;
	//
	//КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_СписаниеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	СписаниеЗапасовДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.СписаниеЗапасов.ДополнительныеРеквизиты КАК СписаниеЗапасовДополнительныеРеквизиты
	               |ГДЕ
	               |	СписаниеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И СписаниеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		//Ищем склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			ТекДок = Документы.СписаниеЗапасов.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("ДокументСсылка.ИнвентаризацияЗапасов")] = "ЗаполнитьПоИнвентаризацииЗапасов";
			
			ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, НЕОПРЕДЕЛЕНО, СтратегияЗаполнения);
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
					
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;
			
			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			
			ТекДок.Корреспонденция = ПланыСчетов.Управленческий.НедостачиИПотериОтПорчиЦенностей;
			ТекДок.КорреспонденцияРегл = СчетКоррекспорденцииРегл;
			РегламентированныйУчетСервер.УстановитьУпрСчетИзПланаСчетовХозрасчетный(ТекДок.КорреспонденцияРегл, ТекДок.Корреспонденция);
			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				ТекДок.Подразделение = Подразделение;
			КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
				
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
			КонецЦикла;
			
			// Проверка остатков
			РЕЗ = ПолучитьМассивОшибокПоОстаткам(ТекДок,ТекДок.СтруктурнаяЕдиница,РЕЗ,МассивОшибок);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
			
			// Проводим
			ОписаниеУспешногоПроведения = "Doc write-off created successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок=РЕЗ.Описание;
			ФиксироватьТранзакции=ЛОЖЬ;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc write-off already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьСписаниеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта, НастройкиПоУмолчанию, СчетКоррекспорденцииРегл=НЕОПРЕДЕЛЕНО, Подразделение=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	//НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	//Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	//
	//	РЕЗ.Результат = ЛОЖЬ;
	//	РЕЗ.ВозвращаемоеЗначение = Ref;
	//	РЕЗ.Описание = "Incorrect default settings";
	//	
	//	Возврат РЕЗ;
	//
	//КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_СписаниеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	СписаниеЗапасовДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.СписаниеЗапасов.ДополнительныеРеквизиты КАК СписаниеЗапасовДополнительныеРеквизиты
	               |ГДЕ
	               |	СписаниеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И СписаниеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		
		//Ищем склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
		
			НачатьТранзакцию();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			КонецЦикла;
			
			// Убираем пометку удаления
			Попытка
				Если ТекДок.ПометкаУдаления Тогда
					ТекДок.Записать(РежимЗаписиДокумента.Запись);
					ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
				КонецЕсли;
			Исключение
				
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = Ref;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
			КонецПопытки;
			
			ТекДок.Дата = ДатаДокумента;
			
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
			УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
						
			ТекДок.Автор = НастройкиПоУмолчанию.Автор;
			ТекДок.Комментарий = Description;

			ТекДок.Организация = НастройкиПоУмолчанию.Организация;
			
			ТекДок.СтруктурнаяЕдиница = ТекСклад;
			
			Если ЗначениеЗаполнено(СчетКоррекспорденцииРегл) Тогда
				ТекДок.Корреспонденция = ПланыСчетов.Управленческий.НедостачиИПотериОтПорчиЦенностей;
				ТекДок.КорреспонденцияРегл = СчетКоррекспорденцииРегл;
				РегламентированныйУчетСервер.УстановитьУпрСчетИзПланаСчетовХозрасчетный(ТекДок.КорреспонденцияРегл, ТекДок.Корреспонденция);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Подразделение) Тогда
				ТекДок.Подразделение = Подразделение;
			КонецЕсли;
			
			// Заполняем табличную часть
			МассивОшибок = Новый Массив();
			ТекДок.Запасы.Очистить();
			Для каждого СоответствиеОбъекта Из TabularSection Цикл
			
				Если НЕ ТипЗНЧ(СоответствиеОбъекта)=Тип("Соответствие") Тогда
					
					РЕЗ.Результат = ЛОЖЬ;
					РЕЗ.ВозвращаемоеЗначение = Ref;
					РЕЗ.Описание = "Incorrect tabular section";
					
					Прервать;
				
				КонецЕсли;				
				
				ProductOptionCode = СоответствиеОбъекта.Получить("ProductOptionCode");
				Quantity = СоответствиеОбъекта.Получить("Quantity");
				
				ТекКоличество = 0;
				ТекНоменклатура = НайтиНомекклатуруПоАртикулу(СокрЛП(ProductOptionCode));
				
				Если ТекНоменклатура = НЕОПРЕДЕЛЕНО Тогда
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Product not found";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",ProductOptionCode);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
				Если ТипЗНЧ(Quantity)=Тип("Строка") Тогда
					Если СтрНайти(НРЕГ(Quantity),"null")=0 Тогда
						ТекКоличество = Число(Quantity);
					Иначе
						ТекКоличество = 0;
					КонецЕсли
				ИначеЕсли ТипЗНЧ(Quantity)=Тип("Число") Тогда
					ТекКоличество = Quantity;
				Иначе
					СтруктураОшибки = ПолучитьСтруктуруОшибки();
					
					СтруктураОшибки.Message = "Invalid quantity";
					СтруктураОшибки.Вставить("ProductOptionCode",ProductOptionCode);
					СтруктураОшибки.Вставить("Value",Quantity);
					
					МассивОшибок.Добавить(СтруктураОшибки);
				КонецЕсли;
				
			    СтрокаТабличнойЧасти = ТекДок.Запасы.Добавить();
				СтрокаТабличнойЧасти.Номенклатура = ТекНоменклатура;
				СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
				СтрокаТабличнойЧасти.СтранаПроисхождения = СтрокаТабличнойЧасти.Номенклатура.СтранаПроисхождения;
				СтрокаТабличнойЧасти.Количество = ТекКоличество;
				
			КонецЦикла;
			
			// Проверка остатков
			РЕЗ = ПолучитьМассивОшибокПоОстаткам(ТекДок,ТекДок.СтруктурнаяЕдиница,РЕЗ,МассивОшибок);
			
			ТекДок.КоличествоТоваров = ТекДок.Запасы.Итог("Количество");
			
			// Проводим
			ОписаниеУспешногоПроведения = "Doc write-off updated successfully";
			ЗаписыватьПриОшибках=ЛОЖЬ;
			ОписаниеДляМассиваОшибок=РЕЗ.Описание;
			ФиксироватьТранзакции=ИСТИНА;
			РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc write-off not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьСписаниеЗапасов(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_СписаниеЗапасов);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	СписаниеЗапасовДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.СписаниеЗапасов.ДополнительныеРеквизиты КАК СписаниеЗапасовДополнительныеРеквизиты
	                      |ГДЕ
	                      |	СписаниеЗапасовДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И СписаниеЗапасовДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc write-off deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc write-off not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
#КонецОбласти

#Область РасходнаяНакладная
Функция СоздатьРасходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	PartnerCIN = СоответствиеОбъекта.Получить("PartnerCIN");
	WarehouseCode = СоответствиеОбъекта.Получить("WarehouseCode");
	Currency = СоответствиеОбъекта.Получить("Currency");
	Description = СоответствиеОбъекта.Получить("Description");
	TabularSection = СоответствиеОбъекта.Получить("TabularSection");
	CashIncomeOrder = СоответствиеОбъекта.Получить("CashIncomeOrder");
	ReceivingMoneyOnAccount = СоответствиеОбъекта.Получить("ReceivingMoneyOnAccount");
	Return_ = СоответствиеОбъекта.Получить("Return");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	НаправлениеДеятельности=НЕОПРЕДЕЛЕНО;
	PartnerType = СоответствиеОбъекта.Получить("PartnerType");
	Если ЗначениеЗаполнено(PartnerType) Тогда
		РЕЗ = ПолучитьНаправлениеДеятельности(PartnerType,РЕЗ);
		Если РЕЗ.Результат Тогда
			НаправлениеДеятельности = РЕЗ.ВозвращаемоеЗначение;
		Иначе	
			Возврат РЕЗ;
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьПредоплату = ЛОЖЬ;
	AdvancePayment = СоответствиеОбъекта.Получить("AdvancePayment");
	Если ТипЗНЧ(AdvancePayment)=Тип("Булево") Тогда
		ЗаполнитьПредоплату = AccountingEntry;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Если НЕ ТипЗНЧ(TabularSection)=Тип("Массив") Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect tabular section";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
	               |ГДЕ
	               |	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		
		// Ищем контрагента				
		ТекКонтрагент = НайтиКонтрагентаПоИНН(СокрЛП(PartnerCIN));
		
		Если ТекКонтрагент = НЕОПРЕДЕЛЕНО Тогда
		
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = PartnerCIN;
			РЕЗ.Описание = "Partner not found";
			
		Иначе
			
			Если ЗначениеЗаполнено(ТекКонтрагент.ДоговорПоУмолчанию) Тогда
				ТекДоговор = ТекКонтрагент.ДоговорПоУмолчанию;
				Если ((НЕ ТекДоговор.Покупатель) И (Константы.ИспользоватьВидыДоговоров.Получить())) ИЛИ (НЕ ТекДоговор.ВалютаРасчетов = ТекВалюта.Ссылка) Тогда
					ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,ИСТИНА);
				КонецЕсли;
			Иначе
				ТекДоговор = СоздатьДоговор(ТекКонтрагент,НастройкиПоУмолчанию,ТекВалюта,ИСТИНА);
			КонецЕсли;
						
		КонецЕсли;
		
		//Ищем Склад
		Если РЕЗ.Результат Тогда
			ТекСклад = НайтиСклад(СокрЛП(WarehouseCode));
			Если ТекСклад = НЕОПРЕДЕЛЕНО Тогда
			
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = WarehouseCode;
				РЕЗ.Описание = "Warehouse not found";
			
			КонецЕсли;
		КонецЕсли;
		
		Если РЕЗ.Результат Тогда
			
			НачатьТранзакцию();
		
			ТекДок = Документы.РасходнаяНакладная.СоздатьДокумент();
			
			ТекДок.Дата = ДатаДокумента;
			ТекДок.УстановитьНовыйНомер();
			
			СтратегияЗаполнения = Новый Соответствие;
			СтратегияЗаполнения[Тип("Структура")] = "ЗаполнитьПоСтруктуре";
			СтратегияЗаполнения[Тип("ДокументСсылка.ПриходнаяНакладная")] = "ЗаполнитьПоПриходнойНакладной";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПокупателя")] = "ЗаполнитьПоЗаказуПокупателя";
			СтратегияЗаполнения[Тип("ДокументСсылка.ЗаказПоставщику")] = "ЗаполнитьПоЗаказуПоставщику";
			СтратегияЗаполнения[Тип("ДокументСсылка.СчетНаОплату")] = "ЗаполнитьПоСчетуНаОплату";
