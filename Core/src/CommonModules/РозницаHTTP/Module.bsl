		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаАвансовПоставщикуРегл)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаРасчетовСПокупателемРегл)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаРасчетовСПоставщикомРегл)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КорреспонденцияРеглОприходованиеЗапасов)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КорреспонденцияРеглОприходованиеЗапасовИнвентаризация)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КорреспонденцияРеглСписаниеЗапасов)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КорреспонденцияРеглСписаниеЗапасовУниформа)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.ПодразделениеСписаниеЗапасовУниформа)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КорреспонденцияРеглСписаниеЗапасовУтилизация)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.ПодразделениеСписаниеЗапасовУтилизация)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КорреспонденцияРеглСписаниеЗапасовИнвентаризация)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.ПодразделениеСписаниеЗапасовИнвентаризация)
		//ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаКасса)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаРеглКасса)
		//ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаБанковскийСчет)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СчетУчетаРеглБанковскийСчет)
		//ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.КассаККМ)
		//ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.ПодразделениеКассаККМ)
		//ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СтатьяКассаККМ)
		ИЛИ НЕ ЗначениеЗаполнено(РЕЗ.СтатьиДвиженияДенежныхСредств_ПеремещениеДС)
		Тогда
		РЕЗ.ВсеПравильно = ЛОЖЬ;
	КонецЕсли;	
	
	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиВалюту(Currency,СтруктураДляВозврата)
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	РЕЗ.Результат = ЛОЖЬ;
	РЕЗ.Описание = "Currency not found";
	
	Если ТипЗНЧ(Currency)=Тип("Соответствие") Тогда
		
		Code = Currency.Получить("Code");
		Description = Currency.Получить("Description");
		
		Если ЗначениеЗаполнено(Description) Тогда
			
			РЕЗ.ВозвращаемоеЗначение = Description;
			
			ОписаниеВалютыСтрока = СокрЛП(Description);
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Валюты.Ссылка
			|ИЗ
			|	Справочник.Валюты КАК Валюты
			|ГДЕ
			|	(Валюты.Наименование = &ОписаниеВалютыСтрока
			|			ИЛИ Валюты.СимвольноеПредставление = &ОписаниеВалютыСтрока)";
			
			Запрос.УстановитьПараметр("ОписаниеВалютыСтрока", ОписаниеВалютыСтрока);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				РЕЗ.Результат = ИСТИНА;
				РЕЗ.ВозвращаемоеЗначение = ВыборкаДетальныеЗаписи.Ссылка;
				РЕЗ.Описание = "";
			КонецЦикла;
			
		КонецЕсли;
		
		Если НЕ РЕЗ.Результат Тогда
		
			Если ЗначениеЗаполнено(Code) Тогда
				
				РЕЗ.ВозвращаемоеЗначение = Code;
				
				КодВалютыЧисло = 0;
				Попытка
					КодВалютыЧисло = ЧИСЛО(Code);
				Исключение
				КонецПопытки;
				
				Если КодВалютыЧисло>0 Тогда
					КодВалютыСтрока = СокрЛП(Строка(КодВалютыЧисло));
					
					Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ ПЕРВЫЕ 1
					|	Валюты.Ссылка
					|ИЗ
					|	Справочник.Валюты КАК Валюты
					|ГДЕ
					|	Валюты.Код = &КодВалютыСтрока";
					
					Запрос.УстановитьПараметр("КодВалютыСтрока", КодВалютыСтрока);
					
					РезультатЗапроса = Запрос.Выполнить();
					
					ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
					
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
						РЕЗ.Результат = ИСТИНА;
						РЕЗ.ВозвращаемоеЗначение = ВыборкаДетальныеЗаписи.Ссылка;
						РЕЗ.Описание = "";
					КонецЦикла;
				КонецЕсли;
			
			КонецЕсли;
		
		КонецЕсли;
		
	ИначеЕсли ТипЗНЧ(Currency)=Тип("Строка") Тогда
		
		РЕЗ.ВозвращаемоеЗначение = Currency;
		
		ОписаниеВалютыСтрока = СокрЛП(Currency);
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Валюты.Ссылка
		|ИЗ
		|	Справочник.Валюты КАК Валюты
		|ГДЕ
		|	(Валюты.Наименование = &ОписаниеВалютыСтрока
		|			ИЛИ Валюты.СимвольноеПредставление = &ОписаниеВалютыСтрока)";
		
		Запрос.УстановитьПараметр("ОписаниеВалютыСтрока", ОписаниеВалютыСтрока);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			РЕЗ.Результат = ИСТИНА;
			РЕЗ.ВозвращаемоеЗначение = ВыборкаДетальныеЗаписи.Ссылка;
			РЕЗ.Описание = "";
		КонецЦикла;
		
		Если НЕ РЕЗ.Результат Тогда
			
			КодВалютыЧисло = 0;
			Попытка
				КодВалютыЧисло = ЧИСЛО(Currency);
			Исключение
			КонецПопытки;
			
			Если КодВалютыЧисло>0 Тогда
				КодВалютыСтрока = СокрЛП(Строка(КодВалютыЧисло));
				
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ ПЕРВЫЕ 1
				|	Валюты.Ссылка
				|ИЗ
				|	Справочник.Валюты КАК Валюты
				|ГДЕ
				|	Валюты.Код = &КодВалютыСтрока";
				
				Запрос.УстановитьПараметр("КодВалютыСтрока", КодВалютыСтрока);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					РЕЗ.Результат = ИСТИНА;
					РЕЗ.ВозвращаемоеЗначение = ВыборкаДетальныеЗаписи.Ссылка;
					РЕЗ.Описание = "";
				КонецЦикла;
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли ТипЗНЧ(Currency)=Тип("Число") Тогда
		
		РЕЗ.ВозвращаемоеЗначение = Currency;
		
		КодВалютыЧисло = 0;
		Попытка
			КодВалютыЧисло = ЧИСЛО(Currency);
		Исключение
		КонецПопытки;
		
		Если КодВалютыЧисло>0 Тогда
			КодВалютыСтрока = СокрЛП(Строка(КодВалютыЧисло));
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Валюты.Ссылка
			|ИЗ
			|	Справочник.Валюты КАК Валюты
			|ГДЕ
			|	Валюты.Код = &КодВалютыСтрока";
			
			Запрос.УстановитьПараметр("КодВалютыСтрока", КодВалютыСтрока);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				РЕЗ.Результат = ИСТИНА;
				РЕЗ.ВозвращаемоеЗначение = ВыборкаДетальныеЗаписи.Ссылка;
				РЕЗ.Описание = "";
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;

	Возврат РЕЗ;
КонецФункции // ()

