			Запрос.УстановитьПараметр("Дата1", ТекДата);
			Запрос.УстановитьПараметр("Субконто2", ТекТовар);
			Запрос.УстановитьПараметр("Счет", ТекТовар.СчетУчетаЗапасовРегл);
			
			РезультатЗапроса = Запрос.Выполнить();
			Если НЕ РезультатЗапроса.Пустой() Тогда
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					ЗаполнитьЗначенияСвойств(РЕЗ,ВыборкаДетальныеЗаписи);
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
		// Ищем по остаткам в группе
		Если РЕЗ.Цена<=0 Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ХозрасчетныйОстатки.СуммаОстаток КАК Сумма,
			|	ХозрасчетныйОстатки.КоличествоОстаток КАК Количество,
			|	ВЫБОР
			|		КОГДА ХозрасчетныйОстатки.КоличествоОстаток <> 0
			|			ТОГДА ХозрасчетныйОстатки.СуммаОстаток / ХозрасчетныйОстатки.КоличествоОстаток
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК Цена
			|ИЗ
			|	РегистрБухгалтерии.Хозрасчетный.Остатки(
			|			&Дата1,
			|			Счет = &Счет,
			|			,
			|			Субконто2.Родитель = ВЫРАЗИТЬ(&Субконто2 КАК Справочник.Номенклатура).Родитель) КАК ХозрасчетныйОстатки";
			
			Запрос.УстановитьПараметр("Дата1", ТекДата);
			Запрос.УстановитьПараметр("Субконто2", ТекТовар);
			Запрос.УстановитьПараметр("Счет", ТекТовар.СчетУчетаЗапасовРегл);
			
			РезультатЗапроса = Запрос.Выполнить();
			Если НЕ РезультатЗапроса.Пустой() Тогда
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					ЗаполнитьЗначенияСвойств(РЕЗ,ВыборкаДетальныеЗаписи);
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
		// Ищем по оборотам в группе
		Если РЕЗ.Цена<=0 Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ХозрасчетныйОстаткиИОбороты.СуммаОборотДт,
			|	ХозрасчетныйОстаткиИОбороты.КоличествоОборотДт,
			|	ВЫБОР
			|		КОГДА ХозрасчетныйОстаткиИОбороты.КоличествоОборотДт > 0
			|				И ХозрасчетныйОстаткиИОбороты.СуммаОборотДт > 0
			|			ТОГДА ХозрасчетныйОстаткиИОбороты.СуммаОборотДт / ХозрасчетныйОстаткиИОбороты.КоличествоОборотДт
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК Цена
			|ИЗ
			|	РегистрБухгалтерии.Хозрасчетный.ОстаткиИОбороты(, &Дата1, , , Счет = &Счет, , Субконто2.Родитель = ВЫРАЗИТЬ(&Субконто2 КАК Справочник.Номенклатура).Родитель) КАК ХозрасчетныйОстаткиИОбороты";
			
			Запрос.УстановитьПараметр("Дата1", ТекДата);
			Запрос.УстановитьПараметр("Субконто2", ТекТовар);
			Запрос.УстановитьПараметр("Счет", ТекТовар.СчетУчетаЗапасовРегл);
			
			РезультатЗапроса = Запрос.Выполнить();
			Если НЕ РезультатЗапроса.Пустой() Тогда
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					ЗаполнитьЗначенияСвойств(РЕЗ,ВыборкаДетальныеЗаписи);
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция ПолучитьНаправлениеДеятельности(PartnerType,СтруктураДляВозврата) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	НаправлениеДеятельности = НЕОПРЕДЕЛЕНО;
	
	ПоУмолчанию = Справочники.ПараметрыДляОбменаДаннымиРозницаHTTP.ПоУмолчанию;
	
	Если ТипЗНЧ(PartnerType) = Тип("Число") Тогда
		
		Для каждого СтрНаправленияДеятельности Из ПоУмолчанию.НаправленияДеятельности Цикл
		
			Если СтрНаправленияДеятельности.НомерСтроки = PartnerType Тогда
			
				НаправлениеДеятельности = СтрНаправленияДеятельности.НаправлениеДеятельности;
				Прервать;
			
			КонецЕсли;
		
		КонецЦикла; 
		
	ИначеЕсли ТипЗНЧ(PartnerType) = Тип("Строка") Тогда
		
		Для каждого СтрНаправленияДеятельности Из ПоУмолчанию.НаправленияДеятельности Цикл
		
			Если СокрЛП(СтрНаправленияДеятельности.Наименование) = СокрЛП(PartnerType) Тогда
			
				НаправлениеДеятельности = СтрНаправленияДеятельности.НаправлениеДеятельности;
				Прервать;
			
			КонецЕсли;
		
		КонецЦикла;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НаправлениеДеятельности) Тогда
	
		РЕЗ.Результат = ИСТИНА;
		РЕЗ.ВозвращаемоеЗначение = НаправлениеДеятельности;
		РЕЗ.Описание = НаправлениеДеятельности.Наименование;
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = PartnerType;
		РЕЗ.Описание = "Incorrect partner type";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	Возврат РЕЗ;

КонецФункции // ()
