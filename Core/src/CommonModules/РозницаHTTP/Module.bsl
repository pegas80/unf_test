		               |ИЗ
		               |	Документ.РасходИзКассы.ДополнительныеРеквизиты КАК РасходИзКассыДополнительныеРеквизиты
		               |ГДЕ
		               |	РасходИзКассыДополнительныеРеквизиты.Значение = &ТекПараметр
		               |	И РасходИзКассыДополнительныеРеквизиты.Свойство = &ДопПараметрРасходИзКассы
		               |
		               |ОБЪЕДИНИТЬ
		               |
		               |ВЫБРАТЬ
		               |	ПоступлениеНаСчетДополнительныеРеквизиты.Ссылка
		               |ИЗ
		               |	Документ.ПоступлениеНаСчет.ДополнительныеРеквизиты КАК ПоступлениеНаСчетДополнительныеРеквизиты
		               |ГДЕ
		               |	ПоступлениеНаСчетДополнительныеРеквизиты.Значение = &ТекПараметр
		               |	И ПоступлениеНаСчетДополнительныеРеквизиты.Свойство = &ДопПараметрПоступлениеНаСчет";
		
		Запрос.УстановитьПараметр("ТекПараметр", ТекСсылка);
		Запрос.УстановитьПараметр("ДопПараметрПриходнаяНакладная", ДопПараметрПриходнаяНакладная);
		Запрос.УстановитьПараметр("ДопПараметрПеремещениеЗапасов", ДопПараметрПеремещениеЗапасов);
		Запрос.УстановитьПараметр("ДопПараметрПриходныйОрдер", ДопПараметрПриходныйОрдер);
		Запрос.УстановитьПараметр("ДопПараметрРасходныйОрдер", ДопПараметрРасходныйОрдер);
		Запрос.УстановитьПараметр("ДопПараметрОприходованиеЗапасов", ДопПараметрОприходованиеЗапасов);
		Запрос.УстановитьПараметр("ДопПараметрСписаниеЗапасов", ДопПараметрСписаниеЗапасов);
		Запрос.УстановитьПараметр("ДопПараметрРасходнаяНакладная", ДопПараметрРасходнаяНакладная);
		Запрос.УстановитьПараметр("ДопПараметрОтчетОРозничныхПродажах", ДопПараметрОтчетОРозничныхПродажах);
		Запрос.УстановитьПараметр("ДопПараметрПоступлениеВКассу", ДопПараметрПоступлениеВКассу);
		Запрос.УстановитьПараметр("ДопПараметрРасходИзКассы", ДопПараметрРасходИзКассы);
		Запрос.УстановитьПараметр("ДопПараметрПоступлениеНаСчет", ДопПараметрПоступлениеНаСчет);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		Пока РезультатЗапроса.Следующий() Цикл
			СсылкаНаДокумент = РезультатЗапроса.Ссылка;
			ДокументОбъект = СсылкаНаДокумент.ПолучитьОбъект();
		КонецЦикла;
		
		Если НЕ ДокументОбъект = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ.Результат = ИСТИНА;
			РЕЗ.ВозвращаемоеЗначение = СсылкаНаДокумент;
			РЕЗ.Описание = "Successfully";
		КонецЕсли;
		
	Иначе
		РЕЗ.Результат = ИСТИНА;
		РЕЗ.ВозвращаемоеЗначение = СсылкаНаДокумент;
		РЕЗ.Описание = "Successfully";
	КонецЕсли;

	Возврат РЕЗ;
КонецФункции // ()

Функция ПолучитьСвязанныеОбъекты(СтруктураДляВозврата,ТекСсылка) ЭКСПОРТ

	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	мДерево = Новый ДеревоЗначений();
	мДерево.Колонки.Добавить("Ссылка");
	
	мУжеВСписке = Новый Соответствие;
	мКэшРеквизитовДокумента = Новый Соответствие;
	
	РЕЗ = ПолучитьДокументПоСсылке(СтруктураДляВозврата,ТекСсылка);
	Если РЕЗ.Результат Тогда
		
		Попытка
			
			ВывестиРодительскиеДокументы(РЕЗ.ВозвращаемоеЗначение,мДерево,мУжеВСписке,мКэшРеквизитовДокумента);
			
			ВывестиПодчиненныеДокументы(мДерево,мУжеВСписке,мКэшРеквизитовДокумента);
		
		Исключение
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = ТекСсылка;
			РЕЗ.Описание = "Internal processing error";
			
			Возврат РЕЗ;
			
		КонецПопытки;
		
	КонецЕсли;
	
	// Пробуем найти подчиненные подчиненных
	Если ТипЗНЧ(мДерево)=Тип("ДеревоЗначений") ИЛИ ТипЗНЧ(мДерево)=Тип("СтрокаДереваЗначений") Тогда
		
		Для каждого СтрокаДерева Из мДерево.Строки Цикл
		
			Попытка
				
				ВывестиРодительскиеДокументы(СтрокаДерева.Ссылка,СтрокаДерева,мУжеВСписке,мКэшРеквизитовДокумента);
				
				ВывестиПодчиненныеДокументы(СтрокаДерева,мУжеВСписке,мКэшРеквизитовДокумента);	
								
			Исключение
				
				РЕЗ.Результат = ЛОЖЬ;
				РЕЗ.ВозвращаемоеЗначение = ТекСсылка;
				РЕЗ.Описание = "Internal processing error";
				
				Возврат РЕЗ;
				
			КонецПопытки;
		
		КонецЦикла; 
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекСсылка;
		РЕЗ.Описание = "Internal processing error";
		
		Возврат РЕЗ;
		
	КонецЕсли;	
	
	мУжеВСписке = Новый Соответствие;
	МассивРезультатов = Новый Массив();
	
	Если ТипЗНЧ(мДерево)=Тип("СтрокаДереваЗначений") Тогда
		
		СтруктураДанных = ОбработатьДанныеДляСтруктурыПодчиненности(мДерево,РЕЗ.ВозвращаемоеЗначение);
						
		МассивРезультатов.Добавить(СтруктураДанных);
		мУжеВСписке.Вставить(мДерево.Ссылка, Истина);
		
		Для каждого СтрокаДерева Из мДерево.Строки Цикл
		
			ОбработатьДеревоСтруктурыПодчиненности(СтрокаДерева,МассивРезультатов,РЕЗ.ВозвращаемоеЗначение,мУжеВСписке);
		
		КонецЦикла;
	
	ИначеЕсли ТипЗНЧ(мДерево)=Тип("ДеревоЗначений") Тогда
		
		Для каждого СтрокаДерева Из мДерево.Строки Цикл
		
			ОбработатьДеревоСтруктурыПодчиненности(СтрокаДерева,МассивРезультатов,РЕЗ.ВозвращаемоеЗначение,мУжеВСписке);
		
		КонецЦикла; 
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ТекСсылка;
		РЕЗ.Описание = "Internal processing error";
		
		Возврат РЕЗ;
		
	КонецЕсли;
	
	РЕЗ.Результат = ИСТИНА;
	РЕЗ.ВозвращаемоеЗначение = МассивРезультатов;
	РЕЗ.Описание = "Successfully";	
	
	Возврат РЕЗ;
	
КонецФункции // ()
#КонецОбласти

#Область ПеремещениеДС
Функция СоздатьПеремещениеДС(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	DepartureCashDeskCode = СоответствиеОбъекта.Получить("DepartureCashDeskCode");
	DepartureCashDesk = СоответствиеОбъекта.Получить("DepartureCashDesk");
	ReceiverCashDeskCode = СоответствиеОбъекта.Получить("ReceiverCashDeskCode");
	ReceiverCashDesk = СоответствиеОбъекта.Получить("ReceiverCashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	ID = СоответствиеОбъекта.Получить("ID");
	PurposeOfPayment = СоответствиеОбъекта.Получить("PurposeOfPayment");
	Sum = СоответствиеОбъекта.Получить("Sum");
	Description = СоответствиеОбъекта.Получить("Description");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ DepartureCashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(DepartureCashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(DepartureCashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ DepartureCashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,DepartureCashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(DepartureCashDeskCode = НЕОПРЕДЕЛЕНО,Ref,DepartureCashDeskCode);
		РЕЗ.Описание = "Departure CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	// Ищем Кассу-получатель
	ТекКассаПолучатель = НЕОПРЕДЕЛЕНО;
	Если НЕ ReceiverCashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(ReceiverCashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(ReceiverCashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКассаПолучатель = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКассаПолучатель = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ ReceiverCashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,ReceiverCashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКассаПолучатель = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКассаПолучатель = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(ReceiverCashDeskCode = НЕОПРЕДЕЛЕНО,Ref,ReceiverCashDeskCode);
		РЕЗ.Описание = "Receiver CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
		Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
			ТекСумма = Число(Sum);
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of money transfer";
		
			Возврат РЕЗ;
		КонецЕсли;
	ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
		ТекСумма = Sum;
		Если ТекСумма = 0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of money transfer";
			
			Возврат РЕЗ;
		КонецЕсли;
	Иначе
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect sum of money transfer";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеДС);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПеремещениеДСДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПеремещениеДС.ДополнительныеРеквизиты КАК ПеремещениеДСДополнительныеРеквизиты
	               |ГДЕ
	               |	ПеремещениеДСДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПеремещениеДСДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Создаём документ
		ТекДок = Документы.ПеремещениеДС.СоздатьДокумент();
		
		ТекДок.Дата = ДатаДокумента;
		ТекДок.УстановитьНовыйНомер();
		
		СтратегияЗаполнения = Новый Соответствие;
		СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеДСПлан")] = "ЗаполнитьПоПеремещениеДСПлан";
		
		ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, НЕОПРЕДЕЛЕНО, СтратегияЗаполнения);
		
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
		
		ТекДок.Автор = НастройкиПоУмолчанию.Автор;
		ТекДок.Комментарий = Description;
		ТекДок.ID = СокрЛП(ID);
		ТекДок.НазначениеПлатежа = СокрЛП(PurposeOfPayment);
				
		ТекДок.Организация = НастройкиПоУмолчанию.Организация;		
		ТекДок.Статья = НастройкиПоУмолчанию.СтатьиДвиженияДенежныхСредств_ПеремещениеДС;
		ТекДок.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные;
		ТекДок.ТипДенежныхСредствПолучатель = Перечисления.ТипыДенежныхСредств.Наличные;
		ТекДок.ХозяйственнаяОперация = Справочники.ХозяйственныеОперации.ПеремещениеДС;
		
		ТекДок.ВалютаДенежныхСредств = ТекВалюта;
		ТекДок.Касса = ТекКасса;
		ТекДок.КассаПолучатель = ТекКассаПолучатель;
		ТекДок.СуммаДокумента = Sum;
		
		МассивОшибок = Новый Массив();
		
		// Проводим
		ОписаниеУспешногоПроведения = "Doc of money transfer created successfully";
		ЗаписыватьПриОшибках=ЛОЖЬ;
		ОписаниеДляМассиваОшибок="";
		ФиксироватьТранзакции=ЛОЖЬ;
		РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc of money transfer already exist";		
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ОбновитьПеремещениеДС(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	Ref = СоответствиеОбъекта.Получить("Ref");
	Number = СоответствиеОбъекта.Получить("Number");
	Date = СоответствиеОбъекта.Получить("Date");
	DepartureCashDeskCode = СоответствиеОбъекта.Получить("DepartureCashDeskCode");
	DepartureCashDesk = СоответствиеОбъекта.Получить("DepartureCashDesk");
	ReceiverCashDeskCode = СоответствиеОбъекта.Получить("ReceiverCashDeskCode");
	ReceiverCashDesk = СоответствиеОбъекта.Получить("ReceiverCashDesk");
	Currency = СоответствиеОбъекта.Получить("Currency");
	ID = СоответствиеОбъекта.Получить("ID");
	PurposeOfPayment = СоответствиеОбъекта.Получить("PurposeOfPayment");
	Sum = СоответствиеОбъекта.Получить("Sum");
	Description = СоответствиеОбъекта.Получить("Description");
	
	НеПроводить=ЛОЖЬ;
	AccountingEntry = СоответствиеОбъекта.Получить("AccountingEntry");
	Если ТипЗНЧ(AccountingEntry)=Тип("Булево") Тогда
		НеПроводить = НЕ (AccountingEntry);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Ref) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	ДатаДокумента = ДатаJSON(Date);
	Если ДатаДокумента = НЕОПРЕДЕЛЕНО Тогда
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Date;
		РЕЗ.Описание = "Error reading date";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	ТекВалюта = НЕОПРЕДЕЛЕНО;
	РЕЗ = НайтиВалюту(Currency,СтруктураДляВозврата);
	Если НЕ РЕЗ.Результат Тогда
		Возврат РЕЗ;
	Иначе
		ТекВалюта = РЕЗ.ВозвращаемоеЗначение;
	КонецЕсли;
	
	// Ищем Кассу
	ТекКасса = НЕОПРЕДЕЛЕНО;
	Если НЕ DepartureCashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(DepartureCashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(DepartureCashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКасса = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ DepartureCashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,DepartureCashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКасса = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКасса = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(DepartureCashDeskCode = НЕОПРЕДЕЛЕНО,Ref,DepartureCashDeskCode);
		РЕЗ.Описание = "Departure CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	// Ищем Кассу-получатель
	ТекКассаПолучатель = НЕОПРЕДЕЛЕНО;
	Если НЕ ReceiverCashDeskCode = НЕОПРЕДЕЛЕНО Тогда
		Если ТипЗНЧ(ReceiverCashDeskCode)=Тип("Строка") Тогда
			ЗапросКасса = Новый Запрос;
			ЗапросКасса.Текст = 
			"ВЫБРАТЬ
			|	Кассы.Ссылка
			|ИЗ
			|	Справочник.Кассы КАК Кассы
			|ГДЕ
			|	Кассы.Код = &Код";
			
			ЗапросКасса.УстановитьПараметр("Код", СокрЛП(ReceiverCashDeskCode));
			РезультатЗапросаКасса = ЗапросКасса.Выполнить();
			ВыборкаДетальныеЗаписиКасса = РезультатЗапросаКасса.Выбрать();
			Пока ВыборкаДетальныеЗаписиКасса.Следующий() Цикл
				ТекКассаПолучатель = ВыборкаДетальныеЗаписиКасса.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ТекКассаПолучатель = НЕОПРЕДЕЛЕНО Тогда
		Если НЕ ReceiverCashDesk = НЕОПРЕДЕЛЕНО Тогда
			РЕЗ = НайтиИлиСоздатьКассу(РЕЗ,ReceiverCashDesk,ТекВалюта);
			Если НЕ РЕЗ.Результат Тогда
				Возврат РЕЗ;
			Иначе
				ТекКассаПолучатель = РЕЗ.ВозвращаемоеЗначение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТекКассаПолучатель = НЕОПРЕДЕЛЕНО Тогда
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ?(ReceiverCashDeskCode = НЕОПРЕДЕЛЕНО,Ref,ReceiverCashDeskCode);
		РЕЗ.Описание = "Receiver CashDesk not found";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	Если ТипЗНЧ(Sum)=Тип("Строка") Тогда
		Если СтрНайти(НРЕГ(Sum),"null")=0 Тогда
			ТекСумма = Число(Sum);
		Иначе
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of money transfer";
		
			Возврат РЕЗ;
		КонецЕсли;
	ИначеЕсли ТипЗНЧ(Sum)=Тип("Число") Тогда
		ТекСумма = Sum;
		Если ТекСумма = 0 Тогда
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Incorrect sum of money transfer";
			
			Возврат РЕЗ;
		КонецЕсли;
	Иначе
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect sum of money transfer";
		
		Возврат РЕЗ;
	КонецЕсли;
	
	НастройкиПоУмолчанию = ПолучитьНастройкиПоУмолчанию();
	Если НЕ НастройкиПоУмолчанию.ВсеПравильно Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Incorrect default settings";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Ищем существующие
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеДС);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ПеремещениеДСДополнительныеРеквизиты.Ссылка
	               |ИЗ
	               |	Документ.ПеремещениеДС.ДополнительныеРеквизиты КАК ПеремещениеДСДополнительныеРеквизиты
	               |ГДЕ
	               |	ПеремещениеДСДополнительныеРеквизиты.Значение = &ТекПараметр
	               |	И ПеремещениеДСДополнительныеРеквизиты.Свойство = &ДопПараметр";
		
	Запрос.УстановитьПараметр("ТекПараметр", Ref);
	Запрос.УстановитьПараметр("ДопПараметр", ДопПараметр);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		НачатьТранзакцию();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекДок = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		КонецЦикла;
		
		// Убираем пометку удаления
		Попытка
			Если ТекДок.ПометкаУдаления Тогда
				ТекДок.Записать(РежимЗаписиДокумента.Запись);
				ТекДок.УстановитьПометкуУдаления(ЛОЖЬ);
			КонецЕсли;
		Исключение
			
			Если ТранзакцияАктивна() Тогда
				ОтменитьТранзакцию();
			КонецЕсли;
			
			РЕЗ.Результат = ЛОЖЬ;
			РЕЗ.ВозвращаемоеЗначение = Ref;
			РЕЗ.Описание = "Internal processing error";
			
			Возврат РЕЗ;
		КонецПопытки;
				
		ТекДок.Дата = ДатаДокумента;
		ТекДок.УстановитьНовыйНомер();
		
		СтратегияЗаполнения = Новый Соответствие;
		СтратегияЗаполнения[Тип("ДокументСсылка.ПеремещениеДСПлан")] = "ЗаполнитьПоПеремещениеДСПлан";
		
		ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(ТекДок, НЕОПРЕДЕЛЕНО, СтратегияЗаполнения);
		
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocRef,Ref);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocNumber,Number);
		УстановитьДополнительныйРеквизит(ТекДок, СтруктураДополнительныхРеквизитов.DocDate,Date);
		
		ТекДок.Автор = НастройкиПоУмолчанию.Автор;
		ТекДок.Комментарий = Description;
		ТекДок.ID = СокрЛП(ID);
		ТекДок.НазначениеПлатежа = СокрЛП(PurposeOfPayment);
				
		ТекДок.Организация = НастройкиПоУмолчанию.Организация;		
		ТекДок.Статья = НастройкиПоУмолчанию.СтатьиДвиженияДенежныхСредств_ПеремещениеДС;
		ТекДок.ТипДенежныхСредств = Перечисления.ТипыДенежныхСредств.Наличные;
		ТекДок.ТипДенежныхСредствПолучатель = Перечисления.ТипыДенежныхСредств.Наличные;
		ТекДок.ХозяйственнаяОперация = Справочники.ХозяйственныеОперации.ПеремещениеДС;
		
		ТекДок.ВалютаДенежныхСредств = ТекВалюта;
		ТекДок.Касса = ТекКасса;
		ТекДок.КассаПолучатель = ТекКассаПолучатель;
		ТекДок.СуммаДокумента = Sum;
		
		МассивОшибок = Новый Массив();
		
		// Проводим
		ОписаниеУспешногоПроведения = "Doc of money transfer updated successfully";
		ЗаписыватьПриОшибках=ЛОЖЬ;
		ОписаниеДляМассиваОшибок="";
		ФиксироватьТранзакции=ИСТИНА;
		РЕЗ = ПопыткаПровестиДокумент(ТекДок,Ref,РЕЗ,ОписаниеУспешногоПроведения,МассивОшибок,ФиксироватьТранзакции,ЗаписыватьПриОшибках,ОписаниеДляМассиваОшибок,НеПроводить);
		
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc of money transfer not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция УдалитьПеремещениеДС(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПеремещениеДС);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	ПеремещениеДСДополнительныеРеквизиты.Ссылка
	                      |ИЗ
