								Return_.Вставить("Date",Date+1);
							КонецЕсли;
							
							Если Return_.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("PartnerCIN",PartnerCIN);
							КонецЕсли;
							
							Если Return_.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("WarehouseCode",WarehouseCode);
							КонецЕсли;
							
							Если Return_.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Currency",Currency);
							КонецЕсли;
							
							Если Return_.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
								Return_.Вставить("Description",Description);
							КонецЕсли;
							
							Если Return_.Получить("PartnerType")=НЕОПРЕДЕЛЕНО Тогда
								Если ЗначениеЗаполнено(PartnerType) Тогда
									Return_.Вставить("PartnerType",PartnerType);
								КонецЕсли;
							КонецЕсли;
							
							РЕЗ = СоздатьИлиОбновитьВозвратТоваровОтПокупателяИзРасходнойНакладной(РЕЗ,ТекReturn_,Ref);
							
							Если НЕ РЕЗ.Результат Тогда
								РЕЗ.Описание = СтрокаОшибок + "; Return of goods: " + РЕЗ.Описание;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
						
					Иначе	

						Если Return_.Получить("Ref")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Ref",Ref);
						КонецЕсли;
						
						Если Return_.Получить("Number")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Number",Number);
						КонецЕсли;
						
						Если Return_.Получить("Date")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Date",Date+1);
						КонецЕсли;
						
						Если Return_.Получить("PartnerCIN")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("PartnerCIN",PartnerCIN);
						КонецЕсли;
						
						Если Return_.Получить("WarehouseCode")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("WarehouseCode",WarehouseCode);
						КонецЕсли;
						
						Если Return_.Получить("Currency")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Currency",Currency);
						КонецЕсли;
						
						Если Return_.Получить("Description")=НЕОПРЕДЕЛЕНО Тогда
							Return_.Вставить("Description",Description);
						КонецЕсли;
						
						Если Return_.Получить("PartnerType")=НЕОПРЕДЕЛЕНО Тогда
							Если ЗначениеЗаполнено(PartnerType) Тогда
								Return_.Вставить("PartnerType",PartnerType);
							КонецЕсли;
						КонецЕсли;
						
						РЕЗ = СоздатьИлиОбновитьВозвратТоваровОтПокупателяИзРасходнойНакладной(РЕЗ,Return_,Ref);
						
						Если НЕ РЕЗ.Результат Тогда
							РЕЗ.Описание = СтрокаОшибок + "; Return of goods: " + РЕЗ.Описание;
						КонецЕсли;
						
					КонецЕсли;
				
				КонецЕсли;
			КонецЕсли;
			
			Если РЕЗ.Результат Тогда
				РЕЗ.Описание = "Doc sale updated successfully";
				ЗафиксироватьТранзакцию()
			Иначе
				Если ТранзакцияАктивна() Тогда
					ОтменитьТранзакцию();
				КонецЕсли;
				
				РЕЗ.Описание = СтрЗаменить(РЕЗ.Описание,"Doc sale updated successfully","Update sales doc: error");
			КонецЕсли;
		
		КонецЕсли;
			
	Иначе
		
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = Ref;
		РЕЗ.Описание = "Doc sale not found";
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция УдалитьРасходнуюНакладную(СтруктураДляВозврата,СоответствиеОбъекта) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ПолучитьСтруктураДляВозврата(СтруктураДляВозврата);
	
	ЗначениеПараметра = СоответствиеОбъекта.Получить("Ref");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеПараметра) Тогда
	
		РЕЗ.Результат = ЛОЖЬ;
		РЕЗ.ВозвращаемоеЗначение = ЗначениеПараметра;
		РЕЗ.Описание = "Incorrect ref";
		
		Возврат РЕЗ;
	
	КонецЕсли;
	
	// Удаляем поступления в кассу
	СтруктураДополнительныхРеквизитовПоступлениеВКассу = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеВКассу);
	ДопПараметрПоступлениеВКассу = СтруктураДополнительныхРеквизитовПоступлениеВКассу.BaseRef;
	
	ЗапросПоступлениеВКассу = Новый Запрос;
	ЗапросПоступлениеВКассу.Текст = "ВЫБРАТЬ
	                                |	ПоступлениеВКассуДополнительныеРеквизиты.Ссылка
	                                |ИЗ
	                                |	Документ.ПоступлениеВКассу.ДополнительныеРеквизиты КАК ПоступлениеВКассуДополнительныеРеквизиты
	                                |ГДЕ
	                                |	ПоступлениеВКассуДополнительныеРеквизиты.Значение = &ТекПараметр
	                                |	И ПоступлениеВКассуДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	ЗапросПоступлениеВКассу.УстановитьПараметр("ТекПараметр", ЗначениеПараметра);
	ЗапросПоступлениеВКассу.УстановитьПараметр("ДопПараметр", ДопПараметрПоступлениеВКассу);
	РезультатЗапросаПоступлениеВКассу = ЗапросПоступлениеВКассу.Выполнить();
	ВыборкаПоступлениеВКассу = РезультатЗапросаПоступлениеВКассу.Выбрать();
	Пока ВыборкаПоступлениеВКассу.Следующий() Цикл
		
		ТекОбъект = ВыборкаПоступлениеВКассу.Ссылка.ПолучитьОбъект();
		
		ТекОбъект.УстановитьПометкуУдаления(ИСТИНА);
		
	КонецЦикла;
	
	// Удаляем поступления на счет
	СтруктураДополнительныхРеквизитовПоступлениеНаСчет = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПоступлениеНаСчет);
	ДопПараметрПоступлениеНаСчет = СтруктураДополнительныхРеквизитовПоступлениеНаСчет.BaseRef;
	
	ЗапросПоступлениеНаСчет = Новый Запрос;
	ЗапросПоступлениеНаСчет.Текст = "ВЫБРАТЬ
	                                |	ПоступлениеНаСчетДополнительныеРеквизиты.Ссылка
	                                |ИЗ
	                                |	Документ.ПоступлениеНаСчет.ДополнительныеРеквизиты КАК ПоступлениеНаСчетДополнительныеРеквизиты
	                                |ГДЕ
	                                |	ПоступлениеНаСчетДополнительныеРеквизиты.Значение = &ТекПараметр
	                                |	И ПоступлениеНаСчетДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	ЗапросПоступлениеНаСчет.УстановитьПараметр("ТекПараметр", ЗначениеПараметра);
	ЗапросПоступлениеНаСчет.УстановитьПараметр("ДопПараметр", ДопПараметрПоступлениеНаСчет);
	РезультатЗапросаПоступлениеНаСчет = ЗапросПоступлениеНаСчет.Выполнить();
	ВыборкаПоступлениеНаСчет = РезультатЗапросаПоступлениеНаСчет.Выбрать();
	Пока ВыборкаПоступлениеНаСчет.Следующий() Цикл
		
		ТекОбъект = ВыборкаПоступлениеНаСчет.Ссылка.ПолучитьОбъект();
		
		ТекОбъект.УстановитьПометкуУдаления(ИСТИНА);
		
	КонецЦикла;
	
	// Удаляем приходные накладные как возвраты
	СтруктураДополнительныхРеквизитовПриходнаяНакладная = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ПриходнаяНакладная);
	ДопПараметрПриходнаяНакладная = СтруктураДополнительныхРеквизитовПриходнаяНакладная.BaseRef;
	
	ЗапросПриходнаяНакладная = Новый Запрос;
	ЗапросПриходнаяНакладная.Текст = "ВЫБРАТЬ
	                                |	ПриходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	                                |ИЗ
	                                |	Документ.ПриходнаяНакладная.ДополнительныеРеквизиты КАК ПриходнаяНакладнаяДополнительныеРеквизиты
	                                |ГДЕ
	                                |	ПриходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	                                |	И ПриходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	ЗапросПриходнаяНакладная.УстановитьПараметр("ТекПараметр", ЗначениеПараметра);
	ЗапросПриходнаяНакладная.УстановитьПараметр("ДопПараметр", ДопПараметрПриходнаяНакладная);
	РезультатЗапросаПриходнаяНакладная = ЗапросПриходнаяНакладная.Выполнить();
	ВыборкаПриходнаяНакладная = РезультатЗапросаПриходнаяНакладная.Выбрать();
	Пока ВыборкаПриходнаяНакладная.Следующий() Цикл
		
		ТекОбъект = ВыборкаПриходнаяНакладная.Ссылка.ПолучитьОбъект();
		
		ТекОбъект.УстановитьПометкуУдаления(ИСТИНА);
		
	КонецЦикла;
	
	СтруктураДополнительныхРеквизитов = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_РасходнаяНакладная);
	ДопПараметр = СтруктураДополнительныхРеквизитов.DocRef;
		
	СтрокаТекстаЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	                      |	РасходнаяНакладнаяДополнительныеРеквизиты.Ссылка
	                      |ИЗ
	                      |	Документ.РасходнаяНакладная.ДополнительныеРеквизиты КАК РасходнаяНакладнаяДополнительныеРеквизиты
	                      |ГДЕ
	                      |	РасходнаяНакладнаяДополнительныеРеквизиты.Значение = &ТекПараметр
	                      |	И РасходнаяНакладнаяДополнительныеРеквизиты.Свойство = &ДопПараметр";
	
	СтрокаОтветаДляУдачногоРезультата = "Doc sale deleted successfully";
	СтрокаОтветаОбъектНеНайден = "Doc sale not found";
	
	РЕЗ = ПометитьНаУдалениеОбъектПоОдномуПараметру(СтруктураДляВозврата,СтрокаТекстаЗапроса,ЗначениеПараметра,СтрокаОтветаДляУдачногоРезультата,СтрокаОтветаОбъектНеНайден,ДопПараметр);
	
	Возврат РЕЗ;
КонецФункции
