Функция ПослатьЗапросНаТерминал_Rest(ПараметрыКоманды, Параметры)
	
	Результат = Новый Структура;
	
	//executeposcmd
	АдресФункции = "/" + СокрЛП(Параметры.ApiVersion) + ПараметрыКоманды.ИмяФункции ; 
	
	ЗаписьЛога = Новый Структура;
	ЗаписьЛога.Вставить("StartDate", ТекущаяДата());
	ЗаписьЛога.Вставить("Method", ПараметрыКоманды.Метод);
	ЗаписьЛога.Вставить("URL",Параметры.АдресСервера + АдресФункции);
	ЗаписьЛога.Вставить("function", АдресФункции);
	ЗаписьЛога.Вставить("BodyRequest","");
	ЗаписьЛога.Вставить("BodyResponce","");
	ЗаписьЛога.Вставить("Code","");
	
	
	ПолучаемТокенДоступа = Ложь;
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("Выполнен", Ложь);
	СтруктураОтвета.Вставить("Ошибка", Ложь);
	СтруктураОтвета.Вставить("КодСостояния", 0);
	СтруктураОтвета.Вставить("ТелоОтвета", Неопределено);
	СтруктураОтвета.Вставить("ТелоОтветаДанные", Неопределено);
	
	
	ЗащищенноеСоединение = Неопределено;
	Если Параметры.ЗащищенноеСоединение ТОгда
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
	КонецЕсли;	

	Заголовки = Новый Соответствие;
	
	Если не ЗначениеЗаполнено(ПараметрыКоманды.ТелоСообщения) и 
		ПараметрыКоманды.ИмяФункции = "/openpos" 
		Тогда
		ТелоСообщения = Новый Структура;
		ТелоСообщения.Вставить("licenseToken", Параметры.licenseToken);
		ТелоСообщения.Вставить("alias", Параметры.TerminalAlias);
		ТелоСообщения.Вставить("username","");
		ТелоСообщения.Вставить("password","");
		ПараметрыКоманды.ТелоСообщения = ТелоСообщения;
		ПолучаемТокенДоступа = Истина;
	КонецЕсли;  
	
	Если Параметры.Свойство("accessToken") И ЗначениеЗаполнено(Параметры.accessToken) 
		//И (ПараметрыКоманды.ИмяФункции = "/getsoftwareversions" или ПараметрыКоманды.ИмяФункции = "/closepos")
		Тогда
		Заголовки.Вставить("Authorization","Bearer " + Параметры.accessToken);		
	КонецЕсли;	
	
	HTTPСоединение = Новый HTTPСоединение(Параметры.АдресСервера, , , , , ПараметрыКоманды.Таймаут, ЗащищенноеСоединение);
		
	HTTPЗапрос = новый HTTPЗапрос(АдресФункции, Заголовки); 
	
	Если ЗначениеЗаполнено(ПараметрыКоманды.ТелоСообщения) Тогда
		Если ТипЗнч(ПараметрыКоманды.ТелоСообщения) = Тип("Строка") Тогда
			HTTPЗапрос.УстановитьТелоИзСтроки(ПараметрыКоманды.ТелоСообщения); 
			ЗаписьЛога.BodyRequest = ПараметрыКоманды.ТелоСообщения;
		Иначе
			BodyRequest = ИзДанных1с_в_JSON(ПараметрыКоманды.ТелоСообщения);
			HTTPЗапрос.УстановитьТелоИзСтроки(BodyRequest);
			ЗаписьЛога.BodyRequest = BodyRequest;			
		КонецЕсли;	
		Заголовки.Вставить("Content-Type","application/json");		
	КонецЕсли;	
	
	Попытка
		HTTPОтвет = HTTPСоединение.ВызватьHTTPМетод(ПараметрыКоманды.Метод , HTTPЗапрос);	
		
		СтруктураОтвета.Вставить("Выполнен", Истина);
	    СтруктураОтвета.Вставить("КодСостояния", HTTPОтвет.КодСостояния);
	    СтруктураОтвета.Вставить("Заголовки", HTTPОтвет.Заголовки);
		
		ЗаписьЛога.Code = HTTPОтвет.КодСостояния;
		
	Исключение
		СтруктураОтвета.Вставить("Ошибка", Истина);
		СтруктураОтвета.Вставить("ТекстОшибки", ОписаниеОшибки());
	Конецпопытки;
	
	
	Если СтруктураОтвета.КодСостояния > 100 Тогда	
		СтруктураОтвета.ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		Если ЗначениеЗаполнено(СтруктураОтвета.ТелоОтвета) Тогда  
			
			ЗаписьЛога.BodyResponce = СтруктураОтвета.ТелоОтвета;
			
			Попытка	
				СтруктураОтвета.ТелоОтветаДанные = ИзJSON_в_Данные1с(СтруктураОтвета.ТелоОтвета);

				Если ТипЗнч(СтруктураОтвета.ТелоОтвета)=Тип("Структура") Тогда
					ЗаполнитьЗначенияСвойств(Результат, СтруктураОтвета.ТелоОтвета);
				КонецЕсли;	
				
				BodyResponce = ИзДанных1с_в_JSON(СтруктураОтвета.ТелоОтветаДанные);
				ЗаписьЛога.BodyResponce = BodyResponce;
			Исключение
				
			КонецПопытки;	
		КонецЕсли;
		
		Если ТипЗнч(СтруктураОтвета.ТелоОтветаДанные)=Тип("Структура") Тогда
			
			resultCode = "";
			Если СтруктураОтвета.ТелоОтветаДанные.Свойство("resultCode", resultCode) Тогда
				Если resultCode<>"OK" Тогда
					//Сообщить("ERR:" + СтруктураОтвета.ТелоОтветаДанные.resultCode + " : " + СтруктураОтвета.ТелоОтветаДанные.resultMessage + "; time " + СтруктураОтвета.ТелоОтветаДанные.resultTime + " " + АдресФункции);
				КонецЕсли;	
			КонецЕсли;	
			
			Если ПолучаемТокенДоступа Тогда
				ТокенСессии = "";
				РезультатПодключения = СтруктураОтвета.ТелоОтветаДанные.Свойство("accessToken", ТокенСессии);
				Если ЗначениеЗаполнено(ТокенСессии) ТОгда	
					Параметры.Вставить("accessToken", ТокенСессии);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли
	КонецЕсли;
	
	Результат.Вставить("ОТВЕТ", СтруктураОтвета);
	
	Логировать = Ложь;
	Если Параметры.Свойство("Логировать") и  Параметры.Логировать = Истина ТОгда
		
		ЗаписьЛога.Вставить("EndDate", ТекущаяДата());
		
		ТекстСообщения = 
		"=========================================================
		|" + ЗаписьЛога.StartDate + " - " + ЗаписьЛога.EndDate + " " + ЗаписьЛога.URL   + "
		| REQUEST: " + ЗаписьЛога.method + " " + ЗаписьЛога.URL  + "
		| " + ЗаписьЛога.function + "
		| BODY: 
		|"  + ЗаписьЛога.BodyRequest + " 
		| RESPONCE: " + ЗаписьЛога.Code + " 
		|" + ЗаписьЛога.BodyResponce + "
		|"; 
		
		ИмяФайла = "" + Параметры.TerminalAlias + "_" + Формат(ТекущаяДата(),"ДФ=yyyyMMdd_hh")+ ".log";
		ПолныйПуть = Параметры.ПутьЛогирования + "\" + ИмяФайла;
		Попытка
			ЗаписьТекста = Новый ТекстовыйДокумент;
			ФС = Новый Файл(ПолныйПуть);
			Если ФС.Существует() Тогда
				ЗаписьТекста.Прочитать(ПолныйПуть);
			КонецЕсли;	
			ЗаписьТекста.ДобавитьСтроку(ТекстСообщения);
			ЗаписьТекста.Записать(ПолныйПуть);
		Исключение       
			Сообщить("Ошибка логирования: " + ОписаниеОшибки());
		КонецПопытки;
		
		
	КонецЕсли;
	
	Возврат Результат;

	
КонецФункции

Функция КомандаТерминалу_RestX(commandName, params, Параметры)  
//4.5 Метод exceuteposcmd 
//{ 
//"header": 
//	{ 
//	"command": "string" #Название команды 
//	}, 
//"params": {  
//	# Параметры команды 
//	} 
//} 

	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("header", Новый Структура("command",commandName));
	Если ТипЗнч(params) = Тип("Структура") и params.Количество()>0 Тогда
    	СтруктураПараметров.Вставить("params", params);
	КонецЕсли;	
	
	ПараметрыКоманды = ПараметрыКомандыREST();
	ПараметрыКоманды.Метод = "POST"; 
	
	//ПараметрыКоманды.ИмяФункции = "/excecuteposcmd"; //executeposcmd  //exceuteposcmd
    //ПараметрыКоманды.ИмяФункции = "/exceuteposcmd"; //executeposcmd  //exceuteposcmd
	ПараметрыКоманды.ИмяФункции = "/executeposcmd"; //правильне написание
	
    ПараметрыКоманды.ТелоСообщения = ИзДанных1с_в_JSON(СтруктураПараметров);
	
	СтруктураОтвета = ПослатьЗапросНаТерминал_Rest(ПараметрыКоманды, Параметры);
	
	СтруктураОтвета.Вставить("TypeResult", СтруктураОтвета_TypeResult());
	Если СтруктураОтвета.ОТВЕТ.Выполнен Тогда
		ЗаполнитьЗначенияСвойств(СтруктураОтвета.TypeResult, СтруктураОтвета.ОТВЕТ.ТелоОтветаДанные); 
		Если Параметры.Отладка и СтруктураОтвета.TypeResult.ResultCode<>"OK" Тогда
			ПоказатьОповещениеПользователя(commandName,,СтруктураОтвета.TypeResult.ResultMessage,БиблиотекаКартинок.ДиалогСтоп,СтатусОповещенияПользователя.Информация);
		КонецЕсли;
	КонецЕсли;	
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция ПолученТокен(Параметры) Экспорт
	
	Результат = Ложь; 
	Если Параметры.Свойство("accessToken") ТОгда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	


Функция ИзJSON_в_Данные1с(СтрокаJSON) Экспорт
	
	Json = Новый ЧтениеJSON;
	Json.УстановитьСтроку(СтрокаJSON);
		
	Рез = ПрочитатьJSON(Json);
		
	Возврат Рез;
		
КонецФункции	

Функция ИзДанных1с_в_JSON(Данные, ИспользоватьФорматДатыJSON = Неопределено) Экспорт
	
	Json = Новый ЗаписьJSON;
	Json.УстановитьСтроку();
	
	Если ИспользоватьФорматДатыJSON <> Неопределено Тогда
		тНастройкиСериализации = Новый НастройкиСериализацииJSON;
		тНастройкиСериализации.ФорматСериализацииДаты = ИспользоватьФорматДатыJSON;
		
		ЗаписатьJSON(Json, Данные, тНастройкиСериализации); 
	Иначе	
		ЗаписатьJSON(Json, Данные);
	КонецЕсли;
	
	Рез = Json.Закрыть();
	
	Возврат Рез;

КонецФункции

Функция ПолучитьПроизвольныйНомерДокументаСтрокой() Экспорт

	Генератор = Новый ГенераторСлучайныхЧисел();
	НомерДокумента = Генератор.СлучайноеЧисло(100000,429496);
    НомерДокументаСтрокой = Формат(НомерДокумента,"ЧГ=");
  	
    Возврат НомерДокументаСтрокой;
	
КонецФункции

Функция МассивВСтроку(МойМассив) Экспорт
	Результат = "";
	Для каждого СтрокаМассива из МойМассив Цикл
		Результат = Результат + СтрокаМассива + "; ";
	КонецЦикла;
	
	Возврат Результат;
	
