//Команда инициирует на POS процедуру возврата средств на счета карты.     
//4.5.8 CREDIT                (REFUND)
Функция КомандаТерминалу_CREDIT(ПараметрыДокумента, Параметры, ПараметрыПодключения) 
	
	ИмяКоменды = "CREDIT";                       
	

	ПараметрыКоманды = Новый Структура; 
	
	//Обязательные параметры
	ПараметрыКоманды.Вставить("amount", Цел(ПараметрыДокумента.Сумма * 100)); 	//сумма в центах
