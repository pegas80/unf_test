	//Обязательные параметры
	ПараметрыКоманды.Вставить("notes", новый Массив);  //Список нот для воспроизведения
	//"notes":[  
	//{"tone": "G5", 
	//"duration": 50} 
	//{"tone": "None", 
	//"duration": 100 }
	//{"tone": "D6", 
	//"duration": 100} 
	//} 
	
	
	//Не обязательные параметры                    
	
	
