//Команда инициирует запрос на POS для увеличения суммы ранее подтвержденной прeавторизации.  
//4.5.5 INCREMENT 
Функция КомандаТерминалу_INCREMENT(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры ) Экспорт 
	
	ИмяКоменды = "INCREMENT";                       

	ПараметрыКоманды = Новый Структура; 
	//Обязательные
	ПараметрыКоманды.Вставить("amount", Цел(ВходныеПараметры.Сумма * 100)); 	//сумма в центах
	ПараметрыКоманды.Вставить("operationId", Параметры.operationId); //Идентификатор операции, полученный в ответе команды PREAUTHORIZE. 
