Функция КомандаТерминалу_WRITECARD(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры ) Экспорт 
	
	ИмяКоменды = "WRITECARD";                       

	ПараметрыКоманды = Новый Структура; 
	
	//Обязательные параметры
	ПараметрыКоманды.Вставить("UID", "");  //Идентификатор плательщика/документа.
	ПараметрыКоманды.Вставить("dataBlocks", "");   //Номер кассового чека
	
	//Не обязательные параметры                    
	ПараметрыКоманды.Вставить("silent", Параметры.silent);   //звук операции есть/нет
	
	ЗаполнитьЗначенияСвойств(ПараметрыКоманды, ВходныеПараметры.ПараметрыКоманды);
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции

//Команда используется для информирования через устройство POS держателя карты, о том, что данная карта не обслуживается. 
//Команда инициирует отображение информационного сообщения для держателя карты, в котором указывается причина, из-за 
//которой данная карта не обслуживается.          
//Команда может быть применена в случае, когда ECR получает событие ONCARD и свойствах  не установлен флаг разрешения авторизации. 
//4.5.27 REMOVECARD          
Функция КомандаТерминалу_REMOVECARD(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры ) Экспорт 
	
	ИмяКоменды = "REMOVECARD";                       

	ПараметрыКоманды = Новый Структура; 
	
	//Обязательные параметры
	ПараметрыКоманды.Вставить("text", "Данная карта не обслуживается");  //Сообщение
	
	//Не обязательные параметры                    
	
	
	ЗаполнитьЗначенияСвойств(ПараметрыКоманды, ВходныеПараметры.ПараметрыКоманды);
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции

//Команда указывает POS-терминалу воспроизвести звуковую последовательность с использованием встроенного динамика .  
