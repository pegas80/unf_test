//Команда возвращает состояние POS.  
//4.5.29 GETPOSSTATUS           
Функция КомандаТерминалу_GETPOSSTATUS(Параметры) Экспорт 
	
	ИмяКоменды = "GETPOSSTATUS";                       

	ПараметрыКоманды = Новый Структура; 
	
	//Обязательные параметры
	СтруктураОткрытия = КомандаТерминалу_OPENPOS(Параметры);
	
	//Не обязательные параметры                    
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции

//Каждая транзакция, начатая с ECR, требует подтверждения через вызов данного метода. При его выполнении кассовый аппарат 
//может запустить создание дополнительных чеков. Это приведет к генерации события ONPRINT. Когда ECR  подтверждает 
//транзакцию, она должна вызывать отправку команды CLOSEDOC до получения ответа от POS терминала. Если передать номер 
//документа (documentNr) без списка операций, то все связанные операции с этим документом будут отменены, если они ранее 
//не были подтверждены.
//
//Примечание: 
//Данный метод должен быть выполнен и для неподтвержденных транзакций (результат неуспешной авторизации). 
//
//Примечание: 
//Для отмены транзакции, связанной с документом, который уже был закрыт, следует использовать VOID или REFUND. 
//
//Примечание: 
//Операции под одним и тем же номером документа, не переданные команде closedoc, будут отменены.. 
//
//Примечание: 
//Очень важно, что вызовы CLOSEDOC будут повторяться ECR до получения положительного результата, чтобы 
//избежать ситуации, когда POS получил CLOSEDOC и считает документ закрытым, а операцию(и) подтвержденной, но из-за 
//непредвиденных технических проблем подтверждение не было получено ECR.. 
//4.5.30 CLOSEDOC          
Функция КомандаТерминалу_CLOSEDOC(ПараметрыКоманды, Параметры) Экспорт 
	
	ИмяКоменды = "CLOSEDOC";                       

	//ПараметрыКоманды = Новый Структура; 
	
	//Обязательные параметры
	ПараметрыКоманды.Вставить("documentNr", ПараметрыКоманды.documentNr);  //Register receipt number 	
	
	//Не обязательные параметры                    
	ПараметрыКоманды.Вставить("operations", ПараметрыКоманды.operations);  //Идентификатор транзакции, полученный в ответе на команду AUTHORIZE.  	
	//ПараметрыКоманды.Вставить("eProducts", новый Массив);  //E идентификатор транзакции продукта, полученный в ответе на команду AUTHORIZE.  	
	//ПараметрыКоманды.Вставить("fiscalOperations", новый Массив);  //Фискальная операция, которая должна быть подтверждена/завершена. .  	
	
	//Комментарий к fiscalOperations:
	//Если фискальная система позволяет сторнировать фискальные операции, то успешные фискальные операции, не 
	//включенные в событие DOCCLOSED, будут автоматически сторнированы. 
	//Если фискальная система не разрешает сторнировать фискальные операции, то включение или невключение фискальной 
	//операции в событие DOCCLOSED не будет иметь никакого эффекта. 
	//В любом случае, CLOSEDOC должен быть  тправлен для любого уникального документа, созданного операцией 
	//FISCALIZE, независимо от ответа ONFISCALIZERESULT. 
	
	
	//ЗаполнитьЗначенияСвойств(ПараметрыКоманды, ВходныеПараметры.ПараметрыКоманды);
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции


//Каждая операция Е-Продукта инициированная из ECR должна подтверждаться вызовом данного метода. При вызове данного 
//метода POS может инициировать создание дополнительных квитанций, для получения которых будет сгенерировано событие ONPRINT.
//
//Примечание:
//  данный метод должен выполняться и для не подтверждённых транзакций (неуспешный результат авторизации) 
//4.5.31 CLOSEEPRODUCT          
Функция КомандаТерминалу_CLOSEEPRODUCT(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры ) Экспорт 
	
	ИмяКоменды = "CLOSEEPRODUCT";                       

	ПараметрыКоманды = Новый Структура; 
	
	//Обязательные параметры
	ПараметрыКоманды.Вставить("operations", новый Массив);  //Идентификатор операции, полученный в ответе команды AUTHORIZE.   	
	
	//Не обязательные параметры                    
	
	
	ЗаполнитьЗначенияСвойств(ПараметрыКоманды, ВходныеПараметры.ПараметрыКоманды);
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция eventType()
	Возврат Новый Структура("eventName,properties", NULL, NULL)
КонецФункции	

//Метод проверяет очередь доступных событий, инициированныx POS терминалом, если в очереди доступны ожидающие 
//события, метод в качестве результата вернет название события и свойства необходимые для обработки события.  
//4.6.1 getEvent          
Функция ПолучитьСобытиеОтТерминала_RestX(Параметры) Экспорт 
	
	event = eventType();
	
	ПараметрыКоманды = ПараметрыКомандыREST();
	ПараметрыКоманды.Метод = "GET";
	ПараметрыКоманды.ИмяФункции = "/getEvent";
	
	СтруктураОтвета = ПослатьЗапросНаТерминал_Rest(ПараметрыКоманды, Параметры);
	
	Если СтруктураОтвета.ОТВЕТ.Выполнен 
		и ТипЗнч(СтруктураОтвета.ОТВЕТ.ТелоОтветаДанные) = Тип("Структура") 
		Тогда
			event = СтруктураОтвета.ОТВЕТ.ТелоОтветаДанные;
			СтруктураОтвета.Вставить("eventType", event)	
	ИначеЕсли ТипЗнч(СтруктураОтвета) = тип("Структура") и не СтруктураОтвета.Свойство("eventType")	Тогда
		СтруктураОтвета.Вставить("eventType", event)	
	КонецЕсли;	
	
	//ПоказатьОповещениеПользователя(,,,,,);
	Если event = Неопределено Тогда 
		//связь не работает совсем
		
	ИначеЕсли event.eventName = NULL или event.eventName = Неопределено ТОгда 
		                          
		//Список событий пуст
	
	ИначеЕсли event.eventName = "ONPROMPT" ТОгда //4.6.2 Событие ONPROMPT
		//При получении данного сообщения программное обеспечение ECR должно отобразить сообщение с возможностью ввода 
		//информации кассиром. 
		//Запросить данные у кассира и отправить в POS	
		//Запомнить введенные данные
		//КомандаТерминалу_RestX_SETPROMPTINPUT(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры);
		
		inputValue = "";
		Если ВвестиСтроку(inputValue, "" + Параметры.TerminalAlias + ":" + event.properties.text, ,Ложь) Тогда
			РезультатОтправки = КомандаТерминалу_SETPROMPTINPUT(inputValue, Параметры);	
		КонецЕсли;
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONSELECT" ТОгда //4.6.3 Событие ONSELECT 
		//При получении данного события программное обеспечение ECR  должно отобразить полученное текстовое сообщение на 
		//экране ECR с возможностью выбора кассиром переданных опций. 
		//Запросить данные у кассира и отправить в POS	
		//Запомнить введенные данные
		//КомандаТерминалу_RestX_SETSELECTEDVALUE(ОбъектДрайвера, ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры )
		
		СписокВыбора = Новый СписокЗначений;
		Для каждого СтрокаЗначений из event.properties.options Цикл
			СписокВыбора.Добавить(СтрокаЗначений);	
		КонецЦикла;	
		ВыбранныйЭлемент = СписокВыбора.ВыбратьЭлемент("" + Параметры.TerminalAlias + ":" +event.properties.displayText);
		Если ВыбранныйЭлемент<>Неопределено Тогда
			РезультатОтправки = КомандаТерминалу_SETSELECTEDVALUE(ВыбранныйЭлемент.Значение, Параметры);	
		КонецЕсли;	
		
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONMSGBOX" ТОгда //4.6.4 Событие ONMSGBOX
		//При получении данного события программное обеспечение ECR должно отобразить полученное текстовое сообщение   в 
		//экране ECR в отдельном окне с возможностью выбора переданных указаний кассирy. 
		Сообщить("Возникло событие " + event.eventName + " - ");
		
		ВариантКнопок = event.properties.boxButtons; 
		
		КнопкиДиалога = РежимДиалогаВопрос.ОК;
		Если ВРЕГ(ВариантКнопок) = ВРЕГ("Ok") Тогда
			КнопкиДиалога = РежимДиалогаВопрос.ОК;
		ИначеЕсли ВРЕГ(ВариантКнопок) = ВРЕГ("OkCancel") Тогда
			КнопкиДиалога = РежимДиалогаВопрос.ОКОтмена;
		ИначеЕсли ВРЕГ(ВариантКнопок) = ВРЕГ("YesNo") Тогда
			КнопкиДиалога = РежимДиалогаВопрос.ДаНет;
		ИначеЕсли ВРЕГ(ВариантКнопок) = ВРЕГ("YesNoCancel") Тогда
			КнопкиДиалога = РежимДиалогаВопрос.ДаНетОтмена;
		КонецЕсли;	
			
		ОтветНаВопрос = Вопрос(event.properties.displayText, КнопкиДиалога,,,"" + Параметры.TerminalAlias + ":reasonType :" + event.properties.reasonType);
		
		ТекстОтвета = "Ok";
		Если ОтветНаВопрос = КодВозвратаДиалога.ОК Тогда
			ТекстОтвета = "Ok";
		ИначеЕсли ОтветНаВопрос = КодВозвратаДиалога.Отмена Тогда
			ТекстОтвета = "Cancel";
		ИначеЕсли ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
			ТекстОтвета = "Yes";
		ИначеЕсли ОтветНаВопрос = КодВозвратаДиалога.Нет Тогда
			ТекстОтвета = "No";
		КонецЕсли;
		
		РезультатОтправки = КомандаТерминалу_SETMSGBOXKEY(ТекстОтвета, Параметры);
		
	ИначеЕсли event.eventName = "ONDISPLAYPROMPTRESULT" ТОгда //4.6.5 Событие ONDISPLAYPROMPTRESULT
		//Событие информирует ECR о том, что на ранее отправленный запрос DISPLAYPROMPT были введены данные. 
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONDISPLAYMSGBOXRESULT" ТОгда //4.6.6 Событие ONDISPLAYMSGBOXRESULT 
		//Событие информирует ECR о том, какая кнопка была нажата на терминале в ответ на ранее отправленный запрос DISPLAYMSGBOX.  
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONDISPLAYSELECTRESULT" ТОгда //4.6.7 Событие ONDISPLAYSELECTRESULT 
		//Событие информирует ECR о том, какая опция была выбрана на терминале в ответ на ранее отправленный запрос DISPLAYSELECT.   
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONTRNSTATUS" ТОгда //4.6.8 Событие ONTRNSTATUS 
		//Событие информирует ECR o изменении статуса выполняемой транзакции.    
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONFISCALIZERESULT" ТОгда //4.6.9 Событие ONFISCALIZERESULT 
		//Событие информирует ECR о результате операции фискализации.     
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONCARD" ТОгда //4.6.10 Событие ONCARD 
		//Событие информирует ECR, о выполнении POS считывания информации о предоставленной карте.     
		//В случае, когда не установлен флаг AllowAuthorize означает, что карта является дисконтной картой, либо картой лояльности. 
		//ообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONCARDREMOVE" ТОгда //4.6.11 Событие ONCARDREMOVE 
		//Событие предназначено для информирования ECR о том, что данные карты больше не доступны.     
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONWRITECARDRESULT" ТОгда //4.6.12 Событие ONWRITECARDRESULT  
		//Событие информирует ECR об успешном выполнении команды WRITECARD.      
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONDISPLAYTEXT" ТОгда //4.6.13 Событие ONDISPLAYTEXT  
		//При получении этого события программа ECR должна вывести полученное текстовое сообщение на экран приложения ECR.      
		//Сообщить("Возникло событие " + event.eventName + " - ");
	
	ИначеЕсли event.eventName = "ONPRINT" ТОгда //4.6.14 Событие ONPRINT  
		//Событие информирует ECR, что POS  подготовил данные чека для печати. Если принтер ECR во время получения чека не 
		//доступен либо занят, полученную информацию чека надо сохранить в приложении ECR.       
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли event.eventName = "ONKBD" ТОгда //4.6.15 Событие ONKBD   
		//Событие информирует ECR,  о том что произошло нажатие клавиши на клавиатуре POS. Это событие генерируется только в том 
		//случае, если устройство находится в состоянии ожидания. Под состоянием ожидания подразумевается, что  POS не выполняет 
		//активной авторизации и не запрашивает у пользователя какие-либо данные для ввода или выбора.       
		//Сообщить("Возникло событие " + event.eventName + " - ");
	
	ИначеЕсли event.eventName = "ONDISPLAYTEXT" ТОгда //4.6.16 Событие ONEPRODUCTRESULT  
		//Событие информирует ECR  о результате выполнения команды EPRODUCTQUERY.  Для завершения операции оплаты Е-Продукта 
		//необходимо выполнить команду CLOSEDOC передав в качестве параметра operationId. В зависимости от конфигурации Е
		//Продукта POS может инициировать печать дополнительного чека сгенерировав событие ONPRINT.       
		//Сообщить("Возникло событие " + event.eventName + " - ");
		
	ИначеЕсли ЗначениеЗаполнено(event.eventName) ТОгда
		
		//Сообщить("Возникло не известное событие " + event.eventName + " - ");
		
	КонецЕсли;
	
	Если Параметры.Отладка Тогда
		Сообщить("" + Параметры.TerminalAlias + ": Возникло событие " + event.eventName + " - ");
	КонецЕсли;
	
	Возврат СтруктураОтвета;
	
КонецФункции
	

#КонецОбласти //ПрограммныйИнтерфейс  

#Область ВспомогательныеФункции

Функция ПараметрыКомандыREST() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Метод","POST");
	Результат.Вставить("ИмяФункции","");
	Результат.Вставить("ТелоСообщения","");
	Результат.Вставить("Таймаут", 10);
	
	Возврат Результат;
КонецФункции

Функция СтруктураОтвета_TypeResult() 
