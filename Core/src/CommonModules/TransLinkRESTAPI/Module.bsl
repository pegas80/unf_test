//Команда инициирует запрос подтверждения на POS ранее выполненной операции прeавторизации.   
//4.5.6 COMPLETE 
//После завершения преавторизации командой Complete, повторный вызов команд Increment или Complete недопустим. 
//Для проверки состояния преавторизации можно использовать GetTrnStatus. В случае завершённой преавторизации в 
//атрибуте state будет значение Settled. Для аннулирования завершённой преавторизации нужно использовать метод 
//Void. Для отмены (аннулирования) незавершённой преавторизации нужно использовать Complete с нулевой суммой. 
Функция КомандаТерминалу_COMPLETE(ВходныеПараметры, Параметры, ПараметрыПодключения, ВыходныеПараметры ) Экспорт 
	
	ИмяКоменды = "COMPLETE";                       

	ПараметрыКоманды = Новый Структура; 
	//Обязательные
	ПараметрыКоманды.Вставить("amount", Цел(ВходныеПараметры.Сумма * 100)); 	//сумма в центах
	ПараметрыКоманды.Вставить("operationId", Параметры.operationId); //Идентификатор операции, полученный в ответе команды PREAUTHORIZE. 
	ПараметрыКоманды.Вставить("cryptogram", "2273827837287вавававав");  //Криптограмма транзакции
	ПараметрыКоманды.Вставить("noShow", Ложь);  //Указывает на то, оплата взымается с держателя карты за непредставленные услуги.
	
		
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции

