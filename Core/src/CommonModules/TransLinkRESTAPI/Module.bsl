//Открытие терминала и получение ключа авторизации
Функция КомандаТерминалу_OPENPOS(Параметры) Экспорт

	РезультатПодключения = Ложь;

	ПараметрыКоманды = ПараметрыКомандыREST();
	ПараметрыКоманды.Метод = "POST"; 
	ПараметрыКоманды.ИмяФункции = "/openpos";
	
	СтруктураОтвета = ПослатьЗапросНаТерминал_Rest(ПараметрыКоманды, Параметры);
	
	Если СтруктураОтвета.ОТВЕТ.Выполнен и Параметры.Свойство("accessToken") и ЗначениеЗаполнено(Параметры.accessToken) ТОгда
		РезультатПодключения = Истина;
	КонецЕсли;	
	
 	Возврат РезультатПодключения;
	
КонецФункции



//Команда выполняет разблокировку POS, для выполнения последующих операций. 
//Данная команда должна выполняться перед началом любой операцией расчёта, инициированной с ECR.  
//4.5.1 UNLOCKDEVICE 
Функция КомандаТерминалу_UNLOCKDEVICE(ДанныеДокумента, Параметры) Экспорт
	
	ИмяКоменды = "UNLOCKDEVICE";                       
	
	ПараметрыКоманды = Новый Структура; 
	
	//Обязательные
	ПараметрыКоманды.Вставить("posOperation", ДанныеДокумента.posOperation);  //AUTHORIZE, NOOPERATION , AUTHORIZE , PREAUTHORIZE , CREDIT , INQUIRY , CARDREAD , MANUALENTRY 
	ПараметрыКоманды.Вставить("amount", Цел(ДанныеДокумента.Сумма * 100)); 				//сумма в центах
	
	ПараметрыКоманды.Вставить("idleText", Параметры.idleText_UnlockDevice);
	
	ПараметрыКоманды.Вставить("language", Параметры.language);
	ПараметрыКоманды.Вставить("ecrVersion", ecrVersion(Параметры));
	
	//Не Обязательные
	ПараметрыКоманды.Вставить("currencyCode",Параметры.currencyCode); 
	Если ДанныеДокумента.Свойство("СуммаВозврата") Тогда	
		ПараметрыКоманды.Вставить("cashBackAmount", Цел(ДанныеДокумента.СуммаВозврата * 100)); //Сумма Cashback. 
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Параметры.operatorId) Тогда
		ПараметрыКоманды.Вставить("operatorId", Параметры.operatorId);
	КонецЕсли;	
	Если ЗначениеЗаполнено(Параметры.operatorName) Тогда
		ПараметрыКоманды.Вставить("operatorName", Параметры.operatorName);
	КонецЕсли;
	Если Параметры.cardTechs.Количество()>0 Тогда
		ПараметрыКоманды.Вставить("cardTechs", Параметры.cardTechs);
	КонецЕсли;	
	Если Параметры.enabledTranSourceMedias.Количество()>0 Тогда
		ПараметрыКоманды.Вставить("enabledTranSourceMedias", Параметры.enabledTranSourceMedias);
	КонецЕсли;
	
	ПараметрыКоманды.Вставить("silentCardRead", Параметры.silentCardRead);  //Звуковой сигнал
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции	

//Команда выполняет блокировку POS, с возможностью отображения на экране сообщения, переданного в параметре idleText. 
//4.5.2 LOCKDEVICE
Функция КомандаТерминалу_LOCKDEVICE(Параметры) Экспорт 
	
	ИмяКоменды = "LOCKDEVICE";                       
	
	ПараметрыКоманды = Новый Структура; 
