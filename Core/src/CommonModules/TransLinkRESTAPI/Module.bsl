	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;

КонецФункции

//Отправляем команду терминалу начать взаимодействовать с пользователем
//в зависимости от вида операции
функция КомандаТерминалуНачатьДействие(ДанныеДокумента, ВходныеПараметры, Параметры) Экспорт 
	
	Результат = Ложь;
	
	Если ДанныеДокумента.posOperation = TransLinkRESTAPI.posOperation_AUTHORIZE() Тогда         
		//Обычная продажа
		Результат = КомандаТерминалу_AUTHORIZE(ДанныеДокумента, ВходныеПараметры, Параметры);
	ИначеЕсли ДанныеДокумента.posOperation = TransLinkRESTAPI.posOperation_CREDIT() Тогда
		//Возврат денег на карту
		Результат = КомандаТерминалу_CREDIT(ДанныеДокумента, ВходныеПараметры, Параметры);		
		
	ИначеЕсли ДанныеДокумента.posOperation = TransLinkRESTAPI.posOperation_PREAUTHORIZE() Тогда
		//предавторизация
		Результат = КомандаТерминалу_PREAUTHORIZE(ДанныеДокумента, ВходныеПараметры, Параметры);		
		
	ИначеЕсли ДанныеДокумента.posOperation = TransLinkRESTAPI.posOperation_INQUIRY() Тогда
		//предавторизация
		Результат = КомандаТерминалу_INQUIRYBALANCE(ВходныеПараметры, Параметры);		
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции	

//Команда инициирует процедуру авторизации (оплата покупок) на POS. 
//4.5.3 AUTHORIZE
Функция КомандаТерминалу_AUTHORIZE(ДанныеДокумента, ВходныеПараметры, Параметры)
	
	ИмяКоменды = "AUTHORIZE";                       
	
	ПараметрыКоманды = Новый Структура; 
	//Обязательные
	ПараметрыКоманды.Вставить("amount", Цел(ДанныеДокумента.Сумма * 100)); 	//сумма в центах
	ПараметрыКоманды.Вставить("currencyCode", Параметры.currencyCode);
	ПараметрыКоманды.Вставить("documentNr", ДанныеДокумента.documentNr);  //Номер платежного документа (уникальный номер в течение банковского дня).
	
	//Не Обязательные
	//ПараметрыКоманды.Вставить("cashBackAmount", Цел(ВходныеПараметры.CashbackAmount * 100)); //Сумма Cashback. 
    //ПараметрыКоманды.Вставить("panL4Digit",); 
	//ПараметрыКоманды.Вставить("ecrData",);
	
	//Комментарий:
	//panL4Digit - 4 последние цифры PAN , которые введены  на устройстве ECR, оператором кассы. 
	//Данное требование может быть инициировано POS, при передаче события ONCARD. 
	
	//ecrData - Дополнительные данные, передаваемые в авторотационном сообщении для эквайера. До 1000 байт в формате UTF-8. 
	
	СтруктураОтвета = КомандаТерминалу_RestX(ИмяКоменды, ПараметрыКоманды, Параметры);
	
	Возврат СтруктураОтвета;
	
КонецФункции


