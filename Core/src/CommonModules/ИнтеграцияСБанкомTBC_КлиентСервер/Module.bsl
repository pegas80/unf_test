// Функция - Создает и возвращает структуру параметров соединения для интеграции с банком ТБС
// 
// Возвращаемое значение - Структура
// 	Поля структуры:
//      TBC_Login					 - Строка - логин пользователя
//      TBC_Password				 - Строка - пароль пользователя
//      TBC_ТестовыйРежим			 - Булево - работаем в тестовом режиме
//      TBC_Сертификат				 - СправочникСсылка.Файлы - ссылка на справочник с хранилищем двоичных данных сертификата
//      TBC_ПарольСертификата		 - Строка - пароль сертификата
//      TBC_РаботаЧерезСервер		 - Булево - предполагается, что соединение с сайтом TBC будет происходить с сервера 1С
//      TBC_ИспользоватьСертификат	 - Булево - ИСТИНА: соединение с банком с использованием сертификата подлинности; ЛОЖЬ - соединение с банком без сертификата подлинности
//      Nonce						 - Строка - Nonce
//      ДвоичныеДанныеСертификата	 - ДвоичныеДанные,АдресВоВременномХранилище - двоичные данные сертификата
//
Функция СтруктураПараметровСоединенияТБС() ЭКСПОРТ
	ПЕРЕМ РЕЗ;

	РЕЗ = ИнтеграцияСБанкомTBC_Сервер.СтруктураПараметровСоединенияТБС();
					
    Возврат РЕЗ;
КонецФункции // ()

// Функция - Получить параметры соединения с банком ТБС для пользователя
//
// Параметры:
//  ТекущийПользователь	 - СправочникСсылка.Пользователи - пользователь, для которого нужно получить настройки
// 
// Возвращаемое значение:
// 	Поля структуры:
//      TBC_Login					 - Строка - логин пользователя
//      TBC_Password				 - Строка - пароль пользователя
//      TBC_ТестовыйРежим			 - Булево - работаем в тестовом режиме
//      TBC_Сертификат				 - СправочникСсылка.Файлы - ссылка на справочник с хранилищем двоичных данных сертификата
//      TBC_ПарольСертификата		 - Строка - пароль сертификата
//      TBC_РаботаЧерезСервер		 - Булево - предполагается, что соединение с сайтом TBC будет происходить с сервера 1С
//      TBC_ИспользоватьСертификат	 - Булево - ИСТИНА: соединение с банком с использованием сертификата подлинности; ЛОЖЬ - соединение с банком без сертификата подлинности
//      Nonce						 - Строка - Nonce
//      ДвоичныеДанныеСертификата	 - ДвоичныеДанные,АдресВоВременномХранилище - двоичные данные сертификата
//
Функция ПолучитьПараметрыСоединенияТБС(ТекущийПользователь = НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ИнтеграцияСБанкомTBC_Сервер.ПолучитьПараметрыСоединенияТБС(ТекущийПользователь);
	
	Возврат РЕЗ;
КонецФункции // ()

Процедура ЗаполнитьСтруктуруОтветаРекурсиеей(ОбъектXDTO, СтруктураЗаполнения, КлючПредыдущейСтруктуры = "")
	
	Для Каждого Строк Из ОбъектXDTO.Свойства() Цикл 
		
		Если ТипЗнч(ОбъектXDTO[Строк.Имя]) = Тип("ОбъектXDTO") Тогда 
			СледующаяСтруктура = Новый Структура;
			СтруктураЗаполнения.Вставить(Строк.Имя, СледующаяСтруктура);
			ЗаполнитьСтруктуруОтветаРекурсиеей(ОбъектXDTO[Строк.Имя], СледующаяСтруктура, Строк.Имя);
		ИначеЕсли ТипЗнч(ОбъектXDTO[Строк.Имя]) = Тип("СписокXDTO") Тогда
			
			МассивСтрокСписка = Новый Массив;
						
			Для Каждого СтрокаСписка Из (ОбъектXDTO[Строк.Имя]) Цикл 
				
				СледующаяСтруктура = Новый Структура;
				СтруктураЗаполнения.Вставить(Строк.Имя, СледующаяСтруктура);
				ЗаполнитьСтруктуруОтветаРекурсиеей(СтрокаСписка, СледующаяСтруктура, Строк.Имя);
				МассивСтрокСписка.Добавить(СледующаяСтруктура)
					
			КонецЦикла;
			
			СтруктураЗаполнения.Вставить(Строк.Имя, МассивСтрокСписка)
			
		ИначеЕсли ТипЗнч(ОбъектXDTO[Строк.Имя]) = Тип("Строка") Тогда 
			СтруктураЗаполнения.Вставить(Строк.Имя, ОбъектXDTO[Строк.Имя]);
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

Функция ПрочитатьФайлОтвета(ПутьКФайлу)
	
	ЧтениеТекста = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
	
	СтрокаXML = ЧтениеТекста.Прочитать();
		
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(СтрокаXML);
	
	//РезультатРазборки = Новый Массив;
	
