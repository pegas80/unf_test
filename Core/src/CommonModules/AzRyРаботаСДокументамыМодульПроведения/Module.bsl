Процедура ОтразитьРасчетыСПокупателямиОтчетОРозничныхПродажах(ДополнительныеСвойства, Движения)

	Движения.РасчетыСПокупателями.Записывать = Истина;
	ДокументСсылка = ДополнительныеСвойства.ДляПроведения.Ссылка; 
	Для каждого ТекСтрока Из ДополнительныеСвойства.ДляПроведения.Ссылка.Запасы Цикл						
		Движение = Движения.РасчетыСПокупателями.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период      = ДокументСсылка.Дата;
		Движение.Организация = ДокументСсылка.Организация;
		Движение.ТипРасчетов = Перечисления.ТипыРасчетов.Долг;
		Движение.Контрагент  = ТекСтрока.AzRyКонтрагент;
		Движение.AzRyАналитикаКонтрагент  = ТекСтрока.AzRyАналитикаКонтрагент;
		Движение.Договор     = ТекСтрока.AzRyЗаказПокупателя.Договор;
		Движение.Документ    = ДокументСсылка;
		Движение.Заказ       = ТекСтрока.AzRyЗаказПокупателя;
		Движение.Сумма       = ТекСтрока.Сумма;
		Движение.СуммаВал    = ТекСтрока.Сумма;
		Движение.СодержаниеПроводки = "მყიდველის ვალდებულებების წარმოშობა (AzRy)";
		
		//Если ТекСтрока.AzRyФормаОплаты <> Перечисления.ТипыДенежныхСредств.Безналичные Тогда
			Движение = Движения.РасчетыСПокупателями.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.Период      = ДокументСсылка.Дата;
			Движение.Организация = ДокументСсылка.Организация;
			Движение.ТипРасчетов = Перечисления.ТипыРасчетов.Долг;
			Движение.Контрагент  = ТекСтрока.AzRyКонтрагент;
			Движение.AzRyАналитикаКонтрагент  = ТекСтрока.AzRyАналитикаКонтрагент;
			Движение.Договор     = ТекСтрока.AzRyЗаказПокупателя.Договор;
			Движение.Документ    = ДокументСсылка;
			Движение.Заказ       = ТекСтрока.AzRyЗаказПокупателя;
			Движение.Сумма       = ТекСтрока.Сумма;
			Движение.СуммаВал    = ТекСтрока.Сумма;
			Движение.СодержаниеПроводки = "მყიდველის ვალდებულებების წარმოშობა (AzRy)";
