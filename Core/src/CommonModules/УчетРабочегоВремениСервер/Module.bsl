Процедура СформироватьДокументТабельПоДаннымУчета() Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Параметры.Вставить("ПериодРегистрации", НачалоМесяца(ТекущаяДатаСеанса()));

	Запрос.Текст =
	"ВЫБРАТЬ
	|	УчетРабочегоВремениСотрудниковСрезПоследних.Организация КАК Организация,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.Сотрудник КАК Сотрудник,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.ГрафикРаботы КАК ГрафикРаботы,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.ТипУчета КАК ТипУчета,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.ВремяНачала КАК ВремяНачала,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.ВремяОкончания КАК ВремяОкончания,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.КоличествоЧасов КАК КоличествоЧасов,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.Возмещаемый КАК Возмещаемый,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.ПричинаНевыхода КАК ПричинаНевыхода
	|ПОМЕСТИТЬ ВТ_ДанныеУчета
	|ИЗ
	|	РегистрСведений.УчетРабочегоВремениСотрудников.СрезПоследних(, НАЧАЛОПЕРИОДА(ВремяНачала, МЕСЯЦ) = НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)) КАК УчетРабочегоВремениСотрудниковСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	//+++ Дмгг Возьмем данные из Регистра сведений
	//|ВЫБРАТЬ
	//|	ГрафикиРаботыПериоды.Ссылка КАК ГрафикРаботы,
	//|	СУММА(ВЫРАЗИТЬ(РАЗНОСТЬДАТ(ГрафикиРаботыПериоды.ВремяНачала, ГрафикиРаботыПериоды.ВремяОкончания, МИНУТА) / 60 КАК ЧИСЛО(5, 0))) КАК КоличествоЧасовПоГрафику,
	//|	ГрафикиРаботыПериоды.НомерДня КАК НомерДня
	//|ПОМЕСТИТЬ ВТ_РабочиеЧасыПоГрафику
	//|ИЗ
	//|	Справочник.ГрафикиРаботы.Периоды КАК ГрафикиРаботыПериоды
	//|ГДЕ
	//|	ГрафикиРаботыПериоды.Ссылка В
	//|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	//|				ВТ_ДанныеУчета.ГрафикРаботы КАК ГрафикРаботы
	//|			ИЗ
	//|				ВТ_ДанныеУчета КАК ВТ_ДанныеУчета)
	//|
	//|СГРУППИРОВАТЬ ПО
	//|	ГрафикиРаботыПериоды.Ссылка,
	//|	ГрафикиРаботыПериоды.НомерДня
	//|
	//|ИНДЕКСИРОВАТЬ ПО
	//|	ГрафикРаботы
	|ВЫБРАТЬ
	|	НАЧАЛОПЕРИОДА(ГрафикиРаботыПериоды.ВремяНачала, ДЕНЬ) ДеньМесяца,
	|	ГрафикиРаботыПериоды.ГрафикРаботы КАК ГрафикРаботы,
	|	СУММА(ВЫРАЗИТЬ(РАЗНОСТЬДАТ(ГрафикиРаботыПериоды.ВремяНачала, ГрафикиРаботыПериоды.ВремяОкончания, МИНУТА) / 60 КАК ЧИСЛО(5, 0))) КАК КоличествоЧасовПоГрафику,
	|	ДЕНЬНЕДЕЛИ(ГрафикиРаботыПериоды.ВремяНачала) КАК НомерДня
	|ПОМЕСТИТЬ ВТ_РабочиеЧасыПоГрафику
	|ИЗ
	|	РегистрСведений.ГрафикиРаботы КАК ГрафикиРаботыПериоды
	|ГДЕ
	|	ГрафикиРаботыПериоды.ГрафикРаботы В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ВТ_ДанныеУчета.ГрафикРаботы КАК ГрафикРаботы
	|			ИЗ
	|				ВТ_ДанныеУчета КАК ВТ_ДанныеУчета)
	|	И ГрафикиРаботыПериоды.ВремяНачала >= НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
	|	И ГрафикиРаботыПериоды.ВремяОкончания <= КОНЕЦПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
	|	
	|СГРУППИРОВАТЬ ПО
	|	НАЧАЛОПЕРИОДА(ГрафикиРаботыПериоды.ВремяНачала, ДЕНЬ),
	|	ГрафикиРаботыПериоды.ГрафикРаботы,
	|	ДЕНЬНЕДЕЛИ(ГрафикиРаботыПериоды.ВремяНачала)
	|	
	|ИНДЕКСИРОВАТЬ ПО
	|	ГрафикРаботы
	//--- Дмгг
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СотрудникиСрезПоследних.Организация КАК Организация,
	|	СотрудникиСрезПоследних.Сотрудник КАК Сотрудник,
	|	СотрудникиСрезПоследних.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	СотрудникиСрезПоследних.Должность КАК Должность,
	|	СотрудникиСрезПоследних.ГрафикРаботы КАК ГрафикРаботы
	|ПОМЕСТИТЬ ВТ_ДанныеСотрудников
	|ИЗ
	|	РегистрСведений.Сотрудники.СрезПоследних(
	|			,
	|			(Организация, Сотрудник) В
	|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|					ВТ_ДанныеУчета.Организация КАК Организация,
	|					ВТ_ДанныеУчета.Сотрудник КАК Сотрудник
	|				ИЗ
	|					ВТ_ДанныеУчета КАК ВТ_ДанныеУчета)) КАК СотрудникиСрезПоследних
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация,
	|	Сотрудник,
	|	СтруктурнаяЕдиница,
	|	ГрафикРаботы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДанныеУчета.Организация КАК Организация,
	|	ВТ_ДанныеУчета.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВТ_ДанныеУчета.Сотрудник КАК Сотрудник,
	|	ВТ_ДанныеУчета.ГрафикРаботы КАК ГрафикРаботы,
	|	ВТ_ДанныеУчета.ТипУчета КАК ТипУчета,
	|	ВТ_ДанныеУчета.ВремяНачала КАК ВремяНачала,
	|	ВТ_ДанныеУчета.ВремяОкончания КАК ВремяОкончания,
	|	ВТ_ДанныеУчета.КоличествоЧасов КАК КоличествоЧасов,
	|	ВТ_ДанныеУчета.Возмещаемый КАК Возмещаемый,
	|	ВТ_ДанныеУчета.ПричинаНевыхода КАК ПричинаНевыхода,
	|	ВТ_РабочиеЧасыПоГрафику.КоличествоЧасовПоГрафику КАК КоличествоЧасовПоГрафику,
	|	ДЕНЬ(ВТ_ДанныеУчета.ВремяНачала) КАК День,
	|	ВТ_ДанныеСотрудников.Должность КАК Должность,
	|	НАЧАЛОПЕРИОДА(ВТ_ДанныеУчета.ВремяНачала, МЕСЯЦ) КАК ПериодРегистрации
	|ИЗ
	|	ВТ_ДанныеУчета КАК ВТ_ДанныеУчета
	//|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РабочиеЧасыПоГрафику КАК ВТ_РабочиеЧасыПоГрафику
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РабочиеЧасыПоГрафику КАК ВТ_РабочиеЧасыПоГрафику
	|		ПО (ИСТИНА)
	|			И ВТ_ДанныеУчета.ГрафикРаботы = ВТ_РабочиеЧасыПоГрафику.ГрафикРаботы
	//|			И (ДЕНЬНЕДЕЛИ(ВТ_ДанныеУчета.ВремяНачала) = ВТ_РабочиеЧасыПоГрафику.НомерДня)
	|			И (НАЧАЛОПЕРИОДА(ВТ_ДанныеУчета.ВремяНачала, ДЕНЬ) = НАЧАЛОПЕРИОДА(ВТ_РабочиеЧасыПоГрафику.ДеньМесяца, ДЕНЬ))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДанныеСотрудников КАК ВТ_ДанныеСотрудников
	|		ПО (ИСТИНА)
	|			И ВТ_ДанныеУчета.Организация = ВТ_ДанныеСотрудников.Организация
	|			И ВТ_ДанныеУчета.СтруктурнаяЕдиница = ВТ_ДанныеСотрудников.СтруктурнаяЕдиница
	|			И ВТ_ДанныеУчета.Сотрудник = ВТ_ДанныеСотрудников.Сотрудник
	|			И ВТ_ДанныеУчета.ГрафикРаботы = ВТ_ДанныеСотрудников.ГрафикРаботы
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сотрудник,
	|	День
	|ИТОГИ
	|	МИНИМУМ(ВремяНачала)
	|ПО
	|	Организация,
	|	СтруктурнаяЕдиница,
	|	ПериодРегистрации,
	|	День
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Табель.Ссылка КАК Ссылка,
	|	Табель.Организация КАК Организация,
	|	Табель.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	Табель.ПериодРегистрации КАК ПериодРегистрации
	|ИЗ
	|	Документ.Табель КАК Табель
	|ГДЕ
	|	НЕ Табель.ПометкаУдаления
	|	И (Табель.Организация, Табель.СтруктурнаяЕдиница, Табель.ПериодРегистрации) В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ВТ_ДанныеУчета.Организация КАК Организация,
	|				ВТ_ДанныеУчета.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|				НАЧАЛОПЕРИОДА(ВТ_ДанныеУчета.ВремяНачала, МЕСЯЦ) КАК Поле1
	|			ИЗ
	|				ВТ_ДанныеУчета КАК ВТ_ДанныеУчета)";
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаОрганизация = РезультатЗапроса[РезультатЗапроса.ВГраница() - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ТаблицаДокументовТабель = РезультатЗапроса[РезультатЗапроса.ВГраница()].Выгрузить();
	ТаблицаДокументовТабель.Индексы.Добавить("Организация, СтруктурнаяЕдиница, ПериодРегистрации");
	СтруктураПоиска = Новый Структура("Организация, СтруктурнаяЕдиница, ПериодРегистрации"); 
	СтруктураПоискаСотрудник = Новый Структура("Сотрудник, Должность"); 
	
	Пока ВыборкаОрганизация.Следующий() Цикл
	
		ВыборкаСтруктурнаяЕдиница = ВыборкаОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСтруктурнаяЕдиница.Следующий() Цикл
		
			ВыборкаПериодРегистрации = ВыборкаСтруктурнаяЕдиница.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПериодРегистрации.Следующий() Цикл
			
				ЗаполнитьЗначенияСвойств(СтруктураПоиска, ВыборкаПериодРегистрации); 
				СтрокиТабель = ТаблицаДокументовТабель.НайтиСтроки(СтруктураПоиска);
				ТабельСуществует = Ложь;
				Если СтрокиТабель.Количество() Тогда
				
					ДокументТабель = СтрокиТабель[0].Ссылка.ПолучитьОбъект();
					ТабельСуществует = Истина;
				
				Иначе
				
					ДокументТабель = Документы.Табель.СоздатьДокумент();
					ЗаполнитьЗначенияСвойств(ДокументТабель, ВыборкаПериодРегистрации); 
					ДокументТабель.Дата = КонецМесяца(ВыборкаПериодРегистрации.ПериодРегистрации);
				
				КонецЕсли;
				
				//ДокументТабель.ОтработанноеВремяПоДням.Очистить();
				ДокументТабель.ОтработанноеВремяЗаПериод.Очистить();
				ДокументТабель.СпособВводаДанных = Перечисления.СпособыВводаДанныхОВремени.ПоДням;
				
				ВыборкаДень = ВыборкаПериодРегистрации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаДень.Следующий() Цикл
				
					Выборка = ВыборкаДень.Выбрать();
					ТекущийСотрудник = Неопределено;
					НомерВидаВремени = 0; 
					ОчиститьДанныеДня(ДокументТабель, ВыборкаДень.День);
					Пока Выборка.Следующий() Цикл
						
						Если ТекущийСотрудник <> Выборка.Сотрудник Тогда
							
							ЗаполнитьЗначенияСвойств(СтруктураПоискаСотрудник, Выборка);
							СтрокиСотрудник = ДокументТабель.ОтработанноеВремяПоДням.НайтиСтроки(СтруктураПоискаСотрудник);
							Если СтрокиСотрудник.Количество() Тогда
							
								СтрокаТабеля = СтрокиСотрудник[0];	
							
							Иначе
							
								СтрокаТабеля = ДокументТабель.ОтработанноеВремяПоДням.Добавить();
								ЗаполнитьЗначенияСвойств(СтрокаТабеля, Выборка);
							
							КонецЕсли; 
							НомерВидаВремени = 0;
							
						КонецЕсли;
						НомерВидаВремени = НомерВидаВремени + 1;
						СтруктураКолонок = ПолучитьИменаКолонокПоНомеруВидаВремени(НомерВидаВремени);
						ТекущийСотрудник = Выборка.Сотрудник;
						СтрокаТабеля[СтруктураКолонок.ВидВремени + Формат(Выборка.День, "ЧДЦ=0; ЧГ=0")] = ПолучитьВидРабочегоВремени(Выборка);
						СтрокаТабеля[СтруктураКолонок.Часы + Формат(Выборка.День, "ЧДЦ=0; ЧГ=0")] = Мин(Выборка.КоличествоЧасовПоГрафику, Выборка.КоличествоЧасов);
						Если Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.Работа
							И Выборка.КоличествоЧасов > Выборка.КоличествоЧасовПоГрафику
							//+++ Дмгг
							ИЛИ (Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.ПустаяСсылка()
									И Выборка.КоличествоЧасов <> 0)
							//--- Дмгг
							Тогда
							
							НомерВидаВремени = НомерВидаВремени + 1;
							СтруктураКолонок = ПолучитьИменаКолонокПоНомеруВидаВремени(НомерВидаВремени);
							СтрокаТабеля[СтруктураКолонок.ВидВремени + Формат(Выборка.День, "ЧДЦ=0; ЧГ=0")] = Справочники.ВидыРабочегоВремени.Сверхурочные;
							СтрокаТабеля[СтруктураКолонок.Часы + Формат(Выборка.День, "ЧДЦ=0; ЧГ=0")] = Выборка.КоличествоЧасов - Выборка.КоличествоЧасовПоГрафику;
							
						КонецЕсли; 
						
					КонецЦикла; 
				
				КонецЦикла; 
				
				ДокументТабель.Записать(РежимЗаписиДокумента.Проведение);
			
			КонецЦикла; 
		
		КонецЦикла; 
	
	КонецЦикла; 	

КонецПроцедуры

Процедура ОчиститьДанныеДня(Табель, НомерДня)

	Для каждого ТекСтрока Из Табель.ОтработанноеВремяПоДням Цикл
	
		ТекСтрока["ПервыйВидВремени" + НомерДня] = Неопределено;	
		ТекСтрока["ВторойВидВремени" + НомерДня] = Неопределено;	
		ТекСтрока["ТретийВидВремени" + НомерДня] = Неопределено;	
		ТекСтрока["ПервыйЧасы" + НомерДня] = 0;	
		ТекСтрока["ВторойЧасы" + НомерДня] = 0;	
		ТекСтрока["ТретийЧасы" + НомерДня] = 0;	
	
	КонецЦикла; 	

КонецПроцедуры

Функция ПолучитьИменаКолонокПоНомеруВидаВремени(НомерВидаВремени)

	Если НомерВидаВремени = 1 Тогда
		
		Нумератор = "Первый";
	
	ИначеЕсли НомерВидаВремени = 2 Тогда
	
		Нумератор = "Второй";
		
	ИначеЕсли НомерВидаВремени = 3 Тогда
	
		Нумератор = "Третий";
	
	КонецЕсли;
	
	СтруктураКолонок = Новый Структура;
	СтруктураКолонок.Вставить("ВидВремени", Нумератор + "ВидВремени");
	СтруктураКолонок.Вставить("Часы", Нумератор + "Часы");
	Возврат СтруктураКолонок;

КонецФункции // ПолучитьИменаКолонокПоНомеруВидаВремени()
 

Функция ПолучитьВидРабочегоВремени(Выборка)

	Если Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.Работа Тогда
	
		Возврат Справочники.ВидыРабочегоВремени.Работа;	
		
	ИначеЕсли Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.Отпуск
		И Выборка.ПричинаНевыхода = Перечисления.ПричиныНевыходовНаРаботу.Отпуск
		Тогда
	
		Возврат Справочники.ВидыРабочегоВремени.ОсновнойОтпуск;	
	
	ИначеЕсли Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.Работа
		И Выборка.ПричинаНевыхода = Перечисления.ПричиныНевыходовНаРаботу.Отгул
		И Выборка.Возмещаемый
		Тогда
	
		Возврат Справочники.ВидыРабочегоВремени.ОсновнойОтпуск;	
	
	ИначеЕсли Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.Работа
		И Выборка.ПричинаНевыхода = Перечисления.ПричиныНевыходовНаРаботу.Отгул
		И НЕ Выборка.Возмещаемый
		Тогда
	
		Возврат Справочники.ВидыРабочегоВремени.НеоплачиваемыйОтпускПоЗаконодательству;	
	
	ИначеЕсли Выборка.ТипУчета = Перечисления.ТипыУчетаРабочегоВремени.Больничный
		И Выборка.ПричинаНевыхода = Перечисления.ПричиныНевыходовНаРаботу.Болезнь
		Тогда
	
		Возврат Справочники.ВидыРабочегоВремени.Болезнь;	
	
	ИначеЕсли Выборка.ПричинаНевыхода = Перечисления.ПричиныНевыходовНаРаботу.БезПричины
		Тогда
	
		Возврат Справочники.ВидыРабочегоВремени.Прогулы;	
	
	Иначе
	
		Возврат Справочники.ВидыРабочегоВремени.Другой;	
	
	КонецЕсли; 	

КонецФункции // ПолучитьВидРабочегоВремени()

Процедура ВыполнитьЗагрузкуДанныхНаСервере()

	Перем ПутьКФайлу;
	УстановитьПривилегированныйРежим(Истина);
	
	НастройкиОбменаХЗ = Константы.НастройкиОбменаСДаннымиОПосещенииСотрудников.Получить();
	Если НастройкиОбменаХЗ <> Неопределено Тогда
	
		НастройкиОбмена = НастройкиОбменаХЗ.Получить();
		Если ТипЗнч(НастройкиОбмена) = Тип("Структура")
			И НастройкиОбмена.Свойство("ПутьКФайлу", ПутьКФайлу)
			Тогда
			
			Файл = Новый Файл(ПутьКФайлу);
			Если Не Файл.Существует() Тогда
			  
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = НСтр("ka='Файл ';ru='Файл ';en='Файл '") + ПутьКФайлу + НСтр("ka=' не найден';ru=' не найден';en=' не найден'");
				Сообщение.Сообщить(); 
				Возврат;
			
			КонецЕсли;
			
			ТабДок = Новый ТабличныйДокумент;
			ТабДок.Прочитать(ПутьКФайлу);
			НаборЗаписей = РегистрыСведений.ПриходыУходыСотрудников.СоздатьНаборЗаписей();
			Период = ТекущаяДатаСеанса();
			ТаблицаЗагрузки = НаборЗаписей.ВыгрузитьКолонки();
			
			Для Сч = 2 По ТабДок.ВысотаТаблицы Цикл
			
				СтрокаТаблицы = ТаблицаЗагрузки.Добавить();
				ДатаИзДокумента = СокрЛП(ТабДок.Область(Сч, 5, Сч, 5).Текст);
				День = Сред(ДатаИзДокумента,1,2);
				Месяц = Сред(ДатаИзДокумента,4,2);
				Год = Сред(ДатаИзДокумента,7,4);
				Час = Сред(ДатаИзДокумента,12,2);
				Минуты = Сред(ДатаИзДокумента,15,2);
				Секунды = Сред(ДатаИзДокумента,18,2);
				
				ДатаДляЗагрузки = Дата(Год,Месяц,День,Час,Минуты,Секунды);
				СтрокаТаблицы.Дата = ДатаДляЗагрузки;//СокрЛП(ТабДок.Область(Сч, 5, Сч, 5).Текст);
				СтрокаТаблицы.DeviceId = СокрЛП(ТабДок.Область(Сч, 1, Сч, 1).Текст);
				СтрокаТаблицы.PersonId = СокрЛП(ТабДок.Область(Сч, 2, Сч, 2).Текст);
				
			КонецЦикла;
			
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ТаблицаЗагрузки", ТаблицаЗагрузки);
			Запрос.УстановитьПараметр("Период", Период);
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ТаблицаЗагрузки.Дата КАК Дата,
			|	ТаблицаЗагрузки.DeviceId КАК DeviceId,
			|	ТаблицаЗагрузки.PersonId КАК PersonId
			|ПОМЕСТИТЬ ВТ_ТаблицаЗагрузки
			|ИЗ
			|	&ТаблицаЗагрузки КАК ТаблицаЗагрузки
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	PersonId
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ПриходыУходыСотрудников.Дата КАК Дата,
			|	ПриходыУходыСотрудников.Сотрудник.PersonId КАК PersonId
			|ПОМЕСТИТЬ ВТ_ЗаписиРегистра
			|ИЗ
			|	РегистрСведений.ПриходыУходыСотрудников КАК ПриходыУходыСотрудников
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	PersonId,
			|	Дата
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	&Период КАК ДатаЗагрузки,
			|	Сотрудники.Ссылка КАК Сотрудник,
			|	ВТ_ТаблицаЗагрузки.Дата КАК Дата,
			|	ВТ_ТаблицаЗагрузки.DeviceId КАК DeviceId,
			|	ВТ_ТаблицаЗагрузки.PersonId КАК PersonId
			|ИЗ
			|	ВТ_ТаблицаЗагрузки КАК ВТ_ТаблицаЗагрузки
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
			|		ПО ВТ_ТаблицаЗагрузки.PersonId = Сотрудники.PersonId
			|ГДЕ
			|	ВТ_ТаблицаЗагрузки.PersonId > 0
			|	И НЕ (ВТ_ТаблицаЗагрузки.PersonId, ВТ_ТаблицаЗагрузки.Дата) В
			|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
			|					ВТ_ЗаписиРегистра.PersonId КАК PersonId,
			|					ВТ_ЗаписиРегистра.Дата КАК Дата
			|				ИЗ
			|					ВТ_ЗаписиРегистра КАК ВТ_ЗаписиРегистра)";
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				
					МенеджерЗаписи = РегистрыСведений.ПриходыУходыСотрудников.СоздатьМенеджерЗаписи();
					ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Выборка); 
					МенеджерЗаписи.Записать();
			
			КонецЦикла; 
			
		КонецЕсли; 
	
	КонецЕсли; 
	
	УстановитьПривилегированныйРежим(Ложь);
	

КонецПроцедуры // ВыполнитьЗагрузкуДанныхНаСервере()


Процедура ПолучениеДанныхУчетаРабочегоВремени() Экспорт
	
	ВыполнитьЗагрузкуДанныхНаСервере();
	СформироватьДокументУчетРабочегоВремени();
	СформироватьДокументТабельПоДаннымУчета();
	
КонецПроцедуры

Процедура СформироватьДокументУчетРабочегоВремени()

	Перем  Организация;
	УстановитьПривилегированныйРежим(Истина);
	ХЗНастройкиОбмена = Константы.НастройкиОбменаСДаннымиОПосещенииСотрудников.Получить();
	Если ХЗНастройкиОбмена <> Неопределено И ТипЗнч(ХЗНастройкиОбмена) = Тип("ХранилищеЗначения") Тогда
	
		НастройкиОбмена = ХЗНастройкиОбмена.Получить();
		Если НастройкиОбмена.Свойство("Организация", Организация)
			И ЗначениеЗаполнено(Организация)
			Тогда
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("Организация", Организация);
			Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	УчетРабочегоВремениСотрудников.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.УчетРабочегоВремениСотрудников КАК УчетРабочегоВремениСотрудников
			|ГДЕ
			|	НАЧАЛОПЕРИОДА(УчетРабочегоВремениСотрудников.Дата, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)
			|	И НЕ УчетРабочегоВремениСотрудников.ПометкаУдаления
			|	И УчетРабочегоВремениСотрудников.Организация = &Организация";
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Выборка = РезультатЗапроса.Выбрать();
		    Если Выборка.Следующий() Тогда
			
				ДокументУчетРВ = Выборка.Ссылка.ПолучитьОбъект();
			
			Иначе
				
				ДокументУчетРВ = Документы.УчетРабочегоВремениСотрудников.СоздатьДокумент();
				
			КонецЕсли; 
			ДокументУчетРВ.Дата = КонецДня(ТекущаяДатаСеанса());
			ДокументУчетРВ.Организация = Организация;
			ДокументУчетРВ.ЗаполнитьПоДаннымУчета();
			ДокументУчетРВ.Записать(РежимЗаписиДокумента.Проведение);
		
		КонецЕсли;	
	
	КонецЕсли; 
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры
 
 