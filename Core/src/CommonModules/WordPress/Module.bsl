	Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,1);
	Если Результат.КодСостояния = 200 Тогда
		
		Данные = Результат.Данные;
		Для каждого СтрДанные Из Данные Цикл
			
			Стр_ТЗ_Товары = ТЗ_Товары.Добавить();
			
			Стр_ТЗ_Товары.id = СтрДанные.Получить("id");
			Стр_ТЗ_Товары.name = СтрДанные.Получить("name");
			Стр_ТЗ_Товары.slug = СтрДанные.Получить("slug");
			Стр_ТЗ_Товары.type = СтрДанные.Получить("type");
			Стр_ТЗ_Товары.status = СтрДанные.Получить("status");
			Стр_ТЗ_Товары.catalog_visibility = СтрДанные.Получить("catalog_visibility");
			Стр_ТЗ_Товары.description = СтрДанные.Получить("description");
			Стр_ТЗ_Товары.sku = СтрДанные.Получить("sku");
			Стр_ТЗ_Товары.price = СтрДанные.Получить("price");
