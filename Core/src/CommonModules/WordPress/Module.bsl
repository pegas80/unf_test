Функция СоздатьЗаказПокупателя(СтруктураШапки,ЗаказПокупателя=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	ЗаказПокупателя = НЕОПРЕДЕЛЕНО;
	СтруктураДополнительныхРеквизитовЗаказыПокупателей = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ЗаказПокупателя);
	
	Если (НЕ ТипЗНЧ(ЗаказПокупателя)=Тип("ДокументСсылка.ЗаказПокупателя")) ИЛИ (ЗаказПокупателя = Документы.ЗаказПокупателя.ПустаяСсылка()) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказПокупателяДополнительныеРеквизиты.Ссылка
		|ИЗ
		|	Документ.ЗаказПокупателя.ДополнительныеРеквизиты КАК ЗаказПокупателяДополнительныеРеквизиты
		|ГДЕ
		|	ЗаказПокупателяДополнительныеРеквизиты.Свойство = &Свойство
		|	И ЗаказПокупателяДополнительныеРеквизиты.Значение = &Значение";
		
		Запрос.УстановитьПараметр("Свойство", СтруктураДополнительныхРеквизитовЗаказыПокупателей.order_key);
		Запрос.УстановитьПараметр("Значение", СтруктураШапки.order_key);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЗаказПокупателя = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЦикла;
		
	Иначе
		
		ЗаказПокупателяОбъект = ЗаказПокупателя.ПолучитьОбъект();
		ЗаказПокупателяОбъект.Запасы.Очистить();
		ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ИСТИНА;
		ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Запись);
		
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЗаказПокупателя) Тогда
		ЗаказПокупателяОбъект = Документы.ЗаказПокупателя.СоздатьДокумент();		
	Иначе
		ЗаказПокупателяОбъект = ЗаказПокупателя.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаказПокупателяОбъект.ПоложениеДатыОтгрузки = ПредопределенноеЗначение("Перечисление.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти");
	
	Для каждого СтрСтруктураДополнительныхРеквизитовЗаказыПокупателей Из СтруктураДополнительныхРеквизитовЗаказыПокупателей Цикл
	
		ТекЗначение = НЕОПРЕДЕЛЕНО;
		СтруктураШапки.Свойство(СтрСтруктураДополнительныхРеквизитовЗаказыПокупателей.Ключ,ТекЗначение);
		УстановитьДополнительныйРеквизит(ЗаказПокупателяОбъект, СтрСтруктураДополнительныхРеквизитовЗаказыПокупателей.Значение, ТекЗначение);
	
	КонецЦикла;
	
	ЗаказПокупателяОбъект.СостояниеЗаказа = Справочники.СостоянияЗаказовПокупателей.Утвержден;
	
	ЗаказПокупателяОбъект.Номер = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(СтруктураШапки.number, 11, "0", "Слева");
	ЗаказПокупателяОбъект.Дата = СтруктураШапки.date_created;
	Если ЗначениеЗаполнено(ЗаказПокупателяОбъект.Дата) Тогда
		ТекДата = ЗаказПокупателяОбъект.Дата;
	Иначе
		ТекДата = ТекущаяДата();
	КонецЕсли;
	
	ЗаказПокупателяОбъект.ВидОперации = Перечисления.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу;
	
	ЗаказПокупателяОбъект.Организация = Справочники.Организации.ОсновнаяОрганизация;
	//ЗаказПокупателяОбъект.СтруктурнаяЕдиницаПродажи = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение;
	Если НЕ ЗначениеЗаполнено(ЗаказПокупателяОбъект.СтруктурнаяЕдиницаПродажи) Тогда
	
		ПодразделениеДляНовыхЗаказов = Константы.WordPress_ПодразделениеДляЗаказовИРасходных.Получить();
		Если ЗначениеЗаполнено(ПодразделениеДляНовыхЗаказов) Тогда
			ЗаказПокупателяОбъект.СтруктурнаяЕдиницаПродажи = ПодразделениеДляНовыхЗаказов;
		Иначе
			ЗаказПокупателяОбъект.СтруктурнаяЕдиницаПродажи = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение;
		КонецЕсли;
	
	КонецЕсли;
	//+++ Дмгг
	//ЗаказПокупателяОбъект.СтруктурнаяЕдиницаРезерв = Константы.WordPress_Склад.Получить();
	Если СтруктураШапки.ЭтоСамовывоз Тогда 
		ЗаказПокупателяОбъект.СтруктурнаяЕдиницаРезерв = СтруктураШапки.СкладРезерв;
		ЗаказПокупателяОбъект.Самвывоз = Истина;
	Иначе
		ЗаказПокупателяОбъект.СтруктурнаяЕдиницаРезерв = Константы.WordPress_Склад.Получить();
		ЗаказПокупателяОбъект.Самвывоз = ЛОЖЬ;
	КонецЕсли;
	//--- Дмгг
	
	Если СтруктураШапки.total_tax>0 Тогда
		ЗаказПокупателяОбъект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
	Иначе
		ЗаказПокупателяОбъект.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураШапки.Контрагент) Тогда
		ЗаказПокупателяОбъект.Контрагент = СтруктураШапки.Контрагент;
	Иначе
		ЗаказПокупателяОбъект.Контрагент = Константы.WordPress_КонтрагентПоУмолчанию.Получить();
	КонецЕсли;
	
	Если ЗаказПокупателяОбъект.Контрагент.ВестиРасчетыПоДоговорам Тогда
		МенеджерСправочника = Справочники.ДоговорыКонтрагентов;
		СписокВидовДоговоров = МенеджерСправочника.ПолучитьСписокВидовДоговораДляДокумента(ЗаказПокупателяОбъект.Ссылка, ЗаказПокупателяОбъект.ВидОперации);
		ЗаказПокупателяОбъект.Договор = МенеджерСправочника.ПолучитьДоговорПоУмолчаниюПоОрганизацииВидуДоговора(ЗаказПокупателяОбъект.Контрагент, ЗаказПокупателяОбъект.Организация, СписокВидовДоговоров);	
	Иначе
		ЗаказПокупателяОбъект.Договор = ЗаказПокупателяОбъект.Контрагент.ДоговорПоУмолчанию;
	КонецЕсли;
	
	ЗаказПокупателяОбъект.ВалютаДокумента = Справочники.Валюты.НайтиПоНаименованию(СОКРЛП(СтруктураШапки.currency));
	Если НЕ ЗначениеЗаполнено(ЗаказПокупателяОбъект.ВалютаДокумента) И ЗначениеЗаполнено(ЗаказПокупателяОбъект.Договор) Тогда
		ЗаказПокупателяОбъект.ВалютаДокумента = ЗаказПокупателяОбъект.Договор.ВалютаРасчетов;
	КонецЕсли;
	
	ВалютаРасчетовКурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекДата, Новый Структура("Валюта", ЗаказПокупателяОбъект.ВалютаДокумента));
	ЗаказПокупателяОбъект.Курс      = ?(ВалютаРасчетовКурсКратность.Курс = 0, 1, ВалютаРасчетовКурсКратность.Курс);
	ЗаказПокупателяОбъект.Кратность = ?(ВалютаРасчетовКурсКратность.Кратность = 0, 1, ВалютаРасчетовКурсКратность.Кратность);
	
	Если ЗначениеЗаполнено(ЗаказПокупателяОбъект.Договор) Тогда
		ЗаказПокупателяОбъект.ВидЦен = ЗаказПокупателяОбъект.Договор.ВидЦен;
		ЗаказПокупателяОбъект.ВидСкидкиНаценки = ЗаказПокупателяОбъект.Договор.ВидСкидкиНаценки;
	КонецЕсли;
	ЗаказПокупателяОбъект.НДСВключатьВСтоимость = СтруктураШапки.prices_include_tax;
	//ЗаказПокупателяОбъект.СуммаВключаетНДС = СтруктураШапки.prices_include_tax;
		
	ЗаказПокупателяОбъект.Комментарий = СтруктураШапки.customer_note;
	ЗаказПокупателяОбъект.СуммаДокумента = СтруктураШапки.total;
	ЗаказПокупателяОбъект.Автор = Константы.WordPress_Автор.Получить();
	
	ЗаказПокупателяОбъект.Запасы.Очистить();
	
	//ЗаказПокупателяОбъект.УстановитьНовыйНомер();
	ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ИСТИНА;
	ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Запись);
	
	ЗаказПокупателя = ЗаказПокупателяОбъект.Ссылка;
	
	РЕЗ = ЗаказПокупателя;
	Возврат РЕЗ;
КонецФункции // ()

Процедура ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатуры) ЭКСПОРТ

	Если НЕ ЗначениеЗаполнено(ЗаказПокупателя) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаказПокупателяОбъект = ЗаказПокупателя.ПолучитьОбъект();
	
	СтрокаТабличнойЧасти = ЗаказПокупателяОбъект.Запасы.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти,СтруктураСтроки);
	
	СтрокаТабличнойЧасти.ДатаОтгрузки = ЗаказПокупателяОбъект.Дата;
	
	СтрокаТабличнойЧасти.ТипНоменклатурыЗапас = ТипНоменклатуры;
	СтрокаТабличнойЧасти.ЕдиницаИзмерения = СтрокаТабличнойЧасти.Номенклатура.ЕдиницаИзмерения;
	
	Если СтрокаТабличнойЧасти.СуммаНДС>0 Тогда
		СтрокаТабличнойЧасти.СтавкаНДС = Справочники.СтавкиНДС.НДС18;
	Иначе
		СтрокаТабличнойЧасти.СтавкаНДС = Справочники.СтавкиНДС.БезНДС;
	КонецЕсли;
	
	СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(ЗаказПокупателяОбъект.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
	
	ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ИСТИНА;	
	ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Запись);

КонецПроцедуры

Функция ЗавершитьРаботуСЗаказом(ЗаказПокупателя, id=НЕОПРЕДЕЛЕНО,Рассрочка) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = ЛОЖЬ;

	ЗаказПокупателяОбъект = ЗаказПокупателя.ПолучитьОбъект();
	
	СуммаВсего = ЗаказПокупателяОбъект.Запасы.Итог("Всего");
	СуммаСкидки = ЗаказПокупателяОбъект.СуммаДокумента - СуммаВсего;
	Если СуммаСкидки>0 Тогда
	
		Для каждого СтрокаТабличнойЧасти Из ЗаказПокупателяОбъект.Запасы Цикл
			
			СуммаПередРасчетом = СтрокаТабличнойЧасти.Сумма;
			
			СуммаСкидкиВСтроке = СуммаСкидки * СтрокаТабличнойЧасти.Всего / СуммаВсего;
			
			СтрокаТабличнойЧасти.ПроцентСкидкиНаценки = СуммаСкидкиВСтроке * 100 / СтрокаТабличнойЧасти.Всего;
			Если СтрокаТабличнойЧасти.ПроцентСкидкиНаценки > 100 Тогда
				СтрокаТабличнойЧасти.Сумма = 0;
			ИначеЕсли СтрокаТабличнойЧасти.ПроцентСкидкиНаценки <> 0 И СтрокаТабличнойЧасти.Количество <> 0 Тогда
				СтрокаТабличнойЧасти.Сумма = СтрокаТабличнойЧасти.Сумма * (1 - СтрокаТабличнойЧасти.ПроцентСкидкиНаценки / 100);
			КонецЕсли;
			
			СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
			
			СтрокаТабличнойЧасти.СуммаНДС = ?(ЗаказПокупателяОбъект.СуммаВключаетНДС, 
												СтрокаТабличнойЧасти.Сумма - (СтрокаТабличнойЧасти.Сумма) / ((СтавкаНДС + 100) / 100),
												СтрокаТабличнойЧасти.Сумма * СтавкаНДС / 100);
			
			СтрокаТабличнойЧасти.Всего = СтрокаТабличнойЧасти.Сумма + ?(ЗаказПокупателяОбъект.СуммаВключаетНДС, 0, СтрокаТабличнойЧасти.СуммаНДС);
			
			СтрокаТабличнойЧасти.СуммаСкидки = СуммаПередРасчетом - СтрокаТабличнойЧасти.Сумма;
			
		
		КонецЦикла; 
	
	КонецЕсли;
	
	// Заполнить партии
	СкладЕДИ = ЗаказПокупателяОбъект.СтруктурнаяЕдиницаРезерв;
	МА_ОбщегоНазначения.ЗаполнениеПоПартиям(ЗаказПокупателяОбъект,СкладЕДИ,Истина,Истина,,Рассрочка);
	
	//+++ Дмгг
	// Да госпада, это костыль!!!
	Если ЗаказПокупателяОбъект.ПоложениеСклада = Перечисления.ПоложениеРеквизитаНаФорме.ПустаяСсылка() Тогда 
		ЗаказПокупателяОбъект.ПоложениеСклада = Перечисления.ПоложениеРеквизитаНаФорме.ВШапке;
	КонецЕсли;
	//--- Дмгг
	
	ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ИСТИНА;
	ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Запись);
	
	Попытка
		ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ЛОЖЬ;
		ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
		РЕЗ = ИСТИНА;
	Исключение
		ТекстСообщения = "Не удалось провести заказ покупателя " + ЗаказПокупателяОбъект.Ссылка;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		РЕЗ = ЛОЖЬ;
	КонецПопытки;
	
	// Записываем в регистры
	СтруктураДополнительныхРеквизитовЗаказыПокупателей = СтруктураДополнительныхРеквизитов(Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ЗаказПокупателя);
	Текid = НайтиЗначениеДополнительногоРеквизита(ЗаказПокупателяОбъект, СтруктураДополнительныхРеквизитовЗаказыПокупателей.id);
	Если НЕ ЗначениеЗаполнено(Текid) Тогда
		Текid = id;
	КонецЕсли;
	
	Если РЕЗ И ЗначениеЗаполнено(Текid) Тогда		
		// Заносим в регистр удачных загрузок
		НаборЗаписей = РегистрыСведений.СопоставлениеЗаказПокупателяWordPress.СоздатьНаборЗаписей(); 
		
		НаборЗаписей.Отбор.id.Установить(Текid); 
		
		НоваяЗапись = НаборЗаписей.Добавить(); 
		НоваяЗапись.ЗаказПокупателя = ЗаказПокупателяОбъект.Ссылка; 
		НоваяЗапись.id = Текid; 
		
		НаборЗаписей.Записать(ИСТИНА);
		
		// Удаляем из регистра неудачных загрузок
		
		НаборЗаписей1 = РегистрыСведений.СопоставлениеНеудачнаяЗагрузкаЗаказПокупателяWordPress.СоздатьНаборЗаписей(); 
		
		НаборЗаписей1.Отбор.id.Установить(Текid); 
		НаборЗаписей1.Записать(ИСТИНА);
		
		РЕЗ = ИСТИНА;
	Иначе
	    // Удаляем из регистра удачных загрузок
		НаборЗаписей = РегистрыСведений.СопоставлениеЗаказПокупателяWordPress.СоздатьНаборЗаписей(); 
		
		НаборЗаписей.Отбор.id.Установить(Текid); 
		НаборЗаписей.Записать(ИСТИНА);
		
		// Заносим в регистр неудачных загрузок
		
		НаборЗаписей1 = РегистрыСведений.СопоставлениеНеудачнаяЗагрузкаЗаказПокупателяWordPress.СоздатьНаборЗаписей(); 
		
		НаборЗаписей1.Отбор.id.Установить(Текid); 
		
		НоваяЗапись1 = НаборЗаписей1.Добавить(); 
		НоваяЗапись1.ЗаказПокупателя = ЗаказПокупателяОбъект.Ссылка; 
		НоваяЗапись1.id = Текid;
		
		НаборЗаписей1.Записать(ИСТИНА);
		
		РЕЗ = ЛОЖЬ;
	КонецЕсли;

	
	Возврат РЕЗ;
КонецФункции

Функция СоздатьРасходнуюНакладнуюНаОснованииЗаказаПокупателя(ЗаказПокупателя) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
		
	РасходнаяНакладная = Документы.РасходнаяНакладная.СоздатьДокумент();
	РасходнаяНакладная.Заполнить(ЗаказПокупателя.Ссылка);
	РасходнаяНакладная.Дата = ЗаказПокупателя.Дата+1;
	РасходнаяНакладная.СуммаВключаетНДС = ЗаказПокупателя.СуммаВключаетНДС;
	//РасходнаяНакладная.СтруктурнаяЕдиница = Константы.WordPress_Склад.Получить();
	//РасходнаяНакладная.Подразделение = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение;
	ПодразделениеДляНовыхЗаказов = Константы.WordPress_ПодразделениеДляЗаказовИРасходных.Получить();
	Если ЗначениеЗаполнено(ПодразделениеДляНовыхЗаказов) Тогда
		РасходнаяНакладная.Подразделение = ПодразделениеДляНовыхЗаказов;
	Иначе
		РасходнаяНакладная.Подразделение = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(РасходнаяНакладная.Контрагент) Тогда
		РасходнаяНакладная.Контрагент = Константы.WordPress_КонтрагентПоУмолчанию.Получить();
	КонецЕсли;
	
	РасходнаяНакладная.ОбменДанными.Загрузка = ИСТИНА;
	РасходнаяНакладная.Записать(РежимЗаписиДокумента.Запись);
	
	РЕЗ = РасходнаяНакладная.Ссылка;
	
	Попытка
		РасходнаяНакладная.ОбменДанными.Загрузка = ЛОЖЬ;
		РасходнаяНакладная.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ТекстСообщения = "Не удалось провести расходную накладную " + РасходнаяНакладная.Ссылка;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
	Возврат РЕЗ;
КонецФункции // ()

Процедура УстановитьАдресДоставкиВЗаказПокупателя(ЗаказПокупателя, СтрокаАдресДоставки)ЭКСПОРТ

	ЗаказПокупателяОбъект = ЗаказПокупателя.ПолучитьОбъект();
	
	СвойствоАдресДоставки = Константы.WordPress_ДополнительныйРеквизитАдресДоставкиДляЗаказовПокупателей.Получить();
	Если ТипЗНЧ(СвойствоАдресДоставки.ТипЗначения)=Тип("Строка") Тогда
		ЗначениеДополнительногоРеквизита = СтрокаАдресДоставки;
	Иначе
		ЗначенияСвойствОбъектов = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(СтрокаАдресДоставки,ИСТИНА,,СвойствоАдресДоставки);
		Если (ЗначенияСвойствОбъектов = НЕОПРЕДЕЛЕНО) ИЛИ (ЗначенияСвойствОбъектов = Справочники.ЗначенияСвойствОбъектов.ПустаяСсылка()) Тогда
			ЗначенияСвойствОбъектовОбъект = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
			ЗначенияСвойствОбъектовОбъект.Наименование = СтрокаАдресДоставки;
			ЗначенияСвойствОбъектовОбъект.Владелец = СвойствоАдресДоставки;
			ЗначенияСвойствОбъектовОбъект.Записать();
			ЗначенияСвойствОбъектов = ЗначенияСвойствОбъектовОбъект.Ссылка;
		КонецЕсли;
		ЗначениеДополнительногоРеквизита = ЗначенияСвойствОбъектов;
	КонецЕсли;
	WordPress.УстановитьДополнительныйРеквизит(ЗаказПокупателяОбъект, СвойствоАдресДоставки, ЗначениеДополнительногоРеквизита);
	
	ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ИСТИНА;
	ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Запись);

КонецПроцедуры

// Функция - Загрузить заказы
// Возвращает сформированную таблицу заказов. Передавать данные может только на сервере.
// Возвращаемое значение:
// ТЗ_Заказы - таблица значений - таблица закаказов товаров.
//
Функция ЗагрузитьЗаказы(Дата1,Дата2) ЭКСПОРТ
	ПЕРЕМ ДеревоОбъектов;
	
	ТЗ_Заказы = Новый ТаблицаЗначений();
	ТЗ_Заказы.Колонки.Добавить("id");
	ТЗ_Заказы.Колонки.Добавить("order_key");
	ТЗ_Заказы.Колонки.Добавить("date_created");
	ТЗ_Заказы.Колонки.Добавить("discount_total");
	ТЗ_Заказы.Колонки.Добавить("discount_tax");
	ТЗ_Заказы.Колонки.Добавить("shipping_total");
	ТЗ_Заказы.Колонки.Добавить("shipping_tax");
	ТЗ_Заказы.Колонки.Добавить("total");
	ТЗ_Заказы.Колонки.Добавить("total_tax");
	ТЗ_Заказы.Колонки.Добавить("prices_include_tax");
	ТЗ_Заказы.Колонки.Добавить("customer_id");
	ТЗ_Заказы.Колонки.Добавить("customer_note");
	ТЗ_Заказы.Колонки.Добавить("currency");
	ТЗ_Заказы.Колонки.Добавить("status");
	ТЗ_Заказы.Колонки.Добавить("personal_number");
	ТЗ_Заказы.Колонки.Добавить("Контрагент");
	ТЗ_Заказы.Колонки.Добавить("email");
	ТЗ_Заказы.Колонки.Добавить("phone");
	ТЗ_Заказы.Колонки.Добавить("first_name");
	ТЗ_Заказы.Колонки.Добавить("last_name");
	ТЗ_Заказы.Колонки.Добавить("company");
	ТЗ_Заказы.Колонки.Добавить("payment_method");
	ТЗ_Заказы.Колонки.Добавить("number");
	ТЗ_Заказы.Колонки.Добавить("ЗаказПокупателя");
	ТЗ_Заказы.Колонки.Добавить("РасходнаяНакладная");
	ТЗ_Заказы.Колонки.Добавить("Результат");
	ТЗ_Заказы.Колонки.Добавить("payment_method_title"); //+++ Дмгг
	ТЗ_Заказы.Колонки.Добавить("ЭтоСамовывоз"); //+++ Дмгг	
	ТЗ_Заказы.Колонки.Добавить("СкладРезерв"); //+++ Дмгг
	
	СтруктураСоединения = WordPress.ПолучитьСтруктуруСоединения();
	ПустойСкладРезерва = Справочники.СтруктурныеЕдиницы.ПустаяСсылка();//+++ Дмгг
	
	АдресРесурса = "/wp-json/wc/v3/orders"+СтруктураСоединения.ПараметрыАутентификации;
	АдресРесурса = АдресРесурса+"&after="+ЗаписатьДатуJSON(Дата1-1, ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.ЛокальнаяДата);
	АдресРесурса = АдресРесурса+"&before="+ЗаписатьДатуJSON(Дата2+1, ФорматДатыJSON.ISO, ВариантЗаписиДатыJSON.ЛокальнаяДата);
	
	Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,1);
	Если Результат.КодСостояния = 200 Тогда
		
		Данные = Результат.Данные;
		Для каждого СтрДанные Из Данные Цикл
			
			АдресСклада = "";//+++ Дмгг

			ТекСтатус = СтрДанные.Получить("status");
			Если НЕ ((ТекСтатус = "on-hold") ИЛИ (ТекСтатус = "processing") ИЛИ (ТекСтатус = "pending") ИЛИ (ТекСтатус = "space-bank")) Тогда
				Продолжить;
			КонецЕсли;
			
			Тек_id = СтрДанные.Получить("id");
			Тек_order_key = СтрДанные.Получить("order_key");
			
			ИскатьНеудачные = ИСТИНА;
			ЗаказПокупателя = WordPress.НайтиЗаказПокупателяВРегистре_СопоставлениеЗаказПокупателяWordPress(Тек_id,ИскатьНеудачные);
			Если НЕ ЗначениеЗаполнено(ЗаказПокупателя) Тогда
				
				Стр_ТЗ_Заказы = ТЗ_Заказы.Добавить();
				Стр_ТЗ_Заказы.Результат = "Неудачно"; // На всякий случай
				Стр_ТЗ_Заказы.ЭтоСамовывоз = ЛОЖЬ;//+++ Дмгг
				
				// Шапка
				Стр_ТЗ_Заказы.id = СтрДанные.Получить("id");
				Стр_ТЗ_Заказы.order_key = СтрДанные.Получить("order_key");
				Стр_ТЗ_Заказы.number = СтрДанные.Получить("number");
				Стр_ТЗ_Заказы.date_created = WordPress.ДатаJSON(СтрДанные.Получить("date_created"));
				Стр_ТЗ_Заказы.discount_total = Число(СтрДанные.Получить("discount_total"));
				Стр_ТЗ_Заказы.discount_tax = Число(СтрДанные.Получить("discount_tax"));
				Стр_ТЗ_Заказы.shipping_total = Число(СтрДанные.Получить("shipping_total"));
				Стр_ТЗ_Заказы.shipping_tax = Число(СтрДанные.Получить("shipping_tax"));
				Стр_ТЗ_Заказы.total = Число(СтрДанные.Получить("total"));
				Стр_ТЗ_Заказы.total_tax = Число(СтрДанные.Получить("total_tax"));
				Стр_ТЗ_Заказы.prices_include_tax = СтрДанные.Получить("prices_include_tax");
				Стр_ТЗ_Заказы.customer_id = СтрДанные.Получить("customer_id");
				Стр_ТЗ_Заказы.customer_note = СтрДанные.Получить("customer_note");
				Стр_ТЗ_Заказы.currency = СтрДанные.Получить("currency");
				Стр_ТЗ_Заказы.status = СтрДанные.Получить("status");
				Стр_ТЗ_Заказы.payment_method = СтрДанные.Получить("payment_method");
				Стр_ТЗ_Заказы.payment_method_title = СтрДанные.Получить("payment_method_title"); //+++ Дмгг
				
				meta_data = СтрДанные.Получить("meta_data");
				Для каждого Стр_meta_data Из meta_data Цикл
					Если Стр_meta_data.Получить("key")="_personal_number" Тогда
						Стр_ТЗ_Заказы.personal_number = Стр_meta_data.Получить("value");
					КонецЕсли;
					//+++ Дмгг
					Если Стр_meta_data.Получить("key")="mx_shipping_option" Тогда
						АдресСклада = Стр_meta_data.Получить("value");
					КонецЕсли;
					//--- Дмгг
				КонецЦикла;
				
				//+++ Дмгг
				Стр_ТЗ_Заказы.ЭтоСамовывоз = Ложь;
				shipping_lines = СтрДанные.Получить("shipping_lines");
				Для Каждого Стр_shipping_lines Из shipping_lines Цикл
					Если Стр_shipping_lines.Получить("method_id")="mx_local_shipping" Тогда
						Стр_ТЗ_Заказы.ЭтоСамовывоз = Истина;
					КонецЕсли;
				КонецЦикла;
				//--- Дмгг
				
				billing = СтрДанные.Получить("billing");
				Стр_ТЗ_Заказы.phone = billing.Получить("phone");
				Стр_ТЗ_Заказы.email = billing.Получить("email");
				Стр_ТЗ_Заказы.first_name = billing.Получить("first_name");
				Стр_ТЗ_Заказы.last_name = billing.Получить("last_name");
				Стр_ТЗ_Заказы.company =  billing.Получить("company");
				
				Стр_ТЗ_Заказы.Контрагент = WordPress.ПоискКонтрагента(Стр_ТЗ_Заказы.customer_id,Стр_ТЗ_Заказы.personal_number,Стр_ТЗ_Заказы.email,Стр_ТЗ_Заказы.phone);
				
				//+++ Дмгг
				Стр_ТЗ_Заказы.СкладРезерв = ПустойСкладРезерва;
				Если Стр_ТЗ_Заказы.ЭтоСамовывоз И ЗначениеЗаполнено(АдресСклада) Тогда 
					Стр_ТЗ_Заказы.СкладРезерв = WordPress.ПоискСкладаПоАдресу(АдресСклада);
				КонецЕсли;
				//--- Дмгг
				
				// создаём заказ покупателя                                                                                                                                                                                      //+++ Дмгг        //+++ Дмгг  //+++ Дмгг
				СтруктураШапки = Новый Структура("id,order_key,number,date_created,total,total_tax,prices_include_tax,customer_id,customer_note,currency,personal_number,phone,email,first_name,last_name,company,Контрагент,payment_method_title,ЭтоСамовывоз,СкладРезерв");
				ЗаполнитьЗначенияСвойств(СтруктураШапки,Стр_ТЗ_Заказы);
				ЗаказПокупателя = WordPress.СоздатьЗаказПокупателя(СтруктураШапки);
				Стр_ТЗ_Заказы.ЗаказПокупателя = ЗаказПокупателя;
				
				// Адрес доставки
				СтрокаАдресДоставки = "";
				
				shipping = СтрДанные.Получить("shipping");
				
				address_1 = СокрЛП(shipping.Получить("address_1"));
				Если СтрДлина(address_1)>0 Тогда
					СтрокаАдресДоставки = СтрокаАдресДоставки + address_1; 
				КонецЕсли;
				
				address_2 = СокрЛП(shipping.Получить("address_2"));
				Если СтрДлина(address_2)>0 Тогда
					Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + address_2; 
				КонецЕсли;
				
				city = СокрЛП(shipping.Получить("city"));
				Если СтрДлина(city)>0 Тогда
					Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + city; 
				КонецЕсли;
				
				first_name = СокрЛП(shipping.Получить("first_name"));
				Если СтрДлина(first_name)>0 Тогда
					Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + first_name; 
				КонецЕсли;
				
				last_name = СокрЛП(shipping.Получить("last_name"));
				Если СтрДлина(last_name)>0 Тогда
					Если СтрДлина(first_name)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + " ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + last_name; 
				КонецЕсли;
				
				Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
					WordPress.УстановитьАдресДоставкиВЗаказПокупателя(ЗаказПокупателя, СтрокаАдресДоставки);
				КонецЕсли;
				
				// Проверка или создание контрагента
				Если НЕ ЗначениеЗаполнено(Стр_ТЗ_Заказы.Контрагент) Тогда
					company = СокрЛП(Стр_ТЗ_Заказы.company);
					Если СтрДлина(company)=0 Тогда
						company = СокрЛП(shipping.Получить("company"));
					КонецЕсли;
					
					name = СокрЛП(Стр_ТЗ_Заказы.first_name) + ?(СтрДлина(СокрЛП(Стр_ТЗ_Заказы.first_name))>0," ","") + СокрЛП(Стр_ТЗ_Заказы.last_name);
					Если СтрДлина(name)=0 Тогда
						name = first_name + ?(СтрДлина(first_name)>0," ","") + last_name;
					КонецЕсли;
					
					Стр_ТЗ_Заказы.Контрагент = WordPress.СоздатьИлиНайтиКонтрагента(Стр_ТЗ_Заказы.customer_id,company,name,Стр_ТЗ_Заказы.personal_number,Стр_ТЗ_Заказы.email,Стр_ТЗ_Заказы.phone,СтрокаАдресДоставки,ЗаказПокупателя.НалогообложениеНДС,ЗаказПокупателя.ВалютаДокумента,ЗаказПокупателя);
				КонецЕсли;
				
				// Табличная часть
				ТЧ_Запасы = Новый ТаблицаЗначений();
				ТЧ_Запасы.Колонки.Добавить("стр_id");
				ТЧ_Запасы.Колонки.Добавить("product_id");
				ТЧ_Запасы.Колонки.Добавить("name");
				ТЧ_Запасы.Колонки.Добавить("sku");
				ТЧ_Запасы.Колонки.Добавить("quantity");
				ТЧ_Запасы.Колонки.Добавить("price");
				ТЧ_Запасы.Колонки.Добавить("subtotal");
				ТЧ_Запасы.Колонки.Добавить("стр_total_tax");
				ТЧ_Запасы.Колонки.Добавить("стр_total");
				ТЧ_Запасы.Колонки.Добавить("Номенклатура");
				
				line_items = СтрДанные.Получить("line_items");
				Для каждого Стр_line_items Из line_items Цикл
					
					Стр_ТЧ_Запасы = ТЧ_Запасы.Добавить();
					
					Стр_ТЧ_Запасы.стр_id = Стр_line_items.Получить("id");
					Стр_ТЧ_Запасы.product_id = Стр_line_items.Получить("product_id");
					Стр_ТЧ_Запасы.name = Стр_line_items.Получить("name");
					Стр_ТЧ_Запасы.sku = Стр_line_items.Получить("sku");
					Стр_ТЧ_Запасы.quantity = Стр_line_items.Получить("quantity");
					Стр_ТЧ_Запасы.price = Стр_line_items.Получить("price");
					Стр_ТЧ_Запасы.subtotal = Стр_line_items.Получить("subtotal");
					Стр_ТЧ_Запасы.стр_total_tax = Стр_line_items.Получить("total_tax");
					Стр_ТЧ_Запасы.стр_total = Стр_line_items.Получить("total");
					Стр_ТЧ_Запасы.Номенклатура = WordPress.ПоискТовара(Стр_ТЧ_Запасы.product_id,Стр_ТЧ_Запасы.sku);
					Если НЕ ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
						Стр_ТЧ_Запасы.Номенклатура = WordPress.ЗагрузитьТоварПо_id(Стр_ТЧ_Запасы.product_id);
					КонецЕсли;
					
					Если ЗначениеЗаполнено(Стр_ТЗ_Заказы.ЗаказПокупателя) Тогда
						
						СтруктураСтроки = Новый Структура("Номенклатура,Количество,Цена,Сумма,СуммаНДС,Всего,ДатаОтгрузки",
						Стр_ТЧ_Запасы.Номенклатура,Стр_ТЧ_Запасы.quantity,Стр_ТЧ_Запасы.price,Стр_ТЧ_Запасы.subtotal,Стр_ТЧ_Запасы.стр_total_tax,Стр_ТЧ_Запасы.стр_total,Стр_ТЗ_Заказы.date_created);
						
						ТипНоменклатурыЗапас = НЕОПРЕДЕЛЕНО;
						Если ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
							ТипНоменклатурыЗапас = (Стр_ТЧ_Запасы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
						КонецЕсли;
						
						WordPress.ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатурыЗапас);
						
					КонецЕсли;
					
				КонецЦикла;
				
				Если ЗначениеЗаполнено(Стр_ТЗ_Заказы.ЗаказПокупателя) Тогда
					Если Стр_ТЗ_Заказы.shipping_total>0 Тогда
						
						Если Стр_ТЗ_Заказы.prices_include_tax Тогда
							СуммаДоставкиБезНДС = Стр_ТЗ_Заказы.shipping_total;
						Иначе	
							СуммаДоставкиБезНДС = Стр_ТЗ_Заказы.shipping_total - Стр_ТЗ_Заказы.shipping_tax;
						КонецЕсли;
						
						УслугаДоставки = Константы.WordPress_УслугаДоставки.Получить();
						СтруктураСтроки = Новый Структура("Номенклатура,Количество,Цена,Сумма,СуммаНДС,Всего,ДатаОтгрузки",
						УслугаДоставки,1,СуммаДоставкиБезНДС,СуммаДоставкиБезНДС,Стр_ТЗ_Заказы.shipping_tax,Стр_ТЗ_Заказы.shipping_total,Стр_ТЗ_Заказы.date_created);
						
						ТипНоменклатурыЗапас = НЕОПРЕДЕЛЕНО;
						Если ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
							ТипНоменклатурыЗапас = (УслугаДоставки.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
						КонецЕсли;
						
						WordPress.ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатурыЗапас);
						
					КонецЕсли;
					
					//Lazare_				
					Рассрочка =Ложь ;				
					Если  Стр_ТЗ_Заказы.payment_method = "tbc_installments_gateway"   Тогда					
						Рассрочка =Истина ;					 
					КонецЕсли;   					
					//_Lazare	
					
					Если WordPress.ЗавершитьРаботуСЗаказом(Стр_ТЗ_Заказы.ЗаказПокупателя,Стр_ТЗ_Заказы.id, Рассрочка) Тогда
						Стр_ТЗ_Заказы.Результат = "Удачно";
						
						Если (Стр_ТЗ_Заказы.payment_method = "cod") ИЛИ (Стр_ТЗ_Заказы.payment_method = "tbc_credit_card_gateway") Тогда
							Стр_ТЗ_Заказы.РасходнаяНакладная = WordPress.СоздатьРасходнуюНакладнуюНаОснованииЗаказаПокупателя(ЗаказПокупателя);
						КонецЕсли;
					Иначе
						Стр_ТЗ_Заказы.Результат = "Неудачно";
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		КоличествоСтраниц = Число(Результат.КоличествоСтраниц);
		//Сообщить(КоличествоСтраниц);
		Если КоличествоСтраниц>1 Тогда
			
			и1=1;
			Пока и1<=КоличествоСтраниц Цикл
				и1 = и1+1;
				
				Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,и1);
				Если Результат.КодСостояния = 200 Тогда
					
					Данные = Результат.Данные;
					
					Если Данные.Количество()=0 Тогда
						Прервать;
					КонецЕсли;
					
					Для каждого СтрДанные Из Данные Цикл
						
						АдресСклада = "";//+++ Дмгг
						
						ТекСтатус = СтрДанные.Получить("status");
						Если НЕ ((ТекСтатус = "on-hold") ИЛИ (ТекСтатус = "processing") ИЛИ (ТекСтатус = "pending") ИЛИ (ТекСтатус = "space-bank")) Тогда
							Продолжить;
						КонецЕсли;
						
						Тек_id = СтрДанные.Получить("id");
						Тек_order_key = СтрДанные.Получить("order_key");
						
						ИскатьНеудачные = ИСТИНА;
						ЗаказПокупателя = WordPress.НайтиЗаказПокупателяВРегистре_СопоставлениеЗаказПокупателяWordPress(Тек_id,ИскатьНеудачные);
						Если НЕ ЗначениеЗаполнено(ЗаказПокупателя) Тогда
							
							Стр_ТЗ_Заказы = ТЗ_Заказы.Добавить();
							Стр_ТЗ_Заказы.Результат = "Неудачно"; // На всякий случай
							Стр_ТЗ_Заказы.ЭтоСамовывоз = ЛОЖЬ;//+++ Дмгг
							
							// Шапка
							Стр_ТЗ_Заказы.id = СтрДанные.Получить("id");
							Стр_ТЗ_Заказы.order_key = СтрДанные.Получить("order_key");
							Стр_ТЗ_Заказы.number = СтрДанные.Получить("number");
							Стр_ТЗ_Заказы.date_created = WordPress.ДатаJSON(СтрДанные.Получить("date_created"));
							Стр_ТЗ_Заказы.discount_total = Число(СтрДанные.Получить("discount_total"));
							Стр_ТЗ_Заказы.discount_tax = Число(СтрДанные.Получить("discount_tax"));
							Стр_ТЗ_Заказы.shipping_total = Число(СтрДанные.Получить("shipping_total"));
							Стр_ТЗ_Заказы.shipping_tax = Число(СтрДанные.Получить("shipping_tax"));
							Стр_ТЗ_Заказы.total = Число(СтрДанные.Получить("total"));
							Стр_ТЗ_Заказы.total_tax = Число(СтрДанные.Получить("total_tax"));
							Стр_ТЗ_Заказы.prices_include_tax = СтрДанные.Получить("prices_include_tax");
							Стр_ТЗ_Заказы.customer_id = СтрДанные.Получить("customer_id");
							Стр_ТЗ_Заказы.customer_note = СтрДанные.Получить("customer_note");
							Стр_ТЗ_Заказы.currency = СтрДанные.Получить("currency");
							Стр_ТЗ_Заказы.status = СтрДанные.Получить("status");
							Стр_ТЗ_Заказы.payment_method = СтрДанные.Получить("payment_method");
							Стр_ТЗ_Заказы.payment_method_title = СтрДанные.Получить("payment_method_title"); //+++ Дмгг
							
							meta_data = СтрДанные.Получить("meta_data");
							Для каждого Стр_meta_data Из meta_data Цикл
								Если Стр_meta_data.Получить("key")="_personal_number" Тогда
									Стр_ТЗ_Заказы.personal_number = Стр_meta_data.Получить("value");
								КонецЕсли;
								//+++ Дмгг
								Если Стр_meta_data.Получить("key")="mx_shipping_option" Тогда
									АдресСклада = Стр_meta_data.Получить("value");
								КонецЕсли;
								//--- Дмгг
							КонецЦикла;
							
							//+++ Дмгг
							Стр_ТЗ_Заказы.ЭтоСамовывоз = Ложь;
							shipping_lines = СтрДанные.Получить("shipping_lines");
							Для Каждого Стр_shipping_lines Из shipping_lines Цикл
								Если Стр_shipping_lines.Получить("method_id")="mx_local_shipping" Тогда
									Стр_ТЗ_Заказы.ЭтоСамовывоз = Истина;
								КонецЕсли;
							КонецЦикла;
							//--- Дмгг
							
							billing = СтрДанные.Получить("billing");
							Стр_ТЗ_Заказы.phone = billing.Получить("phone");
							Стр_ТЗ_Заказы.email = billing.Получить("email");
							Стр_ТЗ_Заказы.first_name = billing.Получить("first_name");
							Стр_ТЗ_Заказы.last_name = billing.Получить("last_name");
							Стр_ТЗ_Заказы.company =  billing.Получить("company");
							
							Стр_ТЗ_Заказы.Контрагент = WordPress.ПоискКонтрагента(Стр_ТЗ_Заказы.customer_id,Стр_ТЗ_Заказы.personal_number,Стр_ТЗ_Заказы.email,Стр_ТЗ_Заказы.phone);
							
							//+++ Дмгг
							Стр_ТЗ_Заказы.СкладРезерв = ПустойСкладРезерва;
							Если Стр_ТЗ_Заказы.ЭтоСамовывоз И ЗначениеЗаполнено(АдресСклада) Тогда 
								Стр_ТЗ_Заказы.СкладРезерв = WordPress.ПоискСкладаПоАдресу(АдресСклада);
							КонецЕсли;
							//--- Дмгг
							
							// создаём заказ покупателя                                                                                                                                                                                     //+++ Дмгг         //+++ Дмгг   //+++ Дмгг
							СтруктураШапки = Новый Структура("id,order_key,number,date_created,total,total_tax,prices_include_tax,customer_id,customer_note,currency,personal_number,phone,email,first_name,last_name,company,Контрагент,payment_method_title,ЭтоСамовывоз,СкладРезерв");
							ЗаполнитьЗначенияСвойств(СтруктураШапки,Стр_ТЗ_Заказы);
							ЗаказПокупателя = WordPress.СоздатьЗаказПокупателя(СтруктураШапки);
							Стр_ТЗ_Заказы.ЗаказПокупателя = ЗаказПокупателя;
							
							// Адрес доставки
							СтрокаАдресДоставки = "";
							
							shipping = СтрДанные.Получить("shipping");
							
							address_1 = СокрЛП(shipping.Получить("address_1"));
							Если СтрДлина(address_1)>0 Тогда
								СтрокаАдресДоставки = СтрокаАдресДоставки + address_1; 
							КонецЕсли;
							
							address_2 = СокрЛП(shipping.Получить("address_2"));
							Если СтрДлина(address_2)>0 Тогда
								Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
									СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
								КонецЕсли;
								СтрокаАдресДоставки = СтрокаАдресДоставки + address_2; 
							КонецЕсли;
							
							city = СокрЛП(shipping.Получить("city"));
							Если СтрДлина(city)>0 Тогда
								Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
									СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
								КонецЕсли;
								СтрокаАдресДоставки = СтрокаАдресДоставки + city; 
							КонецЕсли;
							
							first_name = СокрЛП(shipping.Получить("first_name"));
							Если СтрДлина(first_name)>0 Тогда
								Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
									СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
								КонецЕсли;
								СтрокаАдресДоставки = СтрокаАдресДоставки + first_name; 
							КонецЕсли;
							
							last_name = СокрЛП(shipping.Получить("last_name"));
							Если СтрДлина(last_name)>0 Тогда
								Если СтрДлина(first_name)>0 Тогда
									СтрокаАдресДоставки = СтрокаАдресДоставки + " ";
								КонецЕсли;
								СтрокаАдресДоставки = СтрокаАдресДоставки + last_name; 
							КонецЕсли;
							
							Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
								WordPress.УстановитьАдресДоставкиВЗаказПокупателя(ЗаказПокупателя, СтрокаАдресДоставки);
							КонецЕсли;
							
							// Проверка или создание контрагента
							Если НЕ ЗначениеЗаполнено(Стр_ТЗ_Заказы.Контрагент) Тогда
								company = СокрЛП(Стр_ТЗ_Заказы.company);
								Если СтрДлина(company)=0 Тогда
									company = СокрЛП(shipping.Получить("company"));
								КонецЕсли;
								
								name = СокрЛП(Стр_ТЗ_Заказы.first_name) + ?(СтрДлина(СокрЛП(Стр_ТЗ_Заказы.first_name))>0," ","") + СокрЛП(Стр_ТЗ_Заказы.last_name);
								Если СтрДлина(name)=0 Тогда
									name = first_name + ?(СтрДлина(first_name)>0," ","") + last_name;
								КонецЕсли;
								
								Стр_ТЗ_Заказы.Контрагент = WordPress.СоздатьИлиНайтиКонтрагента(Стр_ТЗ_Заказы.customer_id,company,name,Стр_ТЗ_Заказы.personal_number,Стр_ТЗ_Заказы.email,Стр_ТЗ_Заказы.phone,СтрокаАдресДоставки,ЗаказПокупателя.НалогообложениеНДС,ЗаказПокупателя.ВалютаДокумента,ЗаказПокупателя);
							КонецЕсли;
							
							// Табличная часть
							ТЧ_Запасы = Новый ТаблицаЗначений();
							ТЧ_Запасы.Колонки.Добавить("стр_id");
							ТЧ_Запасы.Колонки.Добавить("product_id");
							ТЧ_Запасы.Колонки.Добавить("name");
							ТЧ_Запасы.Колонки.Добавить("sku");
							ТЧ_Запасы.Колонки.Добавить("quantity");
							ТЧ_Запасы.Колонки.Добавить("price");
							ТЧ_Запасы.Колонки.Добавить("subtotal");
							ТЧ_Запасы.Колонки.Добавить("стр_total_tax");
							ТЧ_Запасы.Колонки.Добавить("стр_total");
							ТЧ_Запасы.Колонки.Добавить("Номенклатура");
							
							line_items = СтрДанные.Получить("line_items");
							Для каждого Стр_line_items Из line_items Цикл
								
								Стр_ТЧ_Запасы = ТЧ_Запасы.Добавить();
								
								Стр_ТЧ_Запасы.стр_id = Стр_line_items.Получить("id");
								Стр_ТЧ_Запасы.product_id = Стр_line_items.Получить("product_id");
								Стр_ТЧ_Запасы.name = Стр_line_items.Получить("name");
								Стр_ТЧ_Запасы.sku = Стр_line_items.Получить("sku");
								Стр_ТЧ_Запасы.quantity = Стр_line_items.Получить("quantity");
								Стр_ТЧ_Запасы.price = Стр_line_items.Получить("price");
								Стр_ТЧ_Запасы.subtotal = Стр_line_items.Получить("subtotal");
								Стр_ТЧ_Запасы.стр_total_tax = Стр_line_items.Получить("total_tax");
								Стр_ТЧ_Запасы.стр_total = Стр_line_items.Получить("total");
								Стр_ТЧ_Запасы.Номенклатура = WordPress.ПоискТовара(Стр_ТЧ_Запасы.product_id,Стр_ТЧ_Запасы.sku);
								Если НЕ ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
									Стр_ТЧ_Запасы.Номенклатура = WordPress.ЗагрузитьТоварПо_id(Стр_ТЧ_Запасы.product_id);
								КонецЕсли;
								
								Если ЗначениеЗаполнено(Стр_ТЗ_Заказы.ЗаказПокупателя) Тогда
									
									СтруктураСтроки = Новый Структура("Номенклатура,Количество,Цена,Сумма,СуммаНДС,Всего,ДатаОтгрузки",
									Стр_ТЧ_Запасы.Номенклатура,Стр_ТЧ_Запасы.quantity,Стр_ТЧ_Запасы.price,Стр_ТЧ_Запасы.subtotal,Стр_ТЧ_Запасы.стр_total_tax,Стр_ТЧ_Запасы.стр_total,Стр_ТЗ_Заказы.date_created);
									
									ТипНоменклатурыЗапас = НЕОПРЕДЕЛЕНО;
									Если ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
										ТипНоменклатурыЗапас = (Стр_ТЧ_Запасы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
									КонецЕсли;
									
									WordPress.ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатурыЗапас);
									
								КонецЕсли;
								
							КонецЦикла;
							
							Если ЗначениеЗаполнено(Стр_ТЗ_Заказы.ЗаказПокупателя) Тогда
								Если Стр_ТЗ_Заказы.shipping_total>0 Тогда
									
									Если Стр_ТЗ_Заказы.prices_include_tax Тогда
										СуммаДоставкиБезНДС = Стр_ТЗ_Заказы.shipping_total;
									Иначе	
										СуммаДоставкиБезНДС = Стр_ТЗ_Заказы.shipping_total - Стр_ТЗ_Заказы.shipping_tax;
									КонецЕсли;
									
									УслугаДоставки = Константы.WordPress_УслугаДоставки.Получить();
									СтруктураСтроки = Новый Структура("Номенклатура,Количество,Цена,Сумма,СуммаНДС,Всего,ДатаОтгрузки",
									УслугаДоставки,1,СуммаДоставкиБезНДС,СуммаДоставкиБезНДС,Стр_ТЗ_Заказы.shipping_tax,Стр_ТЗ_Заказы.shipping_total,Стр_ТЗ_Заказы.date_created);
									
									ТипНоменклатурыЗапас = НЕОПРЕДЕЛЕНО;
									Если ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
										ТипНоменклатурыЗапас = (УслугаДоставки.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
									КонецЕсли;
									
									WordPress.ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатурыЗапас);
									
								КонецЕсли;																
								//Lazare_				
								Рассрочка =Ложь ;				
								Если  Стр_ТЗ_Заказы.payment_method = "tbc_installments_gateway"   Тогда					
									Рассрочка =Истина ;					 
								КонецЕсли;   					
								//_Lazare																			
								Если WordPress.ЗавершитьРаботуСЗаказом(Стр_ТЗ_Заказы.ЗаказПокупателя,Стр_ТЗ_Заказы.id,Рассрочка) Тогда
									Стр_ТЗ_Заказы.Результат = "Удачно";
									
									Если (Стр_ТЗ_Заказы.payment_method = "cod") ИЛИ (Стр_ТЗ_Заказы.payment_method = "tbc_credit_card_gateway") Тогда
										Стр_ТЗ_Заказы.РасходнаяНакладная = WordPress.СоздатьРасходнуюНакладнуюНаОснованииЗаказаПокупателя(ЗаказПокупателя);
									КонецЕсли;
								Иначе
									Стр_ТЗ_Заказы.Результат = "Неудачно";
								КонецЕсли;
								
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ТЗ_Заказы;
КонецФункции

// Функция - ЗагрузитьЗаказПо_id
// Возвращает структуру результата загрузки одного заказа по его id
// id - целое число
// ЗаказПокупателя - Ссылка на документ ЗаказПокупателя, куда будут загружаться данные.
// Возвращаемое значение:
// ТЗ_Заказы - фиксированнная структура - таблица закаказов товаров.
//
Функция ЗагрузитьЗаказПо_id(id,ЗаказПокупателяСсылка) ЭКСПОРТ
	ПЕРЕМ ДеревоОбъектов;
	
	Стр_ТЗ_Заказы = Новый Структура();
	Стр_ТЗ_Заказы.Вставить("id");
	Стр_ТЗ_Заказы.Вставить("order_key");
	Стр_ТЗ_Заказы.Вставить("date_created");
	Стр_ТЗ_Заказы.Вставить("discount_total");
	Стр_ТЗ_Заказы.Вставить("discount_tax");
	Стр_ТЗ_Заказы.Вставить("shipping_total");
	Стр_ТЗ_Заказы.Вставить("shipping_tax");
	Стр_ТЗ_Заказы.Вставить("total");
	Стр_ТЗ_Заказы.Вставить("total_tax");
	Стр_ТЗ_Заказы.Вставить("prices_include_tax");
	Стр_ТЗ_Заказы.Вставить("customer_id");
	Стр_ТЗ_Заказы.Вставить("customer_note");
	Стр_ТЗ_Заказы.Вставить("currency");
	Стр_ТЗ_Заказы.Вставить("status");
	Стр_ТЗ_Заказы.Вставить("personal_number");
	Стр_ТЗ_Заказы.Вставить("Контрагент");
	Стр_ТЗ_Заказы.Вставить("email");
	Стр_ТЗ_Заказы.Вставить("phone");
	Стр_ТЗ_Заказы.Вставить("first_name");
	Стр_ТЗ_Заказы.Вставить("last_name");
	Стр_ТЗ_Заказы.Вставить("company");
	Стр_ТЗ_Заказы.Вставить("payment_method");
	Стр_ТЗ_Заказы.Вставить("number");
	Стр_ТЗ_Заказы.Вставить("ЗаказПокупателя");
	Стр_ТЗ_Заказы.Вставить("РасходнаяНакладная");
	Стр_ТЗ_Заказы.Вставить("Результат");
	
	Если ЗначениеЗаполнено(id) И ЗначениеЗаполнено(ЗаказПокупателяСсылка) Тогда
			
		Стр_ТЗ_Заказы.id = id;
		Стр_ТЗ_Заказы.ЗаказПокупателя = ЗаказПокупателяСсылка;
		Стр_ТЗ_Заказы.Результат = "Неудачно";
		
		СтруктураСоединения = WordPress.ПолучитьСтруктуруСоединения();
	
		АдресРесурса = "/wp-json/wc/v3/orders/"+Формат(id, "ЧДЦ=0; ЧГ=")+СтруктураСоединения.ПараметрыАутентификации;
		
		Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,НЕОПРЕДЕЛЕНО,"POST");
		Если Результат.КодСостояния = 200 Тогда
			
			СтрДанные = Результат.Данные;
			ТекСтатус = СтрДанные.Получить("status");
			Если (ТекСтатус = "on-hold") ИЛИ (ТекСтатус = "processing") ИЛИ (ТекСтатус = "pending") ИЛИ (ТекСтатус = "space-bank") Тогда
				
				// Шапка
				Стр_ТЗ_Заказы.id = СтрДанные.Получить("id");
				Стр_ТЗ_Заказы.order_key = СтрДанные.Получить("order_key");
				Стр_ТЗ_Заказы.number = СтрДанные.Получить("number");
				Стр_ТЗ_Заказы.date_created = WordPress.ДатаJSON(СтрДанные.Получить("date_created"));
				Стр_ТЗ_Заказы.discount_total = Число(СтрДанные.Получить("discount_total"));
				Стр_ТЗ_Заказы.discount_tax = Число(СтрДанные.Получить("discount_tax"));
				Стр_ТЗ_Заказы.shipping_total = Число(СтрДанные.Получить("shipping_total"));
				Стр_ТЗ_Заказы.shipping_tax = Число(СтрДанные.Получить("shipping_tax"));
				Стр_ТЗ_Заказы.total = Число(СтрДанные.Получить("total"));
				Стр_ТЗ_Заказы.total_tax = Число(СтрДанные.Получить("total_tax"));
				Стр_ТЗ_Заказы.prices_include_tax = СтрДанные.Получить("prices_include_tax");
				Стр_ТЗ_Заказы.customer_id = СтрДанные.Получить("customer_id");
				Стр_ТЗ_Заказы.customer_note = СтрДанные.Получить("customer_note");
				Стр_ТЗ_Заказы.currency = СтрДанные.Получить("currency");
				Стр_ТЗ_Заказы.status = СтрДанные.Получить("status");
				Стр_ТЗ_Заказы.payment_method = СтрДанные.Получить("payment_method");
				
				meta_data = СтрДанные.Получить("meta_data");
				Для каждого Стр_meta_data Из meta_data Цикл
					Если Стр_meta_data.Получить("key")="_personal_number" Тогда
						Стр_ТЗ_Заказы.personal_number = Стр_meta_data.Получить("value");
					КонецЕсли;
				КонецЦикла;
				
				billing = СтрДанные.Получить("billing");
				Стр_ТЗ_Заказы.phone = billing.Получить("phone");
				Стр_ТЗ_Заказы.email = billing.Получить("email");
				Стр_ТЗ_Заказы.first_name = billing.Получить("first_name");
				Стр_ТЗ_Заказы.last_name = billing.Получить("last_name");
				Стр_ТЗ_Заказы.company =  billing.Получить("company");
				
				Стр_ТЗ_Заказы.Контрагент = WordPress.ПоискКонтрагента(Стр_ТЗ_Заказы.customer_id,Стр_ТЗ_Заказы.personal_number,Стр_ТЗ_Заказы.email,Стр_ТЗ_Заказы.phone);
				
				// создаём заказ покупателя
				СтруктураШапки = Новый Структура("id,order_key,number,date_created,total,total_tax,prices_include_tax,customer_id,customer_note,currency,personal_number,phone,email,first_name,last_name,company,Контрагент");
				ЗаполнитьЗначенияСвойств(СтруктураШапки,Стр_ТЗ_Заказы);
				ЗаказПокупателя = WordPress.СоздатьЗаказПокупателя(СтруктураШапки,ЗаказПокупателяСсылка);
				Стр_ТЗ_Заказы.ЗаказПокупателя = ЗаказПокупателя;
				
				// Адрес доставки
				СтрокаАдресДоставки = "";
				
				shipping = СтрДанные.Получить("shipping");
				
				address_1 = СокрЛП(shipping.Получить("address_1"));
				Если СтрДлина(address_1)>0 Тогда
					СтрокаАдресДоставки = СтрокаАдресДоставки + address_1; 
				КонецЕсли;
				
				address_2 = СокрЛП(shipping.Получить("address_2"));
				Если СтрДлина(address_2)>0 Тогда
					Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + address_2; 
				КонецЕсли;
				
				city = СокрЛП(shipping.Получить("city"));
				Если СтрДлина(city)>0 Тогда
					Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + city; 
				КонецЕсли;
				
				first_name = СокрЛП(shipping.Получить("first_name"));
				Если СтрДлина(first_name)>0 Тогда
					Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + ", ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + first_name; 
				КонецЕсли;
				
				last_name = СокрЛП(shipping.Получить("last_name"));
				Если СтрДлина(last_name)>0 Тогда
					Если СтрДлина(first_name)>0 Тогда
						СтрокаАдресДоставки = СтрокаАдресДоставки + " ";
					КонецЕсли;
					СтрокаАдресДоставки = СтрокаАдресДоставки + last_name; 
				КонецЕсли;
				
				Если СтрДлина(СтрокаАдресДоставки)>0 Тогда
					WordPress.УстановитьАдресДоставкиВЗаказПокупателя(ЗаказПокупателя, СтрокаАдресДоставки);
				КонецЕсли;
				
				// Проверка или создание контрагента
				Если НЕ ЗначениеЗаполнено(Стр_ТЗ_Заказы.Контрагент) Тогда
					company = СокрЛП(Стр_ТЗ_Заказы.company);
					Если СтрДлина(company)=0 Тогда
						company = СокрЛП(shipping.Получить("company"));
					КонецЕсли;
					
					name = СокрЛП(Стр_ТЗ_Заказы.first_name) + ?(СтрДлина(СокрЛП(Стр_ТЗ_Заказы.first_name))>0," ","") + СокрЛП(Стр_ТЗ_Заказы.last_name);
					Если СтрДлина(name)=0 Тогда
						name = first_name + ?(СтрДлина(first_name)>0," ","") + last_name;
					КонецЕсли;
					
					Стр_ТЗ_Заказы.Контрагент = WordPress.СоздатьИлиНайтиКонтрагента(Стр_ТЗ_Заказы.customer_id,company,name,Стр_ТЗ_Заказы.personal_number,Стр_ТЗ_Заказы.email,Стр_ТЗ_Заказы.phone,СтрокаАдресДоставки,ЗаказПокупателя.НалогообложениеНДС,ЗаказПокупателя.ВалютаДокумента,ЗаказПокупателя);
				КонецЕсли;
				
				// Табличная часть
				ТЧ_Запасы = Новый ТаблицаЗначений();
				ТЧ_Запасы.Колонки.Добавить("стр_id");
				ТЧ_Запасы.Колонки.Добавить("product_id");
				ТЧ_Запасы.Колонки.Добавить("name");
				ТЧ_Запасы.Колонки.Добавить("sku");
				ТЧ_Запасы.Колонки.Добавить("quantity");
				ТЧ_Запасы.Колонки.Добавить("price");
				ТЧ_Запасы.Колонки.Добавить("subtotal");
				ТЧ_Запасы.Колонки.Добавить("стр_total_tax");
				ТЧ_Запасы.Колонки.Добавить("стр_total");
				ТЧ_Запасы.Колонки.Добавить("Номенклатура");
				
				line_items = СтрДанные.Получить("line_items");
				Для каждого Стр_line_items Из line_items Цикл
					
					Стр_ТЧ_Запасы = ТЧ_Запасы.Добавить();
					
					Стр_ТЧ_Запасы.стр_id = Стр_line_items.Получить("id");
					Стр_ТЧ_Запасы.product_id = Стр_line_items.Получить("product_id");
					Стр_ТЧ_Запасы.name = Стр_line_items.Получить("name");
					Стр_ТЧ_Запасы.sku = Стр_line_items.Получить("sku");
					Стр_ТЧ_Запасы.quantity = Стр_line_items.Получить("quantity");
					Стр_ТЧ_Запасы.price = Стр_line_items.Получить("price");
					Стр_ТЧ_Запасы.subtotal = Стр_line_items.Получить("subtotal");
					Стр_ТЧ_Запасы.стр_total_tax = Стр_line_items.Получить("total_tax");
					Стр_ТЧ_Запасы.стр_total = Стр_line_items.Получить("total");
					Стр_ТЧ_Запасы.Номенклатура = WordPress.ПоискТовара(Стр_ТЧ_Запасы.product_id,Стр_ТЧ_Запасы.sku);
					Если НЕ ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
						Стр_ТЧ_Запасы.Номенклатура = WordPress.ЗагрузитьТоварПо_id(Стр_ТЧ_Запасы.product_id);
					КонецЕсли;
					
					Если ЗначениеЗаполнено(Стр_ТЗ_Заказы.ЗаказПокупателя) Тогда
						
						СтруктураСтроки = Новый Структура("Номенклатура,Количество,Цена,Сумма,СуммаНДС,Всего,ДатаОтгрузки",
						Стр_ТЧ_Запасы.Номенклатура,Стр_ТЧ_Запасы.quantity,Стр_ТЧ_Запасы.price,Стр_ТЧ_Запасы.subtotal,Стр_ТЧ_Запасы.стр_total_tax,Стр_ТЧ_Запасы.стр_total,Стр_ТЗ_Заказы.date_created);
						
						ТипНоменклатурыЗапас = НЕОПРЕДЕЛЕНО;
						Если ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
							ТипНоменклатурыЗапас = (Стр_ТЧ_Запасы.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
						КонецЕсли;
						
						WordPress.ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатурыЗапас);
						
					КонецЕсли;
					
				КонецЦикла;
				
				Если ЗначениеЗаполнено(Стр_ТЗ_Заказы.ЗаказПокупателя) Тогда
					Если Стр_ТЗ_Заказы.shipping_total>0 Тогда
						
						Если Стр_ТЗ_Заказы.prices_include_tax Тогда
							СуммаДоставкиБезНДС = Стр_ТЗ_Заказы.shipping_total;
						Иначе	
							СуммаДоставкиБезНДС = Стр_ТЗ_Заказы.shipping_total - Стр_ТЗ_Заказы.shipping_tax;
						КонецЕсли;
						
						УслугаДоставки = Константы.WordPress_УслугаДоставки.Получить();
						СтруктураСтроки = Новый Структура("Номенклатура,Количество,Цена,Сумма,СуммаНДС,Всего,ДатаОтгрузки",
						УслугаДоставки,1,СуммаДоставкиБезНДС,СуммаДоставкиБезНДС,Стр_ТЗ_Заказы.shipping_tax,Стр_ТЗ_Заказы.shipping_total,Стр_ТЗ_Заказы.date_created);
						
						ТипНоменклатурыЗапас = НЕОПРЕДЕЛЕНО;
						Если ЗначениеЗаполнено(Стр_ТЧ_Запасы.Номенклатура) Тогда
							ТипНоменклатурыЗапас = (УслугаДоставки.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Запас);
						КонецЕсли;
						
						WordPress.ДобавитьСтрокуВТЧЗапасыЗаказаПокупателя(ЗаказПокупателя,СтруктураСтроки,ТипНоменклатурыЗапас);
						
					КонецЕсли;
					
					Если WordPress.ЗавершитьРаботуСЗаказом(Стр_ТЗ_Заказы.ЗаказПокупателя,Стр_ТЗ_Заказы.id) Тогда
						Стр_ТЗ_Заказы.Результат = "Удачно";
						
						Если (Стр_ТЗ_Заказы.payment_method = "cod") ИЛИ (Стр_ТЗ_Заказы.payment_method = "tbc_credit_card_gateway") Тогда
							Стр_ТЗ_Заказы.РасходнаяНакладная = WordPress.СоздатьРасходнуюНакладнуюНаОснованииЗаказаПокупателя(ЗаказПокупателя);
						КонецЕсли;
					Иначе
						Стр_ТЗ_Заказы.Результат = "Неудачно";
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат Новый ФиксированнаяСтруктура(Стр_ТЗ_Заказы);
КонецФункции

// Функция - Загрузить контрагентов
// Возвращает сформированную таблицу контрагентов. Передавать данные может только на сервере.
// Возвращаемое значение:
// ТЗ_Контрагенты - таблица значений - таблица контрагентов.
//
Функция ЗагрузитьКонтрагентов() ЭКСПОРТ
	ПЕРЕМ ДеревоОбъектов;
	
	ТЗ_Контрагенты = Новый ТаблицаЗначений();
	ТЗ_Контрагенты.Колонки.Добавить("id");
	ТЗ_Контрагенты.Колонки.Добавить("first_name");
	ТЗ_Контрагенты.Колонки.Добавить("last_name");
	ТЗ_Контрагенты.Колонки.Добавить("Контрагент");
	ТЗ_Контрагенты.Колонки.Добавить("personal_number");
	ТЗ_Контрагенты.Колонки.Добавить("email");
	ТЗ_Контрагенты.Колонки.Добавить("phone");
	
	СтруктураСоединения = WordPress.ПолучитьСтруктуруСоединения();
	
	АдресРесурса = "/wp-json/wc/v3/customers"+СтруктураСоединения.ПараметрыАутентификации;
	
	Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,1);
	Если Результат.КодСостояния = 200 Тогда
		
		Данные = Результат.Данные;
		Для каждого СтрДанные Из Данные Цикл
			
			Стр_ТЗ_Контрагенты = ТЗ_Контрагенты.Добавить();
			
			Стр_ТЗ_Контрагенты.id = СтрДанные.Получить("id");
			Стр_ТЗ_Контрагенты.first_name = СтрДанные.Получить("first_name");
			Стр_ТЗ_Контрагенты.last_name = СтрДанные.Получить("last_name");
			Стр_ТЗ_Контрагенты.email = СтрДанные.Получить("email");
			
			meta_data = СтрДанные.Получить("meta_data");
			Для каждого Стр_meta_data Из meta_data Цикл
				Если Стр_meta_data.Получить("key")="_personal_number" Тогда
					Стр_ТЗ_Контрагенты.personal_number = Стр_meta_data.Получить("value");					
				КонецЕсли;
			КонецЦикла;
			
			billing = СтрДанные.Получить("billing");
			Стр_ТЗ_Контрагенты.phone = billing.Получить("phone");
			Если НЕ ЗначениеЗаполнено(Стр_ТЗ_Контрагенты.email) Тогда
				Стр_ТЗ_Контрагенты.email = billing.Получить("email");
			КонецЕсли; 
			
			Стр_ТЗ_Контрагенты.Контрагент = WordPress.ПоискКонтрагента(Стр_ТЗ_Контрагенты.id,Стр_ТЗ_Контрагенты.personal_number,Стр_ТЗ_Контрагенты.email,Стр_ТЗ_Контрагенты.phone);
			
		КонецЦикла;
		
		КоличествоСтраниц = Число(Результат.КоличествоСтраниц);
		Если КоличествоСтраниц>1 Тогда
			
			и1=1;
			Пока и1<=КоличествоСтраниц Цикл
				и1 = и1+1;
				
				Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,и1);
				Если Результат.КодСостояния = 200 Тогда
					
					Данные = Результат.Данные;
					
					Если Данные.Количество()=0 Тогда
						Прервать;
					КонецЕсли;
					
					Для каждого СтрДанные Из Данные Цикл
						
						Стр_ТЗ_Контрагенты = ТЗ_Контрагенты.Добавить();
						
						Стр_ТЗ_Контрагенты.id = СтрДанные.Получить("id");
						Стр_ТЗ_Контрагенты.first_name = СтрДанные.Получить("first_name");
						Стр_ТЗ_Контрагенты.last_name = СтрДанные.Получить("last_name");
						Стр_ТЗ_Контрагенты.email = СтрДанные.Получить("email");
						
						meta_data = СтрДанные.Получить("meta_data");
						Для каждого Стр_meta_data Из meta_data Цикл
							Если Стр_meta_data.Получить("key")="_personal_number" Тогда
								Стр_ТЗ_Контрагенты.personal_number = Стр_meta_data.Получить("value");					
							КонецЕсли;
						КонецЦикла;
						
						billing = СтрДанные.Получить("billing");
						Стр_ТЗ_Контрагенты.phone = billing.Получить("phone");
						Если НЕ ЗначениеЗаполнено(Стр_ТЗ_Контрагенты.email) Тогда
							Стр_ТЗ_Контрагенты.email = billing.Получить("email");
						КонецЕсли; 
						
						Стр_ТЗ_Контрагенты.Контрагент = WordPress.ПоискКонтрагента(Стр_ТЗ_Контрагенты.id,Стр_ТЗ_Контрагенты.personal_number,Стр_ТЗ_Контрагенты.email,Стр_ТЗ_Контрагенты.phone);
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ТЗ_Контрагенты;
КонецФункции

