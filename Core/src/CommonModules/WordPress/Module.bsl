Процедура СформироватьДеревоJSON(ЧтениеJSON, Дерево) ЭКСПОРТ
    
    ИмяСвойства = НЕОПРЕДЕЛЕНО;
	
    Пока ЧтениеJSON.Прочитать() Цикл
        TипJSON = ЧтениеJSON.ТипТекущегоЗначения;
        
        Если TипJSON = ТипЗначенияJSON.НачалоОбъекта ИЛИ TипJSON = ТипЗначенияJSON.НачалоМассива Тогда
			
			НовыйОбъект = ?(TипJSON = ТипЗначенияJSON.НачалоОбъекта, Новый Соответствие, Новый Массив);
			
			Если Дерево = НЕОПРЕДЕЛЕНО Тогда
                Дерево = НовыйОбъект;
				СформироватьДеревоJSON(ЧтениеJSON, Дерево);
			Иначе
				Если ТипЗнч(Дерево) = Тип("Массив") Тогда
	                Дерево.Добавить(НовыйОбъект);
					СформироватьДеревоJSON(ЧтениеJSON, НовыйОбъект);
				Иначе
					Если ТипЗнч(Дерево) = Тип("Соответствие") И ЗначениеЗаполнено(ИмяСвойства) Тогда
						Дерево.Вставить(ИмяСвойства, НовыйОбъект);
						СформироватьДеревоJSON(ЧтениеJSON, НовыйОбъект);
					Иначе
						Дерево = НовыйОбъект;
						СформироватьДеревоJSON(ЧтениеJSON, Дерево);
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли TипJSON = ТипЗначенияJSON.ИмяСвойства Тогда
			
            ИмяСвойства = ЧтениеJSON.ТекущееЗначение;
			
			Если Дерево = НЕОПРЕДЕЛЕНО Тогда
				Дерево = Новый Соответствие;
			КонецЕсли;
			
		ИначеЕсли TипJSON = ТипЗначенияJSON.Число ИЛИ TипJSON = ТипЗначенияJSON.Строка ИЛИ TипJSON = ТипЗначенияJSON.Булево ИЛИ TипJSON = ТипЗначенияJSON.Null Тогда
			
            Если ТипЗнч(Дерево) = Тип("Массив") Тогда
                Дерево.Добавить(ЧтениеJSON.ТекущееЗначение);
            ИначеЕсли ТипЗнч(Дерево) = Тип("Соответствие") Тогда
                Дерево.Вставить(ИмяСвойства, ЧтениеJSON.ТекущееЗначение);
			КонецЕсли;
			
		Иначе
			
            Возврат;
			
        КонецЕсли;
    КонецЦикла;
    
КонецПроцедуры

Функция ДатаJSON(Date) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = НЕОПРЕДЕЛЕНО;
	
	Попытка
		РЕЗ = ПрочитатьДатуJSON(Date, ФорматДатыJSON.ISO);
	Исключение
		Попытка
			РЕЗ = ПрочитатьДатуJSON(Date, ФорматДатыJSON.JavaScript);
		Исключение
			Попытка
				РЕЗ = ПрочитатьДатуJSON(Date, ФорматДатыJSON.Microsoft);
			Исключение
				РЕЗ = НЕОПРЕДЕЛЕНО;
			КонецПопытки;
		КонецПопытки;
	КонецПопытки;

	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиИлиСоздатьДополнительныйРеквизит(Заголовок,НаборыДополнительныхРеквизитовИСведений,ТекОписаниеТипа) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	РЕЗ=НЕОПРЕДЕЛЕНО;
	
	Если НЕ ЗначениеЗаполнено(НаборыДополнительныхРеквизитовИСведений) Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	//Если НЕ НаборыДополнительныхРеквизитовИСведений.Используется Тогда
	//	Попытка
	//		НаборыДополнительныхРеквизитовИСведенийОбъект = НаборыДополнительныхРеквизитовИСведений.ПолучитьОбъект();
	//		НаборыДополнительныхРеквизитовИСведенийОбъект.Используется = ИСТИНА;
	//		НаборыДополнительныхРеквизитовИСведенийОбъект.Записать();
	//	Исключение
	//	КонецПопытки;
	//КонецЕсли;	
	
	Запрос = Новый Запрос;
	//Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	//               |	ДополнительныеРеквизитыИСведения.Ссылка КАК ТекДопРеквизит
	//               |ИЗ
	//               |	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	//               |ГДЕ
	//               |	ДополнительныеРеквизитыИСведения.Наименование = &Заголовок
	//               |	И ДополнительныеРеквизитыИСведения.ТипЗначения = &НаборСвойств";
	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты.Свойство КАК ТекДопРеквизит
	               |ИЗ
	               |	Справочник.НаборыДополнительныхРеквизитовИСведений.ДополнительныеРеквизиты КАК НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты
	               |ГДЕ
	               |	НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты.Ссылка = &НаборСвойств
	               |	И НаборыДополнительныхРеквизитовИСведенийДополнительныеРеквизиты.Свойство.Наименование = &Заголовок";

	
	Запрос.УстановитьПараметр("Заголовок", Заголовок);
	Запрос.УстановитьПараметр("НаборСвойств", НаборыДополнительныхРеквизитовИСведений);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РЕЗ = ВыборкаДетальныеЗаписи.ТекДопРеквизит;
	КонецЦикла;
	
	Если РЕЗ=НЕОПРЕДЕЛЕНО Тогда	
		РЕЗ = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.СоздатьЭлемент();
		РЕЗ.Наименование = Заголовок;
		РЕЗ.ТипЗначения = ТекОписаниеТипа;
		//РЕЗ.Виден = ИСТИНА;
		//РЕЗ.Доступен = ИСТИНА;
		//РЕЗ.Заголовок = Заголовок;
		//РЕЗ.НаборСвойств = НаборыДополнительныхРеквизитовИСведений;
		//РЕЗ.Комментарий = Заголовок;
		РЕЗ.Записать();
	КонецЕсли;
	
	СтруктураПоиска = Новый Структура("Свойство", РЕЗ.Ссылка);
	МассивСтрок = НаборыДополнительныхРеквизитовИСведений.ДополнительныеРеквизиты.НайтиСтроки(СтруктураПоиска);
	Если МассивСтрок.Количество()=0 Тогда
		НаборыДополнительныхРеквизитовИСведений_Объект=НаборыДополнительныхРеквизитовИСведений.ПолучитьОбъект();
		стрТаб_ДополнительныеРеквизиты=НаборыДополнительныхРеквизитовИСведений_Объект.ДополнительныеРеквизиты.Добавить();
		стрТаб_ДополнительныеРеквизиты.Свойство=РЕЗ.Ссылка;
		НаборыДополнительныхРеквизитовИСведений_Объект.Записать();
	КонецЕсли;			
	
	Возврат РЕЗ.Ссылка;
КонецФункции

Процедура УстановитьДополнительныйРеквизит(ТекОбъект, СвойствоДополнительногоРеквизита, ЗначениеДополнительногоРеквизита) ЭКСПОРТ

	СтрукутраПоиска = Новый Структура("Свойство", СвойствоДополнительногоРеквизита);
	МассивСтрок = ТекОбъект.ДополнительныеРеквизиты.НайтиСтроки(СтрукутраПоиска);
	Если МассивСтрок.Количество()=0 Тогда
		СтрДополнительныеРеквизиты = ТекОбъект.ДополнительныеРеквизиты.Добавить();
		СтрДополнительныеРеквизиты.Свойство = СвойствоДополнительногоРеквизита;
	Иначе
		СтрДополнительныеРеквизиты = МассивСтрок[0];
	КонецЕсли;
	СтрДополнительныеРеквизиты.Значение = ЗначениеДополнительногоРеквизита;

КонецПроцедуры

Функция НайтиЗначениеДополнительногоРеквизита(ТекОбъект, СвойствоДополнительногоРеквизита) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НЕ ТекОбъект.Метаданные().ТабличныеЧасти.Найти("ДополнительныеРеквизиты")=НЕОПРЕДЕЛЕНО Тогда
		Для каждого СтрДополнительныеРеквизиты Из ТекОбъект["ДополнительныеРеквизиты"] Цикл
			Если СтрДополнительныеРеквизиты.Свойство = СвойствоДополнительногоРеквизита Тогда
				РЕЗ = СтрДополнительныеРеквизиты.Значение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция СтруктураДополнительныхРеквизитов(НаборыДополнительныхРеквизитовИСведений) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НаборыДополнительныхРеквизитовИСведений = Справочники.НаборыДополнительныхРеквизитовИСведений.Документ_ЗаказПокупателя Тогда
		//РЕЗ = Новый Структура("id, order_key, number, customer_id, first_name, last_name, company, personal_number, email, phone");  //+++ Дмгг
		РЕЗ = Новый Структура("id, order_key, number, customer_id, first_name, last_name, company, personal_number, email, phone, payment_method_title"); //+++ Дмгг
		
		РЕЗ.id  = НайтиИлиСоздатьДополнительныйРеквизит("id",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0)));
		РЕЗ.order_key  = НайтиИлиСоздатьДополнительныйРеквизит("order_key",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.number  = НайтиИлиСоздатьДополнительныйРеквизит("number",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.customer_id  = НайтиИлиСоздатьДополнительныйРеквизит("customer_id",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0)));
		РЕЗ.first_name  = НайтиИлиСоздатьДополнительныйРеквизит("first_name",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.last_name  = НайтиИлиСоздатьДополнительныйРеквизит("last_name",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.company  = НайтиИлиСоздатьДополнительныйРеквизит("company",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.personal_number  = НайтиИлиСоздатьДополнительныйРеквизит("personal_number",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.email  = НайтиИлиСоздатьДополнительныйРеквизит("email",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.phone  = НайтиИлиСоздатьДополнительныйРеквизит("phone",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка"));
		РЕЗ.payment_method_title  = НайтиИлиСоздатьДополнительныйРеквизит("payment_method_title",НаборыДополнительныхРеквизитовИСведений,Новый ОписаниеТипов("Строка")); //+++ Дмгг
				
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ПолучитьМассивОбъектов(Соединение,Заголовки,ИмяФайлаОтвета,АдресРесурса,НомерСтраницы=НЕОПРЕДЕЛЕНО,МетодЗапроса="GET") ЭКСПОРТ
	ПЕРЕМ РЕЗ,Данные;
	
	РЕЗ = Новый Структура("КодСостояния,КоличествоСтраниц,Данные");
	
	Запрос = Новый HTTPЗапрос();
	Запрос.АдресРесурса = АдресРесурса;
	Запрос.АдресРесурса = Запрос.АдресРесурса+"&page="+НомерСтраницы;
	Запрос.Заголовки = Заголовки;
	
	//Результат = Соединение.Получить(Запрос);
	Результат = Соединение.ВызватьHTTPМетод(МетодЗапроса, Запрос);
	
	РЕЗ.КодСостояния = Результат.КодСостояния;
	
	Если Результат.КодСостояния = 200 Тогда
		
		Если ЗначениеЗаполнено(НомерСтраницы) Тогда
			//РЕЗ.КоличествоСтраниц = Число(Результат.Заголовки.Получить("X-WP-TotalPages"));
			Для каждого ТекЗаголовок Из Результат.Заголовки Цикл
				Если НРЕГ(ТекЗаголовок.Ключ)="x-wp-totalpages" Тогда
					РЕЗ.КоличествоСтраниц = Число(ТекЗаголовок.Значение);
					Прервать;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;
		
		ТелоЗапроса = Результат.ПолучитьТелоКакСтроку();
		
		ТекстОтвета = Новый ЧтениеJSON();
		ТекстОтвета.УстановитьСтроку(ТелоЗапроса);
		
		СформироватьДеревоJSON(ТекстОтвета, Данные);
		
		РЕЗ.Данные = Данные;
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция ПолучитьСтруктуруСоединения() ЭКСПОРТ
	ПЕРЕМ РЕЗ;

	WordPress_Host = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройкиЭлементовДляРасширений("WordPress_Host");//СокрЛП(Константы.WordPress_Host.Получить());
	WordPress_Consumer_key = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройкиЭлементовДляРасширений("WordPress_Consumer_key");//СокрЛП(Константы.WordPress_Consumer_key.Получить());
	WordPress_Consumer_secret = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройкиЭлементовДляРасширений("WordPress_Consumer_secret");//СокрЛП(Константы.WordPress_Consumer_secret.Получить());
	ПараметрыАутентификации = "?consumer_key="+WordPress_Consumer_key+"&consumer_secret="+WordPress_Consumer_secret;
	
	SSL = ИнтеграцияСНалоговойСлужбыПовтИсп.ПолучитьЗащищенноеСоединение();
	Соединение = Новый HTTPСоединение(WordPress_Host,,,,,,SSL);
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Host", WordPress_Host);
	Заголовки.Вставить("Content-type", "application/json");
	Заголовки.Вставить("charset", "utf-8");
	
	ИмяФайлаОтвета = ПолучитьИмяВременногоФайла();
	
	РЕЗ = Новый Структура("Соединение,ПараметрыАутентификации,Заголовки,ИмяФайлаОтвета", Соединение,ПараметрыАутентификации,Заголовки,ИмяФайлаОтвета);

	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиКонтрагентаВРегистре_СопоставлениеКонтрагентовWordPress(id) ЭКСПОРТ
	ПЕРЕМ РЕЗ;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СопоставлениеКонтрагентовWordPress.Контрагент
		|ИЗ
		|	РегистрСведений.СопоставлениеКонтрагентовWordPress КАК СопоставлениеКонтрагентовWordPress
		|ГДЕ
		|	СопоставлениеКонтрагентовWordPress.id = &id";
	
	Запрос.УстановитьПараметр("id", id);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РЕЗ = ВыборкаДетальныеЗаписи.Контрагент
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиКонтрагентаВБазеПоИНН(ТекИНН) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НЕ ЗначениеЗаполнено(ТекИНН) Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	ИНН = СокрЛП(ТекИНН);
	Если СтрДлина(СокрЛП(ТекИНН))=0 Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ИНН = &ИНН";
	
	Запрос.УстановитьПараметр("ИНН", ИНН);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РЕЗ = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиКонтрагентаВБазеПоТелефону(Текphone) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НЕ ЗначениеЗаполнено(Текphone) Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	phone = СокрЛП(Текphone);
	Если СтрДлина(СокрЛП(phone))=0 Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КонтрагентыКонтактнаяИнформация.Ссылка
		|ИЗ
		|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|ГДЕ
		|	КонтрагентыКонтактнаяИнформация.НомерТелефона = &НомерТелефона
		|	ИЛИ КонтрагентыКонтактнаяИнформация.НомерТелефонаБезКодов = &НомерТелефона";
	
	Запрос.УстановитьПараметр("НомерТелефона", phone);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		РЕЗ = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат РЕЗ;
КонецФункции // ()

Функция НайтиКонтрагентаВБазеПоEMAIL(Текemail) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	Если НЕ ЗначениеЗаполнено(Текemail) Тогда
		Возврат РЕЗ;
	КонецЕсли;
	
