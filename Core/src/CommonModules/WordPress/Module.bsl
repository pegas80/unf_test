Процедура РегламентноеЗадание_WordPress_Выгрузка_Остатков() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =	
		"ВЫБРАТЬ
		|	ЗапасыОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыОстатки.ЗаказПокупателя КАК ЗаказПокупателя,
		|	ЗапасыОстатки.КоличествоОстаток КАК КоличествоОстаток
		|ПОМЕСТИТЬ ВременнаяТаблицаРезервы
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(
		|			,
		|			ЗаказПокупателя ССЫЛКА Документ.ЗаказПокупателя
		|				И НЕ ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЗапасыОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыОстатки.КоличествоОстаток КАК Остаток,
		|	0 КАК Резерв
		|ПОМЕСТИТЬ ВременнаяТаблицаОстаткиИРезервы
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(, СтруктурнаяЕдиница = &СтруктурнаяЕдиница) КАК ЗапасыОстатки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Резервы.Номенклатура,
		|	0,
		|	Резервы.КоличествоОстаток
		|ИЗ
		|	ВременнаяТаблицаРезервы КАК Резервы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Остатки.Номенклатура,
		|	ЕСТЬNULL(СУММА(Остатки.Остаток), 0) - ЕСТЬNULL(СУММА(Остатки.Резерв), 0) КАК СвободныйОстаток
		|ПОМЕСТИТЬ ВременнаяТаблицаОстаткиРезервы
		|ИЗ
		|	ВременнаяТаблицаОстаткиИРезервы КАК Остатки
		|
		|СГРУППИРОВАТЬ ПО
		|	Остатки.Номенклатура
		|
		|ИМЕЮЩИЕ
		|	ЕСТЬNULL(СУММА(Остатки.Остаток), 0) - ЕСТЬNULL(СУММА(Остатки.Резерв), 0) > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СопоставлениеНоменклатурыWordPress.id,
		|	СопоставлениеНоменклатурыWordPress.Номенклатура,
		|	ЕСТЬNULL(Остатки.СвободныйОстаток, 0) КАК СвободныйОстаток
		|ИЗ
		|	РегистрСведений.СопоставлениеНоменклатурыWordPress КАК СопоставлениеНоменклатурыWordPress
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаОстаткиРезервы КАК Остатки
		|		ПО СопоставлениеНоменклатурыWordPress.Номенклатура = Остатки.Номенклатура";
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница",Константы.WordPress_Склад.Получить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтруктураСоединения = WordPress.ПолучитьСтруктуруСоединения();
		
		АдресРесурса = "/wp-json/wc/v3/products/"+Формат(ВыборкаДетальныеЗаписи.id, "ЧДЦ=0; ЧГ=")+СтруктураСоединения.ПараметрыАутентификации;
		
		Запрос = Новый HTTPЗапрос();
		Запрос.АдресРесурса = АдресРесурса;
		Запрос.Заголовки = СтруктураСоединения.Заголовки;
		
		СтруктураЗапроса = Новый Структура("stock_quantity,stock_status,manage_stock");
		СтруктураЗапроса.stock_quantity = ВыборкаДетальныеЗаписи.СвободныйОстаток;
		СтруктураЗапроса.manage_stock = ИСТИНА;
		Если ВыборкаДетальныеЗаписи.СвободныйОстаток>0 Тогда
			СтруктураЗапроса.stock_status="instock";
		Иначе
			СтруктураЗапроса.stock_status="outofstock";
		КонецЕсли;
		
		ТелоЗапроса = Новый ЗаписьJSON();
		ТелоЗапроса.УстановитьСтроку();
		ЗаписатьJSON(ТелоЗапроса, СтруктураЗапроса);
		ТелоЗапроса = ТелоЗапроса.Закрыть();
		
		Запрос.УстановитьТелоИзСтроки(ТелоЗапроса,КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		
		Результат = СтруктураСоединения.Соединение.ВызватьHTTPМетод("POST", Запрос);
		
		Если НЕ Результат.КодСостояния = 200 Тогда
			Сообщить("Не удалось выгрузить на сайт остаток для товара " + ВыборкаДетальныеЗаписи.Номенклатура + " с id=" + ВыборкаДетальныеЗаписи.id);			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

