				и1 = и1+1;
				
				Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,и1);
				Если Результат.КодСостояния = 200 Тогда
					
					Данные = Результат.Данные;
					
					Если Данные.Количество()=0 Тогда
						Прервать;
					КонецЕсли;
					
					Для каждого СтрДанные Из Данные Цикл
						
						Стр_ТЗ_Товары = ТЗ_Товары.Добавить();
						
						Стр_ТЗ_Товары.id = СтрДанные.Получить("id");
						Стр_ТЗ_Товары.name = СтрДанные.Получить("name");
						Стр_ТЗ_Товары.slug = СтрДанные.Получить("slug");
						Стр_ТЗ_Товары.type = СтрДанные.Получить("type");
						Стр_ТЗ_Товары.status = СтрДанные.Получить("status");
						Стр_ТЗ_Товары.catalog_visibility = СтрДанные.Получить("catalog_visibility");
						Стр_ТЗ_Товары.description = СтрДанные.Получить("description");
						Стр_ТЗ_Товары.sku = СтрДанные.Получить("sku");
						Стр_ТЗ_Товары.price = СтрДанные.Получить("price");
						Стр_ТЗ_Товары.tax_status = СтрДанные.Получить("tax_status");
						Стр_ТЗ_Товары.stock_quantity = СтрДанные.Получить("stock_quantity");
						Стр_ТЗ_Товары.stock_status = СтрДанные.Получить("stock_status");
						Стр_ТЗ_Товары.lang = СтрДанные.Получить("lang");
						Стр_ТЗ_Товары.Номенклатура = WordPress.НайтиТоварВРегистре_СопоставлениеНоменклатурыWordPress(Стр_ТЗ_Товары.id);
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ТЗ_Товары;
КонецФункции

Функция ЗагрузитьТоварПо_id(id) ЭКСПОРТ
	ПЕРЕМ РЕЗ, ДеревоОбъектов;
	
	// Попытаемся получить данные товара по id
	Стр_ТЗ_Товары = Новый Структура();
	Стр_ТЗ_Товары.Вставить("id");
	Стр_ТЗ_Товары.Вставить("name");
	Стр_ТЗ_Товары.Вставить("slug");
	Стр_ТЗ_Товары.Вставить("type");
	Стр_ТЗ_Товары.Вставить("status");
	Стр_ТЗ_Товары.Вставить("catalog_visibility");
	Стр_ТЗ_Товары.Вставить("description");
	Стр_ТЗ_Товары.Вставить("sku");
	Стр_ТЗ_Товары.Вставить("price");
	Стр_ТЗ_Товары.Вставить("tax_status");
	Стр_ТЗ_Товары.Вставить("stock_quantity");
	Стр_ТЗ_Товары.Вставить("stock_status");
	Стр_ТЗ_Товары.Вставить("lang");
	Стр_ТЗ_Товары.Вставить("Номенклатура");
	
	СтруктураСоединения = WordPress.ПолучитьСтруктуруСоединения();
	
	АдресРесурса = "/wp-json/wc/v3/products/"+Формат(id, "ЧДЦ=0; ЧГ=")+СтруктураСоединения.ПараметрыАутентификации;
	
	Результат = WordPress.ПолучитьМассивОбъектов(СтруктураСоединения.Соединение,СтруктураСоединения.Заголовки,СтруктураСоединения.ИмяФайлаОтвета,АдресРесурса,НЕОПРЕДЕЛЕНО,"POST");
	Если Результат.КодСостояния = 200 Тогда
		
		СтрДанные = Результат.Данные;
		
		Стр_ТЗ_Товары.id = СтрДанные.Получить("id");
		Стр_ТЗ_Товары.name = СтрДанные.Получить("name");
		Стр_ТЗ_Товары.slug = СтрДанные.Получить("slug");
		Стр_ТЗ_Товары.type = СтрДанные.Получить("type");
		Стр_ТЗ_Товары.status = СтрДанные.Получить("status");
		Стр_ТЗ_Товары.catalog_visibility = СтрДанные.Получить("catalog_visibility");
		Стр_ТЗ_Товары.description = СтрДанные.Получить("description");
		Стр_ТЗ_Товары.sku = СтрДанные.Получить("sku");
		Стр_ТЗ_Товары.price = СтрДанные.Получить("price");
		Стр_ТЗ_Товары.tax_status = СтрДанные.Получить("tax_status");
		Стр_ТЗ_Товары.stock_quantity = СтрДанные.Получить("stock_quantity");
		Стр_ТЗ_Товары.stock_status = СтрДанные.Получить("stock_status");
		Стр_ТЗ_Товары.lang = СтрДанные.Получить("lang");
		
		Если СтрДлина(СокрЛП(Стр_ТЗ_Товары.sku))>0 Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Номенклатура.Ссылка КАК Номенклатура
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			//|	(ВЫРАЗИТЬ(Номенклатура.Артикул КАК СТРОКА(25))) = (ВЫРАЗИТЬ(&sku КАК СТРОКА(25)))";
			|	Номенклатура.Артикул = &sku";
			
			Запрос.УстановитьПараметр("sku", СокрЛП(Стр_ТЗ_Товары.sku));
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Стр_ТЗ_Товары.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
			КонецЦикла;	
			
			Если ЗначениеЗаполнено(Стр_ТЗ_Товары.Номенклатура) Тогда
				// Запишем в регистр соответствия
				НаборЗаписей = РегистрыСведений.СопоставлениеНоменклатурыWordPress.СоздатьНаборЗаписей(); 
				
				НаборЗаписей.Отбор.id.Установить(Стр_ТЗ_Товары.id); 
				
				НоваяЗапись = НаборЗаписей.Добавить(); 
				НоваяЗапись.Номенклатура = Стр_ТЗ_Товары.Номенклатура; 
				НоваяЗапись.id = Стр_ТЗ_Товары.id; 
				
				НаборЗаписей.Записать(ИСТИНА);
							
			КонецЕсли;
			
		КонецЕсли;
						
	КонецЕсли;
	
	РЕЗ = Стр_ТЗ_Товары.Номенклатура;
	
	Возврат РЕЗ;
КонецФункции

