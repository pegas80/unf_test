Функция СоздатьИлиНайтиКонтрагента(id, company, name, personal_number, email, phone, СтрокаАдрес, ТипНалогообложенияНДС, Валюта, ЗаказПокупателя) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = WordPress.ПоискКонтрагента(id,personal_number,email,phone);
	Если НЕ ЗначениеЗаполнено(РЕЗ) Тогда
	
		НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
		
		ГруппаДляНовыхКонтрагентов = Константы.WordPress_ГруппаДляНовыхКонтрагентов.Получить();
		Если ЗначениеЗаполнено(ГруппаДляНовыхКонтрагентов) Тогда
			НовыйКонтрагент.Родитель = ГруппаДляНовыхКонтрагентов;
		КонецЕсли;
		
		Если СтрДлина(СокрЛП(company))>0 Тогда
			НовыйКонтрагент.Наименование = СокрЛП(company);
			НовыйКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
		Иначе
			НовыйКонтрагент.Наименование = СокрЛП(name);
			НовыйКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
		КонецЕсли;
		
		НовыйКонтрагент.НаименованиеПолное = НовыйКонтрагент.Наименование;
		
		Если СтрДлина(СокрЛП(personal_number))>=11 Тогда
			НовыйКонтрагент.ИНН = СокрЛП(personal_number);
		КонецЕсли;
		
		НовыйКонтрагент.ТипНалогообложенияНДС = ТипНалогообложенияНДС;
		Если НЕ ЗначениеЗаполнено(НовыйКонтрагент.ТипНалогообложенияНДС) Тогда
			НовыйКонтрагент.ТипНалогообложенияНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
		КонецЕсли;
		
		НовыйКонтрагент.ВестиРасчетыПоДоговорам = Истина;
		НовыйКонтрагент.ВестиРасчетыПоДокументам = Истина;
		НовыйКонтрагент.ВестиРасчетыПоЗаказам = Истина;
		НовыйКонтрагент.ВестиУчетОплатыПоСчетам = Истина;
		
		НовыйКонтрагент.СчетУчетаРасчетовСПокупателем = ПланыСчетов.Управленческий.РасчетыСПокупателями;
		НовыйКонтрагент.СчетУчетаАвансовПокупателя = ПланыСчетов.Управленческий.РасчетыПоАвансамПолученным;
		НовыйКонтрагент.СчетУчетаРасчетовСПоставщиком = ПланыСчетов.Управленческий.РасчетыСПоставщиками;
		НовыйКонтрагент.СчетУчетаАвансовПоставщику = ПланыСчетов.Управленческий.РасчетыПоАвансамВыданным;
		
		НовыйКонтрагент.АдресЭП = email;
		
		Если СтрДлина(СокрЛП(personal_number))<11 Тогда
			
			СтрКонтактнаяИнформация = НовыйКонтрагент.КонтактнаяИнформация.Добавить();
			СтрКонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			СтрКонтактнаяИнформация.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
			СтрКонтактнаяИнформация.ЗначенияПолей = "НомерТелефона="+СокрЛП(personal_number);
			СтрКонтактнаяИнформация.Представление = СокрЛП(personal_number);
			СтрКонтактнаяИнформация.НомерТелефона = СокрЛП(personal_number);		
			
		КонецЕсли;
		
		Если СтрДлина(СокрЛП(phone))>0 Тогда
			
			СтрКонтактнаяИнформация = НовыйКонтрагент.КонтактнаяИнформация.Добавить();
			СтрКонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			СтрКонтактнаяИнформация.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
			СтрКонтактнаяИнформация.ЗначенияПолей = "НомерТелефона="+СокрЛП(phone);
			СтрКонтактнаяИнформация.Представление = СокрЛП(phone);
			СтрКонтактнаяИнформация.НомерТелефона = СокрЛП(phone);		
			
		КонецЕсли;
		
		Если СтрДлина(СокрЛП(email))>0 Тогда
		
			СтрКонтактнаяИнформация = НовыйКонтрагент.КонтактнаяИнформация.Добавить();
			СтрКонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			СтрКонтактнаяИнформация.Вид = Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
			СтрКонтактнаяИнформация.Представление = СокрЛП(email);
			СтрКонтактнаяИнформация.АдресЭП = СокрЛП(email);
			Поз = Найти(СтрКонтактнаяИнформация.АдресЭП, "@");
			Если Поз <> 0 Тогда
				СтрКонтактнаяИнформация.ДоменноеИмяСервера = Сред(СтрКонтактнаяИнформация.АдресЭП, Поз+1);
				
				Если НЕ ЗначениеЗаполнено(НовыйКонтрагент.Наименование) Тогда
					НовыйКонтрагент.Наименование = ЛЕВ(СтрКонтактнаяИнформация.АдресЭП, Поз-1);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрДлина(СокрЛП(СтрокаАдрес))>0 Тогда
			
			СтрКонтактнаяИнформация = НовыйКонтрагент.КонтактнаяИнформация.Добавить();
			СтрКонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
			СтрКонтактнаяИнформация.Вид = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента;
			СтрКонтактнаяИнформация.Представление = СокрЛП(СтрокаАдрес);
			
		КонецЕсли;
		
		Попытка
		
			НовыйКонтрагент.Записать();
			РЕЗ = НовыйКонтрагент.Ссылка;
		
		Исключение
		
		КонецПопытки;
		
		Если ЗначениеЗаполнено(НовыйКонтрагент.Ссылка) И ЗначениеЗаполнено(id) Тогда
			НаборЗаписей = РегистрыСведений.СопоставлениеКонтрагентовWordPress.СоздатьНаборЗаписей(); 
			
			НаборЗаписей.Отбор.id.Установить(id); 
			
			НоваяЗапись = НаборЗаписей.Добавить(); 
			НоваяЗапись.Контрагент = НовыйКонтрагент.Ссылка; 
			НоваяЗапись.id = id; 
			
			НаборЗаписей.Записать(ИСТИНА);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НовыйКонтрагент.Ссылка) Тогда
		
			НовыйДоговор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
			НовыйДоговор.Владелец = НовыйКонтрагент.Ссылка;
			НовыйДоговор.Наименование = "ნაგულისხმევი";
			НовыйДоговор.Организация = Справочники.Организации.ОсновнаяОрганизация;
			НовыйДоговор.ВидДоговора = Перечисления.ВидыДоговоров.СПокупателем;
			НовыйДоговор.ВалютаРасчетов = Валюта;
			Если НЕ ЗначениеЗаполнено(НовыйДоговор.ВалютаРасчетов) Тогда
				НовыйДоговор.ВалютаРасчетов = Константы.ВалютаУчета.Получить();
			КонецЕсли;
			НовыйДоговор.ТипНалогообложенияНДС = НовыйКонтрагент.ТипНалогообложенияНДС;
			НовыйДоговор.Адрес = СокрЛП(СтрокаАдрес);
			
			Попытка
			
				НовыйДоговор.Записать();
				НовыйКонтрагент.ДоговорПоУмолчанию = НовыйДоговор.Ссылка;
				НовыйКонтрагент.Записать();
			
			Исключение
			
			КонецПопытки;
		
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ЗаказПокупателя) Тогда
			
			ЗаказПокупателяОбъект = ЗаказПокупателя.ПолучитьОбъект();
			
			ЗаказПокупателяОбъект.Контрагент = НовыйКонтрагент.Ссылка;
			ЗаказПокупателяОбъект.Договор = НовыйДоговор.Ссылка;
			
			ЗаказПокупателяОбъект.ОбменДанными.Загрузка = ИСТИНА;
			ЗаказПокупателяОбъект.Записать(РежимЗаписиДокумента.Запись);
		
		КонецЕсли;
			
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции // ()

