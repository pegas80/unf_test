
//Проверяет уникальность реквизита
Функция РеквизитУникален(Ссылка, РеквизитИмя, РеквизитЗначение, ИмяСправочника) Экспорт
	
	Если Не ЗначениеЗаполнено(РеквизитЗначение) Тогда
		Возврат Истина; 
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ ПЕРВЫЕ 1
					|	Мета.Ссылка
					|ИЗ
					|	Справочник." + ИмяСправочника + " КАК Мета
		            |ГДЕ
		            |	НЕ Мета.Ссылка = &Ссылка
					|	И НЕ Мета.ПометкаУдаления
		            |	И Мета." + РеквизитИмя + " = &РеквизитЗначение";
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("РеквизитЗначение",	РеквизитЗначение);
	
	Возврат Запрос.Выполнить().Пустой();
					
КонецФункции

Функция получитьДопСвойство(ТекОбъект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)  Экспорт
	
	Перем ЗначениеСвойства;
	
	Если Не ТекОбъект.ДополнительныеСвойства.Свойство(ИмяСвойства, ЗначениеСвойства) Тогда
		ЗначениеСвойства = ЗначениеПоУмолчанию; 			
	КонецЕсли;
	
	Возврат ЗначениеСвойства;	
		
КонецФункции


Процедура ИзменитьЭлементОтбораСписка(Список, ИмяПоля, ПравоеЗначение = Неопределено, Установить = Ложь, ВидСравнения = Неопределено, ОтборПоПериоду = Ложь) Экспорт
	
	УдалитьЭлементОтбораСписка(Список, ИмяПоля);
	
	Если Установить Тогда
		Если ОтборПоПериоду Тогда
			УстановитьЭлементОтбораСписка(Список, ИмяПоля, ПравоеЗначение.ДатаНачала, ВидСравненияКомпоновкиДанных.БольшеИлиРавно);
			УстановитьЭлементОтбораСписка(Список, ИмяПоля, ПравоеЗначение.ДатаОкончания, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);		
		Иначе
		    УстановитьЭлементОтбораСписка(Список, ИмяПоля, ПравоеЗначение, ВидСравнения);	
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры // ИзменитьЭлементОтбораСписка()
Процедура УдалитьЭлементОтбораСписка(Список, ИмяПоля) Экспорт
	
	ПолеКомпоновки = Новый ПолеКомпоновкиДанных(ИмяПоля);
	Счетчик = 1;
	Пока Счетчик <= Список.Отбор.Элементы.Количество() Цикл
		ЭлементОтбора = Список.Отбор.Элементы[Счетчик - 1];
		Если ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных")
			И ЭлементОтбора.ЛевоеЗначение = ПолеКомпоновки Тогда
			Список.Отбор.Элементы.Удалить(ЭлементОтбора);
		Иначе
			Счетчик = Счетчик + 1;
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры // УдалитьЭлементОтбораСписка()
Процедура УстановитьЭлементОтбораСписка(Список, ИмяПоля, ПравоеЗначение, ВидСравнения = Неопределено) Экспорт
	
	ЭлементОтбора = Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение    = Новый ПолеКомпоновкиДанных(ИмяПоля);
	ЭлементОтбора.ВидСравнения     = ?(ВидСравнения = Неопределено, ВидСравненияКомпоновкиДанных.Равно, ВидСравнения);
	ЭлементОтбора.Использование    = Истина;
	ЭлементОтбора.ПравоеЗначение   = ПравоеЗначение;
	ЭлементОтбора.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	
КонецПроцедуры // УстановитьЭлементОтбораСписка()

Функция ПолучитьЗначениеРеквизита(Ссылка, ИмяРеквизита) Экспорт
	Возврат Ссылка[ИмяРеквизита];
КонецФункции

Функция ПолучитьЗначенияРеквизитов(Ссылка, Реквизиты) Экспорт

	МассивИменРеквизитов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(Реквизиты, ",");
	
	СтруктураРеквизитов = Новый Структура;
	Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
		СтруктураРеквизитов.Вставить(ИмяРеквизита, Ссылка[ИмяРеквизита]);
	КонецЦикла;
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

Функция ПолучитьСкладПоАдресу(Адрес) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка КАК Склад
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.КонтактнаяИнформация КАК СтруктурныеЕдиницыКонтактнаяИнформация
		|ГДЕ
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы)
		|	И СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)
		|	И СтруктурныеЕдиницыКонтактнаяИнформация.Представление = &Адрес";
	Запрос.УстановитьПараметр("Адрес", Адрес);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Склад;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции


Функция ПредставлениеНоменклатуры(Номенклатура, Характеристика, Серия) Экспорт

	СтрПредставление = СокрЛП(Номенклатура.Наименование);

	Если ЗначениеЗаполнено(Характеристика)Тогда
		СтрПредставление = СтрПредставление + " / " + СокрЛП(Характеристика.Наименование);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Серия) Тогда
		СтрПредставление = СтрПредставление + " / " + СокрЛП(Серия.Наименование);
	КонецЕсли;

	Возврат СтрПредставление;

КонецФункции

Процедура ЗаполнитьЦену(СтрокаТЧ, ВидЦены) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(ВидЦены) ИЛИ НЕ ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
		СтрокаТЧ.Цена     = 0;
		СтрокаТЧ.Сумма    = 0;
		СтрокаТЧ.СуммаНДС = 0;
		Возврат;
	КонецЕсли;
	
	Цены = РегистрыСведений.ЦеныНоменклатуры.СрезПоследних(, Новый Структура("ВидЦен, Номенклатура, Характеристика", ВидЦены, СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));
	Если Не Цены.Количество() = 0 Тогда
		СтрокаТЧ.СтавкаНДС	= СтрокаТЧ.Номенклатура.СтавкаНДС;
		СтавкаНДС = СтрокаТЧ.СтавкаНДС.Ставка;
		СтрокаТЧ.Цена     	= Цены[0].Цена;
		СтрокаТЧ.Сумма    	= СтрокаТЧ.Количество * СтрокаТЧ.Цена;
		СтрокаТЧ.СуммаНДС 	= Окр(СтрокаТЧ.Сумма  * СтавкаНДС/(100 + СтавкаНДС), 2);
	Иначе
		СтрокаТЧ.Цена     = 0;
		СтрокаТЧ.Сумма    = 0;
		СтрокаТЧ.СуммаНДС = 0;
	КонецЕсли;
		
КонецПроцедуры

Функция ПолучитьФИОФизЛиц(ФизЛицо, Дата = Неопределено) Экспорт
	
	Если Дата = Неопределено Тогда
		Дата = ТекущаяДата();
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФИОФизЛицСрезПоследних.Имя + "" "" + ФИОФизЛицСрезПоследних.Фамилия КАК ИмяФамилия
		|ИЗ
		|	РегистрСведений.ФИОФизЛиц.СрезПоследних(&Дата, ФизЛицо = &ФизЛицо) КАК ФИОФизЛицСрезПоследних";
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ИмяФамилия;
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗначенииСтавок(СтавкаНДС	 = 0, ВидУдержанияНДФЛ	    = 0, ВидУдержанияПФ		= 0,
							   ПредСтавкаНДС = 0, ПредВидУдержанияНДФЛ	= 0, ПредВидУдержанияПФ	= 0) Экспорт

	СтруктураСтавок = Новый Структура;
	Если НЕ СтавкаНДС = 0 Тогда
		СтруктураСтавок.Вставить("СтавкаНДС",		СтавкаНДС.Ставка);
	КонецЕсли;
	Если НЕ ПредСтавкаНДС = 0 Тогда
		СтруктураСтавок.Вставить("ПредСтавкаНДС",	ПредСтавкаНДС.Ставка);
	//+++ Дмгг
	Иначе
		СтруктураСтавок.Вставить("ПредСтавкаНДС",	0);
	КонецЕсли;
	
	Если НЕ ВидУдержанияНДФЛ = 0 Тогда
		СтруктураСтавок.Вставить("СтавкаНДФЛ",		ВидУдержанияНДФЛ.СтавкаНДФЛ);
	КонецЕсли;
	Если НЕ ПредВидУдержанияНДФЛ = 0 Тогда
		СтруктураСтавок.Вставить("ПредСтавкаНДФЛ",	ПредВидУдержанияНДФЛ.СтавкаНДФЛ);
		//+++ Дмгг
	Иначе
		СтруктураСтавок.Вставить("ПредСтавкаНДФЛ",	0);
	КонецЕсли;
	
	Если НЕ ВидУдержанияПФ = 0 Тогда
		СтруктураСтавок.Вставить("СтавкаПФ",		ВидУдержанияПФ.СтавкаПФ);
	КонецЕсли;
	Если НЕ ПредВидУдержанияПФ = 0 Тогда
		СтруктураСтавок.Вставить("ПредСтавкаПФ",	ПредВидУдержанияПФ.СтавкаПФ);
		//+++ Дмгг
	Иначе
		СтруктураСтавок.Вставить("ПредСтавкаПФ",	0);
	КонецЕсли;

	Возврат СтруктураСтавок;
	
КонецФункции

Процедура ПересчитатьСуммыСтрокиРасхода_ПриходнаяНакладная(ИмяПоля, ТекДанные, СуммаВключаетНДС = Ложь) Экспорт

	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Ставки			= ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ);
	ПересчитатьЦену = Истина;
	
	Если ИмяПоля = "СуммаБезНалогов" ИЛИ ИмяПоля = "ВидУдержанияНДФЛ" ИЛИ ИмяПоля = "СтавкаНДС" ИЛИ ИмяПоля = "ВидУдержанияНДФЛ" ИЛИ ИмяПоля = "ВидУдержанияПФ" Тогда
		СуммаБезНалогов = ТекДанные.СуммаБезНалогов;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		Сумма			= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
	ИначеЕсли ИмяПоля = "Всего" Тогда
		Всего			= ТекДанные.Всего;
		СуммаНДС		= Окр(Всего * Ставки.СтавкаНДС/(100 + Ставки.СтавкаНДС), 2);		
		СуммаПФ			= Окр((Всего - СуммаНДС) * Ставки.СтавкаПФ/100, 2);
		СуммаНДФЛ		= Окр((Всего - СуммаПФ - СуммаНДС) * Ставки.СтавкаНДФЛ/100, 2);
		СуммаБезНалогов = Всего - СуммаПФ - СуммаНДС - СуммаНДФЛ;
		Сумма			= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
	ИначеЕсли ИмяПоля = "Сумма" Тогда
		СуммаБезНалогов = ?(СуммаВключаетНДС, 
						  Окр(ТекДанные.Сумма/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2),
						  ТекДанные.Сумма);
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		
		//+++ Дмгг проверка на сьеденный тетри при округлении
		Если (СуммаБезНалогов + СуммаНДС) <> ТекДанные.Сумма Тогда 
			РазницаСумм = ТекДанные.Сумма - (СуммаБезНалогов + СуммаНДС);
			СуммаНДС 	= СуммаНДС + РазницаСумм;
			Сумма		= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
			Всего		= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		КонецЕсли;
		//--- Дмгг
	ИначеЕсли ИмяПоля = "СкидкаПроцент" ИЛИ ИмяПоля = "ПроцентСкидкиНаценки" ИЛИ ИмяПоля = "Цена" ИЛИ ИмяПоля = "СкидкаСумма" ИЛИ ИмяПоля = "Количество" Тогда
		Сумма			= Окр(ТекДанные.Цена * ТекДанные.Количество * (100 - ТекДанные.ПроцентСкидкиНаценки)/100, 2);
		Если СуммаВключаетНДС Тогда
			СуммаБезНалогов = Окр(Сумма /(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2);
			СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
			СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
			СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
			//Прибавить копейку
			Погрешность = Сумма - (СуммаБезНалогов + СуммаНДС);
			СуммаНДС		= СуммаНДС + Погрешность;
			//Прибавить копейку
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		Иначе
			СуммаБезНалогов = Сумма;
			СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
			СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
			СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		КонецЕсли;
		ПересчитатьЦену = Ложь;
	Иначе
		СуммаБезНалогов = ?(СуммаВключаетНДС, 
						  Окр(ТекДанные.Сумма/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2),
						  ТекДанные.Сумма);
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов;
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
	КонецЕсли;
	
	ТекДанные.Сумма				= Сумма;
	ТекДанные.СуммаБезНалогов	= СуммаБезНалогов;
	ТекДанные.СуммаНДФЛ			= СуммаНДФЛ;
	ТекДанные.СуммаНДС			= СуммаНДС;
	ТекДанные.СуммаПФ			= СуммаПФ;
	ТекДанные.Всего				= Всего;
	Если ПересчитатьЦену Тогда
		Если ТекДанные.ПроцентСкидкиНаценки = 0 Тогда
			ТекДанные.Цена 	= ?(ТекДанные.Количество = 0, 0, Окр(ТекДанные.Сумма/ТекДанные.Количество, 2));
		ИначеЕсли НЕ ТекДанные.ПроцентСкидкиНаценки = 0 И НЕ ТекДанные.Количество = 0 Тогда
			ТекДанные.Цена	= ТекДанные.Сумма / ((1 - ТекДанные.ПроцентСкидкиНаценки / 100) * ТекДанные.Количество);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПересчитатьСуммыСтрокиРасхода_ДополнительныеРасходы(ИмяПоля, ТекДанные, СуммаВключаетНДС = Ложь) Экспорт

	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Ставки			= ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ);
	ПересчитатьЦену = Истина;
	
	Если ИмяПоля = "СуммаБезНалогов" ИЛИ ИмяПоля = "ВидУдержанияНДФЛ" ИЛИ ИмяПоля = "СтавкаНДС" ИЛИ ИмяПоля = "ВидУдержанияНДФЛ" ИЛИ ИмяПоля = "ВидУдержанияПФ" Тогда
		СуммаБезНалогов = ТекДанные.СуммаБезНалогов;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		Сумма			= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
	ИначеЕсли ИмяПоля = "Всего" Тогда
		Всего			= ТекДанные.Всего;
		СуммаНДС		= Окр(Всего * Ставки.СтавкаНДС/(100 + Ставки.СтавкаНДС), 2);		
		СуммаПФ			= Окр((Всего - СуммаНДС) * Ставки.СтавкаПФ/100, 2);
		СуммаНДФЛ		= Окр((Всего - СуммаПФ - СуммаНДС) * Ставки.СтавкаНДФЛ/100, 2);
		СуммаБезНалогов = Всего - СуммаПФ - СуммаНДС - СуммаНДФЛ;
		Сумма			= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
	ИначеЕсли ИмяПоля = "Сумма" Тогда
		СуммаБезНалогов = ?(СуммаВключаетНДС, 
						  Окр(ТекДанные.Сумма/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2),
						  ТекДанные.Сумма);
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= ?(СуммаВключаетНДС, СуммаБезНалогов + СуммаНДС, СуммаБезНалогов);
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
	ИначеЕсли ИмяПоля = "Цена" ИЛИ ИмяПоля = "Количество" Тогда
		Сумма			= Окр(ТекДанные.Цена * ТекДанные.Количество, 2);
		Если СуммаВключаетНДС Тогда
			СуммаБезНалогов = Окр(Сумма /(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2);
			СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
			СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
			СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
			//Прибавить копейку
			Погрешность = Сумма - (СуммаБезНалогов + СуммаНДС);
			СуммаНДС		= СуммаНДС + Погрешность;
			//Прибавить копейку
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		Иначе
			СуммаБезНалогов = Сумма;
			СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
			СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
			СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
			Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
		КонецЕсли;
		ПересчитатьЦену = Ложь;
	Иначе
		СуммаБезНалогов = ?(СуммаВключаетНДС, 
						  Окр(ТекДанные.Сумма/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2),
						  ТекДанные.Сумма);
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов;
		Всего			= СуммаБезНалогов + СуммаНДФЛ + СуммаНДС + СуммаПФ;
	КонецЕсли;
	
	ТекДанные.Сумма				= Сумма;
	ТекДанные.СуммаБезНалогов	= СуммаБезНалогов;
	ТекДанные.СуммаНДФЛ			= СуммаНДФЛ;
	ТекДанные.СуммаНДС			= СуммаНДС;
	ТекДанные.СуммаПФ			= СуммаПФ;
	ТекДанные.Всего				= Всего;
	Если ПересчитатьЦену Тогда
		ТекДанные.Цена 	= ?(ТекДанные.Количество = 0, 0, Окр(ТекДанные.Сумма/ТекДанные.Количество, 2));
	КонецЕсли;
	
КонецПроцедуры

Процедура ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные, ИспользоватьНулевуеПредЗначения = ЛОЖЬ) Экспорт
//Процедура ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные) Экспорт


	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	//+++ Дмгг
	Если ИспользоватьНулевуеПредЗначения Тогда 
		
		Ставки			= ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ, 0, 0, 0);
		
	Иначе
		
		Ставки			= ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ, ТекДанные.ПредСтавкаНДС, ТекДанные.ПредВидУдержанияНДФЛ, ТекДанные.ПредВидУдержанияПФ);
		
	КонецЕсли;
	//--- Дмгг
	
	ПересчитатьЦену = Истина;
	
	Изменилась_СтавкаНДС 	= НЕ (Ставки.СтавкаНДС  = Ставки.ПредСтавкаНДС);
	Изменилась_СтавкаНДФЛ	= НЕ (Ставки.СтавкаНДФЛ = Ставки.ПредСтавкаНДФЛ);
	Изменилась_СтавкаПФ		= НЕ (Ставки.СтавкаПФ   = Ставки.ПредСтавкаПФ);
	
	Если Изменилась_СтавкаНДС ИЛИ Изменилась_СтавкаНДФЛ ИЛИ Изменилась_СтавкаПФ Тогда
		СуммаБезНалогов = Окр(ТекДанные.СуммаПлатежа/(1 + (100 * Ставки.ПредСтавкаНДС)/((100 - Ставки.ПредСтавкаНДФЛ)*(100 - Ставки.ПредСтавкаПФ))), 2);
	Иначе
		СуммаБезНалогов = Окр(ТекДанные.СуммаПлатежа/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2);
	КонецЕсли;
	
	Если НЕ ИспользоватьНулевуеПредЗначения Тогда//+++ Дмгг 
		ТекДанные.ПредСтавкаНДС 		= ТекДанные.СтавкаНДС;
		ТекДанные.ПредВидУдержанияПФ	= ТекДанные.ВидУдержанияПФ;
		ТекДанные.ПредВидУдержанияНДФЛ	= ТекДанные.ВидУдержанияНДФЛ;
	КонецЕсли;
	
	Если ИмяПоля = "ВидУдержанияНДФЛ" Тогда
		Если НЕ Изменилась_СтавкаНДФЛ Тогда
			Возврат;
		КонецЕсли;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов + СуммаНДС;
	ИначеЕсли ИмяПоля = "СтавкаНДС" Тогда
		Если НЕ Изменилась_СтавкаНДС Тогда
			Возврат;
		КонецЕсли;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов + СуммаНДС;
	ИначеЕсли ИмяПоля = "ВидУдержанияПФ" Тогда
		Если НЕ Изменилась_СтавкаПФ Тогда
			Возврат;
		КонецЕсли;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов + СуммаНДС;
	ИначеЕсли ИмяПоля = "СуммаПлатежа" Тогда
		Сумма			= ТекДанные.СуммаПлатежа;
		СуммаБезНалогов = Окр(ТекДанные.СуммаПлатежа/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2);
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		//Прибавить копейку
		Погрешность = Сумма - (СуммаБезНалогов + СуммаНДС);
		СуммаНДС	= СуммаНДС + Погрешность;
		//Прибавить копейку
	КонецЕсли;
	
	ТекДанные.СуммаПлатежа		= Сумма;
	ТекДанные.СуммаНДФЛ			= СуммаНДФЛ;
	ТекДанные.СуммаНДС			= СуммаНДС;
	ТекДанные.СуммаПФ			= СуммаПФ;
	
КонецПроцедуры

