Функция ПолучитьСуммоНалоговыхЛгот(Организация,Сотрудник,Подразделение,Дата) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(НалоговыеЛготы.Сумма) КАК Сумма,
	               |	НалоговыеЛготы.Организация,
	               |	НалоговыеЛготы.Сотрудник,
	               |	НалоговыеЛготы.Подразделение
	               |ПОМЕСТИТЬ ВТНачисленно
	               |ИЗ
	               |	РегистрНакопления.НалоговыеЛготы КАК НалоговыеЛготы
	               |ГДЕ
	               |	НалоговыеЛготы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	               |	И НалоговыеЛготы.Период < &Дата
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	НалоговыеЛготы.Организация,
	               |	НалоговыеЛготы.Сотрудник,
	               |	НалоговыеЛготы.Подразделение
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЕСТЬNULL(СУММА(НалоговыеЛготыИнформацияСрезПоследних.Сумма - ЕСТЬNULL(НалоговыеЛготыОстатки.Сумма, 0)), 0) КАК Сумма,
	               |	НалоговыеЛготыИнформацияСрезПоследних.ПроцентПодоходного
	               |ИЗ
	               |	РегистрСведений.НалоговыеЛготыИнформация.СрезПоследних(
	               |			&Дата,
	               |			Подразделение = &Подразделение
	               |				И Сотрудник = &Сотрудник
	               |				И Организация = &Организация) КАК НалоговыеЛготыИнформацияСрезПоследних
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТНачисленно КАК НалоговыеЛготыОстатки
	               |		ПО НалоговыеЛготыИнформацияСрезПоследних.Организация = НалоговыеЛготыОстатки.Организация
	               |			И НалоговыеЛготыИнформацияСрезПоследних.Сотрудник = НалоговыеЛготыОстатки.Сотрудник
	               |			И НалоговыеЛготыИнформацияСрезПоследних.Подразделение = НалоговыеЛготыОстатки.Подразделение
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	НалоговыеЛготыИнформацияСрезПоследних.ПроцентПодоходного";
				   
				   
				   
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	Запрос.УстановитьПараметр("Сотрудник",Сотрудник);
	Запрос.УстановитьПараметр("Дата",Дата);
    Запрос.УстановитьПараметр("Организация",Организация);	
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("Сумма",0);
	СтруктураОтвета.Вставить("ПроцентПодоходного",0);
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураОтвета,Выборка);
	КонецЕсли;
	
	Возврат СтруктураОтвета;
	
КонецФункции	

Процедура ПроверкаСуммиИДниЗадолженности(ДокументСсылка, Отказ) Экспорт 
	
	ТекстСообщение = "";
	НачалоПериодКонтроляЛимитов = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НачалоПериодаКонтроляЛимитовЗадолжностиПокупателей");
	Если НачалоДня(ДокументСсылка.Дата) < НачалоПериодКонтроляЛимитов Тогда 
		Возврат;
	КонецЕсли;
	Договор = ДокументСсылка.Договор;
		
	Если Договор.ДопустимыйЛимитЗадолженностиОтПокупателя > 0 Тогда 
		ОстатокЛимита = Договор.ДопустимыйЛимитЗадолженностиОтПокупателя;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	РасчетыСПокупателямиОстатки.Организация,
			|	РасчетыСПокупателямиОстатки.Договор,
			|	РасчетыСПокупателямиОстатки.СуммаОстаток КАК Сумма,
			|	РасчетыСПокупателямиОстатки.СуммаВалОстаток КАК СуммаВал
			|ИЗ
			|	РегистрНакопления.РасчетыСПокупателями.Остатки(
			|			&Дата,
			|			Организация = &Организация
			|				И Договор = &Договор) КАК РасчетыСПокупателямиОстатки";
		Запрос.УстановитьПараметр("Договор", 		Договор);
		Запрос.УстановитьПараметр("Дата", 			ДокументСсылка.Дата);
		Запрос.УстановитьПараметр("Организация",	ДокументСсылка.Организация);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда 
			ОстатокЛимита = Договор.ДопустимыйЛимитЗадолженностиОтПокупателя - Выборка.Сумма;
		КонецЕсли;
		Если ОстатокЛимита < 0 ИЛИ ОстатокЛимита < ДокументСсылка.СуммаДокумента Тогда
			Отказ = Истина;
			врТекстСообщение = НСтр("ru = 'Задолжность превышает сумму лимита на текущий договор на сумму '; ka = 'დავალიანება მოცემული ხელშეკრულებისთვის აჭარბებს დასაშვებ ლიმიტს თანხით '") + Строка((ОстатокЛимита-ДокументСсылка.СуммаДокумента)*-1);
			ТекстСообщение = ?(ТекстСообщение = "",врТекстСообщение,ТекстСообщение+Символы.ПС+врТекстСообщение);
		КонецЕсли;
	КонецЕсли;
		
	Если Договор.СрокОплатыПокупателя > 0 Тогда
		Если Не Договор.Владелец.ВестиРасчетыПоДокументам Тогда
			врТекстСообщение = НСтр("ka='თუ ხელშეკრულებაში მითითებულია დღეების ლიმიტი, აუცილებელია აღრიცხვა წარმოებდეს დოკუმენტების მიხედვით.';ru='Если в договоре указан срок оплаты покупателя, обязательно учет проводить по документам.'");
			ТекстСообщение = ?(ТекстСообщение = "",врТекстСообщение,ТекстСообщение+Символы.ПС+врТекстСообщение);
			Отказ = Истина;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	РасчетыСПокупателямиОстатки.Договор,
		               |	МИНИМУМ(РасчетыСПокупателямиОстатки.Документ.Дата) КАК ДатаПервДок
		               |ПОМЕСТИТЬ врТаб
		               |ИЗ
		               |	РегистрНакопления.РасчетыСПокупателями.Остатки(&Дата, Договор = &Договор) КАК РасчетыСПокупателямиОстатки
		               |ГДЕ
		               |	НЕ РасчетыСПокупателямиОстатки.Документ.Дата ЕСТЬ NULL
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	РасчетыСПокупателямиОстатки.Договор
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	врТаб.Договор,
		               |	врТаб.ДатаПервДок,
		               |	РАЗНОСТЬДАТ(врТаб.ДатаПервДок, &Дата, ДЕНЬ) КАК РазностьДатВДнях
		               |ИЗ
		               |	врТаб КАК врТаб";
		Запрос.УстановитьПараметр("Договор", 	ДокументСсылка.Договор);
		Запрос.УстановитьПараметр("Дата", 		ДокументСсылка.Дата);
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Если Выборка.РазностьДатВДнях > 0 И Выборка.РазностьДатВДнях > Договор.СрокОплатыПокупателя  Тогда
				Отказ = Истина;
				врТекстСообщение = НСтр("ru = 'Дата задолжности превышает лимита дней на '; ka = 'დავალიანება აჭარბებს დასაშვებ დროით ლიმიტს '") + 
								   Строка(Выборка.РазностьДатВДнях - Договор.СрокОплатыПокупателя) + НСТР("ru = ' дня'; ka = ' დღით'");
				ТекстСообщение = ?(ТекстСообщение = "",врТекстСообщение,ТекстСообщение+Символы.ПС+врТекстСообщение);
			КонецЕсли;  
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ТекстСообщение = "" Тогда
		Сообщить(ТекстСообщение, СтатусСообщения.Важное);
	КонецЕсли;
		

КонецПроцедуры
//_Паганини

&НаСервере
Функция ПолучитьСуммуИНДСДокументаВВалютеРасчета(Документ) Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	СУММА(Закупки.Сумма) КАК Сумма,
	               |	СУММА(Закупки.СуммаНДС) КАК СуммаНДС
	               |ИЗ
	               |	РегистрНакопления.Закупки КАК Закупки
	               |ГДЕ
	               |	Закупки.Регистратор = &Регистратор";
	
	Запрос.УстановитьПараметр("Регистратор",Документ);
	
	СтруктураОтвета = Новый Структура;
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		СтруктураОтвета.Вставить("Сумма",Выборка.Сумма);
		СтруктураОтвета.Вставить("СуммаНДС",Выборка.СуммаНДС);
		СтруктураОтвета.Вставить("СуммаВсего",Выборка.Сумма);
	Иначе
		СтруктураОтвета.Вставить("Сумма",0);
		СтруктураОтвета.Вставить("СуммаНДС",0);
		СтруктураОтвета.Вставить("СуммаВсего",0);
	КонецЕсли;	
	
	Возврат СтруктураОтвета;	
	
КонецФункции
