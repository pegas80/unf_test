
//Проверяет уникальность реквизита
Функция РеквизитУникален(Ссылка, РеквизитИмя, РеквизитЗначение, ИмяСправочника) Экспорт
	
	Если Не ЗначениеЗаполнено(РеквизитЗначение) Тогда
		Возврат Истина; 
	КонецЕсли;
	Запрос = Новый Запрос;
	Запрос.Текст =  "ВЫБРАТЬ ПЕРВЫЕ 1
					|	Мета.Ссылка
					|ИЗ
					|	Справочник." + ИмяСправочника + " КАК Мета
		            |ГДЕ
		            |	НЕ Мета.Ссылка = &Ссылка
					|	И НЕ Мета.ПометкаУдаления
		            |	И Мета." + РеквизитИмя + " = &РеквизитЗначение";
	Запрос.УстановитьПараметр("Ссылка", 			Ссылка);
	Запрос.УстановитьПараметр("РеквизитЗначение",	РеквизитЗначение);
	
	Возврат Запрос.Выполнить().Пустой();
					
КонецФункции

