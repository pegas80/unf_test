			|	РасчетыСПоставщикамиОстатки.СуммаВалОстаток КАК СуммаВал
			|ИЗ
			|	РегистрНакопления.РасчетыСПоставщиками.Остатки(
			|			&ПроверяемаяДата,
			|			Организация = &Организация
			|				И Договор = &Договор) КАК РасчетыСПоставщикамиОстатки";
		Запрос.УстановитьПараметр("Договор", 		Договор);
		Запрос.УстановитьПараметр("ПроверяемаяДата",ПроверяемаяДата);
		Запрос.УстановитьПараметр("Организация",	ДокументСсылка.Организация);
		
		Выборка = Запрос.Выполнить().Выбрать();
		ДолгПередПоставщиком =0 ;
		Если Выборка.Следующий() Тогда 
			ДолгПередПоставщиком = Выборка.Сумма;
		КонецЕсли;
		
		Если ДолгПередПоставщиком > 0 Тогда
			Отказ = Истина;
			врТекстСообщение = НСтр("ru = 'Невозможно провести документ. Задолжность Перед Поставщиком > 0  '; ka = 'დოკუმენტის გატარება შეუძლებელია. მოცემული ხელშეკრულებით არსებული  დავალიანების თანხა > 0 '" );
			ТекстСообщение = ?(ТекстСообщение = "",врТекстСообщение,ТекстСообщение+Символы.ПС+врТекстСообщение);
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ТекстСообщение = "" Тогда
		Сообщить(ТекстСообщение, СтатусСообщения.Важное);
	КонецЕсли;	

КонецПроцедуры

&НаСервере
Функция  ПроверкаЗаполненияПоляКомментарий(Организация)  Экспорт
	
	Проверять = Ложь;	
	
	запрос = Новый Запрос; 
	запрос.Текст =
	"ВЫБРАТЬ
	|	УчетнаяПолитикаРеглСрезПоследних.ЧекККМВозвратПроверкаЗаполненияПоляКомментарий КАК ЧекККМВозвратПроверкаЗаполненияПоляКомментарий
	|ИЗ
	|	РегистрСведений.УчетнаяПолитикаРегл.СрезПоследних(, Организация = &Организация) КАК УчетнаяПолитикаРеглСрезПоследних
	|ГДЕ
	|	УчетнаяПолитикаРеглСрезПоследних.ЧекККМВозвратПроверкаЗаполненияПоляКомментарий = ИСТИНА" ;	
	
	запрос.УстановитьПараметр("Организация" , Организация) ;	
	
	Результат = Запрос.Выполнить().Выгрузить();
	Если Результат.Количество() > 0 Тогда 
		Проверять = Истина ;
		Возврат Проверять ;
	КонецЕсли;
	Возврат  Проверять ;
КонецФункции

