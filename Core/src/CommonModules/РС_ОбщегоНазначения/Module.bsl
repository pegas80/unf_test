Функция СчетДляСписанияОприходованияЗапасов(Документ) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(&Документ) = ТИП(Документ.ОприходованиеЗапасов)
		|			ТОГДА СчетыДляСписанияИОприходованияЗапасов.СчетДляОприходованияЗапасов
		|		ИНАЧЕ СчетыДляСписанияИОприходованияЗапасов.СчетДляСписаянияЗапасов
		|	КОНЕЦ КАК Счет
		|ИЗ
		|	РегистрСведений.СчетыДляСписанияИОприходованияЗапасов КАК СчетыДляСписанияИОприходованияЗапасов";
	Запрос.УстановитьПараметр("Документ",Документ);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если  РезультатЗапроса.Количество()>0 Тогда 	
		Возврат  РезультатЗапроса[0].Счет ;
	КонецЕсли;
	
	Возврат ПланыСчетов.Хозрасчетный.ПустаяСсылка();
	
	КонецФункции
	
Процедура СформироватьТаблицаКонтрольСроковГодностиТовара(ДокументСсылка, СтруктураДополнительныеСвойства) Экспорт
	
	//Если ДокументСсылкаРасходнаяНакладная.ВидОперации <> Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю Тогда
	//	Возврат;
	//КонецЕсли;
	
	КопияТаблицаЗапасы = Новый ТаблицаЗначений;
	КопияТаблицаЗапасы.Колонки.Добавить("Организация");
	КопияТаблицаЗапасы.Колонки.Добавить("СтруктурнаяЕдиница");
	КопияТаблицаЗапасы.Колонки.Добавить("Документ");
	КопияТаблицаЗапасы.Колонки.Добавить("Номенклатура");
	КопияТаблицаЗапасы.Колонки.Добавить("Характеристика");
	КопияТаблицаЗапасы.Колонки.Добавить("Количество");
	КопияТаблицаЗапасы.Колонки.Добавить("Период");
	КопияТаблицаЗапасы.Колонки.Добавить("ВидДвижения");
	КопияТаблицаЗапасы.Колонки.Добавить("СрокГодности");

	
	НовЗапрос = Новый Запрос;
	НовЗапрос.МенеджерВременныхТаблиц = СтруктураДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	НовЗапрос.Текст =
	"ВЫБРАТЬ
	|	КонтрольСроковГодностиТовара.Количество КАК Количество,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	КонтрольСроковГодностиТовара.Период КАК Период,
	|	КонтрольСроковГодностиТовара.Организация КАК Организация,
	|	КонтрольСроковГодностиТовара.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	КонтрольСроковГодностиТовара.Номенклатура КАК Номенклатура,
	|	КонтрольСроковГодностиТовара.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ ВтПродажи
	|ИЗ
	|	ВременнаяТаблицаЗапасы КАК КонтрольСроковГодностиТовара
	|
	|СГРУППИРОВАТЬ ПО
	|	КонтрольСроковГодностиТовара.Номенклатура,
	|	КонтрольСроковГодностиТовара.Характеристика,
	|	КонтрольСроковГодностиТовара.Количество,
	|	КонтрольСроковГодностиТовара.Период,
	|	КонтрольСроковГодностиТовара.Организация,
	|	КонтрольСроковГодностиТовара.СтруктурнаяЕдиница
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 3000000
	|	ВтПродажи.Номенклатура КАК Номенклатура,
	|	ВтПродажи.Количество КАК Количество,
	|	КонтрольСроковГодностиТовараОбороты.Документ КАК Документ,
	|	СУММА(КонтрольСроковГодностиТовараОбороты.КоличествоОборот) КАК КоличествоОстаток,
	|	КонтрольСроковГодностиТовараОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВтПродажи.Организация КАК Организация,
	|	ВтПродажи.Период КАК Период,
	|	ВтПродажи.ВидДвижения КАК ВидДвижения,
	|	КонтрольСроковГодностиТовараОбороты.СрокГодности КАК СрокГодности
	|ПОМЕСТИТЬ ВтСрокиГодности
	|ИЗ
	|	РегистрНакопления.КонтрольСроковГодностиТовара.Обороты(
	|			,
	|			,
	|			Регистратор,
	|			Организация = &Организация
	|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
	|				И (Номенклатура, Характеристика) В
	|					(ВЫБРАТЬ
	|						ВтПродажи.Номенклатура КАК Номенклатура,
	|						ВтПродажи.Характеристика КАК Характеристика
	|					ИЗ
	|						ВтПродажи КАК ВтПродажи)) КАК КонтрольСроковГодностиТовараОбороты,
	|	ВтПродажи КАК ВтПродажи
	|ГДЕ
	|	КонтрольСроковГодностиТовараОбороты.Регистратор <> &Регистратор
	|
	|СГРУППИРОВАТЬ ПО
	|	ВтПродажи.Номенклатура,
	|	ВтПродажи.Организация,
	|	ВтПродажи.Период,
	|	ВтПродажи.ВидДвижения,
	|	КонтрольСроковГодностиТовараОбороты.Документ,
	|	КонтрольСроковГодностиТовараОбороты.СтруктурнаяЕдиница,
	|	КонтрольСроковГодностиТовараОбороты.СрокГодности,
	|	ВтПродажи.Количество
	|
	|УПОРЯДОЧИТЬ ПО
	|	КонтрольСроковГодностиТовараОбороты.СрокГодности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтСрокиГодности.Номенклатура КАК Номенклатура,
	|	ВтСрокиГодности.Количество КАК Количество,
	|	ВтСрокиГодности.Документ КАК Документ,
	|	СУММА(ВтСрокиГодности.КоличествоОстаток) КАК КоличествоОстаток,
	|	ВтСрокиГодности.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	|	ВтСрокиГодности.Организация КАК Организация,
	|	ВтСрокиГодности.Период КАК Период,
	|	ВтСрокиГодности.ВидДвижения КАК ВидДвижения,
	|	ВтСрокиГодности.СрокГодности КАК СрокГодности
	|ИЗ
	|	ВтСрокиГодности КАК ВтСрокиГодности
	|
	|СГРУППИРОВАТЬ ПО
	|	ВтСрокиГодности.Организация,
	|	ВтСрокиГодности.ВидДвижения,
	|	ВтСрокиГодности.СтруктурнаяЕдиница,
	|	ВтСрокиГодности.Документ,
	|	ВтСрокиГодности.Номенклатура,
	|	ВтСрокиГодности.Период,
	|	ВтСрокиГодности.Количество,
	|	ВтСрокиГодности.СрокГодности
	|ИТОГИ
	|	МАКСИМУМ(Количество),
	|	СУММА(КоличествоОстаток)
	|ПО
	|	Номенклатура";

	
	НовЗапрос.УстановитьПараметр("Регистратор",ДокументСсылка);
	НовЗапрос.УстановитьПараметр("Организация",ДокументСсылка.Организация);
	НовЗапрос.УстановитьПараметр("СтруктурнаяЕдиница",ДокументСсылка.СтруктурнаяЕдиница);
		
	ВыборкаНоменклатура = НовЗапрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаНоменклатура.Следующий() Цикл
		КоличествоПогасить=0;
		КоличествоПогасить = ВыборкаНоменклатура.Количество;
		
		ВыборкаПродажи = ВыборкаНоменклатура.Выбрать(); 		
		Пока ВыборкаПродажи.Следующий() Цикл
			Если Не ВыборкаПродажи.КоличествоОстаток > 0 Тогда
				Продолжить;
			КонецЕсли;
			Если   КоличествоПогасить <> Null Тогда 
				Если КоличествоПогасить >0 Тогда  
					стрЗапасы = КопияТаблицаЗапасы.Добавить();
					ЗаполнитьЗначенияСвойств(стрЗапасы,ВыборкаПродажи);
					стрЗапасы.Количество = Мин(ВыборкаПродажи.КоличествоОстаток,КоличествоПогасить);
					КоличествоПогасить 	 = КоличествоПогасить - ВыборкаПродажи.КоличествоОстаток;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	СтруктураДополнительныеСвойства.ТаблицыДляДвижений.Вставить("ТаблицаКонтрольСроковГодностиТовара", КопияТаблицаЗапасы);

КонецПроцедуры

Процедура ПересчитатьСуммыСтроки_ПоступлениеВКассу_ПоступлениеНаСчетa(ИмяПоля, ТекДанные, ИспользоватьНулевуеПредЗначения = ЛОЖЬ) Экспорт
//Процедура ПересчитатьСуммыСтроки_РасходИзКассы_РасходСоСчета(ИмяПоля, ТекДанные) Экспорт


	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	//
	////+++ Дмгг
	//Если ИспользоватьНулевуеПредЗначения Тогда 
	//	
	//	Ставки			= ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ, 0, 0, 0);
	//	
	//Иначе
	//	
		Ставки			= ПолучитьЗначенииСтавок(ТекДанные.СтавкаНДС,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ, ТекДанные.ПредСтавкаНДС, ТекДанные.ПредВидУдержанияНДФЛ, ТекДанные.ПредВидУдержанияПФ);
	//	
	//КонецЕсли;
	////--- Дмгг
	
	ПересчитатьЦену = Истина;
	
	Изменилась_СтавкаНДС 	= НЕ (Ставки.СтавкаНДС  = Ставки.ПредСтавкаНДС);
	Изменилась_СтавкаНДФЛ	= НЕ (Ставки.СтавкаНДФЛ = Ставки.ПредСтавкаНДФЛ);
	Изменилась_СтавкаПФ		= НЕ (Ставки.СтавкаПФ   = Ставки.ПредСтавкаПФ);
	
	Если Изменилась_СтавкаНДС ИЛИ Изменилась_СтавкаНДФЛ ИЛИ Изменилась_СтавкаПФ Тогда
		СуммаБезНалогов = Окр(ТекДанные.СуммаПлатежа/(1 + (100 * Ставки.ПредСтавкаНДС)/((100 - Ставки.ПредСтавкаНДФЛ)*(100 - Ставки.ПредСтавкаПФ))), 2);
	Иначе
		СуммаБезНалогов = Окр(ТекДанные.СуммаПлатежа/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2);
	КонецЕсли;
	
	Если НЕ ИспользоватьНулевуеПредЗначения Тогда//+++ Дмгг 
		ТекДанные.ПредСтавкаНДС 		= ТекДанные.СтавкаНДС;
		ТекДанные.ПредВидУдержанияПФ	= ТекДанные.ВидУдержанияПФ;
		ТекДанные.ПредВидУдержанияНДФЛ	= ТекДанные.ВидУдержанияНДФЛ;
	КонецЕсли;
	
	Если ИмяПоля = "ВидУдержанияНДФЛ" Тогда
		Если НЕ Изменилась_СтавкаНДФЛ Тогда
			Возврат;
		КонецЕсли;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов + СуммаНДС;
	ИначеЕсли ИмяПоля = "СтавкаНДС" Тогда
		Если НЕ Изменилась_СтавкаНДС Тогда
			Возврат;
		КонецЕсли;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов + СуммаНДС;
	ИначеЕсли ИмяПоля = "ВидУдержанияПФ" Тогда
		Если НЕ Изменилась_СтавкаПФ Тогда
			Возврат;
		КонецЕсли;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		Сумма			= СуммаБезНалогов + СуммаНДС;
	ИначеЕсли ИмяПоля = "СуммаПлатежа" Тогда
		Сумма			= ТекДанные.СуммаПлатежа;
		СуммаБезНалогов = Окр(ТекДанные.СуммаПлатежа/(1 + (100 * Ставки.СтавкаНДС)/((100 - Ставки.СтавкаНДФЛ)*(100 - Ставки.СтавкаПФ))), 2);
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
		СуммаНДС		= Окр((СуммаБезНалогов + СуммаНДФЛ + СуммаПФ) * Ставки.СтавкаНДС/100, 2);
		//Прибавить копейку
		Погрешность = Сумма - (СуммаБезНалогов + СуммаНДС);
		СуммаНДС	= СуммаНДС + Погрешность;
		//Прибавить копейку
	КонецЕсли;
	
	ТекДанные.СуммаПлатежа		= Сумма;
	ТекДанные.СуммаНДФЛ			= СуммаНДФЛ;
	ТекДанные.СуммаНДС			= СуммаНДС;
	ТекДанные.СуммаПФ			= СуммаПФ;
	
КонецПроцедуры
//--Lazare

//++lyskov
Процедура СинхронизироватьРеквизитыДокументовОснованийСчетаФактуры(СчетФактураОбъект) Экспорт
	
	ДанныеДокументовДляОбработки = Новый Соответствие;
	
	ВсеДокументыОснования = ОбщегоНазначения.ВыгрузитьКолонку(СчетФактураОбъект.ДокументыОснования, "ДокументОснование", Истина);
	ДокументыПоТипам = ДокументыРазобранныеПоТипам(ВсеДокументыОснования);
	
	Для Каждого НаборДокументов Из ДокументыПоТипам Цикл
		МетаданныеДокумента = Метаданные.НайтиПоТипу(НаборДокументов.Ключ);
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("IDСФ", МетаданныеДокумента)
			И ОбщегоНазначения.ЕстьРеквизитОбъекта("НомерСФ", МетаданныеДокумента) Тогда
			
			ОбщегоНазначенияКлиентСервер.ДополнитьСоответствие(ДанныеДокументовДляОбработки,
				ОбщегоНазначения.ЗначенияРеквизитовОбъектов(НаборДокументов.Значение, "IDСФ,НомерСФ"));
				
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ДанныеДокумента Из ДанныеДокументовДляОбработки Цикл
		
		ДокументСсылка     = ДанныеДокумента.Ключ;
		РеквизитыДокумента = ДанныеДокумента.Значение;
		
		// Если счет-фактура записывается - поля документа-основания требуется заполнить из данных счета-фактуры.
		// Если счет-фактура удаляется - поля документа-основания требуется очистить.
		
		НомерСФДляЗаполнения = ?(СчетФактураОбъект.ПометкаУдаления, "", СчетФактураОбъект.НомерВходящегоДокумента);
		ИдСФДляЗаполнения    = ?(СчетФактураОбъект.ПометкаУдаления, "", Формат(СчетФактураОбъект.Идентификатор, "ЧН=' '; ЧГ=0"));
		
		Если РеквизитыДокумента.НомерСФ <> НомерСФДляЗаполнения
			Или РеквизитыДокумента.IDСФ <> ИдСФДляЗаполнения Тогда
			
			ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.НомерСФ = НомерСФДляЗаполнения;
			ДокументОбъект.IDСФ    = ИдСФДляЗаполнения;
			ДокументОбъект.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ДокументыРазобранныеПоТипам(Документы)
	
	ДокументыПоТипам = Новый Соответствие;
	
	Для Каждого Документ Из Документы Цикл
		ТипДокумента = ТипЗнч(Документ);
		Если ДокументыПоТипам.Получить(ТипДокумента) = Неопределено Тогда
			ДокументыПоТипам.Вставить(ТипДокумента, Новый Массив);
		КонецЕсли;
		ДокументыПоТипам[ТипДокумента].Добавить(Документ);
	КонецЦикла;
	
	Возврат ДокументыПоТипам;
	
КонецФункции
//--lyskov


