Функция ПолучитьЗначенияРеквизитов(Ссылка, Реквизиты) Экспорт

	МассивИменРеквизитов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(Реквизиты, ",");
	
	СтруктураРеквизитов = Новый Структура;
	Для Каждого ИмяРеквизита Из МассивИменРеквизитов Цикл
		СтруктураРеквизитов.Вставить(ИмяРеквизита, Ссылка[ИмяРеквизита]);
	КонецЦикла;
	
	Возврат СтруктураРеквизитов;
	
КонецФункции

Функция ПолучитьСкладПоАдресу(Адрес) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка КАК Склад
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.КонтактнаяИнформация КАК СтруктурныеЕдиницыКонтактнаяИнформация
		|ГДЕ
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы)
		|	И СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)
		|	И СтруктурныеЕдиницыКонтактнаяИнформация.Представление = &Адрес";
	Запрос.УстановитьПараметр("Адрес", Адрес);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Склад;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПредставлениеНоменклатуры(Номенклатура, Характеристика, Серия) Экспорт

	СтрПредставление = СокрЛП(Номенклатура.Наименование);

	Если ЗначениеЗаполнено(Характеристика)Тогда
		СтрПредставление = СтрПредставление + " / " + СокрЛП(Характеристика.Наименование);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Серия) Тогда
		СтрПредставление = СтрПредставление + " / " + СокрЛП(Серия.Наименование);
	КонецЕсли;

	Возврат СтрПредставление;

КонецФункции

Процедура ЗаполнитьЦену(СтрокаТЧ, ВидЦены) Экспорт 
	
	Если НЕ ЗначениеЗаполнено(ВидЦены) ИЛИ НЕ ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
		СтрокаТЧ.Цена     = 0;
		СтрокаТЧ.Сумма    = 0;
		СтрокаТЧ.СуммаНДС = 0;
		Возврат;
	КонецЕсли;
	
	Цены = РегистрыСведений.ЦеныНоменклатуры.СрезПоследних(, Новый Структура("ВидЦен, Номенклатура, Характеристика", ВидЦены, СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));
	Если Не Цены.Количество() = 0 Тогда
		СтрокаТЧ.СтавкаНДС	= СтрокаТЧ.Номенклатура.СтавкаНДС;
		СтавкаНДС = СтрокаТЧ.СтавкаНДС.Ставка;
		СтрокаТЧ.Цена     	= Цены[0].Цена;
		СтрокаТЧ.Сумма    	= СтрокаТЧ.Количество * СтрокаТЧ.Цена;
		СтрокаТЧ.СуммаНДС 	= Окр(СтрокаТЧ.Сумма  * СтавкаНДС/(100 + СтавкаНДС), 2);
	Иначе
		СтрокаТЧ.Цена     = 0;
		СтрокаТЧ.Сумма    = 0;
		СтрокаТЧ.СуммаНДС = 0;
	КонецЕсли;
		
КонецПроцедуры

Функция ПолучитьФИОФизЛиц(ФизЛицо, Дата = Неопределено) Экспорт
	
	Если Дата = Неопределено Тогда
		Дата = ТекущаяДата();
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФИОФизЛицСрезПоследних.Имя + "" "" + ФИОФизЛицСрезПоследних.Фамилия КАК ИмяФамилия
		|ИЗ
		|	РегистрСведений.ФИОФизЛиц.СрезПоследних(&Дата, ФизЛицо = &ФизЛицо) КАК ФИОФизЛицСрезПоследних";
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ИмяФамилия;
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗначенииСтавок(СтавкаНДС	 = 0, ВидУдержанияНДФЛ	    = 0, ВидУдержанияПФ		= 0,
							   ПредСтавкаНДС = 0, ПредВидУдержанияНДФЛ	= 0, ПредВидУдержанияПФ	= 0) Экспорт

	СтруктураСтавок = Новый Структура;
	Если НЕ СтавкаНДС = 0 Тогда
		СтруктураСтавок.Вставить("СтавкаНДС",		СтавкаНДС.Ставка);
	КонецЕсли;
	Если НЕ ПредСтавкаНДС = 0 Тогда
		СтруктураСтавок.Вставить("ПредСтавкаНДС",	ПредСтавкаНДС.Ставка);
	//+++ Дмгг
	Иначе
		СтруктураСтавок.Вставить("ПредСтавкаНДС",	0);
	КонецЕсли;
	
	Если НЕ ВидУдержанияНДФЛ = 0 Тогда
		СтруктураСтавок.Вставить("СтавкаНДФЛ",		ВидУдержанияНДФЛ.СтавкаНДФЛ);
	КонецЕсли;
	Если НЕ ПредВидУдержанияНДФЛ = 0 Тогда
		СтруктураСтавок.Вставить("ПредСтавкаНДФЛ",	ПредВидУдержанияНДФЛ.СтавкаНДФЛ);
		//+++ Дмгг
	Иначе
		СтруктураСтавок.Вставить("ПредСтавкаНДФЛ",	0);
	КонецЕсли;
	
	Если НЕ ВидУдержанияПФ = 0 Тогда
		СтруктураСтавок.Вставить("СтавкаПФ",		ВидУдержанияПФ.СтавкаПФ);
	КонецЕсли;
	Если НЕ ПредВидУдержанияПФ = 0 Тогда
		СтруктураСтавок.Вставить("ПредСтавкаПФ",	ПредВидУдержанияПФ.СтавкаПФ);
		//+++ Дмгг
	Иначе
		СтруктураСтавок.Вставить("ПредСтавкаПФ",	0);
	КонецЕсли;

	Возврат СтруктураСтавок;
	
КонецФункции

