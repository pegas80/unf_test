Процедура ПересчитатьСуммыСтроки_АвансовыйОтчет_Оплата(ИмяПоля, ТекДанные) Экспорт

	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Ставки			= ПолучитьЗначенииСтавок( ,ТекДанные.ВидУдержанияНДФЛ, ТекДанные.ВидУдержанияПФ);
	ПересчитатьЦену = Истина;
	
	СуммаБезНалогов = ТекДанные.СуммаПлатежа;
	
	Если ИмяПоля = "ВидУдержанияНДФЛ" Тогда
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
	ИначеЕсли ИмяПоля = "ВидУдержанияПФ" Тогда
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
	ИначеЕсли ИмяПоля = "СуммаПлатежа" Тогда
		Сумма			= ТекДанные.СуммаПлатежа;
		СуммаНДФЛ		= Окр(СуммаБезНалогов * Ставки.СтавкаНДФЛ/(100 - Ставки.СтавкаНДФЛ), 2);
		СуммаПФ			= Окр((СуммаБезНалогов + СуммаНДФЛ) * Ставки.СтавкаПФ/(100 - Ставки.СтавкаПФ), 2);
	КонецЕсли;
	
	ТекДанные.СуммаПлатежа		= СуммаБезНалогов;
	ТекДанные.СуммаНДФЛ			= СуммаНДФЛ;
	ТекДанные.СуммаПФ			= СуммаПФ;
	
КонецПроцедуры

Функция ПолучитьСтавкиНалогов(Дата, Контрагент, Договор, Организация) Экспорт

	СтруктураВозврата = Новый Структура;
	
	Если НЕ ЗначениеЗаполнено(Договор) Тогда
		СтруктураВозврата.Вставить("ВидУдержанияНДФЛ",	Неопределено);
		СтруктураВозврата.Вставить("ВидУдержанияПФ",	Неопределено);
	Иначе
		СтруктураВозврата.Вставить("ВидУдержанияНДФЛ",	Договор.ВидУдержанияНДФЛ);
		СтруктураВозврата.Вставить("ВидУдержанияПФ",	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВидУдержанияПФ(Дата, Контрагент, Договор));
	КонецЕсли;
	СтруктураВозврата.Вставить("СтавкаНДС",			ПолучитьСтавкуНДСКонтрагента(Контрагент, Организация));
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ПолучитьСтавкуНДСКонтрагента(Контрагент, Организация) Экспорт
	
	Если НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат ?(ЗначениеЗаполнено(Организация), Организация.СтавкаНДСПоУмолчанию, Неопределено);
	Иначе
		ТипНалогооблаженияНДС = Контрагент.НалогообложениеНДС;
		Если ТипНалогооблаженияНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
			Возврат УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСБезНДС();
		ИначеЕсли ТипНалогооблаженияНДС = Перечисления.ТипыНалогообложенияНДС.НаЭкспорт Тогда
			Возврат УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДСНоль();
		Иначе
			Возврат УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС18");
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

//Паганини_
Процедура ЗапретЗаписьДокументовПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт

	Если НЕ ЗначениеЗаполнено(Источник.Ссылка) Тогда
		Источник.ЗапретРедактированияДокументов = Ложь;
		Возврат;
	КонецЕсли;
	
	Если НЕ УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ФункционалЗапретаРедактированияДокументов") Тогда
		Возврат;
	КонецЕсли;
	
	Если Источник.ЗапретРедактированияДокументов И Не Источник.ДополнительныеСвойства.Свойство("ПроводитЗапретныеДляРедактированияДокументов") Тогда
		ТекстСообщения = НСтр("ka='მოცემული დოკუმენტი დაბლოკილია!';ru='Текущий документ заблокированн!'");
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(Источник.Ссылка,ТекстСообщения, , , ,Отказ);
	КонецЕсли;
			
КонецПроцедуры

Функция ПереводВДату(ДатаСтрока) Экспорт
	
	День 	= Сред(ДатаСтрока, 9, 2);
	Месяц 	= Сред(ДатаСтрока, 6, 2);
	Год 	= Сред(ДатаСтрока, 1, 4);

	Если ДатаСтрока = Неопределено или СтрДлина(ДатаСтрока) > 10 Тогда
		Час = Сред(ДатаСтрока, 12, 2);
		Минута = Сред(ДатаСтрока, 15, 2);
		Секунда = Сред(ДатаСтрока, 18, 2);
		Возврат Дата(Год, Месяц, День, Час, Минута, Секунда);
	ИначеЕсли Год <> "" и Месяц <> "" и День <> "" Тогда
		Возврат Дата(Год, Месяц, День);
	Иначе
		Возврат Дата('00010101');
	КонецЕсли;
	
КонецФункции
