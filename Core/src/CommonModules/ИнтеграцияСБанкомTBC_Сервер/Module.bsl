	    |	ВТ_ДанныеДокументов.creditАccountCurrencyCodeИмяРеквизита КАК CreditАccountCurrencyCodeCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.debitАccountNumberИмяРеквизита КАК DebitАccountNumberИмяРеквизита,
	    |	ВТ_ДанныеДокументов.debitАccountCurrencyCodeИмяРеквизита КАК DebitАccountCurrencyCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.documentNumberИмяРеквизита КАК documentNumberИмяРеквизита,
	    |	ВТ_ДанныеДокументов.amountИмяРеквизита КАК amountИмяРеквизита,
	    |	ВТ_ДанныеДокументов.currencyИмяРеквизита КАК currencyИмяРеквизита,
	    |	ВТ_ДанныеДокументов.descriptionИмяРеквизита КАК descriptionИмяРеквизита,
	    |	ВТ_ДанныеДокументов.additionalDescriptionИмяРеквизита КАК additionalDescriptionИмяРеквизита,
	    |	ВТ_ДанныеДокументов.beneficiaryNameИмяРеквизита КАК beneficiaryNameИмяРеквизита,
	    |	ВТ_ДанныеДокументов.beneficiaryTaxCodeИмяРеквизита КАК beneficiaryTaxCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.beneficiaryAddressИмяРеквизита КАК beneficiaryAddressИмяРеквизита,
	    |	ВТ_ДанныеДокументов.beneficiaryBankCodeИмяРеквизита КАК beneficiaryBankCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.beneficiaryBankNameИмяРеквизита КАК beneficiaryBankNameИмяРеквизита,
	    |	ВТ_ДанныеДокументов.intermediaryBankCodeИмяРеквизита КАК intermediaryBankCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.intermediaryBankNameИмяРеквизита КАК intermediaryBankNameИмяРеквизита,
	    |	ВТ_ДанныеДокументов.chargeDetailsИмяРеквизита КАК chargeDetailsИмяРеквизита,
	    |	ВТ_ДанныеДокументов.Сотрудник КАК Сотрудник,
	    |	ВТ_ДанныеДокументов.taxpayerCodeИмяРеквизита КАК taxpayerCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.taxpayerNameИмяРеквизита КАК taxpayerNameИмяРеквизита,
	    |	ВТ_ДанныеДокументов.treasuryCodeИмяРеквизита КАК treasuryCodeИмяРеквизита,
	    |	ВТ_ДанныеДокументов.taxpayerCode КАК taxpayerCode,
	    |	ВТ_ДанныеДокументов.taxpayerName КАК taxpayerName,
	    |	ВТ_ДанныеДокументов.treasuryCode КАК treasuryCode
	    |ИЗ
	    |	ВТ_ПредПроверка КАК ВТ_ПредПроверка
	    |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеДокументов КАК ВТ_ДанныеДокументов
	    |		ПО ВТ_ПредПроверка.Ссылка = ВТ_ДанныеДокументов.Ссылка
		|		И ВТ_ПредПроверка.НомерСтроки = ВТ_ДанныеДокументов.НомерСтроки
		|
	    |УПОРЯДОЧИТЬ ПО
	    |	batchName,
	    |	Ссылка,
	    |	position
	    |ИТОГИ ПО
	    |	batchName,
	    |	DebitАccountNumber,
	    |	DebitАccountCurrencyCode";
	
	Запрос.УстановитьПараметр("МассивДокументов", СтруктураПарметровЗапросаВБанк.МассивДокументов);
	Запрос.УстановитьПараметр("НацВалюта", СтруктураПарметровЗапросаВБанк.ВалютаУчета);
	Запрос.УстановитьПараметр("КодЯзвка", ПользователиИнформационнойБазы.ТекущийПользователь().Язык.КодЯзыка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Процедура ОбработатьВыгрузкуДокументовВБанкНаСервере(СтруктураОтвета,ТаблицаПозицийАдресВременногоХранилища) ЭКСПОРТ
	
	КолвоВыгруженныхДоков = 0;
	
	Если СтруктураОтвета.Свойство("ТекстОшибки") Тогда 
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураОтвета.ТекстОшибки);
		
	Иначе
		
		ТаблицаПозиций = ПолучитьИзВременногоХранилища(ТаблицаПозицийАдресВременногоХранилища);
		
		МассивПакетов = Неопределено;
		Если СтруктураОтвета.Свойство("МассивСсылокДокументовПакетов") Тогда 
			МассивПакетов = СтруктураОтвета.МассивСсылокДокументовПакетов;
		КонецЕсли;
		
		Если СтруктураОтвета.Свойство("PaymentOrdersResults") Тогда 
			
			Если ТипЗнч(СтруктураОтвета.PaymentOrdersResults) = Тип("Массив") Тогда 
				
				Для Каждого ЭлементМассива Из СтруктураОтвета.PaymentOrdersResults Цикл 
					
					Позиция = ЭлементМассива.position;
					УИД_Документа = ЭлементМассива.paymentId;
					
					МассивНайденныхСтрок = ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
					Если МассивНайденныхСтрок.Количество() > 0 Тогда 
						
						ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
						
						Банк = ПолучитьБанкИзСсылкиНаДокумент(ДокументСсылка,ПредопределенноеЗначение("Справочник.КлассификаторБанков.ПустаяСсылка"));
						Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
						
						Если ТипЗНЧ(ДокументСсылка) = Тип("ДокументСсылка.ВыплатаЗарплаты") Тогда
							ИнтеграцияСБанком_НаСервере.ВнестиНовыйСтатусДокумента(ДокументСсылка,Статус,МассивНайденныхСтрок[0].Сотрудник,ЛОЖЬ,УИД_Документа,Банк,Позиция);
						Иначе	
							ИнтеграцияСБанком_НаСервере.ВнестиНовыйСтатусДокумента(ДокументСсылка,Статус,МассивНайденныхСтрок[0].Сотрудник,ЛОЖЬ,УИД_Документа,Банк,0);
						КонецЕсли;
						
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгружен'"));
						КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
					КонецЕсли;
				КонецЦикла;
				
			ИначеЕсли ТипЗнч(СтруктураОтвета.PaymentOrdersResults) = Тип("Структура") Тогда
				
				Позиция = СтруктураОтвета.PaymentOrdersResults.position;
				УИД_Документа = СтруктураОтвета.PaymentOrdersResults.paymentId;
				
				МассивНайденныхСтрок = ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
				Если МассивНайденныхСтрок.Количество() > 0 Тогда 
					
					ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
					
					Банк = ПолучитьБанкИзСсылкиНаДокумент(ДокументСсылка,ПредопределенноеЗначение("Справочник.КлассификаторБанков.ПустаяСсылка"));
					Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
					
					Если ТипЗНЧ(ДокументСсылка) = Тип("ДокументСсылка.ВыплатаЗарплаты") Тогда
						ИнтеграцияСБанком_НаСервере.ВнестиНовыйСтатусДокумента(ДокументСсылка,Статус,МассивНайденныхСтрок[0].Сотрудник,ЛОЖЬ,УИД_Документа,Банк,Позиция);
					Иначе	
						ИнтеграцияСБанком_НаСервере.ВнестиНовыйСтатусДокумента(ДокументСсылка,Статус,МассивНайденныхСтрок[0].Сотрудник,ЛОЖЬ,УИД_Документа,Банк,0);
					КонецЕсли;
					
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгружен'"));
					КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли СтруктураОтвета.Свойство("mygeminiBatchId") Тогда
			
			ДокументСсылка = НЕОПРЕДЕЛЕНО;
			
			ТаблицаПозиций.Сортировать("ДокументСсылка,Позиция");
			
			Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
			
			УИД_Пакета = Структураответа.mygeminiBatchId;
			
			Для каждого ТекущаяСтрока Из ТаблицаПозиций Цикл
				
				Если НЕ ДокументСсылка = ТекущаяСтрока.ДокументСсылка Тогда
					
					ДокументСсылка = ТекущаяСтрока.ДокументСсылка;
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгружен'"));
					
				КонецЕсли;
				
				Банк = ПолучитьБанкИзСсылкиНаДокумент(ДокументСсылка,ПредопределенноеЗначение("Справочник.КлассификаторБанков.ПустаяСсылка"));
				Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
				
				Если ТипЗНЧ(ДокументСсылка) = Тип("ДокументСсылка.ВыплатаЗарплаты") Тогда
					ИнтеграцияСБанком_НаСервере.ВнестиНовыйСтатусДокумента(ДокументСсылка,Статус,ТекущаяСтрока.Сотрудник,ЛОЖЬ,УИД_Пакета,Банк,ТекущаяСтрока.Позиция);
				Иначе
					ИнтеграцияСБанком_НаСервере.ВнестиНовыйСтатусДокумента(ДокументСсылка,Статус,ТекущаяСтрока.Сотрудник,ЛОЖЬ,УИД_Пакета,Банк,0);
				КонецЕсли;
				
				КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
				
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьСтатусДокумента(ДокументСсылка,СтруктураОтвета,СтруктураПарметровЗапросаВБанк) ЭКСПОРТ
	
	ДатаОбновления = ТекущаяДатаСеанса();
	Банк = ПолучитьБанкИзСсылкиНаДокумент(ДокументСсылка,ПредопределенноеЗначение("Справочник.КлассификаторБанков.ПустаяСсылка"));
	ПеречислениеСтатусовДокументовВИнтернетБанке = "СтатусыДокументовВИнтернетБанке";
	
	ЭтоПакет = ЛОЖЬ;
	Если СтруктураОтвета.Свойство("batchPaymentData")
		ИЛИ (СтруктураПарметровЗапросаВБанк.Свойство("ЭтоПакет") И СтруктураПарметровЗапросаВБанк.ЭтоПакет)
		Тогда
		
		ПеречислениеСтатусовДокументовВИнтернетБанке = "СтатусыПакетныхПеречисленийВИнтернетБанке";
	
		ЭтоПакет = ИСТИНА;
	
	КонецЕсли;
	
	СтатусПолучен = СтруктураОтвета.Свойство("status");
	
	Если СтатусПолучен Тогда
		
		СтатусПолучен = ЛОЖЬ;
		СтатусВИнтернетБанке = НЕОПРЕДЕЛЕНО;
		ТекстСтатуса = СокрЛП(СтруктураОтвета.status);
		
		Для Каждого СтатусЗначениеПеречисления Из Метаданные.Перечисления[ПеречислениеСтатусовДокументовВИнтернетБанке].ЗначенияПеречисления Цикл
			
			Если СтатусЗначениеПеречисления.Имя = ТекстСтатуса Или СтатусЗначениеПеречисления.Синоним = ТекстСтатуса Тогда
				
				СтатусВИнтернетБанке = Перечисления[ПеречислениеСтатусовДокументовВИнтернетБанке][СтатусЗначениеПеречисления.Имя];					
				СтатусПолучен = ИСТИНА;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если СтатусПолучен Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	УИДДокументовВИнтернетБанке.ДокументСсылка КАК ДокументСсылка,
			|	УИДДокументовВИнтернетБанке.Банк КАК Банк,
			|	УИДДокументовВИнтернетБанке.Position КАК Position,
			|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке,"""") КАК УИДДокументаВБанке,
			|	УИДДокументовВИнтернетБанке.Сотрудник КАК Сотрудник
			|ПОМЕСТИТЬ УИДДокументовВИнтернетБанке
			|ИЗ
			|	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
			|ГДЕ
			|	УИДДокументовВИнтернетБанке.ДокументСсылка = &ДокументСсылка
			|	И УИДДокументовВИнтернетБанке.Банк = &Банк
			|	И УИДДокументовВИнтернетБанке.УИДДокументаВБанке = &УИДДокументаВБанке
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	УИДДокументовВИнтернетБанке.ДокументСсылка КАК ДокументСсылка,
			|	УИДДокументовВИнтернетБанке.Position КАК Position,
			|	СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке КАК СтатусДокументаВИнтернетБанке,
			|	СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусПозицииДокументаВИнтернетБанке КАК СтатусПозицииДокументаВИнтернетБанке,
			|	СтатусыДокументовВИнтернетБанкеСрезПоследних.Сотрудник КАК Сотрудник
			|ИЗ
			|	УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
			|		ПО УИДДокументовВИнтернетБанке.ДокументСсылка = СтатусыДокументовВИнтернетБанкеСрезПоследних.ДокументСсылка
			|			И УИДДокументовВИнтернетБанке.Банк = СтатусыДокументовВИнтернетБанкеСрезПоследних.Банк
			|			И УИДДокументовВИнтернетБанке.Position = СтатусыДокументовВИнтернетБанкеСрезПоследних.Position
			|ИТОГИ ПО
			|	ДокументСсылка
			|	,Position";
			
			Запрос.УстановитьПараметр("Банк", Банк);
			Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
			Запрос.УстановитьПараметр("УИДДокументаВБанке", СтруктураПарметровЗапросаВБанк.УИД);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока Выборка.Следующий() Цикл
				
				ВыборкаПозиция = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаПозиция.Следующий() Цикл
					
					ВыборкаДетальныеЗаписи = ВыборкаПозиция.Выбрать();
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
						
						Если ЭтоПакет Тогда
							
							Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.СтатусПозицииДокументаВИнтернетБанке) Тогда
								ТекущийСтатусДокументаВИнтернетБанке = ВыборкаДетальныеЗаписи.СтатусПозицииДокументаВИнтернетБанке;
							Иначе	
								ТекущийСтатусДокументаВИнтернетБанке = ВыборкаДетальныеЗаписи.СтатусДокументаВИнтернетБанке;
							КонецЕсли;
							
							Если СтруктураОтвета.Свойство("batchPaymentData") Тогда
								
								Если ТипЗнч(СтруктураОтвета.batchPaymentData) = Тип("Массив") Тогда
									
									Для Каждого ЭлементМассива Из СтруктураОтвета.batchPaymentData Цикл 
										
										Позиция = Число(ЭлементМассива.position);
										errorDetailGE = "";
										ЭлементМассива.Свойство("errorDetailGE",errorDetailGE);
										errorDetailEN = "";
										ЭлементМассива.Свойство("errorDetailEN",errorDetailEN);
										
										СтатусПозиции = НЕОПРЕДЕЛЕНО;
										paymentStatus = НЕОПРЕДЕЛЕНО;
										Если ЭлементМассива.Свойство("paymentStatus",paymentStatus) Тогда
											
											Для Каждого СтатусЗначениеПеречисления Из Метаданные.Перечисления.СтатусыДокументовВИнтернетБанке.ЗначенияПеречисления Цикл
												
												Если СтатусЗначениеПеречисления.Имя = paymentStatus Или СтатусЗначениеПеречисления.Синоним = paymentStatus Тогда
													
													СтатусПозиции = Перечисления.СтатусыДокументовВИнтернетБанке[СтатусЗначениеПеречисления.Имя];					
													Прервать;
													
												КонецЕсли;
												
											КонецЦикла;
											
											Если СтатусПозиции = НЕОПРЕДЕЛЕНО Тогда
												
												Для Каждого СтатусЗначениеПеречисления Из Метаданные.Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке.ЗначенияПеречисления Цикл
													
													Если СтатусЗначениеПеречисления.Имя = paymentStatus Или СтатусЗначениеПеречисления.Синоним = paymentStatus Тогда
														
														СтатусПозиции = Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке[СтатусЗначениеПеречисления.Имя];					
														Прервать;
														
													КонецЕсли;
													
												КонецЦикла;
												
											КонецЕсли;
											
