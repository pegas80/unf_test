		|	ВТ_ДанныеДокументов.chargeDetailsИмяРеквизита КАК chargeDetailsИмяРеквизита,
		|	ВТ_ДанныеДокументов.Сотрудник КАК Сотрудник,
		|	ВТ_ДанныеДокументов.taxpayerCode КАК taxpayerCode,
		|	ВТ_ДанныеДокументов.taxpayerName КАК taxpayerName,
		|	ВТ_ДанныеДокументов.treasuryCode КАК treasuryCode,
		|	ВТ_ДанныеДокументов.taxpayerCodeИмяРеквизита КАК taxpayerCodeИмяРеквизита,
		|	ВТ_ДанныеДокументов.taxpayerNameИмяРеквизита КАК taxpayerNameИмяРеквизита,
		|	ВТ_ДанныеДокументов.treasuryCodeИмяРеквизита КАК treasuryCodeИмяРеквизита
		|ИЗ
		|	ВТ_ПредПроверка КАК ВТ_ПредПроверка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеДокументов КАК ВТ_ДанныеДокументов
		|		ПО ВТ_ПредПроверка.Ссылка = ВТ_ДанныеДокументов.Ссылка
		|			И ВТ_ПредПроверка.НомерСтроки = ВТ_ДанныеДокументов.НомерСтроки";
	
	Запрос.УстановитьПараметр("МассивДокументов", СтруктураПарметровЗапросаВБанк.МассивДокументов);
	Запрос.УстановитьПараметр("НацВалюта", СтруктураПарметровЗапросаВБанк.ВалютаУчета);
	Запрос.УстановитьПараметр("КодЯзвка", ПользователиИнформационнойБазы.ТекущийПользователь().Язык.КодЯзыка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Функция ПолучитьВыборкуПакетногоЗаполненияПоДокументам(СтруктураПарметровЗапросаВБанк)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	    "ВЫБРАТЬ
	    |	ВыплатаЗарплатыВыплаты.Ссылка КАК Ссылка,
		|	ВыплатаЗарплатыВыплаты.НомерСтроки КАК НомерСтроки,
	    |	ПРЕДСТАВЛЕНИЕ(ВыплатаЗарплатыВыплаты.Ссылка) КАК ИмяПакета,
	    |	ЕСТЬNULL(СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИНтернетБанке.ПрисутствуетТолькоВТекущейБазе)) КАК ТекущийСтатусДокумента,
	    |	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД,
	    |	ВЫБОР
	    |		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
	    |				И ВыплатаЗарплатыВыплаты.Ссылка.Проведен
	    |				И НЕ ВыплатаЗарплатыВыплаты.Ссылка.ПометкаУдаления
	    |				И ВыплатаЗарплатыВыплаты.Ссылка.БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
	    |				И НЕ ВыплатаЗарплатыВыплаты.БанковскийСчетСотрудника = ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
	    |			ТОГДА ИСТИНА
	    |		ИНАЧЕ ЛОЖЬ
	    |	КОНЕЦ КАК РазрешеноВыгрузить,
	    |	ВЫБОР
	    |		КОГДА &КодЯзвка = ""ru""
	    |			ТОГДА ВЫБОР
	    |					КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") <> """"
	    |						ТОГДА ""Документ %ПарамДокументСсылка%: был ранее выгружен""
	    |					КОГДА НЕ ВыплатаЗарплатыВыплаты.Ссылка.Проведен
	    |						ТОГДА ""Документ %ПарамДокументСсылка%: должен быть проведенным""
	    |					КОГДА ВыплатаЗарплатыВыплаты.Ссылка.ПометкаУдаления
	    |						ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы помеченые на удаление""
