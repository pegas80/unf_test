Функция ПолучитьБанкИзСсылкиНаДокумент(ДокументСсылка, БанкПоУмолчанию=НЕОПРЕДЕЛЕНО)
	ПЕРЕМ РЕЗ;
	
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументСсылка, "БанковскийСчетКасса") Тогда
		РЕЗ = ДокументСсылка.БанковскийСчетКасса.Банк;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументСсылка, "Отправитель") Тогда
		РЕЗ = ДокументСсылка.Отправитель.Банк;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументСсылка, "БанковскийСчетКассаОтправитель") Тогда
		РЕЗ = ДокументСсылка.БанковскийСчетКассаОтправитель.Банк;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументСсылка, "БанковскийСчет") Тогда
		РЕЗ = ДокументСсылка.БанковскийСчет.Банк;
	ИначеЕсли ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ДокументСсылка, "Банк") Тогда
		РЕЗ = ДокументСсылка.Банк;
	Иначе
		РЕЗ = БанкПоУмолчанию;
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

// Функция - Создает и возвращает структуру параметров соединения для интеграции с банком ТБС
// 
// Возвращаемое значение - Структура
// 	Поля структуры:
//      TBC_Login					 - Строка - логин пользователя
//      TBC_Password				 - Строка - пароль пользователя
//      TBC_ТестовыйРежим			 - Булево - работаем в тестовом режиме
//      TBC_Сертификат				 - СправочникСсылка.Файлы - ссылка на справочник с хранилищем двоичных данных сертификата
//      TBC_ПарольСертификата		 - Строка - пароль сертификата
//      TBC_РаботаЧерезСервер		 - Булево - предполагается, что соединение с сайтом TBC будет происходить с сервера 1С
//      TBC_ИспользоватьСертификат	 - Булево - ИСТИНА: соединение с банком с использованием сертификата подлинности; ЛОЖЬ - соединение с банком без сертификата подлинности
//      Nonce						 - Строка - Nonce
//      ДвоичныеДанныеСертификата	 - ДвоичныеДанные,АдресВоВременномХранилище - двоичные данные сертификата
//
Функция СтруктураПараметровСоединенияТБС() ЭКСПОРТ
	ПЕРЕМ РЕЗ;

	РЕЗ = Новый Структура("TBC_Login,TBC_Password,TBC_ТестовыйРежим,TBC_Сертификат,TBC_ПарольСертификата,TBC_РаботаЧерезСервер,TBC_ИспользоватьСертификат,Nonce,ДвоичныеДанныеСертификата");
					
    Возврат РЕЗ;
КонецФункции // ()

// Функция - Получить параметры соединения с банком ТБС для пользователя
//
// Параметры:
//  ТекущийПользователь	 - СправочникСсылка.Пользователи - пользователь, для которого нужно получить настройки
// 
// Возвращаемое значение:
// 	Поля структуры:
//      TBC_Login					 - Строка - логин пользователя
//      TBC_Password				 - Строка - пароль пользователя
//      TBC_ТестовыйРежим			 - Булево - работаем в тестовом режиме
//      TBC_Сертификат				 - СправочникСсылка.Файлы - ссылка на справочник с хранилищем двоичных данных сертификата
//      TBC_ПарольСертификата		 - Строка - пароль сертификата
//      TBC_РаботаЧерезСервер		 - Булево - предполагается, что соединение с сайтом TBC будет происходить с сервера 1С
//      TBC_ИспользоватьСертификат	 - Булево - ИСТИНА: соединение с банком с использованием сертификата подлинности; ЛОЖЬ - соединение с банком без сертификата подлинности
//      Nonce						 - Строка - Nonce
//      ДвоичныеДанныеСертификата	 - ДвоичныеДанные,АдресВоВременномХранилище - двоичные данные сертификата
//
Функция ПолучитьПараметрыСоединенияТБС(ТекущийПользователь = НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = СтруктураПараметровСоединенияТБС();
	
	Если ТекущийПользователь = НЕОПРЕДЕЛЕНО Тогда
	
		ТекущийПользователь = Пользователи.ТекущийПользователь();
		
	ИначеЕсли ТипЗНЧ(ТекущийПользователь) = Тип("ПользовательИнформационнойБазы") Тогда
		
		ТекущийПользователь = Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ", ТекущийПользователь.УникальныйИдентификатор);
		
	ИначеЕсли НЕ(ТипЗНЧ(ТекущийПользователь) = Тип("СправочникСсылка.Пользователи")) Тогда
		
		ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	КонецЕсли;

	TBC_Login = ПланыВидовХарактеристик.НастройкиПользователей.TBC_Login;
	TBC_Password = ПланыВидовХарактеристик.НастройкиПользователей.TBC_Password; 
	TBC_ТестовыйРежим = ПланыВидовХарактеристик.НастройкиПользователей.TBC_ТестовыйРежим;
	TBC_Сертификат = ПланыВидовХарактеристик.НастройкиПользователей.TBC_Сертификат;
	TBC_ПарольСертификата = ПланыВидовХарактеристик.НастройкиПользователей.TBC_ПарольСертификата; 
	TBC_РаботаЧерезСервер = ПланыВидовХарактеристик.НастройкиПользователей.TBC_РаботаЧерезСервер;
	TBC_ИспользоватьСертификат = ПланыВидовХарактеристик.НастройкиПользователей.TBC_ИспользоватьСертификат;
	
	СписокНастроек = Новый СписокЗначений();
	СписокНастроек.Добавить(TBC_Login);	
	СписокНастроек.Добавить(TBC_Password);
	СписокНастроек.Добавить(TBC_ТестовыйРежим);
	СписокНастроек.Добавить(TBC_Сертификат);
	СписокНастроек.Добавить(TBC_ПарольСертификата);
	СписокНастроек.Добавить(TBC_РаботаЧерезСервер);
	СписокНастроек.Добавить(TBC_ИспользоватьСертификат);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиПользователей.Настройка КАК Настройка,
		|	НастройкиПользователей.Значение КАК Значение
		|ИЗ
		|	РегистрСведений.НастройкиПользователей КАК НастройкиПользователей
		|ГДЕ
		|	НастройкиПользователей.Настройка В(&Настройка)
		|	И НастройкиПользователей.Пользователь = &ТекущийПользователь";
	
	Запрос.УстановитьПараметр("Настройка", СписокНастроек);
	Запрос.УстановитьПараметр("ТекущийПользователь",ТекущийПользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.Настройка = TBC_Login Тогда
			РЕЗ.TBC_Login = ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка = TBC_Password Тогда
			РЕЗ.TBC_Password = ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка = TBC_ТестовыйРежим Тогда
			РЕЗ.TBC_ТестовыйРежим = ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка = TBC_Сертификат Тогда
			РЕЗ.TBC_Сертификат = ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка = TBC_ПарольСертификата Тогда
			РЕЗ.TBC_ПарольСертификата = ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка = TBC_РаботаЧерезСервер Тогда
			РЕЗ.TBC_РаботаЧерезСервер = ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка = TBC_ИспользоватьСертификат Тогда
			РЕЗ.TBC_ИспользоватьСертификат = ВыборкаДетальныеЗаписи.Значение;
		КонецЕсли;
		
	КонецЦикла;
	
	Если ЗначениеЗаполнено(РЕЗ.TBC_Сертификат) Тогда
	
		ДанныеСертификата = РаботаСФайлами.ДвоичныеДанныеФайла(РЕЗ.TBC_Сертификат, ЛОЖЬ);
		РЕЗ.ДвоичныеДанныеСертификата = ПоместитьВоВременноеХранилище(ДанныеСертификата, Новый УникальныйИдентификатор());
	
	КонецЕсли;
	
    Возврат РЕЗ;
КонецФункции // ()

// Функция - Создать XML Структуру запроса метода сервиса
//
// Параметры:
//  СтруктураПарметровЗапросаВБанк	 - Структура - параметры запроса к банку, содержание зависит от метода, вызываемого на сервисе банка
//  МассивСсылокДокументовПакетов	 - Массив - массив обработанных документов, может быть пустым в зависимости от метода
//  ПрефиксОтвета					 - Строка - используется для создания тела запроса в формате протокала SOAP
//  СуфиксОтвета					 - Строка - используется для создания тела запроса в формате протокала SOAP
//  ПрефиксЗапроса					 - Строка - используется для создания тела запроса в формате протокала SOAP
//  СуфиксЗапроса					 - Строка - используется для создания тела запроса в формате протокала SOAP
// 
// Возвращаемое значение:
//  РЕЗ - Строка - тело XML запроса к банку TBC, содержание зависит от имени метода
//
Функция СоздатьXMLСтруктуруЗапросаМетодаСервиса(СтруктураПарметровЗапросаВБанк,МассивСсылокДокументовПакетов = НЕОПРЕДЕЛЕНО,ПрефиксОтвета = "ns2:",СуфиксОтвета = "ResponseIo",ПрефиксЗапроса = "myg:",СуфиксЗапроса = "RequestIo") ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = "";
	
	ИмяМетода = СтруктураПарметровЗапросаВБанк.ИмяМетода;
	
	Если ИмяМетода = "GetAccountMovements" Тогда
		//Добавим фильтра если есть 
		Если СтруктураПарметровЗапросаВБанк.Свойство("ФильтраЗапроса") Тогда 
			РЕЗ = РЕЗ + ДобавитьФильтры(СтруктураПарметровЗапросаВБанк.ФильтраЗапроса, ПрефиксЗапроса);
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "GetPaymentOrderStatus" Тогда
		
		Если СтруктураПарметровЗапросаВБанк.ЭтоПакет Тогда 
			РЕЗ = РЕЗ + "<" + ПрефиксЗапроса + "batchPaymentId>"+ СокрЛП(СтруктураПарметровЗапросаВБанк.УИД) + "</" + ПрефиксЗапроса + "batchPaymentId>";
		Иначе
			РЕЗ = РЕЗ + "<" + ПрефиксЗапроса + "singlePaymentId>"+ СокрЛП(СтруктураПарметровЗапросаВБанк.УИД) + "</" + ПрефиксЗапроса + "singlePaymentId>";
		КонецЕсли;
		
	ИначеЕсли ИмяМетода = "ImportSinglePaymentOrders" Тогда
		
		МассивСсылокДокументовПакетов = Новый Массив;
		тзПозиций = ПолучитьИзВременногоХранилища(СтруктураПарметровЗапросаВБанк.ТаблицаПозиций);
		
		ВыборкаДляЗаполнения = ПолучитьВыборкуЗаполненияПоДокументам(СтруктураПарметровЗапросаВБанк);
		
		ТекстТэговРасходовСоСчетов = "";
		СчетчикПозиций = 1;
		КолвоДоковВЗапросе = 0;
		ПредыдущийДокумент = Неопределено;
		Пока ВыборкаДляЗаполнения.Следующий() Цикл 
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса + "singlePaymentOrder xsi:type=""" + ПрефиксЗапроса + ВыборкаДляЗаполнения["singlePaymentOrder"] + """>";
			
			Если НЕ ВыборкаДляЗаполнения.РазрешеноВыгрузить Тогда
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрЗаменить(ВыборкаДляЗаполнения.ОписатниеЗапрета, "%ПарамДокументСсылка%", ВыборкаДляЗаполнения.Ссылка));
				Продолжить;
				
			Иначе                                                                                                         
				
				Если НЕ ЗначениеЗаполнено(ВыборкаДляЗаполнения.singlePaymentOrder) И Не ЗначениеЗаполнено(ВыборкаДляЗаполнения.CreditАccountNumber) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName +"'; ka = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName+"'"));
					Продолжить;
				КонецЕсли;
				
				Если ПредыдущийДокумент <> ВыборкаДляЗаполнения.Ссылка Тогда 
					КолвоДоковВЗапросе = КолвоДоковВЗапросе + 1;
					ПредыдущийДокумент = ВыборкаДляЗаполнения.Ссылка;
				КонецЕсли;
				
			КонецЕсли;
			
			СтруктураТэгов = СтруктураПарметровЗапросаВБанк.СтруктурыТэгов[ВыборкаДляЗаполнения.singlePaymentOrder];
			
			Для Каждого Элем Из СтруктураТэгов Цикл 
				
				Если Элем.Ключ = "singlePaymentRequestId" Тогда 
					
					Если СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) <> "" Тогда 
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					КонецЕсли;
					
				ИначеЕсли Элем.Ключ = "documentNumber" Тогда 
					
					НомерДокумента = ВыборкаДляЗаполнения.documentNumber;
					НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(НомерДокумента, Истина, Истина);
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+"documentNumber>" + НомерДокумента + "</"+ПрефиксЗапроса+"documentNumber>";
					
				ИначеЕсли Элем.Ключ = "position" Тогда
					
					Если ВыборкаДляЗаполнения.position>0 Тогда
						СчетчикПозиций = ВыборкаДляЗаполнения.position;
					КонецЕсли;
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СчетчикПозиций + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					
					СтрокаПоизиции = тзПозиций.Добавить();
					СтрокаПоизиции.Позиция = Строка(СчетчикПозиций);
					СтрокаПоизиции.Сотрудник = ВыборкаДляЗаполнения.Сотрудник;
					СтрокаПоизиции.ДокументСсылка = ВыборкаДляЗаполнения.Ссылка;
					
					СчетчикПозиций = СчетчикПозиций + 1;
					
				ИначеЕсли Элем.Ключ = "taxpayerCode" ИЛИ Элем.Ключ = "taxpayerName" Тогда
					
					Если ЗначениеЗаполнено(ВыборкаДляЗаполнения[Элем.Ключ]) Тогда
					
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					
					КонецЕсли;
					
				ИначеЕсли Элем.Ключ = "additionalDescription" Тогда
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "##"+XMLСтрока(ВыборкаДляЗаполнения.Ссылка) + "##" + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					
				ИначеЕсли Элем.Значение = Неопределено Тогда 
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
					
				ИначеЕсли ТипЗнч(Элем.Значение) = Тип("Структура") Тогда 
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">"; 
					Для Каждого ДопЭлемент Из Элем.Значение Цикл
						Если ДопЭлемент.Ключ = "amount" Тогда  
							ЦелаяЧасть = Цел(ВыборкаДляЗаполнения[ДопЭлемент.Ключ]);
							ДробнаяЧасть = ВыборкаДляЗаполнения[ДопЭлемент.Ключ] - ЦелаяЧасть;
							ЦелаяЧасть = СтрЗаменить(СтрЗаменить(СтрЗаменить(Строка(ЦелаяЧасть), ",", ""), Символы.НПП, ""),"", "");
							Если ДробнаяЧасть = 0 Тогда 
								ЗначенияПодстановки = ЦелаяЧасть;
							Иначе
								ЗначенияПодстановки = ЦелаяЧасть + "." + Сред(Строка(ДробнаяЧасть),3);
							КонецЕсли;
						Иначе
							
							ЗначенияПодстановки = СтрЗаменить(СтрЗаменить(Строка(ВыборкаДляЗаполнения[ДопЭлемент.Ключ]), ",", "."), Символы.НПП, "");
							
						КонецЕсли;
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+ДопЭлемент.Ключ+">" + СокрЛп(ЗначенияПодстановки) + "</"+ПрефиксЗапроса+ДопЭлемент.Ключ+">";
					КонецЦикла;
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса+Элем.Ключ+">";
				КонецЕсли;
			КонецЦикла;
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса + "singlePaymentOrder>";
			
		КонецЦикла;
		
		Если КолвоДоковВЗапросе = 0 Тогда 
			
			СтруктураОтвета = Новый Структура;
			Если МассивСсылокДокументовПакетов <> Неопределено И МассивСсылокДокументовПакетов.Количество() > 0 Тогда 
				СтруктураОтвета.Вставить("МассивСсылокДокументовПакетов", МассивСсылокДокументовПакетов);
			КонецЕсли;
			
			Возврат СтруктураОтвета;
			
		КонецЕсли;
		
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountNumber", "accountNumber");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "DebitАccountNumber", "accountNumber");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountCurrencyCode", "accountCurrencyCode");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "DebitАccountCurrencyCode", "accountCurrencyCode");
		
		РЕЗ = РЕЗ + ТекстТэговРасходовСоСчетов;
		
	ИначеЕсли ИмяМетода = "ImportBatchPaymentOrder" Тогда
		
		ВалютаУчета = СтруктураПарметровЗапросаВБанк.ВалютаУчета;
		
		тзПозиций = ПолучитьИзВременногоХранилища(СтруктураПарметровЗапросаВБанк.ТаблицаПозиций);
		
		ВыборкаГруппыИмяПакета = ПолучитьВыборкуПакетногоЗаполненияПоДокументам(СтруктураПарметровЗапросаВБанк);
		
		ТекстТэговРасходовСоСчетов = "";
		СчетчикПозиций = 1;
		
		КолвоДоковВЗапросе = 0;
		Пока ВыборкаГруппыИмяПакета.Следующий() Цикл 
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов +"<myg:"+ИмяМетода+СуфиксЗапроса+">";
			
			ВыборкаГруппаНомерСчета = ВыборкаГруппыИмяПакета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаГруппаНомерСчета.Следующий() Цикл
				ВыборкаГруппаВалютаДебита = ВыборкаГруппаНомерСчета.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				
				Пока ВыборкаГруппаВалютаДебита.Следующий() Цикл
					//Дополним Текст Данными имени пакета и счата Дебита
					
					ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + ПолучитьТекстДебита(ВыборкаГруппаВалютаДебита);
										
					ВыборкаДляЗаполнения = ВыборкаГруппаВалютаДебита.Выбрать();
					
					Пока ВыборкаДляЗаполнения.Следующий() Цикл
						
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса + "paymentOrder xsi:type=""" + ПрефиксЗапроса + ВыборкаДляЗаполнения["paymentOrder"] + """>";
						
						Если НЕ ВыборкаДляЗаполнения.РазрешеноВыгрузить Тогда
							
							// с "" документы Зарплаты, которые выгружаются пакетом
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрЗаменить(ВыборкаДляЗаполнения.ОписатниеЗапрета, "%ПарамДокументСсылка%", ВыборкаДляЗаполнения.Ссылка));
							
							Продолжить;
							
						Иначе
							
							Если НЕ ЗначениеЗаполнено(ВыборкаДляЗаполнения.paymentOrder) И Не ЗначениеЗаполнено(ВыборкаДляЗаполнения.CreditАccountNumber) Тогда
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName +"'; ka = 'Документ: """+ВыборкаДляЗаполнения.Ссылка+""", не заполнен """+ВыборкаДляЗаполнения.CreditАccountNumberИмяРеквизита+""", у "+ВыборкаДляЗаполнения.beneficiaryName+"'"));
								Продолжить;
							КонецЕсли;
							
							Если ПредыдущийДокумент <> ВыборкаДляЗаполнения.Ссылка Тогда 
								КолвоДоковВЗапросе = КолвоДоковВЗапросе + 1;
								ПредыдущийДокумент = ВыборкаДляЗаполнения.Ссылка;
							КонецЕсли;
							//КолвоДоковВЗапросе = КолвоДоковВЗапросе + 1;
							
						КонецЕсли;
						
						СтруктураТэгов = СтруктураПарметровЗапросаВБанк.СтруктурыТэгов[ВыборкаДляЗаполнения.paymentOrder];
						
						Для Каждого Элем Из СтруктураТэгов Цикл 
							
							Если Элем.Ключ = "singlePaymentRequestId" Тогда 
								
								//Повторная отправки выгруженного документа - не используется в конфигурации
								// создайте новый документ
								
							ИначеЕсли Элем.Ключ = "documentNumber" Тогда 
								
								НомерДокумента = ВыборкаДляЗаполнения.documentNumber;
								НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(НомерДокумента, Истина, Истина);
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+"documentNumber>" + НомерДокумента + "</"+ПрефиксЗапроса+"documentNumber>";
								
							ИначеЕсли Элем.Ключ = "position" Тогда
								
								Если ВыборкаДляЗаполнения.position>0 Тогда
									СчетчикПозиций = ВыборкаДляЗаполнения.position;
								КонецЕсли;
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СчетчикПозиций + "</"+ПрефиксЗапроса+Элем.Ключ+">";
								
								СтрокаПоизиции = тзПозиций.Добавить();
								СтрокаПоизиции.Позиция = Строка(СчетчикПозиций);
								СтрокаПоизиции.Сотрудник = ВыборкаДляЗаполнения.Сотрудник;
								СтрокаПоизиции.ДокументСсылка = ВыборкаДляЗаполнения.Ссылка;
								
								СчетчикПозиций = СчетчикПозиций + 1;
								
							ИначеЕсли Элем.Ключ = "taxpayerCode" ИЛИ Элем.Ключ = "taxpayerName" Тогда
					
								Если ЗначениеЗаполнено(ВыборкаДляЗаполнения[Элем.Ключ]) Тогда
									
									ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
									
								КонецЕсли;
								
							ИначеЕсли Элем.Ключ = "debitAccount" Тогда
								
								Продолжить;
								
							ИначеЕсли Элем.Ключ = "additionalDescription" Тогда
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "##"+XMLСтрока(ВыборкаДляЗаполнения.Ссылка) + "##" + "</"+ПрефиксЗапроса+Элем.Ключ+">";
								
							ИначеЕсли Элем.Значение = Неопределено Тогда 
								
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">" + СокрЛП(ВыборкаДляЗаполнения[Элем.Ключ]) + "</"+ПрефиксЗапроса+Элем.Ключ+">";
								
							ИначеЕсли ТипЗнч(Элем.Значение) = Тип("Структура") Тогда 
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+Элем.Ключ+">"; 
								Для Каждого ДопЭлемент Из Элем.Значение Цикл
									ЗначенияПодстановки = СтрЗаменить(СтрЗаменить(Строка(ВыборкаДляЗаполнения[ДопЭлемент.Ключ]), ",", "."), Символы.НПП, "");
									ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "<"+ПрефиксЗапроса+ДопЭлемент.Ключ+">" + СокрЛП(ЗначенияПодстановки) + "</"+ПрефиксЗапроса+ДопЭлемент.Ключ+">";
								КонецЦикла;
								ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса+Элем.Ключ+">";
							КонецЕсли;
						КонецЦикла;
						
						ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</"+ПрефиксЗапроса + "paymentOrder>";
						
					КонецЦикла;
				КонецЦикла;
				
			КонецЦикла;
			
			ТекстТэговРасходовСоСчетов = ТекстТэговРасходовСоСчетов + "</myg:"+ИмяМетода+СуфиксЗапроса+">"
		КонецЦикла;
		
		Если КолвоДоковВЗапросе = 0 Тогда 
			Возврат новый Структура;
		КонецЕсли;
		
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountNumber", "accountNumber");
		ТекстТэговРасходовСоСчетов = СтрЗаменить(ТекстТэговРасходовСоСчетов, "CreditАccountCurrencyCode", "accountCurrencyCode");
		
		РЕЗ = РЕЗ + ТекстТэговРасходовСоСчетов;
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции

Функция ПолучитьТекстДебита(Выборка)
	
	ТекстВозврата = 
	"<myg:debitAccountIdentification>"
	+"<myg:accountNumber>"+Выборка.DebitАccountNumber+"</myg:accountNumber>"           
	+"<myg:accountCurrencyCode>"+Выборка.DebitАccountCurrencyCode+"</myg:accountCurrencyCode>"
	+"</myg:debitAccountIdentification>"
	+"<myg:batchName>"+Выборка.batchName+"</myg:batchName>";
	
	Возврат ТекстВозврата;
	
КонецФункции

Функция ДобавитьФильтры(СтруктураФильтров, Префикс)
	
	ТекстXML = "<myg:accountMovementFilterIo>";
	
	Для Каждого Элем Из СтруктураФильтров Цикл
		
		ТекстXML = ТекстXML + "<" + Префикс + Элем.Ключ + ">" ;
		
		Если ТипЗНЧ(Элем.Значение) = Тип("Структура") Тогда
			
			ВнутренняяСтруктураФильтров = Элем.Значение;
			
			Для каждого ВнутреннийЭлемент Из ВнутренняяСтруктураФильтров Цикл
			
				ТекстXML = ТекстXML + "<" + Префикс + ВнутреннийЭлемент.Ключ + ">";
				
				ЗначениеВнутреннеегоФильтра = ОбработатьТекстДляXML(ВнутреннийЭлемент.Значение);
				ТекстXML = ТекстXML + ЗначениеВнутреннеегоФильтра;
				
				ТекстXML = ТекстXML + "</" + Префикс + ВнутреннийЭлемент.Ключ + ">";	
			
			КонецЦикла;
			
		Иначе
			
			ЗначениеФильтра = ОбработатьТекстДляXML(Элем.Значение);
			ТекстXML = ТекстXML + ЗначениеФильтра;	
			
		КонецЕсли;
		
		ТекстXML = ТекстXML + "</" + Префикс + Элем.Ключ + ">";	
		
	КонецЦикла;
	
	ТекстXML = ТекстXML + "</myg:accountMovementFilterIo>";
	
	Возврат ТекстXML;
	
КонецФункции

Функция ОбработатьТекстДляXML(Значение)
	
	ЗначениеВозврата = Значение;
	Если ТипЗнч(Значение) = Тип("Дата") Тогда 
		ЗначениеВозврата = ДатаВремяВСтроку(ЗначениеВозврата);
	КонецЕсли;
	
	ЗначениеВозврата = ЗаменитьНедопустимыСимволы(ЗначениеВозврата);
	
	Возврат ЗначениеВозврата;	
	
КонецФункции

Функция ЗаменитьНедопустимыСимволы(Значение)
	ПЕРЕМ РЕЗ;
	
	РЕЗ=Строка(Значение);
	
	ТекДлинаСтроки = СтрДлина(Значение);
	
	РЕЗ=СтрЗаменить(РЕЗ,"&","&amp;");
	РЕЗ=СтрЗаменить(РЕЗ,"<","&lt;");
	РЕЗ=СтрЗаменить(РЕЗ,">","&gt;");
	РЕЗ=СтрЗаменить(РЕЗ,"'","&apos;");
	РЕЗ=СтрЗаменить(РЕЗ,"""","&quot;");
	
	Возврат РЕЗ;
КонецФункции

Функция ДатаВремяВСтроку(Дата) 
	
	Если НЕ ЗначениеЗаполнено(Дата) Тогда
		Возврат "";
	Иначе
		ДатаСтрока = Строка(Формат(Дата, "ДФ='yyyy-MM-dd'")) + "T" + Строка(Формат(Дата, "ДФ=HH:mm:ss"));
		Возврат ДатаСтрока;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьВыборкуЗаполненияПоДокументам(СтруктураПарметровЗапросаВБанк)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходДенежныхСредств.Ссылка КАК Ссылка,
		|	0 КАК НомерСтроки,
		|	ЕСТЬNULL(СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке, ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИНтернетБанке.ПрисутствуетТолькоВТекущейБазе)) КАК ТекущийСтатусДокумента,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
		|				И РасходДенежныхСредств.Проведен
		|				И НЕ РасходДенежныхСредств.ПометкаУдаления
		|				И РасходДенежныхСредств.БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|				И НЕ РасходДенежныхСредств.СчетКонтрагента = ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК РазрешеноВыгрузить,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") <> """"
		|			ТОГДА ""Документ %ПарамДокументСсылка%: был ранее выгружен""
		|		КОГДА НЕ РасходДенежныхСредств.Проведен
		|			ТОГДА ""Документ %ПарамДокументСсылка%: должен быть проведенным""
		|		КОГДА РасходДенежныхСредств.ПометкаУдаления
		|			ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы помеченые на удаление""
		|		КОГДА НЕ РасходДенежныхСредств.БанковскийСчетКасса ССЫЛКА Справочник.БанковскиеСчета
		|			ТОГДА ""Документ %ПарамДокументСсылка%: Запрещенно выгружать документы расхода по кассе или сотруднику""
		|		КОГДА РасходДенежныхСредств.СчетКонтрагента = ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
		|			ТОГДА ""Документ %ПарамДокументСсылка%: Не определен счет контрагента""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК ОписатниеЗапрета
		|ПОМЕСТИТЬ ВТ_ПредПроверка
