Процедура ЗаписатьНовыйСтатусДокумента(ДатаОбновления,ДокументСсылка,Банк,position,СтатусВИнтернетБанке,Сотрудник,СтатусПозиции=НЕОПРЕДЕЛЕНО) ЭКСПОРТ
	
	ТекPosition = ЧИСЛО(position);

	ДатаОбновления = ТекущаяДата();
	НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
	НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ДатаОбновления);
	НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
	НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(Банк);
	НаборЗаписейСтатусовДокумента.Отбор.Position.Установить(ТекPosition);
	
	НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
	НовыйСтатус.Период = ДатаОбновления;
	НовыйСтатус.ДокументСсылка = ДокументСсылка;
	НовыйСтатус.Банк = Банк;
	НовыйСтатус.Position = ТекPosition;
	НовыйСтатус.СтатусДокументаВИнтернетБанке = СтатусВИнтернетБанке;
	НовыйСтатус.Сотрудник = Сотрудник;
	НовыйСтатус.СтатусПозицииДокументаВИнтернетБанке = СтатусПозиции;
	
	НаборЗаписейСтатусовДокумента.Записать();

КонецПроцедуры

Функция ПолучитьМассив_УИД_Документа(ДокументСсылка) ЭКСПОРТ
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Массив();
	
	Банк = ПолучитьБанкИзСсылкиНаДокумент(ДокументСсылка);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	УИДДокументовВИнтернетБанке.ДокументСсылка КАК ДокументСсылка,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """""""") КАК УИД
		|ИЗ
		|	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|ГДЕ
		|	УИДДокументовВИнтернетБанке.ДокументСсылка = &ДокументСсылка
		|	И УИДДокументовВИнтернетБанке.Банк = &Банк";
	
	Запрос.УстановитьПараметр("Банк", Банк);
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		РЕЗ = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("УИД");
	КонецЕсли;
	
	Возврат РЕЗ;
	
КонецФункции

Процедура ОбработатьДанныеДвиженийПоСчетуНаСервере(СтруктураОтвета,ТаблицаДвиженийПоСчетуАдресВременногоХранилища) ЭКСПОРТ
	
	Если СтруктураОтвета.Свойство("ТекстОшибки") Тогда 
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураОтвета.ТекстОшибки);
		
	Иначе
		
		ТаблицаДвиженийПоСчету = ПолучитьИзВременногоХранилища(ТаблицаДвиженийПоСчетуАдресВременногоХранилища);
		
		Если Структураответа.Свойство("accountMovement") Тогда 
			
			Если ТипЗнч(Структураответа.accountMovement) = Тип("Массив") Тогда 
				Для Каждого ЭлемМассива Из Структураответа.accountMovement Цикл 
					
					СтруктураЗаполнения = ЭлемМассива;
					
					ДобавитьСтрокуТаблицыДвиженийПоСчету(СтруктураЗаполнения, ТаблицаДвиженийПоСчету);
					
				КонецЦикла;
			ИначеЕсли ТипЗнч(Структураответа.accountMovement) = Тип("Структура") Тогда	
				
				СтруктураЗаполнения = Структураответа.accountMovement;
				
				ДобавитьСтрокуТаблицыДвиженийПоСчету(СтруктураЗаполнения, ТаблицаДвиженийПоСчету);
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьСтрокуТаблицыДвиженийПоСчету(СтруктураЗаполнения, ТаблицаДвиженийПоСчету)
	
	СтрокаТаблицаДвиженийПоСчету = ТаблицаДвиженийПоСчету.Добавить();
	
	ЗаполнитьЗначенияСвойств(СтрокаТаблицаДвиженийПоСчету, СтруктураЗаполнения);
	
	Если СтруктураЗаполнения.Свойство("amount") Тогда 
		ЗаполнитьЗначенияСвойств(СтрокаТаблицаДвиженийПоСчету, СтруктураЗаполнения.amount);
	КонецЕсли;
	
КонецПроцедуры

