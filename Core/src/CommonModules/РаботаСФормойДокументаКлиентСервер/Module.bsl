
#Область ПрограммныйИнтерфейс

Функция СформироватьНадписьСчетФактура(НайденныйСчетФактура, Полученный = Ложь, СчетФактураТекст="") Экспорт

	КомпонентыФС = Новый Массив;
	Если Полученный Тогда
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Счет-фактура (полученный): '; ka = 'ანგარიშფაქტურა (მიღებული): '; en = 'Invoice (received):'")));
		
	Иначе
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Счет-фактура: '; ka = 'ანგარიშფაქტურა: '; en = 'Invoice:'")));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НайденныйСчетФактура) Тогда
		Если ТипЗнч(НайденныйСчетФактура) = Тип("Структура") Тогда
			Если Полученный Тогда
				СчетФактураТекст = СтрЗаменить(НайденныйСчетФактура.Ссылка, 
					НСтр("ru = 'Счет-фактура (полученный) '; ka = 'ანგარიშფაქტურა (მიღბული)'; en = 'Invoice (received)'")+РаботаСФормойДокументаКлиентСервер.ПолучитьКороткийНомерДокумента(НайденныйСчетФактура.Ссылка.Номер),
					"№ "+НайденныйСчетФактура.Ссылка.НомерВходящегоДокумента);
			Иначе
				СчетФактураТекст = СтрЗаменить(НайденныйСчетФактура.Ссылка, НСтр("ru = 'Счет-фактура '; ka = 'ანგარიშფაქტურა '; en = 'Invoice'"),"№");
			КонецЕсли;
		Иначе
			//для строки
			СчетФактураТекст = СтрЗаменить(НайденныйСчетФактура, НСтр("ru = 'Счет-фактура '; ka = 'ანგარიშფაქტურა '; en = 'Invoice'"),"№");
		КонецЕсли;
		
		СчетФактураТекст = СтрЗаменить(СчетФактураТекст, НСтр("ru = ' (удален)'; ka = '(წაშლილია)'; en = '(deleted)'"),"");
		СчетФактураТекст = СтрЗаменить(СчетФактураТекст, НСтр("ru = ' (не проведен)'; ka = '(არ  არის გატარებული)'; en = '(not posted)'"),"");
		
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(СчетФактураТекст, , , , "открыть"));
	Иначе
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока("შექმნა", , , , "შექმნა"));
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(КомпонентыФС);

КонецФункции

Функция СформироватьНадписьДокументОснование(Знач ДокОснование, Знач пТолькоПросмотр = Ложь) Экспорт
	
	КомпонентыФС = Новый Массив;
	
	ПредставлениеДокОснования = РаботаСФормойДокумента.ПредставлениеДокументаОснования(ДокОснование);
	
	Если ПредставлениеДокОснования = "НетОбъекта" Тогда
		
		КомпонентыФС = Новый Массив;
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ka='საფუძველი: იმყოფება ავტონომიურ სამუშაო ადგილზე';ru='Основание: находится в автомном рабочем месте';en='Base: it is in avtomnom workplace'")));
		
	ИначеЕсли ЗначениеЗаполнено(ПредставлениеДокОснования) Тогда
		
		//Для документов, у которых "номер входящего документа" указывается в отдельном поле, например Счет-фактура входящий
		Если ТипЗнч(ДокОснование) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда
			ПредставлениеДокОснования = СтрЗаменить(ПредставлениеДокОснования, 
				НСтр("ru = 'Счет-фактура (полученный) '; ka = 'ანგარიშ-ფაქტორა (მიღებული)'; en = 'Invoice (received)'")+РаботаСФормойДокументаКлиентСервер.ПолучитьКороткийНомерДокумента(ДокОснование.Номер),
				НСтр("ru = 'Счет-фактура (полученный) '; ka = 'ანგარიშ-ფაქტორა (მიღებული)'; en = 'Invoice (received)'")+ДокОснование.НомерВходящегоДокумента);
			ПредставлениеДокОснования = СтрЗаменить(ПредставлениеДокОснования,
				Формат(ДокОснование.Дата,"ДФ=dd.MM.yyyy"),
				Формат(ДокОснование.ДатаВходящегоДокумента,"ДФ=dd.MM.yyyy"));
		КонецЕсли;
		
		ДокОснованиеТекст = ПредставлениеДокОснования;
		
		ДокОснованиеТекст = СтрЗаменить(ДокОснованиеТекст, НСтр("ru = ' (удален)'; ka = '(წაშლილია)'; en = '(deleted)'"),"");
		ДокОснованиеТекст = СтрЗаменить(ДокОснованиеТекст, НСтр("ru = ' (не проведен)'; ka = '(არ  არის გატარებული)'; en = '(hasn''t been posted)'"),"");

		КомпонентыФС = Новый Массив;
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Основание: '; ka = 'საფუძველი: '; en = 'Basis:'")));
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(ДокОснованиеТекст, , , , "открыть"));
		Если НЕ пТолькоПросмотр Тогда
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(" "));
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.ЗаполнитьПоОснованию12х12, , , , "заполнить"));
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(" "));
			КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(БиблиотекаКартинок.Очистить, , , , "удалить"));
		КонецЕсли;
	Иначе
		КомпонентыФС = Новый Массив;
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Основание: '; ka = 'საფუძველი: '; en = 'Basis:'")));
		КомпонентыФС.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'выбрать'; ka = 'არჩევა'; en = 'select'"), , , , "выбрать"));
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(КомпонентыФС);

КонецФункции


Функция ПолучитьЗаголовокПредоплаты(Знач ТабЧасть, Знач ВалютаДокумента) Экспорт
	
	Если ТабЧасть.Количество()>0 Тогда
		Возврат НСтр("ru = 'Предоплата: '; ka = 'წინასწარი გადახდა: '; en = 'Prepayment:'") + ТабЧасть.Итог("СуммаРасчетов") + " " + УправлениеНебольшойФирмойПовтИсп.ПолучитьСимвольноеПредставлениеВалюты(ВалютаДокумента); 
	Иначе
		Возврат НСтр("ru = 'Предоплата'; ka = 'წინასწარი გადახდა'; en = 'prepayment'");
	КонецЕсли;
	
КонецФункции

Функция КраткоеПредставлениеТипаНалогообложенияНДС(НалогообложениеНДС) Экспорт
	
	Если НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС") Тогда
		Возврат НСтр("ka='დღგ-ით';ru='с НДС';en='VAT included'");
	ИначеЕсли НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НеОблагаетсяНДС") Тогда
		Возврат НСтр("ka='დღგ-ის გარეშე';ru='без НДС';en='without VAT'");
	ИначеЕсли НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.НаЭкспорт") Тогда
		Возврат НСтр("ka='0% დღგ';ru='0% НДС';en='0% VAT'");
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

#КонецОбласти

