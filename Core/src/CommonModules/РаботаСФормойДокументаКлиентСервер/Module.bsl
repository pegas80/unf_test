Функция СформироватьНадписьЭлНакладная(НайденныйЭлНакладная, ЭлНакладнаяТекст="") Экспорт

	КомпонентыЭН = Новый Массив;
	КомпонентыЭН.Добавить(Новый ФорматированнаяСтрока(НСтр("ru = 'Эл-Накладная: '; ka = 'სასაქონლო ზედნადები: '; en = 'Waybill:'")));
	
	Если ЗначениеЗаполнено(НайденныйЭлНакладная) Тогда
		Если ТипЗнч(НайденныйЭлНакладная) = Тип("Структура") Тогда
			ЭлНакладнаяТекст = СтрЗаменить(НайденныйЭлНакладная.Ссылка, НСтр("ru = 'Эл-Накладная: '; ka = 'სასაქონლო ზედნადები: '; en = 'WayBill:'"),"№");
		КонецЕсли;
		ЭлНакладнаяТекст = СтрЗаменить(ЭлНакладнаяТекст, НСтр("ru = ' (удален)'; ka = '(წაშლილია)'; en = '(deleted)'"),"");
		ЭлНакладнаяТекст = СтрЗаменить(ЭлНакладнаяТекст, НСтр("ru = ' (не проведен)'; ka = '(არ არის გატარებული)'; en = '(not posted)'"),"");
		
		КомпонентыЭН.Добавить(Новый ФорматированнаяСтрока(ЭлНакладнаяТекст, , , , НСтр("ka='გახსნა';ru='открыть';en='open'")));
	Иначе
		КомпонентыЭН.Добавить(Новый ФорматированнаяСтрока(НСтр("ka='შექმნა';ru='создать';en='create'"), , , , НСтр("ka='შექმნა';ru='создать';en='create'")));
	КонецЕсли;
	Возврат Новый ФорматированнаяСтрока(КомпонентыЭН);

КонецФункции

