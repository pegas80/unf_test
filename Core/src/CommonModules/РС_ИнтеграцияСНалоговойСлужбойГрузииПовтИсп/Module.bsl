Функция ПолучитьSLLСоединение() Экспорт 
	
	SLL = Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаWindows(),Новый СертификатыУдостоверяющихЦентровWindows());
	
	Возврат SLL;
	
КонецФункции

Функция ПолучитьWSОпределение(РежимПротокола = Неопределено) Экспорт 
	
	SLL = ПолучитьSLLСоединение();
	
	#Если Сервер Тогда
		Если РежимПротокола = Перечисления.РС_ВидыРежимовПротокола.http Тогда 
			Возврат Новый WSОпределения("http://services.rs.ge/WayBillService/WayBillService.asmx?wsdl", "");
		Иначе 
			Возврат Новый WSОпределения("https://services.rs.ge/WayBillService/WayBillService.asmx?wsdl", "",,,,SLL);
		КонецЕсли;
	#Иначе
		Если глОпределение = Неопределено Тогда
			Если РежимПротокола = Перечисления.РС_ВидыРежимовПротокола.http Тогда 
				глОпределение = Новый WSОпределения("http://services.rs.ge/WayBillService/WayBillService.asmx?wsdl", "");
			Иначе 
				глОпределение = Новый WSОпределения("https://services.rs.ge/WayBillService/WayBillService.asmx?wsdl", "",,,,SLL);
			КонецЕсли;
		КонецЕсли;
		Возврат	глОпределение;
	#КонецЕсли
	
КонецФункции

