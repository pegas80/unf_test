Функция ПолучитьСтруктуруПараметровWS(Организация = Неопределено) Экспорт
	
	СтруктураИнициализации = Новый Структура;
	СтруктураИнициализации.Вставить("ПользовательПодключения","");
	СтруктураИнициализации.Вставить("ПарольПодключения","");
	СтруктураИнициализации.Вставить("РежимовПротоколаДляОбменаRS","");
	
	Если Организация = Неопределено Тогда 
		Организация = РегламентированнаяОтчетность.ПолучитьОрганизациюПоУмолчанию();//РС_ИнтеграцияСНалоговойСлужбойГрузииПовтИсп
	КонецЕсли;
	
	Если Организация.МногопользовательскийРежимОбменаRS Тогда 
		//Отбор = Новый Структура;
		//Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьНесколькоОрганизаций") Тогда
		//	Отбор.Вставить("Организация", Организация);
		//КонецЕсли;
		//Отбор.Вставить("Пользователь", Пользователи.ТекущийПользователь());
		//ВыборкаТекПараметрыПользователья = РегистрыСведений.РС_ПользователиИнтеграцийНалоговойСлужбы.Выбрать(Отбор);
		
		//++Lazare_ закомментировал 25.08.2021. Когда количество параметров >1,выборка не работает.Структура Отборa может содержать только один элемент !	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РС_ПользователиИнтеграцийНалоговойСлужбы.ПользовательПодключения КАК ПользовательПодключения,
		|	РС_ПользователиИнтеграцийНалоговойСлужбы.ПарольПодключения КАК ПарольПодключения,
		|	РС_ПользователиИнтеграцийНалоговойСлужбы.РежимовПротоколаДляОбменаRS КАК РежимовПротоколаДляОбменаRS
		|ИЗ
		|	РегистрСведений.РС_ПользователиИнтеграцийНалоговойСлужбы КАК РС_ПользователиИнтеграцийНалоговойСлужбы
		|ГДЕ
		|	РС_ПользователиИнтеграцийНалоговойСлужбы.Пользователь = &Пользователь
		|	И РС_ПользователиИнтеграцийНалоговойСлужбы.Организация = &Организация";
		Если УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьНесколькоОрганизаций") Тогда
			Запрос.УстановитьПараметр("Организация", Организация);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "И РС_ПользователиИнтеграцийНалоговойСлужбы.Организация = &Организация", "");
		КонецЕсли;
		Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
		//--Lazare_25.08.2021
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаТекПараметрыПользователья = РезультатЗапроса.Выбрать();	
		
		Если ВыборкаТекПараметрыПользователья.Следующий() Тогда  
			СтруктураИнициализации.ПользовательПодключения		= ВыборкаТекПараметрыПользователья.ПользовательПодключения;
			СтруктураИнициализации.ПарольПодключения			= ВыборкаТекПараметрыПользователья.ПарольПодключения;
			СтруктураИнициализации.РежимовПротоколаДляОбменаRS  = ?(ЗначениеЗаполнено(Организация.РежимовПротоколаДляОбменаRS), Организация.РежимовПротоколаДляОбменаRS, Перечисления.РС_ВидыРежимовПротокола.http);
		Иначе 
			Сообщить(НСтр("ka='არ არის ნაპოვნი სერვისის მომხმარებელი პროგრამის მიმდინარე მომხმარებლისთვის.';ru='Не найдены настройки сервиса для текущего пользователя.';en='service settings are not found for the current user.'"));
		КонецЕсли;
	Иначе 
		СтруктураИнициализации.ПользовательПодключения		= Организация.ПользовательПодключения;
		СтруктураИнициализации.ПарольПодключения			= Организация.ПарольПодключения;
		СтруктураИнициализации.РежимовПротоколаДляОбменаRS  = ?(ЗначениеЗаполнено(Организация.РежимовПротоколаДляОбменаRS), Организация.РежимовПротоколаДляОбменаRS, Перечисления.РС_ВидыРежимовПротокола.http);
	КонецЕсли;
	Возврат СтруктураИнициализации;
	
КонецФункции

