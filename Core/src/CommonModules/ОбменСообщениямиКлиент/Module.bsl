#Область СлужебныйПрограммныйИнтерфейс

// Выполняет отправку и получение сообщений системы.
// 
Процедура ОтправитьИПолучитьСообщения() Экспорт
	
	Состояние(НСтр("ka='მიმდინარეობს შეტყობინებების გაგზავნა და მიღება.';ru='Выполняется отправка и получение сообщений.';en='You are sending and receiving messages.'"),,
			НСтр("ka='გთხოვთ, მოიცადეთ...';ru='Пожалуйста, подождите...';en='Please wait...'"), БиблиотекаКартинок.Информация32);
	
	Отказ = Ложь;
	
	ОбменСообщениямиВызовСервера.ОтправитьИПолучитьСообщения(Отказ);
	
	Если Отказ Тогда
		
		Состояние(НСтр("ka='შეტყობინებების გაგზავნა-მიღებისას შეცდომები წარმოიშვა!';ru='Возникли ошибки при отправке и получении сообщений!';en='An error occurred while sending and receiving messages!'"),,
				НСтр("ka='შეცდომების დიაგნოსტიკისთვის გამოიყენეთ რეგისტრაციის ჟურნალი.';ru='Используйте журнал регистрации для диагностики ошибок.';en='Use the log for error diagnostics.'"), БиблиотекаКартинок.Ошибка32);
		
	Иначе
		
		Состояние(НСтр("ka='შეტყობინებების გაგზავნა და მიღება წარმატებით დასრულდა.';ru='Отправка и получение сообщений успешно завершены.';en='Sending and receiving messages is successfully completed.'"),,, БиблиотекаКартинок.Информация32);
		
	КонецЕсли;
	
	Оповестить(ИмяСобытияВыполненаОтправкаИПолучениеСообщений());
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

