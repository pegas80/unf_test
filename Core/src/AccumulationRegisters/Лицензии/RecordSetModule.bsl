#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	
	Если Не ДополнительныеСвойства.Свойство("ДляПроведения")
		Или Не ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	// Установка исключительной блокировки текущего набора записей регистратора.
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.Лицензии.НаборЗаписей");
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировки.УстановитьЗначение("Регистратор", Отбор.Регистратор.Значение);
	Блокировка.Заблокировать();
	
	Если НЕ СтруктураВременныеТаблицы.Свойство("ДвиженияЛизензииИзменение")
		ИЛИ	СтруктураВременныеТаблицы.Свойство("ДвиженияЛизензииИзменение")
	   И НЕ СтруктураВременныеТаблицы.ДвиженияЛизензииИзменение Тогда
		
		// Если временная таблица "ДвиженияРасчетыСПокупателямиИзменение" не существует или не содержит записей
		// об изменении набора, значит набор записывается первый раз или для набора был выполнен контроль остатков.
		// Текущее состояние набора помещается во временную таблицу "ДвиженияРасчетыСПокупателямиПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно текущего.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Лицензии.НомерСтроки КАК НомерСтроки,
		|	Лицензии.Организация КАК Организация,
		|	Лицензии.Номенклатура КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА Лицензии.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА Лицензии.Себестоимость
		|		ИНАЧЕ -Лицензии.Себестоимость
		|	КОНЕЦ КАК СуммаПередЗаписью
		|ПОМЕСТИТЬ ДвиженияЛизензииПередЗаписью
		|ИЗ
		|	РегистрНакопления.Лицензии КАК Лицензии
		|ГДЕ
		|	Лицензии.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	Иначе
		
		// Если временная таблица "ДвиженияРасчетыСПокупателямиИзменение" существует и содержит записи
		// об изменении набора, значит набор записывается не первый раз и для набора не был выполнен контроль остатков.
		// Текущее состояние набора и текущее состояние изменений помещаются во временную таблцу "ДвиженияРасчетыСПокупателямиПередЗаписью",
		// чтобы при записи получить изменение нового набора относительно первоначального.
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ДвиженияЛизензииИзменение.НомерСтроки КАК НомерСтроки,
		|	ДвиженияЛизензииИзменение.Организация КАК Организация,
		|	ДвиженияЛизензииИзменение.Номенклатура КАК Номенклатура,
		|	ДвиженияЛизензииИзменение.СуммаПередЗаписью КАК СуммаПередЗаписью
		|ПОМЕСТИТЬ ДвиженияЛизензииИзменениеПередЗаписью
		|ИЗ
		|	ДвиженияЛизензииИзменение КАК ДвиженияЛизензииИзменение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Лицензии.НомерСтроки,
		|	Лицензии.Организация,
		|	Лицензии.Номенклатура,
		|	ВЫБОР
		|		КОГДА Лицензии.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|			ТОГДА Лицензии.Себестоимость
		|		ИНАЧЕ -Лицензии.Себестоимость
		|	КОНЕЦ
		|ИЗ
		|	РегистрНакопления.Лицензии КАК Лицензии
		|ГДЕ
		|	Лицензии.Регистратор = &Регистратор
		|	И &Замещение");
		
		Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
		Запрос.УстановитьПараметр("Замещение", Замещение);
				
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
	КонецЕсли;
	
	// Временная таблица "ДвиженияРасчетыСПокупателямиИзменение" уничтожается
	// Удаляется информация о ее существовании.
	
	Если СтруктураВременныеТаблицы.Свойство("ДвиженияЛизензииИзменение") Тогда
		
		Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияЛизензииИзменение");
		Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		СтруктураВременныеТаблицы.Удалить("ДвиженияЛизензииИзменение");
	
	КонецЕсли;
	
	// Хозяйственная операция
	ХозяйственныеОперацииСервер.ЗаполнитьХозяйственнуюОперациюВНабореЗаписей(ЭтотОбъект);
	// Конец Хозяйственная операция
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	//Если ДополнительныеСвойства.Свойство("КонтрагентыСИзмененнымиВзаиморасчетами") Тогда
	//	РегистрыСведений.ОстаткиВзаиморасчетов.ОбновитьОстаткиВзаиморасчетов(ДополнительныеСвойства.КонтрагентыСИзмененнымиВзаиморасчетами);
	//КонецЕсли;
	
	Если Не ДополнительныеСвойства.Свойство("ДляПроведения")
		Или Не ДополнительныеСвойства.ДляПроведения.Свойство("СтруктураВременныеТаблицы") Тогда
		
		Возврат;
	КонецЕсли;
	
	СтруктураВременныеТаблицы = ДополнительныеСвойства.ДляПроведения.СтруктураВременныеТаблицы;
	
	// Рассчитывается изменение нового набора относительно текущего с учетом накопленных изменений
	// и помещается во временную таблицу "ДвиженияРасчетыСПокупателямиИзменение".
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	МИНИМУМ(ДвиженияЛизензииИзменение.НомерСтроки) КАК НомерСтроки,
	|	ДвиженияЛизензииИзменение.Организация КАК Организация,
	|	СУММА(ДвиженияЛизензииИзменение.СуммаПередЗаписью) КАК СуммаПередЗаписью,
	|	СУММА(ДвиженияЛизензииИзменение.СуммаИзменение) КАК СуммаИзменение,
	|	СУММА(ДвиженияЛизензииИзменение.СуммаПриЗаписи) КАК СуммаПриЗаписи,
	|	ДвиженияЛизензииИзменение.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ДвиженияЛизензииИзменение
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДвиженияЛизензииПередЗаписью.НомерСтроки КАК НомерСтроки,
	|		ДвиженияЛизензииПередЗаписью.Организация КАК Организация,
	|		ДвиженияЛизензииПередЗаписью.Номенклатура КАК Номенклатура,
	|		ДвиженияЛизензииПередЗаписью.СуммаПередЗаписью КАК СуммаПередЗаписью,
	|		ДвиженияЛизензииПередЗаписью.СуммаПередЗаписью КАК СуммаИзменение,
	|		0 КАК СуммаПриЗаписи
	|	ИЗ
	|		ДвиженияЛизензииПередЗаписью КАК ДвиженияЛизензииПередЗаписью
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		Лицензии.НомерСтроки,
	|		Лицензии.Организация,
	|		Лицензии.Номенклатура,
	|		0,
	|		ВЫБОР
	|			КОГДА Лицензии.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА -Лицензии.Себестоимость
	|			ИНАЧЕ Лицензии.Себестоимость
	|		КОНЕЦ,
	|		Лицензии.Себестоимость
	|	ИЗ
	|		РегистрНакопления.Лицензии КАК Лицензии
	|	ГДЕ
	|		Лицензии.Регистратор = &Регистратор) КАК ДвиженияЛизензииИзменение
	|
	|СГРУППИРОВАТЬ ПО
	|	ДвиженияЛизензииИзменение.Организация,
	|	ДвиженияЛизензииИзменение.Номенклатура
	|
	|ИМЕЮЩИЕ
	|	СУММА(ДвиженияЛизензииИзменение.СуммаИзменение) <> 0
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Организация");
	
	Запрос.УстановитьПараметр("Регистратор", Отбор.Регистратор.Значение);
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаИзРезультатаЗапроса = РезультатЗапроса.Выбрать();
	ВыборкаИзРезультатаЗапроса.Следующий();
	
	// Новые изменения были помещены во временную таблицу "ДвиженияРасчетыСПокупателямиИзменение".
	// Добавляется информация о ее существовании и наличии в ней записей об изменении.
	СтруктураВременныеТаблицы.Вставить("ДвиженияЛизензииИзменение", ВыборкаИзРезультатаЗапроса.Количество > 0);
	
	// Временная таблица "ДвиженияРасчетыСПокупателямиПередЗаписью" уничтожается
	Запрос = Новый Запрос("УНИЧТОЖИТЬ ДвиженияЛизензииПередЗаписью");
	Запрос.МенеджерВременныхТаблиц = СтруктураВременныеТаблицы.МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли