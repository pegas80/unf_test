		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Сумма_Реализация</dataPath>
			<field>Сумма_Реализация</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма (реализация)</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>თანხა (შემოსული)</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДатаДокумента</dataPath>
			<field>ДатаДокумента</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Дата документа</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:periodNumber>12</dcscom:periodNumber>
				<dcscom:periodType>Main</dcscom:periodType>
			</role>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЗаказыПокупателейОбороты.ЗаказПокупателя,
	СУММА(ЗаказПокупателяЗапасы.Сумма) КАК Сумма
ПОМЕСТИТЬ СуммыЗаказов
ИЗ
	РегистрНакопления.ЗаказыПокупателей.Обороты({(&amp;НачалоПериода)}, {(&amp;КонецПериода)}, Авто, ) КАК ЗаказыПокупателейОбороты
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
		ПО ЗаказыПокупателейОбороты.ЗаказПокупателя = ЗаказПокупателяЗапасы.Ссылка

СГРУППИРОВАТЬ ПО
	ЗаказыПокупателейОбороты.ЗаказПокупателя
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВЫБОР
		КОГДА ЗаказыПокупателейОстаткиИОбороты.Регистратор = НЕОПРЕДЕЛЕНО
			ТОГДА NULL
		ИНАЧЕ ЗаказыПокупателейОстаткиИОбороты.Регистратор
	КОНЕЦ КАК Регистратор,
	ЗаказыПокупателейОстаткиИОбороты.ПериодСекунда,
	ЗаказыПокупателейОстаткиИОбороты.ПериодМинута,
	ЗаказыПокупателейОстаткиИОбороты.ПериодЧас,
	ЗаказыПокупателейОстаткиИОбороты.ПериодДень,
	ЗаказыПокупателейОстаткиИОбороты.ПериодНеделя,
	ЗаказыПокупателейОстаткиИОбороты.ПериодДекада,
	ЗаказыПокупателейОстаткиИОбороты.ПериодМесяц,
	ЗаказыПокупателейОстаткиИОбороты.ПериодКвартал,
	ЗаказыПокупателейОстаткиИОбороты.ПериодПолугодие,
	ЗаказыПокупателейОстаткиИОбороты.ПериодГод,
	ЗаказыПокупателейОстаткиИОбороты.Организация,
	ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя,
	ЗаказыПокупателейОстаткиИОбороты.Номенклатура КАК Номенклатура,
	ЗаказыПокупателейОстаткиИОбороты.Характеристика,
	ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя.СостояниеЗаказа КАК СостояниеЗаказа,
	ЗаказыПокупателейОстаткиИОбороты.ЗаказПокупателя.Договор КАК Договор,
	0 КАК Количество_Реализация,
	0 КАК Сумма_Реализация,
	NULL КАК Документ
ПОМЕСТИТЬ Заказы
ИЗ
	РегистрНакопления.ЗаказыПокупателей.ОстаткиИОбороты(
			{(&amp;НачалоПериода)},
			{(&amp;КонецПериода)},
			Авто,
			Движения,
			ЗаказПокупателя В
				(ВЫБРАТЬ
					СуммыЗаказов.ЗаказПокупателя
				ИЗ
					СуммыЗаказов)) КАК ЗаказыПокупателейОстаткиИОбороты

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	ПродажиОбороты.Регистратор,
	ПродажиОбороты.ПериодСекунда,
	ПродажиОбороты.ПериодМинута,
	ПродажиОбороты.ПериодЧас,
	ПродажиОбороты.ПериодДень,
	ПродажиОбороты.ПериодНеделя,
	ПродажиОбороты.ПериодДекада,
	ПродажиОбороты.ПериодМесяц,
	ПродажиОбороты.ПериодКвартал,
	ПродажиОбороты.ПериодПолугодие,
	ПродажиОбороты.ПериодГод,
	ПродажиОбороты.Организация,
	ПродажиОбороты.ЗаказПокупателя,
	ПродажиОбороты.Номенклатура,
	ПродажиОбороты.Характеристика,
	NULL,
	ВЫБОР
		КОГДА ПродажиОбороты.Документ ССЫЛКА Документ.ОтчетОРозничныхПродажах
				ИЛИ ПродажиОбороты.Документ ССЫЛКА Документ.АвансовыйОтчет
				ИЛИ ПродажиОбороты.Документ ССЫЛКА Документ.ЧекККМ
			ТОГДА ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
		ИНАЧЕ ПродажиОбороты.Документ.Договор
	КОНЕЦ,
	NULL,
	ПродажиОбороты.СуммаОборот,
	ПродажиОбороты.Документ
ИЗ
	РегистрНакопления.Продажи.Обороты({(&amp;НачалоПериода)}, {(&amp;КонецПериода)}, Авто, ) КАК ПродажиОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Заказы.ПериодСекунда,
	Заказы.Организация,
	Заказы.ЗаказПокупателя,
	Заказы.Договор,
	Заказы.Документ,
	Заказы.Сумма_Реализация
ПОМЕСТИТЬ Продажи
ИЗ
	Заказы КАК Заказы
ГДЕ
	Заказы.ЗаказПокупателя &lt;&gt; ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
	И Заказы.Документ &lt;&gt; НЕОПРЕДЕЛЕНО
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Заказы.Регистратор,
	Заказы.ПериодСекунда,
	Заказы.ПериодМинута,
	Заказы.ПериодЧас,
	Заказы.ПериодДень,
	Заказы.ПериодНеделя,
	Заказы.ПериодДекада,
	Заказы.ПериодМесяц,
	Заказы.ПериодКвартал,
	Заказы.ПериодПолугодие,
	Заказы.ПериодГод,
	Заказы.ЗаказПокупателя,
	Заказы.Документ,
	Заказы.Номенклатура,
	Заказы.Характеристика,
	Заказы.СостояниеЗаказа,
	Заказы.Договор,
	Заказы.Количество_Реализация,
	Заказы.Сумма_Реализация,
	Заказы.Организация,
	ВЫБОР
		КОГДА Заказы.ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
			ТОГДА Заказы.Документ.Дата
		ИНАЧЕ Заказы.ЗаказПокупателя.Дата
	КОНЕЦ КАК ДатаДокумента,
	ЕСТЬNULL(СуммыЗаказов.Сумма, 0) КАК Сумма
ИЗ
	Заказы КАК Заказы
		ЛЕВОЕ СОЕДИНЕНИЕ Продажи КАК Продажи
		ПО Заказы.ЗаказПокупателя = Продажи.ЗаказПокупателя
		ЛЕВОЕ СОЕДИНЕНИЕ СуммыЗаказов КАК СуммыЗаказов
		ПО Заказы.ЗаказПокупателя = СуммыЗаказов.ЗаказПокупателя
ГДЕ
	ВЫБОР
			КОГДА Продажи.ЗаказПокупателя ЕСТЬ NULL
					ИЛИ Заказы.Документ = НЕОПРЕДЕЛЕНО
				ТОГДА ИСТИНА
			КОГДА НЕ Продажи.ЗаказПокупателя ЕСТЬ NULL
					И Заказы.Документ &lt;&gt; НЕОПРЕДЕЛЕНО
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ</query>
	</dataSet>
	<totalField>
		<dataPath>Сумма</dataPath>
		<expression>Сумма(Сумма)</expression>
	</totalField>
	<totalField>
		<dataPath>Сумма_Реализация</dataPath>
		<expression>Сумма(Сумма_Реализация)</expression>
	</totalField>
	<parameter>
		<name>НачалоПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Начало периода</v8:content>
			</v8:item>
			<v8:item>
				<v8:lang>ka</v8:lang>
				<v8:content>პერიოდის დასაწყისი</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>&amp;СтПериод.ДатаНачала</expression>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>КонецПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Конец периода</v8:content>
			</v8:item>
			<v8:item>
