	КонецЦикла; 
	
	
	// Выведем данные
	ОбластьСтрокаТаблицыКод = Макет.ПолучитьОбласть("Строка|Код"); 
	ОбластьСтрокаТаблицыСтатья = Макет.ПолучитьОбласть("Строка|Статья"); 
	ОбластьСтрокаТаблицыПериод = Макет.ПолучитьОбласть("Строка|Период"); 
	Для каждого СтрокаДанных Из ТаблицаДанных Цикл
		
		Если СтрокаДанных.Статья.Скрыть Тогда
			
			Продолжить;
			
		КонецЕсли; 
		
		ЦветТекстаСтатьи = СтрокаДанных.Статья.ЦветТекстаСтатьи.Получить();
		ЦветФонаСтатьи = СтрокаДанных.Статья.ЦветФонаСтатьи.Получить();
