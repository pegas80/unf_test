#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если НЕ ЗначениеЗаполнено(Отчет.Период) Тогда
		
		Отчет.Период = Новый СтандартныйПериод;
		Отчет.Период.Вариант = ВариантСтандартногоПериода.ЭтотГод;
		
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(Отчет.ВидУниверсальногоОтчета) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДЛ_ВидыУниверсальныхОтчетов.Ссылка
		|ИЗ
		|	Справочник.ДЛ_ВидыУниверсальныхОтчетов КАК ДЛ_ВидыУниверсальныхОтчетов";
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			
			Отчет.ВидУниверсальногоОтчета = Выборка.Ссылка;
			
		КонецЕсли; 
		
	КонецЕсли; 
	
	Если НЕ ЗначениеЗаполнено(РазделительДробнойЧасти) Тогда 
		РазделительДробнойЧасти = ",";
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(РазделительГрупп) Тогда 
		РазделительГрупп = Символы.НПП;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	
	Если Не ЗначениеЗаполнено(Отчет.ВидУниверсальногоОтчета) Тогда
		Сообщить(НСтр("ka='მიუთითეთ ფინანსური ანგარიშგების ტიპი!';ru='Укажите вид универсального отчета!'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Отчет.Период) Тогда
		Сообщить(НСтр("ka='მიუთითეთ პერიოდი ანგარიშგების ფორმირებისთვის!';ru='Укажите период формирования отчета!'"));
		Возврат;
	КонецЕсли; 
	
	
	СформироватьОтчет();
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПериодВЗависимостиОтВывода()
	
	ДатаНач = Отчет.Период.ДатаНачала;
	ДатаКон = Отчет.Период.ДатаОкончания;
	
	Если Вывод = 0 Тогда
		Отчет.Период.ДатаНачала = НачалоМесяца(ДатаНач);
		Отчет.Период.ДатаОкончания = КонецМесяца(ДатаКон);
	ИначеЕсли Вывод = 1 Тогда
		Отчет.Период.ДатаНачала = НачалоКвартала(ДатаНач);
		Отчет.Период.ДатаОкончания = КонецКвартала(ДатаКон);
	Иначе
		Отчет.Период.ДатаНачала = НачалоГода(ДатаНач);
		Отчет.Период.ДатаОкончания = КонецГода(ДатаКон);
	КонецЕсли;	
	
КонецПроцедуры // ИзменитьПериодВЗависимостиОтВывода()

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	
	ИзменитьПериодВЗависимостиОтВывода();	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыводПриИзменении(Элемент)
	
	ИзменитьПериодВЗависимостиОтВывода();	
	
КонецПроцедуры

#КонецОбласти 

#Область ФормированиеОтчета

Процедура УстановитьОформлениеОбласти(Область, ЦветФона, ЦветТекста, Шрифт)
	
	Если Область = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли; 
	
	Если ЦветФона <> Неопределено Тогда
		Область.ТекущаяОбласть.ЦветФона = ЦветФона;
	КонецЕсли; 
	
	Если ЦветТекста <> Неопределено Тогда
		Область.ТекущаяОбласть.ЦветТекста = ЦветТекста;
	КонецЕсли; 
	
	Если Шрифт <> Неопределено Тогда
		Область.ТекущаяОбласть.Шрифт = Шрифт;
	КонецЕсли; 
	
КонецПроцедуры

Процедура ВывестиПустуюСтроку(Макет, МассивПериодов, ЦветФона, ЦветТекста, Шрифт)
	
	ОбластьПустаяСтрокаКод = Макет.ПолучитьОбласть("ПустаяСтрока|Код");
	УстановитьОформлениеОбласти(ОбластьПустаяСтрокаКод, ЦветФона, ЦветТекста, Шрифт);
	ТабличныйДокумент.Вывести(ОбластьПустаяСтрокаКод);
	
	ОбластьПустаяСтрокаСтатья = Макет.ПолучитьОбласть("ПустаяСтрока|Статья");
	УстановитьОформлениеОбласти(ОбластьПустаяСтрокаСтатья, ЦветФона, ЦветТекста, Шрифт);
	ТабличныйДокумент.Присоединить(ОбластьПустаяСтрокаСтатья);
	
	ОбластьПустаяСтрокаПериод = Макет.ПолучитьОбласть("ПустаяСтрока|Период");
	Для Каждого Период Из МассивПериодов Цикл
		
		УстановитьОформлениеОбласти(ОбластьПустаяСтрокаПериод, ЦветФона, ЦветТекста, Шрифт);
		ТабличныйДокумент.Присоединить(ОбластьПустаяСтрокаПериод);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СформироватьОтчет() Экспорт 
	
	_Отчет = РеквизитФормыВЗначение("Отчет");
	Макет = _Отчет.ПолучитьМакет("Макет");
	
	ТабличныйДокумент.Очистить();
	
	Если Вывод = 1 Тогда
		ВидПериода = "Квартал";
		Интервал = 3;
	ИначеЕсли Вывод = 2 Тогда
		ВидПериода = "Год";
		Интервал = 12;
	Иначе
		ВидПериода = "Месяц";
		Интервал = 1;
	КонецЕсли;
	
	НачалоПериода = НачалоМесяца(Отчет.Период.ДатаНачала);
	КонецПериода = НачалоМесяца(Отчет.Период.ДатаОкончания);
	
	ТаблицаДанных = Новый ТаблицаЗначений;
	ТаблицаДанных.Колонки.Добавить("КодСтатьи");
	ТаблицаДанных.Колонки.Добавить("Статья");
	ТаблицаДанных.Колонки.Добавить("ИдентификаторФормулы");
	
	МассивПериодов = Новый Массив;
	
	ТекущийМесяц = НачалоПериода;
	Пока ТекущийМесяц <= КонецПериода Цикл
		
		ТаблицаДанных.Колонки.Добавить("Период" + Формат(ТекущийМесяц, "ДФ=MMyyyy"), Новый ОписаниеТипов("Число"));
		МассивПериодов.Добавить(ТекущийМесяц);
		ТекущийМесяц = ДобавитьМесяц(ТекущийМесяц, Интервал);
		
	КонецЦикла;   
	
	Язык = ПользователиИнформационнойБазы.ТекущийПользователь().Язык;
	
	ТаблицаМесяцы = ПолучитьТаблицуМесяцовПериода(НачалоПериода, КонецПериода, ВидПериода); 
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидУниверсальногоОтчета"	, Отчет.ВидУниверсальногоОтчета);
	Запрос.УстановитьПараметр("КонецПериода"			, КонецПериода);
	Запрос.УстановитьПараметр("НачалоПериода"			, НачалоПериода);
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ДЛ_СтатьиУниверсальногоОтчета.Ссылка КАК СтатьяУниверсальногоОтчета,
	|	ДЛ_СтатьиУниверсальногоОтчета.Код КАК КодСтатьи,
	|	ДЛ_СтатьиУниверсальногоОтчета.Наименование,
	|	ДЛ_СтатьиУниверсальногоОтчета.Порядок КАК Порядок,
	|	ДЛ_СтатьиУниверсальногоОтчета.ИдентификаторФормулы
	|ИЗ
	|	Справочник.ДЛ_СтатьиУниверсальногоОтчета КАК ДЛ_СтатьиУниверсальногоОтчета
	|ГДЕ
	|	ДЛ_СтатьиУниверсальногоОтчета.Владелец = &ВидУниверсальногоОтчета
	|	И НЕ ДЛ_СтатьиУниверсальногоОтчета.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	Порядок";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ЦветФонаШапки = Отчет.ВидУниверсальногоОтчета.ЦветФонаШапки.Получить();
	ЦветТекстаШапки = Отчет.ВидУниверсальногоОтчета.ЦветТекстаШапки.Получить();
	ШрифтШапки = Отчет.ВидУниверсальногоОтчета.ШрифтШапки.Получить();
	
	//ПодольскийАИ #УчетПоПроектам 09.11.2020 {
	//Добавление фильтра по проектам. Если указано несколько проектов, тогда для каждого проекта ормируем отдельную таблицу
	//Формирование таблицы вынесено в процедуру
	ПараметрыВывода = Новый Структура;
	ПараметрыВывода.Вставить("Макет", Макет);
	ПараметрыВывода.Вставить("РезультатЗапроса", РезультатЗапроса);
	ПараметрыВывода.Вставить("ТаблицаДанных", ТаблицаДанных);
	ПараметрыВывода.Вставить("ТаблицаМесяцы", ТаблицаМесяцы);
	ПараметрыВывода.Вставить("МассивПериодов", МассивПериодов);
	ПараметрыВывода.Вставить("Язык", Язык);
	ПараметрыВывода.Вставить("ЦветФонаШапки", ЦветФонаШапки);
	ПараметрыВывода.Вставить("ЦветТекстаШапки", ЦветТекстаШапки);
	ПараметрыВывода.Вставить("ШрифтШапки", ШрифтШапки);
	ПараметрыВывода.Вставить("Интервал", Интервал);
	ПараметрыВывода.Вставить("ВидПериода", ВидПериода);
	
	Если Проекты.Количество() > 1 Тогда
		Для Каждого ТекПроект Из Проекты Цикл
			
			ВывестиОбластьПроект(Макет, МассивПериодов, ТекПроект.Значение);
			ЗаполнитьИВывестиРезультатВТабличныйДокумент(ПараметрыВывода, ТекПроект.Значение);
			ВывестиПустуюСтрокуБезОформления(Макет, МассивПериодов);
			
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ПараметрыВывода.ТаблицаДанных.Очистить();
		КонецЦикла;
	ИначеЕсли Проекты.Количество() = 1 Тогда
		ЗаполнитьИВывестиРезультатВТабличныйДокумент(ПараметрыВывода, Проекты[0].Значение);
	Иначе
		ЗаполнитьИВывестиРезультатВТабличныйДокумент(ПараметрыВывода);
	КонецЕсли;
	//ПодольскийАИ #УчетПоПроектам 09.11.2020 }
	
КонецПроцедуры // СформироватьОтчет()

//ПодольскийАИ #УчетПроектов 09.11.2020 {
Процедура ЗаполнитьИВывестиРезультатВТабличныйДокумент(ПараметрыВывода, Проект = Неопределено)

	ЦветФонаШапки = ПараметрыВывода.ЦветФонаШапки;
	ЦветТекстаШапки = ПараметрыВывода.ЦветТекстаШапки;
	ШрифтШапки = ПараметрыВывода.ШрифтШапки;
	МассивПериодов = ПараметрыВывода.МассивПериодов;
	РезультатЗапроса = ПараметрыВывода.РезультатЗапроса;
	ТаблицаДанных = ПараметрыВывода.ТаблицаДанных;
	Макет = ПараметрыВывода.Макет;
	Интервал = ПараметрыВывода.Интервал;
	ВидПериода = ПараметрыВывода.ВидПериода;
	
	НачалоПериода = НачалоМесяца(Отчет.Период.ДатаНачала);
	КонецПериода = НачалоМесяца(Отчет.Период.ДатаОкончания);
	
//ПодольскийАИ #УчетПроектов 09.11.2020 }

	ОбластьШапкаКод = Макет.ПолучитьОбласть("Шапка|Код");
	УстановитьОформлениеОбласти(ОбластьШапкаКод, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
	ОбластьШапкаКод.Параметры.ВидУниверсальногоОтчета = Отчет.ВидУниверсальногоОтчета;
	ТабличныйДокумент.Вывести(ОбластьШапкаКод);
	
	ОбластьШапкаСтатья = Макет.ПолучитьОбласть("Шапка|Статья");
	УстановитьОформлениеОбласти(ОбластьШапкаСтатья, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
	ТабличныйДокумент.Присоединить(ОбластьШапкаСтатья);
	
	ОбластьШапкаПериод = Макет.ПолучитьОбласть("Шапка|Период");
	Для Каждого Период Из МассивПериодов Цикл
		
		УстановитьОформлениеОбласти(ОбластьШапкаПериод, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
		ТабличныйДокумент.Присоединить(ОбластьШапкаПериод);
		
	КонецЦикла;
	
	ВывестиПустуюСтроку(Макет, МассивПериодов, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
	
	// Выводим шапку
	
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы|Код");
	УстановитьОформлениеОбласти(ОбластьШапкаТаблицы, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
	ТабличныйДокумент.Вывести(ОбластьШапкаТаблицы);
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы|Статья");
	УстановитьОформлениеОбласти(ОбластьШапкаТаблицы, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
	ТабличныйДокумент.Присоединить(ОбластьШапкаТаблицы);
	
	ОбластьШапкаТаблицыПериод = Макет.ПолучитьОбласть("ШапкаТаблицы|Период");
	Для Каждого Период Из МассивПериодов Цикл
		
		Если Интервал = 12 Тогда
			ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "ДФ='yyyy'");
		ИначеЕсли Интервал = 3 Тогда	
			ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "ДФ='к ''кв'' yyyy'");
		Иначе	
			//ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "ДФ='MMMM yyyy'");
			Если ЯзыкВыводаМесяцев = "ka" Тогда 
				ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "Л=ka_GE; ДФ='MMMM yyyy'");
			ИначеЕсли ЯзыкВыводаМесяцев = "ru" Тогда
				ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "Л=ru_RU; ДФ='MMMM yyyy'");
			ИначеЕсли ЯзыкВыводаМесяцев = "en" Тогда
				ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "Л=en_US; ДФ='MMMM yyyy'");
			Иначе
				ОбластьШапкаТаблицыПериод.Параметры.Период = Формат(Период, "ДФ='MMMM yyyy'");
			КонецЕсли;
		КонецЕсли; 
		
		УстановитьОформлениеОбласти(ОбластьШапкаТаблицыПериод, ЦветФонаШапки, ЦветТекстаШапки, ШрифтШапки);
		ТабличныйДокумент.Присоединить(ОбластьШапкаТаблицыПериод);
		
	КонецЦикла; 
	
	// Заполнить таблицу данных
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НоваяСтрока = ТаблицаДанных.Добавить();
		НоваяСтрока.КодСтатьи = Выборка.КодСтатьи;
		НоваяСтрока.Статья = Выборка.СтатьяУниверсальногоОтчета;
		НоваяСтрока.ИдентификаторФормулы = Выборка.ИдентификаторФормулы;
		
		//ПодольскийАИ #УчетПроектов 09.11.2020 {
		//Добавлен параметр Проект
		ТаблицаСуммПоПериодам = ПолучитьСуммуПоИсточнику(Выборка.СтатьяУниверсальногоОтчета, МассивПериодов, НачалоПериода, КонецПериода, ВидПериода, Проект);
		//ПодольскийАИ #УчетПроектов 09.11.2020 }
		Для Каждого Период из МассивПериодов Цикл
			
			СтрокаСуммаПоПериоду = ТаблицаСуммПоПериодам.Найти(Период, "Период");
			Если СтрокаСуммаПоПериоду <> Неопределено Тогда
				
				НоваяСтрока["Период" + Формат(Период, "ДФ=MMyyyy")] = СтрокаСуммаПоПериоду.Сумма;
				
			КонецЕсли; 
			
		КонецЦикла;               
		
	КонецЦикла;
	
	// Рассчитаем формулы
	Для каждого СтрокаДанных Из ТаблицаДанных Цикл
		
		Для каждого СтрокаФормула Из СтрокаДанных.Статья.Формулы Цикл
			
			
			Для каждого Период Из МассивПериодов Цикл
				
				РезультатФормулы = 0;
				
				Формула = СтрокаФормула.Формула;
				Результат = 0;
				
				Для каждого СтрокаИдентификатор Из ТаблицаДанных Цикл
					
					Формула = СтрЗаменить(Формула, "[" + СтрокаИдентификатор.ИдентификаторФормулы + "]", Формат(СтрокаИдентификатор["Период" + Формат(Период, "ДФ=MMyyyy")], "ЧРД=.; ЧН=0; ЧГ=0"));
					
				КонецЦикла; 
				
				Формула = "РезультатФормулы = " + Формула;
				
				Попытка
				
					Выполнить(Формула);
				
				Исключение
					
					Сообщить(ОписаниеОшибки());
					РезультатФормулы = 0;
				
				КонецПопытки; 
				
				
				СтрокаДанных["Период" + Формат(Период, "ДФ=MMyyyy")] = СтрокаДанных["Период" + Формат(Период, "ДФ=MMyyyy")] + РезультатФормулы;
				
