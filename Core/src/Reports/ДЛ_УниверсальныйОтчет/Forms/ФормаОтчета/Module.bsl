			УстановитьОформлениеОбласти(ОбластьСтрокаТаблицыПериод, ЦветФонаСтатьи, ЦветТекстаСтатьи, ШрифтСтатьи);
			//+++ Дмгг
			Сумма = СтрокаДанных["Период" + Формат(Период, "ДФ=MMyyyy")];
			ЦелаяЧастьЧисла = Цел(Сумма);
			ДробнаяЧастьЧисла = Сумма - Цел(Сумма);
			
			СуммаСтройкой = Формат(Сумма,"ЧДЦ="+Точность+"");
			
			ЦелаяЧастьСтрокий = Формат(ЦелаяЧастьЧисла,"");
			ДробнаяЧастьСтрокой = "";
			Если Точность <> 0 Тогда 
				ДробнаяЧастьСтрокой = Сред(Формат(ДробнаяЧастьЧисла,""), ?(ДробнаяЧастьЧисла<0, 4, 3), Точность);
			КонецЕсли;
			
			ЦелаяЧастьСтрокий = СтрЗаменить(СтрЗаменить(СтрЗаменить(СтрЗаменить(ЦелаяЧастьСтрокий,".",РазделительГрупп),",",РазделительГрупп)," ",РазделительГрупп),Символы.НПП,РазделительГрупп);
			СтрокаСуммыВывода = ЦелаяЧастьСтрокий + ?(ЗначениеЗаполнено(ДробнаяЧастьСтрокой), РазделительДробнойЧасти + ДробнаяЧастьСтрокой, "");
			//ОбластьСтрокаТаблицыПериод.Параметры.Сумма = СтрокаДанных["Период" + Формат(Период, "ДФ=MMyyyy")]; //+++ Дмгг
			ОбластьСтрокаТаблицыПериод.Параметры.Сумма = ?(Сумма=0, "", СтрокаСуммыВывода); 
			//--- Дмгг
			ТабличныйДокумент.Присоединить(ОбластьСтрокаТаблицыПериод);
			
		КонецЦикла; 
		
	КонецЦикла; 
	
