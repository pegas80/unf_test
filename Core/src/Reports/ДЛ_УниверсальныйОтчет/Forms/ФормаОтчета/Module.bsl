Функция ПолучитьТаблицуМесяцовПериода(НачалоПериода, КонецПериода, ВидПериода)
	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Месяц", Новый ОписаниеТипов("Дата"));
	
	Если ВидПериода = 1 Тогда
		РасМесяц = НачалоКвартала(НачалоПериода);
		ПериодДо = НачалоКвартала(КонецПериода);
		П = 3;
	ИначеЕсли ВидПериода = 2 Тогда
		РасМесяц = НачалоГода(НачалоПериода);
		ПериодДо = НачалоГода(КонецПериода);
		П = 12;
	Иначе 
		РасМесяц = НачалоМесяца(НачалоПериода);
		ПериодДо = НачалоМесяца(КонецПериода);
		П = 1;
	КонецЕсли;
	
	Пока РасМесяц <= ПериодДо Цикл
		НоваяСтрока = ТЗ.Добавить();
		НоваяСтрока.Месяц = РасМесяц;
		РасМесяц = ДобавитьМесяц(РасМесяц, П);
	КонецЦикла;
	
	Возврат ТЗ;
	
КонецФункции // ПолучитьТаблицуМесяцовПериода()

Функция РасчичатьГруппировкуПоФормуле(Таблица, Выборка)
	
	СтруктураПараметров = Новый Структура;	
	СтруктураПараметров.Вставить("Группировка"		, Выборка.СтатьяУниверсальногоОтчета);
	СтруктураПараметров.Вставить("СуммаГруппировки"	, 0);
	СуммаГруппировки = 0;
	
	Формула = Выборка.Формула;
	
	Если Не ЗначениеЗаполнено(Выборка.Формула) Или Таблица.Количество() = 0 Тогда
		Возврат СтруктураПараметров;
	КонецЕсли;
	
	МассивСтрокТаблицыПоМесяцу = Таблица.НайтиСтроки(Новый Структура("Месяц", Выборка.Месяц));
	
	Для Каждого СтрМас Из МассивСтрокТаблицыПоМесяцу Цикл
		Если Найти(Формула, СокрЛП(СтрМас.ИдентификаторФормулы)) <> 0 Тогда
			Формула = СтрЗаменить(Формула, "[" + СокрЛП(СтрМас.ИдентификаторФормулы) + "]", Строка(СтрМас.СуммаОборот)); 	
		КонецЕсли;
	КонецЦикла;
	
	Формула = СтрЗаменить(Формула, ",", ".");
	Формула = СтрЗаменить(Формула, " ", "");
	
	Попытка
		СтруктураПараметров.СуммаГруппировки = Вычислить(Формула); 
	Исключение
		Сообщить(НСтр("ka='არასწორად არის მითითებული ფორმულა დაჯგუფებაში: ""';ru='Не корректно указана формула в группировке: ""'") + Выборка.СтатьяУниверсальногоОтчета + """.");
		Возврат СтруктураПараметров;
	КонецПопытки;
	
	Возврат СтруктураПараметров;
	
КонецФункции // РасчичатьГруппировкуПоФормуле()

Функция ОпределитьФорматДаты(Период, ВидПериода, Язык)
	
	КодЯзыка = Язык.КодЯзыка;
	
	Если ВидПериода = 1 Тогда
		ПериодСФорматом = ОпределитьКвартал(Период, КодЯзыка);
	ИначеЕсли ВидПериода = 2 Тогда
		ПериодСФорматом = Строка(Год(Период));
	Иначе	
		ПериодСФорматом = формат(Период,"Л=" + КодЯзыка + "; ДФ=ММММ");
	КонецЕсли;
	
	ПериодСФорматом	= СтрЗаменить(ПериодСФорматом, " ", "");
	
	Возврат ПериодСФорматом;
	
КонецФункции // ОпределитьФорматДаты()

Функция ОпределитьКвартал(Дата, КодЯзыка)
	
	Если КодЯзыка = "ka" Тогда
		ПредставлениеКвартала = "კვარტალი";
	Иначе
		ПредставлениеКвартала = "Квартал";
	КонецЕсли;
	
	Если Месяц(Дата) = 1 Тогда
		Квартал = ПредставлениеКвартала + " I (" + Строка(Год(Дата)) + ")";
	ИначеЕсли Месяц(Дата) = 4 Тогда
		Квартал = ПредставлениеКвартала + " II (" + Строка(Год(Дата)) + ")";
	ИначеЕсли Месяц(Дата) = 7 Тогда
		Квартал = ПредставлениеКвартала + " III (" + Строка(Год(Дата)) + ")";
	ИначеЕсли Месяц(Дата) = 10 Тогда
		Квартал = ПредставлениеКвартала + " IV(" + Строка(Год(Дата)) + ")";
	КонецЕсли;
	
	Возврат Квартал;
	
КонецФункции // ОпределитьКвартал()

