<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Номенклатура</dataPath>
			<field>Номенклатура</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Номенклатура</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>ნომენკლატურა</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Характеристика</dataPath>
			<field>Характеристика</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Характеристика</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>მახასიათებელი</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЦенаЗакупкиКон</dataPath>
			<field>ЦенаЗакупкиКон</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Цена закупки</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>შესასყიდი ფასი</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ЦенаПродажиКон</dataPath>
			<field>ЦенаПродажиКон</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Цена продажи</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>გასაყიდი ფასი</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Маржа</dataPath>
			<field>Маржа</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Маржа %</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>მარჟა %</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>РазностьЦен</dataPath>
			<field>РазностьЦен</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Разность цен</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>თანხობრივი ცვლილება</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Номенклатуры.Ссылка КАК Номенклатура
ПОМЕСТИТЬ ЗапасыПред
ИЗ
	Справочник.Номенклатура КАК Номенклатуры
ГДЕ
	Номенклатуры.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	И НЕ Номенклатуры.ЭтоГруппа
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.Владелец КАК Справочник.Номенклатура) КАК Номенклатура,
	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика
ПОМЕСТИТЬ Запасы
ИЗ
	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
ГДЕ
	ХарактеристикиНоменклатуры.Владелец ССЫЛКА Справочник.Номенклатура

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗапасыПред.Номенклатура,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
ИЗ
	ЗапасыПред КАК ЗапасыПред
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	ЦеныНоменклатурыСрезПоследних.Характеристика,
	МАКСИМУМ(ЦеныНоменклатурыСрезПоследних.Цена) КАК ЦенаПродажи
ПОМЕСТИТЬ ЦеныПродажи
ИЗ
	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
			,
			Актуальность
				И ВидЦен = &amp;ВидЦенПродажи) КАК ЦеныНоменклатурыСрезПоследних

СГРУППИРОВАТЬ ПО
	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	ЦеныНоменклатурыСрезПоследних.Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныНоменклатурыКонтрагентовСрезПоследних.Номенклатура КАК Номенклатура,
	ЦеныНоменклатурыКонтрагентовСрезПоследних.Характеристика,
	ЦеныНоменклатурыКонтрагентовСрезПоследних.Период,
	ЦеныНоменклатурыКонтрагентовСрезПоследних.Цена КАК ЦенаЗакупки
ПОМЕСТИТЬ ЦеныЗакупкиПред
ИЗ
	РегистрСведений.ЦеныНоменклатурыКонтрагентов.СрезПоследних(, Актуальность) КАК ЦеныНоменклатурыКонтрагентовСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныЗакупкиПред.Номенклатура,
	ЦеныЗакупкиПред.Характеристика,
	МАКСИМУМ(ЦеныЗакупкиПред.Период) КАК Период
ПОМЕСТИТЬ МаксПериодыЗакупок
ИЗ
	ЦеныЗакупкиПред КАК ЦеныЗакупкиПред

СГРУППИРОВАТЬ ПО
	ЦеныЗакупкиПред.Номенклатура,
	ЦеныЗакупкиПред.Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныЗакупкиПред.Номенклатура КАК Номенклатура,
	ЦеныЗакупкиПред.Характеристика,
	МАКСИМУМ(ЦеныЗакупкиПред.ЦенаЗакупки) КАК ЦенаЗакупки
ПОМЕСТИТЬ ЦеныЗакупки
ИЗ
	ЦеныЗакупкиПред КАК ЦеныЗакупкиПред
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ МаксПериодыЗакупок КАК МаксПериодыЗакупок
		ПО ЦеныЗакупкиПред.Номенклатура = МаксПериодыЗакупок.Номенклатура
			И ЦеныЗакупкиПред.Характеристика = МаксПериодыЗакупок.Характеристика
			И ЦеныЗакупкиПред.Период = МаксПериодыЗакупок.Период

СГРУППИРОВАТЬ ПО
	ЦеныЗакупкиПред.Номенклатура,
	ЦеныЗакупкиПред.Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Запасы.Номенклатура,
	Запасы.Характеристика,
	ЕСТЬNULL(ЦеныЗакупки.ЦенаЗакупки, 0) КАК ЦенаЗакупкиКон,
	ЕСТЬNULL(ЦеныПродажи.ЦенаПродажи, 0) КАК ЦенаПродажиКон,
	ВЫБОР
		КОГДА ЕСТЬNULL(ЦеныЗакупки.ЦенаЗакупки, 0) = 0
				ИЛИ ЕСТЬNULL(ЦеныПродажи.ЦенаПродажи, 0) = 0
			ТОГДА 0
		ИНАЧЕ ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныПродажи.ЦенаПродажи, 0) / ЕСТЬNULL(ЦеныЗакупки.ЦенаЗакупки, 0) * 100 - 100 КАК ЧИСЛО(15, 2))
	КОНЕЦ КАК Маржа,
	ЕСТЬNULL(ЦеныПродажи.ЦенаПродажи, 0) - ЕСТЬNULL(ЦеныЗакупки.ЦенаЗакупки, 0) КАК РазностьЦен
ИЗ
	Запасы КАК Запасы
		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныПродажи КАК ЦеныПродажи
		ПО Запасы.Номенклатура = ЦеныПродажи.Номенклатура
			И Запасы.Характеристика = ЦеныПродажи.Характеристика
		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныЗакупки КАК ЦеныЗакупки
		ПО Запасы.Номенклатура = ЦеныЗакупки.Номенклатура
			И Запасы.Характеристика = ЦеныЗакупки.Характеристика</query>
	</dataSet>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ka</v8:lang>
				<v8:content>Период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>ВидЦенПродажи</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Вид цен продажи</v8:content>
			</v8:item>
			<v8:item>
				<v8:lang>ka</v8:lang>
				<v8:content>გასაყიდი ფასის ტიპი</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:CatalogRef.ВидыЦен</v8:Type>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>false</useRestriction>
		<denyIncompleteValues>true</denyIncompleteValues>
		<use>Always</use>
	</parameter>
	<settingsVariant>
		<dcsset:name>АнализЦен</dcsset:name>
		<dcsset:presentation xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>АнализЦен</v8:content>
			</v8:item>
			<v8:item>
				<v8:lang>ka</v8:lang>
				<v8:content>ფასთა ანალიზი</v8:content>
			</v8:item>
		</dcsset:presentation>
		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:selection>
