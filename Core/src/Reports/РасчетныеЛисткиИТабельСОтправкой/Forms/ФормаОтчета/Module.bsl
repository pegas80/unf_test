// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
// Процедура - обработчик события формы ПриСозданииНаСервере.
//
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПериодРегистрации 				= НачалоМесяца(ТекущаяДата());
	ОтображениеПериодаРегистрации 	= Формат(ПериодРегистрации, "ДФ='MMMM yyyy'");
	
	Если Константы.УчетПоКомпании.Получить() Тогда
		
		Организация = Константы.Компания.Получить();
		Элементы.Организация.Видимость = Ложь;
		
	Иначе
		
		Организация 				= УправлениеНебольшойФирмойСервер.ПолучитьОрганизацию(Справочники.Организации.ОсновнаяОрганизация);
		
	КонецЕсли;
	
	Валюта 							= Константы.ВалютаУчета.Получить();

	Если НЕ Константы.ФункциональнаяОпцияУчетПоНесколькимПодразделениям.Получить() Тогда
		
		Подразделение = Справочники.СтруктурныеЕдиницы.ОсновноеПодразделение;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
// Процедура - обработчик события формы ОбработкаВыбора
//
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ТипЗнч(ИсточникВыбора) = Тип("УправляемаяФорма")
		И СтрНайти(ИсточникВыбора.ИмяФормы, "ФормаКалендаря") > 0 Тогда
		
		ПериодРегистрации = КонецДня(ВыбранноеЗначение);
		УправлениеНебольшойФирмойКлиент.ПриИзмененииПериодаРегистрации(ЭтаФорма);
		
	КонецЕсли;
	
КонецПроцедуры // ОбработкаВыбора()


////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ РЕКВИЗИТОВ ФОРМЫ

&НаКлиенте
// Процедура - обработчик события Регулирования реквизита ПериодРегистрации.
//
Процедура ПериодРегистрацииРегулирование(Элемент, Направление, СтандартнаяОбработка)
	
	УправлениеНебольшойФирмойКлиент.ПриРегулированииПериодаРегистрации(ЭтаФорма, Направление);
	УправлениеНебольшойФирмойКлиент.ПриИзмененииПериодаРегистрации(ЭтаФорма);
	
КонецПроцедуры //ПериодРегистрацииРегулирование()

&НаКлиенте
// Процедура - обработчик события НачалоВыбора реквизита ПериодРегистрации.
//
Процедура ПериодРегистрацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка	 = Ложь;
	
	ДатаКалендаряПриОткрытии = ?(ЗначениеЗаполнено(ПериодРегистрации), ПериодРегистрации, УправлениеНебольшойФирмойПовтИсп.ПолучитьТекущуюДатаСеанса());
	
	ОткрытьФорму("ОбщаяФорма.ФормаКалендаря", УправлениеНебольшойФирмойКлиент.ПолучитьПараметрыОткрытияФормыКалендаря(ДатаКалендаряПриОткрытии), ЭтаФорма);
	
КонецПроцедуры //ПериодРегистрацииНачалоВыбора()

&НаСервере
Процедура ПриСохраненииПользовательскихНастроекНаСервере(Настройки)
	
	ВариантыОтчетов.ПриСохраненииПользовательскихНастроекНаСервере(ЭтотОбъект, Настройки);
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьНаСервере()
	
	Если НЕ ПроверитьНастройкиПочты() Тогда 
		ТекстСообщения = НСтр("ka='Сперва требуеться указать настройки почтового ящика!';ru='Сперва требуеться указать настройки почтового ящика!';en='Сперва требуеться указать настройки почтового ящика!'");
		ПолеСообщения = "НастройкиПочты";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(Отчет, ТекстСообщения,,,ПолеСообщения);
		Возврат;
	КонецЕсли;
	
	Если Константы.ИспользоватьНесколькоОрганизаций.Получить() И НЕ ЗначениеЗаполнено(Организация) Тогда
		ТекстСообщения = НСтр("ka='Не выбрана организация!';ru='Не выбрана организация!';en='Not selected organization!'");
		ПолеСообщения = "Организация";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(Отчет, ТекстСообщения,,,ПолеСообщения);
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(ПериодРегистрации) Тогда
		ТекстСообщения = НСтр("ka='Не выбран период регистрации!';ru='Не выбран период регистрации!';en='Not selected registration period!'");
		ПолеСообщения = "ПериодРегистрации";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(Отчет, ТекстСообщения,,,ПолеСообщения);
		Возврат;
	КонецЕсли;

	Если НЕ Константы.ФункциональнаяУчетВалютныхОпераций.Получить() И НЕ ЗначениеЗаполнено(Валюта) Тогда
		ТекстСообщения = НСтр("ka='Не выбрана валюта!';ru='Не выбрана валюта!';en='Not selected currency!'");
		ПолеСообщения = "Валюта";
		УправлениеНебольшойФирмойСервер.СообщитьОбОшибке(Отчет, ТекстСообщения,,,ПолеСообщения);
		Возврат;
	КонецЕсли;
	
	ТаблицаОтправики = Новый ТаблицаЗначений;
	ТаблицаОтправики.Колонки.Добавить("Получатель");
	ТаблицаОтправики.Колонки.Добавить("ТабличныйДокумент");

	РезультатЗапроса = ВыполнитьЗапрос();

	Если РезультатЗапроса[0].Пустой() Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ka='Нет данных для формирования отчета!';ru='Нет данных для формирования отчета!';en='No data to generate a report!'");
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;

	//Макет = Отчеты.РасчетныеЛисткиСОтправкой.ПолучитьМакет("Макет");
	// Олег Литвиненко 29.06.23 --->
	ЭтотОтчет = РеквизитФормыВЗначение("Отчет");
	Макет = ЭтотОтчет.ПолучитьМакет("Макет"); 

	РегВалюта = Константы.НациональнаяВалюта.Получить();
	// Олег Литвиненко <---

	ОбластьШапка 				= Макет.ПолучитьОбласть("Шапка");
	ОбластьЗаголовок 			= Макет.ПолучитьОбласть("Заголовок");
	ОбластьНачисленоУдержано 	= Макет.ПолучитьОбласть("НачисленоУдержано");
	ОбластьДетали 				= Макет.ПолучитьОбласть("Детали");
	ОбластьДоходыВыплачено 		= Макет.ПолучитьОбласть("ДоходыВыплачено");
	ОбластьДеталиВыплаты 		= Макет.ПолучитьОбласть("ДеталиВыплаты");
	ОбластьВсего 				= Макет.ПолучитьОбласть("Всего");
	// Олег Литвиненко 29.06.23 --->
	ОбластьВсегоВал				= Макет.ПолучитьОбласть("ВсегоВал");
	ОбластьВремяШапка			= Макет.ПолучитьОбласть("РабочееВремяШапка");
	ОбластьВремяСтрока			= Макет.ПолучитьОбласть("РабочееВремяСтрока");
	// Олег Литвиненко <---
	ОбластьПодвал 				= Макет.ПолучитьОбласть("Подвал");
	ОбластьОтбивка 				= Макет.ПолучитьОбласть("Отбивка");

	//ТабличныйДокумент.Очистить();
	
	// Олег Литвиненко 29.06.23 --->
	ТаблицаТабель = РезультатЗапроса[2].Выгрузить();
	СтруктураОтбораТабель = Новый Структура("Подразделение,Должность,ФизЛицо");
	// Олег Литвиненко <---

	ВыборкаПодразделение = РезультатЗапроса[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Подразделение");
	Пока ВыборкаПодразделение.Следующий() Цикл
			
		ВыборкаФизлицо = ВыборкаПодразделение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизЛицо");
		Пока ВыборкаФизлицо.Следующий() Цикл
			
			НовСтрокаТабОтправки = ТаблицаОтправики.Добавить();
			
			ТабДок = Новый ТабличныйДокумент;
			
			ОбластьОтбивка.Параметры.ТекстОтбивки = Формат(ПериодРегистрации , "ДФ=""ММММ гггг 'г.' """);
			ТабДок.Вывести(ОбластьОтбивка);
			
			ОбластьОтбивка.Параметры.ТекстОтбивки = "Организация: " + Организация;
			ТабДок.Вывести(ОбластьОтбивка);
			
			//ВыборкаПодразделение = РезультатЗапроса[0].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Подразделение");
			//Пока ВыборкаПодразделение.Следующий() Цикл
			
			ОбластьОтбивка.Параметры.ТекстОтбивки = "Подразделение: " + ВыборкаПодразделение.Подразделение;
			ТабДок.Вывести(ОбластьОтбивка);
			//ТабДок.НачатьГруппуСтрок();
			
			ОбластьШапка.Параметры.Заголовок = "Расчетный листок за " + Формат(ПериодРегистрации , "ДФ=""ММММ гггг 'г.' """);
			ОбластьШапка.Параметры.Организация = Организация;
			ОбластьШапка.Параметры.Заполнить(ВыборкаФизлицо);
			ПредставлениеФизЛицо = УправлениеНебольшойФирмойСервер.ПолучитьФамилиюИмяОтчество(ВыборкаФизлицо.Фамилия, ВыборкаФизлицо.Имя, ВыборкаФизлицо.Отчество, Истина);
			ОбластьШапка.Параметры.ФизЛицо = ВыборкаФизлицо.Физлицо.НаименованиеНаИностранскомЯзыке;//Физлицо.НаименованиеАнглиское;//?(ЗначениеЗаполнено(ПредставлениеФизЛицо), ПредставлениеФизЛицо, ВыборкаФизлицо.Физлицо);
			ТабДок.Вывести(ОбластьШапка);
			ТабДок.Вывести(ОбластьЗаголовок);
			ТабДок.Вывести(ОбластьНачисленоУдержано);
			
			ПоследнееНачисление = ТабДок.ВысотаТаблицы;
			ПоследнееУдержание = ТабДок.ВысотаТаблицы;
			
			ВыборкаДетали = ВыборкаФизлицо.Выбрать();
			Пока ВыборкаДетали.Следующий() Цикл
				
				Если ВыборкаДетали.Удержание = NULL Тогда
					
					Если ПоследнееНачисление < ПоследнееУдержание Тогда
						
						ТабДок.Область(ПоследнееНачисление + 1, 1).Текст = ВыборкаДетали.Начисление;
						ТабДок.Область(ПоследнееНачисление + 1, 2, ПоследнееНачисление + 1, 3).Текст = "" + День(ВыборкаДетали.ДатаНачала) + "-" + День(ВыборкаДетали.ДатаОкончания) + " " + Формат(ВыборкаДетали.ДатаОкончания , "ДФ=""МММ гг""");
						ТабДок.Область(ПоследнееНачисление + 1, 4).Текст = ВыборкаДетали.ОтработаноДней;
						ТабДок.Область(ПоследнееНачисление + 1, 5).Текст = ВыборкаДетали.ОтработаноЧасов;
						//ТабДок.Область(ПоследнееНачисление + 1, 6, ПоследнееНачисление + 1, 7).Текст = ВыборкаДетали.СуммаНачислено;
						// Олег Литвиненко 17.08.23 --->
						ТабДок.Область(ПоследнееНачисление + 1, 6, ПоследнееНачисление + 1, 7).Текст = ?(ВыборкаДетали.Валюта=РегВалюта, ВыборкаДетали.СуммаНачислено, ВыборкаДетали.СуммаНачисленоВал);
						// Олег Литвиненко <---
					
					Иначе
					
						ОбластьДетали.Параметры.Начисление = СтрШаблон("%1, %2", ВыборкаДетали.Начисление, ВыборкаДетали.ВалютаПредставление);
						ОбластьДетали.Параметры.ПериодНачисление = "" + День(ВыборкаДетали.ДатаНачала) + "-" + День(ВыборкаДетали.ДатаОкончания) + " " + Формат(ВыборкаДетали.ДатаОкончания , "ДФ=""МММ гг""");
						ОбластьДетали.Параметры.ОтработаноДнейНачисление = ВыборкаДетали.ОтработаноДней;
						ОбластьДетали.Параметры.ОтработаноЧасовНачисление = ВыборкаДетали.ОтработаноЧасов;
						ОбластьДетали.Параметры.СуммаНачислениеВал = ВыборкаДетали.СуммаНачисленоВал;
						
						ТабДок.Вывести(ОбластьДетали);
						
						ОбластьДетали.Параметры.Начисление = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
						ОбластьДетали.Параметры.ПериодНачисление = "";
						ОбластьДетали.Параметры.ОтработаноДнейНачисление = 0;
						ОбластьДетали.Параметры.ОтработаноЧасовНачисление = 0;
						ОбластьДетали.Параметры.СуммаНачислениеВал = 0;
					
					КонецЕсли; 
					
					ПоследнееНачисление = ПоследнееНачисление + 1;
					
				Иначе
					
					Если ПоследнееУдержание < ПоследнееНачисление Тогда
					
						ТабДок.Область(ПоследнееУдержание + 1, 8, ПоследнееУдержание + 1, 10).Текст = ВыборкаДетали.Удержание;	
						ТабДок.Область(ПоследнееУдержание + 1, 11, ПоследнееУдержание + 1, 12).Текст = "" + День(ВыборкаДетали.ДатаНачала) + "-" + День(ВыборкаДетали.ДатаОкончания) + " " + Формат(ВыборкаДетали.ДатаОкончания , "ДФ=""МММ гг""");
						ТабДок.Область(ПоследнееУдержание + 1, 13, ПоследнееУдержание + 1, 14).Текст = ВыборкаДетали.СуммаУдержано;
					
					Иначе
					
						ОбластьДетали.Параметры.Удержание = ВыборкаДетали.Удержание;
						ОбластьДетали.Параметры.ПериодУдержание = "" + День(ВыборкаДетали.ДатаНачала) + "-" + День(ВыборкаДетали.ДатаОкончания) + " " + Формат(ВыборкаДетали.ДатаОкончания , "ДФ=""МММ гг""");
						ОбластьДетали.Параметры.СуммаУдержаниеВал = ВыборкаДетали.СуммаУдержаноВал;
						
						ТабДок.Вывести(ОбластьДетали);
						
						ОбластьДетали.Параметры.Удержание = Справочники.ВидыНачисленийИУдержаний.ПустаяСсылка();
						ОбластьДетали.Параметры.ПериодУдержание = "";
						ОбластьДетали.Параметры.СуммаУдержаниеВал = 0;
					
					КонецЕсли; 
					
					ПоследнееУдержание = ПоследнееУдержание + 1;
					
				КонецЕсли; 
				
			КонецЦикла;
			
			ОбластьВсего.Параметры.ВсегоНачисления = ВыборкаФизлицо.СуммаНачислено;
			ОбластьВсего.Параметры.ВсегоУдержания = ВыборкаФизлицо.СуммаУдержано;
			// Олег Литвиненко 29.06.23 --->
			ОбластьВсегоВал.Параметры.Валюта = ВыборкаФизлицо.ВалютаПредставление;
			ОбластьВсегоВал.Параметры.ВсегоНачисленияВал = ВыборкаФизлицо.СуммаНачисленоВал;
			//ОбластьВсегоВал.Параметры.ВсегоУдержанияВал = ВыборкаФизлицо.СуммаУдержаноВал;
			Если Не ВыборкаФизлицо.Валюта = РегВалюта Тогда
				ТабДок.Вывести(ОбластьВсегоВал);
			КонецЕсли;
			// Олег Литвиненко <---
			ТабДок.Вывести(ОбластьВсего);
			
			Если Ложь Тогда // Выключено по просьбе Giorgi Sigua
				ТабДок.Вывести(ОбластьДоходыВыплачено);
				ВыборкаВыплатСотрудника		= РезультатЗапроса[1].Выбрать();
				
				СтруктураПоискиПоВыборкей	= Новый Структура("Сотрудник", ВыборкаФизлицо.Физлицо);
				Пока ВыборкаВыплатСотрудника.НАйтиСледующий(СтруктураПоискиПоВыборкей) Цикл
					
					//ОбластьДеталиВыплаты.Параметры.Заполнить(ВыборкаВыплатСотрудника);
					// Олег Литвиненко 29.06.23 --->
					Если Не РегВалюта = ВыборкаФизлицо.Валюта Тогда
						ОбластьДеталиВыплаты.Параметры.СуммаВыплаты	= ВыборкаВыплатСотрудника.СуммаВыплатыВал;
					
						ОбластьДеталиВыплаты.Параметры.ТекстВыплаты = "" + ВыборкаВыплатСотрудника.ПредставлениеДокумента + ?(ВыборкаВыплатСотрудника.ПризнакАванса, "(аванс) №", " №") + 
																		СокрЛП(ВыборкаВыплатСотрудника.Номер) + " от " + Формат(ВыборкаВыплатСотрудника.Дата, "ДФ=dd.MM.yyyy") + ", "+ ВыборкаФизлицо.ВалютаПредставление;
						ОбластьДеталиВыплаты.Параметры.ПериодВыплат		= "" + День(ПериодРегистрации) + "-" + День(КонецМесяца(ПериодРегистрации)) + " " + Формат(КонецМесяца(ПериодРегистрации) , "ДФ=""МММ гг""");
						
						ТабДок.Вывести(ОбластьДеталиВыплаты);
					КонецЕсли;
					// Олег Литвиненко <---
					
					ОбластьДеталиВыплаты.Параметры.СуммаВыплаты	= ВыборкаВыплатСотрудника.СуммаВыплаты;
					
					ОбластьДеталиВыплаты.Параметры.ТекстВыплаты = "" + ВыборкаВыплатСотрудника.ПредставлениеДокумента + ?(ВыборкаВыплатСотрудника.ПризнакАванса, "(аванс) №", " №") + 
																	СокрЛП(ВыборкаВыплатСотрудника.Номер) + " от " + Формат(ВыборкаВыплатСотрудника.Дата, "ДФ=dd.MM.yyyy") + ", "+ РегВалюта;
					ОбластьДеталиВыплаты.Параметры.ПериодВыплат		= "" + День(ПериодРегистрации) + "-" + День(КонецМесяца(ПериодРегистрации)) + " " + Формат(КонецМесяца(ПериодРегистрации) , "ДФ=""МММ гг""");
					
					ТабДок.Вывести(ОбластьДеталиВыплаты);
					
				КонецЦикла;
				
				ОбластьПодвал.Параметры.СуммаДолгНаНачалоПериода = ВыборкаФизлицо.СальдоНаНачало;
				
				Если ВыборкаФизлицо.СальдоНаНачало < 0 Тогда
					ОбластьПодвал.Параметры.ТекстДолгНаНачалоПериода = "Долг за работником на начало месяца:";
				Иначе	
					ОбластьПодвал.Параметры.ТекстДолгНаНачалоПериода = "Долг за организацией на начало месяца:";
				КонецЕсли; 
			
			КонецЕсли;
			
			ОбластьПодвал.Параметры.СуммаДолгНаКонецПериода = ВыборкаФизлицо.СальдоНаКонец;
			Если ВыборкаФизлицо.СальдоНаКонец < 0 Тогда
				ОбластьПодвал.Параметры.ТекстДолгНаКонецПериода = "Долг за работником на конец месяца:";
			Иначе	
				ОбластьПодвал.Параметры.ТекстДолгНаКонецПериода = "Долг за организацией на конец месяца:";
			КонецЕсли; 
			ТабДок.Вывести(ОбластьПодвал);
			
			Если Ложь Тогда // Выключено по просьбе Giorgi Sigua
				// Олег Литвиненко 29.06.23 --->
				ЗаполнитьЗначенияСвойств(СтруктураОтбораТабель, ВыборкаФизлицо);
				МассивСтрокТабеля = ТаблицаТабель.НайтиСтроки(СтруктураОтбораТабель);
				Если МассивСтрокТабеля.Количество()>0 Тогда
					ТабДок.Вывести(ОбластьВремяШапка);
					Для Каждого ТекСтр Из МассивСтрокТабеля Цикл
						ОбластьВремяСтрока.Параметры.Заполнить(ТекСтр);
						ТабДок.Вывести(ОбластьВремяСтрока);
					КонецЦикла;
				КонецЕсли;
				// Олег Литвиненко <---
			КонецЕсли;
			
			ВидКИ = Справочники.ВидыКонтактнойИнформации.EmailФизическиеЛица;
			ТипКИ = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			
			КонтактнаяИнформацияСотрудника = ВыборкаФизлицо.Физлицо.Физлицо.КонтактнаяИнформация;
			ПоискМейла = КонтактнаяИнформацияСотрудника.НайтиСтроки(Новый Структура("Вид, Тип", ВидКИ, ТипКИ));
			
			Если ПоискМейла.Количество() > 0 Тогда 
				НовСтрокаТабОтправки.Получатель = ?(ЗначениеЗаполнено(ПоискМейла[0].АдресЭП), ПоискМейла[0].АдресЭП, ПоискМейла[0].Представление);
			КонецЕсли;
			НовСтрокаТабОтправки.ТабличныйДокумент = ТабДок;        
				
		КонецЦикла;
		
		//ТабДок.ЗакончитьГруппуСтрок();
		
		//НовСтрокаТабОтправки.Получатель = 
	КонецЦикла;
	
	ПодготовитьОтпраивтьПисьма(ТаблицаОтправики)
	
КонецПроцедуры

&НаСервере
Функция ПроверитьНастройкиПочты()

	МожноОтправлять = Истина;
	УстановитьПривилегированныйРежим(Истина);
	ХЗНастройкиОбмена = Константы.НастройкиДляОтправкиОтчетов.Получить();
	УстановитьПривилегированныйРежим(Истина);
	Если ХЗНастройкиОбмена <> Неопределено И ТипЗнч(ХЗНастройкиОбмена) = Тип("ХранилищеЗначения") Тогда
	
		НастройкиОбмена = ХЗНастройкиОбмена.Получить();
		Если ТипЗнч(НастройкиОбмена) = Тип("Структура") Тогда
		
			Если НЕ ЗначениеЗаполнено(НастройкиОбмена.ИмяСервераSMTP) 
				ИЛИ НЕ ЗначениеЗаполнено(НастройкиОбмена.ЛогинSMTP)
				ИЛИ НЕ ЗначениеЗаполнено(НастройкиОбмена.ПарольSMTP) Тогда 
				
				МожноОтправлять = Ложь;
				
			КонецЕсли;
		
		КонецЕсли; 
	
	КонецЕсли;	

	Возврат МожноОтправлять;
	
КонецФункции // ()

&НаСервере
Процедура ПодготовитьОтпраивтьПисьма(ТаблицаОтправики)
	
	Для Каждого Строк Из ТаблицаОтправики Цикл
		
		Если НЕ ЗначениеЗаполнено(Строк.Получатель) Тогда 
			Продолжить;
		КонецЕсли;
		
		МенеджерЗаписи = РегистрыСведений.ОтправкаОтчетаНаЭлектроннуюПочту.СоздатьМенеджерЗаписи();
	
		МенеджерЗаписи.ПолучательМейл = Строк.Получатель;
		МенеджерЗаписи.ИмяОтчета = "РасчетныеЛисткиСОтправкой";
		МенеджерЗаписи.ВложеныйФайл = Новый ХранилищеЗначения(Строк.ТабличныйДокумент);

		МенеджерЗаписи.Записать();
		
	КонецЦикла;
	
	РегЗадание = РегламентныеЗадания.НайтиПредопределенное("ОтправкаПисемСОтчетами");
	
	Если НЕ РегЗадание.Использование Тогда 
		РегЗадание.Использование = Истина;
		РегЗадание.Записать();
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура Отправить(Команда)
	ОтправитьНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура НастройкиПочты(Команда)
	ОткрытьФорму("Отчет.РасчетныеЛисткиСОтправкой.Форма.ФормаНастройкиСоединения");
КонецПроцедуры
