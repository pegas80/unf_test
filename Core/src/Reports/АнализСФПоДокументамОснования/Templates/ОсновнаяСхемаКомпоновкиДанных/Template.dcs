		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>НомерСФ</dataPath>
			<field>НомерСФ</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Номер СФ</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>აფ-ს ნომერი</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаНДСПоСФНаПортале</dataPath>
			<field>СуммаНДСПоСФНаПортале</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма НДС по СФ на портале</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>დღგ-ის თანხა აფ-ის მიხედვით პორტალზე</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СуммаПоСФНаПортале</dataPath>
			<field>СуммаПоСФНаПортале</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сумма по СФ на портале</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>თანხა აფ-ის მიხედვით პორტალზე</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СФПолученный</dataPath>
			<field>СФПолученный</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>СФ Полученный</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>აფ მიღებული</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	СчетФактураПолученныйГрузия.Ссылка КАК СФПолученный,
	СчетФактураПолученныйГрузия.Сумма КАК СуммаПоСФНаПортале,
	СчетФактураПолученныйГрузия.СуммаНДС КАК СуммаНДСПоСФНаПортале,
	СчетФактураПолученныйГрузия.Ссылка.НомерВходящегоДокумента КАК НомерСФ
ИЗ
	(ВЫБРАТЬ
		СчетФактураПолученныйГрузия.Ссылка КАК Ссылка,
		СУММА(ЕСТЬNULL(СчетФактураПолученныйГрузияТоварыНаПортале.СуммаНДС, 0)) КАК СуммаНДС,
		СУММА(ЕСТЬNULL(СчетФактураПолученныйГрузияТоварыНаПортале.Сумма, 0)) КАК Сумма
	ИЗ
		Документ.СчетФактураПолученныйГрузия КАК СчетФактураПолученныйГрузия
			ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураПолученныйГрузия.ТоварыНаПортале КАК СчетФактураПолученныйГрузияТоварыНаПортале
			ПО СчетФактураПолученныйГрузия.Ссылка = СчетФактураПолученныйГрузияТоварыНаПортале.Ссылка
	ГДЕ
		СчетФактураПолученныйГрузия.ДатаВходящегоДокумента МЕЖДУ &amp;ДатаНач И ВЫБОР
				КОГДА &amp;ДатаКон = НЕОПРЕДЕЛЕНО
						ИЛИ &amp;ДатаКон = NULL
						ИЛИ &amp;ДатаКон = ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА ДАТАВРЕМЯ(3999, 12, 31)
				ИНАЧЕ &amp;ДатаКон
			КОНЕЦ
	
	СГРУППИРОВАТЬ ПО
		СчетФактураПолученныйГрузия.Ссылка) КАК СчетФактураПолученныйГрузия</query>
	</dataSet>
