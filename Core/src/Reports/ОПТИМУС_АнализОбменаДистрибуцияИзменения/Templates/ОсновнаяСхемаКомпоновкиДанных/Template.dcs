		<field xsi:type="DataSetFieldField">
			<dataPath>Узел</dataPath>
			<field>Узел</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДоговорыКонтрагентовИзменения.Ссылка КАК Ссылка,
	ДоговорыКонтрагентовИзменения.Ссылка.Владелец КАК Владелец,
	ДоговорыКонтрагентовИзменения.Ссылка.ВидЦен КАК ВидЦен,
	ДоговорыКонтрагентовИзменения.Ссылка.ТорговыйПредставитель КАК ТорговыйПредставитель,
	ДоговорыКонтрагентовИзменения.Узел
ПОМЕСТИТЬ врДоговоры
ИЗ
	Справочник.ДоговорыКонтрагентов.Изменения КАК ДоговорыКонтрагентовИзменения
ГДЕ
	ДоговорыКонтрагентовИзменения.Узел = &amp;Узел
	И ДоговорыКонтрагентовИзменения.Ссылка.ТорговыйПредставитель = &amp;ТорговыйПредставитель
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	КонтрагентыИзменения.Ссылка КАК Владелец,
	КонтрагентыИзменения.Узел КАК Узел,
	ДоговорыКонтрагентов.ВидЦен
ПОМЕСТИТЬ врКонтрагенти
ИЗ
	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.Изменения КАК КонтрагентыИзменения
		ПО ДоговорыКонтрагентов.Владелец = КонтрагентыИзменения.Ссылка
ГДЕ
	КонтрагентыИзменения.Узел = &amp;Узел
	И ДоговорыКонтрагентов.ТорговыйПредставитель = &amp;ТорговыйПредставитель
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	врДоговоры.ВидЦен,
	врДоговоры.Узел
ПОМЕСТИТЬ врВыдиЦен
ИЗ
	врДоговоры КАК врДоговоры

СГРУППИРОВАТЬ ПО
	врДоговоры.ВидЦен,
	врДоговоры.Узел

ОБЪЕДИНИТЬ

ВЫБРАТЬ РАЗЛИЧНЫЕ
	врКонтрагенти.ВидЦен,
	врКонтрагенти.Узел
ИЗ
	врКонтрагенти КАК врКонтрагенти
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НоменклатураИзменения.Ссылка,
	ВЫБОР
		КОГДА НоменклатураИзменения.Ссылка.ЭтоГруппа
			ТОГДА 1
		ИНАЧЕ 2
	КОНЕЦ КАК врЭтоГруппа,
	НоменклатураИзменения.Узел
ПОМЕСТИТЬ врНоменклатури
ИЗ
	Справочник.Номенклатура.Изменения КАК НоменклатураИзменения
ГДЕ
	НоменклатураИзменения.Ссылка В ИЕРАРХИИ(&amp;Номенклатура)
	И НоменклатураИзменения.Узел = &amp;Узел
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗапасыОстатки.Номенклатура,
	ЗапасыОстатки.КоличествоОстаток,
	ЗапасыОстатки.СтруктурнаяЕдиница
ПОМЕСТИТЬ врОстатки
ИЗ
	РегистрНакопления.Запасы.Остатки(
			&amp;ТекДата,
			ВЫБОР
					КОГДА &amp;НесколькоОрганизация
						ТОГДА Организация = &amp;Организация
					ИНАЧЕ ИСТИНА
				КОНЕЦ
				И СтруктурнаяЕдиница В (&amp;Склад)
				И ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
				И Номенклатура В ИЕРАРХИИ (&amp;Номенклатура)) КАК ЗапасыОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗапасыОстатки.Номенклатура,
	ЗапасыОстатки.КоличествоОстаток,
	ЗапасыОстатки.СтруктурнаяЕдиница
ПОМЕСТИТЬ врОстаткиВозвратов
ИЗ
	РегистрНакопления.Запасы.Остатки(
			,
			ВЫБОР
					КОГДА &amp;НесколькоОрганизация
						ТОГДА Организация = &amp;Организация
					ИНАЧЕ ИСТИНА
				КОНЕЦ
				И СтруктурнаяЕдиница В (&amp;СкладВотврата)
				И ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
				И Номенклатура В ИЕРАРХИИ (&amp;Номенклатура)) КАК ЗапасыОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	РасчетыСПокупателямиОстатки.Контрагент,
	ВЫБОР
		КОГДА НЕ РасчетыСПокупателямиОстатки.Документ ЕСТЬ NULL 
			ТОГДА РасчетыСПокупателямиОстатки.Документ.Дата
		ИНАЧЕ ""
	КОНЕЦ КАК Дата,
	РасчетыСПокупателямиОстатки.СуммаОстаток КАК Сумма,
	ВЫБОР
		КОГДА НЕ РасчетыСПокупателямиОстатки.Документ ЕСТЬ NULL 
			ТОГДА РасчетыСПокупателямиОстатки.Документ.Номер
		ИНАЧЕ ""
	КОНЕЦ КАК Номер,
	РасчетыСПокупателямиОстатки.Договор
ПОМЕСТИТЬ врВзаиморасчети
ИЗ
	РегистрНакопления.РасчетыСПокупателями.Остатки(
			,
			ВЫБОР
					КОГДА &amp;НесколькоОрганизация
						ТОГДА Организация = &amp;Организация
					ИНАЧЕ ИСТИНА
				КОНЕЦ
				И Договор.ТорговыйПредставитель = &amp;ТорговыйПредставитель) КАК РасчетыСПокупателямиОстатки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныНоменклатурыСрезПоследних.Период,
	ЦеныНоменклатурыСрезПоследних.ВидЦен,
	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	ЦеныНоменклатурыСрезПоследних.Характеристика,
	ЦеныНоменклатурыСрезПоследних.Цена,
	ЦеныНоменклатурыСрезПоследних.Актуальность,
	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения,
	ЦеныНоменклатурыСрезПоследних.Автор
ПОМЕСТИТЬ врЦены
ИЗ
	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, Номенклатура В ИЕРАРХИИ (&amp;Номенклатура)) КАК ЦеныНоменклатурыСрезПоследних
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ врВыдиЦен КАК врВыдиЦен
		ПО ЦеныНоменклатурыСрезПоследних.ВидЦен = врВыдиЦен.ВидЦен
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	врДоговоры.Ссылка,
	NULL КАК КоличествоОстаток,
	NULL КАК Дата,
	NULL КАК Сумма,
	NULL КАК Номер,
	NULL КАК Договор,
	NULL КАК Период,
	NULL КАК Номенклатура,
	NULL КАК Характеристика,
	NULL КАК Цена,
	NULL КАК Актуальность,
	NULL КАК ЕдиницаИзмерения,
	NULL КАК Автор,
	"Договоры" КАК ВидДанных,
	врДоговоры.ТорговыйПредставитель,
	4 КАК ПолеСортировки,
	NULL КАК ВидЦен,
	0 КАК врЭтоГруппа,
	NULL КАК Контрагент,
	врДоговоры.Узел
ИЗ
	врДоговоры КАК врДоговоры

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	врКонтрагенти.Владелец,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"_Контрагенты",
	NULL,
	3,
	NULL,
	0,
	врКонтрагенти.Владелец,
	NULL
ИЗ
	врКонтрагенти КАК врКонтрагенти

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	врВыдиЦен.ВидЦен,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"ВидыЦен",
	NULL,
	2,
	NULL,
	0,
	NULL,
	врВыдиЦен.Узел
ИЗ
	врВыдиЦен КАК врВыдиЦен

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	врНоменклатури.Ссылка,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"Номенклатура",
	NULL,
	1,
	NULL,
	врНоменклатури.врЭтоГруппа,
	NULL,
	врНоменклатури.Узел
ИЗ
	врНоменклатури КАК врНоменклатури

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"Остатки",
	СУММА(врОстатки.КоличествоОстаток),
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	врОстатки.Номенклатура,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"Остатки",
	NULL,
	6,
	NULL,
	0,
	NULL,
	NULL
ИЗ
	врОстатки КАК врОстатки

СГРУППИРОВАТЬ ПО
	врОстатки.Номенклатура

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"Взаиморасчети",
	NULL,
	врВзаиморасчети.Дата,
	врВзаиморасчети.Сумма,
	врВзаиморасчети.Номер,
	врВзаиморасчети.Договор,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"Взаиморасчети",
	NULL,
	5,
	NULL,
	0,
	врВзаиморасчети.Контрагент,
	NULL
ИЗ
	врВзаиморасчети КАК врВзаиморасчети

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"Цены",
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	врЦены.Период,
	врЦены.Номенклатура,
	врЦены.Характеристика,
	врЦены.Цена,
	врЦены.Актуальность,
	врЦены.ЕдиницаИзмерения,
	врЦены.Автор,
	"Цены",
	NULL,
	7,
	врЦены.ВидЦен,
	0,
	NULL,
	NULL
ИЗ
	врЦены КАК врЦены

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"ОстаткиВозвратов",
	СУММА(врОстаткиВозвратов.КоличествоОстаток),
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	врОстаткиВозвратов.Номенклатура,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"ОстаткиВозвратов",
	NULL,
	6.5,
	NULL,
	0,
	NULL,
	NULL
ИЗ
	врОстаткиВозвратов КАК врОстаткиВозвратов

СГРУППИРОВАТЬ ПО
	врОстаткиВозвратов.Номенклатура

УПОРЯДОЧИТЬ ПО
	врЭтоГруппа</query>
	</dataSet>
