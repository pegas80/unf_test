		<field xsi:type="DataSetFieldField">
			<dataPath>врЭтоГруппа</dataPath>
			<field>врЭтоГруппа</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Вр это группа</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>Вр ეს ჯგუფი</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
