			<field xsi:type="DataSetFieldField">
				<dataPath>МинималныйОстатокНаСкладе</dataPath>
				<field>МинималныйОстатокНаСкладе</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Минималный остаток на складе</v8:content>
					</v8:item>
				</title>
