			<dataSource>ИсточникДанных1</dataSource>
			<query>ВЫБРАТЬ
	МинимальныеОстаткиСкладаСрезПоследних.СтруктурнаяЕдиница,
	МинимальныеОстаткиСкладаСрезПоследних.Номенклатура,
	МинимальныеОстаткиСкладаСрезПоследних.Количество КАК МинималныйОстатокНаСкладе
ПОМЕСТИТЬ МОС
ИЗ
	РегистрСведений.МинимальныеОстаткиСклада.СрезПоследних КАК МинимальныеОстаткиСкладаСрезПоследних
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВЫБОР
		КОГДА ЗапасыОстаткиИОбороты.Регистратор = НЕОПРЕДЕЛЕНО
				ИЛИ ЗапасыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЗаказПокупателя
					И ВЫРАЗИТЬ(ЗапасыОстаткиИОбороты.Регистратор КАК Документ.ЗаказПокупателя).ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЗаказПокупателя.ЗаказНаПродажу)
				ИЛИ ЗапасыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЗаказНаПроизводство
			ТОГДА NULL
		ИНАЧЕ ЗапасыОстаткиИОбороты.Регистратор
	КОНЕЦ КАК Регистратор,
	ЗапасыОстаткиИОбороты.ПериодСекунда,
	ЗапасыОстаткиИОбороты.ПериодМинута,
	ЗапасыОстаткиИОбороты.ПериодЧас,
	ЗапасыОстаткиИОбороты.ПериодДень,
	ЗапасыОстаткиИОбороты.ПериодНеделя,
	ЗапасыОстаткиИОбороты.ПериодДекада,
	ЗапасыОстаткиИОбороты.ПериодМесяц,
	ЗапасыОстаткиИОбороты.ПериодКвартал,
	ЗапасыОстаткиИОбороты.ПериодГод,
	ЗапасыОстаткиИОбороты.Организация,
	ЕСТЬNULL(ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница, МОС.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиница,
	ЗапасыОстаткиИОбороты.СчетУчетаРегл КАК СчетУчета,
	ЕСТЬNULL(ЗапасыОстаткиИОбороты.Номенклатура, МОС.Номенклатура) КАК Номенклатура,
	ЗапасыОстаткиИОбороты.Характеристика КАК Характеристика,
	ЗапасыОстаткиИОбороты.Партия,
	ЗапасыОстаткиИОбороты.ЗаказПокупателя,
	ЗапасыОстаткиИОбороты.КоличествоНачальныйОстаток,
	ЗапасыОстаткиИОбороты.КоличествоКонечныйОстаток,
	ЗапасыОстаткиИОбороты.КоличествоОборот,
	ЗапасыОстаткиИОбороты.КоличествоПриход,
	ЗапасыОстаткиИОбороты.КоличествоРасход,
	ЗапасыОстаткиИОбороты.СуммаНачальныйОстаток,
	ЗапасыОстаткиИОбороты.СуммаКонечныйОстаток,
	ЗапасыОстаткиИОбороты.СуммаОборот,
	ЗапасыОстаткиИОбороты.СуммаПриход,
	ЗапасыОстаткиИОбороты.СуммаРасход,
	ЗапасыОстаткиИОбороты.Номенклатура.ЕдиницаИзмерения,
	ВЫБОР
		КОГДА ЗапасыОстаткиИОбороты.Партия &lt;&gt; ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
				И ЗапасыОстаткиИОбороты.Партия.Статус &lt;&gt; ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы)
			ТОГДА "Принятые"
		ИНАЧЕ "Собственные"
	КОНЕЦ КАК Статус,
	ЕСТЬNULL(УправлениеЗапасами.МинимальныйУровеньЗапаса, 0) КАК МинимальныйУровеньЗапаса,
	ЕСТЬNULL(УправлениеЗапасами.МаксимальныйУровеньЗапаса, 0) КАК МаксимальныйУровеньЗапаса,
	ЕСТЬNULL(МОС.МинималныйОстатокНаСкладе, 0) КАК МинималныйОстатокНаСкладе
ИЗ
	МОС КАК МОС
		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.ОстаткиИОбороты(
				,
				,
				Авто,
				,
				СчетУчетаРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.Запасы)
					И (&amp;ВыводитьТолькоСобственныеЗапасы &lt;&gt; ИСТИНА
						ИЛИ (Партия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
							ИЛИ Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы)))) КАК ЗапасыОстаткиИОбороты
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УправлениеЗапасами КАК УправлениеЗапасами
			ПО ЗапасыОстаткиИОбороты.Номенклатура = УправлениеЗапасами.Номенклатура
				И ЗапасыОстаткиИОбороты.Характеристика = УправлениеЗапасами.Характеристика
		ПО МОС.СтруктурнаяЕдиница = ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница
			И МОС.Номенклатура = ЗапасыОстаткиИОбороты.Номенклатура</query>
		</item>
		<item xsi:type="DataSetQuery">
			<name>НаборДанных3</name>
			<field xsi:type="DataSetFieldField">
				<dataPath>Номенклатура</dataPath>
				<field>Номенклатура</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Номенклатура</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>ka</v8:lang>
						<v8:content>ნომენკლატურა</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>en</v8:lang>
						<v8:content>Nomenclature</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Характеристика</dataPath>
				<field>Характеристика</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Характеристика</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>ka</v8:lang>
						<v8:content>მახასიათებელი</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>en</v8:lang>
						<v8:content>Characteristic</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Статус</dataPath>
				<field>Статус</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Статус</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>ka</v8:lang>
						<v8:content>სტატუსი</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>en</v8:lang>
						<v8:content>Status</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Партия</dataPath>
				<field>Партия</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Партия</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>ka</v8:lang>
						<v8:content>პარტია</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>en</v8:lang>
						<v8:content>Партия</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Организация</dataPath>
				<field>Организация</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СтруктурнаяЕдиница</dataPath>
				<field>СтруктурнаяЕдиница</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ЗаказПокупателя</dataPath>
				<field>ЗаказПокупателя</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СчетУчета</dataPath>
				<field>СчетУчета</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СчетУчетаРегл</dataPath>
				<field>СчетУчетаРегл</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СчетУчетаЗатратРегл</dataPath>
				<field>СчетУчетаЗатратРегл</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>МаксимальныйУровеньЗапаса</dataPath>
				<field>МаксимальныйУровеньЗапаса</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>МинимальныйУровеньЗапаса</dataPath>
				<field>МинимальныйУровеньЗапаса</field>
			</field>
			<dataSource>ИсточникДанных1</dataSource>
			<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Номенклатура.Ссылка КАК Номенклатура,
	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика
ПОМЕСТИТЬ ВременнаяТаблицаНоменклатураХарактеристики
ИЗ
	Справочник.Номенклатура КАК Номенклатура
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		ПО (ХарактеристикиНоменклатуры.Владелец = Номенклатура.Ссылка)
			И (Номенклатура.ИспользоватьХарактеристики)
ГДЕ
	&amp;ВыводитьОтсутствующиеНаСкладе = ИСТИНА
	И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	И НЕ Номенклатура.ПометкаУдаления
	И НЕ Номенклатура.ЭтоГруппа
	И НЕ ХарактеристикиНоменклатуры.ПометкаУдаления

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	Номенклатура.Ссылка,
	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
ИЗ
	Справочник.Номенклатура КАК Номенклатура
ГДЕ
	&amp;ВыводитьОтсутствующиеНаСкладе = ИСТИНА
	И Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Запас)
	И НЕ Номенклатура.ПометкаУдаления
	И НЕ Номенклатура.ЭтоГруппа

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗапасыОстаткиИОбороты.Организация,
	ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница
ПОМЕСТИТЬ ВременнаяТаблицаДанныеПоСкладам
ИЗ
	РегистрНакопления.Запасы.ОстаткиИОбороты(
			,
			,
			Авто,
			,
			СчетУчетаРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.Запасы)
				И (&amp;ВыводитьТолькоСобственныеЗапасы &lt;&gt; ИСТИНА
					ИЛИ (Партия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
						ИЛИ Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы)))) КАК ЗапасыОстаткиИОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЕСТЬNULL(ВременнаяТаблицаДанныеПоСкладам.Организация, ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)) КАК Организация,
	ЕСТЬNULL(ВременнаяТаблицаДанныеПоСкладам.СтруктурнаяЕдиница, ЗНАЧЕНИЕ(Справочник.СтруктурныеЕдиницы.ПустаяСсылка)) КАК СтруктурнаяЕдиница,
	ВременнаяТаблицаНоменклатураХарактеристики.Номенклатура КАК Номенклатура,
	ВременнаяТаблицаНоменклатураХарактеристики.Характеристика КАК Характеристика,
	ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка) КАК Партия,
	"Собственные" КАК Статус,
	УправлениеЗапасами.МинимальныйУровеньЗапаса,
	УправлениеЗапасами.МаксимальныйУровеньЗапаса
ИЗ
	ВременнаяТаблицаНоменклатураХарактеристики КАК ВременнаяТаблицаНоменклатураХарактеристики
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблицаДанныеПоСкладам КАК ВременнаяТаблицаДанныеПоСкладам
		ПО (ИСТИНА)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УправлениеЗапасами КАК УправлениеЗапасами
		ПО УправлениеЗапасами.Номенклатура = ВременнаяТаблицаНоменклатураХарактеристики.Номенклатура
			И УправлениеЗапасами.Характеристика = ВременнаяТаблицаНоменклатураХарактеристики.Характеристика</query>
		</item>
	</dataSet>
