		<field xsi:type="DataSetFieldField">
			<dataPath>МаксимальныйУровеньЗапаса</dataPath>
			<field>МаксимальныйУровеньЗапаса</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>მაქსიმალური ზღვარი</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>МинимальныйУровеньЗапаса</dataPath>
			<field>МинимальныйУровеньЗапаса</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>მინიმალური ზღვარი</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЦеныНоменклатурыКонтрагентов.Номенклатура КАК Номенклатура,
	ЦеныНоменклатурыКонтрагентов.Характеристика КАК Характеристика,
	МАКСИМУМ(ЦеныНоменклатурыКонтрагентов.Период) КАК Период
ПОМЕСТИТЬ МаксимальныйПериод
ИЗ
	РегистрСведений.ЦеныНоменклатурыКонтрагентов КАК ЦеныНоменклатурыКонтрагентов
ГДЕ
	ЦеныНоменклатурыКонтрагентов.Актуальность
	И (&amp;Период = ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
			ИЛИ ЦеныНоменклатурыКонтрагентов.Период &lt;= &amp;Период)

СГРУППИРОВАТЬ ПО
	ЦеныНоменклатурыКонтрагентов.Характеристика,
	ЦеныНоменклатурыКонтрагентов.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Период,
	Характеристика,
	Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	МаксимальныйПериод.Номенклатура КАК Номенклатура,
	МаксимальныйПериод.Характеристика КАК Характеристика,
	МАКСИМУМ(ЦеныНоменклатурыКонтрагентов.ВидЦенКонтрагента.Владелец) КАК Поставщик
ПОМЕСТИТЬ Поставщики
ИЗ
	МаксимальныйПериод КАК МаксимальныйПериод
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатурыКонтрагентов КАК ЦеныНоменклатурыКонтрагентов
		ПО МаксимальныйПериод.Период = ЦеныНоменклатурыКонтрагентов.Период
			И МаксимальныйПериод.Номенклатура = ЦеныНоменклатурыКонтрагентов.Номенклатура
			И МаксимальныйПериод.Характеристика = ЦеныНоменклатурыКонтрагентов.Характеристика
			И (ЦеныНоменклатурыКонтрагентов.Актуальность)

СГРУППИРОВАТЬ ПО
	МаксимальныйПериод.Характеристика,
	МаксимальныйПериод.Номенклатура

ИНДЕКСИРОВАТЬ ПО
	Номенклатура,
	Характеристика
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗапасыОстаткиИОбороты.Номенклатура КАК Номенклатура,
	ЗапасыОстаткиИОбороты.Характеристика КАК Характеристика,
	Поставщики.Поставщик КАК Поставщик,
	ЗапасыОстаткиИОбороты.Партия,
	ВЫБОР
		КОГДА ЗапасыОстаткиИОбороты.Партия &lt;&gt; ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
				И ЗапасыОстаткиИОбороты.Партия.Статус &lt;&gt; ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы)
			ТОГДА "Принятые"
		ИНАЧЕ "Собственные"
	КОНЕЦ КАК Статус,
	УправлениеЗапасами.МинимальныйУровеньЗапаса,
	УправлениеЗапасами.МаксимальныйУровеньЗапаса
ИЗ
	РегистрНакопления.Запасы.ОстаткиИОбороты(
			,
			,
			Авто,
			,
			СчетУчетаРегл.ТипСчета = ЗНАЧЕНИЕ(Перечисление.ТипыСчетов.Запасы)
				И (&amp;ВыводитьТолькоСобственныеЗапасы &lt;&gt; ИСТИНА
					ИЛИ (Партия = ЗНАЧЕНИЕ(Справочник.ПартииНоменклатуры.ПустаяСсылка)
						ИЛИ Партия.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПартий.СобственныеЗапасы)))) КАК ЗапасыОстаткиИОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ Поставщики КАК Поставщики
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УправлениеЗапасами КАК УправлениеЗапасами
			ПО (УправлениеЗапасами.Номенклатура = Поставщики.Номенклатура)
				И (УправлениеЗапасами.Характеристика = Поставщики.Характеристика)
		ПО ЗапасыОстаткиИОбороты.Номенклатура = Поставщики.Номенклатура
			И ЗапасыОстаткиИОбороты.Характеристика = Поставщики.Характеристика</query>
	</dataSet>
