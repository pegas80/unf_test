			<c>
				<c>
					<f>1</f>
					<tl>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>В течение отчетного периода применялось более одного тарифа</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>В течение отчетного периода применялось более одного тарифа</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
