			<field xsi:type="DataSetFieldField">
				<dataPath>Регистратор</dataPath>
				<field>Регистратор</field>
				<role>
					<dcscom:periodNumber>1</dcscom:periodNumber>
					<dcscom:periodType>Main</dcscom:periodType>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>ЗаказПокупателя</dataPath>
				<field>ЗаказПокупателя</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Организация</dataPath>
				<field>Организация</field>
				<role>
					<dcscom:dimension>true</dcscom:dimension>
				</role>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Подразделение</dataPath>
				<field>Подразделение</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СтоимостьЗатрат</dataPath>
				<field>СтоимостьЗатрат</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>СтоимостьЗатратПлан</dataPath>
				<field>СтоимостьЗатратПлан</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Стоимость затрат план</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>ka</v8:lang>
						<v8:content>Стоимость затрат план</v8:content>
					</v8:item>
					<v8:item>
						<v8:lang>en</v8:lang>
						<v8:content>The cost of the plan costs</v8:content>
					</v8:item>
				</title>
			</field>
			<dataSource>ИсточникДанных1</dataSource>
			<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Запасы.Регистратор КАК Регистратор,
	Запасы.Организация КАК Организация,
	Запасы.КоррСтруктурнаяЕдиница КАК Подразделение,
	Запасы.КоррНоменклатура КАК Продукция,
	Запасы.КоррХарактеристика КАК ХарактеристикаПродукции,
	Запасы.КоррПартия КАК ПартияПродукции,
	Запасы.КоррСпецификация КАК СпецификацияПродукции,
	Запасы.КоррЗаказПокупателя КАК ЗаказПокупателя,
	ВЫБОР
	//+++ Дмгг Замена по всей конфигурации, теперь будет заполняться с типом услуга
	//КОГДА Запасы.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
		КОГДА Запасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
				ИЛИ Запасы.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	//--- Дмгг
			ТОГДА "Нематериальные затраты"
		ИНАЧЕ Запасы.Номенклатура
	КОНЕЦ КАК Номенклатура,
	ВЫБОР
	//+++ Дмгг Замена по всей конфигурации, теперь будет заполняться с типом услуга
	//КОГДА Запасы.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
		КОГДА Запасы.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
				ИЛИ Запасы.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	//--- Дмгг
			ТОГДА Запасы.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК СтоимостьЗатратПлан,
	Запасы.Характеристика КАК Характеристика,
	Запасы.Партия КАК Партия,
	Запасы.Сумма КАК СтоимостьЗатрат,
	Запасы.Количество КАК КоличествоЗатрат,
	0 КАК КоличествоПродукции,
	Запасы.Спецификация КАК Спецификация
ИЗ
	РегистрНакопления.Запасы КАК Запасы
ГДЕ
	Запасы.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	И Запасы.ЗатратыНаВыпуск
	И ВЫБОР
			КОГДА &amp;КонецПериода = ДАТАВРЕМЯ(1, 1, 1)
				ТОГДА Запасы.Период &gt;= &amp;НачалоПериода
			ИНАЧЕ Запасы.Период МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
		КОНЕЦ</query>
		</item>
