						<v8:startDate>0001-01-01T00:00:00</v8:startDate>
						<v8:endDate>0001-01-01T00:00:00</v8:endDate>
					</dcscor:value>
					<dcsset:userSettingID>88f65ba8-6585-49d5-8357-e72389418fb8</dcsset:userSettingID>
				</dcscor:item>
