		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	АнализПоПодразделениямОбороты.Регистратор,
	АнализПоПодразделениямОбороты.НомерСтроки,
	АнализПоПодразделениямОбороты.Организация,
	АнализПоПодразделениямОбороты.СтруктурнаяЕдиница,
	АнализПоПодразделениямОбороты.Номенклатура,
	АнализПоПодразделениямОбороты.Содержание,
	АнализПоПодразделениямОбороты.СуммаОборот,
	АнализПоПодразделениямОбороты.СуммаНДСОборот,
	АнализПоПодразделениямОбороты.КоличествоОборот,
	АнализПоПодразделениямОбороты.ПериодСекунда,
	АнализПоПодразделениямОбороты.ПериодМинута,
	АнализПоПодразделениямОбороты.ПериодЧас,
	АнализПоПодразделениямОбороты.ПериодДень,
	АнализПоПодразделениямОбороты.ПериодНеделя,
	АнализПоПодразделениямОбороты.ПериодДекада,
	АнализПоПодразделениямОбороты.ПериодМесяц,
	АнализПоПодразделениямОбороты.ПериодКвартал,
	АнализПоПодразделениямОбороты.ПериодПолугодие,
	АнализПоПодразделениямОбороты.ПериодГод,
	АнализПоПодразделениямОбороты.Регистратор.Ссылка
ИЗ
	РегистрНакопления.АнализПоПодразделениям.Обороты(, , Авто, ) КАК АнализПоПодразделениямОбороты</query>
	</dataSet>
