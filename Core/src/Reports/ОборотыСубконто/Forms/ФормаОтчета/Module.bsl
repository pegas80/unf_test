	РЕЗ = "";
	
	Если ЗначениеЗаполнено(ВидСубконто) Тогда
	
		РЕЗ = РЕЗ + ВидСубконто.Наименование;
		
		Если ЗначениеЗаполнено(ЗначениеСубконто) Тогда
		
			РЕЗ = РЕЗ + " = " + ЗначениеСубконто;
		
		КонецЕсли;
	
	КонецЕсли;
	
	ВОЗВРАТ РЕЗ;
