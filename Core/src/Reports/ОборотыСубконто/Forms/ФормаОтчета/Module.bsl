&НаСервере
Процедура ИзменениеСхемыКомпоновкиДанныхПоСубконто() Экспорт
	
	Схема = ПолучитьИзВременногоХранилища(СхемаКомпоновкиДанных);
	
	ТекстУсловияВидСубконто = "";
	Если ЗначениеЗаполнено(ВидСубконто) Тогда
		ТекстУсловияВидСубконто = "&ВидСубконто";
	КонецЕсли;
	
	ТекстЗапроса = НачальныйТекстЗапросаОбороты;
	ТекстЗапроса = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ТекстЗапроса, Новый Структура("УсловиеВидСубконто", ТекстУсловияВидСубконто));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//", "");
	Схема.НаборыДанных.ОстаткиИОборотыПоКорсчетам.Элементы.Обороты.Запрос = ТекстЗапроса;
	
	ТекстЗапроса = НачальныйТекстЗапросаОсновнойНаборДанных;
	ТекстЗапроса = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ТекстЗапроса, Новый Структура("УсловиеВидСубконто", ТекстУсловияВидСубконто));
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "//", "");
	Схема.НаборыДанных.ОстаткиИОборотыПоКорсчетам.Элементы.ОсновнойНаборДанных.Запрос = ТекстЗапроса;
	
	СхемаКомпоновкиДанных = ПоместитьВоВременноеХранилище(Схема, СхемаКомпоновкиДанных);
	Отчет.КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьНачальныйТекстЗапроса()

	СхемаЭталон = Отчеты.ОборотыСубконто.ПолучитьМакет("СхемаКомпоновкиДанных");
	НачальныйТекстЗапросаОбороты = СхемаЭталон.НаборыДанных.ОстаткиИОборотыПоКорсчетам.Элементы.Обороты.Запрос;
	НачальныйТекстЗапросаОсновнойНаборДанных = СхемаЭталон.НаборыДанных.ОстаткиИОборотыПоКорсчетам.Элементы.ОсновнойНаборДанных.Запрос;

КонецПроцедуры

