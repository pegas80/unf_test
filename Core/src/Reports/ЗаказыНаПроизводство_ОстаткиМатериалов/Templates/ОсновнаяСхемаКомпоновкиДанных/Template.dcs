					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТипДвижения</dataPath>
			<field>ТипДвижения</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КоличествоМатериала</dataPath>
			<field>КоличествоМатериала</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>В заказе</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>შეკვეთაში</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>В заказе</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>ka</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>ЧДЦ=3</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВЫБОР
		КОГДА ЗаказыНаПроизводствоОстаткиИОбороты.Регистратор = НЕОПРЕДЕЛЕНО
			ТОГДА NULL
		ИНАЧЕ ЗаказыНаПроизводствоОстаткиИОбороты.Регистратор
	КОНЕЦ КАК Регистратор,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодСекунда,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодМинута,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодЧас,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодДень,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодНеделя,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодДекада,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодМесяц,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодКвартал,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодПолугодие,
	ЗаказыНаПроизводствоОстаткиИОбороты.ПериодГод,
	ЗаказыНаПроизводствоОстаткиИОбороты.Организация,
	ЗаказыНаПроизводствоОстаткиИОбороты.ЗаказНаПроизводство КАК ЗаказНаПроизводство,
	ЗаказыНаПроизводствоОстаткиИОбороты.ЗаказНаПроизводство.ЗаказПокупателя КАК ЗаказПокупателя,
	ЗаказыНаПроизводствоОстаткиИОбороты.Номенклатура КАК Номенклатура,
	ЗаказыНаПроизводствоОстаткиИОбороты.Характеристика КАК Характеристика,
	ЗаказыНаПроизводствоОстаткиИОбороты.КоличествоНачальныйОстаток,
	ЗаказыНаПроизводствоОстаткиИОбороты.КоличествоКонечныйОстаток,
	ЗаказыНаПроизводствоОстаткиИОбороты.КоличествоОборот,
	ЗаказыНаПроизводствоОстаткиИОбороты.КоличествоПриход,
	ЗаказыНаПроизводствоОстаткиИОбороты.КоличествоРасход,
	ЗаказыНаПроизводствоОстаткиИОбороты.ЗаказНаПроизводство.СостояниеЗаказа КАК СостояниеЗаказа,
	ЗаказыНаПроизводствоОстаткиИОбороты.ЗаказНаПроизводство.СтруктурнаяЕдиница КАК Изготовитель
ПОМЕСТИТЬ ЗаказыНаПроизводствоОстаткиИОбороты
ИЗ
	РегистрНакопления.ЗаказыНаПроизводство.ОстаткиИОбороты(, , Авто, Движения, ) КАК ЗаказыНаПроизводствоОстаткиИОбороты

ИНДЕКСИРОВАТЬ ПО
	ЗаказНаПроизводство,
	ЗаказПокупателя,
	Номенклатура,
	Характеристика,
	Изготовитель
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЗаказыНаПроизводствоОстаткиИОбороты.ЗаказНаПроизводство КАК Ссылка
ПОМЕСТИТЬ ТЗ_ЗаказыНаПроизводство
ИЗ
	ЗаказыНаПроизводствоОстаткиИОбороты КАК ЗаказыНаПроизводствоОстаткиИОбороты

ИНДЕКСИРОВАТЬ ПО
	Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЗаказНаПроизводствоЗапасы.Ссылка КАК Ссылка,
	ЗаказНаПроизводствоЗапасы.Ссылка.ЗаказПокупателя КАК ЗаказПокупателя,
	ЗаказНаПроизводствоЗапасы.Ссылка.СтруктурнаяЕдиницаРезерв КАК СтруктурнаяЕдиницаРезерв,
	ЗаказНаПроизводствоЗапасы.Номенклатура КАК Материал,
	ЗаказНаПроизводствоЗапасы.Характеристика КАК ХарактеристикаМатериала,
	СУММА(ЗаказНаПроизводствоЗапасы.Количество) КАК КоличествоМатериала
ПОМЕСТИТЬ ТЗ_Материалы
ИЗ
	Документ.ЗаказНаПроизводство.Запасы КАК ЗаказНаПроизводствоЗапасы
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЗ_ЗаказыНаПроизводство КАК ТЗ_ЗаказыНаПроизводство
		ПО ЗаказНаПроизводствоЗапасы.Ссылка = ТЗ_ЗаказыНаПроизводство.Ссылка

СГРУППИРОВАТЬ ПО
	ЗаказНаПроизводствоЗапасы.Ссылка,
	ЗаказНаПроизводствоЗапасы.Ссылка.ЗаказПокупателя,
	ЗаказНаПроизводствоЗапасы.Ссылка.СтруктурнаяЕдиницаРезерв,
	ЗаказНаПроизводствоЗапасы.Номенклатура,
	ЗаказНаПроизводствоЗапасы.Характеристика

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Материал,
	ХарактеристикаМатериала
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЗаказНаПроизводствоПродукция.Ссылка КАК Ссылка,
	ЗаказНаПроизводствоПродукция.Номенклатура КАК Номенклатура,
	ЗаказНаПроизводствоПродукция.Характеристика КАК Характеристика,
	СУММА(ЗаказНаПроизводствоПродукция.Количество) КАК Количество,
	ЗаказНаПроизводствоПродукция.Спецификация КАК Спецификация
ПОМЕСТИТЬ ТЗ_Продукция
ИЗ
	Документ.ЗаказНаПроизводство.Продукция КАК ЗаказНаПроизводствоПродукция
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЗ_ЗаказыНаПроизводство КАК ТЗ_ЗаказыНаПроизводство
		ПО ЗаказНаПроизводствоПродукция.Ссылка = ТЗ_ЗаказыНаПроизводство.Ссылка

СГРУППИРОВАТЬ ПО
	ЗаказНаПроизводствоПродукция.Ссылка,
	ЗаказНаПроизводствоПродукция.Номенклатура,
	ЗаказНаПроизводствоПродукция.Характеристика,
	ЗаказНаПроизводствоПродукция.Спецификация

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Номенклатура,
	Характеристика,
	Спецификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	ТЗ_Продукция.Номенклатура КАК Номенклатура,
	ТЗ_Продукция.Характеристика КАК Характеристика,
	ТЗ_Продукция.Спецификация КАК Спецификация
ПОМЕСТИТЬ НаборСпецификаций
ИЗ
	ТЗ_Продукция КАК ТЗ_Продукция
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	СправочникСпецификацииСостав.Ссылка КАК Ссылка,
	СправочникСпецификацииСостав.Ссылка.Владелец КАК Продукция,
	СправочникСпецификацииСостав.Ссылка.ХарактеристикаПродукции КАК ХарактеристикаПродукции,
	СУММА(СправочникСпецификацииСостав.КоличествоПродукции) КАК КоличествоПродукции,
	СУММА(СправочникСпецификацииСостав.Количество) КАК Количество,
	СправочникСпецификацииСостав.Номенклатура КАК Материал,
	СправочникСпецификацииСостав.Характеристика КАК ХарактеристикаМатериала
ПОМЕСТИТЬ ТЗ_Спецификации
ИЗ
	Справочник.Спецификации.Состав КАК СправочникСпецификацииСостав
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НаборСпецификаций КАК НаборСпецификаций
		ПО СправочникСпецификацииСостав.Ссылка = НаборСпецификаций.Спецификация
			И СправочникСпецификацииСостав.Ссылка.Владелец = НаборСпецификаций.Номенклатура
			И СправочникСпецификацииСостав.Ссылка.ХарактеристикаПродукции = НаборСпецификаций.Характеристика

СГРУППИРОВАТЬ ПО
	СправочникСпецификацииСостав.Ссылка,
	СправочникСпецификацииСостав.Ссылка.Владелец,
	СправочникСпецификацииСостав.Номенклатура,
	СправочникСпецификацииСостав.Характеристика,
	СправочникСпецификацииСостав.Ссылка.ХарактеристикаПродукции

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Продукция,
	Материал,
	ХарактеристикаМатериала
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТЗ_Продукция.Ссылка КАК Ссылка,
	ТЗ_Продукция.Номенклатура КАК Номенклатура,
	ТЗ_Продукция.Характеристика КАК Характеристика,
	СУММА(ТЗ_Продукция.Количество) КАК Количество,
	ТЗ_Продукция.Спецификация КАК Спецификация,
	ТЗ_Спецификации.Материал КАК Материал,
	ТЗ_Спецификации.ХарактеристикаМатериала КАК ХарактеристикаМатериала,
	СУММА(ВЫБОР
			КОГДА ЕСТЬNULL(ТЗ_Спецификации.КоличествоПродукции, 0) = 0
				ТОГДА ТЗ_Спецификации.Количество * ТЗ_Продукция.Количество
			ИНАЧЕ ТЗ_Спецификации.Количество * ТЗ_Продукция.Количество / ТЗ_Спецификации.КоличествоПродукции
		КОНЕЦ) КАК КоличествоМатериала
ПОМЕСТИТЬ ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть
ИЗ
	ТЗ_Продукция КАК ТЗ_Продукция
		ЛЕВОЕ СОЕДИНЕНИЕ ТЗ_Спецификации КАК ТЗ_Спецификации
		ПО ТЗ_Продукция.Спецификация = ТЗ_Спецификации.Ссылка
			И ТЗ_Продукция.Номенклатура = ТЗ_Спецификации.Продукция
			И ТЗ_Продукция.Характеристика = ТЗ_Спецификации.ХарактеристикаПродукции

СГРУППИРОВАТЬ ПО
	ТЗ_Продукция.Ссылка,
	ТЗ_Продукция.Номенклатура,
	ТЗ_Продукция.Характеристика,
	ТЗ_Продукция.Спецификация,
	ТЗ_Спецификации.Материал,
	ТЗ_Спецификации.ХарактеристикаМатериала

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Номенклатура,
	Характеристика,
	Материал,
	ХарактеристикаМатериала,
	Спецификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Ссылка КАК Ссылка,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Материал КАК Материал,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.ХарактеристикаМатериала КАК ХарактеристикаМатериала,
	СУММА(ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.КоличествоМатериала) КАК КоличествоМатериала
ПОМЕСТИТЬ ТЗ_Материалов_для_Заказа_должно_быть_всего
ИЗ
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть КАК ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть

СГРУППИРОВАТЬ ПО
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Ссылка,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Материал,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.ХарактеристикаМатериала

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Материал,
	ХарактеристикаМатериала
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Ссылка КАК Ссылка,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Номенклатура КАК Номенклатура,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Характеристика КАК Характеристика,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Количество КАК Количество,
	ТЗ_Материалов_для_Заказа_должно_быть_всего.Материал КАК Материал,
	ТЗ_Материалов_для_Заказа_должно_быть_всего.ХарактеристикаМатериала КАК ХарактеристикаМатериала,
	ВЫБОР
		КОГДА ЕСТЬNULL(ТЗ_Материалов_для_Заказа_должно_быть_всего.КоличествоМатериала, 0) = 0
			ТОГДА 0
		ИНАЧЕ ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.КоличествоМатериала / ТЗ_Материалов_для_Заказа_должно_быть_всего.КоличествоМатериала
	КОНЕЦ КАК КоэффициентДляМатериала,
	ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Спецификация КАК Спецификация
ПОМЕСТИТЬ ПропорцииМатериаловВЗаказе
ИЗ
	ТЗ_Материалов_для_Заказа_должно_быть_всего КАК ТЗ_Материалов_для_Заказа_должно_быть_всего
		ЛЕВОЕ СОЕДИНЕНИЕ ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть КАК ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть
		ПО ТЗ_Материалов_для_Заказа_должно_быть_всего.Ссылка = ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Ссылка
			И ТЗ_Материалов_для_Заказа_должно_быть_всего.Материал = ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.Материал
			И ТЗ_Материалов_для_Заказа_должно_быть_всего.ХарактеристикаМатериала = ТЗ_Продукция_и_Материалы_Для_Заказа_должно_быть.ХарактеристикаМатериала

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	Номенклатура,
	Характеристика,
	Материал,
	ХарактеристикаМатериала,
	Спецификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ТЗ_Материалы.Ссылка КАК Ссылка,
	ТЗ_Материалы.ЗаказПокупателя КАК ЗаказПокупателя,
	ТЗ_Материалы.СтруктурнаяЕдиницаРезерв КАК СтруктурнаяЕдиницаРезерв,
	ПропорцииМатериаловВЗаказе.Номенклатура КАК Номенклатура,
	ПропорцииМатериаловВЗаказе.Характеристика КАК Характеристика,
	ПропорцииМатериаловВЗаказе.Количество КАК Количество,
	ТЗ_Материалы.Материал КАК Материал,
	ТЗ_Материалы.ХарактеристикаМатериала КАК ХарактеристикаМатериала,
	ТЗ_Материалы.КоличествоМатериала * ЕСТЬNULL(ПропорцииМатериаловВЗаказе.КоэффициентДляМатериала,1) КАК КоличествоМатериала,
	ЕСТЬNULL(ПропорцииМатериаловВЗаказе.КоэффициентДляМатериала,1) КАК КоэффициентДляМатериала,
	ПропорцииМатериаловВЗаказе.Спецификация КАК Спецификация
ПОМЕСТИТЬ РаспределениеМатериаловВЗаказеПоСпецификациям
ИЗ
	ТЗ_Материалы КАК ТЗ_Материалы
		ЛЕВОЕ СОЕДИНЕНИЕ ПропорцииМатериаловВЗаказе КАК ПропорцииМатериаловВЗаказе
		ПО ТЗ_Материалы.Ссылка = ПропорцииМатериаловВЗаказе.Ссылка
			И ТЗ_Материалы.Материал = ПропорцииМатериаловВЗаказе.Материал
			И ТЗ_Материалы.ХарактеристикаМатериала = ПропорцииМатериаловВЗаказе.ХарактеристикаМатериала

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	ЗаказПокупателя,
	СтруктурнаяЕдиницаРезерв,
	Номенклатура,
	Характеристика,
	Материал,
	ХарактеристикаМатериала,
	Спецификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РаспределениеМатериаловВЗаказеПоСпецификациям.Ссылка КАК Ссылка,
	РаспределениеМатериаловВЗаказеПоСпецификациям.ЗаказПокупателя КАК ЗаказПокупателя,
	РаспределениеМатериаловВЗаказеПоСпецификациям.СтруктурнаяЕдиницаРезерв КАК СтруктурнаяЕдиницаРезерв,
	РаспределениеМатериаловВЗаказеПоСпецификациям.Номенклатура КАК Номенклатура,
	РаспределениеМатериаловВЗаказеПоСпецификациям.Характеристика КАК Характеристика,
	РаспределениеМатериаловВЗаказеПоСпецификациям.Количество КАК Количество,
	РаспределениеМатериаловВЗаказеПоСпецификациям.Материал КАК Материал,
	РаспределениеМатериаловВЗаказеПоСпецификациям.ХарактеристикаМатериала КАК ХарактеристикаМатериала,
	РаспределениеМатериаловВЗаказеПоСпецификациям.КоличествоМатериала КАК КоличествоМатериала,
	РаспределениеМатериаловВЗаказеПоСпецификациям.КоэффициентДляМатериала КАК КоэффициентДляМатериала,
	РаспределениеМатериаловВЗаказеПоСпецификациям.Спецификация КАК Спецификация
ПОМЕСТИТЬ Материалы_В_Заказах
ИЗ
	РаспределениеМатериаловВЗаказеПоСпецификациям КАК РаспределениеМатериаловВЗаказеПоСпецификациям

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	ТЗ_Материалы.Ссылка,
	ТЗ_Материалы.ЗаказПокупателя,
	ТЗ_Материалы.СтруктурнаяЕдиницаРезерв,
	НЕОПРЕДЕЛЕНО,
	НЕОПРЕДЕЛЕНО,
	0,
	ТЗ_Материалы.Материал,
	ТЗ_Материалы.ХарактеристикаМатериала,
	ТЗ_Материалы.КоличествоМатериала,
	1,
	НЕОПРЕДЕЛЕНО
ИЗ
	ТЗ_Материалы КАК ТЗ_Материалы
ГДЕ
	НЕ (ТЗ_Материалы.Материал, ТЗ_Материалы.ХарактеристикаМатериала) В
				(ВЫБРАТЬ
					РаспределениеМатериаловВЗаказеПоСпецификациям.Материал,
					РаспределениеМатериаловВЗаказеПоСпецификациям.ХарактеристикаМатериала КАК ХарактеристикаМатериала
				ИЗ
					РаспределениеМатериаловВЗаказеПоСпецификациям)

ИНДЕКСИРОВАТЬ ПО
	Ссылка,
	ЗаказПокупателя,
	СтруктурнаяЕдиницаРезерв,
	Номенклатура,
	Характеристика,
	Материал,
	ХарактеристикаМатериала,
	Спецификация
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Материалы_В_Заказах.Ссылка КАК ЗаказНаПроизводство,
	Материалы_В_Заказах.ЗаказПокупателя КАК ЗаказПокупателя,
	Материалы_В_Заказах.СтруктурнаяЕдиницаРезерв КАК СтруктурнаяЕдиницаРезерв,
	Материалы_В_Заказах.Номенклатура КАК Номенклатура,
	Материалы_В_Заказах.Характеристика КАК Характеристика,
	Материалы_В_Заказах.Количество КАК Количество,
	Материалы_В_Заказах.Материал КАК Материалы,
	Материалы_В_Заказах.ХарактеристикаМатериала КАК ХарактеристикаМатериала,
	Материалы_В_Заказах.КоличествоМатериала КАК КоличествоМатериала,
	Материалы_В_Заказах.Спецификация КАК Спецификация,
	Материалы_В_Заказах.КоэффициентДляМатериала КАК КоэффициентДляМатериала,
	ЕСТЬNULL(ПотребностьВЗапасахОстаткиИОбороты.КоличествоНачальныйОстаток, 0) * Материалы_В_Заказах.КоэффициентДляМатериала КАК МатериалыНачальныйОстаток,
	ЕСТЬNULL(ПотребностьВЗапасахОстаткиИОбороты.КоличествоОборот, 0) * Материалы_В_Заказах.КоэффициентДляМатериала КАК МатериалыОборот,
	ЕСТЬNULL(ПотребностьВЗапасахОстаткиИОбороты.КоличествоПриход, 0) * Материалы_В_Заказах.КоэффициентДляМатериала КАК МатериалыПриход,
	ЕСТЬNULL(ПотребностьВЗапасахОстаткиИОбороты.КоличествоРасход, 0) * Материалы_В_Заказах.КоэффициентДляМатериала КАК МатериалыРасход,
	ЕСТЬNULL(ПотребностьВЗапасахОстаткиИОбороты.КоличествоКонечныйОстаток, 0) * Материалы_В_Заказах.КоэффициентДляМатериала КАК МатериалыКонечныйОстаток,
	ЕСТЬNULL(ЗапасыОстаткиРезерв.КоличествоОстаток, 0) * Материалы_В_Заказах.КоэффициентДляМатериала КАК МатериалыРезерв,
	ЕСТЬNULL(ЗапасыОстаткиСвободныеОстатки.КоличествоОстаток, 0) КАК МетериалыСвободныеОстатки
ПОМЕСТИТЬ ОстаткиМатериаловПред
ИЗ
	Материалы_В_Заказах КАК Материалы_В_Заказах
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПотребностьВЗапасах.ОстаткиИОбороты(, , , , ) КАК ПотребностьВЗапасахОстаткиИОбороты
		ПО Материалы_В_Заказах.ЗаказПокупателя = ПотребностьВЗапасахОстаткиИОбороты.ЗаказПокупателя
			И Материалы_В_Заказах.Материал = ПотребностьВЗапасахОстаткиИОбороты.Номенклатура
			И Материалы_В_Заказах.ХарактеристикаМатериала = ПотребностьВЗапасахОстаткиИОбороты.Характеристика
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(, ) КАК ЗапасыОстаткиРезерв
		ПО Материалы_В_Заказах.ЗаказПокупателя = ЗапасыОстаткиРезерв.ЗаказПокупателя
			И Материалы_В_Заказах.Материал = ЗапасыОстаткиРезерв.Номенклатура
			И Материалы_В_Заказах.ХарактеристикаМатериала = ЗапасыОстаткиРезерв.Характеристика
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(, ) КАК ЗапасыОстаткиСвободныеОстатки
		ПО (ЗапасыОстаткиСвободныеОстатки.ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка))
			И Материалы_В_Заказах.СтруктурнаяЕдиницаРезерв = ЗапасыОстаткиСвободныеОстатки.СтруктурнаяЕдиница
			И Материалы_В_Заказах.Материал = ЗапасыОстаткиСвободныеОстатки.Номенклатура
			И Материалы_В_Заказах.ХарактеристикаМатериала = ЗапасыОстаткиСвободныеОстатки.Характеристика

ИНДЕКСИРОВАТЬ ПО
	ЗаказНаПроизводство,
	ЗаказПокупателя,
	Номенклатура,
	Характеристика,
	Материалы,
	ХарактеристикаМатериала
;

