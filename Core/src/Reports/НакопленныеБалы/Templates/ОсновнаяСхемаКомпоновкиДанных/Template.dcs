		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Т.КартаЛояльности КАК КартаЛояльности,
	Т.КоличествоОборот КАК Балы,
	Т.СуммаОборот КАК Сумма,
	Т.КоличествоОборот * Т.КартаЛояльности.Владелец.КоэфициентПересчета КАК БаллыВДеньгах_Оборот,
	Т.Контрагент КАК Контрагент,
	Т.Регистратор КАК Регистратор,
	РасходнаяНакладная.Ссылка КАК Регистратор_РасходнаяНакладная,
	Т.ПериодДень КАК ПериодДень,
	Т.ПериодНеделя КАК ПериодНеделя,
	Т.ПериодМесяц КАК ПериодМесяц,
	Т.КоличествоНачальныйОстаток КАК БалыНачальныйОстаток,
	Т.КоличествоКонечныйОстаток КАК БалыКонечныйОстаток,
	Т.КоличествоНачальныйОстаток * Т.КартаЛояльности.Владелец.КоэфициентПересчета КАК БаллыВДеньгах_НачОстаток,
	Т.КоличествоКонечныйОстаток * Т.КартаЛояльности.Владелец.КоэфициентПересчета КАК БаллыВДеньгах_КонОстаток,
	Т.КоличествоПриход КАК БалыПриход,
	Т.КоличествоРасход КАК БалыРасход,
	Т.КоличествоПриход * Т.КартаЛояльности.Владелец.КоэфициентПересчета КАК БаллыВДеньгах_Приход,
	Т.КоличествоРасход * Т.КартаЛояльности.Владелец.КоэфициентПересчета КАК БаллыВДеньгах_Расход,
	Т.СуммаНачальныйОстаток КАК СуммаНачальныйОстаток,
	Т.СуммаКонечныйОстаток КАК СуммаКонечныйОстаток,
	Т.СуммаПриход КАК СуммаПриход,
	Т.СуммаРасход КАК СуммаРасход,
	Т.ПериодКвартал КАК ПериодКвартал,
	Т.ПериодГод КАК ПериодГод,
	Т.Договор КАК Договор
ИЗ
	РегистрНакопления.БалыЛояльности.ОстаткиИОбороты(, , Авто, , ) КАК Т
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходнаяНакладная КАК РасходнаяНакладная
		ПО Т.Регистратор = РасходнаяНакладная.Ссылка</query>
	</dataSet>
	<totalField>
		<dataPath>Балы</dataPath>
