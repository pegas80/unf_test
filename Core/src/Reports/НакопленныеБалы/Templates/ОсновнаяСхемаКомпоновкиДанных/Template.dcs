	</totalField>
	<totalField>
		<dataPath>БаллыВДеньгах_Расход</dataPath>
		<expression>Сумма(БаллыВДеньгах_Расход)</expression>
	</totalField>
	<totalField>
		<dataPath>БаллыВДеньгах_Оборот</dataPath>
		<expression>Сумма(БаллыВДеньгах_Оборот)</expression>
	</totalField>
	<parameter>
		<name>НачалоПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Начало периода</v8:content>
			</v8:item>
		</title>
		<valueType>
