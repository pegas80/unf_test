		<field xsi:type="DataSetFieldField">
			<dataPath>Процент</dataPath>
			<field>Процент</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Склад</dataPath>
			<field>Склад</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Склад</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>საწყობი</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Warehouse</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СкладВозврата</dataPath>
			<field>СкладВозврата</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Склад возврата</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>ka</v8:lang>
					<v8:content>დაბრუნების საწყობი</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>return warehouse</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Ячейка</dataPath>
			<field>Ячейка</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СчетУчетаРегл</dataPath>
			<field>СчетУчетаРегл</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СчетУчетаЗатратРегл</dataPath>
			<field>СчетУчетаЗатратРегл</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Проект</dataPath>
			<field>Проект</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
	ДоговорыКонтрагентов.Владелец КАК Владелец,
	ДоговорыКонтрагентов.ВидЦен КАК ВидЦен,
	ДоговорыКонтрагентов.ТорговыйПредставитель КАК ТорговыйПредставитель
ПОМЕСТИТЬ врДоговоры
ИЗ
	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	врДоговоры.Владелец КАК Владелец
ПОМЕСТИТЬ врКонтрагенти
ИЗ
	врДоговоры КАК врДоговоры

СГРУППИРОВАТЬ ПО
	врДоговоры.Владелец
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	врДоговоры.ВидЦен КАК ВидЦен
ПОМЕСТИТЬ врВыдиЦен
ИЗ
	врДоговоры КАК врДоговоры

СГРУППИРОВАТЬ ПО
	врДоговоры.ВидЦен
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Номенклатуры.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА Номенклатуры.ЭтоГруппа
			ТОГДА 1
		ИНАЧЕ 2
	КОНЕЦ КАК врЭтоГруппа,
	Номенклатуры.Ссылка КАК Номенклатура
ПОМЕСТИТЬ врНоменклатури
ИЗ
	Справочник.Номенклатура КАК Номенклатуры
ГДЕ
	НЕ Номенклатуры.ПометкаУдаления
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗапасыОстатки.Номенклатура КАК Номенклатура,
	ЗапасыОстатки.КоличествоОстаток КАК КоличествоОстаток,
	ЗапасыОстатки.Характеристика КАК Характеристика
ПОМЕСТИТЬ врОстатки
ИЗ
	РегистрНакопления.Запасы.Остатки(
			&amp;ТекДата,
			ЗаказПокупателя = ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяСсылка)
				И Номенклатура В ИЕРАРХИИ
					(ВЫБРАТЬ
						врНоменклатури.Ссылка
					ИЗ
						врНоменклатури КАК врНоменклатури)) КАК ЗапасыОстатки
{ГДЕ
	ЗапасыОстатки.СтруктурнаяЕдиница КАК Склад}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗапасыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	ЗапасыНаСкладахОстатки.КоличествоОстаток КАК Количество,
	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
	ЗапасыНаСкладахОстатки.Характеристика КАК Характеристика
ПОМЕСТИТЬ врОстаткиВозвратов
ИЗ
	РегистрНакопления.ЗапасыНаСкладах.Остатки(, ) КАК ЗапасыНаСкладахОстатки
{ГДЕ
	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница КАК СкладВозврата}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	РасчетыСПокупателямиОстатки.Контрагент КАК Контрагент,
	ВЫБОР
		КОГДА НЕ РасчетыСПокупателямиОстатки.Документ ЕСТЬ NULL
			ТОГДА РасчетыСПокупателямиОстатки.Документ.Дата
		ИНАЧЕ ""
	КОНЕЦ КАК Дата,
	РасчетыСПокупателямиОстатки.СуммаОстаток КАК Сумма,
	ВЫБОР
		КОГДА НЕ РасчетыСПокупателямиОстатки.Документ ЕСТЬ NULL
			ТОГДА РасчетыСПокупателямиОстатки.Документ.Номер
		ИНАЧЕ ""
	КОНЕЦ КАК Номер,
	РасчетыСПокупателямиОстатки.Договор КАК Договор
ПОМЕСТИТЬ врВзаиморасчети
ИЗ
	врДоговоры КАК врДоговоры
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСПокупателями.Остатки(, ) КАК РасчетыСПокупателямиОстатки
		ПО врДоговоры.Ссылка = РасчетыСПокупателямиОстатки.Договор
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЦеныНоменклатурыСрезПоследних.Период КАК Период,
	ЦеныНоменклатурыСрезПоследних.ВидЦен КАК ВидЦен,
	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	ЦеныНоменклатурыСрезПоследних.Актуальность КАК Актуальность,
	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	ЦеныНоменклатурыСрезПоследних.Автор КАК Автор
ПОМЕСТИТЬ врЦены
ИЗ
	врВыдиЦен КАК врВыдиЦен
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
				,
				Номенклатура В ИЕРАРХИИ
					(ВЫБРАТЬ
						врНоменклатури.Ссылка
					ИЗ
						врНоменклатури КАК врНоменклатури)) КАК ЦеныНоменклатурыСрезПоследних
		ПО врВыдиЦен.ВидЦен = ЦеныНоменклатурыСрезПоследних.ВидЦен
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВидыСкидокНаценок.Наименование КАК Наименование,
	ВидыСкидокНаценок.Процент КАК Процент,
	ВидыСкидокНаценок.Ссылка КАК Ссылка
ПОМЕСТИТЬ врВидыСкидокНаценок
ИЗ
	Справочник.ВидыСкидокНаценок КАК ВидыСкидокНаценок
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	врДоговоры.Ссылка КАК Ссылка,
	NULL КАК КоличествоОстаток,
	NULL КАК Дата,
	NULL КАК Сумма,
	NULL КАК Номер,
	NULL КАК Договор,
	NULL КАК Период,
	NULL КАК Номенклатура,
	NULL КАК Характеристика,
	NULL КАК Цена,
	NULL КАК Актуальность,
	NULL КАК ЕдиницаИзмерения,
	NULL КАК Автор,
	"Договоры" КАК ВидДанных,
	врДоговоры.ТорговыйПредставитель КАК ТорговыйПредставитель,
	4 КАК ПолеСортировки,
	NULL КАК ВидЦен,
	0 КАК врЭтоГруппа,
	NULL КАК Контрагент,
	NULL КАК Процент
ИЗ
	врДоговоры КАК врДоговоры

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	врКонтрагенти.Владелец,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"_Контрагенты",
	NULL,
	3,
	NULL,
	0,
	NULL,
	NULL
ИЗ
	врКонтрагенти КАК врКонтрагенти

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	врВыдиЦен.ВидЦен,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"ВидыЦен",
	NULL,
	2,
	NULL,
	0,
	NULL,
	NULL
ИЗ
	врВыдиЦен КАК врВыдиЦен

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	врНоменклатури.Ссылка,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	врНоменклатури.Номенклатура,
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	"Номенклатура",
	NULL,
	1,
	NULL,
	врНоменклатури.врЭтоГруппа,
	NULL,
	NULL
ИЗ
	врНоменклатури КАК врНоменклатури
ГДЕ
	ВЫБОР
			КОГДА &amp;ВыгружатьТолькоОстатки
				ТОГДА врНоменклатури.Номенклатура В
							(ВЫБРАТЬ
								ВрОстатки.Номенклатура
							ИЗ
								ВрОстатки)
						ИЛИ врНоменклатури.Номенклатура В
							(ВЫБРАТЬ
								ВрОстаткиВозвратов.Номенклатура
							ИЗ
								ВрОстаткиВозвратов)
			ИНАЧЕ ИСТИНА
		КОНЕЦ

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"Остатки",
	СУММА(врОстатки.КоличествоОстаток),
	NULL,
	NULL,
	NULL,
	NULL,
	NULL,
	врОстатки.Номенклатура,
	врОстатки.Характеристика,
	NULL,
	NULL,
	NULL,
	NULL,
	"Остатки",
	NULL,
	6,
	NULL,
	0,
	NULL,
	NULL
ИЗ
	врОстатки КАК врОстатки

СГРУППИРОВАТЬ ПО
	врОстатки.Номенклатура,
	врОстатки.Характеристика

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"Взаиморасчети",
	NULL,
	врВзаиморасчети.Дата,
