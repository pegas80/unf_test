		<field xsi:type="DataSetFieldField">
			<dataPath>ВидЦен</dataPath>
			<field>ВидЦен</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>врЭтоГруппа</dataPath>
			<field>врЭтоГруппа</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
