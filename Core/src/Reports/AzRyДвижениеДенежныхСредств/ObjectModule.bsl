#Область ПрограммныйИнтерфейс

Процедура ПриОпределенииНастроекОтчета(НастройкиОтчета, НастройкиВариантов) Экспорт
	
	НастройкиОтчета.ПоказыватьГруппуСтрокиНаФормеОтчета = Ложь;
	НастройкиОтчета.ПоказыватьНастройкиДиаграммыНаФормеОтчета = Ложь;
	
	ЗаполнитьПредопределенныеВариантыОформления(НастройкиВариантов);
	УстановитьТегиВариантов(НастройкиВариантов);
	ДобавитьОписанияСвязанныхПолей(НастройкиВариантов);
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытий

Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ДокументРезультат.Очистить();
	
	// ─── 1. პერიოდი ПользовательскиеНастройки-დან ───────────────────────────
	// UNF ინახავს СтандартныйПериод-ს ПользовательскиеНастройки-ში.
	НачалоПериода = Дата(1, 1, 1);
	КонецПериода  = Дата(1, 1, 1);
	Для н = 0 По КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Количество() - 1 Цикл
		Если ТипЗнч(КомпоновщикНастроек.ПользовательскиеНастройки.Элементы[н].Значение) = Тип("СтандартныйПериод") Тогда
			НачалоПериода = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы[н].Значение.ДатаНачала;
			КонецПериода  = КомпоновщикНастроек.ПользовательскиеНастройки.Элементы[н].Значение.ДатаОкончания;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если НачалоПериода = Дата(1, 1, 1) Тогда
		Возврат; // პერიოდი ვერ ვიპოვეთ
	КонецЕсли;
	
	// ვიღებთ ორგანიზაციების სიას პერიოდის მიხედვით
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДенежныеСредства.Организация КАК Организация
	|ИЗ
	|	РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
	|ГДЕ
	|	ДенежныеСредства.Период >= &НачалоПериода
	|	И ДенежныеСредства.Период <= &КонецПериода
	|УПОРЯДОЧИТЬ ПО
	|	Организация";
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода",  КонецПериода);
	
	Организации = Запрос.Выполнить().Выбрать();
	
	// ჯერ ყველა ბლოკი მასივში ვაგროვებთ
	МассивБлоков = Новый Массив;
	
	Пока Организации.Следующий() Цикл
		
		БлокОрг = Новый ТабличныйДокумент;
		
		НастройкиКопия = КомпоновщикНастроек.ПолучитьНастройки();
		
		ЭлементОтбора = НастройкиКопия.Отбор.Элементы.Добавить(
			Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Организация");
		ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Организации.Организация;
		ЭлементОтбора.Использование  = Истина;
		
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновки = КомпоновщикМакета.Выполнить(
			СхемаКомпоновкиДанных,
			НастройкиКопия,
			ДанныеРасшифровки
		);
		
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки);
		
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
		ПроцессорВывода.УстановитьДокумент(БлокОрг);
		ПроцессорВывода.Вывести(ПроцессорКомпоновки);
		
		МассивБлоков.Добавить(БлокОрг);
		
	КонецЦикла;
	
	Если МассивБлоков.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// ვპოულობთ მაქსიმალურ სიმაღლეს
	МаксВысота = 0;
	Для каждого Блок Из МассивБлоков Цикл
		МаксВысота = Макс(МаксВысота, Блок.ВысотаТаблицы);
	КонецЦикла;

	// ყველა ბლოკს ერთნაირ სიმაღლეზე ვიყვანთ
	// На сервере доступны только Вывести + ПолучитьОбласть.
	// ვინახავთ ორიგინალ სიმაღლეებს padding-ამდე
	МассивВысот = Новый Массив;
	Для каждого Блок Из МассивБлоков Цикл
		МассивВысот.Добавить(Блок.ВысотаТаблицы);
	КонецЦикла;

	ДокПустой = Новый ТабличныйДокумент;
	ОблПустая = ДокПустой.ПолучитьОбласть(1, 1, 1, 1);

	Для каждого Блок Из МассивБлоков Цикл
		Для й = 1 По МаксВысота - Блок.ВысотаТаблицы Цикл
			Блок.Вывести(ОблПустая);
		КонецЦикла;
	КонецЦикла;

	// სეპარატორის შაბლონი — padding-ის შემდეგ ვიწრო ბლოკის ბოლო სტრიქონის
	// ბოლო სვეტი: Вывести მხოლოდ 1-ლ სვეტს ავსებს, ბოლო სვეტი ცარიელია
	// მაგრამ SKD-ის ვიწრო სვეტის სიგანეს ინახავს — .Текст საჭირო არ არის.
	ШирБлока  = МассивБлоков[0].ШиринаТаблицы;
	ОблДляСеп = ОблПустая; // fallback — ყველა ბლოკი ერთ სიმაღლეზე

	Для н = 0 По МассивБлоков.Количество() - 1 Цикл
		Если МассивВысот[н] < МаксВысота Тогда
			// ეს ბლოკი პატარა იყო — padding სტრიქონების ბოლო სვეტი ცარიელი + ვიწრო
			ОблДляСеп = МассивБлоков[н].ПолучитьОбласть(МаксВысота, ШирБлока, МаксВысота, ШирБлока);
			Прервать;
		КонецЕсли;
	КонецЦикла;

	// ვაერთებთ ჰორიზონტალურად
	ПервыйБлок = Истина;

	Для каждого Блок Из МассивБлоков Цикл

		Если ПервыйБлок Тогда
			ДокументРезультат.Присоединить(Блок);
			ПервыйБлок = Ложь;
		Иначе
			Разделитель = Новый ТабличныйДокумент;
			Для й = 1 По МаксВысота Цикл
				Разделитель.Вывести(ОблДляСеп);
			КонецЦикла;
			ДокументРезультат.Присоединить(Разделитель, , Истина);
			ДокументРезультат.Присоединить(Блок, , Истина);
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьПредопределенныеВариантыОформления(НастройкиВариантов)
	
	МассивПолейСумм = Новый Массив;
	Для каждого ДоступноеПоле Из КомпоновщикНастроек.Настройки.ДоступныеПоляВыбора.Элементы Цикл
		Если НЕ ДоступноеПоле.Ресурс Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоля = Строка(ДоступноеПоле.Поле);
		МассивПолейСумм.Добавить(ИмяПоля);
	КонецЦикла; 
	
	Для каждого НастройкиТекВарианта Из НастройкиВариантов Цикл
		
		ВариантыОформления = НастройкиТекВарианта.Значение.ВариантыОформления;
		ОтчетыУНФ.ДобавитьВариантыОформленияСумм(ВариантыОформления, МассивПолейСумм);
			
	КонецЦикла; 
	
КонецПроцедуры

Процедура УстановитьТегиВариантов(НастройкиВариантов)
	
	НастройкиВариантов["Основной"].Теги = НСТР("ka='ფული';ru='Деньги';en='Money'");
	
КонецПроцедуры

Процедура ДобавитьОписанияСвязанныхПолей(НастройкиВариантов)
	
	ОтчетыУНФ.ДобавитьОписаниеПривязки(НастройкиВариантов["Основной"].СвязанныеПоля, "БанковскийСчетКасса", "Справочник.Кассы");
	ОтчетыУНФ.ДобавитьОписаниеПривязки(НастройкиВариантов["Основной"].СвязанныеПоля, "БанковскийСчетКасса", "Справочник.БанковскиеСчета");
	
КонецПроцедуры
 
#КонецОбласти 

ЭтоОтчетУНФ = Истина;

#КонецЕсли
