#Область ПрограммныйИнтерфейс

Процедура ПриОпределенииНастроекОтчета(НастройкиОтчета, НастройкиВариантов) Экспорт
	
	НастройкиВариантов["РасчетНалогаНаИмущество"].Рекомендуемый = Истина;
	
	ЗаполнитьПредопределенныеВариантыОформления(НастройкиВариантов);
	УстановитьТегиВариантов(НастройкиВариантов);
	ДобавитьОписанияСвязанныхПолей(НастройкиВариантов);
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиСобытий

Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	//ОтчетыУНФ.ПриКомпоновкеРезультата(КомпоновщикНастроек, СхемаКомпоновкиДанных, ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка);
	
	СтандартнаяОбработка = Ложь;
	ОбновитьОтчет(ДокументРезультат, ДанныеРасшифровки);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьПредопределенныеВариантыОформления(НастройкиВариантов)
	
	МассивПолейСумм = Новый Массив;
	Для каждого ДоступноеПоле Из КомпоновщикНастроек.Настройки.ДоступныеПоляВыбора.Элементы Цикл
		Если НЕ ДоступноеПоле.Ресурс Тогда
			Продолжить;
		КонецЕсли;
		ИмяПоля = Строка(ДоступноеПоле.Поле);
		МассивПолейСумм.Добавить(ИмяПоля);
	КонецЦикла; 
	
	Для каждого НастройкиТекВарианта Из НастройкиВариантов Цикл
		
		ВариантыОформления = НастройкиТекВарианта.Значение.ВариантыОформления;
		ОтчетыУНФ.ДобавитьВариантыОформленияСумм(ВариантыОформления, МассивПолейСумм);
			
	КонецЦикла; 
	
КонецПроцедуры

Процедура УстановитьТегиВариантов(НастройкиВариантов)
	
	НастройкиВариантов["РасчетНалогаНаИмущество"].Теги = НСТР("ka='Компания,Внеоборотный актив,Основное средство,Имущество,Амортизация';ru='Компания,Внеоборотный актив,Основное средство,Имущество,Амортизация';en='The company, non-current assets Fixed assets Property, Depreciation'");
	
КонецПроцедуры

Процедура ДобавитьОписанияСвязанныхПолей(НастройкиВариантов)
	
	ОтчетыУНФ.ДобавитьОписаниеПривязки(НастройкиВариантов["РасчетНалогаНаИмущество"].СвязанныеПоля, "ВнеоборотныйАктив", "Справочник.ВнеоборотныеАктивы");
	
КонецПроцедуры

Функция ОбновитьОтчет(ДокументРезультат, ДанныеРасшифровки) 
	
	ДокументРезультат.Очистить();
			
	Схема = ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	
	НастройкиКомпоновкиДанных = КомпоновщикНастроек.ПолучитьНастройки();
	
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	//Сгенерируем макет компоновки данных при помощи компоновщика макета
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		
	//Paganini(LTB)_{
	пПараметры = НастройкиКомпоновкиДанных.ПараметрыДанных.Элементы;
	//ПараметрХарактеристика = пПараметры.Найти("Характеристика");
	//Если НЕ пПараметры.Найти("Характеристика").Использование Тогда
	//	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос 	= СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос, "ЕСТЬNULL(ВТ_Статусы.ЕстьСтатусХарактеристики, ЛОЖЬ)",							"ИСТИНА");
	//	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос  	= СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос,	"ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Статусы КАК ВТ_Статусы",									"");
	//	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос  	= СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос,	"ПО ТоварыОрганизацийОстаткиИОбороты.Номенклатура = ВТ_Статусы.Номенклатура",	"");
	//	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос  	= СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос, "И ИСТИНА",																		"");
	//КонецЕсли;
	Год1 = пПараметры.Найти("Год1").Значение;
	Год2 = пПараметры.Найти("Год2").Значение;
	
	НачалоГода1 = "ДАТАВРЕМЯ("+Формат(Год1, "ЧГ=0") + ", 1, 1)";
	КонецГода1  = "ДАТАВРЕМЯ("+Формат(Год1, "ЧГ=0") + ", 12, 31, 23, 59, 59)";
	
	НачалоГода2 = "ДАТАВРЕМЯ("+Формат(Год2, "ЧГ=0") + ", 1, 1)";
	КонецГода2  = "ДАТАВРЕМЯ("+Формат(Год2, "ЧГ=0") + ", 12, 31, 23, 59, 59)";
	//}_Paganini(LTB)


	//В качестве схемы компоновки будет выступать схема самого отчета
	//В качестве настроек отчета - текущие настройки отчета
	//Данные расшифровки будем помещать в ДанныеРасшифровки
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, НастройкиКомпоновкиДанных, ДанныеРасшифровки);
	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос = СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос,"РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты(&П, &П2, МЕСЯЦ",
																													"РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты("+НачалоГода1+"," +КонецГода1+", ГОД");
	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос = СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос,"РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты(&П, &П2, ГОД",
																													"РегистрНакопления.ВнеоборотныеАктивы.ОстаткиИОбороты("+НачалоГода2+"," +КонецГода2+", ГОД");
	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос = СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос,"ПараметрыВнеоборотныхАктивов.Период <= ДАТАВРЕМЯ(1, 1, 1)",	
																													"ПараметрыВнеоборотныхАктивов.Период <= " + КонецГода2);
	МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос = СтрЗаменить(МакетКомпоновки.НаборыДанных.НаборДанных1.Запрос,"ДАТАВРЕМЯ(2222, 2, 2)",	КонецГода2);
	
	//Создадим и инициализируем процессор компоновки
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, , ДанныеРасшифровки, Истина);//პარამეტრი 2: Новый Структура("ОборотыПродаж", ТаблицаОборотыПродаж)
	
	//Создадим и инициализируем процессор вывода результата
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ДокументРезультат);
	
	
	//Обозначим начало вывода
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
		
КонецФункции

#КонецОбласти 


ЭтоОтчетУНФ = Истина;

#КонецЕсли


