
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Если Параметры.Свойство("Получатель") Тогда
		Запись.СтатусНапоминания = Параметры.СтатусНапоминания;
		Запись.Получатель = Параметры.Получатель;
		Запись.Отправитель = Параметры.Отправитель;
		Запись.Источник = Параметры.Источник;
		Возврат;
	КонецЕсли;	       
	
	Если Запись.СтатусНапоминания = Перечисления.AzRyСтатусНапоминания.Finnished Тогда
		ЭтаФорма.КоманднаяПанель.Доступность = РольДоступна("AzRyНапоминанияПользователяАдминистратор");
		Элементы.AzRyОтветственныйЗаСкладСтатусДокумента.ТолькоПросмотр = Не РольДоступна("AzRyНапоминанияПользователяАдминистратор");
		Элементы.Получатель.ТолькоПросмотр = Не РольДоступна("AzRyНапоминанияПользователяАдминистратор");
		Элементы.Отправитель.ТолькоПросмотр = Не РольДоступна("AzRyНапоминанияПользователяАдминистратор");
		Элементы.Источник.ТолькоПросмотр = Не РольДоступна("AzRyНапоминанияПользователяАдминистратор");
		Элементы.Комментарий.ТолькоПросмотр = Не РольДоступна("AzRyНапоминанияПользователяАдминистратор");
	Иначе
		ПравоНаРедактирование = Запись.Получатель = Пользователи.ТекущийПользователь() Или РольДоступна("AzRyНапоминанияПользователяАдминистратор");
		ЭтаФорма.КоманднаяПанель.Доступность = ПравоНаРедактирование;
		Элементы.AzRyОтветственныйЗаСкладСтатусДокумента.ТолькоПросмотр = Не ПравоНаРедактирование;
		Элементы.Получатель.ТолькоПросмотр = Не ПравоНаРедактирование;
		Элементы.Отправитель.ТолькоПросмотр = Не ПравоНаРедактирование;
		Элементы.Источник.ТолькоПросмотр = Не ПравоНаРедактирование;
		Элементы.Комментарий.ТолькоПросмотр = Не ПравоНаРедактирование;		
	КонецЕсли;
		
КонецПроцедуры 

&НаСервереБезКонтекста
Функция ДанныеТаблицыЗначенийВТабличныйДокумент(ДанныеВТабличныйДокумент)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Построитель = Новый ПостроительОтчета;
	Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ДанныеВТабличныйДокумент);       
	Построитель.Вывести(ТабличныйДокумент);
		
	Возврат ТабличныйДокумент;

КонецФункции

&НаКлиенте
Процедура AzRyОтветственныйЗаСкладСтатусДокументаПриИзменении(Элемент)
	
	AzRyОтветственныйЗаСкладСтатусДокументаПриИзмененииНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура AzRyОтветственныйЗаСкладСтатусДокументаПриИзмененииНаСервере()
	
	Если Запись.СтатусНапоминания = Перечисления.AzRyСтатусНапоминания.ПодтверждениеОдобрено Или Запись.СтатусНапоминания = Перечисления.AzRyСтатусНапоминания.ПодтверждениеНеОдобрено Тогда
		
		Запись.Получатель = Параметры.Ключ.Отправитель;
		Запись.Отправитель   = Параметры.Ключ.Получатель;		
		
	КонецЕсли;
				
КонецПроцедуры

&НаКлиенте
Процедура AzRyОтветственныйЗаСкладСтатусДокументаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Запись.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПустаяСсылка") Тогда
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения"));
		
	ИначеЕсли Запись.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения") И ЗначениеЗаполнено(Параметры.Ключ) = Ложь Тогда // ახალის შემთხვევაში
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения"));                                                                         

	ИначеЕсли Запись.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения") И ЗначениеЗаполнено(Параметры.Ключ) = Истина Тогда // არსებულის შემთხვევაში
		ДанныеВыбора = Новый СписокЗначений;
		//ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения"));
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеОдобрено"));
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеНеОдобрено"));		
		
	ИначеЕсли Запись.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеОдобрено") Тогда
		ДанныеВыбора = Новый СписокЗначений;
		//ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеОдобрено"));
		//ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеНеОдобрено"));
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.Finnished"));
		
	ИначеЕсли Запись.СтатусНапоминания = ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеНеОдобрено") Тогда
		ДанныеВыбора = Новый СписокЗначений;                                                                          
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ОжидаетПодтверждения"));
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеОдобрено"));
		ДанныеВыбора.Добавить(ПредопределенноеЗначение("Перечисление.AzRyСтатусНапоминания.ПодтверждениеНеОдобрено"));
		
	КонецЕсли; 	
	
	Если РольДоступнаНаСервере("AzRyНапоминанияПользователяАдминистратор") Тогда
		СтандартнаяОбработка = Истина;		
	КонецЕсли; 
	
КонецПроцедуры

