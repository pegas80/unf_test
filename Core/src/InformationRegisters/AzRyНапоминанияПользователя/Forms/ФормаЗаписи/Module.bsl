&НаСервере
Функция ТекстЗапросаТоварыВДокументе(СсылкаДокумента)

	ТексЗапроса = "";
	
	Если Тип("ДокументСсылка.ПриходнаяНакладная") = ТипЗнч(СсылкаДокумента) Тогда
		
		ТексЗапроса = "ВЫБРАТЬ
		              |	ПриходнаяНакладнаяЗапасы.Номенклатура.Код КАК НоменклатураКод,
		              |	ПриходнаяНакладнаяЗапасы.Номенклатура КАК Номенклатура,
		              |	ПриходнаяНакладнаяЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		              |	ПриходнаяНакладнаяЗапасы.Характеристика КАК Характеристика,
		              |	ПриходнаяНакладнаяЗапасы.Количество КАК Количество,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.Номер КАК Номер,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.Дата КАК Дата,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.Организация КАК Организация,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.Контрагент КАК Контрагент,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.Договор КАК Договор,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		              |	ПриходнаяНакладнаяЗапасы.Ссылка.Ячейка КАК Ячейка
		              |ИЗ
		              |	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
		              |ГДЕ
		              |	ПриходнаяНакладнаяЗапасы.Ссылка = &Ссылка
		              |
		              |ОБЪЕДИНИТЬ ВСЕ
		              |
		              |ВЫБРАТЬ
		              |	ПриходнаяНакладнаяРасходы.Номенклатура.Код,
		              |	ПриходнаяНакладнаяРасходы.Номенклатура,
		              |	ПриходнаяНакладнаяРасходы.ЕдиницаИзмерения,
		              |	NULL,
		              |	ПриходнаяНакладнаяРасходы.Количество,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.Номер,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.Дата,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.Организация,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.Контрагент,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.Договор,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.СтруктурнаяЕдиница,
		              |	ПриходнаяНакладнаяРасходы.Ссылка.Ячейка
		              |ИЗ
		              |	Документ.ПриходнаяНакладная.Расходы КАК ПриходнаяНакладнаяРасходы
		              |ГДЕ
		              |	ПриходнаяНакладнаяРасходы.Ссылка = &Ссылка";
		
	ИначеЕсли Тип("ДокументСсылка.АвансовыйОтчет") = ТипЗнч(СсылкаДокумента) Тогда
		
		ТексЗапроса = "ВЫБРАТЬ
		              |	АвансовыйОтчетЗапасы.Номенклатура.Код КАК НоменклатураКод,
		              |	АвансовыйОтчетЗапасы.Номенклатура КАК Номенклатура,
		              |	АвансовыйОтчетЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		              |	АвансовыйОтчетЗапасы.Характеристика КАК Характеристика,
		              |	АвансовыйОтчетЗапасы.Количество КАК Количество,
		              |	АвансовыйОтчетЗапасы.Ссылка.Номер КАК Номер,
		              |	АвансовыйОтчетЗапасы.Ссылка.Дата КАК Дата,
		              |	АвансовыйОтчетЗапасы.Ссылка.Организация КАК Организация,
		              |	НЕОПРЕДЕЛЕНО КАК Контрагент,
		              |	НЕОПРЕДЕЛЕНО КАК Договор,
		              |	НЕОПРЕДЕЛЕНО КАК СтруктурнаяЕдиница,
		              |	НЕОПРЕДЕЛЕНО КАК Ячейка
		              |ИЗ
		              |	Документ.АвансовыйОтчет.Запасы КАК АвансовыйОтчетЗапасы
		              |ГДЕ
		              |	АвансовыйОтчетЗапасы.Ссылка = &Ссылка
		              |
		              |ОБЪЕДИНИТЬ ВСЕ
		              |
		              |ВЫБРАТЬ
		              |	АвансовыйОтчетРасходы.Номенклатура.Код,
		              |	АвансовыйОтчетРасходы.Номенклатура,
		              |	АвансовыйОтчетРасходы.ЕдиницаИзмерения,
		              |	NULL,
		              |	АвансовыйОтчетРасходы.Количество,
		              |	АвансовыйОтчетРасходы.Ссылка.Номер,
		              |	АвансовыйОтчетРасходы.Ссылка.Дата,
		              |	АвансовыйОтчетРасходы.Ссылка.Организация,
		              |	НЕОПРЕДЕЛЕНО,
		              |	НЕОПРЕДЕЛЕНО,
		              |	НЕОПРЕДЕЛЕНО,
		              |	НЕОПРЕДЕЛЕНО
		              |ИЗ
		              |	Документ.АвансовыйОтчет.Расходы КАК АвансовыйОтчетРасходы
		              |ГДЕ
		              |	АвансовыйОтчетРасходы.Ссылка = &Ссылка";		
		
	ИначеЕсли Тип("ДокументСсылка.ЗаказПокупателя") = ТипЗнч(СсылкаДокумента) Тогда
		
		ТексЗапроса = "ВЫБРАТЬ
		              |	ЗаказПокупателяЗапасы.Номенклатура.Код КАК НоменклатураКод,
		              |	ЗаказПокупателяЗапасы.Номенклатура КАК Номенклатура,
		              |	ЗаказПокупателяЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		              |	ЗаказПокупателяЗапасы.Характеристика КАК Характеристика,
		              |	ЗаказПокупателяЗапасы.Количество КАК Количество,
		              |	ЗаказПокупателяЗапасы.Ссылка.Номер КАК Номер,
		              |	ЗаказПокупателяЗапасы.Ссылка.Дата КАК Дата,
		              |	ЗаказПокупателяЗапасы.Ссылка.Организация КАК Организация,
		              |	ЗаказПокупателяЗапасы.Ссылка.Контрагент КАК Контрагент,
		              |	ЗаказПокупателяЗапасы.Ссылка.Договор КАК Договор,
		              |	ЗаказПокупателяЗапасы.Ссылка.СтруктурнаяЕдиницаПродажи КАК СтруктурнаяЕдиница,
		              |	ЗаказПокупателяЗапасы.Ссылка.Ячейка КАК Ячейка
		              |ИЗ
		              |	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
		              |ГДЕ
		              |	ЗаказПокупателяЗапасы.Ссылка = &Ссылка";
		
	ИначеЕсли Тип("ДокументСсылка.ОприходованиеЗапасов") = ТипЗнч(СсылкаДокумента) Тогда
		
		ТексЗапроса = "ВЫБРАТЬ
		              |	ОприходованиеЗапасовЗапасы.Номенклатура.Код КАК НоменклатураКод,
		              |	ОприходованиеЗапасовЗапасы.Номенклатура КАК Номенклатура,
		              |	ОприходованиеЗапасовЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		              |	ОприходованиеЗапасовЗапасы.Характеристика КАК Характеристика,
		              |	ОприходованиеЗапасовЗапасы.Количество КАК Количество,
		              |	ОприходованиеЗапасовЗапасы.Ссылка.Номер КАК Номер,
		              |	ОприходованиеЗапасовЗапасы.Ссылка.Дата КАК Дата,
		              |	ОприходованиеЗапасовЗапасы.Ссылка.Организация КАК Организация,
		              |	ОприходованиеЗапасовЗапасы.Ссылка.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		              |	ОприходованиеЗапасовЗапасы.Ссылка.Ячейка КАК Ячейка,
		              |	НЕОПРЕДЕЛЕНО КАК Контрагент,
		              |	НЕОПРЕДЕЛЕНО КАК Договор
		              |ИЗ
		              |	Документ.ОприходованиеЗапасов.Запасы КАК ОприходованиеЗапасовЗапасы
