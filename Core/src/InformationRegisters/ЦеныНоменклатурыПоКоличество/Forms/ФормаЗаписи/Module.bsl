&НаСервереБезКонтекста
// Получает набор данных с сервера для процедуры НоменклатураПриИзменении.

Функция ПолучитьДанныеНоменклатураПриИзменении(Номенклатура)
	
	Возврат Новый Структура("ЕдиницаИзмерения, ИспользоватьХарактеристики", Номенклатура.ЕдиницаИзмерения);
	
КонецФункции


&НаСервере
Функция ПроверкаДиапазона(СтруктураПараметров)
	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.Период,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.Организация,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.Номенклатура,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.Характеристика,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.НачальноеКаличество,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.КанечноеКаличество,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.ЕдиницаИзмерения,
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.ВидЦен
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатурыПоКоличество.СрезПоследних(, Период = &Дата) КАК ЦеныНоменклатурыПоКоличествоСрезПоследних
	|ГДЕ
	|	ЦеныНоменклатурыПоКоличествоСрезПоследних.Организация = &Организация
	|	И ЦеныНоменклатурыПоКоличествоСрезПоследних.Номенклатура = &Номенклатура
	|	И ЦеныНоменклатурыПоКоличествоСрезПоследних.Характеристика = &Характеристика
	|	И ЦеныНоменклатурыПоКоличествоСрезПоследних.ВидЦен = &ВидЦен";
	
	Запрос.УстановитьПараметр("Дата", СтруктураПараметров.Дата);
	Запрос.УстановитьПараметр("Номенклатура", СтруктураПараметров.Номенклатура);
	Запрос.УстановитьПараметр("Организация", СтруктураПараметров.Организация);
	Запрос.УстановитьПараметр("Характеристика", СтруктураПараметров.Характеристика);
	Запрос.УстановитьПараметр("ВидЦен", СтруктураПараметров.ВидЦен);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Стр Из  РезультатЗапроса Цикл 
		
		Если (СтруктураПараметров.НачальноеКаличество>= Стр.НачальноеКаличество) И 
			 (СтруктураПараметров.НачальноеКаличество< Стр.КанечноеКаличество)  Тогда
			 
			//(СтруктураПараметров.КанечноеКаличество<= Стр.КанечноеКаличество) Тогда 
			ВходитДиапазон = Истина;
			Возврат  ВходитДиапазон;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат  ВходитДиапазон = Ложь ;

КонецФункции 


