
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	
	Если Запись.НеИспользуется Тогда 		
		Элементы.Группа3.Доступность = Ложь;				
	КонецЕсли;
		
	ОрганизацияЗаполнена = Не (Запись.Организация = Справочники.Организации.ПустаяСсылка());	
	Если ОрганизацияЗаполнена Тогда
		Возврат;
	КонецЕсли;	
	ОсновнаяОрганизация     = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.Организации.ОсновнаяОрганизация");	
	ОрганизацияПоУмолчанию  = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
	Пользователи.ТекущийПользователь(),
	"ОсновнаяОрганизация");	
	Если ЗначениеЗаполнено(ОрганизацияПоУмолчанию) Тогда	
		Запись.Организация  = ОрганизацияПоУмолчанию;
	Иначе 
		Запись.Организация  = ОсновнаяОрганизация;
	КонецЕсли;
	
	Автор = ПараметрыСеанса.ТекущийПользователь ;	
	Запись.Автор =	Автор ;
	
	
КонецПроцедуры


&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	НачальноеКаличество	= Запись.НачальноеКаличество ;
	КанечноеКаличество  = Запись.КанечноеКаличество  ;
	
	//Если (НачальноеКаличество > КанечноеКаличество)Или (НачальноеКаличество = КанечноеКаличество) Тогда 	
	//	ТекстСообщения              =  НСтр("ru = 'Конечное количество должно превышать начальное количество'; ka = 'საბოლოო რაოდენობა უნდა აღემატებოდეს საწყის რაოდენობას!'" );
	//	ЭлементНачальноеКаличество  =  Элементы.НачальноеКаличество;
	//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , ЭлементНачальноеКаличество);
	//	Отказ = Истина ;
	//КонецЕсли;	
	
	Если Запись.ЭтотНовыйЗапис  Тогда 
		
		ВходитДиапазон = Ложь ;
		СтруктураПараметров = Новый Структура ;
		СтруктураПараметров.Вставить ("Дата",Запись.Период);
		СтруктураПараметров.Вставить ("Номенклатура",Запись.Номенклатура);
		СтруктураПараметров.Вставить ("Организация",Запись.Организация);
		СтруктураПараметров.Вставить ("НачальноеКаличество",Запись.НачальноеКаличество);
		СтруктураПараметров.Вставить ("КанечноеКаличество",Запись.КанечноеКаличество);
		СтруктураПараметров.Вставить ("ВидЦен", Запись.ВидЦен );
		СтруктураПараметров.Вставить ("Характеристика", Запись.Характеристика );
		
		ВходитДиапазон = ПроверкаДиапазонаНачальноеКаличество(СтруктураПараметров);
		
		Если ВходитДиапазон Тогда 	
			ТекстСообщения              =  НСтр("ru = ''; ka = ' საწყისი რაოდენობის მონაცემის ჩაწერა არ შეიძლება.მოცემული რაოდენობა უკვე მითითებულია აქტიურ ჩანაწერებში!'" );
			ЭлементНачальноеКаличество  =  Элементы.НачальноеКаличество;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , ЭлементНачальноеКаличество);
			Отказ = Истина ;
			Возврат ;
		КонецЕсли;
		
		Если  КанечноеКаличество<> 0 Тогда 
			ВходитДиапазон = ПроверкаДиапазонаКанечноеКаличество(СтруктураПараметров);
			Если ВходитДиапазон Тогда 	
				ТекстСообщения              =  НСтр("ru = ''; ka = ' საწყისი რაოდენობის მონაცემის ჩაწერა არ შეიძლება.მოცემული რაოდენობა უკვე მითითებულია აქტიურ ჩანაწერებში!'" );
				ЭлементКанечноеКаличество  =  Элементы.КанечноеКаличество;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , ЭлементКанечноеКаличество);
				Отказ = Истина ;
				Возврат ;
			КонецЕсли;
		КонецЕсли;

		Если  КанечноеКаличество = 0 Тогда 	
			ВходитДиапазон = ПроверкаДиапазонаКанечноеКаличествоНаНолл(СтруктураПараметров);
			Если  ВходитДиапазон Тогда 
				ТекстСообщения              =  НСтр("ru = ''; ka = 'საბოლოო რაოდენობის მონაცემი - 0 უკვე მითითებულია სხვა ჩანაწერში.მსგავსი მონაცემების ჩაწერა არარეკომენდებულია.გადაამოწმეთ არსებული დიაპაზონები !'" );
				ЭлементКанечноеКаличество  =  Элементы.КанечноеКаличество;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , ЭлементКанечноеКаличество);
				Отказ = Истина ;
				Возврат ;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
		
	 Запись.ЭтотНовыйЗапис = Ложь ;
	
КонецПроцедуры


