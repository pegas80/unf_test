#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИспользуютсяХарактеристики = ПолучитьФункциональнуюОпцию("ИспользоватьХарактеристики");
	
	Элементы.ПротоколОбмена.Видимость = ИнтеграцияОбменШтрихМКлиентСервер.РежимОтладкиОбменаШтрихМ();
	
	Если НЕ Параметры.Свойство("Отбор") ИЛИ НЕ Параметры.Отбор.Свойство("КассаККМ") ИЛИ
		(Параметры.Отбор.Свойство("КассаККМ") И НЕ ЗначениеЗаполнено(Параметры.Отбор.КассаККМ)) Тогда
		
		Элементы.ГруппаДанных.Видимость = Ложь;
		Элементы.ГруппаНетДанных.Видимость = Истина;
		
	Иначе
		Элементы.ГруппаДанных.Видимость = Истина;
		Элементы.ГруппаНетДанных.Видимость = Ложь;
		Запись.КассаККМ = Параметры.Отбор.КассаККМ;
		
		ПриЧтенииСозданииНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ПриЧтенииСозданииНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовФормы

&НаКлиенте
Процедура ПерейтиКЗаполнениюЦен(Команда)
	
	Если ИспользуютсяХарактеристики Тогда
		ОткрытьФорму("Обработка.Ценообразование.Форма.ФормаПомощника");
	Иначе
		ОткрытьФорму(
			"РегистрСведений.НастройкиКассыШтрихМ.Форма.ФормаРедактированияЦен",
			Новый Структура("ПрайсЛист", Запись.ПрайсЛист),,,,,,
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РегистрационныйНомерПриИзменении(Элемент)
	ЗаписатьЗапись();
КонецПроцедуры

&НаКлиенте
Процедура ТокенПриИзменении(Элемент)
	ЗаписатьЗапись();
КонецПроцедуры

&НаКлиенте
Процедура ПрайсЛистПриИзменении(Элемент)
	ЗаписатьЗапись();
КонецПроцедуры

&НаКлиенте
Процедура ПечатьПрайсЛиста(Команда)
	ОткрытьФорму(
		"Обработка.ФормированиеПрайсЛистов.Форма", 
		Новый Структура("ПрайсЛист", Запись.ПрайсЛист));
КонецПроцедуры

&НаКлиенте
Процедура ПротоколОбмена(Команда)
	ОткрытьФорму("РегистрСведений.НастройкиКассыШтрихМ.Форма.ФормаПротокола",Новый Структура("Касса", Запись.КассаККМ));
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКоманд

&НаКлиенте
Процедура Подключить(Команда)
	
	Если НЕ ЗначениеЗаполнено(Запись.РегистрационныйНомер) Тогда
		ТекстСообщения = НСтр("ka='Введите регистрационный номер, полученный при регистрации ККМ в ФНС.';ru='Введите регистрационный номер, полученный при регистрации ККМ в ФНС.';en='Enter the registration number you received when registering in CMC FTS.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "Запись.РегистрационныйНомер");
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Запись.Токен) Тогда
		ТекстСообщения = НСтр("ru='Введите пароль для подключения (token),"
"полученный на ККМ при регистрации у оператора фискальных данных (ОФД).';ka='Введите пароль для подключения (token),"
"полученный на ККМ при регистрации у оператора фискальных данных (ОФД).'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "ЗаписьТокен");
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Запись.ПрайсЛист) Тогда
		ТекстСообщения = НСтр("ka='Для работы с кассой необходим прайс-лист для указания цен.';ru='Для работы с кассой необходим прайс-лист для указания цен.';en='To work with the cashier needs a price list to indicate prices.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, "ПрайсЛист");
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаОЗаписиОбъекта", ЭтотОбъект);
	
	Если Модифицированность Тогда
		ЗаголовокВопроса = Нстр("ka='Подключение кассового аппарата';ru='Подключение кассового аппарата';en='Connecting the cash register'");
		ТекстВопроса = Нстр("ka='Для подключения необходимо сохранить введенные данные. Сохранить?';ru='Для подключения необходимо сохранить введенные данные. Сохранить?';en='To connect you need to save the entered data. Save?'");
		СписокКнопок = Новый СписокЗначений;
		СписокКнопок.Добавить(КодВозвратаДиалога.Да, Нстр("ka='შენახვა';ru='Сохранить';en='retain'"));
		СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, Нстр("ka='გაუქმება';ru='Отменить';en='cancel'"));
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, СписокКнопок,, КодВозвратаДиалога.Да, ЗаголовокВопроса);
	Иначе
		ВыполнитьОбработкуОповещения(ОписаниеОповещения, КодВозвратаДиалога.Да);
	КонецЕсли;
КонецПроцедуры

//
&НаКлиенте
Процедура ВыгрузитьТовары(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаВыгрузкаТоваров", ЭтотОбъект);
	
	ЗаголовокВопроса = Нстр("ka='Выгрузка товаров и цен для кассового аппарата';ru='Выгрузка товаров и цен для кассового аппарата';en='Unloading of goods and prices for the cash register'");
	ТекстВопроса = Нстр("ka='Все товары и цены будут выгружены в кассовый аппарат. Выгрузить?';ru='Все товары и цены будут выгружены в кассовый аппарат. Выгрузить?';en='All products and prices will be uploaded to the cash register. Unload?'");
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить(КодВозвратаДиалога.Да, Нстр("ka='გადმოტვირთვა';ru='Выгрузить';en='unload'"));
	СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, Нстр("ka='გაუქმება';ru='Отменить';en='cancel'"));
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, СписокКнопок,, КодВозвратаДиалога.Да, ЗаголовокВопроса);
КонецПроцедуры

//
&НаКлиенте
Процедура ОчиститьТовары(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаУдалениеТоваров", ЭтотОбъект);
	
	ЗаголовокВопроса = Нстр("ka='Удаление товаров и цен с кассового аппарата';ru='Удаление товаров и цен с кассового аппарата';en='Removal of goods and price to cash register'");
	ТекстВопроса = Нстр("ka='Вы действительно хотите удалить все товары и цены с кассового аппарата?';ru='Вы действительно хотите удалить все товары и цены с кассового аппарата?';en='Are you sure you want to remove all the products and prices to the cash register?'");
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить(КодВозвратаДиалога.Да, Нстр("ka='წაშლა';ru='Удалить';en='Delete'"));
	СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, Нстр("ka='გაუქმება';ru='Отменить';en='cancel'"));
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, СписокКнопок,, КодВозвратаДиалога.Да, ЗаголовокВопроса);
КонецПроцедуры

//
&НаКлиенте
Процедура ЗагрузитьЧеки(Команда)
	
	ВыборПериода = Новый СписокЗначений;
	ВыборПериода.Добавить("ТекущаяНеделя", НСтр("ka='მიმდინარე კვირა';ru='Текущая неделя';en='This week'"));
	ВыборПериода.Добавить("ТекущийМесяц", НСтр("ka='მიმდინარე თვე';ru='Текущий месяц';en='Current month'"));
	ВыборПериода.Добавить("ПрошлыйМесяц", НСтр("ka='Прошлый и текущий месяц';ru='Прошлый и текущий месяц';en='Past and current month'"));
	ВыборПериода.Добавить("ТекущийКвартал", НСтр("ka='მიმდინარე კვარტალი';ru='Текущий квартал';en='current quarter'"));
	ВыборПериода.Добавить("ТекущийГод", НСтр("ka='მიმდინარე წელი';ru='Текущий год';en='This year'"));
	ВыборПериода.Добавить("Все", НСтр("ka='За все периоды';ru='За все периоды';en='For all periods'"));
	
	ПоказатьВыборИзМеню(Новый ОписаниеОповещения("ПослеВыбораПериода", ЭтотОбъект),ВыборПериода,Элементы.ЗагрузитьЧеки);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораПериода(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ПериодЗагрузки.ДатаОкончания = ТекущаяДата();
		
		Если Результат.Значение = "ТекущаяНеделя" Тогда
			ПериодЗагрузки.ДатаНачала = НачалоНедели(ТекущаяДата());
		ИначеЕсли Результат.Значение = "ТекущийМесяц" Тогда
			ПериодЗагрузки.ДатаНачала = НачалоМесяца(ТекущаяДата());
		ИначеЕсли Результат.Значение = "ПрошлыйМесяц" Тогда
			ПериодЗагрузки.ДатаНачала = НачалоМесяца(НачалоМесяца(ТекущаяДата())-1);
		ИначеЕсли Результат.Значение = "ТекущийКвартал" Тогда
			ПериодЗагрузки.ДатаНачала = НачалоКвартала(ТекущаяДата());
		ИначеЕсли Результат.Значение = "ТекущийГод" Тогда
			ПериодЗагрузки.ДатаНачала = НачалоГода(ТекущаяДата());
		ИначеЕсли Результат.Значение = "Все" Тогда
			ПериодЗагрузки.ДатаНачала = Дата(2016,1,1,1,1,1);
		КонецЕсли;
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаЗагрузкаЧеков", ЭтотОбъект);
		
		ЗаголовокВопроса = Нстр("ka='Загрузка чеков с кассового аппарата';ru='Загрузка чеков с кассового аппарата';en='Loading checks with cash register'");
		ТекстВопроса = Нстр("ka='Будут загружены все кассовые чеки за выбранный период. Загрузить?';ru='Будут загружены все кассовые чеки за выбранный период. Загрузить?';en='They will be loaded with all the cash receipts for the selected period. Download?'");
		СписокКнопок = Новый СписокЗначений;
		СписокКнопок.Добавить(КодВозвратаДиалога.Да, Нстр("ka='ჩატვირთვა';ru='Загрузить';en='Download'"));
		СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, Нстр("ka='გაუქმება';ru='Отменить';en='cancel'"));
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, СписокКнопок,, КодВозвратаДиалога.Да, ЗаголовокВопроса);
		
	КонецЕсли;
	
КонецПроцедуры
//
&НаКлиенте
Процедура ПослеВопросаВыгрузкаТоваров(Знач Результат, Знач ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ВыгрузитьТоварыНаСервере();
		ЗаголовокПредупреждения = НСтр("ka='Выгрузка товаров и цен';ru='Выгрузка товаров и цен';en='Unloading of goods and prices'");
		ТекстПредупреждения = НСтр("ru='Выгрузка товаров и цен займет около 3 минут."
" Вы можете продолжить работу с программой в это время.';ka='Выгрузка товаров и цен займет около 3 минут."
" Вы можете продолжить работу с программой в это время.'");
		ДополнительныеПараметры = Новый Структура("РежимТовары", Истина);
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПредупрежденияОРегистрации", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьПредупреждение(ОписаниеОповещения, ТекстПредупреждения,, ЗаголовокПредупреждения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаСнятиеСРегистрации(Знач Результат, Знач ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗаголовокПредупреждения = Нстр("ka='Отключение кассового аппарата.';ru='Отключение кассового аппарата.';en='Turn off the cash register.'");
		ДополнительныеПараметры = Новый Структура("Режим", 2);
		ТекстПредупреждения = НСтр("ka='Отключение может занять некоторое время.';ru='Отключение может занять некоторое время.';en='The trip can take some time.'");
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПредупрежденияОРегистрации", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьПредупреждение(ОписаниеОповещения, ТекстПредупреждения,, ЗаголовокПредупреждения);
	КонецЕсли;
КонецПроцедуры

//
&НаКлиенте
Процедура ПослеВопросаУдалениеТоваров(Знач Результат, Знач ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОчиститьТоварыНаСервере();
		ЗаголовокПредупреждения = НСтр("ka='საქონლის მოშორება';ru='Удаление товаров';en='removal of goods'");
		ТекстПредупреждения = НСтр("ru='Удаление товаров займет около 3 мин."
" Вы можете продолжить работу с программой в это время.';ka='Удаление товаров займет около 3 мин."
" Вы можете продолжить работу с программой в это время.'");
		ДополнительныеПараметры = Новый Структура("РежимТоварыОчистка", Истина);
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПредупрежденияОРегистрации", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьПредупреждение(ОписаниеОповещения, ТекстПредупреждения,, ЗаголовокПредупреждения);
	КонецЕсли;
	
КонецПроцедуры
//
&НаКлиенте
Процедура ПослеВопросаЗагрузкаЧеков(Знач Результат, Знач ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗагрузитьЧекиНаСервере();
		ЗаголовокПредупреждения = НСтр("ka='Загрузка кассовых чеков';ru='Загрузка кассовых чеков';en='Loading cash checks'");
		ТекстПредупреждения = НСтр("ru='Загрузка кассовых чеков может занять продолжительное время."
" Вы можете продолжить работу с программой в это время.';ka='Загрузка кассовых чеков может занять продолжительное время."
" Вы можете продолжить работу с программой в это время.'");
		ДополнительныеПараметры = Новый Структура("РежимДокументы", Истина);
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПредупрежденияОРегистрации", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьПредупреждение(ОписаниеОповещения, ТекстПредупреждения,, ЗаголовокПредупреждения);
	КонецЕсли;

КонецПроцедуры
//
&НаКлиенте
Процедура ПослеПредупрежденияОРегистрации(Знач ДополнительныеПараметры) Экспорт
	
	ЕстьОшибки = Ложь;
	СообщениеОбОшибке = "";
	
	Если НЕ ДополнительныеПараметры = Неопределено Тогда
		Если ДополнительныеПараметры.Свойство("Режим") Тогда
			ВыполнитьРегистрациюНаСервере(ДополнительныеПараметры.Режим, ЕстьОшибки, СообщениеОбОшибке);
			Если ЕстьОшибки Тогда
				ЗаголовокПредупреждения = Нстр("ka='Подключение кассового аппарата.';ru='Подключение кассового аппарата.';en='Connecting the cash register.'");
				ПоказатьПредупреждение(, СообщениеОбОшибке,, ЗаголовокПредупреждения);
			Иначе
				ОповеститьОбИзменении(Запись.КассаККМ);
				ПриЧтенииСозданииНаСервере();
			КонецЕсли;
		ИначеЕсли ДополнительныеПараметры.Свойство("РежимТовары") Тогда
			ВыполнитьВыгрузкуТоваровНаСервере(ЕстьОшибки, СообщениеОбОшибке);
			Если ЕстьОшибки Тогда
				ЗаголовокПредупреждения = Нстр("ka='Выгрузка товаров на кассовый аппарат.';ru='Выгрузка товаров на кассовый аппарат.';en='Unloading of goods at the cash register.'");
				ПоказатьПредупреждение(, СообщениеОбОшибке,, ЗаголовокПредупреждения);
			Иначе
				ОповеститьОбИзменении(Запись.КассаККМ);
				ПриЧтенииСозданииНаСервере();
			КонецЕсли;
		ИначеЕсли ДополнительныеПараметры.Свойство("РежимТоварыОчистка") Тогда
			ВыполнитьОчисткуТоваровНаСервере(ЕстьОшибки, СообщениеОбОшибке);
			Если ЕстьОшибки Тогда
				ЗаголовокПредупреждения = Нстр("ka='Очистка товаров на кассовом аппарате.';ru='Очистка товаров на кассовом аппарате.';en='Clearance of goods at the cash register.'");
				ПоказатьПредупреждение(, СообщениеОбОшибке,, ЗаголовокПредупреждения);
			Иначе
				ОповеститьОбИзменении(Запись.КассаККМ);
				ПриЧтенииСозданииНаСервере();
			КонецЕсли;
		ИначеЕсли ДополнительныеПараметры.Свойство("РежимДокументы") Тогда
			ВыполнитьЗагрузкуЧековНаСервере(ЕстьОшибки, СообщениеОбОшибке);
			Если ЕстьОшибки Тогда
				ЗаголовокПредупреждения = Нстр("ka='Загрузка чеков с кассового аппарата.';ru='Загрузка чеков с кассового аппарата.';en='Loading checks from the cash register.'");
				ПоказатьПредупреждение(, СообщениеОбОшибке,, ЗаголовокПредупреждения);
			Иначе
				ОповеститьОбИзменении(Запись.КассаККМ);
				ПриЧтенииСозданииНаСервере();
			КонецЕсли;
		КонецЕсли;
	Иначе
		ПриЧтенииСозданииНаСервере();
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура ПослеВопросаОЗаписиОбъекта(Знач Результат, Знач ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Успешно = Истина;
		Если Модифицированность Или НЕ ЗначениеЗаполнено(Запись.КассаККМ) Тогда
			Успешно = Записать();
		КонецЕсли;
		Если Успешно И ЗначениеЗаполнено(Запись.КассаККМ) Тогда
			ЗаголовокПредупреждения = Нстр("ka='Подключение кассового аппарата';ru='Подключение кассового аппарата';en='Connecting the cash register'");
			Если СостояниеРегистрации =
					ПредопределенноеЗначение("Перечисление.СостоянияРегистрацииКассовогоАппарата.Подключен") Тогда
				ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВопросаСнятиеСРегистрации", ЭтотОбъект);
				
				ЗаголовокВопроса = Нстр("ka='Отключение кассового аппарата';ru='Отключение кассового аппарата';en='Turn off the cash register'");
				ТекстВопроса = Нстр("ka='После отключения данные по чекам не смогут быть загружены. Отключить?';ru='После отключения данные по чекам не смогут быть загружены. Отключить?';en='After tripping checks the data can not be downloaded. Disable?'");
				СписокКнопок = Новый СписокЗначений;
				СписокКнопок.Добавить(КодВозвратаДиалога.Да, Нстр("ka='გამორთვა';ru='Отключить';en='shut off'"));
				СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, Нстр("ka='გაუქმება';ru='Отменить';en='cancel'"));
				ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, СписокКнопок,, КодВозвратаДиалога.Да, ЗаголовокВопроса);
			Иначе
				Результат = ПодключитьОтключитьКассуПоТарифу(Истина);
				Если Результат Тогда
					ДополнительныеПараметры = Новый Структура("Режим", 1);
					ТекстПредупреждения = НСтр("ka='Подключение может занять некоторое время.';ru='Подключение может занять некоторое время.';en='Connection may take some time.'");
				Иначе
					ТекстПредупреждения = НСтр("ru='Закончились свободные лицензии для регистрации касс."
"Для регистрации кассового аппарата вам необходимо увеличить количество разрешенных касс по тарифу"
"в личном кабинете абонента.';ka='Закончились свободные лицензии для регистрации касс."
"Для регистрации кассового аппарата вам необходимо увеличить количество разрешенных касс по тарифу"
"в личном кабинете абонента.'");
				КонецЕсли;
				
				ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПредупрежденияОРегистрации", ЭтотОбъект, ДополнительныеПараметры);
				ПоказатьПредупреждение(ОписаниеОповещения, ТекстПредупреждения,, ЗаголовокПредупреждения);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

