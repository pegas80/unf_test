		Элементы.ОчиститьТовары.Доступность = Ложь;
		Элементы.ОчиститьТовары.Заголовок = НСтр("ka='Удалить товары и цены';ru='Удалить товары и цены';en='Remove products and prices'");
		
		Ожидание = Истина;
		//Заголовок = СтрШаблон(НСтр("ka='%1 (%2)';ru='%1 (%2)';en='%12)'"),
		//	Запись.КассаККМ.Наименование, Элементы.ВыгрузитьТовары.Заголовок);
	ИначеЕсли Запись.ОчиститьТоварыНаСервереШтрихМ Тогда
		Элементы.ВыгрузитьТовары.Доступность = Ложь;
		Элементы.ВыгрузитьТовары.Заголовок = НСтр("ka='Выгрузить товары и цены';ru='Выгрузить товары и цены';en='Unload the goods and prices'");
