        <autoFill>true</autoFill>
      </contextMenu>
      <type>RadioButtonField</type>
      <editMode>Enter</editMode>
      <showInHeader>true</showInHeader>
      <headerHorizontalAlign>Left</headerHorizontalAlign>
      <showInFooter>true</showInFooter>
      <extInfo xsi:type="form:RadioButtonsFieldExtInfo">
        <columnsCount>1</columnsCount>
        <choiceList>
          <presentation>
            <key>ru</key>
            <value>400 р.(Код 103 для тех, кто не относится к коду 104 и коду 105)</value>
          </presentation>
          <presentation>
            <key>ka</key>
            <value>15 ლარი (კოდი 103, მათთვის ვინც კოდ 104-ს და კოდ 105-ს არ განეკუთვნება)</value>
          </presentation>
          <presentation>
            <key>en</key>
            <value>400 p. (Code 103 for those who does not belong to the code 104 and code 105)</value>
          </presentation>
          <value xsi:type="core:ReferenceValue">
            <value>Catalog.ВычетыНДФЛ.Код103</value>
          </value>
        </choiceList>
        <choiceList>
          <presentation>
            <key>ru</key>
            <value>500 р. (Код 104 для тех, кто относится к лицам, перечисленным в пп.2 п.1 ст. 218 НК РФ)</value>
          </presentation>
          <presentation>
            <key>ka</key>
            <value>15 ლ. (კოდი 104 მათთვის, ვინც განეკუთვნება საგადასახადო კოდექსის მუხლში ჩამოთვლილ პირებს)</value>
          </presentation>
          <presentation>
            <key>en</key>
            <value>500 p. (Code 104 for those who belong to the persons listed in claims 2 to claim 1 of Art. 218 of the Tax Code)</value>
          </presentation>
          <value xsi:type="core:ReferenceValue">
            <value>Catalog.ВычетыНДФЛ.Код104</value>
          </value>
        </choiceList>
        <choiceList>
          <presentation>
            <key>ru</key>
            <value>3000 р. (Код 105 для тех, кто относится к лицам, перечисленным в пп.1 п.1 ст. 218 НК РФ)</value>
          </presentation>
          <presentation>
            <key>ka</key>
            <value>100 ლარი (კოდი 105 მათთვის, ვინც განეკუთვნება საგადასახადო კოდექსის მუხლში ჩამოთვლილ პირებს)</value>
          </presentation>
          <presentation>
            <key>en</key>
            <value>3000 p. (Code 105 for those who treat persons listed in claim 1 of claims 1 v. 218 RF)</value>
          </presentation>
          <value xsi:type="core:ReferenceValue">
            <value>Catalog.ВычетыНДФЛ.Код105</value>
          </value>
        </choiceList>
      </extInfo>
    </items>
