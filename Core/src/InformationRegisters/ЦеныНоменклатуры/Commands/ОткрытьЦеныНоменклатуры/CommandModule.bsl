
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	//+++ Дмгг
	//на всякий случай попытка, если команду еще кто-то вызывает, кроме карточки номенклатуры
	ЗначениеЗапрета = ЛОЖЬ;
	Попытка
		ЗначениеЗапрета = ПараметрыВыполненияКоманды.Источник.ЗапретОтображенияЦен;
	Исключение
		ЗначениеЗапрета = ЛОЖЬ;
	КонецПопытки;
	
	Если ЗначениеЗапрета Тогда 
		Возврат;
	КонецЕсли;
	//--- Дмгг
	
	Отбор 			= Новый Структура("Номенклатура", ПараметрКоманды);
	ПараметрыФормы	= Новый Структура("Отбор", Отбор);
	
	ОткрытьФорму("РегистрСведений.ЦеныНоменклатуры.Форма.ЦеныНоменклатуры", ПараметрыФормы, ПараметрыВыполненияКоманды.Источник, ПараметрыВыполненияКоманды.Уникальность, ПараметрыВыполненияКоманды.Окно);
	
КонецПроцедуры
