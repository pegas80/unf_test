
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Параметры.Заказ) Тогда
		ВызватьИсключение НСтр("ka='Не указан заказ';ru='Не указан заказ';en='Unknown order'");
	КонецЕсли;
	
	Список.Параметры.УстановитьЗначениеПараметра("Заказ", Параметры.Заказ);
	
	ТолькоПросмотр = Истина;
	Заголовок = СтрШаблон(НСтр("ka='История изменения состояний заказа: ""%1""';ru='История изменения состояний заказа: ""%1""';en='The history of the order states: ""%1""'"), Параметры.Заказ);
	
КонецПроцедуры

#КонецОбласти
