
Процедура ПередЗаписью(Отказ)

	// Вставить содержимое обработчика.  ,
	КоличествоКонстанты = Константы.ОПТИМУС_КоличествоПлановОбменаДистрибуции.Получить();
	КоличествоКонстанты = ?(КоличествоКонстанты = 0 , 0 ,КоличествоКонстанты);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	КОЛИЧЕСТВО(ОПТИМУС_Дистрибуция.Ссылка) КАК Ссылка
	               |ИЗ
	               |	ПланОбмена.ОПТИМУС_Дистрибуция КАК ОПТИМУС_Дистрибуция
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА Не &ЭтоНовый
	               |				ТОГДА ОПТИМУС_Дистрибуция.Ссылка <> &Ссылка
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ЭтоНовый",ЭтоНовый());			   
	Запрос.УстановитьПараметр("Ссылка",Ссылка);			   
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	КоличествоПлановОбмена = 0;
	Если  Выборка.Следующий() Тогда 
		КоличествоПлановОбмена =  Выборка.Ссылка;
	Иначе 
		КоличествоПлановОбмена = 0;
	КонецЕсли;
	
	Если КоличествоКонстанты < КоличествоПлановОбмена Тогда 
		Сообщить(НСтр("ka='გაცვლის გეგმების რაოდენობა აჭარბებს დასაშვებ';ru='Количество планов обмена преувеличивает допустимого';en='Number sharing plans exaggerates permissible'"));
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры
