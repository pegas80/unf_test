					<dcsset:right xsi:type="dcscor:DesignTimeValue">Справочник.Пользователи.ПустаяСсылка</dcsset:right>
					<dcsset:userSettingID>5d171473-29d5-4561-8805-c36555000a4a</dcsset:userSettingID>
				</dcsset:item>
