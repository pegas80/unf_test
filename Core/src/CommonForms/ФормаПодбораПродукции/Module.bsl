// Процедура - обработчик нажатия кнопки ОК.
//
&НаКлиенте
Процедура OK(Команда)
	
	Отказ = Истина;
	КоличествоПродукции = 1;
	Если ВвестиЧисло(КоличествоПродукции, НСтр("ru = 'Введите количество продукции для производства'; ka = 'მიუთითეთ პროდუქციის რაოდენობა საწარმოებლად'; en = 'Введите количество продукции для производства'"), 15, 3) Тогда
		Отказ = ЛОЖЬ;
	КонецЕсли;
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = Элементы.ВариантыПродукции.ТекущиеДанные;
	УИДСтроки = ТекущаяСтрока.ПолучитьИдентификатор();
	
	ЗаписатьПодборВХранилище(УИДСтроки, КоличествоПродукции);
	Закрыть(КодВозвратаДиалога.OK);
	
КонецПроцедуры

// Процедура помещает результаты варианта в хранилище.
//
&НаСервере
Процедура ЗаписатьПодборВХранилище(УИДСтроки, КоличествоПродукции)
	
	СтрокаВарианта = ВариантыПродукции.НайтиПоИдентификатору(УИДСтроки);
	
	СтрокаВарианта.Количество = КоличествоПродукции;
	
	МассивСтрок = Новый Массив;
	МассивСтрок.Добавить(СтрокаВарианта);
	
	ВариантВХранилище = ВариантыПродукции.Выгрузить(МассивСтрок);
	ПоместитьВоВременноеХранилище(ВариантВХранилище, АдресВариантовПродукцииВХранилище);
	
КонецПроцедуры // ЗаписатьПодборВХранилище()

