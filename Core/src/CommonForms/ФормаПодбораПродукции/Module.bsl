
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	АдресВариантовПродукцииВХранилище = Параметры.АдресВариантовПродукцииВХранилище;
	
	Запасы.Загрузить(ПолучитьИзВременногоХранилища(АдресВариантовПродукцииВХранилище));
	
	ЗаполнитьТаблицуВариантовПродукции();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуВариантовПродукции()

	тзЗапасы = Запасы.Выгрузить();
	
	КолвоСтрок = тзЗапасы.Количество();
	ТекстЗапроса = ПолучитьТекстЗапроса(КолвоСтрок);
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("тзЗапасы", тзЗапасы);
	тзВариантыПродукции = Запрос.Выполнить().Выгрузить();
	
	ВариантыПродукции.Загрузить(тзВариантыПродукции);

КонецПроцедуры

&НаСервере
Функция ПолучитьТекстЗапроса(КолвоСтрок)

	ТекстЗапроса =  "ВЫБРАТЬ
		|	тзЗапасы.НомерСтроки КАК НомерСтроки,
		|	тзЗапасы.Номенклатура КАК Номенклатура,
		|	тзЗапасы.Характеристика КАК Характеристика,
		|	тзЗапасы.Количество КАК Количество,
		|	тзЗапасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ПОМЕСТИТЬ ВТ_Запасы
		|ИЗ
		|	&тзЗапасы КАК тзЗапасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Запасы.НомерСтроки КАК НомерСтроки,
		|	ВТ_Запасы.Номенклатура КАК Номенклатура,
		|	ВТ_Запасы.Характеристика КАК Характеристика,
		|	ВТ_Запасы.Количество КАК КоличествоДокумент,
		|	ВТ_Запасы.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ПОМЕСТИТЬ ВТ_ВсеМатериалы
		|ИЗ
		|	ВТ_Запасы КАК ВТ_Запасы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВариантыПроизводстваМатериалы.КлючСвязи КАК КлючСвязи,
		|	ВариантыПроизводстваМатериалы.Материал КАК Материал,
		|	ВариантыПроизводстваМатериалы.ВсегоМатериалов КАК ВсегоМатериалов,
		|	ВариантыПроизводстваМатериалы.Количество КАК КоличествоМатериалаНеобходходимо,
		|	ВариантыПроизводстваМатериалы.ЕдиницаИзмерений КАК ЕдиницаИзмерений,
		|	ВариантыПроизводстваМатериалы.Характеристика КАК Характеристика
		|ПОМЕСТИТЬ ВТ__ВариантыМатериалов
		|ИЗ
		|	РегистрСведений.ВариантыПроизводстваМатериалы КАК ВариантыПроизводстваМатериалы
		|ГДЕ
		|	(ВариантыПроизводстваМатериалы.Материал, ВариантыПроизводстваМатериалы.Характеристика) В
		|			(ВЫБРАТЬ
		|				а.Номенклатура,
		|				а.Характеристика
		|			ИЗ
		|				ВТ_ВсеМатериалы КАК а)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|";
	
	Для Сч = 1 По КолвоСтрок Цикл 
		
		Если Сч > 1 Тогда 
			
		    ТекстЗапроса = ТекстЗапроса + "
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|";
			
		КонецЕсли;
		
			
		ТекстЗапроса = ТекстЗапроса + "ВЫБРАТЬ
		|	ВТ_ВсеМатериалы.Номенклатура КАК Номенклатура,
		|	ВТ_ВсеМатериалы.Характеристика КАК Характеристика,
		|	ВТ_ВсеМатериалы.КоличествоДокумент КАК КоличествоДокумент,
		|	ВТ_ВсеМатериалы.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ВТ__ВариантыМатериалов.КлючСвязи КАК КлючСвязи,
		|	ВТ__ВариантыМатериалов.ВсегоМатериалов КАК ВсегоМатериалов,
		|	ВТ__ВариантыМатериалов.КоличествоМатериалаНеобходходимо КАК КоличествоМатериалаНеобходходимо,
		|	ВариантыПроизводстваПродукция.Продукция КАК Продукция,
		|	ВариантыПроизводстваПродукция.Характеристика КАК ХарактеристикаПродукции
		|"+?(Сч = 1, "ПОМЕСТИТЬ ВТ_ДокСВариантом", "") + "
		|ИЗ
		|	ВТ_ВсеМатериалы КАК ВТ_ВсеМатериалы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ__ВариантыМатериалов КАК ВТ__ВариантыМатериалов
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВариантыПроизводстваПродукция КАК ВариантыПроизводстваПродукция
		|			ПО ВТ__ВариантыМатериалов.КлючСвязи = ВариантыПроизводстваПродукция.КлючСвязи
		|		ПО ВТ_ВсеМатериалы.Номенклатура = ВТ__ВариантыМатериалов.Материал
