    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокХарактеристик.НоменклатураСсылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокХарактеристик.ЦенаВключаетНДС</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
