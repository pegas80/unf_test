    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЗапасыИерархия.НоменклатураСсылка</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникНоменклатура.Наименование КАК Группа,
	СправочникНоменклатура.Ссылка КАК НоменклатураСсылка
ИЗ
	Справочник.Номенклатура КАК СправочникНоменклатура
ГДЕ
	СправочникНоменклатура.ЭтоГруппа</queryText>
      <mainTable>Catalog.Номенклатура</mainTable>
