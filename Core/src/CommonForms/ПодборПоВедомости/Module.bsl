
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)	
	Параметры.Свойство("ДатаДокумента",ДатаДокумента);
	Если НЕ ЗначениеЗаполнено(ДатаДокумента) Тогда
		ДатаДокумента = ТекущаяДата();
	КонецЕсли;
	
	Параметры.Свойство("Организация",Организация);
	Параметры.Свойство("Подразделение",Подразделение);
	Параметры.Свойство("Сотрудник",Сотрудник);
	
	МассивВедомостей = Новый Массив();
	Если Параметры.Свойство("МассивВедомостей",МассивВедомостей) Тогда
		СписокВедомостей.ЗагрузитьЗначения(МассивВедомостей);
	КонецЕсли;
	
	//ПодольскийАИ #УчетПроектов 25.11.2020 {
	УчетПоПроектам = ПолучитьФункциональнуюОпцию("УчетПоПроектам");
	//ПодольскийАИ #УчетПроектов 25.11.2020 }
	
	ЗаполнитьДанныеФормы();
КонецПроцедуры


&НаСервере
Процедура ЗаполнитьДанныеФормы()
	Если СписокВедомостей.Количество()=0 Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	ЗапросТекст = 
		"ВЫБРАТЬ
		|	ПлатежнаяВедомостьСотрудники.Ссылка КАК Ведомость,
		|	ПлатежнаяВедомостьСотрудники.Сотрудник,
		//ПодольскийАИ #УчетПроектов 25.11.2020 {
		|	Выбор 
		|		Когда &УчетПоПроектам
		|			Тогда ПлатежнаяВедомостьСотрудники.Проект
		|		Иначе Значение(Справочник.Проекты.БезПроекта)
		|	Конец КАК Проект,
		//ПодольскийАИ #УчетПроектов 25.11.2020 }
		|	ПлатежнаяВедомостьСотрудники.СуммаПлатежа,
		|	ПлатежнаяВедомостьСотрудники.НДФЛПлатежа,
		//Паганини ПФ_
	    //|	РасчетыСПерсоналомОстатки.СуммаОстаток
		|	ПлатежнаяВедомостьСотрудники.ВидУдержанияНДФЛ,
		|	ПлатежнаяВедомостьСотрудники.ВидУдержанияПФ,
		|	ПлатежнаяВедомостьСотрудники.СуммаПФПлатежа,
		|	ЕСТЬNULL(РасчетыСПерсоналомОстатки.СуммаОстаток, 0) КАК СуммаОстаток
		//_Паганини ПФ
		|,	ПлатежнаяВедомостьСотрудники.СуммаЛгот КАК СуммаЛьгот //+++ Дмгг
		|ИЗ
		|	Документ.ПлатежнаяВедомость.Сотрудники КАК ПлатежнаяВедомостьСотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСПерсоналом.Остатки(&ДатаДокумента, ) КАК РасчетыСПерсоналомОстатки
		|		ПО ПлатежнаяВедомостьСотрудники.Ссылка.Организация = РасчетыСПерсоналомОстатки.Организация
		|			И ПлатежнаяВедомостьСотрудники.Ссылка.СтруктурнаяЕдиница = РасчетыСПерсоналомОстатки.СтруктурнаяЕдиница
		|			И ПлатежнаяВедомостьСотрудники.Сотрудник = РасчетыСПерсоналомОстатки.Сотрудник
		//ПодольскийАИ #УчетПроектов 25.11.2020 {
		|			И Выбор 
		|				Когда &УчетПоПроектам
		|					Тогда ПлатежнаяВедомостьСотрудники.Проект = РасчетыСПерсоналомОстатки.Проект
		|				Иначе Истина
		|			Конец
		//ПодольскийАИ #УчетПроектов 25.11.2020 }
		|ГДЕ
		|	ПлатежнаяВедомостьСотрудники.Ссылка В(&СписокВедомостей)";
	Если ЗначениеЗаполнено(Организация) Тогда
		ЗапросТекст = ЗапросТекст+"
		|	И ПлатежнаяВедомостьСотрудники.Ссылка.Организация = &Организация";
		Запрос.УстановитьПараметр("Организация", Организация);
	КонецЕсли;
	Если ЗначениеЗаполнено(Подразделение) Тогда
		ЗапросТекст = ЗапросТекст+"
		|	И ПлатежнаяВедомостьСотрудники.Ссылка.СтруктурнаяЕдиница = &СтруктурнаяЕдиница";
		Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Подразделение);
	КонецЕсли;
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		ЗапросТекст = ЗапросТекст+"
		|	И ПлатежнаяВедомостьСотрудники.Сотрудник = &Сотрудник";
		Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	Запрос.УстановитьПараметр("СписокВедомостей", СписокВедомостей);
	
	//ПодольскийАИ #УчетПроектов 25.11.2020 {
	Запрос.УстановитьПараметр("УчетПоПроектам", УчетПоПроектам);
	//ПодольскийАИ #УчетПроектов 25.11.2020 }
	
	Запрос.Текст = ЗапросТекст;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ТеСумма = МИН(ВыборкаДетальныеЗаписи.СуммаПлатежа,ВыборкаДетальныеЗаписи.СуммаОстаток);
		Если ТеСумма>0 Тогда
			Коэффициент = ТеСумма/ВыборкаДетальныеЗаписи.СуммаПлатежа;//Паганини
			СтрСотрудникиИзВедомость = СотрудникиИзВедомость.Добавить();
			ЗаполнитьЗначенияСвойств(СтрСотрудникиИзВедомость,ВыборкаДетальныеЗаписи);
			СтрСотрудникиИзВедомость.СуммаПлатежа = ТеСумма;
			СтрСотрудникиИзВедомость.НДФЛПлатежа = ВыборкаДетальныеЗаписи.НДФЛПлатежа * ТеСумма / ВыборкаДетальныеЗаписи.СуммаПлатежа;
			СтрСотрудникиИзВедомость.Сумма = ВыборкаДетальныеЗаписи.СуммаПлатежа;
			СтрСотрудникиИзВедомость.НДФЛ = ВыборкаДетальныеЗаписи.НДФЛПлатежа;
			//Паганини ПФ_
			СтрСотрудникиИзВедомость.СуммаПФПлатежа = ВыборкаДетальныеЗаписи.СуммаПФПлатежа * Коэффициент;
			СтрСотрудникиИзВедомость.ПФ				= ВыборкаДетальныеЗаписи.СуммаПФПлатежа;
			//_Паганини ПФ	
			СтрСотрудникиИзВедомость.СуммаЛьгот		= ВыборкаДетальныеЗаписи.СуммаЛьгот; //+++ Дмгг
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры


