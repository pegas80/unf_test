
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Параметры.Свойство("Идентификатор", Идентификатор);
	Заголовок = НСтр("ka='ФР';ru='ФР';en='DF'") + " """ + Строка(Идентификатор) + """";

	СпМодель = Элементы.Модель.СписокВыбора;
	СпМодель.Добавить("Daisy_eXpert_Georgia_DPrint", "Daisy eXpert Georgia (using DPrint)");
	СпМодель.СортироватьПоПредставлению();

	
	времНомерСекции = Неопределено;
	времМодель      = Неопределено;
	времИмяФайла	= Неопределено;
	времКаталогСДаннымиЧеков = Неопределено;
	времВыводитьСписокТоваров = Неопределено;
	времПечататьНаОбычныйПринтер = Неопределено;
	времИспользоватьПриБезналичнойОплате = Неопределено;
    времШиринаЛенты	= Неопределено;
	времВремяОжиданияОтвета = Неопределено;
	времПолучатьОтветОтФС = Неопределено;
    времИмяФайлаОтвета	= Неопределено;
	
	Параметры.ПараметрыОборудования.Свойство("НомерСекции"			, времНомерСекции);
	Параметры.ПараметрыОборудования.Свойство("Модель"					, времМодель);
	Параметры.ПараметрыОборудования.Свойство("ИмяФайла"				, времИмяФайла);	
	Параметры.ПараметрыОборудования.Свойство("КаталогСДаннымиЧеков"	, времКаталогСДаннымиЧеков);
	Параметры.ПараметрыОборудования.Свойство("ВыводитьСписокТоваров"	, времВыводитьСписокТоваров);
	Параметры.ПараметрыОборудования.Свойство("ПечататьНаОбычныйПринтер", времПечататьНаОбычныйПринтер);
	Параметры.ПараметрыОборудования.Свойство("ШиринаЛенты"			, времШиринаЛенты);
	Параметры.ПараметрыОборудования.Свойство("ИспользоватьПриБезналичнойОплате", времИспользоватьПриБезналичнойОплате);
	Параметры.ПараметрыОборудования.Свойство("ВремяОжиданияОтвета"	, времВремяОжиданияОтвета);
    Параметры.ПараметрыОборудования.Свойство("ПолучатьОтветОтФС"		, времПолучатьОтветОтФС);
	Параметры.ПараметрыОборудования.Свойство("ИмяФайлаОтвета"			, времИмяФайлаОтвета);
	
	
	
	НомерСекции					= ?(времНомерСекции				= Неопределено, 1, времНомерСекции);
	Модель						= ?(времМодель					= Неопределено, Элементы.Модель.СписокВыбора[0].Значение, времМодель);
	ИмяФайла					= ?(времИмяФайла				= Неопределено, "DEFEXEC.txt", времИмяФайла);
	КаталогСДаннымиЧеков		= ?(времКаталогСДаннымиЧеков	= Неопределено, "c:", времКаталогСДаннымиЧеков);
	ВыводитьСписокТоваров		= ?(времВыводитьСписокТоваров	= Неопределено, Ложь, времВыводитьСписокТоваров);
	ПечататьНаОбычныйПринтер	= ?(времПечататьНаОбычныйПринтер= Неопределено, Ложь, времПечататьНаОбычныйПринтер);
	ШиринаЛенты					= ?(времШиринаЛенты				= Неопределено, "24", времШиринаЛенты);
	ИспользоватьПриБезналичнойОплате = ?(времИспользоватьПриБезналичнойОплате = Неопределено, Ложь, времИспользоватьПриБезналичнойОплате);
	ВремяОжиданияОтвета			= ?(времВремяОжиданияОтвета		= Неопределено, 10, времВремяОжиданияОтвета);
	ПолучатьОтветОтФС			= ?(времПолучатьОтветОтФС		= Неопределено, Ложь, времПолучатьОтветОтФС);
	ИмяФайлаОтвета				= ?(времИмяФайлаОтвета			= Неопределено, "DEFANSW.TXT", времИмяФайлаОтвета);

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ОбновитьИнформациюОДрайвере();

КонецПроцедуры

// Процедура представляет обработчик события "Нажатие" кнопки
// "ОК" командной панели "ОсновныеДействияФормы".
//
// Параметры:
//  Кнопка - <КнопкаКоманднойПанели>
//         - Кнопка, с которой связано данное событие (кнопка "ОК").
//
&НаКлиенте
Процедура ЗаписатьИЗакрытьВыполнить()

	НовыеЗначениеПараметров = Новый Структура();
	НовыеЗначениеПараметров.Вставить("НомерСекции"	, НомерСекции);
	НовыеЗначениеПараметров.Вставить("Модель"		, Модель);
	НовыеЗначениеПараметров.Вставить("Имяфайла"		, ИмяФайла);	
	НовыеЗначениеПараметров.Вставить("КаталогСДаннымиЧеков"	, КаталогСДаннымиЧеков);
	НовыеЗначениеПараметров.Вставить("ВыводитьСписокТоваров", ВыводитьСписокТоваров);
	НовыеЗначениеПараметров.Вставить("ПечататьНаОбычныйПринтер", ПечататьНаОбычныйПринтер);
    НовыеЗначениеПараметров.Вставить("ШиринаЛенты", ШиринаЛенты);
	НовыеЗначениеПараметров.Вставить("ИспользоватьПриБезналичнойОплате", ИспользоватьПриБезналичнойОплате);
	НовыеЗначениеПараметров.Вставить("ВремяОжиданияОтвета", ВремяОжиданияОтвета);
    НовыеЗначениеПараметров.Вставить("ПолучатьОтветОтФС", ПолучатьОтветОтФС);
	НовыеЗначениеПараметров.Вставить("ИмяФайлаОтвета", ИмяФайлаОтвета);

	Результат = Новый Структура;
	Результат.Вставить("Идентификатор", Идентификатор);
	Результат.Вставить("ПараметрыОборудования", НовыеЗначениеПараметров);

	Закрыть(Результат);

КонецПроцедуры // ОсновныеДействияФормыОК()

