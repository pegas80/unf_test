// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест"
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;

	Параметры.Свойство("Идентификатор", Идентификатор);
	Параметры.Свойство("ДрайверОборудования", ДрайверОборудования);
	Заголовок = НСтр("ka='ДП';ru='ДП'") + " """ + Строка(Идентификатор) + """";

	ЦветТекста = ЦветаСтиля.ЦветТекстаФормы;
	ЦветОшибки = ЦветаСтиля.ЦветОтрицательногоЧисла;

	Параметры.ПараметрыОборудования.Свойство("БанкТерминала"  , БанкТерминала);
	Параметры.ПараметрыОборудования.Свойство("ЗапретВозвратаЧастичнуюСуммуНаТерминале"  , ЗапретВозвратаЧастичнуюСуммуНаТерминале);
	Параметры.ПараметрыОборудования.Свойство("TerminalAlias"  , TerminalAlias);
	Параметры.ПараметрыОборудования.Свойство("ПечатьСлипНаТерминале"  , ПечатьСлипНаТерминале);
	
	//Малыщев 2024-07-19 ONESOFT-3343 (--
		
	КарточнаяТехника.Добавить("IsoTypeA");
	КарточнаяТехника.Добавить("IsoTypeB");
	КарточнаяТехника.Добавить("Mifare1K");
	КарточнаяТехника.Добавить("Mifare4K");
	КарточнаяТехника.Добавить("MifareUL");
	
	
	НосителиИсточникаТранзакций.Добавить("ManualEntry");
	НосителиИсточникаТранзакций.Добавить("MagnetSwipe");
	НосителиИсточникаТранзакций.Добавить("EmvChip");
	НосителиИсточникаТранзакций.Добавить("EmvContactless");
	НосителиИсточникаТранзакций.Добавить("EmvQRCPS");
	НосителиИсточникаТранзакций.Добавить("NFC");
	
	
	Параметры.ПараметрыОборудования.Свойство("licenseToken"  , licenseToken);
    Параметры.ПараметрыОборудования.Свойство("АдресСервера"  , АдресСервера);
	Параметры.ПараметрыОборудования.Свойство("ApiVersion"  , ApiVersion);
	
	Параметры.ПараметрыОборудования.Свойство("language"  , language);
	Параметры.ПараметрыОборудования.Свойство("idleText_LockDevice"  , idleText_LockDevice);
	Параметры.ПараметрыОборудования.Свойство("idleText_UnlockDevice"  , idleText_UnlockDevice);
	Параметры.ПараметрыОборудования.Свойство("operatorId"  , operatorId);
	Параметры.ПараметрыОборудования.Свойство("operatorName"  , operatorName);
	Параметры.ПараметрыОборудования.Свойство("silentCardRead"  , silentCardRead);
	Параметры.ПараметрыОборудования.Свойство("currencyCode"  , currencyCode);
	Параметры.ПараметрыОборудования.Свойство("Логировать"  , Логировать);
	Параметры.ПараметрыОборудования.Свойство("ПутьЛогирования"  , ПутьЛогирования);
	Параметры.ПараметрыОборудования.Свойство("Отладка"  , Отладка);
	Параметры.ПараметрыОборудования.Свойство("ГолосовоеОповещение"  , ГолосовоеОповещение);
	Параметры.ПараметрыОборудования.Свойство("СкрытьИзСпискаВыбора"  , СкрытьИзСпискаВыбора);
	Параметры.ПараметрыОборудования.Свойство("ВремяОжиданияКарты"  , ВремяОжиданияКарты);
	Параметры.ПараметрыОборудования.Свойство("ПредлагатьПовторитьОперациюОжидания"  , ПредлагатьПовторитьОперациюОжидания);
	
	//Карточная техника
	cardTechs = Новый Массив;
	Параметры.ПараметрыОборудования.Свойство("cardTechs"  , cardTechs);
	Если типЗнч(cardTechs)<>Тип("Массив") Тогда
		cardTechs = Новый Массив;	
	КонецЕсли;	
	КарточнаяТехникаВсе = cardTechs.Количество()=0;
	Для каждого Стр из cardTechs Цикл
		ИскомыйЭлемент = КарточнаяТехника.НайтиПоЗначению(Стр);
		Если ИскомыйЭлемент<>Неопределено ТОгда
			ИскомыйЭлемент.Пометка = Истина;
		КонецЕсли;	
	КонецЦикла;	

	//Носители источника транзакции
	enabledTranSourceMedias = Новый Массив;
	Параметры.ПараметрыОборудования.Свойство("enabledTranSourceMedias"  , enabledTranSourceMedias);
	Если типЗнч(enabledTranSourceMedias)<>Тип("Массив") Тогда
		enabledTranSourceMedias = Новый Массив;	
	КонецЕсли;	
	НосителиТранзакцийВсе = enabledTranSourceMedias.Количество()=0;
	Для каждого Стр из enabledTranSourceMedias Цикл
		ИскомыйЭлемент = НосителиИсточникаТранзакций.НайтиПоЗначению(Стр);
		Если ИскомыйЭлемент<>Неопределено ТОгда
			ИскомыйЭлемент.Пометка = Истина;
		КонецЕсли;	
	КонецЦикла;	
	
	
	//Малыщев 2024-07-19 ONESOFT-3343 --)
	
	
	Элементы.ТестУстройства.Видимость    = (ПараметрыСеанса.РабочееМестоКлиента
	                                        = Идентификатор.РабочееМесто);
	Элементы.УстановитьДрайвер.Видимость = Ложь; //(ПараметрыСеанса.РабочееМестоКлиента
	                                        //= Идентификатор.РабочееМесто);
											
	Если не ТолькоПросмотр и Не ЗначениеЗаполнено(language) Тогда
		
		ВремяОжиданияКарты = 30;
		
		Если Не ЗначениеЗаполнено(АдресСервера) ТОгда
			АдресСервера = "localhost:XXXX";
		КонецЕсли;	                         
		Если Не ЗначениеЗаполнено(ApiVersion) ТОгда
			ApiVersion = "v107";
		КонецЕсли;	                         
		Если Не ЗначениеЗаполнено(licenseToken) ТОгда
			licenseToken = "e034d5a6cf3212826c57f35cffb103905afe5936/f86419d06688b6336ddfe68dc00c214b9b83fb10";
		КонецЕсли;	                         
		Если Не ЗначениеЗаполнено(TerminalAlias) ТОгда
			TerminalAlias = "TerminalAlias";
		КонецЕсли;	                         
		
		Если Не ЗначениеЗаполнено(operatorId) ТОгда
			operatorId = "001";
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(operatorName) ТОгда
			operatorName = "Operator";	
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(language) ТОгда
			language = "EN";
		КонецЕсли;	                         
		
		Если Не ЗначениеЗаполнено(idleText_LockDevice) ТОгда
			idleText_LockDevice = "Welcome!!!";
		КонецЕсли;	                         
		Если Не ЗначениеЗаполнено(idleText_UnlockDevice) ТОгда
			idleText_UnlockDevice = "Be ready!!!";
		КонецЕсли;	                         
		
		Для Каждого Стр из КарточнаяТехника Цикл
			Стр.Пометка = Истина;
		КонецЦикла;	
		Для Каждого Стр из НосителиИсточникаТранзакций Цикл
			Стр.Пометка = Истина;
		КонецЦикла;	
		
	КонецЕсли;	
											
КонецПроцедуры

// Процедура - обработчик события "Перед открытием" формы.
//
// Параметры:
//  Отказ                - <Булево>
//                       - Признак отказа от открытия формы. Если в теле
//                         процедуры-обработчика установить данному параметру
//                         значение Истина, открытие формы выполнено не будет.
//                         Значение по умолчанию: Ложь 
//
//  СтандартнаяОбработка - <Булево>
//                       - В данный параметр передается признак выполнения
//                         стандартной (системной) обработки события. Если в
//                         теле процедуры-обработчика установить данному
//                         параметру значение Ложь, стандартная обработка
//                         события производиться не будет. Отказ от стандартной
//                         обработки не отменяет открытие формы.
//                         Значение по умолчанию: Истина 
//
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	СписокЯзыков = TransLinkRESTAPI.ПолучитьСписокПоддерживаемыхЯзыков();
	Для Каждого КодЯзыка из СписокЯзыков Цикл
		Элементы.Язык.СписокВыбора.Добавить(КодЯзыка.Ключ,КодЯзыка.Значение);
	КонецЦикла;
	
	СписокВалют = TransLinkRESTAPI.ПолучитьСписокПоддерживаемыхВалют();
	Для Каждого КодВалюты из СписокВалют Цикл
		Элементы.currencyCode.СписокВыбора.Добавить(КодВалюты.Ключ,КодВалюты.Значение);
	КонецЦикла;
	
	ОбновитьИнформациюОДрайвере();
	
	УправлениеВидимостью();
	
КонецПроцедуры

