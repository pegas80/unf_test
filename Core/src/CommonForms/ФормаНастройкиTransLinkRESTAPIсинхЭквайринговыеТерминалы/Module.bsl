&НаКлиенте
Процедура ЗакрытьДокумент(Команда)

	ПараметрыФормы = Новый Структура();
	ПараметрыФормы.Вставить("Сумма", 100);
	ПараметрыФормы.Вставить("ПределСуммы", 100);
	ПараметрыФормы.Вставить("УказатьДополнительныеДанные", Истина);
	ПараметрыФормы.Вставить("СписокТиповКарт", Новый СписокЗначений());
	Индекс = 0; 
	СписокКарт = ПолучитьСписокВидовКартТерминала(Идентификатор);
	Для каждого ВидКарты Из СписокКарт Цикл
		ПараметрыФормы.СписокТиповКарт.Добавить(Индекс, ВидКарты.Значение);
		Индекс = Индекс + 1;
	КонецЦикла;
	
	Результат = Неопределено;
	НомерКарты = "";
	ИдентификаторУстройстваЭТ = Идентификатор;
	ИдентификаторУстройстваФР = Неопределено;
	
	ДополнительныеПараметры = Новый Структура(
		"ИдентификаторУстройстваФР, ИдентификаторУстройстваЭТ, НомерКарты",
		ИдентификаторУстройстваФР, ИдентификаторУстройстваЭТ, НомерКарты
		);
	
	ОписаниеЗавершения = Новый ОписаниеОповещения("ВыполнитьЗакрытиеДокумента_Завершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму("Справочник.ПодключаемоеОборудование.Форма.ФормаАвторизацииЭТ", ПараметрыФормы,,,,,ОписаниеЗавершения);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьСписокВидовКартТерминала(ИдентификаторУстройстваЭТ)
	
	Результат = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Если Метаданные.Справочники.Найти("ЭквайринговыеТерминалы") <> Неопределено Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЭквайринговыеТерминалыВидыПлатежныхКарт.ВидПлатежнойКарты КАК ВидПлатежнойКарты
		|ИЗ
		|	Справочник.ЭквайринговыеТерминалы.ВидыПлатежныхКарт КАК ЭквайринговыеТерминалыВидыПлатежныхКарт
		|ГДЕ
		|	ЭквайринговыеТерминалыВидыПлатежныхКарт.Ссылка.ПодключаемоеОборудование = &ПодключаемоеОборудование";
		Запрос.УстановитьПараметр("ПодключаемоеОборудование", ИдентификаторУстройстваЭТ);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Результат.Добавить(Выборка.ВидПлатежнойКарты);
		КонецЦикла;	                                      
	Иначе 
		Результат.Добавить(ИдентификаторУстройстваЭТ);
	КонецЕсли;
	
	Возврат Результат;

КонецФункции // ПолучитьСписокКартТерминала()


&НаКлиенте
Процедура ВыполнитьЗакрытиеДокумента_Завершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Результат.СсылочныйНомер = СокрЛП(Результат.СсылочныйНомер);
	Результат.НомерЧека = СокрЛП(Результат.НомерЧека);
	
	Если не ЗначениеЗаполнено(Результат.НомерЧека) Тогда
		Сообщить("Ошибка: Номер чека не заполнен");
		Возврат;
	КонецЕсли;	
	Если не ЗначениеЗаполнено(Результат.СсылочныйНомер) Тогда
		Сообщить("Ошибка: Ссылочный номер не заполнен");
		Возврат;
	КонецЕсли;	
	
	
	РезультатТеста = Неопределено;

	ВходныеПараметры  = Новый Структура("СсылочныйНомер, НомерЧека", Результат.СсылочныйНомер, Результат.НомерЧека);
	
	ВыходныеПараметры = Неопределено;
	
	времПараметрыУстройства = ПоместитьВсеПараметрыВСтруктуру();
	
	
	Результат = МенеджерОборудованияКлиент.ВыполнитьДополнительнуюКоманду("CloseDoc",
	                                                                      ВходныеПараметры,
	                                                                      ВыходныеПараметры,
	                                                                      Идентификатор,
	                                                                      времПараметрыУстройства);

	ДополнительноеОписание = ?(ТипЗнч(ВыходныеПараметры) = Тип("Массив")
	                           И ВыходныеПараметры.Количество(),
	                           НСтр("ka='დამატებითი აღწერილობა:';ru='Дополнительное описание:'") + " " + ВыходныеПараметры[1],
	                           "");
							   
							   
	Если Результат Тогда
		ТекстСообщения = НСтр("ka='დოკუმენტი წარმატებით დაიხურა';ru='Документ закрыт успешно.'");
		ПоказатьОповещениеПользователя("Закрыть документ",,ТекстСообщения,БиблиотекаКартинок.ОформлениеЗнакФлажок,СтатусОповещенияПользователя.Информация);	
		
	Иначе
		ТекстСообщения = НСтр("ka='დახურვა ვერ მოხერხდა';ru='Закрытие не выполнено.'");
	    ПоказатьОповещениеПользователя("Закрыть документ",,ТекстСообщения,БиблиотекаКартинок.ОформлениеЗнакКрест,СтатусОповещенияПользователя.Информация);	
	КонецЕсли;
	

КонецПроцедуры

