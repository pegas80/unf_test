// Процедура представляет обработчик события "Нажатие" кнопки
// "ОК" командной панели "ОсновныеДействияФормы".
//
// Параметры:
//  Кнопка - <КнопкаКоманднойПанели>
//         - Кнопка, с которой связано данное событие (кнопка "ОК").
//
&НаКлиенте
Процедура ЗаписатьИЗакрытьВыполнить()

	НовыеЗначениеПараметров = ПоместитьВсеПараметрыВСтруктуру();
	
	Результат = Новый Структура;
	Результат.Вставить("Идентификатор", Идентификатор);
	Результат.Вставить("ПараметрыОборудования", НовыеЗначениеПараметров);
	
	Закрыть(Результат);

КонецПроцедуры

&НаКлиенте
Функция ПоместитьВсеПараметрыВСтруктуру()
	
	НовыеЗначениеПараметров = Новый Структура;
	
	НовыеЗначениеПараметров.Вставить("Наименование"   , Наименование);
	НовыеЗначениеПараметров.Вставить("БанкТерминала"  , БанкТерминала);
	НовыеЗначениеПараметров.Вставить("ЗапретВозвратаЧастичнуюСуммуНаТерминале"  , ЗапретВозвратаЧастичнуюСуммуНаТерминале);
	НовыеЗначениеПараметров.Вставить("TerminalAlias"  , TerminalAlias);
	НовыеЗначениеПараметров.Вставить("ИспользоватьTranslinkДляТерминала"  , ИспользоватьTranslinkДляТерминала);
	НовыеЗначениеПараметров.Вставить("ПечатьСлипНаТерминале"  , ПечатьСлипНаТерминале);
	
	//Малышев 2024-07-19 ONESOFT-3343 (--
	НовыеЗначениеПараметров.Вставить("АдресСервера"  , АдресСервера);
	НовыеЗначениеПараметров.Вставить("licenseToken"  , licenseToken);
	НовыеЗначениеПараметров.Вставить("ЗащищенноеСоединение"  , ЗащищенноеСоединение);
	НовыеЗначениеПараметров.Вставить("ApiVersion"  , ApiVersion);
	
	НовыеЗначениеПараметров.Вставить("language"  , language);
	НовыеЗначениеПараметров.Вставить("idleText_LockDevice"  , idleText_LockDevice);
	НовыеЗначениеПараметров.Вставить("idleText_UnlockDevice"  , idleText_UnlockDevice);
	НовыеЗначениеПараметров.Вставить("operatorId"  , operatorId);
	НовыеЗначениеПараметров.Вставить("operatorName"  , operatorName);
	НовыеЗначениеПараметров.Вставить("silentCardRead"  , silentCardRead);
	НовыеЗначениеПараметров.Вставить("currencyCode"  , currencyCode);
	
	НовыеЗначениеПараметров.Вставить("Логировать"  , Логировать);
	НовыеЗначениеПараметров.Вставить("ПутьЛогирования"  , ПутьЛогирования);
	НовыеЗначениеПараметров.Вставить("Отладка"  , Отладка);
	НовыеЗначениеПараметров.Вставить("ГолосовоеОповещение"  , ГолосовоеОповещение);
	НовыеЗначениеПараметров.Вставить("СкрытьИзСпискаВыбора"  , СкрытьИзСпискаВыбора);
    НовыеЗначениеПараметров.Вставить("ВремяОжиданияКарты"  , ВремяОжиданияКарты);
    НовыеЗначениеПараметров.Вставить("ПредлагатьПовторитьОперациюОжидания"  , ПредлагатьПовторитьОперациюОжидания);
 	
	cardTechs = Новый Массив;
	Если не КарточнаяТехникаВсе ТОгда
		Для каждого СтрЭлемента из КарточнаяТехника Цикл
			Если СтрЭлемента.Пометка Тогда
				cardTechs.Добавить(СтрЭлемента.Значение);	
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;
	НовыеЗначениеПараметров.Вставить("cardTechs"  , cardTechs);
	
	enabledTranSourceMedias = Новый Массив;
	Если не НосителиТранзакцийВсе Тогда
		Для каждого СтрЭлемента из НосителиИсточникаТранзакций Цикл
			Если СтрЭлемента.Пометка Тогда
				enabledTranSourceMedias.Добавить(СтрЭлемента.Значение);	
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;
	НовыеЗначениеПараметров.Вставить("enabledTranSourceMedias"  , enabledTranSourceMedias);
	
	//Малышев 2024-07-19 ONESOFT-3343 --)

	Возврат НовыеЗначениеПараметров;
КонецФункции	


&НаКлиенте
Процедура УстановитьДрайвер(Команда)

	ОчиститьСообщения();
	
	ТекстСообщения = НСтр("ka='ამ კომუნიკაციის მეთოდისთვის დრაივერის ინსტალაცია არ არის საჭირო.';ru='Для данного способа связи устанавливать драйвер не требуется.'");
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
 	
	ОбновитьИнформациюОДрайвере();

КонецПроцедуры

&НаКлиенте
Процедура ТестУстройства(Команда)

	РезультатТеста = Неопределено;

	ВходныеПараметры  = Неопределено;
	ВыходныеПараметры = Неопределено;
	
	времПараметрыУстройства = ПоместитьВсеПараметрыВСтруктуру();
	
	
	Результат = МенеджерОборудованияКлиент.ВыполнитьДополнительнуюКоманду("CheckHealth",
	                                                                      ВходныеПараметры,
	                                                                      ВыходныеПараметры,
	                                                                      Идентификатор,
	                                                                      времПараметрыУстройства);

	ДополнительноеОписание = ?(ТипЗнч(ВыходныеПараметры) = Тип("Массив")
	                           И ВыходныеПараметры.Количество(),
	                           НСтр("ka='დამატებითი აღწერილობა:';ru='Дополнительное описание:'") + " " + ВыходныеПараметры[1],
	                           "");
							   
							   
	Если Результат Тогда
		ТекстСообщения = НСтр("ka='ტესტი შესრულებულია წარმატებით.%ПереводСтроки%%ДополнительноеОписание%';ru='Тест успешно выполнен.%ПереводСтроки%%ДополнительноеОписание%'");
		
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ПереводСтроки%", ?(ПустаяСтрока(ДополнительноеОписание),
		                                                                  "",
		                                                                  Символы.ПС));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ?(ПустаяСтрока(ДополнительноеОписание),
		                                                                           "",
		                                                                           ДополнительноеОписание));
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	Иначе
		ТекстСообщения = НСтр("ka='ტესტი არ არის ჩაბარებული.%ПереводСтроки%%ДополнительноеОписание%';ru='Тест не пройден.%ПереводСтроки%%ДополнительноеОписание%'");
	
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ПереводСтроки%", ?(ПустаяСтрока(ДополнительноеОписание),
		                                                                  "",
		                                                                  Символы.ПС));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДополнительноеОписание%", ?(ПустаяСтрока(ДополнительноеОписание),
		                                                                           "",
		                                                                           ДополнительноеОписание));
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
	РезультатТестирования = ТекстСообщения;						   
	ЭтаФорма.ТекущийЭлемент = Элементы.ГруппаРезультатТестирования;
	
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ

&НаКлиенте
Процедура ОбновитьИнформациюОДрайвере()

	ВходныеПараметры  = Неопределено;
	ВыходныеПараметры = Неопределено;

	времПараметрыУстройства = ПоместитьВсеПараметрыВСтруктуру();

	Если МенеджерОборудованияКлиент.ВыполнитьДополнительнуюКоманду("ПолучитьВерсиюДрайвера",
	                                                               ВходныеПараметры,
	                                                               ВыходныеПараметры,
	                                                               Идентификатор,
	                                                               времПараметрыУстройства) Тогда
		Если ВыходныеПараметры.Количество()>=2 Тогда														   
			Драйвер = ВыходныеПараметры[0];
			Версия  = ВыходныеПараметры[1];
		КонецЕсли;	
	Иначе
		Драйвер = ВыходныеПараметры[2];
		Версия  = НСтр("ka='არ არის განსაზღვრული';ru='Не определена'");
	КонецЕсли;

	Элементы.Драйвер.ЦветТекста = ?(Драйвер = НСтр("ka='არ არის დაყენებული';ru='Не установлен'"), ЦветОшибки, ЦветТекста);
	Элементы.Версия.ЦветТекста  = ?(Версия  = НСтр("ka='არ არის განსაზღვრული';ru='Не определена'"), ЦветОшибки, ЦветТекста);

	Элементы.УстановитьДрайвер.Доступность = Не (Драйвер = НСтр("ka='დაყენებულია';ru='Установлен'"));

КонецПроцедуры

&НаСервере
Функция ВозвратИсползованиеНесколькоЭквайринговыхТерминалов()
	
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	|	НастройкиРМКЭквайринговыеТерминалы.ЭквайринговыйТерминал,
	|	НастройкиРМКЭквайринговыеТерминалы.ПодключаемоеОборудование
	|ИЗ
	|	Справочник.НастройкиРМК.ЭквайринговыеТерминалы КАК НастройкиРМКЭквайринговыеТерминалы
	|ГДЕ
	|	НЕ НастройкиРМКЭквайринговыеТерминалы.ИспользоватьБезПодключенияОборудования
	|	И НЕ НастройкиРМКЭквайринговыеТерминалы.Ссылка.ПометкаУдаления
	|	И НастройкиРМКЭквайринговыеТерминалы.Ссылка.РабочееМесто = &РабочееМесто
	|
	|СГРУППИРОВАТЬ ПО
	|	НастройкиРМКЭквайринговыеТерминалы.ЭквайринговыйТерминал,
	|	НастройкиРМКЭквайринговыеТерминалы.ПодключаемоеОборудование";
	
	Запрос.УстановитьПараметр("РабочееМесто", МенеджерОборудованияВызовСервера.ПолучитьРабочееМестоКлиента());
	Таб = Запрос.Выполнить().Выгрузить();
	
	Если Таб.Количество() > 1 Тогда 
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
		
КонецФункции

