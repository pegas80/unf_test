КонецФункции // ()


&НаКлиенте
Процедура ПолучитьСправочники()

	КоллекцияСправочников = ПолучитьСправочникиСервер();
	
	Элементы.Справочники.Заголовок = "Справочники";
	
	Элементы.Справочники.Заголовок = Элементы.Справочники.Заголовок + " ("+КоллекцияСправочников.Количество()+")";
	
	ТЗСправочники.Очистить();
	
	Номер = 1;
    Для каждого ЭлементСоответствия Из КоллекцияСправочников Цикл
		
		Колич = ЭлементСоответствия.Значение.Количество;
		
		Если флагНеПоказыватьПустые И Колич = 0 Тогда
			
			Продолжить;
			
		КонецЕсли;
	
		СтрокаТЗ = ТЗСправочники.Добавить();
		СтрокаТЗ.Номер = Номер;
		СтрокаТЗ.Справочник = ЭлементСоответствия.Ключ;
		СтрокаТЗ.Представление = ЭлементСоответствия.Значение.Синоним;
		СтрокаТЗ.Количество = ЭлементСоответствия.Значение.Количество;
		СтрокаТЗ.ПомеченоНаУдаление = ЭлементСоответствия.Значение.ПомеченныеНаУдаление;
		СтрокаТЗ.Предопределенные = ЭлементСоответствия.Значение.Предопределенные;
		СтрокаТЗ.ЭтоГруппа = ЭлементСоответствия.Значение.Группы;
		СтрокаТЗ.Иерархический = ЭлементСоответствия.Значение.Иерархический;
		
		Номер = Номер + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСправочникиСервер()

	ТекТипы = Справочники.ТипВсеСсылки();
    МассивТипов = ТекТипы.Типы();
	Запрос = Новый Запрос;
	
	СоответствиеСправочники = Новый Соответствие;
	
    Для каждого Спр Из МассивТипов Цикл
	
		СпрОбъект = Метаданные.НайтиПоТипу(Спр);
		
		ПредставлениеСправочника = СпрОбъект.Имя;
		
		Если СпрОбъект.Иерархический И СпрОбъект.ВидИерархии = Метаданные.СвойстваОбъектов.ВидИерархии.ИерархияГруппИЭлементов Тогда
			
			СтрокаЗапроса = 
			"ВЫБРАТЬ        
			|	КОЛИЧЕСТВО(*) КАК КоличествоВсего,
			|	СУММА(ВЫБОР
			|			КОГДА " + ПредставлениеСправочника + ".ПометкаУдаления
			|				ТОГДА 1
			|			ИНАЧЕ 0
			|		КОНЕЦ) КАК КоличествоПомеченныхНаУдаление,
			|	СУММА(ВЫБОР
			|			КОГДА " + ПредставлениеСправочника + ".Предопределенный
			|				ТОГДА 1
			|			ИНАЧЕ 0
			|		КОНЕЦ) КАК КоличествоПредопределенных,
			|	СУММА(ВЫБОР
			|			КОГДА " + ПредставлениеСправочника + ".ЭтоГруппа
			|				ТОГДА 1
			|			ИНАЧЕ 0
			|		КОНЕЦ) КАК КоличествоГрупп
			|ИЗ
			|	Справочник." + ПредставлениеСправочника +" КАК " + ПредставлениеСправочника +"
			|";
			
		Иначе
			
			СтрокаЗапроса = 
			"ВЫБРАТЬ        
			|	КОЛИЧЕСТВО(*) КАК КоличествоВсего,
			|	СУММА(ВЫБОР
			|			КОГДА " + ПредставлениеСправочника + ".ПометкаУдаления
			|				ТОГДА 1
			|			ИНАЧЕ 0
			|		КОНЕЦ) КАК КоличествоПомеченныхНаУдаление,
			|	СУММА(ВЫБОР
			|			КОГДА " + ПредставлениеСправочника + ".Предопределенный
			|				ТОГДА 1
			|			ИНАЧЕ 0
			|		КОНЕЦ) КАК КоличествоПредопределенных,
			|	СУММА(0) КАК КоличествоГрупп
			|ИЗ
			|	Справочник." + ПредставлениеСправочника +" КАК " + ПредставлениеСправочника +"
			|";
			
		КонецЕсли;
		
		Запрос.Текст = СтрокаЗапроса;
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Выборка.Следующий();
		
		Количество = Выборка.КоличествоВсего;
		
		СтруктураПараметровСправочника = Новый Структура();
		
		СтруктураПараметровСправочника.Вставить("Имя", СпрОбъект.Имя);
		СтруктураПараметровСправочника.Вставить("Синоним", СпрОбъект.Представление());
		
		СтруктураПараметровСправочника.Вставить("Количество", Количество);
		
		СтруктураПараметровСправочника.Вставить("ПомеченныеНаУдаление", Выборка.КоличествоПомеченныхНаУдаление);
		
		СтруктураПараметровСправочника.Вставить("Предопределенные", Выборка.КоличествоПредопределенных);
		
		СтруктураПараметровСправочника.Вставить("Группы", Выборка.КоличествоГрупп);
		
