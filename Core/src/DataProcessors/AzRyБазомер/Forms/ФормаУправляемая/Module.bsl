Процедура ПроверитьСброситьФлагДляВсех()

	флагиВсеУстановлены = флагКонстанты И 
						  флагДокументы И 
						  флагСправочники И 
						  флагПеречисления И 
						  флагРегистрыНакопления И 
						  флагРегистрыБухгалтерии И 
						  флагРегистрыСведений И 
						  флагОбщиеМодули И
						  флагПланыОбмена И
						  флагОтчеты И
						  флагОбработки;
	флагДляВсех = ?(флагиВсеУстановлены, Истина, Ложь);

КонецПроцедуры


&НаКлиенте
Процедура УдалитьСтрокиДерева(Команда)
	
	ЭлементыПервыйУровень = ДЗПеречисления.ПолучитьЭлементы();
	Счетчик = ЭлементыПервыйУровень.Количество() - 1;
	
	Пока Счетчик >= 0 Цикл
	
		ЭлементыПервыйУровень.Удалить(0);
		Счетчик = Счетчик - 1;
	
	КонецЦикла;
	
