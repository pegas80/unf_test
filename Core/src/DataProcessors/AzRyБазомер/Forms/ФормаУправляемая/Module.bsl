&НаСервере
Функция ПолучитьДокументыСервер()

	ТекТипы = Документы.ТипВсеСсылки();
    МассивТипов = ТекТипы.Типы();
	Запрос = Новый Запрос;
	
	СоответствиеДокументы = Новый Соответствие;
	
    Для каждого Док Из МассивТипов Цикл
				
		ДокОбъект = Метаданные.НайтиПоТипу(Док);
		
		Если ДокОбъект.Имя = "ПоказателиЕНВД" Тогда
			Продолжить;
		КонецЕсли; 
		
		ПредставлениеДокумента = ДокОбъект.Имя;
		
		Если ПредставлениеДокумента = "РаспределениеЗатрат" Тогда 
			Продолжить;
		КонецЕсли;	
		
		СтрокаЗапроса = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(*) КАК КоличествоВсего,
		|	СУММА(ВЫБОР
		|			КОГДА " + ПредставлениеДокумента + ".Проведен
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК КоличествоПроведенных,
		|	СУММА(ВЫБОР
		|			КОГДА " + ПредставлениеДокумента + ".ПометкаУдаления
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК КоличествоПомеченныхНаУдаление
		|ИЗ
		|	Документ." + ПредставлениеДокумента + " КАК " + ПредставлениеДокумента + "
		|";
		
		Если ЗначениеЗаполнено(Организация) Тогда
			СтрокаЗапроса = СтрокаЗапроса + ?(Метаданные.Документы[ПредставлениеДокумента].Реквизиты.Найти("Организация") <> Неопределено, " ГДЕ "+ПредставлениеДокумента+".Организация = &Организация ", "");		
		КонецЕсли; 
		
		Запрос.Текст = СтрокаЗапроса;
		Запрос.Параметры.Вставить("Организация", Организация);
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Выборка.Следующий();
		
		Количество = Выборка.КоличествоВсего;
		
		СтруктураПараметровДокумента = Новый Структура();
		
		СтруктураПараметровДокумента.Вставить("Имя", ДокОбъект.Имя);
		СтруктураПараметровДокумента.Вставить("Синоним", ДокОбъект.Представление());
		
		СтруктураПараметровДокумента.Вставить("Количество", Количество);
		
		СтруктураПараметровДокумента.Вставить("ПомеченныеНаУдаление", Выборка.КоличествоПомеченныхНаУдаление);
		
		СтруктураПараметровДокумента.Вставить("Проведено", Выборка.КоличествоПроведенных);
		
		СоответствиеДокументы.Вставить(ДокОбъект.Имя, СтруктураПараметровДокумента);
	
	КонецЦикла;
	
	Возврат СоответствиеДокументы;

КонецФункции // ПолучитьДокументыСервер()

