&НаКлиенте
Процедура ОбновитьЗаголовкиСтраниц(СтрокаОбъект)
		
	ПозицияСкобки = Найти(Элементы[СтрокаОбъект].Заголовок, "(");
	
	Если НЕ ПозицияСкобки = 0 Тогда
		
		Элементы[СтрокаОбъект].Заголовок = СокрЛП(Лев(Элементы[СтрокаОбъект].Заголовок, ПозицияСкобки-1));
		
	КонецЕсли;

КонецПроцедуры


&НаКлиенте
Процедура КомандаОчистить(Команда)
	
	Если флагДляВсех Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		Ответ = Вопрос("Очистить все табличные части?", Режим, 0, КодВозвратаДиалога.Нет, "Внимание!");
		
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			
			Возврат;
			
		КонецЕсли;
		
		ТЗСправочники.Очистить();
		
		ТЗДокументы.Очистить();
		
		ТЗРегистрыСведений.Очистить();
		
		ТЗРегистрыНакопления.Очистить();
		УдалитьСтрокиДерева("");
		ТЗОбщиеМодули.Очистить();
		ТЗПланыОбмена.Очистить();
		ТЗОтчеты.Очистить();
		ТЗОбработки.Очистить();
		
		ОбновитьЗаголовкиСтраниц("Справочники");
		ОбновитьЗаголовкиСтраниц("Документы");
		ОбновитьЗаголовкиСтраниц("РегистрыСведений");
		ОбновитьЗаголовкиСтраниц("РегистрыНакопления");
		ОбновитьЗаголовкиСтраниц("Перечисления");
		ОбновитьЗаголовкиСтраниц("ОбщиеМодули");
		ОбновитьЗаголовкиСтраниц("ПланыОбмена");
		ОбновитьЗаголовкиСтраниц("Отчеты");
		ОбновитьЗаголовкиСтраниц("Обработки");
		
	Иначе
		
		Режим = РежимДиалогаВопрос.ДаНет;
		
		Ответ = Вопрос("Очистить выбранные табличные части?", Режим, 0, КодВозвратаДиалога.Нет, "Внимание!");
		
		Если Ответ = КодВозвратаДиалога.Нет Тогда
			
			Возврат;
			
		КонецЕсли;
		
		Если флагСправочники Тогда
			
			ТЗСправочники.Очистить();
			ОбновитьЗаголовкиСтраниц("Справочники");
			
		КонецЕсли;
		
		Если флагДокументы Тогда
			
			ТЗДокументы.Очистить();
			ОбновитьЗаголовкиСтраниц("Документы");
			
		КонецЕсли;
		
		Если флагРегистрыСведений Тогда
			
			ТЗРегистрыСведений.Очистить();
			ОбновитьЗаголовкиСтраниц("РегистрыСведений");
			
		КонецЕсли;
		
		Если флагРегистрыНакопления Тогда
			
			ТЗРегистрыНакопления.Очистить();
			ОбновитьЗаголовкиСтраниц("РегистрыНакопления");
			
		КонецЕсли;
		
		Если флагПеречисления Тогда
			
			УдалитьСтрокиДерева("");
			ОбновитьЗаголовкиСтраниц("Перечисления");
			
		КонецЕсли;
		
		Если флагОбщиеМодули Тогда
			
			ТЗОбщиеМодули.Очистить();
			ОбновитьЗаголовкиСтраниц("ОбщиеМодули");
			
		КонецЕсли;
		
		Если флагПланыОбмена Тогда
			
			ТЗПланыОбмена.Очистить();
			ОбновитьЗаголовкиСтраниц("ПланыОбмена");
			
		КонецЕсли;
		
		Если флагОтчеты Тогда
			
			ТЗОтчеты.Очистить();
			ОбновитьЗаголовкиСтраниц("Отчеты");
			
		КонецЕсли;
		
		Если флагОбработки Тогда
			
			ТЗОбработки.Очистить();
			ОбновитьЗаголовкиСтраниц("Обработки");
			
		КонецЕсли;
		
    КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ТЗВыбранныеПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	Если Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.Справочники 
		ИЛИ 
		Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.Документы
		ИЛИ
		Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.РегистрыНакопления
		ИЛИ 
		Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.РегистрыСведений
		Тогда
		
		Для каждого ТекЗначение Из ПараметрыПеретаскивания.Значение Цикл
			
			НоваяСтрока = ТЗВыбранные.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекЗначение);
			Если Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.Справочники Тогда
				
				НоваяСтрока.Объект = ТекЗначение.Справочник;
				
			ИначеЕсли Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.Документы Тогда	
				
				НоваяСтрока.Объект = ТекЗначение.Документ;
				
			ИначеЕсли Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.РегистрыНакопления Тогда	
				
				НоваяСтрока.Объект = ТекЗначение.РН;
				
			ИначеЕсли Элементы.ГруппаОбъектыМетаданных.ТекущаяСтраница = Элементы.ГруппаОбъектыМетаданных.ПодчиненныеЭлементы.РегистрыСведений Тогда	
				
				НоваяСтрока.Объект = ТекЗначение.РС;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

