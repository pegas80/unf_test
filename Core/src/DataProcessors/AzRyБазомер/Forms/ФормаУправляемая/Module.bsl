Функция ПолучитьРегистрыНакопленияСервер()

	Запрос = Новый Запрос;
	
	РНОбъект = Метаданные.РегистрыНакопления;
	СоответствиеРН = Новый Соответствие;
	Для каждого РН Из РНОбъект Цикл
		
		Инд = РНОбъект.Индекс(РН);
		ПредставлениеРН = РНОбъект[Инд].Имя;
		
		СтрокаЗапроса = "Выбрать Количество(*) КАК КолВо Из РегистрНакопления." + ПредставлениеРН;
		
		Запрос.Текст = СтрокаЗапроса;
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Выборка.Следующий();
		
		Количество = Выборка.КолВо;
		
		СтруктураРН = Новый Структура;
		СтруктураРН.Вставить("Количество", Количество);
		СтруктураРН.Вставить("Синоним", РНОбъект[Инд].Представление());
		
		Если РНОбъект[Инд].ВидРегистра = Метаданные.СвойстваОбъектов.ВидРегистраНакопления.Остатки Тогда
			
			СтруктураРН.Вставить("Вид", "Остатки");
			
			Рез = ?(РегистрыНакопления[РНОбъект[Инд].Имя].ПолучитьИспользованиеИтогов(), "Исп. Итоги", "Не исп. Итоги");
			
			ДатаИтогов = РегистрыНакопления[РНОбъект[Инд].Имя].ПолучитьПериодРассчитанныхИтогов();
			
		    СтруктураРН.Вставить("ИспользованиеИтоговАгрегатов", Рез);
			СтруктураРН.Вставить("ДатаИтогов", ДатаИтогов);
			
			СтруктураРН.Вставить("ИспользованиеТекущихИтогов", РегистрыНакопления[РНОбъект[Инд].Имя].ПолучитьИспользованиеТекущихИтогов());
			
		Иначе
			
			СтруктураРН.Вставить("Вид", "Обороты");
			
			Рез = ?(РегистрыНакопления[РНОбъект[Инд].Имя].ПолучитьИспользованиеАгрегатов(), "Исп. Агрегаты", "Не исп. Агрегаты");
			
			СтруктураРН.Вставить("ИспользованиеИтоговАгрегатов", Рез);
			
			ДатаИтогов = '00010101';
			
			СтруктураРН.Вставить("ДатаИтогов", ДатаИтогов);
			
			СтруктураРН.Вставить("ИспользованиеТекущихИтогов", "Нет");
			
		КонецЕсли;
		
		СтруктураРН.Вставить("РазделениеИтогов", РНОбъект[Инд].РазрешитьРазделениеИтогов);
		СтруктураРН.Вставить("ЕстьАгрегаты", ?(РНОбъект[Инд].Агрегаты.Количество(), Истина, Ложь));
		
		
		
		СоответствиеРН.Вставить(ПредставлениеРН, СтруктураРН);
		
	КонецЦикла;
	
	Возврат СоответствиеРН;

КонецФункции // ()

