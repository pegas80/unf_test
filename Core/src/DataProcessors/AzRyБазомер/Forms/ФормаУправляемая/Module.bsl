&НаКлиенте
Процедура ПолучитьПланыОбмена()

	КоллекцияПлановОбмена = ПолучитьПланыОбменаСервер();

	Элементы.ПланыОбмена.Заголовок = "Планы обмена";
	
	Элементы.ПланыОбмена.Заголовок = Элементы.ПланыОбмена.Заголовок + " (" + КоллекцияПлановОбмена.Количество() + ")";
	
	ТЗПланыОбмена.Очистить();
	
	Для каждого ПланОбмена Из КоллекцияПлановОбмена Цикл
	
		СтрокаТЗ = ТЗПланыОбмена.Добавить();
		СтрокаТЗ.ИмяПланаОбмена = ПланОбмена.Ключ;
		
		СтрокаТЗ.Представление = ПланОбмена.Значение.Синоним;
		СтрокаТЗ.РаспределеннаяИБ = ПланОбмена.Значение.РИБ;
	
