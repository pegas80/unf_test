
&НаКлиенте
Перем ТекСтрокаОписаниеСтруктурыМетаданных;
//Перем ТекСтрокаОписаниеИндексов1;

&НаКлиенте
Перем ТекСтрокаОписаниеИндексов1;


&НаКлиенте
Процедура ЗаполнитьМетаданные(Команда)
	
	Если флагКонстанты Тогда
	
		ПолучитьКонстанты();
		Если флагСортировка Тогда
		
			ТЗКонстанты.Сортировать("Константа Возр");
		
		КонецЕсли;
	
	КонецЕсли; 
	
	Если флагСправочники Тогда
		
		ПолучитьСправочники();
		Если флагСортировка Тогда
			
			ТЗСправочники.Сортировать("Количество Убыв");
			
		КонецЕсли;

	КонецЕсли;
	
	Если флагДокументы Тогда
		
		ПолучитьДокументы();
		Если флагСортировка Тогда
			
			ТЗДокументы.Сортировать("Количество Убыв");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если флагПеречисления Тогда
		
		ПолучитьПеречисления();
		
	КонецЕсли;    
	
	Если флагРегистрыСведений Тогда
		
		ПолучитьРегистрыСведений();
		Если флагСортировка Тогда
			
			ТЗРегистрыСведений.Сортировать("Количество Убыв");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если флагРегистрыНакопления Тогда
		
		ПолучитьРегистрыНакопления();
		Если флагСортировка Тогда
			
			ТЗРегистрыНакопления.Сортировать("Количество Убыв");
			
		КонецЕсли;
		
	КонецЕсли;    
	
	Если флагРегистрыБухгалтерии Тогда
		
		ПолучитьРегистрыБухгалтерии();
		Если флагСортировка Тогда
			
			ТЗРегистрыБухгалтерии.Сортировать("Количество Убыв");
			
		КонецЕсли;
		
	КонецЕсли;    
	
	
	Если флагОбщиеМодули Тогда
	
		ПолучитьОбщиеМодули();
	
	КонецЕсли;
	
	Если флагПланыОбмена Тогда
	
		ПолучитьПланыОбмена();
	
	КонецЕсли; 
	
	Если флагОтчеты Тогда
	
		ПолучитьОтчеты();
	
	КонецЕсли;
	
	Если флагОбработки Тогда
	
		ПолучитьОбработки();
	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьОтчеты()

	КоллекцияОтчетов = ПолучитьОтчетыСервер();

	Элементы.Отчеты.Заголовок = "Отчеты";
	
	Элементы.Отчеты.Заголовок = Элементы.Отчеты.Заголовок + " (" + КоллекцияОтчетов.Количество() + ")";
	
	ТЗОтчеты.Очистить();
	
	Для каждого Отчет Из КоллекцияОтчетов Цикл
	
		СтрокаТЗ = ТЗОтчеты.Добавить();
		СтрокаТЗ.Отчет = Отчет.Ключ;
		СтрокаТЗ.Представление = Отчет.Значение.Синоним;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОтчетыСервер()

	КоллекцияОтчетов = Метаданные.Отчеты;
	СоответствиеОтчетов = Новый Соответствие;
	Для каждого Отчет Из КоллекцияОтчетов Цикл
	
		СтруктураОтчета = Новый Структура;
		СтруктураОтчета.Вставить("Имя", Отчет.Имя);
		СтруктураОтчета.Вставить("Синоним", Отчет.Синоним);
		
		СоответствиеОтчетов.Вставить(Отчет.Имя, СтруктураОтчета);
		
	КонецЦикла;
	
	Возврат СоответствиеОтчетов;

КонецФункции 

