	ТЗКонстанты.Очистить();
	
	Номер = 1;
    Для каждого ЭлементСоответствия Из КоллекцияКонстант Цикл
	
		СтрокаТЗ = ТЗКонстанты.Добавить();
		СтрокаТЗ.Номер = Номер;
		СтрокаТЗ.Константа = ЭлементСоответствия.Ключ;
		СтрокаТЗ.Представление = ЭлементСоответствия.Значение.Синоним;
		
		Номер = Номер + 1;
		
