&НаСервере
Функция ПолучитьСтруктуруБДСервер(ИмяМетаданного)
	
	Если ЗначениеЗаполнено(ИмяМетаданного) Тогда
		
		МассивИмен = Новый Массив;
		МассивИмен.Добавить(ИмяМетаданного);
		
		ТЗ = ПолучитьСтруктуруХраненияБазыДанных(МассивИмен, ВТерминахСУБД);
		
		КореньДерева = ДеревоМетаданные.ПолучитьЭлементы();
		
		Если КореньДерева.Количество() Тогда
		
			КореньДерева.Очистить();
		
		КонецЕсли;
		
		Для каждого СтрокаТЗ Из ТЗ Цикл
			
			НСтрока = КореньДерева.Добавить();
			
			НСтрока.ИмяТаблицыХранения = СтрокаТЗ.ИмяТаблицыХранения;
			НСтрока.ИмяТаблицы = СтрокаТЗ.ИмяТаблицы;
			НСтрока.Метаданные = СтрокаТЗ.Метаданные;
			НСтрока.Назначение = СтрокаТЗ.Назначение;
			
			ВторойУровень = НСтрока.ПолучитьЭлементы();
			// Поля таблицы БД
			НСтрокаПоля = ВторойУровень.Добавить();
			НСтрокаПоля.ИмяТаблицыХранения = "Поля таблицы";
			
			ТретийУровень = НСтрокаПоля.ПолучитьЭлементы();
			
			Для каждого Поля Из СтрокаТЗ.Поля Цикл
			
				НовСтрокаПоля = ТретийУровень.Добавить();
				НовСтрокаПоля.ИмяТаблицыХранения = Поля.ИмяПоляХранения;
				НовСтрокаПоля.ИмяТаблицы = Поля.ИмяПоля;
				НовСтрокаПоля.Метаданные = Поля.Метаданные;
			
			КонецЦикла;
			
			// Индексы таблицы БД
			НСтрокаПоля = ВторойУровень.Добавить();
			НСтрокаПоля.ИмяТаблицыХранения = "Индексы таблицы";
			
			ИндексыДерева = НСтрокаПоля.ПолучитьЭлементы();
			
			Для каждого Инд Из СтрокаТЗ.Индексы Цикл
				
				НСтрокаИндекс = ИндексыДерева.Добавить();
				НСтрокаИндекс.ИмяТаблицыХранения = Инд.ИмяИндексаХранения;
				
				ПоляИндексаДерева = НСтрокаИндекс.ПолучитьЭлементы();
				Пол = ПоляИндексаДерева.Добавить();
				Пол.ИмяТаблицыХранения = "Поля индекса";
				
				ПоляИндексаДер = Пол.ПолучитьЭлементы();
				
				Для каждого ПолеИндекса Из Инд.Поля Цикл
					
					НСтрИндекс = ПоляИндексаДер.Добавить();
					НСтрИндекс.ИмяТаблицыХранения = ПолеИндекса.ИмяПоля;
					НСтрИндекс.ИмяТаблицы = ПолеИндекса.ИмяПоляХранения;
					НСтрИндекс.Метаданные = ПолеИндекса.Метаданные;
					
				КонецЦикла;
				
			КонецЦикла;
			
			
		КонецЦикла;
		
		Результат = 1;
		
		Возврат Результат;
		
	Иначе
		
		ТЗ = ПолучитьСтруктуруХраненияБазыДанных(, ВТерминахСУБД);
		
		ТЗ.Сортировать("ИмяТаблицыХранения");
		
		КореньДерева = ДеревоМетаданные.ПолучитьЭлементы();
		
		Если КореньДерева.Количество() Тогда
		
			КореньДерева.Очистить();
		
		КонецЕсли;
		
		Для каждого СтрокаТЗ Из ТЗ Цикл
			
			НСтрока = КореньДерева.Добавить();
			
			НСтрока.ИмяТаблицыХранения = СтрокаТЗ.ИмяТаблицыХранения;
			НСтрока.ИмяТаблицы = СтрокаТЗ.ИмяТаблицы;
			НСтрока.Метаданные = СтрокаТЗ.Метаданные;
			НСтрока.Назначение = СтрокаТЗ.Назначение;
			
			ВторойУровень = НСтрока.ПолучитьЭлементы();
			// Поля таблицы БД
			НСтрокаПоля = ВторойУровень.Добавить();
			НСтрокаПоля.ИмяТаблицыХранения = "Поля таблицы";
			
			ТретийУровень = НСтрокаПоля.ПолучитьЭлементы();
			
			Для каждого Поля Из СтрокаТЗ.Поля Цикл
			
				НовСтрокаПоля = ТретийУровень.Добавить();
				НовСтрокаПоля.ИмяТаблицыХранения = Поля.ИмяПоляХранения;
				НовСтрокаПоля.ИмяТаблицы = Поля.ИмяПоля;
				НовСтрокаПоля.Метаданные = Поля.Метаданные;
			
			КонецЦикла;
			
			// Индексы таблицы БД
			НСтрокаПоля = ВторойУровень.Добавить();
			НСтрокаПоля.ИмяТаблицыХранения = "Индексы таблицы";
			
			ИндексыДерева = НСтрокаПоля.ПолучитьЭлементы();
			
			Для каждого Инд Из СтрокаТЗ.Индексы Цикл
				
				НСтрокаИндекс = ИндексыДерева.Добавить();
				НСтрокаИндекс.ИмяТаблицыХранения = Инд.ИмяИндексаХранения;
				
				ПоляИндексаДерева = НСтрокаИндекс.ПолучитьЭлементы();
				Пол = ПоляИндексаДерева.Добавить();
				Пол.ИмяТаблицыХранения = "Поля индекса";
				
				ПоляИндексаДер = Пол.ПолучитьЭлементы();
				
				Для каждого ПолеИндекса Из Инд.Поля Цикл
					
					НСтрИндекс = ПоляИндексаДер.Добавить();
					НСтрИндекс.ИмяТаблицыХранения = ПолеИндекса.ИмяПоля;
					НСтрИндекс.ИмяТаблицы = ПолеИндекса.ИмяПоляХранения;
					НСтрИндекс.Метаданные = ПолеИндекса.Метаданные;
					
				КонецЦикла;
				
			КонецЦикла;
			
			
		КонецЦикла;
		
		
		Результат = 1;
		
		Возврат Результат;
	
	КонецЕсли;

КонецФункции // ПолучитьСтруктуруБДСервер()

&НаКлиенте
Процедура ДеревоМетаданныхПриАктивизацииСтроки(Элемент)
	
	Результат = ПолучитьРодителяЛиста(Элемент.ТекущаяСтрока);
	
	ИмяМетаданного = "";
	
	ОписаниеСтруктурыМетаданных.Очистить();
	
	Если Результат = "Планы обмена" Тогда
		
		ИмяМетаданного = "ПланОбмена."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Перечисления" Тогда	
		
		ИмяМетаданного = "Перечисление."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Справочники" Тогда	
		
		ИмяМетаданного = "Справочник."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Документы" Тогда	
		
		Если НЕ Элемент.ТекущиеДанные.ИмяОбъекта = "Последовательности" Тогда
		
			ИмяМетаданного = "Документ."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
		КонецЕсли;
		
	ИначеЕсли Результат = "Последовательности" Тогда	
		
		ИмяМетаданного = "Последовательность."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Журналы документов" Тогда	
		
		ИмяМетаданного = "ЖурналДокументов."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Планы видов характеристик" Тогда	
		
		ИмяМетаданного = "ПланВидовХарактеристик."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Регистры сведений" Тогда	
		
		ИмяМетаданного = "РегистрСведений."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Регистры накопления" Тогда	
		
		ИмяМетаданного = "РегистрНакопления."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Регистры бухгалтерии" Тогда	
		
		ИмяМетаданного = "РегистрБухгалтерии."+Элемент.ТекущиеДанные.ИмяОбъекта;
	
	ИначеЕсли Результат = "Регистры расчета" Тогда	
		
		ИмяМетаданного = "РегистрРасчета."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Бизнес-процессы" Тогда	
		
		ИмяМетаданного = "БизнесПроцесс."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Задачи" Тогда	
		
		ИмяМетаданного = "Задача."+Элемент.ТекущиеДанные.ИмяОбъекта;
		
	ИначеЕсли Результат = "Планы видов расчета" Тогда	
		
		ИмяМетаданного = "ПланВидовРасчета."+Элемент.ТекущиеДанные.ИмяОбъекта;
	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИмяМетаданного) Тогда
	
		ПолучитьСтруктуруБДСервер(ИмяМетаданного);
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьРодителяЛиста(Идентификатор)

	ЭлементДерева = ДеревоМетаданных.НайтиПоИдентификатору(Идентификатор);
	
	РодительЭлементаДерева = ЭлементДерева.ПолучитьРодителя();
	
	Возврат ?(РодительЭлементаДерева = Неопределено, "", РодительЭлементаДерева.ИмяОбъекта);
	
КонецФункции // ПолучитьРодителяЛиста()


