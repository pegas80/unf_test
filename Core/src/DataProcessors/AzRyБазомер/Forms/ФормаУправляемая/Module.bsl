&НаСервере
Процедура УдалитьНепредопределенныеСубконтоСервер(ИмяПланСчетов)

	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	"+ИмяПланСчетов+"ВидыСубконто.Ссылка КАК Счет,
	|	"+ИмяПланСчетов+"ВидыСубконто.ВидСубконто КАК Субконто,
	|	"+ИмяПланСчетов+"ВидыСубконто.НомерСтроки - 1 КАК ИндексСубконто
	|ИЗ
	|	ПланСчетов."+ИмяПланСчетов+".ВидыСубконто КАК "+ИмяПланСчетов+"ВидыСубконто
	|ГДЕ
	|	"+ИмяПланСчетов+"ВидыСубконто.Предопределенное = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	"+ИмяПланСчетов+"ВидыСубконто.Ссылка.Код";
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Для каждого СтрокаТЗ Из ТЗ Цикл
	
		СчетОбъект = СтрокаТЗ.Счет.ПолучитьОбъект();
		
		Попытка
			
			СчетОбъект.ВидыСубконто.Удалить(СчетОбъект.ВидыСубконто[СтрокаТЗ.ИндексСубконто]);
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = "Удалено субконто """+СтрокаТЗ.Субконто+""" счета: "+СтрокаТЗ.Счет;
			Сообщение.Сообщить();
	
		Исключение
			
		КонецПопытки;
		
		СчетОбъект.Записать();
		
	КонецЦикла;
	
