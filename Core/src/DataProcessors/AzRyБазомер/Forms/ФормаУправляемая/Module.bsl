Функция ПолучитьРегистрыСведенийСервер()

	Запрос = Новый Запрос;
	
	РСОбъект = Метаданные.РегистрыСведений;
	
	СоответствиеРС = Новый Соответствие;
	
	Для каждого РС Из РСОбъект Цикл
		
		Инд = РСОбъект.Индекс(РС);
		
		ПредставлениеРС = РСОбъект[Инд].Имя;
		
		СтрокаЗапроса = "Выбрать Количество(*) КАК КолВо Из РегистрСведений." + ПредставлениеРС;
		
		Запрос.Текст = СтрокаЗапроса;
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Выборка.Следующий();
		
		Количество = Выборка.КолВо;
		
		СтруктураРС = Новый Структура;
		
		СтруктураРС.Вставить("Количество", Количество);
		
		СтруктураРС.Вставить(РСОбъект[Инд].Имя, РСОбъект[Инд].Имя);
		СтруктураРС.Вставить("Синоним", РСОбъект[Инд].Представление());
		
		Если РСОбъект[Инд].ПериодичностьРегистраСведений = Метаданные.СвойстваОбъектов.ПериодичностьРегистраСведений.Непериодический Тогда
			
			СтруктураРС.Вставить("Периодичность","+");
			
		Иначе
			
			СтруктураРС.Вставить("Периодичность","");
			
		КонецЕсли;
		
		Если РСОбъект[Инд].РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору Тогда
			
			СтруктураРС.Вставить("Регистратор","+");
			
		Иначе
			
			СтруктураРС.Вставить("Регистратор","");
			
		КонецЕсли;
		
		СоответствиеРС.Вставить(ПредставлениеРС, СтруктураРС);
		
	КонецЦикла;

	Возврат СоответствиеРС;
	
