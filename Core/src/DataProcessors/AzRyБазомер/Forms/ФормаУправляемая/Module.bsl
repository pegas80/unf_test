&НаСервере
Процедура ЗаполнитьПоляИндексы(ИдентификаторСтроки)

	ЭлементТЗ = ОписаниеСтруктурыМетаданных.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	ОписаниеПолей.Очистить();
	Для каждого ТекПоле Из ЭлементТЗ.Поля Цикл
	
		НовСтр = ОписаниеПолей.Добавить();
		НовСтр.ИмяПоляХранения = ТекПоле.ИмяПоляХранения;
		НовСтр.ИмяПоля = ТекПоле.ИмяПоля;
		НовСтр.Метаданные = ТекПоле.Метаданные;
	
	КонецЦикла;
	
    ОписаниеИндексов.Очистить();
	Для каждого ТекПоле Из ЭлементТЗ.Индексы Цикл
	
		НовСтр = ОписаниеИндексов.Добавить();
		НовСтр.ИмяИндексаХранения = ТекПоле.ИмяИндексаХранения;
		
		Для каждого ПолеИндекса Из ТекПоле.ПоляИндекса Цикл
		
			  НоваяСтр = НовСтр.ПоляИндекса.Добавить();
			  НоваяСтр.ИмяПоля = ПолеИндекса.ИмяПоля;
			  НоваяСтр.ИмяПоляХранения = ПолеИндекса.ИмяПоляХранения;
			  НоваяСтр.Метаданные = ПолеИндекса.Метаданные;
			  
		КонецЦикла;
		
	КонецЦикла;
	
	
КонецПроцедуры


