КонецПроцедуры

&НаСервере
Функция ПолучитьПланыОбменаСервер()

	КоллекцияПлановОбмена = Метаданные.ПланыОбмена;
	СоответствиеПланыОбмена = Новый Соответствие;
	Для каждого ПланОбмена Из КоллекцияПлановОбмена Цикл
	
		СтруктураПланыОбмена = Новый Структура;
		СтруктураПланыОбмена.Вставить("Имя", ПланОбмена.Имя);
		СтруктураПланыОбмена.Вставить("Синоним", ПланОбмена.Синоним);
		Если ПланОбмена.РаспределеннаяИнформационнаяБаза Тогда
		
			СтруктураПланыОбмена.Вставить("РИБ", "+");
			
		Иначе
			
			СтруктураПланыОбмена.Вставить("РИБ", "");
		
		КонецЕсли;
		
		
		СоответствиеПланыОбмена.Вставить(ПланОбмена.Имя, СтруктураПланыОбмена);
		
	КонецЦикла;
	
	Возврат СоответствиеПланыОбмена;

КонецФункции // ПолучитьОбщиеМодулиСервер()


&НаКлиенте
Процедура ПолучитьОбщиеМодули()

	КоллекцияОбщихМодулей = ПолучитьОбщиеМодулиСервер();

	Элементы.ОбщиеМодули.Заголовок = "Общие модули";
	
	Элементы.ОбщиеМодули.Заголовок = Элементы.ОбщиеМодули.Заголовок + " (" + КоллекцияОбщихМодулей.Количество() + ")";
	
	ТЗОбщиеМодули.Очистить();
	
	Для каждого Модуль Из КоллекцияОбщихМодулей Цикл
	
		СтрокаТЗ = ТЗОбщиеМодули.Добавить();
		СтрокаТЗ.ИмяМодуля = Модуль.Ключ;
		СтрокаТЗ.КлиентУП = Модуль.Значение.КлиентУправляемоеПриложение;
		СтрокаТЗ.Сервер = Модуль.Значение.Сервер;
		СтрокаТЗ.ВнешнееСоединение = Модуль.Значение.ВнешнееСоединение;
		СтрокаТЗ.КлиентОП = Модуль.Значение.КлиентОбычноеПриложение;
		СтрокаТЗ.ВызовСервера = Модуль.Значение.ВызовСервера;
		СтрокаТЗ.Привилегированный = Модуль.Значение.Привилегированный;
		СтрокаТЗ.ПовторноеИспользованиеВозвращаемыхЗначений = Модуль.Значение.ПовторноеИспользованиеВозвращаемыхЗначений;
		
	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОбщиеМодулиСервер()

	КоллекцияМодулей = Метаданные.ОбщиеМодули;
	СоответствиеМодули = Новый Соответствие;
	Для каждого Модуль Из КоллекцияМодулей Цикл
	
		СтруктураМодули = Новый Структура;
		СтруктураМодули.Вставить("Имя", Модуль.Имя);
		СтруктураМодули.Вставить("Синоним", Модуль.Синоним);
		СтруктураМодули.Вставить("Комментарий", Модуль.Комментарий);
		Если Модуль.ВнешнееСоединение Тогда
		
			СтруктураМодули.Вставить("ВнешнееСоединение", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("ВнешнееСоединение", "");
			
		КонецЕсли;
		
		Если Модуль.ВызовСервера Тогда
		
			СтруктураМодули.Вставить("ВызовСервера", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("ВызовСервера", "");
			
		КонецЕсли;
		
		Если Модуль.Глобальный Тогда
		
			СтруктураМодули.Вставить("Глобальный", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("Глобальный", "");
			
		КонецЕсли;
		
		Если Модуль.КлиентОбычноеПриложение Тогда
		
			СтруктураМодули.Вставить("КлиентОбычноеПриложение", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("КлиентОбычноеПриложение", "");
			
		КонецЕсли;
		
		Если Модуль.КлиентУправляемоеПриложение Тогда
		
			СтруктураМодули.Вставить("КлиентУправляемоеПриложение", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("КлиентУправляемоеПриложение", "");
			
		КонецЕсли;
		
		Если Модуль.ПовторноеИспользованиеВозвращаемыхЗначений = Метаданные.СвойстваОбъектов.ПовторноеИспользованиеВозвращаемыхЗначений.НеИспользовать  Тогда
		
			СтруктураМодули.Вставить("ПовторноеИспользованиеВозвращаемыхЗначений", "");
			
		Иначе
			
			Если Модуль.ПовторноеИспользованиеВозвращаемыхЗначений = Метаданные.СвойстваОбъектов.ПовторноеИспользованиеВозвращаемыхЗначений.НаВремяВызова Тогда
			
				СтруктураМодули.Вставить("ПовторноеИспользованиеВозвращаемыхЗначений", "На время вызова");
				
			Иначе	
				
				СтруктураМодули.Вставить("ПовторноеИспользованиеВозвращаемыхЗначений", "На время сеанса");
			
			КонецЕсли;
			
		КонецЕсли;
		
		Если Модуль.Привилегированный Тогда
		
			СтруктураМодули.Вставить("Привилегированный", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("Привилегированный", "");
			
		КонецЕсли;
		
		Если Модуль.Сервер Тогда
		
			СтруктураМодули.Вставить("Сервер", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("Сервер", "");
			
		КонецЕсли;
		
		Если Модуль.ВызовСервера Тогда
		
			СтруктураМодули.Вставить("ВызовСервера", "+");
			
		Иначе
			
			СтруктураМодули.Вставить("ВызовСервера", "");
			
		КонецЕсли;
		
		СоответствиеМодули.Вставить(Модуль.Имя, СтруктураМодули);
		
	КонецЦикла;
	
	Возврат СоответствиеМодули;

КонецФункции // ПолучитьОбщиеМодулиСервер()

&НаКлиенте
Процедура ПолучитьКонстанты()

	КоллекцияКонстант = ПолучитьКонстантыСервер();	
	
	Элементы.Константы.Заголовок = "Константы";
	
