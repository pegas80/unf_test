
&НаСервере
Процедура ОбновитьСписокНаСервере()
	
	ТаблицаЦен.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЦеныНоменклатуры.ВидЦен,
	               |	ЦеныНоменклатуры.Номенклатура,
	               |	ЦеныНоменклатуры.Характеристика,
	               |	МАКСИМУМ(ЦеныНоменклатуры.Период) КАК Период
	               |ПОМЕСТИТЬ ВТПериоды
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	               |ГДЕ
	               |	ЦеныНоменклатуры.ВидЦен В(&ВидЦен)
	               |	И ЦеныНоменклатуры.Период МЕЖДУ &ДатаНач И &ДатаКон
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ЦеныНоменклатуры.ВидЦен,
	               |	ЦеныНоменклатуры.Номенклатура,
	               |	ЦеныНоменклатуры.Характеристика
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ЦеныНоменклатуры.ВидЦен,
	               |	ЦеныНоменклатуры.Номенклатура,
	               |	ЦеныНоменклатуры.Характеристика,
	               |	ЦеныНоменклатуры.Цена
	               |ПОМЕСТИТЬ ВТЦеныСтар
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			&ДатаКон,
	               |			ВидЦен В (&ВидЦен)
	               |				И НЕ (ВидЦен, Номенклатура, Характеристика, Период) В
	               |						(ВЫБРАТЬ
	               |							ЦеныНоменклатуры.ВидЦен,
	               |							ЦеныНоменклатуры.Номенклатура,
	               |							ЦеныНоменклатуры.Характеристика,
	               |							ЦеныНоменклатуры.Период
	               |						ИЗ
	               |							ВТПериоды КАК ЦеныНоменклатуры
	               |						ГДЕ
	               |							ЦеныНоменклатуры.ВидЦен В (&ВидЦен)
	               |							И ЦеныНоменклатуры.Период МЕЖДУ &ДатаНач И &ДатаКон)) КАК ЦеныНоменклатуры
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТПериоды.ВидЦен,
	               |	ВТПериоды.Номенклатура,
	               |	ВТПериоды.Характеристика,
	               |	ВТПериоды.Период,
	               |	ЦеныНоменклатуры.Цена КАК ЦенаНов,
	               |	ВТЦеныСтар.Цена КАК ЦенаСтар,
	               |	ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) - ЕСТЬNULL(ВТЦеныСтар.Цена, 0) КАК Разница
	               |ИЗ
	               |	ВТПериоды КАК ВТПериоды
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	               |		ПО ВТПериоды.ВидЦен = ЦеныНоменклатуры.ВидЦен
	               |			И ВТПериоды.Период = ЦеныНоменклатуры.Период
	               |			И ВТПериоды.Номенклатура = ЦеныНоменклатуры.Номенклатура
	               |			И ВТПериоды.Характеристика = ЦеныНоменклатуры.Характеристика
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦеныСтар КАК ВТЦеныСтар
	               |		ПО ВТПериоды.ВидЦен = ВТЦеныСтар.ВидЦен
	               |			И ВТПериоды.Номенклатура = ВТЦеныСтар.Номенклатура
	               |			И ВТПериоды.Характеристика = ВТЦеныСтар.Характеристика
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Разница УБЫВ";
	
	
	Запрос.УстановитьПараметр("ДатаНач",?(ЗначениеЗаполнено(ДатаНач),ДатаНач,Дата("1,1,1")));
	Запрос.УстановитьПараметр("ДатаКон",?(ЗначениеЗаполнено(ДатаКон),ДатаКон,ТекущаяДата()));
	
	Запрос.УстановитьПараметр("ВидЦен",ВидыЦен);
	
	ТаблицаЦен.Загрузить(Запрос.Выполнить().Выгрузить());
	
	
	
КонецПроцедуры

