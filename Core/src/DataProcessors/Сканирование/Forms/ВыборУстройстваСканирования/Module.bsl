
#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	КоличествоЭлементов = 0;
	Если ФайловыеФункцииСлужебныйКлиент.ПроинициализироватьКомпоненту() Тогда
		МассивУстройств = ФайловыеФункцииСлужебныйКлиент.ПолучитьУстройства();
		Для Каждого Строка Из МассивУстройств Цикл
			КоличествоЭлементов = КоличествоЭлементов + 1;
			Элементы.ИмяУстройства.СписокВыбора.Добавить(Строка);
		КонецЦикла;
	КонецЕсли;
	Если КоличествоЭлементов = 0 Тогда
		Отказ = Истина;
		ПоказатьПредупреждение(, НСтр("ka='Не установлен сканер. Обратитесь к администратору программы.';ru='Не установлен сканер. Обратитесь к администратору программы.';en='Do not set the scanner. Refer to the program administrator.'"));
	Иначе
		Элементы.ИмяУстройства.РежимВыбораИзСписка = Истина;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьСканер(Команда)
	
	Если ПустаяСтрока(ИмяУстройства) Тогда
		ТекстСообщения = НСтр("ka='Не выбран сканер.';ru='Не выбран сканер.';en='Not selected scanner.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "ИмяУстройства");
		Возврат;
	КонецЕсли;
	
	СистемнаяИнформация = Новый СистемнаяИнформация();
	ОбщегоНазначенияВызовСервера.ХранилищеОбщихНастроекСохранить(
		"НастройкиСканирования/ИмяУстройства",
		СистемнаяИнформация.ИдентификаторКлиента,
		ИмяУстройства,
		,
		,
		Истина);
	Закрыть(ИмяУстройства);
КонецПроцедуры

#КонецОбласти