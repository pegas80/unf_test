Функция НайтиДокументПоИД(ID)
	
	НаиденныйДок = Документы.РасходСоСчета.НайтиПоРеквизиту("ID",ID);
	
	Если НЕ ЗначениеЗаполнено(НаиденныйДок) Тогда 
		
		НаиденныйДок = Документы.ПоступлениеНаСчет.НайтиПоРеквизиту("ID",ID);
		
	ИначеЕсли НЕ ЗначениеЗаполнено(НаиденныйДок) Тогда 
		
		НаиденныйДок = Документы.ПеремещениеДС.НайтиПоРеквизиту("ID",ID);
		
	КонецЕсли;
	
	Возврат НаиденныйДок;
	
КонецФункции
