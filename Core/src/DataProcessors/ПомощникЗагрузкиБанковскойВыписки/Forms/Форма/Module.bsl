	ЗагрузитьНаКлиенте(Объект.ПутьКФайлу);
	
КонецПроцедуры


&НаКлиенте
Процедура ЗагрузитьНаКлиенте(АдресФайла)
	
	
	Если не ПроверитьЗаполнение() Тогда 
		Возврат;
	КонецЕсли;

	Попытка
		Excel = Новый COMОбъект("Excel.Application");
	Исключение
		Сообщить("Похоже, Excel на компьютере не установлен. Необходимо выполнить установку/переустановку Excel.");
		Возврат;
	КонецПопытки;     
	
	Excel.Workbooks.Open(АдресФайла);
	Книга = Excel.ActiveWorkbook; 
	
	//ЗагрузитьНаСервере(Excel, Книга);

	Если BOG Тогда
		Лист = Книга.Worksheets(1);
	ИначеЕсли TBC Тогда 
		Лист = Книга.Worksheets(2);
	ИначеЕсли CARTU Тогда 
		Лист = Книга.Worksheets(2);
	ИначеЕсли VTB Тогда 
		Лист = Книга.Worksheets(1);
	КонецЕсли;
	
	ArrExcel = Лист.UsedRange.Value.Выгрузить();
	
	ЗагрузитьНаСервере(ArrExcel);
	
	Excel.quit();
	Excel.Application.Quit();

	
КонецПроцедуры 

&НаСервере
Процедура ЗагрузитьНаСервере(ArrExcel)
	
	Если BOG Тогда
		BOG_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia);
	КонецЕсли;
	
	Если TBC Тогда
		TBC_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.TBC);
	КонецЕсли;
	
	Если CARTU Тогда
		CARTU_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.Cartu);
	КонецЕсли;
	
	Если VTB Тогда
		VTB_ЗагрузитьНаСервере(ArrExcel,Перечисления.ТипыОбменаСИнтернетБанком.VTB);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура BOG_ЗагрузитьНаСервере(ArrExcel,ТипОбмена)
	СтруктураКолонок = ПолучитьСтруктуруСоответствииКолонок(ТипОбмена);
	
	Объект.ТаблицаВыписки.Очистить();
	врТаблицаВыписки = Объект.ТаблицаВыписки.Выгрузить();
	врТаблицаВыпискиШ =  врТаблицаВыписки.Скопировать();
	Для Каждого стр Из ArrExcel[0] Цикл 
		врТаблицаВыписки.Добавить();
	КонецЦикла;
	
	Для каждого стрСтруктури Из СтруктураКолонок Цикл
		стЗначение = стрСтруктури.Значение;
		стКлюч	   = стрСтруктури.Ключ;
		
		Если стКлюч = "НаименованиеКт" Или стКлюч = "НаименованиеДт" Тогда
			//стКлюч = "Наименование";
		ИначеЕсли стКлюч = "ИННКт" Или стКлюч = "ИННДт" Тогда
			//стКлюч = "ИНН";
		ИначеЕсли стКлюч = "СчетБанкКт" Или стКлюч = "СчетБанкДт" Тогда
			//стКлюч = "СчетБанк";
		КонецЕсли;
		Попытка
			врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],стКлюч);
		Исключение
			Сообщить(ОписаниеОшибки() +  " колонка " + " стЗначение ");
		КонецПопытки;
	КонецЦикла;
	
	МассивУдаления = Новый Массив;
	Для каждого СтрокаВыписки Из врТаблицаВыписки Цикл
		Если СтрокаВыписки.Дата = "" 
			Или Не ЗначениеЗаполнено(СтрокаВыписки.Дата) 
			Или СтрокаВыписки.Дата = "ამონაწერი" 
			Или СтрокаВыписки.Дата = "თარიღი"	Тогда 
			МассивУдаления.Добавить(СтрокаВыписки);
			Продолжить;
		ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.СуммаДт) Тогда 
			СтрокаВыписки.Наименование = СтрокаВыписки.НаименованиеДт;
			СтрокаВыписки.ИНН = СтрокаВыписки.ИННДт;
			СтрокаВыписки.СчетБанк = СтрокаВыписки.СчетБанкДт;
		ИначеЕсли ЗначениеЗаполнено(СтрокаВыписки.СуммаКт) Тогда 
			СтрокаВыписки.Наименование = СтрокаВыписки.НаименованиеКт;
			СтрокаВыписки.ИНН = СтрокаВыписки.ИННКт;
			СтрокаВыписки.СчетБанк = СтрокаВыписки.СчетБанкКт;
		КонецЕсли;
		врТаблицаВыпискиШ.Очистить();
		СтрокаВыпискиШ = врТаблицаВыпискиШ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаВыпискиШ,СтрокаВыписки);
		СтрокаВыписки._ШаблонЗаполнения = СоответствоватьШаблонЗаполнения(врТаблицаВыпискиШ);
		
		пИНН = СтрЗаменить(СтрокаВыписки.ИНН, " ", "");//Паганини
		СтрокаВыписки.ID = 
		СтрокаВыписки.Ключ 
		+ "_" + Лев(СтрокаВыписки.Дата, 10) 
		+ "_" + пИНН//СтрокаВыписки.ИНН 
		+ "_" + СтрокаВыписки.НомерДокумента 
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_-" + Строка(СтрокаВыписки.СуммаКт), "") 
		+ "_" + СтрокаВыписки.НазначениеПлатежа;
		
		СтрокаВыписки._СсылкаНаДокумент  = НайтиДокументПоИД(СтрокаВыписки.ID);
		
		//Паганини_
		СтрокаВыписки.Контрагент1С      = НайтиКонтрагента(пИНН,СтрокаВыписки.Наименование);//СтрокаВыписки.ИНН
		СтрокаВыписки.Подотчетник1С     = НайтиПодотчетника(пИНН);                          //СтрокаВыписки.ИНН
		СтрокаВыписки.СчетКонтрагента1С = НайтиСчет(СтрокаВыписки.Контрагент1С,СтрокаВыписки.СчетБанк);
		//_Паганини
		
	КонецЦикла;
	
	Для каждого стрМУд Из МассивУдаления Цикл
		врТаблицаВыписки.Удалить(стрМУд);
	КонецЦикла;
	Объект.ТаблицаВыписки.Загрузить(врТаблицаВыписки);
	

КонецПроцедуры 

