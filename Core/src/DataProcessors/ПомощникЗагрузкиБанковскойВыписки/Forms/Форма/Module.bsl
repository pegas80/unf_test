&НаСервере
Процедура VTB_ЗагрузитьНаСервере(ArrExcel,ТипОбмена)

    СтруктураКолонок = ПолучитьСтруктуруСоответствииКолонок(ТипОбмена);

	Объект.ТаблицаВыписки.Очистить();
	врТаблицаВыписки = Объект.ТаблицаВыписки.Выгрузить();
	врТаблицаВыпискиШ =  врТаблицаВыписки.Скопировать();
	Для Каждого стр Из ArrExcel[0] Цикл 
		врТаблицаВыписки.Добавить();
	КонецЦикла;
	
	Для каждого стрСтруктури Из СтруктураКолонок Цикл
		стЗначение = стрСтруктури.Значение;
		стКлюч	   = стрСтруктури.Ключ;
		Попытка
			Если VTB И стКлюч = "Дата" Тогда 
				врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],"ДатаСтрока");
			Иначе 
				врТаблицаВыписки.ЗагрузитьКолонку(ArrExcel[стЗначение-1],стКлюч);
			КонецЕсли;
		Исключение
			Сообщить(ОписаниеОшибки() +  " колонка " + " стЗначение ");
		КонецПопытки;
	КонецЦикла;
	
	МассивУдаления = Новый Массив;
	Для каждого СтрокаВыписки Из врТаблицаВыписки Цикл
		Если  НЕ VTB Тогда 
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки.Дата) 
				Или  СтрокаВыписки.Дата = "" 
				Или СтрокаВыписки.Дата = "ამონაწერი" 
				Или СтрокаВыписки.Дата = "თარიღი"	 
				Или СтрокаВыписки.Дата = "დანიშნულება"	 
				Или СтрокаВыписки.Дата = "Date"	Тогда 
				МассивУдаления.Добавить(СтрокаВыписки);
				Продолжить;
			КонецЕсли;
		ИначеЕсли VTB Тогда
			Если НЕ ЗначениеЗаполнено(СтрокаВыписки.ДатаСтрока) 
				Или  СтрокаВыписки.ДатаСтрока = "" 
				Или СтрокаВыписки.ДатаСтрока = "ამონაწერი" 
				Или СтрокаВыписки.ДатаСтрока = "თარიღი"	 
				Или СтрокаВыписки.ДатаСтрока = "დანიშნულება"	 
				Или СтрокаВыписки.ДатаСтрока = "Date"	Тогда 
				МассивУдаления.Добавить(СтрокаВыписки);
			Иначе 
				СтрокаВыписки.Дата = ПреобразоватьВДату(СтрокаВыписки.ДатаСтрока);
				Если НЕ ЗначениеЗаполнено(СтрокаВыписки.Дата) Тогда 
					МассивУдаления.Добавить(СтрокаВыписки);
					Продолжить;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		врТаблицаВыпискиШ.Очистить();
		СтрокаВыпискиШ = врТаблицаВыпискиШ.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаВыпискиШ,СтрокаВыписки);
		СтрокаВыписки._ШаблонЗаполнения = СоответствоватьШаблонЗаполнения(врТаблицаВыпискиШ);
		
		пИНН = СтрЗаменить(СтрокаВыписки.ИНН, " ", "");//Паганини
		СтрокаВыписки.ID = 
		СтрокаВыписки.Ключ 
		+ "_" + Строка(СтрокаВыписки.Дата) 
		+ "_" + пИНН//СтрокаВыписки.ИНН 
		+ "_" + СтрокаВыписки.НомерДокумента 
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаДт), "_" + Строка(СтрокаВыписки.СуммаДт), "")
		+ ?(ЗначениеЗаполнено(СтрокаВыписки.СуммаКт), "_-" + Строка(СтрокаВыписки.СуммаКт), "") 
		+ "_" + СтрокаВыписки.НазначениеПлатежа;
		
		СтрокаВыписки._СсылкаНаДокумент  = НайтиДокументПоИД(СтрокаВыписки.ID);
		
		СтрокаВыписки.Контрагент1С      = НайтиКонтрагента(пИНН,СтрокаВыписки.Наименование);//СтрокаВыписки.ИНН
		СтрокаВыписки.Подотчетник1С     = НайтиПодотчетника(пИНН);							//СтрокаВыписки.ИНН
		СтрокаВыписки.СчетКонтрагента1С = НайтиСчет(СтрокаВыписки.Контрагент1С,СтрокаВыписки.СчетБанк);
		
	КонецЦикла;
	
	Для каждого стрМУд Из МассивУдаления Цикл
		врТаблицаВыписки.Удалить(стрМУд);
	КонецЦикла;
	Объект.ТаблицаВыписки.Загрузить(врТаблицаВыписки);


КонецПроцедуры // ()

&НаСервере
Функция ПреобразоватьВДату(ДатаСтрока)
	
	ТекДата = "";	
	Попытка
		врДенъ  = Лев(ДатаСтрока,2);
		врМесяц = Сред(ДатаСтрока,4,2);
		врГод   = Прав(ДатаСтрока,4);
		
		ТекДата = Дата(врГод+врМесяц+врДенъ);
	Исключение
	КонецПопытки;
	
	Возврат ТекДата;
	
КонецФункции

&НаСервере
Функция НайтиКонтрагента(ИНН,Наименование)
	
	наидКонтрагент = Неопределено;
	Если Не (ЗначениеЗаполнено(ИНН) ИЛИ ЗначениеЗаполнено(Наименование)) Тогда
		Возврат наидКонтрагент;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИНН) Тогда
		
		наидКонтрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН",ИНН);
		Если Не ЗначениеЗаполнено(наидКонтрагент) Тогда 
			наидКонтрагент = Справочники.Контрагенты.НайтиПоНаименованию(Наименование);
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(Наименование) Тогда 
		наидКонтрагент = Справочники.Контрагенты.НайтиПоНаименованию(Наименование);
	КонецЕсли;
	
	Возврат наидКонтрагент;
	
КонецФункции //

&НаСервере
Функция НайтиПодотчетника(ЛичныйНомер)
	
	ЗнчВозврата = Справочники.Сотрудники.ПустаяСсылка();
	Если Не ЗначениеЗаполнено(ЛичныйНомер) Тогда 
		Возврат ЗнчВозврата;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	НЕ Сотрудники.ПометкаУдаления
	|	И Сотрудники.Физлицо.ИНН = &ПерсональныйНомер
	|	И НЕ Сотрудники.Физлицо.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ПерсональныйНомер", ЛичныйНомер);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		
		ЗнчВозврата = ВыборкаДетальныеЗаписи.Ссылка;
		
	КонецЕсли;  
	Возврат ЗнчВозврата;
	
КонецФункции //


&НаСервере
Функция НайтиСчет(Контрагент1С,СчетБанк)
	
	ЗнчВозврата = Справочники.БанковскиеСчета.ПустаяСсылка();
	
	наидСчет = Справочники.БанковскиеСчета.НайтиПоРеквизиту("НомерСчета", СчетБанк);
	Если наидСчет.Владелец = Контрагент1С Тогда
		ЗнчВозврата =  наидСчет;
	КонецЕсли;
	
	Возврат ЗнчВозврата;
	
КонецФункции //


&НаСервере
Функция СоответствоватьШаблонЗаполнения(СтрокаВыписки) Экспорт 
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ШаблоныЗаполнения.Ссылка КАК ШаблонЗаполнения
	               |ИЗ
	               |	Справочник.ШаблоныЗаполнения КАК ШаблоныЗаполнения
	               |ГДЕ
	               |	НЕ ШаблоныЗаполнения.ПометкаУдаления
	               |	И ШаблоныЗаполнения.ТипОбменаСИнтернетБанком = &ТипОбменаСИнтернетБанком
	               |	И ШаблоныЗаполнения.Действующий";
	
	Запрос.УстановитьПараметр("ТипОбменаСИнтернетБанком", Объект.ТипОбменаСИнтернетБанком);			   
	Результат = Запрос.Выполнить();
	стрШаблонЗаполнения = Результат.Выбрать();
	
	
	
	//Для Каждого стрШаблонЗаполнения Из ШаблоныЗаполнения Цикл 
	Пока стрШаблонЗаполнения.Следующий() Цикл 
		
		//стрШаблонЗаполнения = Выборка.Ссылка; 
		НастройкиШаблонЗаполнения =  стрШаблонЗаполнения.ШаблонЗаполнения.ХранилищеНастроекКомпоновкиДанных.получить();
		ВнешниеНаборыДанных=Новый Структура;
		ВнешниеНаборыДанных.Вставить("ВнешниеДанные",СтрокаВыписки);

		Если BOG Тогда
			СхемаКомпоновкиДанных = Справочники.ШаблоныЗаполнения.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_BOG");
		ИначеЕсли TBC Тогда
			СхемаКомпоновкиДанных = Справочники.ШаблоныЗаполнения.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_TBC");
		ИначеЕсли CARTU Тогда
			СхемаКомпоновкиДанных = Справочники.ШаблоныЗаполнения.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_CARTU");
		ИначеЕсли VTB Тогда
			СхемаКомпоновкиДанных = Справочники.ШаблоныЗаполнения.ПолучитьМакет("МакетЗагрузкиВыписокСФайла_VTB");
		КонецЕсли;
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиШаблонЗаполнения,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		//МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, НастройкиШаблонЗаполнения);
		
		// Построение таблицы значений.
		Процессор = Новый ПроцессорКомпоновкиДанных;
		Процессор.Инициализировать(МакетКомпоновкиДанных,ВнешниеНаборыДанных);
		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений();
		ИсходныеДанные  = Новый ТаблицаЗначений;
		ПроцессорВывода.УстановитьОбъект(ИсходныеДанные);
		ПроцессорВывода.Вывести(Процессор);
		Если ИсходныеДанные.Количество() Тогда 
			Возврат  стрШаблонЗаполнения.ШаблонЗаполнения;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Возврат  Справочники.ШаблоныЗаполнения.ПустаяСсылка();

КонецФункции


&НаСервере
Функция ПолучитьСтруктуруСоответствииКолонок(ТипОбмена)
	
	СтруктураКолонок = Новый Структура;
	
	//Макет = Обработки.ОбменСБанкомСФайлом.ПолучитьМакет("СоответствиеКолонокЗагрузкиВыписокСФайла");
	Макет =  Справочники.ШаблоныЗаполнения.ПолучитьМакет("СоответствиеКолонокЗагрузкиВыписокСФайла");
	Если ТипОбмена = Перечисления.ТипыОбменаСИнтернетБанком.BankOfGeorgia Тогда 
		
		Если Объект.БанковскийСчет.ВалютаДенежныхСредств = Константы.ВалютаУчета.Получить() Тогда 
			ОбластьКолонок = Макет.ПолучитьОбласть("BOG_Excel");
		Иначе
			ОбластьКолонок = Макет.ПолучитьОбласть("BOG_Вал_Excel");
		КонецЕсли;
		
		
	ИначеЕсли ТипОбмена = Перечисления.ТипыОбменаСИнтернетБанком.TBC Тогда 
		
		ОбластьКолонок = Макет.ПолучитьОбласть("TBC_Excel");
			
	ИначеЕсли ТипОбмена = Перечисления.ТипыОбменаСИнтернетБанком.Cartu Тогда 
		
		ОбластьКолонок = Макет.ПолучитьОбласть("CARTU_Excel");
		
	ИначеЕсли ТипОбмена = Перечисления.ТипыОбменаСИнтернетБанком.VTB Тогда 
		
		ОбластьКолонок = Макет.ПолучитьОбласть("VTB_Excel");
		
	КонецЕсли;                                   
	
	Если ОбластьКолонок <> Неопределено Тогда 
		Колонка1с = "";
		Для Сч = 1 По ОбластьКолонок.ВысотаТаблицы   Цикл 
			Колонка1с = ОбластьКолонок.Область(Сч, 5, Сч,5).Текст;
			Если ЗначениеЗаполнено(Колонка1с) Тогда 
				СтруктураКолонок.Вставить(Колонка1с,Число(ОбластьКолонок.Область(Сч, 1, Сч, 1).Текст));
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат СтруктураКолонок;
	
КонецФункции

