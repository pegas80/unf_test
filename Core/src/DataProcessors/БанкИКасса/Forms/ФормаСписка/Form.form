    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументыПоБанкуИКассе.Ссылка,
	ДокументыПоБанкуИКассе.Дата,
	ДокументыПоБанкуИКассе.ПометкаУдаления,
	ДокументыПоБанкуИКассе.Номер,
	ДокументыПоБанкуИКассе.Проведен,
	ДокументыПоБанкуИКассе.Организация КАК ОрганизацияДляОтбора,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
			ТОГДА &quot;Перемещение. Между кассами&quot;
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
			ТОГДА &quot;Перемещение. Из кассы на счет&quot;
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
			ТОГДА &quot;Перемещение. Между счетами&quot;
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
			ТОГДА &quot;Перемещение. Со счета в кассу&quot;
		КОГДА ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПолучениеНаличныхВБанке)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СнятиеНаличных)
			ТОГДА &quot;Перемещение. Со счета в кассу&quot;
		КОГДА ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличными)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличнымиВБанк)
			ТОГДА &quot;Перемещение. Из кассы на счет&quot;
		КОГДА ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводСДругогоСчета)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводНаДругойСчет)
			ТОГДА &quot;Перемещение. Между счетами&quot;
		ИНАЧЕ ДокументыПоБанкуИКассе.ВидОперации
	КОНЕЦ КАК ВидОперации,
	ДокументыПоБанкуИКассе.БанковскийСчет,
	ДокументыПоБанкуИКассе.Статья,
	ДокументыПоБанкуИКассе.Контрагент,
	ДокументыПоБанкуИКассе.Подотчетник,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПолучениеНаличныхВБанке)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличными)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводСДругогоСчета)
			ТОГДА 0
		ИНАЧЕ ДокументыПоБанкуИКассе.СуммаПриход
	КОНЕЦ КАК СуммаПриход,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СнятиеНаличных)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличнымиВБанк)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводНаДругойСчет)
			ТОГДА 0
		ИНАЧЕ -ДокументыПоБанкуИКассе.СуммаРасход
	КОНЕЦ КАК СуммаРасход,
	ДокументыПоБанкуИКассе.Валюта,
	ДокументыПоБанкуИКассе.Комментарий,
	ДокументыПоБанкуИКассе.Тип,
	КОНЕЦПЕРИОДА(ДокументыПоБанкуИКассе.Дата, ДЕНЬ) КАК ДатаДень,
	ДокументыПоБанкуИКассе.НазначениеПлатежа КАК НазначениеПлатежа,
	ДокументыПоБанкуИКассе.Корреспонденция,
	ДокументыПоБанкуИКассе.Автор,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПолучениеНаличныхВБанке)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличными)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводСДругогоСчета)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличнымиВБанк)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СнятиеНаличных)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводНаДругойСчет)
			ТОГДА 0
		КОГДА ДокументыПоБанкуИКассе.СуммаПриход >= 0
			ТОГДА ДокументыПоБанкуИКассе.Сумма
		КОГДА ДокументыПоБанкуИКассе.СуммаРасход > 0
			ТОГДА -ДокументыПоБанкуИКассе.Сумма
		ИНАЧЕ 0
	КОНЕЦ КАК Сумма,
	ВЫБОР
		КОГДА (ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПоступлениеНаСчет
				ИЛИ ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПоступлениеВКассу)
				И НЕ(ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПолучениеНаличныхВБанке)
						ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличными)
						ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводСДругогоСчета))
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоПоступление,
	ВЫБОР
		КОГДА (ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.РасходСоСчета
				ИЛИ ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.РасходИзКассы)
				И НЕ(ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличнымиВБанк)
						ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СнятиеНаличных)
						ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводНаДругойСчет))
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоРасход,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПоступлениеНаСчет
				ИЛИ ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.РасходСоСчета
				ИЛИ ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
					И (ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
						ИЛИ ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные))
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоБанк,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПоступлениеНаСчет
				ИЛИ ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.РасходСоСчета
				ИЛИ ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
					И (ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные)
						И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредствПолучатель = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Безналичные))
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ЭтоКасса,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПолучениеНаличныхВБанке)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличными)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводСДругогоСчета)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ВзносНаличнымиВБанк)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.СнятиеНаличных)
				ИЛИ ДокументыПоБанкуИКассе.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Справочник.ХозяйственныеОперации.ПереводНаДругойСчет)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ЭтоПеремещение,
	ВЫБОР
		КОГДА ДокументыПоБанкуИКассе.Ссылка ССЫЛКА Документ.ПеремещениеДС
				И ДокументыПоБанкуИКассе.Ссылка.ТипДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ТипыДенежныхСредств.Наличные)
