// Создать объект чтения и открыть файл, из которого будет выполняться чтение и запис курсов валют.
Процедура ПроизвестиОбработкуJSONФайла(Данные, ДатаКурса2)
	
	ДатаКурса = ДатаКурса2;
	КодВалютыЛари = "GEL";
	
	СписокВалют = ПолучитьСписокВалют().Выгрузить().ВыгрузитьКолонку("Валюта");
	
	ВалютаЛари = Справочники.Валюты.НайтиПоНаименованию(КодВалютыЛари);
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	КодВалютыУчета = ВалютаУчета.Наименование;
	КурсВалютыУчета = 1;
	КратностьВалютыУчета = 1; 
	
	КурсПересчета = 1;
	КратностьПересчета = 1;
	
	Если КодВалютыУчета <> КодВалютыЛари Тогда
		Если ЗначениеЗаполнено(ВалютаЛари) и СписокВалют.Найти(ВалютаЛари)=Неопределено  ТОгда
			СписокВалют.Добавить(ВалютаЛари);	
		КонецЕсли;	
		Если ЗначениеЗаполнено(ВалютаУчета) и СписокВалют.Найти(ВалютаУчета)=Неопределено  ТОгда
			СписокВалют.Добавить(ВалютаУчета);	
		КонецЕсли;	
	КонецЕсли;	
	
	
	Для Каждого ЭлемМассиваНаДату Из Данные Цикл 
		
		Если ЭлемМассиваНаДату.Свойство("date") Тогда
			ДатаКурса = Дата(СтрЗаменить(Лев(ЭлемМассиваНаДату.date, 10), "-", ""));
		КонецЕсли;
		
		ТаблицаКурсов = Новый ТаблицаЗначений;
		ТаблицаКурсов.Колонки.Добавить("code");
		ТаблицаКурсов.Колонки.Добавить("date");
		ТаблицаКурсов.Колонки.Добавить("diff");
		ТаблицаКурсов.Колонки.Добавить("diffFormated");
		ТаблицаКурсов.Колонки.Добавить("name");
		ТаблицаКурсов.Колонки.Добавить("quantity");
		ТаблицаКурсов.Колонки.Добавить("rate");
		ТаблицаКурсов.Колонки.Добавить("rateFormated");
		ТаблицаКурсов.Колонки.Добавить("validFromDate");
		
		
		Если ЭлемМассиваНаДату.Свойство("currencies") Тогда 
			Для Каждого ЭлемКурсы Из ЭлемМассиваНаДату.currencies Цикл  
				НовСтрока = ТаблицаКурсов.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтрока,ЭлемКурсы);
			КонецЦикла;  
		КонецЕсли;
		
		
		КурсВалютыУчетаВТаблице = ТаблицаКурсов.Найти(КодВалютыУчета, "code");
		КурсЛариВТаблице = ТаблицаКурсов.Найти(КодВалютыЛари, "code");
		
		Если КурсВалютыУчетаВТаблице <> Неопределено Тогда
			КурсПересчета = КурсВалютыУчетаВТаблице.rate;
			КратностьПересчета = КурсВалютыУчетаВТаблице.quantity;
		Иначе
			КодВалюты = ВалютаУчета.Наименование;
			Результат = ДобавитьКурсДляВалюты(ДатаКурса, КодВалюты, КурсВалютыУчета, КратностьВалютыУчета);	
		КонецЕсли;	
		
		Для каждого СтрВалюты из СписокВалют Цикл
			
			НайденКурсДляВалюты = Ложь;
			
			КодВалюты = СтрВалюты.Наименование;
			СтрокаКурса = ТаблицаКурсов.Найти(КодВалюты, "code");
			
			Если КодВалюты = КодВалютыУчета Тогда //Валюту учеа не грузим - она всегда 1
				Если КурсЛариВТаблице = Неопределено Тогда
					КодВалюты = КодВалютыЛари;
					КурсВалюты = 1/КурсПересчета;
					КратностьВалюты = 1/КратностьПересчета;  
					
					Результат = ДобавитьКурсДляВалюты(ДатаКурса, КодВалюты, КурсВалюты, КратностьВалюты);
				КонецЕсли;
				
			ИначеЕсли СтрокаКурса<>Неопределено Тогда
				
				КурсВалюты = СтрокаКурса.rate/КурсПересчета;
				КратностьВалюты = СтрокаКурса.quantity/КратностьПересчета;
				
				
				Результат = ДобавитьКурсДляВалюты(ДатаКурса, КодВалюты, КурсВалюты, КратностьВалюты);
				
			ИначеЕсли КодВалюты = КодВалютыЛари	 Тогда
				
				
			Иначе	
				СтрСообщения = НСтр("ru='Отсутствует курс для валюты с кодом <%1> на дату <%2>';ka='თარიღისთვის <%2> კოდით <%1> ვალუტისთვის კურსი არ არის'");
				Сообщить(СтрШаблон(СтрСообщения, СтрВалюты, ДатаКурса));
			КонецЕсли;
			
		КонецЦикла;
	
	КонецЦикла;	
	
КонецПроцедуры 
