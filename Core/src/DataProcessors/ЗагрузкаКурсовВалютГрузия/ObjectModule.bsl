Процедура ЗагрузитьИсториюКурсов(НачалоПериода, ОкончаниеПериода) Экспорт  
	
	ТекстОтвета = "";
	
	//++Lazare 26.08.2022	
	СерверИсточник = "nbg.gov.ge";
	Ресурс		= "/gw/api/ct/monetarypolicy/currencies";
			
	ТекДата = НачалоДня(НачалоПериода);			
	//Пока Не ТекДата = НачалоДня(ОкончаниеПериода+86400) Цикл 
	Пока ТекДата <= ОкончаниеПериода Цикл 
		
		ТекстЗапроса = СтрШаблон("%1/?date=%2", Ресурс, ЗаписатьДатуJSON(ТекДата,ФорматДатыJSON.ISO)); 	
		HTTPЗапрос = Новый HTTPЗапрос(ТекстЗапроса);	
	
		HTTPСоединение =  Новый HTTPСоединение(СерверИсточник, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());	
		//ИмяПромежуточногоФайла = ПолучитьИмяВременногоФайла("json");
		
		Попытка
			HTTPОтвет  = HTTPСоединение.Получить(HTTPЗапрос);	
			
