Функция ПолучитьКурсы(ПутьКRSS)

	ТекстОтвета = "";

	ДатаКурса = НачалоДня(ТекущаяДата());
	
	Сервер = Сред(ПутьКRSS,9,10); //  "nbg.gov.ge";	
	Ресурс = Сред(ПутьКRSS,19,36); //  "/gw/api/ct/monetarypolicy/currencies"; 	
	
	ТекстЗапроса = СтрШаблон("%1/?date=%2", Ресурс, ЗаписатьДатуJSON(НачалоДня(ТекущаяДата()),ФорматДатыJSON.ISO)); 
	HTTPЗапрос = Новый HTTPЗапрос(ТекстЗапроса);	
	
	HTTPСоединение =  Новый HTTPСоединение(Сервер, 443,,,,, Новый ЗащищенноеСоединениеOpenSSL());	
	
	HTTPОтвет  = HTTPСоединение.Получить(HTTPЗапрос);	
	ТекстОтвета = HTTPОтвет.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);	
	
   	Data = ИзJSON_в_Данные1с(ТекстОтвета);
	
	Если РежимОтладки Тогда
		ТекстОтвета	 = ТекстОтвета + "
		|=======================  " + ДатаКурса + "
		|" + ТекстОтвета; 
	КонецЕсли;	
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("Data", Data);
	СтруктураОтвета.Вставить("GetBodyAsString", ТекстОтвета);
	СтруктураОтвета.Вставить("StatusCode", HTTPОтвет.StatusCode);
	СтруктураОтвета.Вставить("Headers", HTTPОтвет.Headers);
	
	Если СтруктураОтвета.StatusCode <> 200 Тогда		
		ТекстСообщения = СтрШаблон( "Ошибка при получении курсов валют на дату %1. StatusCode %2!", Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy"), СтруктураОтвета.StatusCode  );
		ЗаписьЖурналаРегистрации("Загрузка курсов валют", УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);		
	Иначе
		ПроизвестиОбработкуJSONФайла(Data, ДатаКурса);
	КонецЕсли;
	
	//ЗаписатьФайлJSON(СтруктураОтвета.Data,ДатаИзДанных);

	Возврат ДатаКурса; 
	
КонецФункции 

