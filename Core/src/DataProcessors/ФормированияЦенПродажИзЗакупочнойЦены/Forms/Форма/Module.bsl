&НаКлиенте
Функция ЗаполнитьТаблицу()
	Если Объект.Таблица.Количество() = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	Ответ = Вопрос(НСТР("ka='ცხრილი არ არის ცარიელი. გასუფთავდეს და შეივსოს თავიდან?';ru='Таблица не пустая. Продолжит и перезаполнить?';en='The table is not empty. And continue to refill?'"), РежимДиалогаВопрос.ОКОтмена, , КодВозвратаДиалога.ОК);
	Если Ответ = КодВозвратаДиалога.ОК Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции


&НаКлиенте
Процедура ВыбратьНадбавку(Команда)
	ВыбранныеЗначения = ОткрытьФормуМодально("Обработка.ФормированияЦенПродажИзЗакупочнойЦены.Форма.ФормаНадбавки", Новый Структура("Заголовок", НСТР("ka='ფასნამატი თანხა';ru='Надбавка сумма';en='The surcharge amount'")));
	Если ВыбранныеЗначения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Надбавка = ВыбранныеЗначения.Надбавка;
	Для Каждого ТекущиеДанные ИЗ Объект.Таблица Цикл
		Если ТекущиеДанные.Флаг Тогда
			ТекущиеДанные.Надбавка = Надбавка;
			
			Если Вариант2 Тогда
				ТекущиеДанные.ЦенаПродажиНовая	= ТекущиеДанные.ЦенаЗакупки + ТекущиеДанные.Надбавка;
				ТекущиеДанные.НадбавкаПроцент	= ?(ТекущиеДанные.ЦенаЗакупки = 0, 0, ТекущиеДанные.ЦенаПродажиНовая/ТекущиеДанные.ЦенаЗакупки*100-100);
			Иначе
				//Т
				Если ТекущиеДанные.ЦенаПродажиТекущая = 0 Тогда
					ЦенаПродажиТекущая = ТекущиеДанные.ЦенаЗакупки;
				Иначе
					ЦенаПродажиТекущая = ТекущиеДанные.ЦенаПродажиТекущая;
				КонецЕсли;
				//
			
				ТекущиеДанные.ЦенаПродажиНовая	= ЦенаПродажиТекущая + ТекущиеДанные.Надбавка;
				ТекущиеДанные.НадбавкаПроцент	= ?(ЦенаПродажиТекущая = 0, 0, ТекущиеДанные.ЦенаПродажиНовая/ЦенаПродажиТекущая*100-100);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьНадбавкуПроцент(Команда)
	
	ВыбранныеЗначения = ОткрытьФормуМодально("Обработка.ФормированияЦенПродажИзЗакупочнойЦены.Форма.ФормаНадбавки", Новый Структура("Заголовок", НСТР("ka='ფასნამატი %';ru='Надбавка %';en='Weighting%'")));
	Если ВыбранныеЗначения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Надбавка = ВыбранныеЗначения.Надбавка;
	Для Каждого ТекущиеДанные ИЗ Объект.Таблица Цикл
		Если ТекущиеДанные.Флаг Тогда
			ТекущиеДанные.НадбавкаПроцент 	= Надбавка;
			Если Вариант2 Тогда
				ТекущиеДанные.ЦенаПродажиНовая 	= ТекущиеДанные.ЦенаЗакупки *(1 + ТекущиеДанные.НадбавкаПроцент/100);
				ТекущиеДанные.Надбавка			= ТекущиеДанные.ЦенаПродажиНовая - ТекущиеДанные.ЦенаЗакупки;
			Иначе				
				//Т
				Если ТекущиеДанные.ЦенаПродажиТекущая = 0 Тогда
					ЦенаПродажиТекущая = ТекущиеДанные.ЦенаЗакупки;
				Иначе
					ЦенаПродажиТекущая = ТекущиеДанные.ЦенаПродажиТекущая;
				КонецЕсли;
				//				
				ТекущиеДанные.ЦенаПродажиНовая 	= ЦенаПродажиТекущая *(1 + ТекущиеДанные.НадбавкаПроцент/100);
				ТекущиеДанные.Надбавка			= ТекущиеДанные.ЦенаПродажиНовая - ЦенаПродажиТекущая;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Формировать(Команда)
	
	ОчиститьСообщения();
	//ТекДата = НачалоДня(ТекущаяДата());
	Отказ	= Ложь;
	ВыбранныеСтроки = Объект.Таблица.НайтиСтроки(Новый Структура("Флаг", Истина));
	
	Если ВыбранныеСтроки.Количество() = 0 Тогда
		Предупреждение(НСТР("ka='არ არის არჩეული სტრიქონები!';ru='Не выбранны строки!';en='Not selected line!'"));
		Возврат;
	КонецЕсли;
	//СинонимНадбавка = ?(ВариантНадбавки = 2, НСтр("ka='ფასნამატი %';ru='Надбавка %';en='Weighting%'"), НСтр("ka='ფასნამატი თანხა';ru='Надбавка сумма';en='The surcharge amount'"));
	//
	////Проверка строк
	//Если ВариантНадбавки = 0 ИЛИ ВариантНадбавки = 1 Тогда
	//	Для Каждого СтрокаТЧ ИЗ ВыбранныеСтроки Цикл
