&НаКлиенте
Процедура ОбновитьСписок(Команда)
	Если Объект.Таблица.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	Ответ = Вопрос(НСТР("ka='მოცემული ბრძანებით ნომენკლატურის ფასები და თარიღები განახლდება მიმდინარე მონაცემებით და დაიკარგება ხელით შეცვლილი ფასნამატები. გავაგრძელოთ?';ru='Данной командой обновятся данные текущих номенклатур с текущими ценами и датами и потеряются данный надбавки. Продолжить?';en='This command will update the data of the current nomenclature with current prices and dates and lose this allowance. Proceed?'"), РежимДиалогаВопрос.ОКОтмена);
	Если НЕ Ответ = КодВозвратаДиалога.ОК Тогда
		Возврат;
	КонецЕсли;
	СформироватьТаблицуЗапасов("ОбновитьСписок", Неопределено);
КонецПроцедуры

&НаСервере
Процедура СформироватьТаблицуЗапасов(ИмяКоманды, ВыбранныеЗначения)
	
	МВТ = Новый МенеджерВременныхТаблиц;
	Запрос1 = Новый Запрос;
	Запрос1.УстановитьПараметр("ВыбранныеЗначения", 	ВыбранныеЗначения);
	Запрос1.МенеджерВременныхТаблиц = МВТ;

	Если ИмяКоманды = "ЗаполнитьПоПриходнымНакладным" Тогда
		Запрос1.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ПриходнаяНакладнаяЗапасы.Номенклатура КАК Номенклатура,
			|	ПриходнаяНакладнаяЗапасы.Характеристика
			|ПОМЕСТИТЬ Запасы
			|ИЗ
			|	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
			|ГДЕ
			|	ПриходнаяНакладнаяЗапасы.Ссылка В(&ВыбранныеЗначения)
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	Номенклатура";
	ИначеЕсли ИмяКоманды = "ЗаполнитьПоКатегорииНоменклатуры" Тогда
		Запрос1.Текст =
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Номенклатура
			|ПОМЕСТИТЬ ЗапасыПред
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	Номенклатура.КатегорияНоменклатуры В(&ВыбранныеЗначения)
			|	И НЕ Номенклатура.ПометкаУдаления
			|	И НЕ Номенклатура.ЭтоГруппа";
	ИначеЕсли ИмяКоманды = "ЗаполнитьПоГруппамНоменклатуры" Тогда
		Запрос1.Текст =
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Номенклатура
			|ПОМЕСТИТЬ ЗапасыПред
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	Номенклатура.Родитель В ИЕРАРХИИ(&ВыбранныеЗначения)
			|	И НЕ Номенклатура.ПометкаУдаления
			|	И НЕ Номенклатура.ЭтоГруппа";
	ИначеЕсли ИмяКоманды = "ОбновитьСписок" Тогда
		Запрос1.Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Таблица.Номенклатура,
			|	Таблица.Характеристика
			|ПОМЕСТИТЬ Запасы
			|ИЗ
			|	&Таблица КАК Таблица";
		Запрос1.УстановитьПараметр("Таблица", Объект.Таблица.Выгрузить());
	ИначеЕсли ИмяКоманды = "ЗаполнитьПоВидуЦен" Тогда
		Запрос1.Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
			|	ЦеныНоменклатурыСрезПоследних.Характеристика
			|ПОМЕСТИТЬ Запасы
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦен В (&ВыбранныеЗначения)) КАК ЦеныНоменклатурыСрезПоследних";
	ИначеЕсли ИмяКоманды = "ЗаполнитьПоВидуЦенКонтрагента" Тогда
		Запрос1.Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
			|	ЦеныНоменклатурыСрезПоследних.Характеристика
			|ПОМЕСТИТЬ Запасы
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатурыКонтрагентов.СрезПоследних(, ВидЦенКонтрагента В (&ВыбранныеЗначения)) КАК ЦеныНоменклатурыСрезПоследних";
	ИначеЕсли ИмяКоманды = "ЗаполнитьПоЭлементамНоменклатуры" Тогда
		Запрос1.Текст =
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Номенклатура
			|ПОМЕСТИТЬ ЗапасыПред
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	Номенклатура.Ссылка В(&ВыбранныеЗначения)";
	КонецЕсли;
	Запрос1.Выполнить();

	Если ИмяКоманды = "ЗаполнитьПоКатегорииНоменклатуры" ИЛИ
		 ИмяКоманды = "ЗаполнитьПоГруппамНоменклатуры" ИЛИ
		 ИмяКоманды = "ЗаполнитьПоЭлементамНоменклатуры" Тогда
		Запрос2 = Новый Запрос;
		Запрос2.МенеджерВременныхТаблиц = МВТ;
		Запрос2.Текст =
			"ВЫБРАТЬ
			|	ВЫРАЗИТЬ(ХарактеристикиНоменклатуры.Владелец КАК Справочник.Номенклатура) КАК Номенклатура,
			|	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика
			|ПОМЕСТИТЬ ХарактеристикиНом
			|ИЗ
			|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
			|ГДЕ
			|	ХарактеристикиНоменклатуры.Владелец В
			|			(ВЫБРАТЬ
			|				ЗапасыПред.Номенклатура
			|			ИЗ
			|				ЗапасыПред КАК ЗапасыПред)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ЗапасыПред.Номенклатура,
			|	ХарактеристикиНом.Характеристика
			|ПОМЕСТИТЬ Запасы
			|ИЗ
			|	ЗапасыПред КАК ЗапасыПред
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ХарактеристикиНом КАК ХарактеристикиНом
			|		ПО ЗапасыПред.Номенклатура = ХарактеристикиНом.Номенклатура
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ЗапасыПред.Номенклатура,
			|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)
			|ИЗ
			|	ЗапасыПред КАК ЗапасыПред
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ЗапасыПред
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ХарактеристикиНом";
		Запрос2.Выполнить();
	КонецЕсли;
	
	ЗаполнитьТовары_НаСервере(МВТ);
	
КонецПроцедуры

Процедура ЗаполнитьТовары_НаСервере(МВТ)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МВТ;
	Запрос.Текст = 
		//"ВЫБРАТЬ РАЗЛИЧНЫЕ
		//|	ПриходнаяНакладнаяЗапасы.Номенклатура КАК Номенклатура
		//|ПОМЕСТИТЬ Запасы
		//|ИЗ
		//|	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
		//|ГДЕ
		//|	ПриходнаяНакладнаяЗапасы.Ссылка В(&СписокДокументов)
		//|
		//|ИНДЕКСИРОВАТЬ ПО
		//|	Номенклатура
		//|;
		//|
		//|////////////////////////////////////////////////////////////////////////////////
		//|
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
		|	МАКСИМУМ(ЦеныНоменклатурыСрезПоследних.Цена) КАК Цена,
		|	ЦеныНоменклатурыСрезПоследних.Период КАК ДатаПоследнейУстановленнойЦеныПродажи,
		|	ЦеныНоменклатурыСрезПоследних.Характеристика
		|ПОМЕСТИТЬ ЦеныПродажи
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			,
		|			Актуальность
		|				И ВидЦен = &ВидЦенПродажи
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						Запасы.Номенклатура
		|					ИЗ
		|						Запасы КАК Запасы)) КАК ЦеныНоменклатурыСрезПоследних
		|
		|СГРУППИРОВАТЬ ПО
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Период,
		|	ЦеныНоменклатурыСрезПоследних.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.ВидЦенКонтрагента,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Период КАК Период,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Цена,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Характеристика
		|ПОМЕСТИТЬ ЦеныК
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатурыКонтрагентов.СрезПоследних(
		|			,
		|			Актуальность
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						Запасы.Номенклатура
		|					ИЗ
		|						Запасы КАК Запасы)) КАК ЦеныНоменклатурыКонтрагентовСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныК.Номенклатура,
		|	МАКСИМУМ(ЦеныК.Период) КАК Период,
		|	ЦеныК.Характеристика
		|ПОМЕСТИТЬ ДатыПоследнихЦенК
		|ИЗ
		|	ЦеныК КАК ЦеныК
		|
		|СГРУППИРОВАТЬ ПО
		|	ЦеныК.Номенклатура,
		|	ЦеныК.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныК.Номенклатура,
		|	ЦеныК.Цена,
		|	ЦеныК.ВидЦенКонтрагента,
		|	ЦеныК.Период,
		|	ЦеныК.Характеристика
		|ПОМЕСТИТЬ ПоследниеЦеныК
		|ИЗ
		|	ЦеныК КАК ЦеныК
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихЦенК КАК ДатыПоследнихЦенК
		|		ПО ЦеныК.Номенклатура = ДатыПоследнихЦенК.Номенклатура
		|			И ЦеныК.Характеристика = ДатыПоследнихЦенК.Характеристика
		|			И ЦеныК.Период = ДатыПоследнихЦенК.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоследниеЦеныК.Номенклатура,
		|	ПоследниеЦеныК.Характеристика,
		|	МАКСИМУМ(ПоследниеЦеныК.Период) КАК Период,
		|	МАКСИМУМ(ПоследниеЦеныК.Цена) КАК Цена
		|ПОМЕСТИТЬ СрезПоследнихБезДок
		|ИЗ
		|	ПоследниеЦеныК КАК ПоследниеЦеныК
		|
		|СГРУППИРОВАТЬ ПО
		|	ПоследниеЦеныК.Номенклатура,
		|	ПоследниеЦеныК.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СрезПоследнихБезДок.Номенклатура КАК Номенклатура,
		|	СрезПоследнихБезДок.Характеристика,
		|	МАКСИМУМ(ПоследниеЦеныК.ВидЦенКонтрагента) КАК ВидЦенКонтрагента,
		|	СрезПоследнихБезДок.Период КАК ДатаПоследнейЦеныЗакупки,
		|	СрезПоследнихБезДок.Цена КАК ЦенаЗакупки
		|ПОМЕСТИТЬ СрезПоследних
		|ИЗ
		|	СрезПоследнихБезДок КАК СрезПоследнихБезДок
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоследниеЦеныК КАК ПоследниеЦеныК
		|		ПО СрезПоследнихБезДок.Номенклатура = ПоследниеЦеныК.Номенклатура
		|			И СрезПоследнихБезДок.Период = ПоследниеЦеныК.Период
		|			И СрезПоследнихБезДок.Цена = ПоследниеЦеныК.Цена
		|			И СрезПоследнихБезДок.Характеристика = ПоследниеЦеныК.Характеристика
		|
		|СГРУППИРОВАТЬ ПО
		|	СрезПоследнихБезДок.Номенклатура,
		|	СрезПоследнихБезДок.Период,
		|	СрезПоследнихБезДок.Цена,
		|	СрезПоследнихБезДок.Характеристика
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура,
		|	ВидЦенКонтрагента,
		|	ЦенаЗакупки,
		|	ДатаПоследнейЦеныЗакупки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Номенклатура,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Характеристика,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.ВидЦенКонтрагента,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Период,
		|	ЦеныНоменклатурыКонтрагентовСрезПоследних.Цена
		|ПОМЕСТИТЬ ЦеныКДо
		|ИЗ
		|	Запасы КАК Запасы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатурыКонтрагентов.СрезПоследних(
		|				,
		|				Актуальность
		|					И НЕ (Номенклатура, ВидЦенКонтрагента, Период, Цена) В
		|							(ВЫБРАТЬ
		|								СрезПоследних.Номенклатура,
		|								СрезПоследних.ВидЦенКонтрагента,
		|								СрезПоследних.ДатаПоследнейЦеныЗакупки,
		|								СрезПоследних.ЦенаЗакупки
		|							ИЗ
		|								СрезПоследних КАК СрезПоследних)) КАК ЦеныНоменклатурыКонтрагентовСрезПоследних
		|		ПО Запасы.Номенклатура = ЦеныНоменклатурыКонтрагентовСрезПоследних.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныКДо.Номенклатура,
		|	ЦеныКДо.Характеристика,
		|	МАКСИМУМ(ЦеныКДо.Период) КАК Период
		|ПОМЕСТИТЬ ДатыПоследнихЦенКДо
		|ИЗ
		|	ЦеныКДо КАК ЦеныКДо
		|
		|СГРУППИРОВАТЬ ПО
		|	ЦеныКДо.Номенклатура,
		|	ЦеныКДо.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныКДо.Номенклатура,
		|	ЦеныКДо.Цена,
		|	ЦеныКДо.ВидЦенКонтрагента,
		|	ЦеныКДо.Период,
		|	ЦеныКДо.Характеристика
		|ПОМЕСТИТЬ ПоследниеЦеныКДо
		|ИЗ
		|	ЦеныКДо КАК ЦеныКДо
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДатыПоследнихЦенКДо КАК ДатыПоследнихЦенКДо
		|		ПО ЦеныКДо.Номенклатура = ДатыПоследнихЦенКДо.Номенклатура
		|			И ЦеныКДо.Характеристика = ДатыПоследнихЦенКДо.Характеристика
		|			И ЦеныКДо.Период = ДатыПоследнихЦенКДо.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоследниеЦеныКДо.Номенклатура,
		|	ПоследниеЦеныКДо.Характеристика,
		|	МАКСИМУМ(ПоследниеЦеныКДо.Период) КАК Период,
		|	МАКСИМУМ(ПоследниеЦеныКДо.Цена) КАК Цена
		|ПОМЕСТИТЬ СрезПоследнихДо
		|ИЗ
		|	ПоследниеЦеныКДо КАК ПоследниеЦеныКДо
		|
		|СГРУППИРОВАТЬ ПО
		|	ПоследниеЦеныКДо.Номенклатура,
		|	ПоследниеЦеныКДо.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Запасы.Номенклатура,
		|	Запасы.Характеристика,
		|	СрезПоследнихДо.Цена КАК ЦенаЗакупкиПред,
		|	СрезПоследних.ЦенаЗакупки,
		|	СрезПоследнихДо.Период КАК ДатаПоследнейЦеныЗакупки,
		|	ЕСТЬNULL(ЦеныПродажи.Цена, 0) КАК ЦенаПродажиТекущая,
		|	ЦеныПродажи.ДатаПоследнейУстановленнойЦеныПродажи,
		|	ВЫБОР
		|		КОГДА &Вариант2
		|			ТОГДА ЕСТЬNULL(ЦеныПродажи.Цена, 0) - ЕСТЬNULL(СрезПоследних.ЦенаЗакупки, 0)
		|		ИНАЧЕ ЕСТЬNULL(СрезПоследних.ЦенаЗакупки, 0) - ЕСТЬNULL(СрезПоследнихДо.Цена, 0)
		|	КОНЕЦ КАК РазностьЦеныЗакупки,
		|	ВЫБОР
		|		КОГДА &Вариант2
		|			ТОГДА ВЫБОР
		|					КОГДА ЕСТЬNULL(СрезПоследних.ЦенаЗакупки, 0) = 0
		|						ТОГДА 0
		|					ИНАЧЕ (ЕСТЬNULL(ЦеныПродажи.Цена, 0) - ЕСТЬNULL(СрезПоследних.ЦенаЗакупки, 0)) / ЕСТЬNULL(СрезПоследних.ЦенаЗакупки, 0) * 100
		|				КОНЕЦ
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ЕСТЬNULL(СрезПоследних.ЦенаЗакупки, 0) = 0
		|						ИЛИ ЕСТЬNULL(СрезПоследнихДо.Цена, 0) = 0
		|					ТОГДА 0
		|				ИНАЧЕ ВЫРАЗИТЬ(СрезПоследних.ЦенаЗакупки / СрезПоследнихДо.Цена * 100 - 100 КАК ЧИСЛО(15, 2))
		|			КОНЕЦ
		|	КОНЕЦ КАК РазностьЦеныЗакупкиПроцент
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Запасы КАК Запасы
		|		ЛЕВОЕ СОЕДИНЕНИЕ СрезПоследних КАК СрезПоследних
		|		ПО Запасы.Номенклатура = СрезПоследних.Номенклатура
		|			И Запасы.Характеристика = СрезПоследних.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныПродажи КАК ЦеныПродажи
		|		ПО Запасы.Номенклатура = ЦеныПродажи.Номенклатура
		|			И Запасы.Характеристика = ЦеныПродажи.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ СрезПоследнихДо КАК СрезПоследнихДо
		|		ПО Запасы.Номенклатура = СрезПоследнихДо.Номенклатура
		|			И Запасы.Характеристика = СрезПоследнихДо.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Номенклатура,
		|	ВТ.Характеристика,
		|	ВТ.ЦенаЗакупкиПред,
		|	ВТ.ЦенаЗакупки,
		|	ВТ.ДатаПоследнейЦеныЗакупки,
		|	ВТ.ЦенаПродажиТекущая,
		|	ВТ.ДатаПоследнейУстановленнойЦеныПродажи,
		|	ВТ.РазностьЦеныЗакупки,
		|	ВТ.РазностьЦеныЗакупкиПроцент,
		|	ВЫБОР
		|		КОГДА &Вариант2
		|			ТОГДА 0
		|		ИНАЧЕ ВЫБОР
		|				КОГДА ВТ.ЦенаПродажиТекущая = 0
		|					ТОГДА 0
		|				ИНАЧЕ ВТ.РазностьЦеныЗакупкиПроцент
		|			КОНЕЦ
		|	КОНЕЦ КАК НадбавкаПроцент,
		|	ВЫБОР
		|		КОГДА &Вариант2
		|			ТОГДА 0
		|		ИНАЧЕ ВЫРАЗИТЬ(ВТ.ЦенаПродажиТекущая * ВТ.РазностьЦеныЗакупкиПроцент / 100 КАК ЧИСЛО(15, 2))
		|	КОНЕЦ КАК Надбавка,
		|	ВЫБОР
		|		КОГДА &Вариант2
		|			ТОГДА 0
		|		ИНАЧЕ ВЫРАЗИТЬ(ВТ.ЦенаПродажиТекущая * (1 + ВТ.РазностьЦеныЗакупкиПроцент / 100) КАК ЧИСЛО(15, 2))
		|	КОНЕЦ КАК ЦенаПродажиНовая,
		|	""%"" КАК ЗнакПроцент
		|ИЗ
		|	ВТ КАК ВТ";
	//Запрос.УстановитьПараметр("СписокДокументов", 	СписокДокументов);
	//Запрос.УстановитьПараметр("ВидЦенКонтрагента", 	Объект.ВидЦенКонтрагента);
	Запрос.УстановитьПараметр("ВидЦенПродажи", 		Объект.ВидЦенПродажи);
	Запрос.УстановитьПараметр("Вариант2", 			Вариант2);
	
	ТаблицаЗапасов = Запрос.Выполнить().Выгрузить();
	Объект.Таблица.Загрузить(ТаблицаЗапасов);
	//Рассчитать_ЦенаПродажиНоваяНаСервере();

КонецПроцедуры





