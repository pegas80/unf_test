
&НаКлиенте
Процедура ЗаполнитьПоПриходнымНакладным(Команда)
	
	ОчиститьСообщения();

	НеЗаполненыЦены = ПроверкаПередЗаполнением();
	Если НеЗаполненыЦены Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ЗаполнитьТаблицу() Тогда
		Возврат;
	КонецЕсли;
	
	Отбор = Новый Структура("Проведен", 	Истина);
	ВыбранныеЗначения = ОткрытьФормуМодально("Документ.ПриходнаяНакладная.ФормаВыбора", Новый Структура("Отбор, МножественныйВыбор", Отбор, Истина));
	Если ВыбранныеЗначения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	//ЗаполнитьТовары_НаСервере(СписокДокументов)
	Вариант2 = Ложь;
	УстановитьВидимость();	
	СформироватьТаблицуЗапасов("ЗаполнитьПоПриходнымНакладным", ВыбранныеЗначения);

КонецПроцедуры

