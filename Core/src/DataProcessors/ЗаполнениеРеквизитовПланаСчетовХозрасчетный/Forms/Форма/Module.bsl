
&НаСервере
Процедура ЗаполнитьНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Хозрасчетный.Ссылка КАК СчетХозрасчетного,
		|	Хозрасчетный.СчетАналогУУ.ТипСчета КАК ТипСчета,
		|	Хозрасчетный.СчетАналогУУ.СпособРаспределения КАК СпособРаспределения,
		|	Хозрасчетный.СчетАналогУУ.СчетЗакрытия КАК СчетЗакрытия,
		|	Хозрасчетный.СчетАналогУУ.АналитикаДоходовИРасходов КАК АналитикаДоходовИРасходов
		|ИЗ
		|	ПланСчетов.Хозрасчетный КАК Хозрасчетный";
	
	тзРезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	КоличествоОбходов = тзРезультатЗапроса.Количество();
	Инд = 0;
	Для Каждого Строк Из тзРезультатЗапроса Цикл
		
		СчетОбъект = Строк.СчетХозрасчетного.ПолучитьОбъект();
		
		ЗаполнитьЗначенияСвойств(СчетОбъект, Строк);
		
		Попытка
			СчетОбъект.Записать();
		Исключение
			Сообщить(НСтр("ru = 'Не заполнить счет: "+Строк.СчетХозрасчетного+"'; ka = 'Не заполнить счет: "+Строк.СчетХозрасчетного+"'"));
		КонецПопытки;
		
		Индикатор = Инд*100/КоличествоОбходов;
		Инд = Инд + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Заполнить(Команда)
	ЗаполнитьНаСервере();
КонецПроцедуры
