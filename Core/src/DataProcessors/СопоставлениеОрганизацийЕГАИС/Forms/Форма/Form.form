  <attributes>
    <name>СписокОрганизацийЕГАИС</name>
    <title>
      <key>ru</key>
      <value>Список организаций ЕГАИС</value>
    </title>
    <title>
      <key>ka</key>
      <value>Список организаций ЕГАИС</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокОрганизацийЕГАИС.ИдентификаторУпаковки</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокОрганизацийЕГАИС.Номенклатура</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокОрганизацийЕГАИС.Code</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокОрганизацийЕГАИС.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокОрганизацийЕГАИС.ИНН</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокОрганизацийЕГАИС.Контрагент</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	КлассификаторОрганизацийЕГАИС.Ссылка,
	КлассификаторОрганизацийЕГАИС.ПометкаУдаления,
	КлассификаторОрганизацийЕГАИС.Код,
	КлассификаторОрганизацийЕГАИС.Наименование,
	КлассификаторОрганизацийЕГАИС.НаименованиеПолное,
	КлассификаторОрганизацийЕГАИС.ИНН,
	КлассификаторОрганизацийЕГАИС.КПП,
	КлассификаторОрганизацийЕГАИС.КодСтраны,
	КлассификаторОрганизацийЕГАИС.КодРегиона,
	КлассификаторОрганизацийЕГАИС.ПочтовыйИндекс,
	КлассификаторОрганизацийЕГАИС.ПредставлениеАдреса,
	КлассификаторОрганизацийЕГАИС.Предопределенный,
	КлассификаторОрганизацийЕГАИС.ИмяПредопределенныхДанных,
	КлассификаторОрганизацийЕГАИС.Представление,
	ЕСТЬNULL(СоответствиеОрганизацийЕГАИС.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент
ИЗ
	Справочник.КлассификаторОрганизацийЕГАИС КАК КлассификаторОрганизацийЕГАИС
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			СоответствиеОрганизацийЕГАИС.ОрганизацияЕГАИС КАК ОрганизацияЕГАИС,
			СоответствиеОрганизацийЕГАИС.Контрагент КАК Контрагент
		ИЗ
			РегистрСведений.СоответствиеОрганизацийЕГАИС КАК СоответствиеОрганизацийЕГАИС) КАК СоответствиеОрганизацийЕГАИС
		ПО КлассификаторОрганизацийЕГАИС.Ссылка = СоответствиеОрганизацийЕГАИС.ОрганизацияЕГАИС</queryText>
      <mainTable>Catalog.КлассификаторОрганизацийЕГАИС</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
