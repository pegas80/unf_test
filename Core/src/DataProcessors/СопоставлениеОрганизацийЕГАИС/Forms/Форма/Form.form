  <formCommands>
    <name>УстановитьСоответствие</name>
    <title>
      <key>ru</key>
      <value>Сопоставить</value>
    </title>
    <title>
      <key>ka</key>
      <value>შედარება</value>
    </title>
    <id>1</id>
    <toolTip>
      <key>ru</key>
      <value>Установить соответствие</value>
    </toolTip>
    <toolTip>
      <key>ka</key>
      <value>Установить соответствие</value>
    </toolTip>
    <use>
      <common>true</common>
