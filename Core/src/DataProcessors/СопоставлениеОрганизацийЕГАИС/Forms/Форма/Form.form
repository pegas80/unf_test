      <segments>СписокКонтрагентов.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокКонтрагентов.ЕстьСоответствие</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокКонтрагентов.ИНН</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Контрагенты.Ссылка,
	Контрагенты.ПометкаУдаления,
	Контрагенты.Родитель,
	Контрагенты.ЭтоГруппа,
	Контрагенты.Код,
	Контрагенты.Наименование,
	Контрагенты.ИНН,
	Контрагенты.КодПоОКПО,
	Контрагенты.Комментарий,
	Контрагенты.КПП,
	Контрагенты.НаименованиеПолное,
	Контрагенты.ВидКонтрагента,
	Контрагенты.Предопределенный,
	Контрагенты.ИмяПредопределенныхДанных,
	Контрагенты.Представление,
	ВЫБОР
		КОГДА СоответствиеОрганизацийЕГАИС.Контрагент ЕСТЬ NULL 
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ЕстьСоответствие
ИЗ
	Справочник.Контрагенты КАК Контрагенты
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			СоответствиеОрганизацийЕГАИС.Контрагент КАК Контрагент
		ИЗ
			РегистрСведений.СоответствиеОрганизацийЕГАИС КАК СоответствиеОрганизацийЕГАИС) КАК СоответствиеОрганизацийЕГАИС
		ПО Контрагенты.Ссылка = СоответствиеОрганизацийЕГАИС.Контрагент</queryText>
      <mainTable>Catalog.Контрагенты</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
