Функция ПолучитьЗначениеСвойства(НаименованиеЗначения, СвойствоОбъекта)
	Результат = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(НаименованиеЗначения, , ,СвойствоОбъекта);
	Если Результат = Справочники.ЗначенияСвойствОбъектов.ПустаяСсылка() Тогда
		Результат = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
		Результат.Наименование = НаименованиеЗначения;
		Результат.Владелец = СвойствоОбъекта;
		Результат.Записать();				
	КонецЕсли;
Возврат Результат.Ссылка;
КонецФункции

Функция СоздатьНоменклатуру(ВыборкаЗапроса)
	Элемент = Справочники.Номенклатура.СоздатьЭлемент();
	
	Элемент.Родитель			= ЭтотОбъект.ГруппаДляЗагрузкиНоменклатуры;
	//Паганини_
	//Элемент.НоменклатурнаяГруппа= ЭтотОбъект.НоменклатурнаяГруппа;
	Элемент.КатегорияНоменклатуры = ЭтотОбъект.НоменклатурнаяГруппа;
	//_Паганини
	Элемент.СчетУчетаЗапасов	= ЭтотОбъект.СчетУчетаЗапасов;
	Элемент.СчетУчетаЗатрат		= ЭтотОбъект.СчетУчетаЗатрат;
	//Паганини_
	Элемент.СчетУчетаЗапасовРегл	= ЭтотОбъект.СчетУчетаЗапасовРегл;
	Элемент.СчетУчетаЗатратРегл		= ЭтотОбъект.СчетУчетаЗатратРегл;
	//_Паганини
	Элемент.ЕдиницаИзмерения	= ЭтотОбъект.ЕдиницаИзмерения;
	Элемент.СтавкаНДС			= ЭтотОбъект.СтавкаНДС;
	
	
	Элемент.НаправлениеДеятельности = Справочники.НаправленияДеятельности.ОсновноеНаправление;
	Элемент.СпособПополнения		= Перечисления.СпособыПополненияЗапасов.Закупка;
	Элемент.МетодОценки				= Перечисления.МетодОценкиЗапасов.ПоСредней;
	Элемент.ТипНоменклатуры			= Перечисления.ТипыНоменклатуры.Запас;
	
	Элемент.Наименование		= ВыборкаЗапроса.Наименование;
	Элемент.НаименованиеПолное	= ВыборкаЗапроса.Наименование;
	
	Элемент.ИспользоватьХарактеристики = Истина;
	Элемент.Записать();
	
	Возврат Элемент.Ссылка;
КонецФункции

Функция СоздатьХарактеристику(Номенклатура, ВыборкаПоХарактеристикам)
	Характеристика = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
	
	Характеристика.Владелец = Номенклатура;
	Характеристика.Наименование = ВыборкаПоХарактеристикам.Размер;		
	
	//Паганини_
	//СтрокаСвойств = Характеристика.ДополнительныеРеквизиты.Добавить();
	//// у характеристики только одно свойство, в будущем будет более общий вариант
	//СвойствоХарактеристики = НоменклатурнаяГруппа.НаборСвойствХарактеристики.ДополнительныеРеквизиты[0].Свойство;
	//СтрокаСвойств.Свойство = СвойствоХарактеристики;
	//СтрокаСвойств.Значение = ПолучитьЗначениеСвойства(ВыборкаПоХарактеристикам.Размер, СвойствоХарактеристики);				
	//_Паганини
	
	Характеристика.Записать();
Возврат Характеристика.Ссылка;
КонецФункции

Функция ЗарегистрироватьШтрихКод(Характеристика, ВыборкаПоХарактеристикам)
	Запись = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
	Запись.Номенклатура		= Характеристика.Владелец;
	Запись.Характеристика	= Характеристика;
	Запись.Штрихкод			= ВыборкаПоХарактеристикам.Штрихкод;
	Запись.Записать();	
КонецФункции

Функция ЗарегистрироватьЦенуКонтрагента(Характеристика, ВыборкаПоХарактеристикам)
	Если ЭтотОбъект.ВидЦенКонтрагента.Пустая() Тогда 
		Возврат Ложь;
	КонецЕсли;
	Запись = РегистрыСведений.ЦеныНоменклатурыКонтрагентов.СоздатьМенеджерЗаписи();
	Запись.Период = ДатаЗагрузки;	
	Запись.Номенклатура			= Характеристика.Владелец;
	Запись.Характеристика		= Характеристика;
	Запись.ВидЦенКонтрагента	= ЭтотОбъект.ВидЦенКонтрагента;
	Запись.ЕдиницаИзмерения		= ЭтотОбъект.ЕдиницаИзмерения;
	Запись.Цена					= ВыборкаПоХарактеристикам.ЦенаЗакупки;
	Запись.Записать();
Возврат Истина;
КонецФункции

Функция ЗарегистрироватьЦенуРеализации(Характеристика, ВыборкаПоХарактеристикам)
	Если ЭтотОбъект.ВидЦен.Пустая() Тогда 
		Возврат Ложь;
	КонецЕсли;
	Запись = РегистрыСведений.ЦеныНоменклатуры.СоздатьМенеджерЗаписи();
	Запись.Период = ДатаЗагрузки;	
	Запись.Номенклатура			= Характеристика.Владелец;
	Запись.Характеристика		= Характеристика;
	Запись.ВидЦен				= ЭтотОбъект.ВидЦен;
	Запись.ЕдиницаИзмерения		= ЭтотОбъект.ЕдиницаИзмерения;
	Запись.Цена					= ВыборкаПоХарактеристикам.ЦенаПродажи;
	Запись.Записать();
Возврат Истина;
КонецФункции

//////////////////////////////////////////////////////////////////////////////
// Функции и процедуры для обработки данных из файла 
//

// Обновление данных планов счетов
Функция ОбработкаДанныхИзФайла(СтраницыИзФайла, АдресХранилища = Неопределено) Экспорт
	Если АдресХранилища = Неопределено Тогда 
		АдресХранилища = АдресВременногоХранилища;
	КонецЕсли;
	Если ПустаяСтрока(АдресХранилища) ИЛИ (Не ВыполнитьЗагрузкуДанныхИзВременногоХранилища(АдресХранилища))	Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	// Запустим приложение EXCEL
	Попытка
		Excel = новый COMОбъект("Excel.Application");
	Исключение
		Сообщить(НСтр("ka='როგორც ჩანს სერვერზე არ არის დაყენებული Microsoft Excel, გთხოვთ სცადოთ დაინსტალირების შემდეგ';ru='По всей видимости на сервере не установлен Microsoft Excel, повторите попытку после установки.'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Возврат Неопределено;
	КонецПопытки; 
	
	// Откроем файл EXCEL-а 
	Попытка
		Excel.Workbooks.Open(ИмяВременногоФайла);
	Исключение
		Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის გახსნა!';ru='Не удалось открыть файл!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Excel.Quit();
		Возврат Неопределено;
	КонецПопытки;	

	
	//Получим количество строк и колонок.
	//В разных версиях Excel получаются по-разному, поэтому сначала определим версию Excel
	Версия = Лев(Excel.Version,Найти(Excel.Version,".")-1);

	// Создание таблицы значений 
	ТаблицаЗначений = Новый ТаблицаЗначений;
	
	Массив = Новый Массив;
	Массив.Добавить(Тип("Строка"));
	КС = Новый КвалификаторыСтроки(256, ДопустимаяДлина.Переменная);
	ОписаниеТипа = Новый ОписаниеТипов(Массив,,КС);
	
	// добавим в таблицу значений три колонки
	ТаблицаЗначений.Колонки.Добавить("Наименование", ОписаниеТипа,"Наименование");
	ТаблицаЗначений.Колонки.Добавить("Штрихкод", ОписаниеТипа,"Штрихкод");
	ТаблицаЗначений.Колонки.Добавить("Размер", ОписаниеТипа,"Размер");
	ТаблицаЗначений.Колонки.Добавить("ЦенаЗакупки", ОписаниеТипа,"Цена закупки");
	ТаблицаЗначений.Колонки.Добавить("ЦенаПродажи", ОписаниеТипа,"Цена продажи");
	
	Запрос = Новый Запрос();
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВТДанныеИЗФайла.Наименование,
	               |	ВТДанныеИЗФайла.Штрихкод,
	               |	ВТДанныеИЗФайла.Размер,
	               |	ВТДанныеИЗФайла.ЦенаЗакупки,
	               |	ВТДанныеИЗФайла.ЦенаПродажи
	               |ПОМЕСТИТЬ ВТТаблица
	               |ИЗ
	               |	&ВТДанныеИЗФайла КАК ВТДанныеИЗФайла
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТТаблица.Наименование КАК Наименование,
	               |	ВТТаблица.Штрихкод КАК Штрихкод,
	               |	ВТТаблица.Размер КАК Размер,
	               |	ВТТаблица.ЦенаЗакупки КАК ЦенаЗакупки,
	               |	ВТТаблица.ЦенаПродажи КАК ЦенаПродажи
	               |ИЗ
	               |	ВТТаблица КАК ВТТаблица
	               |ИТОГИ
	               |	КОЛИЧЕСТВО(Штрихкод),
	               |	КОЛИЧЕСТВО(Размер),
	               |	МАКСИМУМ(ЦенаЗакупки),
	               |	МАКСИМУМ(ЦенаПродажи)
	               |ПО
	               |	Наименование";
	
	Попытка
		НачатьТранзакцию();					   
		ДатаЗагрузки = ТекущаяДата();					   
		Для Каждого Эл Из СтраницыИзФайла Цикл
			
			// Проверка по страницам
			Если Эл.Используеться = Ложь
				// Или Эл.Наименование <> "ОбновлениеПлановСчетов"
					Тогда 
				Продолжить;
			КонецЕсли;
			
			ТаблицаЗначений.Очистить();
			// Обход страницы в файле и генерируем таблицу значений
			Для ИндексСтроки = 2 По Эл.Строк Цикл
	        	СтрокаТЗ = ТаблицаЗначений.Добавить();
				СтрокаТЗ["Наименование"]	= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,1).Value);
				СтрокаТЗ["Штрихкод"]		= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,2).Value);
				СтрокаТЗ["Размер"]			= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,3).Value);
				СтрокаТЗ["ЦенаЗакупки"]		= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,4).Value);
				СтрокаТЗ["ЦенаПродажи"]		= СокрЛП(Excel.Sheets(Эл.Номер).Cells(ИндексСтроки,5).Value);
			КонецЦикла;
			
			Запрос.УстановитьПараметр("ВТДанныеИЗФайла", ТаблицаЗначений);
			ВыборкаПоНоменклатуре = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаПоНоменклатуре.Следующий() Цикл 
				Если ВыборкаПоНоменклатуре.Наименование = Неопределено ИЛИ ПустаяСтрока(ВыборкаПоНоменклатуре.Наименование) Тогда 
					Продолжить;	
				КонецЕсли;

				Номенклатура = СоздатьНоменклатуру(ВыборкаПоНоменклатуре);
				
				ВыборкаПоХарактеристикам = ВыборкаПоНоменклатуре.Выбрать();
				
				Пока ВыборкаПоХарактеристикам.Следующий() Цикл 
					
					Характеристика = СоздатьХарактеристику(Номенклатура, ВыборкаПоХарактеристикам);
					
					ЗарегистрироватьШтрихКод(Характеристика, ВыборкаПоХарактеристикам);
					
					ЗарегистрироватьЦенуКонтрагента(Характеристика, ВыборкаПоХарактеристикам);
					
                    ЗарегистрироватьЦенуРеализации(Характеристика, ВыборкаПоХарактеристикам);
					
				КонецЦикла; // Конец обработки характеристик
			КонецЦикла; // Конец обработки номенклатуры
		КонецЦикла; // Конец обработки страницы из файла
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის შიგთავსის დამუშავება!';ru='Не удалось обработать содержимое файла!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Excel.Quit();
		Возврат Неопределено;		
	КонецПопытки;
	
	// Закроем приложение EXCEL
	Excel.ActiveWorkbook.Close();
	Excel.Quit();
	
	// удалим временный файл созданный на сервере
	УдалитьВременныйФайл();	
КонецФункции


