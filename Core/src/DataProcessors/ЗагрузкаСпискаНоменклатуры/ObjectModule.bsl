// Генерация шаблона для обновления данных планов счетов
Функция СгенерироватьШаблонДляФайлаИмпорта(УникальныйИдентификаторФормы) Экспорт 
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		
		Попытка
			Excel = новый COMОбъект("Excel.Application");
		Исключение
			Сообщить(НСтр("ka='როგორც ჩანს სერვერზე არ არის დაყენებული Microsoft Excel, გთხოვთ სცადოთ დაინსტალირების შემდეგ';ru='По всей видимости на сервере не установлен Microsoft Excel, повторите попытку после установки.'"));
			Ошибка = ОписаниеОшибки();
			Сообщить(Ошибка);
			Возврат Неопределено;
		КонецПопытки;
		
		Попытка
						
			Версия = Число(Лев(Excel.Version,Найти(Excel.Version,".")-1));
			
			Если Версия < 13 Тогда // если установлен 2003 и более ранний ексель то используем старый формат
				// получаем имя временного файла в локальной ФС на сервере
				ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xls");
			Иначе //иначе испорльзуем новый формат
				// получаем имя временного файла в локальной ФС на сервере
				ИмяВременногоФайла = ПолучитьИмяВременногоФайла("xlsx");				
			КонецЕсли;
			
			КнигаExcel = Excel.WorkBooks.Add();
			Страница1 = КнигаExcel.WorkSheets.Add();
			Страница1.Name = "ДанныеПоНоменклатуре";
			Страница1.Cells(1,1).Value = "'Артикул / наименование";
			Страница1.Cells(1,2).Value = "'Штрихкод";
			Страница1.Cells(1,3).Value = "'Размер";
			Страница1.Cells(1,4).Value = "'Цена закупки";
			Страница1.Cells(1,5).Value = "'Цена продажи";
			КнигаExcel.SaveAs(ИмяВременногоФайла);
			
			// Закроем приложение EXCEL
			Excel.ActiveWorkbook.Close();
			Excel.Quit();			
			
			Адрес = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяВременногоФайла), УникальныйИдентификаторФормы);
			
			// удалим временный файл созданный на сервере 
			УдалитьВременныйФайл();			
		Исключение
			Сообщить(НСтр("ka='ვერ მოხერხდა ფაილის გახსნა!';ru='Не удалось создать файл!'"));
			Ошибка = ОписаниеОшибки();
			Сообщить(Ошибка);
			Excel.Quit();
			Возврат Неопределено;
		КонецПопытки;
		
	Возврат Версия;	
	
	Исключение
		Сообщить(НСтр("ka='Не удалось создать файл на диске из временного хранилища!';ru='Не удалось создать файл на диске из временного хранилища!'"));
		Ошибка = ОписаниеОшибки();
		Сообщить(Ошибка);
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции
