
&НаСервере
Процедура ОчиститьНаСервере()
	
	ВсеСправочники = Метаданные.Справочники;
	
	СтруктураДанныхЗапроса = Новый Структура;
	Для Каждого Спр Из ВсеСправочники Цикл 
		
		ИмяСправочника = Спр.Имя;
		
		МассивИменРеквизитов = Новый Массив;
		Для Каждого Ревк ИЗ Спр.Реквизиты Цикл 
			
			ОписаниеТиповРекв = Ревк.Тип;
			
			Для Каждого Типа Из ОписаниеТиповРекв.Типы() Цикл 
				
				Попытка
					Если Метаданные.НайтиПоТипу(Типа).ПолноеИмя() = "ПланСчетов.Управленческий" Тогда 
						
						а=1;
						МассивИменРеквизитов.Добавить(Ревк.Имя);
						
					КонецЕсли;
				Исключение
					Продолжить;
				КонецПопытки;
				
			КонецЦикла;
			
		КонецЦикла;
		
		Если МассивИменРеквизитов.Количество() > 0 Тогда 
			
			СтруктураДанныхЗапроса.Вставить(ИмяСправочника, МассивИменРеквизитов);
			
		КонецЕсли;
		
		//Метаданные.НайтиПоТипу(Спр.Реквизиты[0].Тип.Типы()[0]).ПолноеИмя()
	КонецЦикла;
	
	ПустаяСсылкаУпрПланаСчетов = ПланыСчетов.Управленческий.ПустаяСсылка();
	
	КоличествоОбходов = СтруктураДанныхЗапроса.Количество();
	Инд = 0;
	Для Каждого КлючЗначение Из СтруктураДанныхЗапроса Цикл
		
		ВыборкаСсылок = ПолучитьВыборку(КлючЗначение.Ключ);
		
		Пока ВыборкаСсылок.Следующий() Цикл 
			
			СпрОбъект = ВыборкаСсылок.Ссылка.ПолучитьОбъект();
			
			КолвоИзмененныхРеквизитов = 0;
			Для Каждого ИмениРекв Из КлючЗначение.Значение Цикл 
				
				Если ТипЗнч(СпрОбъект[ИмениРекв]) = Тип("ПланСчетовСсылка.Управленческий") Тогда 
					СпрОбъект[ИмениРекв] = ПустаяСсылкаУпрПланаСчетов; 
					КолвоИзмененныхРеквизитов = КолвоИзмененныхРеквизитов + 1;
				КонецЕсли;
				
			КонецЦикла;
			
			Если КолвоИзмененныхРеквизитов = 0 Тогда 
				Продолжить;
			КонецЕсли;
			
			Попытка
				СпрОбъект.Записать();
			Исключение
				Сообщить("Справочник: """+КлючЗначение.Ключ+""", Элемент: """+ВыборкаСсылок.Ссылка+""", не удалось записать");
			КонецПопытки;
			
		КонецЦикла;
		
		Индикатор = Инд*100/КоличествоОбходов;
		
		Инд = Инд + 1;
		
	КонецЦикла;
	
	а=1;
КонецПроцедуры

&НаСервере
Функция ПолучитьВыборку(ИмяСправочника)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Спр.Ссылка
		|ИЗ
		|	Справочник."+ ИмяСправочника +" КАК Спр";
	
	РезультатЗапроса = Запрос.Выполнить();
	      
	Возврат РезультатЗапроса.Выбрать();
	
КонецФункции

&НаКлиенте
Процедура Очистить(Команда)
	ОчиститьНаСервере();
КонецПроцедуры
