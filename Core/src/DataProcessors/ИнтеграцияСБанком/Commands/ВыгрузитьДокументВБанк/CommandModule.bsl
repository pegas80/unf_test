    СтруктураДругойБанкИностраннаяВалюта.Вставить("intermediaryBankCode",Неопределено);
    СтруктураДругойБанкИностраннаяВалюта.Вставить("intermediaryBankName",Неопределено);
    СтруктураДругойБанкИностраннаяВалюта.Вставить("chargeDetails",Неопределено);
	
	СтруктураВозврата.Вставить("TransferToOtherBankForeignCurrencyPaymentOrderIo", СтруктураДругойБанкИностраннаяВалюта);
	
	
	//TreasuryTransferPaymentOrderIo
	СтруктураКазначейчтво = Новый Структура;
	
	//СтруктураКазначейчтво.Вставить("singlePaymentRequestId",Неопределено);
	СтруктураКазначейчтво.Вставить("debitAccount",СтруктураDebit);
	СтруктураКазначейчтво.Вставить("documentNumber",Неопределено);
	СтруктураКазначейчтво.Вставить("amount",Структураamount);
	СтруктураКазначейчтво.Вставить("position",Неопределено);
	СтруктураКазначейчтво.Вставить("additionalDescription", Неопределено);
	//СтруктураКазначейчтво.Вставить("taxpayerCode", Неопределено);   Если Платим за когото
	//СтруктураКазначейчтво.Вставить("taxpayerName", Неопределено);
    СтруктураКазначейчтво.Вставить("treasuryCode", Неопределено);
	
	СтруктураВозврата.Вставить("TreasuryTransferPaymentOrderIo", СтруктураКазначейчтво);
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаСервере
Процедура ДоотпрвкаПакетПлатежейНаСервере(СтруктураПараметров, МассивПакетов)
	
	ТаблицаПозиций = Новый ТаблицаЗначений;
	ТаблицаПозиций.Колонки.Добавить("Позиция");
	ТаблицаПозиций.Колонки.Добавить("ДокументСсылка");
	ТаблицаПозиций.Колонки.Добавить("Сотрудник");
	
	СтруктураПараметров.Вставить("ТаблицаПозиций", ТаблицаПозиций);
	
	тзДоки = Новый ТаблицаЗначений;
	тзДоки.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.РасходСоСчета"));
	
	Для Каждого Элем Из МассивПакетов Цикл 
		СтрокТЗ = тзДоки.Добавить();//ЗагрузитьКолонку(МассивПакетов, "ДокументСсылка");
		СтрокТЗ.ДокументСсылка = Элем;
	КонецЦикла;
	
	тзДоки.Свернуть("ДокументСсылка");
	
	ТаблицаПакетнойВыгрузки = Новый ТаблицаЗначений;//= Объект[СтруктураПараметров.ИмяТабличнойЧасти].Выгрузить(Новый СТруктура("Пометка", Истина));//НайтиСтроки(Новый Структура("Пометка", Истина));
	ТаблицаПакетнойВыгрузки.Колонки.Добавить("Пометка",Новый ОписаниеТипов("Булево"));
	ТаблицаПакетнойВыгрузки.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.РасходСоСчета"));
	ТаблицаПакетнойВыгрузки.Колонки.Добавить("ИмяПакета", Новый ОписаниеТипов("Строка"));
	ТаблицаПакетнойВыгрузки.Колонки.Добавить("БанковскийСчет", Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета"));
	
	//Отказ = ПроверитьПравильностьЗаолнения(ТаблицаПакетнойВыгрузки);
	//
	//Если Отказ Тогда 
	//	Возврат;
	//КонецЕсли;
	
	Для Каждого Дока Из тзДоки Цикл 
		НовСтрок = ТаблицаПакетнойВыгрузки.Добавить();
		
		НовСтрок.Пометка = Истина;
		НовСтрок.ДокументСсылка = Дока.ДокументСсылка;
		НовСтрок.ИмяПакета = "Зарплата " + Строка(Дока.ДокументСсылка);
		НовСтрок.БанковскийСчет = Дока.ДокументСсылка.БанковскийСчет;
	КонецЦикла;
	
	
	тзПакетов = ТаблицаПакетнойВыгрузки.Скопировать(, "ИмяПакета");
	тзПакетов.Свернуть("ИмяПакета");
	
	ТекущийДокумент = Неопределено;
	Для Каждого ИмяПакета Из тзПакетов Цикл 
		
		СтруктураПараметров.ТаблицаПозиций.Очистить();
		
		тзОдногоПакета = ТаблицаПакетнойВыгрузки.Скопировать(Новый Структура("ИмяПакета", ИмяПакета.ИмяПакета));
		КолвоВыгруженныхДоков = 0;
		
		Если тзОдногоПакета.Количество() > 0 Тогда 
			
			СтруктураПараметров.Вставить("ТаблицаПакетнойВыгрузки", тзОдногоПакета);
			
			МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
			Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
			
			Если Структураответа.Свойство("mygeminiBatchId") Тогда 
				
				ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
				ПустойСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
				Статус = ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.INIT");
				
				УИД_Пакета = Структураответа.mygeminiBatchId;
				
				//Задержка перед запросом статуса пакета
				Для Сч=0 По 1000000 Цикл
				КонецЦикла;
				
				СтруктураУИД = ЗапроситьСтатусПакета(СокрЛП(УИД_Пакета),Истина, СтруктураПараметров);
				
				Если СтруктураУИД.Свойство("status") Тогда 
					СтатусПакета = СтруктураУИД.status;
				КонецЕсли;
				
				СтатусПакетаСсылка = ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.INIT");
				МассивОдиночныхДокументов = Новый Массив;
				Если СтруктураУИД.Свойство("status") Тогда 
					
					СтатусПакетаСтрока = СтруктураУИД.status;
					СтатусПакетаСсылка = Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке[СтатусПакетаСтрока];
					
					Банк = ?(ТипЗнч(тзОдногоПакета[0].ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), тзОдногоПакета[0].ДокументСсылка.БанковскийСчет.Банк, тзОдногоПакета[0].ДокументСсылка.Отправитель.Банк);
					ВнестиИнформациюСтатусаУИД(тзОдногоПакета[0].ДокументСсылка, ЗначениеСотрудника, УИД_Пакета, Банк, СтатусПакетаСсылка, ЛОЖЬ);
					
					Если СтруктураУИД.Свойство("batchPaymentData") Тогда
						МассивОдиночныхДокументов = СтруктураУИД.batchPaymentData;
					ИНаче
						КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
					КонецЕсли;
					
				КонецЕсли;
				
				Для Каждого Элем Из МассивОдиночныхДокументов Цикл 
					
					Позиция = Элем.position;
					СтатусСтрокой = Элем.paymentStatus;
					УИД_Позиции = Элем.paymentId;
					
					//Свойства ошибки 
					
					
					МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
					Если МассивНайденныхСтрок.Количество() > 0 Тогда 
						
						ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
						Сотрудник = МассивНайденныхСтрок[0].Сотрудник;
						
						Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
						
						Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
							ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
							
							ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Пакета, Банк, СтатусПакетаСсылка, ЛОЖЬ);
							
						КонецЕсли;
						
						СтатусСсылка = Перечисления.СтатусыДокументовВИнтернетБанке[СтатусСтрокой];//ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
						
						ВнестиИнформациюСтатусаУИД(ДокументСсылка, Сотрудник, УИД_Позиции, Банк, СтатусСсылка);
						
						Если ТекущийДокумент <> ДокументСсылка Тогда 
							Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
							КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
							ТекущийДокумент = ДокументСсылка;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				
			ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда
				
				 Сообщить(Структураответа.ТекстОшибки);
				 
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если СтруктураПараметров.Свойство("ТаблицаПакетнойВыгрузки") Тогда 
		СтруктураПараметров.ТаблицаПакетнойВыгрузки = Неопределено;
	КонецЕсли;
	
	Сообщить(НСтр("ru = 'Всего выгруженно пакетов: "+КолвоВыгруженныхДоков+"'; ka = 'Всего выгруженно пакетов: "+КолвоВыгруженныхДоков+"'"));
	
КонецПроцедуры

&НаСервере
Функция ЗапроситьСтатусПакета(УИД, ЭтоПакет = Истина, СтарыйСтруктураПараметров);
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				СтарыйСтруктураПараметров.USER);
	СтруктураПараметров.Вставить("PASSWORD",  			СтарыйСтруктураПараметров.PASSWORD);
	СтруктураПараметров.Вставить("Nonce",				СтарыйСтруктураПараметров.Nonce);
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", СтарыйСтруктураПараметров.ИспользоватьТестовыйРежим);
	СтруктураПараметров.Вставить("Метод",   			"GetPaymentOrderStatus");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo");
	СтруктураПараметров.Вставить("ЭтоПакет",   			ЭтоПакет);
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"">");
	СтруктураПараметров.Вставить("УИД", 				УИД);
	
	//ОбновитьСтатусыДокументовНаСервере(СтруктураПараметров, Ложь, ДокументСсылка);
	Возврат ЗапроситьСтатусыНаСервере(СтруктураПараметров);
	
КонецФункции

&НаСервере
Функция ЗапроситьСтатусыНаСервере(СтруктураПараметров);
	
	ОбработкаМенеджер = Обработки.ИнтеграцияСБанкомTBC;
	
	Возврат ОбработкаМенеджер.ОтправитьЗапросXML(СтруктураПараметров);
	
КонецФункции