	|			ТОГДА ВЫБОР
	|					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ПереводНаДругойСчет)
	|						ТОГДА ""ИНН организации""
	|					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику)
	|						ТОГДА """"
	|					ИНАЧЕ ""ИНН контрагента""
	|				КОНЕЦ
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""BeneficiaryName""
	|			ТОГДА ВЫБОР
	|					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ПереводНаДругойСчет)
	|						ТОГДА ""Наименование организации""
	|					КОГДА РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику)
	|						ТОГДА ""Наименование сотрудника""
	|					ИНАЧЕ ВЫБОР
	|							КОГДА (ВЫРАЗИТЬ(РасходСоСчета.Контрагент.НаименованиеПолное КАК СТРОКА(5))) = """"
	|								ТОГДА ""Наименование контрагента""
	|							ИНАЧЕ ""Наименование полное контрагента""
	|						КОНЕЦ
	|				КОНЕЦ
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""IntermediaryBankCode""
	|			ТОГДА ""SWIFT банка последника""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""IntermediaryBankName""
	|			ТОГДА ""Наименование банка посредника""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""AdditionalInformation""
	|			ТОГДА ""Коментарий""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""PaymentDetail""
	|			ТОГДА ""Назначение платежа""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""ValueDate""
	|			ТОГДА """"
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""UniqueId""
	|			ТОГДА """"
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Amount""
	|			ТОГДА ""Сумма документа""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Currency""
	|			ТОГДА ""Валюта документа""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DocumentNo""
	|			ТОГДА ""Номер документа""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""SourceAccountNumber""
	|			ТОГДА ""Номер банковского счета организации""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""BeneficiaryAccountNumber""
	|			ТОГДА ""Номер банковского счета получателя""
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""Nomination""
	|			ТОГДА """"
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""DispatchType""
	|			ТОГДА """"
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""PayerInn""
	|			ТОГДА ВЫБОР
	|					КОГДА РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.РасчетыПоКредитам)
	|							И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику)
	|						ТОГДА ""ИНН организации""
	|					ИНАЧЕ """"
	|				КОНЕЦ
	|		КОГДА ТаблицаПараметров.КлючОтправки = ""PayerName""
	|			ТОГДА """"
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
	|			ТОГДА ВЫБОР
	|					КОГДА РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК = ""BAGAGE22""
	|						ТОГДА ИСТИНА
	|					ИНАЧЕ ЛОЖЬ
	|				КОНЕЦ
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
	|			ТОГДА ВЫБОР
	|					КОГДА РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК = ""BAGAGE22""
	|						ТОГДА """"
	|					ИНАЧЕ ""Документ ПармДокументСсылка: Можно выгружать только счета с банком BAGAGE22""
	|				КОНЕЦ
	|		ИНАЧЕ ""Документ ПармДокументСсылка Ранее был выгружен""
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = """"
	|			ТОГДА ВЫБОР
	|					КОГДА РасходСоСчета.БанковскийСчет.Банк.СВИФТБИК = ""BAGAGE22""
	|						ТОГДА """"
	|					ИНАЧЕ ""Документ ПармДокументСсылка: Можно выгружать только счета с банком BAGAGE22""
	|				КОНЕЦ
	|		ИНАЧЕ ""Документ ПармДокументСсылка Ранее был выгружен""
	|	КОНЕЦ,
	|	РасходСоСчета.Проведен
	|ИЗ
	|	ВременнаяТаблицаПараметров КАК ТаблицаПараметров,
	|	Документ.РасходСоСчета КАК РасходСоСчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	|		ПО (УИДДокументовВИнтернетБанке.ДокументСсылка = РасходСоСчета.Ссылка)
	|ГДЕ
	|	РасходСоСчета.Ссылка В(&Ссылка)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Поставщику)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Покупателю)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Зарплата)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Налоги)
	|	И РасходСоСчета.ВалютаДенежныхСредств <> &НацВалюта
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Прочее)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.НаРасходы)
	|	И РасходСоСчета.ВидОперации <> ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.СнятиеНаличных)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	NULL,
	|	NULL,
	|	NULL,
	|	РасходСоСчета.Ссылка,
	|	NULL,
	|	NULL,
	|	ЛОЖЬ,
	|	""Выгрузка документа с видом операции ПарамВидОперации не предусмотрена"",
	|	""Выгрузка документа с видом операции ПарамВидОперации не предусмотрена"",
	|	NULL
	|ИЗ
	|	Документ.РасходСоСчета КАК РасходСоСчета
	|ГДЕ
	|	РасходСоСчета.Ссылка В(&Ссылка)
	|	И РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.Прочее)
	|	И РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.НаРасходы)
	|	И РасходСоСчета.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийРасходСоСчета.СнятиеНаличных)";
	
	Возврат ТекстВозврата;	
	
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапросаОкончания()
	
	ТекстВозврата = 
	"
	|;
	|///////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблицаОсновная.КлючОтправки,
	|	ВременнаяТаблицаОсновная.ЗначениеЗаполнения,
	|	ВременнаяТаблицаОсновная.ТребуетсяПроверка,
	|	ВременнаяТаблицаОсновная.Ссылка КАК Ссылка,
	|	ВременнаяТаблицаОсновная.СинонимРеквизитаRU,
	|	ВременнаяТаблицаОсновная.СинонимРеквизитаKA,
	|	ВременнаяТаблицаОсновная.ВыгрузкаРазрешена,
	|	ВременнаяТаблицаОсновная.ТекстОшибкиRU,
	|	ВременнаяТаблицаОсновная.ТекстОшибкиKA,
	|	ВременнаяТаблицаОсновная.Проведен
	|ИЗ
	|	ВременнаяТаблицаОсновная КАК ВременнаяТаблицаОсновная
	|ИТОГИ ПО
	|	Ссылка";
	Возврат ТекстВозврата;
	
КонецФункции

&НаСервере
Функция ПолучитьИмяМетода(ДокументСсылка, НацВалюта)
	
	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда
		
		Возврат "api/documents/conversion";	
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета") Тогда
		Если ДокументСсылка.ВалютаДенежныхСредств = НацВалюта 
			И Не ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата 
			И Не ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников Тогда 
			
			Возврат "api/documents/domestic";
			
		ИначеЕсли ДокументСсылка.ВалютаДенежныхСредств = НацВалюта
			И (ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата 
			ИЛИ ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников) ТОгда
			
			Возврат "api/documents/bulk/domestic";
			
		ИначеЕсли ДокументСсылка.ВалютаДенежныхСредств <> НацВалюта 
			И (ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата
			ИЛИ ДокументСсылка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников) Тогда 
			
			Возврат "api/documents/bulk/foreign";
			
		Иначе 
			Возврат "api/documents/foreign";			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

&НаСервере
Процедура ВыгрузитьДокументыTBC(МассивДокументов, Nonce)
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Login"));
	СтруктураПараметров.Вставить("PASSWORD",  			УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Password"));
	СтруктураПараметров.Вставить("Nonce",				Nonce);
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	СтруктураПараметров.Вставить("ИмяТабличнойЧасти",	"РасходыСоСчета");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo");
	СтруктураПараметров.Вставить("МассивДокументов",   	МассивДокументов);
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"" xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"">");
	
	СтруктураПараметров.Вставить("Метод",   			"ImportSinglePaymentOrders");
	СтруктураПараметров.Вставить("СтруктурыТэгов",		ЗаполнитьСтрукутуруТеговВыгрузкиРасходаСоСчета());
	
	ПлатежTBCНаСервере(СтруктураПараметров);
	
КонецПроцедуры

&НаСервере
Процедура ПлатежTBCНаСервере(СтруктураПараметров)
	
	ТаблицаПозиций = Новый ТаблицаЗначений;
	ТаблицаПозиций.Колонки.Добавить("Позиция");
	ТаблицаПозиций.Колонки.Добавить("ДокументСсылка");
	ТаблицаПозиций.Колонки.Добавить("Сотрудник");
	
	СтруктураПараметров.Вставить("ТаблицаПозиций", ТаблицаПозиций);
	
	КолвоВыгруженныхДоков = 0;
	
	ПустойСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	
	Если СтруктураПараметров.МассивДокументов.Количество() > 0 Тогда 
		
		СтруктураПараметров.Вставить("МассивДокументов", СтруктураПараметров.МассивДокументов);
		
		МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
		Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
		
		МассивПакетов = Неопределено;
		Если Структураответа.Свойство("МассивСсылокДокументовПакетов") Тогда 
			МассивПакетов = Структураответа.МассивСсылокДокументовПакетов;
		КонецЕсли;
		
		ТекущийДокумент = Неопределено;
		Если Структураответа.Свойство("PaymentOrdersResults") Тогда 
			
			Если ТипЗнч(Структураответа.PaymentOrdersResults) = Тип("Массив") Тогда 
				
				ДобавитьСтатусБезСотрудника = ЛОЖЬ;
				Для Каждого ЭлемМассива Из Структураответа.PaymentOrdersResults Цикл 
					
					Позиция = ЭлемМассива.position;
					УИД_Документа = ЭлемМассива.paymentId;
					
					МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
					Если МассивНайденныхСтрок.Количество() > 0 Тогда 
						
						ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
						
						ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
						Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
						Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
						
						Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
							ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
							
							ЗначениеСотрудника = МассивНайденныхСтрок[0].Сотрудник;
							
							ВнестиИнформациюСтатусаУИД(ДокументСсылка, ПустойСотрудник, УИД_Документа, Банк, Статус);
							
						КонецЕсли;
						
						ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Документа, Банк, Статус);
						
						Если ТекущийДокумент <> ДокументСсылка Тогда 
							Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
							КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
							ТекущийДокумент = ДокументСсылка;
						КонецЕсли;
						
					КонецЕсли;
				КонецЦикла;
			ИначеЕсли ТипЗнч(Структураответа.PaymentOrdersResults) = Тип("Структура") Тогда
				
				Позиция = Структураответа.PaymentOrdersResults.position;
				УИД_Документа = Структураответа.PaymentOrdersResults.paymentId;
				
				МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
				Если МассивНайденныхСтрок.Количество() > 0 Тогда 
					
					ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
					
					ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
					Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
					Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
					
					Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
						ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
						
						ЗначениеСотрудника = МассивНайденныхСтрок[0].Сотрудник;
						
						ВнестиИнформациюСтатусаУИД(ДокументСсылка, ПустойСотрудник, УИД_Документа, Банк, Статус);
						
					КонецЕсли;
					
					ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Документа, Банк, Статус);
					
					Если ТекущийДокумент <> ДокументСсылка Тогда
						Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
						КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
						ТекущийДокумент = ДокументСсылка;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда 
			Сообщить(Структураответа.ТекстОшибки);
		КонецЕсли;
		
		Если МассивПакетов <> Неопределено И МассивПакетов.Количество() > 0 Тогда 
			ОтправитьПакетыИзОдиночногоЗапроса(МассивПакетов, СтруктураПараметров);
		КонецЕсли;
		
	КонецЕсли;
	
	Сообщить(НСтр("ru = 'Всего выгруженно одиночных документов: "+КолвоВыгруженныхДоков+"'; ka = 'Всего выгруженно одиночных документов: "+КолвоВыгруженныхДоков+"'"));
	
КонецПроцедуры

&НаСервере
Процедура ВнестиИнформациюСтатусаУИД(ДокументСсылка, Сотрудник, УИД_Документа, Банк, Статус, ТолькоСтатус = Ложь)
	
	Если НЕ ТолькоСтатус Тогда 
		НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
		НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
		НаборЗаписейУИДДокумента.Отбор.Сотрудник.Установить(Сотрудник);
		НаборЗаписейУИДДокумента.Отбор.Банк.Установить(Банк);
		
		НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
		НовыйУИД.ДокументСсылка = ДокументСсылка;
		НовыйУИД.Сотрудник = Сотрудник;
		НовыйУИД.Банк = Банк;
		НовыйУИД.УИДДокументаВБанке = УИД_Документа;
		НовыйУИД.Выгружен = Истина;
		
		НаборЗаписейУИДДокумента.Записать();
	КонецЕсли;
	
	// Запись нового статуса
	
	ДатаОбновления = ТекущаяДата();
	НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
	НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
	НаборЗаписейСтатусовДокумента.Отбор.Сотрудник.Установить(Сотрудник);
	НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ДатаОбновления);
	НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(Банк);
	
	НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
	НовыйСтатус.ДокументСсылка = ДокументСсылка;
	НовыйСтатус.Период = ДатаОбновления;
	НовыйСтатус.Сотрудник = Сотрудник;
	НовыйСтатус.СтатусДокументаВИнтернетБанке = Статус;
	НовыйСтатус.Банк = Банк;
	
	НаборЗаписейСтатусовДокумента.Записать();
	
КонецПроцедуры

