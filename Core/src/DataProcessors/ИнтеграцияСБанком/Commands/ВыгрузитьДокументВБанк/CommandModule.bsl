
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды) Экспорт 
	
	ОчиститьСообщения();
	
	ТекстСообщения = "";
	Отказ = Ложь;//ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") ИЛИ ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета");
	НацВалюта = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НациональнаяВалюта");
	Если ПараметрыВыполненияКоманды.Источник.Элементы.Найти("Список") <> Неопределено Тогда 
		ДокументСсылка = ПараметрыВыполненияКоманды.Источник.ТекущийЭлемент.ВыделенныеСтроки;
	ИНаче
		ДокументСсылка = ПараметрКоманды;
	КонецЕсли;
	
	МассивНаименований = ПолучитьНаСетветеМассивНаименованийИспользуемыхБанков();
	
	СтруктураМассивовДокументов = Новый Структура;
	СтруктураМассивовДокументов.Вставить("МассивНекорректныхДокументов", Новый Массив);
	Для Каждого Банк Из МассивНаименований Цикл
		СтруктураМассивовДокументов.Вставить(Строка("МассивДокументов" + Банк), Новый Массив);
	КонецЦикла;
	
	РасспределитьДокументыПоМассивам(ДокументСсылка, СтруктураМассивовДокументов);
	
	Для Каждого Наименования Из МассивНаименований Цикл 
		
		Если Наименования = "TBCBGE22" Тогда 
			
			Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Наименования) Тогда 
				МассивДокументов = СтруктураМассивовДокументов["МассивДокументов"+Наименования];
			Иначе
				Продолжить;
			КонецЕсли;
			
			Если МассивДокументов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Nonce = "";
			Подсказка = НСтр("ka='Введите пароль DigiPass';ru='Введите пароль DigiPass!'");
			Если НЕ ВвестиСтроку(Nonce, Подсказка, 0, Истина) Тогда
				// запомнить текст напоминания
				Продолжить;
			КонецЕсли;
			
			
			
			ВыгрузитьДокументыTBC(МассивДокументов, Nonce); 
			
		ИначеЕсли Наименования = "BAGAGE22" Тогда
			
			Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Наименования) Тогда 
				МассивДокументов = СтруктураМассивовДокументов["МассивДокументов"+Наименования];
			Иначе
				Продолжить;
			КонецЕсли;
			
			Если МассивДокументов.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтруктураВсехПараметров = ПолучитьСтруктуруВсехПараметров();
			
			Токен = ПолучитьДокенИзБазы();
			
			Если Токен = "" Тогда 
				Токен = ОткрытьФормуМодально("Обработка.ИнтеграцияСБанком.Форма.ФормаАвторизации");
			КонецЕсли;
			
			Если Токен <> "" И Токен <> Неопределено Тогда 
				ВыполнитьПроверкуДанныхНаСервере(МассивДокументов, НацВалюта, Отказ, СтруктураВсехПараметров, ТекстСообщения, Токен);	
			КонецЕсли;
			
			СтруктураОповещения = Новый Структура("ВыгруженныеСсылки", МассивДокументов);
			
			Оповестить("ИнтеграцияСБанком_ВыгрузкаЗавершина", СтруктураОповещения);
			
			ПараметрыФормы = Новый Структура("ДокументСсылка", ПараметрКоманды);//"", );
			
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Док Из СтруктураМассивовДокументов.МассивНекорректныхДокументов Цикл 
		
		Сообщить(НСтр("ru = 'Выгрузка в банк для документа: """+Док+""" невозможна'; ka = 'Выгрузка в банк для документа: """+Док+""" невозможна'"));

	КонецЦикла;
	
	
КонецПроцедуры

&НаСервере
Процедура РасспределитьДокументыПоМассивам(ДокументСсылка, СтруктураМассивовДокументов)
	
	Если ТипЗнч(ДокументСсылка) = Тип("Массив") Тогда 
		
		Для Каждого Элем Из ДокументСсылка Цикл 
			
			Если ТипЗнч(Элем) = Тип("ДокументСсылка.РасходСоСчета") Тогда 
				Свифт = Элем.БанковскийСчет.Банк.СВИФТБИК;
			ИначеЕсли ТипЗнч(Элем) = Тип("ДокументСсылка.Конвертация") Тогда
				Свифт = Элем.Отправитель.Банк.СВИФТБИК;
			КонецЕсли;
			
			ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, Элем);
			
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета") Тогда 
		
		Свифт = ДокументСсылка.БанковскийСчет.Банк.СВИФТБИК;
		ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, ДокументСсылка);
		
	ИначеЕсли ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.Конвертация") Тогда
		
		Свифт = ДокументСсылка.Отправитель.Банк.СВИФТБИК;
		ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, ДокументСсылка);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьСтруктуруМассивов(СтруктураМассивовДокументов, Свифт, ДокСсылка)
	
	Если СтруктураМассивовДокументов.Свойство("МассивДокументов"+Свифт) Тогда 
		СтруктураМассивовДокументов["МассивДокументов"+Свифт].Добавить(ДокСсылка);
	Иначе
		СтруктураМассивовДокументов.МассивНекорректныхДокументов.Добавить(ДокСсылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьНаСетветеМассивНаименованийИспользуемыхБанков()
	
	МассивВозврата = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИнтеграцииСБанками.Наименование
		|ИЗ
		|	Справочник.ИнтеграцииСБанками КАК ИнтеграцииСБанками
		|ГДЕ
		|	ИнтеграцииСБанками.Предопределенный
		|	И ИнтеграцииСБанками.ЗначениеКонстанты";
	
	тзИспользуемыеБанки = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Строк Из тзИспользуемыеБанки Цикл 
		
		МассивВозврата.Добавить(Строк.Наименование);
		
	КонецЦикла;
	
	Возврат МассивВозврата;
	
КонецФункции

&НаКлиенте
Функция ПолучитьСтруктуруВсехПараметров()
	
	// Желательно не повторятся
	СтруктураВозврата = Новый Структура;
	
	МассивЗначений = Новый Массив;
	
	МассивЗначений.Добавить("Документ");
	МассивЗначений.Добавить("Charges");
	МассивЗначений.Добавить("ComissionAccountNumber");
	МассивЗначений.Добавить("BeneficiaryBankCode");
	МассивЗначений.Добавить("BeneficiaryBankName");
	МассивЗначений.Добавить("BeneficiaryInn");
	МассивЗначений.Добавить("BeneficiaryName");
	МассивЗначений.Добавить("IntermediaryBankCode");
	МассивЗначений.Добавить("IntermediaryBankName");
	МассивЗначений.Добавить("AdditionalInformation");
	МассивЗначений.Добавить("PaymentDetail");
	МассивЗначений.Добавить("ValueDate");
	МассивЗначений.Добавить("UniqueId");
	МассивЗначений.Добавить("Amount");
	МассивЗначений.Добавить("Currency");
	МассивЗначений.Добавить("DocumentNo");
	МассивЗначений.Добавить("SourceAccountNumber");
	МассивЗначений.Добавить("BeneficiaryAccountNumber");
	МассивЗначений.Добавить("Nomination");
	МассивЗначений.Добавить("DispatchType");
	МассивЗначений.Добавить("PayerInn");
	МассивЗначений.Добавить("PayerName");
	
	СтруктураВозврата.Вставить("РасходСоСчета", МассивЗначений);
	
	МассивЗначений = Новый Массив;
	
	МассивЗначений.Добавить("SourceCurrency");
	МассивЗначений.Добавить("DestinationAccountNumber");
	МассивЗначений.Добавить("DestinationCurrency");
	МассивЗначений.Добавить("Rate");
	МассивЗначений.Добавить("AdditionalInfo");
	
	СтруктураВозврата.Вставить("Конвертация", МассивЗначений);
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаСервере
Функция ПолучитьДокенИзБазы();
	
	ТекПользователь = Пользователи.АвторизованныйПользователь();
	СтруктураОтветаТокена = РегистрыСведений.ТокеныПользователейBOG.Получить(Новый Структура("Пользователь", ТекПользователь));
	
	Токен = СтруктураОтветаТокена.Токен;
	
	МинутСПоследнейЗаписи = Цел((ТекущаяДата() - СтруктураОтветаТокена.ДатаВремяПолучения)/60);
	Если МинутСПоследнейЗаписи > 12 Тогда 
		Возврат "";
	КонецЕсли;
	
	Возврат Токен;
	
КонецФункции

&НаСервере
Процедура ДополнитьСообщениеОшибки(ТекстСообщения, ИмяРеквизита);
	
	Если СокрЛп(ИмяРеквизита) = "" Тогда 
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = ТекстСообщения + НСтр(("ru = '"+ИмяРеквизита+" должен быть заполненным'; ka = '"+ИмяРеквизита+" უნდა იყოს სავსე'")) + Символы.ПС;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьПроверкуДанныхНаСервере(ДокументСсылка, НацВалюта, Отказ, СтруктураВсехПараметров, ТекстСообщения, Токен)
	   
	МенеджерИнтеграцииСБанком = Обработки.ИнтеграцияСБанком;
	
	ТаблицаДанных = Новый ТаблицаЗначений;
	ТаблицаДанных.Колонки.Добавить("КлючОтправки"				, Новый ОписаниеТипов("Строка"));
	
	Для Каждого ЭлемСтруктуры ИЗ СтруктураВсехПараметров Цикл 
		Для Каждого ЭлемМассива ИЗ ЭлемСтруктуры.Значение Цикл 
			СтрокаТЗ = ТаблицаДанных.Добавить();
			СтрокаТЗ.КлючОтправки = ЭлемМассива;
		КонецЦикла;
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НацВалюта", НацВалюта);
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	Запрос.УстановитьПараметр("тзПараметров", ТаблицаДанных);
	
	ТекстЗапросаПараметров = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(тзПараметров.КлючОтправки КАК Строка(50)) КАК КлючОтправки
		|ПОМЕСТИТЬ ВременнаяТаблицаПараметров
		|ИЗ
		|	&тзПараметров КАК тзПараметров
		|;
		|//////////////////////////////////////
		|";
	
	ТестЗапросаОсновнойТаблицы = ПолучитьТекстЗапросаОсновнойТаблиц();		
	
	//////////////////////////////////	
	Запрос.Текст = ТекстЗапросаПараметров + ТестЗапросаОсновнойТаблицы;
	
	ВыборкаПоСсылке = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	КоличествоВыгруженныхДокументов = 0;
	
	Пока ВыборкаПоСсылке.Следующий() Цикл
		
		ВыборкаДетальныеЗаписи = ВЫборкаПоСсылке.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		РазрешинаВыгрузка = Истина;
		ТекстСообщения = НСтр(("ru = 'Документ: "+ВыборкаПоСсылке.Ссылка+", не выгружен. Причина:'; ka = 'Документ: "+ВыборкаПоСсылке.Ссылка+", не выгружен. Причина:'")) + Символы.ПС;;
		СтруктураПараметров = Новый Структура;
		ЗначениеСтруктурыПараметров = Неопределено;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			Если НЕ ВыборкаДетальныеЗаписи.ВыгрузкаРазрешена Тогда
				ТекстРУ = СтрЗаменить(СтрЗаменить(ВыборкаДетальныеЗаписи.ТекстОшибкиRU, "ПармДокументСсылка", ВыборкаДетальныеЗаписи.Ссылка), "ПарамВидОперации", ВыборкаДетальныеЗаписи.Ссылка.ВидОперации);
				ТекстКА = СтрЗаменить(СтрЗаменить(ВыборкаДетальныеЗаписи.ТекстОшибкиKA, "ПармДокументСсылка", ВыборкаДетальныеЗаписи.Ссылка), "ПарамВидОперации", ВыборкаДетальныеЗаписи.Ссылка.ВидОперации);
				Сообщить(НСтр("ru = '"+ТекстРУ+"'; ka = '"+ТекстКА+"'"));
				ТекстСообщения = "";
				РазрешинаВыгрузка = Ложь;
				Прервать;
			ИначеЕсли НЕ ВыборкаДетальныеЗаписи.Проведен Тогда 
				
				Сообщить(НСтр("ru = 'Документ "+ВыборкаПоСсылке.Ссылка+" не будет выгружен так как не проведен'; ka = 'Документ "+ВыборкаПоСсылке.Ссылка+" не будет выгружен так как не проведен'"));
				ТекстСообщения = "";
				РазрешинаВыгрузка = Ложь;
				
			КонецЕсли;
			
			ИмяРеквизита = НСтр("ru = '"+ВыборкаДетальныеЗаписи.СинонимРеквизитаRU+"'; ka = '"+ВыборкаДетальныеЗаписи.СинонимРеквизитаKA+"'");
			
			КлючСтруктурыПараметров = СокрЛП(ВыборкаДетальныеЗаписи.КлючОтправки);
			ЗначениеСтруктурыПараметров = ?(ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ЗначениеЗаполнения), ВыборкаДетальныеЗаписи.ЗначениеЗаполнения, "");
			
			Если НЕ ВыборкаДетальныеЗаписи.ТребуетсяПроверка = NULL И НЕ ВыборкаДетальныеЗаписи.ТребуетсяПроверка = "" И ВыборкаДетальныеЗаписи.ТребуетсяПроверка  Тогда 
				Если ИмяРеквизита <> "" Тогда //От другого запроса
					Если СокрЛП(ЗначениеСтруктурыПараметров) = "" Тогда 
						ДополнитьСообщениеОшибки(ТекстСообщения, ИмяРеквизита);
						РазрешинаВыгрузка = ЛОЖЬ;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если СтруктураПараметров.Свойство(КлючСтруктурыПараметров) Тогда 
				СтруктураПараметров[КлючСтруктурыПараметров] = ЗначениеСтруктурыПараметров;
			Иначе
				Если КлючСтруктурыПараметров = "Документ" Тогда
					СтруктураПараметров.Вставить(КлючСтруктурыПараметров, ВыборкаДетальныеЗаписи.Ссылка);
				Иначе
					СтруктураПараметров.Вставить(КлючСтруктурыПараметров, ЗначениеСтруктурыПараметров);
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ РазрешинаВыгрузка Тогда 
			Если ТекстСообщения <> "" Тогда 
				Сообщить(ТекстСообщения);
			КонецЕсли;
		Иначе
			ИмяМетода = ПолучитьИмяМетода(ВыборкаПоСсылке.Ссылка, НацВалюта);
			СтруктураОтвета = Неопределено;
			Если ИмяМетода <> "" Тогда 
				СтруктураОтвета = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, СтруктураПараметров, , Токен, ИСТИНА);
				//СтруктураОтвета = МенеджерИнтеграцииСБанком.ВыполнитьМетодСервиса(ИмяМетода, СтруктураПараметров, , Токен, ЛОЖЬ);
			Иначе
				Сообщить(НСтр("ru = 'Документ "+ВыборкаПоСсылке.Ссылка+" не выгружен'; ka = 'Документ "+ВыборкаПоСсылке.Ссылка+" не выгружен'"));
			КонецЕсли;
			
			Если Не СтруктураОтвета = Неопределено Тогда
				Если СтруктураОтвета.Результат = 0 Тогда
					
					ДатаЗаполнения = ТекущаяДата();
					УИДДокументаВБанке = СтрЗаменить(СтрЗаменить(СтрЗаменить(СтруктураОтвета.УникальныйКлюч," ",""),",",""),Символы.НПП,"");
					
					ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
					НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
					НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(ВыборкаПоСсылке.Ссылка);
					НаборЗаписейУИДДокумента.Отбор.Сотрудник.Установить(ЗначениеСотрудника);
					НаборЗаписейУИДДокумента.Отбор.Банк.Установить(ВыборкаПоСсылке.Ссылка.БанковскийСчет.Банк);
					
					НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
					НовыйУИД.ДокументСсылка = ВыборкаПоСсылке.Ссылка;
					НовыйУИД.Сотрудник = ЗначениеСотрудника;
					НовыйУИД.Банк = ВыборкаПоСсылке.Ссылка.БанковскийСчет.Банк;
					НовыйУИД.УИДДокументаВБанке = УИДДокументаВБанке;
					НовыйУИД.Выгружен = Истина;
					
					НаборЗаписейУИДДокумента.Записать();
					
					///////////////////////
					НоборЗаписейСтатусыДокументовBOG = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
					НоборЗаписейСтатусыДокументовBOG.Отбор.Период.Установить(ДатаЗаполнения);
					НоборЗаписейСтатусыДокументовBOG.Отбор.ДокументСсылка.Установить(ВыборкаПоСсылке.Ссылка);
					НоборЗаписейСтатусыДокументовBOG.Отбор.Сотрудник.Установить(ЗначениеСотрудника);
					НоборЗаписейСтатусыДокументовBOG.Отбор.Банк.Установить(ВыборкаПоСсылке.Ссылка.БанковскийСчет.Банк);
					
					НоваяЗапись = НоборЗаписейСтатусыДокументовBOG.Добавить();
					НоваяЗапись.ДокументСсылка = ВыборкаПоСсылке.Ссылка;
					НоваяЗапись.Период = ДатаЗаполнения;
					НоваяЗапись.СтатусДокументаВИнтернетБанке = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
					НоваяЗапись.Сотрудник = ЗначениеСотрудника;
					НоваяЗапись.Банк = ВыборкаПоСсылке.Ссылка.БанковскийСчет.Банк;
					
					НоборЗаписейСтатусыДокументовBOG.Записать();
					
					КоличествоВыгруженныхДокументов = КоличествоВыгруженныхДокументов + 1;
					
					Сообщить(НСтр("ru = 'Документ "+ВыборкаПоСсылке.Ссылка+" выгружен'; ka = 'Документ "+ВыборкаПоСсылке.Ссылка+" выгружен'"));
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = НСтр("ru = 'Выгружен/о " + КоличествоВыгруженныхДокументов + " документ/ов.'; ka = 'ატვირთულია " + КоличествоВыгруженныхДокументов + " დოკუმენტი.'");
	Сообщение.Сообщить();
	
КонецПроцедуры

