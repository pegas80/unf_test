
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ИзДокумента") Тогда
		ИзДокумента = Параметры.ИзДокумента
	КонецЕсли;

	ТипАутентификацииBOG = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(), "ТипАутентификацииBOG");

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ТипАутентификацииBOG = ПредопределенноеЗначение("Перечисление.ТипыАутентификацииBOG.ForDesktopApplication") Тогда        
		
		АдресСтраницыАутентификации = ИнтеграцияСБанком_НаСервере.АдресСтраницыАутентификации();      
		
	ИначеЕсли ТипАутентификацииBOG = ПредопределенноеЗначение("Перечисление.ТипыАутентификацииBOG.AuthentificationUsingToken") Тогда      
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В настройках пользователя не указан ""Вариант аутентификации""");	
		
	КонецЕсли;
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура АдресСтраницыАутентификацииДокументСформирован(Элемент)
	
	Если ТокенПолучен Тогда
		Возврат;
	КонецЕсли;
	
	Если Найти(Элемент.Документ.location.href, "access_token=") <> 0 Тогда	
		ТекущийURL = Элементы.АдресСтраницыАутентификации.Документ.location.href;
		ТокенДоступа = ИнтеграцияСБанком_НаКлиенте.ПолучитьТокенИзURL(ТекущийURL);
		ИнтеграцияСБанком_НаСервере.УстановитьТокенДоступа(ТокенДоступа);
		//Токен = ТокенДоступа;
		ТокенПолучен = Истина;
		Если ИзДокумента Тогда 
			ЭтаФорма.Закрыть(ТокенДоступа);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	
	ТокенДоступа = ИнтеграцияСБанком_НаСервере.АвторизацияЧерезЛогинИПароль();   
	
	Если ЗначениеЗаполнено(ТокенДоступа) Тогда 
		ИнтеграцияСБанком_НаСервере.УстановитьТокенДоступа(ТокенДоступа, "BAGAGE22");    
		
		Если ИзДокумента Тогда 
			Закрыть(ТокенДоступа);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьВидимость()

	Если ТипАутентификацииBOG = ПредопределенноеЗначение("Перечисление.ТипыАутентификацииBOG.ForDesktopApplication") Тогда        
		
		Элементы.СтраницаАвторизация.Видимость = Истина;
		Элементы.ГруппаСтраницаАутентификацииПоТокену.Видимость = Ложь; 
		Элементы.Группа1.ТекущаяСтраница = Элементы.СтраницаАвторизация;
		
	ИначеЕсли ТипАутентификацииBOG = ПредопределенноеЗначение("Перечисление.ТипыАутентификацииBOG.AuthentificationUsingToken") Тогда 
		
		Элементы.СтраницаАвторизация.Видимость = Ложь;
		Элементы.ГруппаСтраницаАутентификацииПоТокену.Видимость = Истина;	          
		Элементы.Группа1.ТекущаяСтраница = Элементы.ГруппаСтраницаАутентификацииПоТокену;
		
	КонецЕсли;	

КонецПроцедуры
