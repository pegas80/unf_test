		НоваяСтрока.DocumentNo               = Док.Номер;
		НоваяСтрока.SourceAccountNumber      = Док.БанковскийСчет.НомерСчета;//СчетОрганизации.НомерСчета;
		НоваяСтрока.BeneficiaryAccountNumber = ?(Док.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Налоги, Док.КодКазначейства, ?(Док.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ПереводНаДругойСчет, Док.СчетКонтрагента.НомерСчета, Док.СчетКонтрагента.НомерСчета));
		НоваяСтрока.Nomination               = Док.НазначениеПлатежа;
		НоваяСтрока.DispatchType             = Док.ТипОтправки;  //"BULK";
		Если Док.ВидОперации <> Перечисления.ВидыОперацийРасходСоСчета.ПрочиеРасчеты 
			И Док.ВидОперации <> Перечисления.ВидыОперацийРасходСоСчета.РасчетыПоКредитам 
			И Док.ВидОперации <> Перечисления.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику 
			И Док.ВидОперации <> Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику Тогда
			НоваяСтрока.PayerInn                 = Док.Организация.ИНН;
		КонецЕсли;
		НоваяСтрока.PayerName                = Док.Организация;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоДокументамКонвертаций(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Проведен", Истина);
	ПараметрыОтбора.Вставить(СокрЛП("КодБанкаСчетаОтправителя"), "BAGAGE22");	
	ПараметрыОтбора.Вставить("УникальныйКлючВИнтернетБанке", "");
	ПараметрыОтбора.Вставить("СтатусВИнтернетБанке", ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ПустаяСсылка"));
	
	СтруктураВыбора = Новый Структура("МножественныйВыбор, Отбор", Истина, ПараметрыОтбора);
	
	ФормаКонвертации = ПолучитьФорму("Документ.Конвертация.ФормаВыбора", СтруктураВыбора); 
	Если Не ФормаКонвертации = Неопределено Тогда 
		
		НоваяГруппа = ФормаКонвертации.Список.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		НоваяГруппа.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		НоваяГруппа.Использование = Истина;
		
		НоваяГруппа11 = НоваяГруппа.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		НоваяГруппа11.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
		НоваяГруппа11.Использование = Истина;
		
		НовыйЭлемент1 = НоваяГруппа11.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент1.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОперации"); 
		НовыйЭлемент1.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.Касса");
		НовыйЭлемент1.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
		НовыйЭлемент1.Использование = Истина;
		
		НовыйЭлемент2 = НоваяГруппа11.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент2.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОперации"); 
		НовыйЭлемент2.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.Подотчетник");
		НовыйЭлемент2.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
		НовыйЭлемент2.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа11.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком"); 
		НовыйЭлемент3.ПравоеЗначение = Истина;
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа11.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Выгружен"); 
		НовыйЭлемент3.ПравоеЗначение = Ложь;
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа11.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("УИДДокументаВБанке"); 
		НовыйЭлемент3.ПравоеЗначение = "";
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		ВыбранныеСтроки = ФормаКонвертации.ОткрытьМодально();

		Если Не ВыбранныеСтроки = Неопределено Тогда 
			
			Если Объект.КонвертацииДС.Количество() > 0 Тогда
				ТекстВопроса = НСтр("ka='ცხრილური ნაწილი გასუფთავდება. გავაგრძელოთ?';ru='Табличная часть будет очищена. Продолжить?';en='Tabular section is cleared. Proceed?'");
				Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да,);
				
				Если Ответ <> КодВозвратаДиалога.Да Тогда
					Возврат;
				Иначе 
					Объект.КонвертацииДС.Очистить();
				КонецЕсли;
			КонецЕсли;
			
			ЗаполнитьПоДокументамКонвертацийСервер(ВыбранныеСтроки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДокументамКонвертацийСервер(ВыбранныеДокументы)
	
	Для Каждого Док Из ВыбранныеДокументы Цикл 
		
		НоваяСтрока = Объект.КонвертацииДС.Добавить();
		
		НоваяСтрока.КонвертацияБезналичныхДенежныхСредств = Док.Ссылка;
		НоваяСтрока.Пометка                               = Ложь;
		НоваяСтрока.UniqueId                              = 1;
		НоваяСтрока.DocumentNo                            = Док.Номер;
		Если ТипЗнч(Док.Отправитель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда 
			НоваяСтрока.SourceAccountNumber                   = Док.Отправитель.НомерСчета;//СчетОтправитель.НомерСчета;
			НоваяСтрока.SourceCurrency                        = Док.Отправитель.ВалютаДенежныхСредств;//СчетОтправитель.ВалютаДенежныхСредств;
			ВалютаОтправителя = Док.Отправитель.ВалютаДенежныхСредств;
		ИначеЕсли ТипЗнч(Док.Отправитель) = Тип("СправочникСсылка.Сотрудники") Тогда
			НоваяСтрока.SourceAccountNumber                   = Док.Отправитель.БанковскийСчетПоУмолчанию.НомерСчета;//СчетОтправитель.НомерСчета;
			НоваяСтрока.SourceCurrency                        = Док.Отправитель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;//СчетОтправитель.ВалютаДенежныхСредств;
			ВалютаОтправителя = Док.Отправитель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;
		КонецЕсли;
		
		Если ТипЗнч(Док.Получатель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда
			НоваяСтрока.DestinationAccountNumber              = Док.Получатель.НомерСчета;//СчетПолучатель.НомерСчета;
			НоваяСтрока.DestinationCurrency                   = Док.Получатель.ВалютаДенежныхСредств;//СчетПолучатель.ВалютаДенежныхСредств;
			ВалютаПолучателя = Док.Получатель.ВалютаДенежныхСредств;
		ИначеЕсли ТипЗнч(Док.Отправитель) = Тип("СправочникСсылка.Сотрудники") Тогда
			НоваяСтрока.DestinationAccountNumber              = Док.Получатель.БанковскийСчетПоУмолчанию.НомерСчета;//СчетПолучатель.НомерСчета;
			НоваяСтрока.DestinationCurrency                   = Док.Получатель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;//СчетПолучатель.ВалютаДенежныхСредств;
			ВалютаПолучателя = Док.Получатель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;
		КонецЕсли;
		
		НоваяСтрока.Amount                                = СтрЗаменить(СтрЗаменить(СтрЗаменить(Строка(Док.СуммаКонвертации),",", ""), " ", ""),Символы.НПП, "");//СтрЗаменить(СтрЗаменить(СтрЗаменить(Строка(Док.СуммаСписанная),",", ""), " ", ""),Символы.НПП, "");
		
		НацВалюта = Константы.НациональнаяВалюта.Получить();
		//СтруктураКурсаОтправителя = МодульВалютногоУчета.ПолучитьКурсВалюты(Док.СчетОтправитель.ВалютаДенежныхСредств, Док.Дата);
		Если Док.Получатель.ВалютаДенежныхСредств = НацВалюта ИЛИ Док.Отправитель.ВалютаДенежныхСредств = НацВалюта Тогда 		
			////НоваяСтрока.Rate           = СтруктураКурсаОтправителя.Курс;
			НоваяСтрока.Rate           = Док.КоммерческийКурс;
		ИначеЕсли Док.Отправитель.ВалютаДенежныхСредств <> НацВалюта И Док.Получатель.ВалютаДенежныхСредств <> НацВалюта Тогда 
			НоваяСтрока.Rate           = Док.КроссКурс;
		КонецЕсли;
		//НоваяСтрока.Rate = ?(ВалютаОтправителя = Справочники.Валюты.НайтиПоКоду("643"), Док.КурсПолучатель, Док.КурсОтправитель);
		НоваяСтрока.AdditionalInfo = Док.Комментарий;
		
	КонецЦикла;
	
КонецПроцедуры
