&НаКлиенте
Процедура АдресСтраницыАутентификацииДокументСформирован(Элемент)
	
	Если ТокенПолучен Тогда
		Возврат;
	КонецЕсли;
	
	Если Найти(Элемент.Документ.location.href, "access_token=") <> 0 Тогда	
		ТокенДоступа = ПолучитьТокенИзURL();
		УстановитьТокенДоступа(ТокенДоступа);
		Токен = ТокенДоступа;
		ТокенПолучен = Истина;
		Элементы.СтраницаОбщая.Видимость = Истина;
		Элементы.СтраницыВебСервисов.Видимость = Ложь;
	КонецЕсли;
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьТокенИзURL()
	
	ТекущийURL = Элементы.АдресСтраницыАутентификации.Документ.location.href;
	НачалоТокена = Найти(ТекущийURL, "access_token=") + 13;
	КонецТокена = Найти(Сред(ТекущийURL, НачалоТокена), "&") - 1;
	Если КонецТокена > -1 Тогда 
		Возврат Сред(ТекущийURL, НачалоТокена, КонецТокена);
	Иначе
		Возврат Сред(ТекущийURL, НачалоТокена);	
	КонецЕсли;	
	
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьТокенДоступа(ТокенДоступа)
	
	Константы.ТокенДоступаBoG.Установить(ТокенДоступа);
	
	// плюс новая система
	ТекПользователь = Пользователи.АвторизованныйПользователь();
	
	НаборЗаписейТокена = РегистрыСведений.ТокеныПользователейBOG.СоздатьНаборЗаписей();
	
	НаборЗаписейТокена.Отбор.Пользователь.Установить(ТекПользователь);
	
	НоваяЗапись = НаборЗаписейТокена.Добавить();
	НоваяЗапись.Пользователь = ТекПользователь;
	НоваяЗапись.Токен = ТокенДоступа;
	НоваяЗапись.ДатаВремяПолучения = ТекущаяДата();
	
	НаборЗаписейТокена.Записать();
	
КонецПроцедуры

