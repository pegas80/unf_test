&НаСервере
Процедура ВыгурзкаКонвертацийСервер()
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;	
	КоличествоСозданныхДокуметов = 0;
	
	Для Каждого СтрокаТЧ ИЗ Объект.КонвертацииДС Цикл
		
		Если СтрокаТЧ.Пометка Тогда 	
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("UniqueId"                 , СтрокаТЧ.UniqueId);
			ПараметрыЗапроса.Вставить("DocumentNo"               , СтрокаТЧ.DocumentNo);
			ПараметрыЗапроса.Вставить("SourceAccountNumber"      , СтрокаТЧ.SourceAccountNumber);
			ПараметрыЗапроса.Вставить("SourceCurrency"           , СтрокаТЧ.SourceCurrency);
			ПараметрыЗапроса.Вставить("DestinationAccountNumber" , СтрокаТЧ.DestinationAccountNumber);
			ПараметрыЗапроса.Вставить("DestinationCurrency"      , СтрокаТЧ.DestinationCurrency);
			ПараметрыЗапроса.Вставить("Amount"                   , СтрокаТЧ.Amount);
			ПараметрыЗапроса.Вставить("Rate"                     , СтрокаТЧ.Rate);
			ПараметрыЗапроса.Вставить("AdditionalInfo"           , СтрокаТЧ.AdditionalInfo);
			
			ИмяМетода = "api/documents/conversion";
			
			//медленно работающая штука
			СтруктураОтвета = МенеджерОбработки.ВыполнитьМетодСервиса(ИмяМетода, ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
			//медленно работающая штука
			
			Если Не СтруктураОтвета = Неопределено Тогда
				Если СтруктураОтвета.Результат = 0 Тогда  //если создался док
					
					ДокументОбъект = СтрокаТЧ.КонвертацияБезналичныхДенежныхСредств.ПолучитьОбъект(); 		
					ДокументОбъект.УникальныйКлючВИнтернетБанке = СтруктураОтвета.УникальныйКлюч;
					
					
					НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
					НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(СтрокаТЧ.КонвертацияБезналичныхДенежныхСредств);
					НаборЗаписейУИДДокумента.Отбор.Сотрудник.Установить(Справочники.Сотрудники.ПустаяСсылка());
					НаборЗаписейУИДДокумента.Отбор.Банк.Установить(Объект.Банк);
					
					НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
					НовыйУИД.ДокументСсылка = СтрокаТЧ.КонвертацияБезналичныхДенежныхСредств;
					НовыйУИД.Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
					НовыйУИД.Банк = Объект.Банк;
					НовыйУИД.УИДДокументаВБанке = СтрЗаменить(СтрЗаменить(СтруктураОтвета.УникальныйКлюч,",",""),Символы.НПП,"");
					НовыйУИД.Выгружен = Истина;
					
					НаборЗаписейУИДДокумента.Записать();
					
					////тут же заполнить статус
					//ПараметрыЗапроса = Новый Структура;
					//УникальныйКлюч = СтрЗаменить(СокрЛП(СтрокаТЧ.КонвертацияБезналичныхДенежныхСредств.УникальныйКлючВИнтернетБанке), "," , "");
					//ПараметрыЗапроса.Вставить("Key", УникальныйКлюч);
					//ДокументОбъект.Записать();
					
					//Статус = МенеджерОбработки.ВыполнитьМетодСервиса("api/documents/status/", ПараметрыЗапроса, Режим, Токен);
					
					//// тут надо сделать проверки, если статус не получен или еще что-то надо проверять
					//Если Не Статус = Неопределено Тогда 
					//	ДокументОбъект = СтрокаТЧ.КонвертацияБезналичныхДенежныхСредств.ПолучитьОбъект(); 		
					//	ДокументОбъект.СтатусВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке[Статус];
					//			
					//	Сообщение = Новый СообщениеПользователю;
					//	Сообщение.Текст = НСтр("ka='დოკუმენტის სტატუსები განახლებულია.';ru='Статусы документов обновлены.';en='Document statuses are updated.'");	
					//	Сообщение.Сообщить();	
					//КонецЕсли;
					
					ДокументОбъект.Записать();
					КоличествоСозданныхДокуметов = КоличествоСозданныхДокуметов + 1;
					
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = НСтр("ru = 'Создано " + КоличествоСозданныхДокуметов + " документов.'; ka = 'შექმნილია " + КоличествоСозданныхДокуметов + " დოკუმენტი.'");	
	Сообщение.Сообщить();	
	
КонецПроцедуры
