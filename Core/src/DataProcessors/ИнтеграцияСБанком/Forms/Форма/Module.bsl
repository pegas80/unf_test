		ИмяФайла = "C:\Users\USR1CV82\Desktop\"+СтрЗаменить(СтрЗаменить(ДельтаНСФ.ДатаВремяВСтроку(ТекущаяДата()),"-", " "), ":", " ")+".xlsx";
		
