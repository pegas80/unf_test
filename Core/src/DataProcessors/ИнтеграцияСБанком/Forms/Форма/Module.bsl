&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ВидимостьОбновлений = Ложь;
	УстановитьВидимость();
	Объект.ИдентификаторПриложения = Константы.ИдентификаторПриложенияBoG.Получить();
	
	УстановитьОтбор();
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда 
		Объект.Организация = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
								Пользователи.ТекущийПользователь(),
								"ОсновнаяОрганизация");
	КонецЕсли;
							
	Если СчетаУчетаПоУмолчаниюВходящие.Количество() = 0 Тогда 
		
		ЗаполнитьТаблицуСчетовПоУмолчанию("Входящие");
		
	КонецЕсли;
	
	Если СчетаУчетаПоУмолчаниюРасход.Количество() = 0 Тогда 
		
		ЗаполнитьТаблицуСчетовПоУмолчанию("Расход");
		
	КонецЕсли;
	
	НациональнаяВалюта = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НациональнаяВалюта");//.Получить();
	
	РабочийБанк = Справочники.Банки.НайтиПоРеквизиту("СВИФТБИК","BAGAGE22");
	
	Если ЗначениеЗаполнено(РабочийБанк) Тогда 
		Объект.Банк = РабочийБанк;
		Элементы.Банк.Вид = ВидПоляФормы.ПолеНадписи;
	Иначе
		Элементы.Банк.Вид = ВидПоляФормы.ПолеВвода;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	АвторизацияАккаунта(Неопределено);
	УстановитьОтбор();
	
КонецПроцедуры

