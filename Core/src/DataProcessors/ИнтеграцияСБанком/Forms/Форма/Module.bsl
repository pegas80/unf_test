Функция ПолучитьПроведениеНаСервере(ДокСсылка)
	
	Возврат ДокСсылка.Проведен
	
КонецФункции


&НаКлиенте
Процедура ФильтрПриИзменении(Элемент)
	
	ИмяТаблицы = "";
	Если Найти(Элемент.Имя, "Расходы") <> 0 Тогда 
		ИмяТаблицы = "Расходы";
	ИначеЕсли Найти(Элемент.Имя, "Конвертации") <> 0 Тогда
		ИмяТаблицы = "Конвертации";
	Иначе
		ИмяТаблицы = ""; // просто Входящике
	КонецЕсли;
	
	ОбновитьВидимость(ИмяТаблицы);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимость(ИмяТаблицы)
	
	ОкончаниеФильтра = ?(ИмяТаблицы = "", "Входящие", ИмяТаблицы);
	
	Для Каждого Строк Из Объект["ПлатежныеПорученияВходящие" + ИмяТаблицы] Цикл
		
		СчетОтправителя = Неопределено;
		Если ИмяТаблицы = "Конвертации" Тогда 
			СчетОтправителя = Строк.СчетОтправителя;
		КонецЕсли;
		
		Строк.Видимость = ЛОЖЬ;
		Строк.Видимость = ОпределитьВидимость(Строк.СозданныйДокумент,Строк.Контрагент,Строк.ДоговорКонтрагента,Строк.СчетКонтрагента, ОкончаниеФильтра, СчетОтправителя);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ОпределитьВидимость(ДокСсылка, Контрагент, Договор, БанковскийСчет, ИмяТаблицы, СчетОтправителя = Неопределено)
	                          
	Если ЭтаФорма["ФильтрЗеленого"+ИмяТаблицы] Тогда 
		
		Если ЗначениеЗаполнено(ДокСсылка) И ДокСсылка.Проведен Тогда 
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтаФорма["ФильтрСерого"+ИмяТаблицы] Тогда 
		
		Если ЗначениеЗаполнено(ДокСсылка) И НЕ ДокСсылка.Проведен Тогда 
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтаФорма["ФильтрКрасного"+ИмяТаблицы] Тогда 
		
		Если ИмяТаблицы = "Конвертации" Тогда 
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И (НЕ ЗначениеЗаполнено(БанковскийСчет) 
				ИЛИ НЕ ЗначениеЗаполнено(СчетОтправителя)) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		Иначе
			
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И (НЕ ЗначениеЗаполнено(Контрагент)
				ИЛИ НЕ ЗначениеЗаполнено(Договор)
				ИЛИ НЕ ЗначениеЗаполнено(БанковскийСчет)) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтаФорма["ФильтрЖолтого"+ИмяТаблицы] Тогда 
		
		Если ИмяТаблицы = "Конвертации" Тогда 
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И ЗначениеЗаполнено(БанковскийСчет) 
				И ЗначениеЗаполнено(СчетОтправителя) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		Иначе
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И ЗначениеЗаполнено(Контрагент)
				И ЗначениеЗаполнено(Договор)
				И ЗначениеЗаполнено(БанковскийСчет) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЛОЖЬ;
	
КонецФункции

&НаСервере
Процедура ВнестиНовыйСтатусДокумента(ДатаЗаполнения, ДокументСсылка, СтатусСсылка, УИДДокуента, Сотрудник = Неопределено)
	
	Если Сотрудник = Неопределено Тогда 
		Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;
	
	НоборЗаписейСтатусыДокументовBOG = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
	НоборЗаписейСтатусыДокументовBOG.Отбор.Период.Установить(ДатаЗаполнения);
	НоборЗаписейСтатусыДокументовBOG.Отбор.ДокументСсылка.Установить(ДокументСсылка);
	НоборЗаписейСтатусыДокументовBOG.Отбор.Сотрудник.Установить(Сотрудник);
	НоборЗаписейСтатусыДокументовBOG.Отбор.Банк.Установить(Объект.Банк);
	
	НоваяЗапись = НоборЗаписейСтатусыДокументовBOG.Добавить();
	НоваяЗапись.ДокументСсылка = ДокументСсылка;
	НоваяЗапись.Период = ДатаЗаполнения;
	НоваяЗапись.Банк = Объект.Банк;
	НоваяЗапись.СтатусДокументаВИнтернетБанке = СтатусСсылка;
	НоваяЗапись.Сотрудник = Сотрудник;
	
	НоборЗаписейСтатусыДокументовBOG.Записать();	
	
КонецПроцедуры

&НаСервере
Функция ПолучитьУИДДокументаПоСсылке(ДокументСсылка, Сотрудник = Неопределено)
	
	Если Сотрудник = Неопределено Тогда 
		Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура("ДокументСсылка, Сотрудник", ДокументСсылка, Сотрудник);
	НаборЗапичейУИД = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
	НаборЗапичейУИД.Отбор.ДокументСсылка.Установить(ДокументСсылка);//СрезПоследних(ТекущаяДата(), СтруктураОтбора);
	НаборЗапичейУИД.Отбор.Сотрудник.Установить(Сотрудник);
	НаборЗапичейУИД.Банк.Сотрудник.Установить(Объект.Банк);
	НаборЗапичейУИД.Прочитать();
	
	Если НаборЗапичейУИД.Количество() > 0 Тогда 
		//Обновим статус
		Возврат НаборЗапичейУИД[0].УИДДокументаВБанке;
		
	Иначе
		
		Возврат "";
	КонецЕсли;
	
	
КонецФункции

&НаСервере
Функция ПолучитьСтруктуруСтаатьиКорреспонденциюКонтрагентаПоВидуОперации(ИмяТаблицыНастройки, ВидОперации, КонтрагентСотрудник, ИННКонтрагента)
	
	СтруктураВозврата = Новый Структура("Корреспонденция, КорреспонденцияРегл, Статья, Контрагент, СчетКонтрагента, ДоговорКонтрагента");
	
	СтруктураОтбора = Новый Структура("ВидОперации", ВидОперации);
	
	МассивНайденныхСтрок = Новый Массив;
	Если ИмяТаблицыНастройки = "Входящие" Тогда 
		МассивНайденныхСтрок = СчетаУчетаПоУмолчаниюВходящие.НайтиСтроки(СтруктураОтбора);
	ИначеЕсли ИмяТаблицыНастройки = "Расход" Тогда 
		МассивНайденныхСтрок = СчетаУчетаПоУмолчаниюРасход.НайтиСтроки(СтруктураОтбора);
	КонецЕсли;
	
	Если МассивНайденныхСтрок.Количество() <> 0 Тогда 
		СтруктураВозврата.Корреспонденция 		= МассивНайденныхСтрок[0].Корреспонденция;
		СтруктураВозврата.КорреспонденцияРегл 	= МассивНайденныхСтрок[0].КорреспонденцияРегл;
		СтруктураВозврата.Статья 				= МассивНайденныхСтрок[0].Статья;
	КонецЕсли;
	
	НуженСотрудник = (ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику")
			ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику")
			ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником")
			ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника"));
	
	Если ВидОперации <> ПредыдущиеЗначениеВидаОперации Тогда 
		Если НуженСотрудник 
			И (ТипЗнч(КонтрагентСотрудник) = Тип("СправочникСсылка.Контрагенты") 
				ИЛИ НЕ ЗначениеЗаполнено(КонтрагентСотрудник)) Тогда 
			
			// 1-контрагент, 2-Сотрудник, 0-Любого найденного
			НайтиКонтрагентаСотрудникаПоИНН(ИННКонтрагента, 2, СтруктураВозврата); 
			
			Если СтруктураВозврата.Контрагент = Неопределено Тогда 
				СтруктураВозврата.Контрагент = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
			КонецЕсли;
			
		ИначеЕсли НЕ НуженСотрудник 
			И (ТипЗнч(КонтрагентСотрудник) = Тип("СправочникСсылка.Сотрудники") 
				ИЛИ НЕ ЗначениеЗаполнено(КонтрагентСотрудник)) Тогда 
			
			// 1-контрагент, 2-Сотрудник, 0-Любого найденного
			НайтиКонтрагентаСотрудникаПоИНН(ИННКонтрагента, 1, СтруктураВозврата); 
			
			Если СтруктураВозврата.Контрагент = Неопределено Тогда 
				СтруктураВозврата.Контрагент = ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка");
			КонецЕсли;
			
		Иначе 
			СтруктураВозврата.Контрагент = Неопределено;
		КонецЕсли;
	Иначе
		СтруктураВозврата.Контрагент = Неопределено;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
		
КонецФункции

&НаСервере
Процедура НайтиКонтрагентаСотрудникаПоИНН(ИННКонтрагента, ПриоритетеПоиска, СтруктураВозврата)
	
	СтруктураВозврата.Контрагент = Неопределено;
	СтруктураВозврата.СчетКонтрагента = ПредопределенноеЗначение("Справочник.БанковскиеСчета.ПустаяСсылка");
	СтруктураВозврата.ДоговорКонтрагента = ПредопределенноеЗначение("Справочник.ДоговорыКонтрагентов.ПустаяСсылка");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка,
		|	1 КАК ПриоритетПоиска,
		|	Контрагенты.ДоговорПоУмолчанию,
		|	Контрагенты.БанковскийСчетПоУмолчанию
		|ПОМЕСТИТЬ ВТ_КонтрагентСотрудник
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ИНН = &ИННКонтрагента
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка,
		|	2,
		|	ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка),
		|	Сотрудники.БанковскийСчетПоУмолчанию
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Физлицо.ИНН = &ИННКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ДоговорыКонтрагентов.Ссылка,
		|	ДоговорыКонтрагентов.Владелец
		|ПОМЕСТИТЬ ВТ_Договра
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Владелец В
		|			(ВЫБРАТЬ
		|				а.Ссылка
		|			ИЗ
		|				ВТ_КонтрагентСотрудник КАК а
		|			ГДЕ
		|				а.Ссылка ССЫЛКА Справочник.Контрагенты)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	БанковскиеСчета.Ссылка,
		|	БанковскиеСчета.Владелец
		|ПОМЕСТИТЬ ВТ_БанковскиеСчета
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	БанковскиеСчета.Владелец В
		|			(ВЫБРАТЬ
		|				а.Ссылка
		|			ИЗ
		|				ВТ_КонтрагентСотрудник КАК а)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КонтрагентСотрудник.Ссылка КАК Контрагент,
		|	ВТ_КонтрагентСотрудник.ПриоритетПоиска,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_КонтрагентСотрудник.ДоговорПоУмолчанию, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
		|			ТОГДА ЕСТЬNULL(ВТ_Договра.Ссылка, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка))
		|		ИНАЧЕ ВТ_КонтрагентСотрудник.ДоговорПоУмолчанию
		|	КОНЕЦ КАК ДоговорКонтрагента,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_КонтрагентСотрудник.БанковскийСчетПоУмолчанию, ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
		|			ТОГДА ЕСТЬNULL(ВТ_БанковскиеСчета.Ссылка, ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка))
		|		ИНАЧЕ ВТ_КонтрагентСотрудник.БанковскийСчетПоУмолчанию
		|	КОНЕЦ КАК СчетКонтрагента
		|ИЗ
		|	ВТ_КонтрагентСотрудник КАК ВТ_КонтрагентСотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Договра КАК ВТ_Договра
		|		ПО ВТ_КонтрагентСотрудник.Ссылка = ВТ_Договра.Владелец
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_БанковскиеСчета КАК ВТ_БанковскиеСчета
		|		ПО ВТ_КонтрагентСотрудник.Ссылка = ВТ_БанковскиеСчета.Владелец";
	
	Запрос.УстановитьПараметр("ИННКонтрагента", ИННКонтрагента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ПриоритетеПоиска = 0 Тогда 
			СтруктураВозврата.Контрагент = ВыборкаДетальныеЗаписи.Контрагент;
			СтруктураВозврата.СчетКонтрагента = ВыборкаДетальныеЗаписи.СчетКонтрагента;
			СтруктураВозврата.ДоговорКонтрагента = ВыборкаДетальныеЗаписи.ДоговорКонтрагента;
			Прервать;
		ИначеЕсли ВыборкаДетальныеЗаписи.ПриоритетПоиска = ПриоритетеПоиска Тогда 
			СтруктураВозврата.Контрагент = ВыборкаДетальныеЗаписи.Контрагент;
			СтруктураВозврата.СчетКонтрагента = ВыборкаДетальныеЗаписи.СчетКонтрагента;
			СтруктураВозврата.ДоговорКонтрагента = ВыборкаДетальныеЗаписи.ДоговорКонтрагента;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПлатежныеПорученияВходящиеВидОперацииПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ПлатежныеПорученияВходящие.ТекущиеДанные;
	
	СтруктураНастройки = ПолучитьСтруктуруСтаатьиКорреспонденциюКонтрагентаПоВидуОперации("Входящие", ТекущаяСтрока.ВидОперации, ТекущаяСтрока.Контрагент, СокрЛП(ТекущаяСтрока.SenderInn));
	
	ТекущаяСтрока.Корреспонденция 		= СтруктураНастройки.Корреспонденция;
	ТекущаяСтрока.КорреспонденцияРегл   = СтруктураНастройки.КорреспонденцияРегл;
	ТекущаяСтрока.Статья                = СтруктураНастройки.Статья;
	
	// Если СтруктураНастройки.Контрагент <> Неопределено, то менять ничего не нужно
	Если СтруктураНастройки.Контрагент <> Неопределено Тогда 
		ТекущаяСтрока.Контрагент 		= СтруктураНастройки.Контрагент;
		ТекущаяСтрока.СчетКонтрагента   = СтруктураНастройки.СчетКонтрагента;
		ТекущаяСтрока.ДоговорКонтрагента= СтруктураНастройки.ДоговорКонтрагента;
	КонецЕсли;
	
	ПредыдущиеЗначениеВидаОперации = ТекущаяСтрока.ВидОперации;
	
КонецПроцедуры

&НаКлиенте
Процедура ПлатежныеПорученияВходящиеРасходыВидОперацииПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ПлатежныеПорученияВходящиеРасходы.ТекущиеДанные;
	
	СтруктураНастройки = ПолучитьСтруктуруСтаатьиКорреспонденциюКонтрагентаПоВидуОперации("Расход", ТекущаяСтрока.ВидОперации, ТекущаяСтрока.Контрагент, СокрЛП(ТекущаяСтрока.BeneficiaryInn));
	
	ТекущаяСтрока.Корреспонденция 		= СтруктураНастройки.Корреспонденция;
	ТекущаяСтрока.КорреспонденцияРегл   = СтруктураНастройки.КорреспонденцияРегл;
	ТекущаяСтрока.Статья                = СтруктураНастройки.Статья;
	
	// Если СтруктураНастройки.Контрагент <> Неопределено, то менять ничего не нужно
	Если СтруктураНастройки.Контрагент <> Неопределено Тогда 
		ТекущаяСтрока.Контрагент 		= СтруктураНастройки.Контрагент;
		ТекущаяСтрока.СчетКонтрагента   = СтруктураНастройки.СчетКонтрагента;
		ТекущаяСтрока.ДоговорКонтрагента= СтруктураНастройки.ДоговорКонтрагента;
	КонецЕсли;
	
	ПредыдущиеЗначениеВидаОперации = ТекущаяСтрока.ВидОперации;
	
КонецПроцедуры

&НаКлиенте
Процедура СчетаУчетаПоУмолчаниюВходящиеПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	ТекущаяСтрока = Элементы.СчетаУчетаПоУмолчаниюВходящие.ТекущиеДанные;
	
	Для Каждого Строк Из СчетаУчетаПоУмолчаниюВходящие Цикл 
		Если Строк <> ТекущаяСтрока Тогда 
			Если Строк.ВидОперации = ТекущаяСтрока.ВидОперации Тогда 
				Отказ = Истина;
				Сообщить(НСтр("ru = 'Вид операции: "+ ТекущаяСтрока.ВидОперации +" уже есть в таблице!'; ka = 'Вид операции: "+ ТекущаяСтрока.ВидОперации +" уже есть в таблице!'"));
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

