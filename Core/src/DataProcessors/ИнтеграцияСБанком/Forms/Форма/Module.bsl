&НаСервере
Процедура ЗаполнитьТаблицуСчетовПоУмолчанию(ИмяТаблицы)
	
	Если ИмяТаблицы = "Входящие" Тогда
		
		Для Каждого Элемент Из Метаданные.Перечисления.ВидыОперацийПоступлениеНаСчет.ЗначенияПеречисления Цикл 
			НовСтрокВход = СчетаУчетаПоУмолчаниюВходящие.Добавить();
			НовСтрокВход.ВидОперации 			= Перечисления.ВидыОперацийПоступлениеНаСчет[Элемент.Имя];
			НовСтрокВход.Корреспонденция 		= ПланыСчетов.Управленческий.ПустаяСсылка();
			НовСтрокВход.КорреспонденцияРегл	= ПланыСчетов.Хозрасчетный.ПустаяСсылка();
			НовСтрокВход.Статья					= Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
		КонецЦикла;
		
	ИначеЕсли ИмяТаблицы = "Расход" Тогда
		
		Для Каждого Элемент Из Метаданные.Перечисления.ВидыОперацийРасходСоСчета.ЗначенияПеречисления Цикл 
			НовСтрокВход = СчетаУчетаПоУмолчаниюРасход.Добавить();
			НовСтрокВход.ВидОперации 			= Перечисления.ВидыОперацийРасходСоСчета[Элемент.Имя];
			НовСтрокВход.Корреспонденция 		= ПланыСчетов.Управленческий.ПустаяСсылка();
			НовСтрокВход.КорреспонденцияРегл	= ПланыСчетов.Хозрасчетный.ПустаяСсылка();
			НовСтрокВход.Статья					= Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка();
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимость()
	
	Элементы.СтраницыОбновлений.Видимость = ВидимостьОбновлений;
	
	Элементы.ДатаНачала.АвтоОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.ДатаНачала);
	Элементы.ДатаНачала.ОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.ДатаНачала);
	
	Элементы.ДатаОкончания.АвтоОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.ДатаОкончания);
	Элементы.ДатаОкончания.ОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.ДатаОкончания); 
	
	//Элементы.Валюта.АвтоОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.Валюта);
	//Элементы.Валюта.ОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.Валюта); 
	
	//Элементы.Банк.АвтоОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.Банк);
	//Элементы.Банк.ОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.Банк); 
	
	Элементы.СчетОрганизации.АвтоОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.СчетОрганизации);
	Элементы.СчетОрганизации.ОтметкаНезаполненного = ВидимостьОбновлений И НЕ ЗначениеЗаполнено(Объект.СчетОрганизации); 
	
	Элементы.ПредИСлед.Видимость = НомерСтраницы > 0; 
	
	Элементы.ШапкаВыгрузка.Видимость = IDВыпискиПолучен; 
	Элементы.ПредИСледППВ.Видимость = НомерСтраницы > 0;
	
КонецПроцедуры

