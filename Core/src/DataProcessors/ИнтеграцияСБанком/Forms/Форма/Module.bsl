&НаСервере
Функция ПолучитьОстатокНаДату(EntryDate)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТаблицаОстатковПоДням.Date,
	|	ТаблицаОстатковПоДням.BalanceBase,
	|	ТаблицаОстатковПоДням.DebitSum,
	|	ТаблицаОстатковПоДням.Balance,
	|	ТаблицаОстатковПоДням.Rate,
	|	ТаблицаОстатковПоДням.CreditSum,
	|	ТаблицаОстатковПоДням.EntryCount
	|ПОМЕСТИТЬ ТаблицаОстатковПоДням
	|ИЗ
	|	&ТаблицаОстатковПоДням КАК ТаблицаОстатковПоДням
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТаблицаОстатковПоДням.Date,
	|	ТаблицаОстатковПоДням.BalanceBase,
	|	ТаблицаОстатковПоДням.DebitSum,
	|	ТаблицаОстатковПоДням.Balance,
	|	ТаблицаОстатковПоДням.Rate,
	|	ТаблицаОстатковПоДням.CreditSum,
	|	ТаблицаОстатковПоДням.EntryCount
	|ИЗ
	|	ТаблицаОстатковПоДням КАК ТаблицаОстатковПоДням
	|ГДЕ
	|	ТаблицаОстатковПоДням.Date = &EntryDate";
	
	Запрос.УстановитьПараметр("ТаблицаОстатковПоДням", ТаблицаОстатковПоДням);
	Запрос.УстановитьПараметр("EntryDate", ДельтаНСФ.ПереводВДату(EntryDate));
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Выборка.Следующий();
	
	СтруктураПолей = Новый Структура();
	СтруктураПолей.Вставить("Date",        Выборка.Date);
	СтруктураПолей.Вставить("BalanceBase", Выборка.BalanceBase);
	СтруктураПолей.Вставить("DebitSum",    Выборка.DebitSum);
	СтруктураПолей.Вставить("Balance",     Выборка.Balance);
	СтруктураПолей.Вставить("CreditSum",   Выборка.CreditSum);
	СтруктураПолей.Вставить("Rate",        Выборка.Rate);
	СтруктураПолей.Вставить("EntryCount",  Выборка.EntryCount);
	
	Возврат СтруктураПолей;
	
КонецФункции

