&НаСервере
Процедура ОбновитьСтатусыДокументовГлобальноСервер()
	
	Если ЗначениеЗаполнено(Объект.ДатаОкончания) И ЗначениеЗаполнено(Объект.ДатаНачала) Тогда 
		Если Не Объект.ДатаНачала <= Объект.ДатаОкончания Тогда 
			ТекстСообщения = НСтр("ka='დაწყების თარიღი არ უნდა იყოს დასრულების თარიღზე მეტი ან ტოლი!';ru='Дата начала не может быть больше или равна дате окончания!';en='Start date can not be greater than or equal to the end date!'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);
			Возврат;
		КонецЕсли;
	Иначе 
		ТекстСообщения = НСтр("ka='დაწყების თარიღი და დასრულების თარიღი აუცილებლად შესავსები ველებია!';ru='Дата начала и дата окончания обязательны для заполнения!';en='Start date and end date are required!'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);	
		Возврат;
	КонецЕсли;	
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;	
	КоличествоОбновленныхСтатусов = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СтатусыДокументовВИнтернетБанке.ДокументСсылка КАК Документ,
	               |	УИДДокументовВИнтернетБанке.УИДДокументаВБанке КАК УникальныйКлючВИнтернетБанке,
	               |	СтатусыДокументовВИнтернетБанке.ДокументСсылка.Дата КАК Дата,
	               |	ВЫБОР
	               |		КОГДА СтатусыДокументовВИнтернетБанке.ДокументСсылка ССЫЛКА Документ.Конвертация
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК Конвертация,
	               |	СтатусыДокументовВИнтернетБанке.СтатусДокументаВИнтернетБанке КАК ТекущийСтатусДокумента
	               |ПОМЕСТИТЬ ДокументыДляОбновления
	               |ИЗ
	               |	РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(
	               |			&ТекДата,
	               |			ДокументСсылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	               |				И (ДокументСсылка ССЫЛКА Документ.Конвертация
	               |					ИЛИ ДокументСсылка ССЫЛКА Документ.РасходСоСчета)
	               |				И СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИНтернетБанке.ПустаяСсылка)
	               |				И СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИНтернетБанке.ПрисутствуетТолькоВТекущейБазе)) КАК СтатусыДокументовВИнтернетБанке
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	               |		ПО СтатусыДокументовВИнтернетБанке.ДокументСсылка = УИДДокументовВИнтернетБанке.ДокументСсылка
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ДокументыДляОбновления.Документ,
	               |	ДокументыДляОбновления.УникальныйКлючВИнтернетБанке,
	               |	ДокументыДляОбновления.Дата,
	               |	ДокументыДляОбновления.Документ.ВидОперации КАК ВидОперации,
	               |	ДокументыДляОбновления.Конвертация,
	               |	ДокументыДляОбновления.ТекущийСтатусДокумента
	               |ИЗ
	               |	ДокументыДляОбновления КАК ДокументыДляОбновления
	               |ГДЕ
	               |	ДокументыДляОбновления.Дата >= &ДатаНачала
	               |	И ДокументыДляОбновления.Дата <= &ДатаОкончания
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ДокументыДляОбновления.УникальныйКлючВИнтернетБанке,
	               |	ДокументыДляОбновления.Дата,
	               |	ДокументыДляОбновления.Конвертация,
	               |	ДокументыДляОбновления.Документ,
	               |	ДокументыДляОбновления.Документ.ВидОперации,
	               |	ДокументыДляОбновления.ТекущийСтатусДокумента";
	
	Граница = Новый Граница(КонецДня(Объект.ДатаОкончания), ВидГраницы.Включая);
	Запрос.УстановитьПараметр("ДатаНачала"   , Объект.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", Граница.Значение); //Объект.ДатаОкончания
	Запрос.УстановитьПараметр("ТекДата"		 , ТекущаяДата());
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл  
		
		ПараметрыЗапроса = Новый Структура;
		УникальныйКлюч = СтрЗаменить(СокрЛП(Выборка.УникальныйКлючВИнтернетБанке), "," , "");
		ПараметрыЗапроса.Вставить("Key", УникальныйКлюч);
		
		//Если Выборка.ВидОперации = Перечисления.ВидыОперацийППИсходящее.ВыплатаЗаработнойПлатыРаботнику И НЕ Выборка.Конвертация Тогда 
		Если (Выборка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Зарплата 
			ИЛИ Выборка.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников)
			И НЕ Выборка.Конвертация Тогда 
			ТаблицаСтатусов = МенеджерОбработки.ВыполнитьМетодСервиса("api/documents/bulk/status/", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
		Иначе 			
			Статус = МенеджерОбработки.ВыполнитьМетодСервиса("api/documents/status/", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
		КонецЕсли;
		
		// тут надо сделать проверки , если статус не получен или еще что-то надо проверять
		
		//ДокументОбъект = Выборка.Документ.ПолучитьОбъект();
		
		Если Не ТаблицаСтатусов = Неопределено Тогда 
			
			//Для Каждого СтрТЧ Из ДокументОбъект.ВыплатаЗаработнойПлаты Цикл      
			Для Каждого СтрТЧ Из Выборка.Документ.ВыплатаЗаработнойПлаты Цикл
				
				//ВедомостьОбъект = СтрТЧ.Ведомость.ПолучитьОбъект();
				///??? пока не знаю что с этим делать
				//Для Каждого СтрокаТЧ Из ВедомостьОбъект.СуммаКВыплате Цикл 
				Для Каждого СтрокаТЧ Из СтрТЧ.Ведомость.Сотрудники Цикл 
					Для Каждого Строка ИЗ ТаблицаСтатусов Цикл
						
						Отбор = Новый Структура("УникальныйИД", СтрокаТЧ.УникальныйИдентификаторВИнтернетБанке);
						НайденныеСтроки = ТаблицаСтатусов.НайтиСтроки(Отбор);
						Если НайденныеСтроки.Количество() = 1 И Не НайденныеСтроки[0].Статус = "" Тогда
							//СтрокаТЧ.СтатусВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке[НайденныеСтроки[0].Статус];	
							
							ВнестиНовыйСтатусДокумента(ТекущаяДата(), 
								СтрТЧ.Ведомость, 
								Перечисления.СтатусыДокументовВИнтернетБанке[НайденныеСтроки[0].Статус],
								УникальныйКлюч, СтрокаТЧ.Сотрудник);
							
							КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1;
						ИначеЕсли Строка.УникальныйИД = "" И ЗначениеЗаполнено(Строка.Статус) И Не Строка.Статус = "" Тогда 
							//ДокументОбъект.СтатусВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке[Строка.Статус];
							
							ВнестиНовыйСтатусДокумента(ТекущаяДата(), 
								СтрТЧ.Ведомость, 
								Перечисления.СтатусыДокументовВИнтернетБанке[Строка.Статус],
								УникальныйКлюч, СтрокаТЧ.Сотрудник);
							
							КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1; 
						КонецЕсли;
					КонецЦикла;
					
				КонецЦикла;
			КонецЦикла;
			
			//ДокументОбъект.Записать();
			
			//ВедомостьОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДокументЗарплатыКВыплате", Истина);
			//ВедомостьОбъект.Записать();
		КонецЕсли;
		
		Если Не Статус = Неопределено Тогда 
			//ДокументОбъект.СтатусВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке[Статус];
			
			//ДокументОбъект.Записать();	
			
			ПолученыйСтатус = Перечисления.СтатусыДокументовВИнтернетБанке[Статус];
			
			Если ПолученыйСтатус <> Выборка.ТекущийСтатусДокумента Тогда 
				ВнестиНовыйСтатусДокумента(ТекущаяДата(), 
						Выборка.Документ, 
						Перечисления.СтатусыДокументовВИнтернетБанке[Статус],
						УникальныйКлюч);
			КонецЕсли;
			КоличествоОбновленныхСтатусов = КоличествоОбновленныхСтатусов + 1;				
		КонецЕсли;	
		
		ТаблицаСтатусов = Неопределено;
		Статус = Неопределено;
		
		
		/////
		
