	Лист = Книга.WorkSheets(1);
	//Или добавить в книгу новый лист:	
	
	Строка  = 15; 
	Строка  = Строка + 1;  
	Колонка = 1;
	Шапка   = Истина;
	Индекс  = 0;            
	
	Лист.Cells(4, 3).Value  = "ამონაწერი";
	Лист.Cells(4, 3).Font.Bold = 1;
	
	Лист.Cells(5, 1).Value  = "ანგარიშის მფლობელი: " + Объект.СчетВыписки.Владелец.Наименование;
	Лист.Cells(6, 1).Value  = "საიდენტიფიკაციო კოდი: " + Объект.СчетВыписки.Владелец.ИНН;
	Лист.Cells(7, 1).Value  = "ანგარიში: " + Объект.СчетВыписки.НомерСчета;
	Лист.Cells(8, 1).Value  = "ვალუტა: " + Объект.СчетВыписки.ВалютаДенежныхСредств.Код;
	Лист.Cells(9, 1).Value  = "პერიოდი: " + ДельтаНСФ.ДатаВремяВСтроку(Объект.ДатаНачалаВыписки) + " - " + ДельтаНСФ.ДатаВремяВСтроку(Объект.ДатаОкончанияВыписки);
	Лист.Cells(10, 1).Value = "საწყისი ნაშთი: " + Объект.InAmount;
	Лист.Cells(11, 1).Value = "საბოლოო ნაშთი: " + Объект.OutAmount;
	Лист.Cells(12, 1).Value = "საწყისი ნაშთი ექვ ლარში: " + Объект.InAmountBase;
	Лист.Cells(13, 1).Value = "საბოლოო ნაშთი ექვ ლარში: " + Объект.OutAmountBase;	
	
	Для Каждого СтрокаТаблицы Из ТаблицаExcel Цикл 
		
		Счетчик = 1;
		Для Каждого СтрокаПоле ИЗ ВыбранныеПоля Цикл 
			
			Если Шапка Тогда 
				Лист.Cells(Строка - 1, Счетчик).Value = СтрокаПоле.СинонимПоля;
				Лист.Cells(Строка - 1, Счетчик).Font.Bold = 1;
				//илона
				Лист.Cells(Строка - 1, Счетчик).Borders.Linestyle = 1;
				Лист.Cells(Счетчик).ColumnWidth = 20;
				//илона
			КонецЕсли;							
			
			Лист.Cells(Строка, Счетчик).Value = ?(ТипЗнч(СтрокаТаблицы[СтрЗаменить(СтрокаПоле.Поле, " ", "")]) = ТИП("Дата"), ДельтаНСФ.ДатаВСтроку(СтрокаТаблицы[СтрЗаменить(СтрокаПоле.Поле, " ", "")]), СтрокаТаблицы[СтрЗаменить(СтрокаПоле.Поле, " ", "")]);
			//илона
			Лист.Cells(Строка, Счетчик).Borders.Linestyle = 1;
			//илона
			Счетчик = Счетчик + 1;
		КонецЦикла;
		
		Шапка = Ложь;
		Строка = Строка + 1;
		
	КонецЦикла;
