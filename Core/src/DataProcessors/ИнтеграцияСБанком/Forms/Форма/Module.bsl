Функция ПроверкаНаСуществованиеДанногоДокумента(EntryId)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПлатежноеПоручениеВходящее.Ссылка
	               |ПОМЕСТИТЬ ВТ_Ссылки
	               |ИЗ
	               |	Документ.ПоступлениеНаСчет КАК ПлатежноеПоручениеВходящее
	               |ГДЕ
	               |	ЕСТЬNULL(ПлатежноеПоручениеВходящее.EntryId, """") = &EntryId
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ПлатежноеПоручениеВходящее.Ссылка
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	УИДДокументовВИнтернетБанке.ДокументСсылка
	               |ИЗ
	               |	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	               |ГДЕ
	               |	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = &EntryId
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Ссылки.Ссылка
	               |ИЗ
	               |	ВТ_Ссылки КАК ВТ_Ссылки";
	
	Запрос.УстановитьПараметр("EntryId", EntryId);
	
	Результат = Запрос.Выполнить();
	
