Процедура ПлатежныеПорученияВходящиеРасходыВидОперацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Вставити вміст обробника.
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеСчетовОрганизации(СтрокаТЧ, Владелец, ВалютаОтправитель, ВалютаПолучатель)
	
	ПустойБанковскийСчет = ПредопределенноеЗначение("Справочник.БанковскиеСчета.ПустаяСсылка");
	ЕстьСчетОтправителя = ЗначениеЗаполнено(СтрокаТЧ.СчетОтправителя); 
	ЕстьСчетПолучателя  = ЗначениеЗаполнено(СтрокаТЧ.СчетКонтрагента);
	
	ДобавитьНайденныйСчет = Ложь;
	
	Если НЕ ЕстьСчетОтправителя Тогда 
		
		//Попробуем ОтыскатьСчет по номеру и в таблице созданных
		НайденныйСчет = ПустойБанковскийСчет;
		СтруктураПоиска = Новый Структура("НомерСчета", СокрЛП(СтрокаТЧ.SenderAccountNumber));
		МассивПоиска = ТаблицаСозданныхСчетовОрганизации.НайтиСтроки(СтруктураПоиска);
		
		Если МассивПоиска.Количество() <> 0 Тогда 
			НайденныйСчет = МассивПоиска[0].БанковскийСчет;
		Иначе
			НайденныйСчет = ПолучитьСчетОрганизации(Лев(СокрЛП(СтрокаТЧ.SenderAccountNumber),22), СокрЛП(СтрокаТЧ.SenderAccountNumber), ВалютаОтправитель);
			ДобавитьНайденныйСчет = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НайденныйСчет) Тогда 
			
			СтрокаТЧ.СчетОтправителя = НайденныйСчет;
			
			Если ДобавитьНайденныйСчет Тогда 
				
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = СокрЛП(СтрокаТЧ.SenderAccountNumber);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НайденныйСчет;
				ДобавитьНайденныйСчет = Ложь;
				
			КонецЕсли;
			
		Иначе
			
			НовыйСчет = Объект.СчетДляППВ.Скопировать();
			// Меняем только номерСчета, валюту, наименование
			НовыйСчет.НомерСчета 			= СокрЛП(СтрокаТЧ.SenderAccountNumber);
			НовыйСчет.ВалютаДенежныхСредств = ВалютаОтправитель;
			НаименованиеБанка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НовыйСчет.Банк, "Наименование");
			НовыйСчет.Наименование 			= Лев(СокрЛП(НовыйСчет.НомерСчета) + ?(ЗначениеЗаполнено(НаименованиеБанка), ", в " + НаименованиеБанка, ""), 100);
			
			Попытка
				
				НовыйСчет.Записать();
				Сообщить(НСтр("ru = 'Был создан новый банковский счет организации: """+ СокрЛП(СтрокаТЧ.SenderAccountNumber) +"""!'; ka = 'Был создан новый банковский счет организации: """+ СокрЛП(СтрокаТЧ.SenderAccountNumber) +"""!'"));
				СтрокаТЧ.СчетОтправителя = НовыйСчет.Ссылка;
				
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = СокрЛП(СтрокаТЧ.SenderAccountNumber);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НовыйСчет.Ссылка;
				
			Исключение
				
				Сообщить(НСтр("ru = 'Не удалось создать банковский счет организации: """+ СокрЛП(СтрокаТЧ.SenderAccountNumber) +"""!'; ka = 'Не удалось создать банковский счет организации: """+ СокрЛП(СтрокаТЧ.SenderAccountNumber) +"""!'"));
				
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
	ДобавитьНайденныйСчет = Ложь;
	
	Если НЕ ЕстьСчетПолучателя Тогда 
		
		//Попробуем ОтыскатьСчет по номеру и в таблице созданных
		НайденныйСчет = ПустойБанковскийСчет;
		СтруктураПоиска = Новый Структура("НомерСчета", СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber));
		МассивПоиска = ТаблицаСозданныхСчетовОрганизации.НайтиСтроки(СтруктураПоиска);
		
		Если МассивПоиска.Количество() <> 0 Тогда 
			НайденныйСчет = МассивПоиска[0].БанковскийСчет;
		Иначе
			НайденныйСчет = ПолучитьСчетОрганизации(Лев(СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber),22), СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber), ВалютаОтправитель);
			ДобавитьНайденныйСчет = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НайденныйСчет) Тогда 
			
			СтрокаТЧ.СчетКонтрагента = НайденныйСчет;
			
			Если ДобавитьНайденныйСчет Тогда 
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НайденныйСчет;
				ДобавитьНайденныйСчет = Ложь;
			КонецЕсли;
			
		Иначе
			
			НовыйСчет = Объект.СчетДляППВ.Скопировать();
			// Меняем только номерСчета, валюту, наименование
			НовыйСчет.НомерСчета 			= СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber);
			НовыйСчет.ВалютаДенежныхСредств = ВалютаПолучатель;
			НаименованиеБанка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НовыйСчет.Банк, "Наименование");
			НовыйСчет.Наименование 			= Лев(СокрЛП(НовыйСчет.НомерСчета) + ?(ЗначениеЗаполнено(НаименованиеБанка), ", в " + НаименованиеБанка, ""), 100);
			
			Попытка
				
				НовыйСчет.Записать();
				Сообщить(НСтр("ru = 'Был создан новый банковский счет организации: """+ СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber) +"""!'; ka = 'Был создан новый банковский счет организации: """+ СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber) +"""!'"));
				СтрокаТЧ.СчетКонтрагента = НовыйСчет.Ссылка;
				
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НовыйСчет.Ссылка;
				
			Исключение
				
				Сообщить(НСтр("ru = 'Не удалось создать банковский счет организации: """+ СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber) +"""!'; ka = 'Не удалось создать банковский счет организации: """+ СокрЛП(СтрокаТЧ.BeneficiaryAccountNumber) +"""!'"));
				
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументыКонвертацииНаСервере()
	
	КолВоСозданныхДокументов = 0;		
	КоличествоПовторныхПопыток = 0;
	
	МассивНомеровСтрок = Новый Массив;
	
	ТаблицаСозданныхДокументов = Новый ТаблицаЗначений;
	ТаблицаСозданныхДокументов.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.Конвертация"));
	ТаблицаСозданныхДокументов.Колонки.Добавить("EntryId", Новый ОписаниеТипов("Строка"));
	
	
	СтруктураПоискаПомеченыхСтрок = Новый Структура("Пометка", Истина);
	МассивОбхода = Объект.ПлатежныеПорученияВходящиеКонвертации.НайтиСтроки(СтруктураПоискаПомеченыхСтрок);
	
	Для Каждого Транзакция ИЗ МассивОбхода Цикл
		
		СуществуетДокумент = ПроверкаНаСуществованиеДанногоДокумента(Транзакция.EntryId);
		
		Если НЕ ЗначениеЗаполнено(Транзакция.СозданныйДокумент) И Не СуществуетДокумент Тогда 
			
			ВалютаОтправитель = ПолучитьВалюту(Транзакция.DocumentDestinationCurrency);
			ВалютаПолучатель = ПолучитьВалюту(Транзакция.DocumentSourceCurrency);
			Если СоздаватьСчетаОрганизации Тогда 
				ПроверитьЗаполнениеСчетовОрганизации(Транзакция, Объект.Организация, ВалютаОтправитель, ВалютаПолучатель);
			КонецЕсли;
			
			НовыйДокумент 						= Документы.Конвертация.СоздатьДокумент();
			
			НовыйДокумент.Автор 				= ПараметрыСеанса.ТекущийПользователь;
			НовыйДокумент.ВалютаОтправитель     = ВалютаОтправитель;
			НовыйДокумент.ВалютаПолучатель      = ВалютаПолучатель;
			НовыйДокумент.ВидОперации           = Транзакция.ВидОперации;
			НовыйДокумент.Дата                  = Дата(Транзакция.EntryDate);
			НовыйДокумент.Комментарий           = Транзакция.DocumentInformation;
			
			
			
			НовыйДокумент.Организация           = Объект.Организация;
			НовыйДокумент.Отправитель           = Транзакция.СчетОтправителя;
			НовыйДокумент.Получатель            = Транзакция.СчетКонтрагента;
			
			ВалютаОтправитель = Транзакция.СчетОтправителя.ВалютаДенежныхСредств;
			ВалютаПолучатель = Транзакция.СчетКонтрагента.ВалютаДенежныхСредств;
			
			НовыйДокумент.ВалютаОтправитель     = ВалютаОтправитель;
			НовыйДокумент.ВалютаПолучатель      = ВалютаПолучатель;
			НовыйДокумент.Статья                = СтатьяПоУмолчанию;
			НовыйДокумент.СуммаКонвертации      = Число(Транзакция.DocumentDestinationAmount);
			НовыйДокумент.СуммаПолучено         = Число(Транзакция.DocumentSourceAmount);
			EntryId = СтрЗаменить(СтрЗаменить(СтрЗаменить(Транзакция.EntryId, " ", ""), ",", ""), Символы.НПП, "");
			НовыйДокумент.УникальныйКлючВИнтернетБанке = EntryId;
			
			
			Если ВалютаОтправитель = НациональнаяВалюта ИЛИ ВалютаПолучатель = НациональнаяВалюта Тогда 
				НовыйДокумент.КоммерческийКурс      = Число(Транзакция.DocumentRate); 
			Иначе
				НовыйДокумент.КроссКурс             = Число(Транзакция.DocumentRate);
			КонецЕсли;
			
			НовыйДокумент.КратностьОтправитель  = 1;
			НовыйДокумент.КратностьПолучатель   = 1;
			
			Если ВалютаОтправитель = НациональнаяВалюта Тогда 
				НовыйДокумент.КурсОтправитель       = 1; //Число(Транзакция.DocumentRate);
				НовыйДокумент.КурсПолучатель        = Число(Транзакция.DocumentRate); //1;
			ИначеЕсли ВалютаПолучатель = НациональнаяВалюта Тогда
				НовыйДокумент.КурсОтправитель       = Число(Транзакция.DocumentRate); //1;
				НовыйДокумент.КурсПолучатель        = 1; //Число(Транзакция.DocumentRate);
			Иначе 
				НовыйДокумент.КурсОтправитель       = 1;
				НовыйДокумент.КурсПолучатель        = 1;
			КонецЕсли;
			
			/////////////////////////////////////////////////////////////////
			//НовыйДокумент.ЗагруженоИзБанка				= Истина;
			
			НовыйДокумент.Записать();
			КолВоСозданныхДокументов = КолВоСозданныхДокументов + 1;
			
			// Запись нового УИД банка
			НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
			НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(НовыйДокумент.Ссылка);
			НаборЗаписейУИДДокумента.Отбор.Сотрудник.Установить(Справочники.Сотрудники.ПустаяСсылка());
			НаборЗаписейУИДДокумента.Отбор.Банк.Установить(Объект.Банк);
			
			НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
			НовыйУИД.ДокументСсылка = НовыйДокумент.Ссылка;
			НовыйУИД.Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
			НовыйУИД.Банк = Объект.Банк;
			НовыйУИД.УИДДокументаВБанке = EntryId;
			НовыйУИД.Выгружен = Истина;
			
			НаборЗаписейУИДДокумента.Записать();
			
			// Запись нового статуса
			НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
			НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(НовыйДокумент.Ссылка);
			НаборЗаписейСтатусовДокумента.Отбор.Сотрудник.Установить(Справочники.Сотрудники.ПустаяСсылка());
			НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ТекущаяДата());
			НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(Объект.Банк);
			
			НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
			НовыйСтатус.ДокументСсылка = НовыйДокумент.Ссылка;
			НовыйСтатус.Период = ТекущаяДата();
			НовыйСтатус.Банк = Объект.Банк;
			НовыйСтатус.Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
			НовыйСтатус.СтатусДокументаВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка;
			
			НаборЗаписейСтатусовДокумента.Записать();
			////////////////////////////////////
			
			Если ПытатьсяПровестиДокументКонвертация Тогда 
				Попытка
					НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
					Транзакция.Проведен = Истина;
				Исключение
					а=1;
				КонецПопытки;
				
			КонецЕсли;
			Транзакция.СозданныйДокумент = НовыйДокумент.Ссылка;
			
		КонецЕсли;	
		
		Если СуществуетДокумент И Транзакция.Пометка Тогда
			
			СозданныйДокумент = ПолучитьСуществующийДокумент(Транзакция.EntryId);
			
			НоваяСтрока = ТаблицаСозданныхДокументов.Добавить();
			НоваяСтрока.ДокументСсылка = СозданныйДокумент;
			НоваяСтрока.EntryId = Транзакция.EntryId;
			
			МассивНомеровСтрок.Добавить(Транзакция.НомерСтроки);			
			КоличествоПовторныхПопыток = КоличествоПовторныхПопыток + 1;
		КонецЕсли;	
		
		Для Каждого СтрокаТЧ ИЗ Объект.ПлатежныеПорученияВходящие Цикл
			Для Каждого Строка ИЗ ТаблицаСозданныхДокументов Цикл 			
				Если СтрокаТЧ.EntryId = Строка.EntryId Тогда 
					СтрокаТЧ.СозданныйДокумент = Строка.ДокументСсылка;
				КонецЕсли;
			КонецЦикла;	
			
			// Дозаполним поле контрагент
			//СтруктураПоиска = Новый Структура("ИНН, Наименование", СокрЛП(СтрокаТЧ.SenderInn), СокрЛП(СтрокаТЧ.SenderName));
			//
			//МассивНайденныхСтрок = ТаблицаСозданныхКонтрагентов.НайтиСтроки(СтруктураПоиска);
			//
			//Если МассивНайденныхСтрок.Количество() <> 0 Тогда
			//	СтрокаТЧ.Контрагент = МассивНайденныхСтрок[0].Контрагент;
			//КонецЕсли;
		КонецЦикла;
		
	КонецЦикла;	
	
	ТекстКолВоСозданныхДокументов = Нстр("ka='შექმნილია "+ КолВоСозданныхДокументов + " დოკუმენტი! ';ru='Создано "+ КолВоСозданныхДокументов + " документа/ов'");
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстКолВоСозданныхДокументов,,Объект,, ЛОЖЬ);
	
	Если КоличествоПовторныхПопыток > 0 Тогда 		
		Для Каждого ЭлементМассива ИЗ МассивНомеровСтрок Цикл 
			ТекстКолВоСозданныхДокументов = Нстр("ka='სტრიქონისთვის № "+ ЭлементМассива + " არ შეიქმნა დოკუმენტი, რადგან ამ ჩანაწერისთვის სისტემაში უკვე არსებობს დოკუმენტი! ';ru='Для строки № "+ ЭлементМассива + " не создано документа, так как для этой записи в системе уже создан документ!'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстКолВоСозданныхДокументов,,Объект,, ЛОЖЬ);		
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументыКонвертации(Команда)
	
	ОчиститьСообщения();
	СоздатьДокументыКонвертацииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура КонвертацииДСДокументКонвертацииДСОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)

	СтандартнаяОбработка = Ложь;     
	ТекСтрока = Элементы.КонвертацииДС.ТекущиеДанные;
	
	УИДСтроки = ТекСтрока.ПолучитьИдентификатор();
	
	ОпределитьСтрокуНаСервереИЗаполнитьСтрокуКонвертацииНаСервере(УИДСтроки, ВыбранноеЗначение);
	
КонецПроцедуры

Процедура ОпределитьСтрокуНаСервереИЗаполнитьСтрокуКонвертацииНаСервере(УИДСтроки, Док)
	
	СтрокаКонвертации = Объект.КонвертацииДС.НайтиПоИдентификатору(УИДСтроки);
	
	//ЗаполнитьСтрокуТЧПлатежныеПаручения(Док, СтрокаПлатежногоПолучения);
	
	СтрокаКонвертации.КонвертацияБезналичныхДенежныхСредств = Док.Ссылка;
	СтрокаКонвертации.Пометка                               = Ложь;
	СтрокаКонвертации.UniqueId                              = 1;
	СтрокаКонвертации.DocumentNo                            = Док.Номер;
	Если ТипЗнч(Док.Отправитель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда 
		СтрокаКонвертации.SourceAccountNumber                   = Док.Отправитель.НомерСчета;//СчетОтправитель.НомерСчета;
		СтрокаКонвертации.SourceCurrency                        = Док.Отправитель.ВалютаДенежныхСредств;//СчетОтправитель.ВалютаДенежныхСредств;
		ВалютаОтправителя = Док.Отправитель.ВалютаДенежныхСредств;
	ИначеЕсли ТипЗнч(Док.Отправитель) = Тип("СправочникСсылка.Сотрудники") Тогда
		СтрокаКонвертации.SourceAccountNumber                   = Док.Отправитель.БанковскийСчетПоУмолчанию.НомерСчета;//СчетОтправитель.НомерСчета;
		СтрокаКонвертации.SourceCurrency                        = Док.Отправитель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;//СчетОтправитель.ВалютаДенежныхСредств;
		ВалютаОтправителя = Док.Отправитель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;
	КонецЕсли;
	
	Если ТипЗнч(Док.Получатель) = Тип("СправочникСсылка.БанковскиеСчета") Тогда
		СтрокаКонвертации.DestinationAccountNumber              = Док.Получатель.НомерСчета;//СчетПолучатель.НомерСчета;
		СтрокаКонвертации.DestinationCurrency                   = Док.Получатель.ВалютаДенежныхСредств;//СчетПолучатель.ВалютаДенежныхСредств;
		ВалютаПолучателя = Док.Получатель.ВалютаДенежныхСредств;
	ИначеЕсли ТипЗнч(Док.Отправитель) = Тип("СправочникСсылка.Сотрудники") Тогда
		СтрокаКонвертации.DestinationAccountNumber              = Док.Получатель.БанковскийСчетПоУмолчанию.НомерСчета;//СчетПолучатель.НомерСчета;
		СтрокаКонвертации.DestinationCurrency                   = Док.Получатель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;//СчетПолучатель.ВалютаДенежныхСредств;
		ВалютаПолучателя = Док.Получатель.БанковскийСчетПоУмолчанию.ВалютаДенежныхСредств;
	КонецЕсли;
	
	СтрокаКонвертации.Amount                                = СтрЗаменить(СтрЗаменить(СтрЗаменить(Строка(Док.СуммаКонвертации),",", ""), " ", ""),Символы.НПП, "");//СтрЗаменить(СтрЗаменить(СтрЗаменить(Строка(Док.СуммаСписанная),",", ""), " ", ""),Символы.НПП, "");
	
	НацВалюта = Константы.НациональнаяВалюта.Получить();
	//СтруктураКурсаОтправителя = МодульВалютногоУчета.ПолучитьКурсВалюты(Док.СчетОтправитель.ВалютаДенежныхСредств, Док.Дата);
	Если Док.Получатель.ВалютаДенежныхСредств = НацВалюта ИЛИ Док.Отправитель.ВалютаДенежныхСредств = НацВалюта Тогда 		
		////НоваяСтрока.Rate           = СтруктураКурсаОтправителя.Курс;
		СтрокаКонвертации.Rate           = Док.КоммерческийКурс;
	ИначеЕсли Док.Отправитель.ВалютаДенежныхСредств <> НацВалюта И Док.Получатель.ВалютаДенежныхСредств <> НацВалюта Тогда 
		СтрокаКонвертации.Rate           = Док.КроссКурс;
	КонецЕсли;
	//НоваяСтрока.Rate = ?(ВалютаОтправителя = Справочники.Валюты.НайтиПоКоду("643"), Док.КурсПолучатель, Док.КурсОтправитель);
	СтрокаКонвертации.AdditionalInfo = Док.Комментарий;
	
КонецПроцедуры
