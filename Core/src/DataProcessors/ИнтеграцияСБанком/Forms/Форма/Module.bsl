Процедура УстановитьОтбор()
	
	ПараметрыОтбораКонв = Новый Структура;
	ПараметрыОтбораКонв.Вставить("Проведен", Истина);
	ПараметрыОтбораКонв.Вставить(СокрЛП("КодБанкаСчетаОтправителя"), "BAGAGE22");
	ПараметрыОтбораКонв.Вставить("УникальныйКлючВИнтернетБанке", "");
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Проведен", Истина);
	ПараметрыОтбора.Вставить(СокрЛП("КодБанкаСчетаОтправителя"), "BAGAGE22");
	ПараметрыОтбора.Вставить("УникальныйКлючВИнтернетБанке", "");
	
	НовыйМассив = Новый Массив;
	НовыйМассив.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ПустаяСсылка"));
	НовыйМассив.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.ПустаяСсылка"));
	НовыйМассив.Добавить(Неопределено);
	
	ФиксированныйМассив = Новый ФиксированныйМассив(НовыйМассив);
	ПараметрыОтбора.Вставить("СтатусВИнтернетБанке", ФиксированныйМассив);
	
	Элементы.КонвертацииДСДокументКонвертацииДС.ПараметрыВыбора = ОбработатьПараметрВыбора(ПараметрыОтбораКонв);			
	Элементы.ПлатежныеПорученияПлатежноеПоручениеИсходящее.ПараметрыВыбора = ОбработатьПараметрВыбора(ПараметрыОтбора);	
	
КонецПроцедуры
// Отбор для доков

Функция ОбработатьПараметрВыбора(Параметры, НачальныеДанные = Неопределено) Экспорт
	
	НовыйМассив = Новый Массив();
	Если НЕ Параметры = Неопределено Тогда 
		Для Каждого Парам Из Параметры Цикл
			НовыйМассив.Добавить(Новый ПараметрВыбора("Отбор." + Парам.Ключ, Парам.Значение));	
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ НачальныеДанные = Неопределено Тогда
		Для Каждого СтрокаДанных Из НачальныеДанные Цикл
			НовыйМассив.Добавить(Новый ПараметрВыбора(СтрокаДанных.Имя, СтрокаДанных.Значение));			
		КонецЦикла;
	КонецЕсли;	
	
	Возврат Новый ФиксированныйМассив(НовыйМассив); 	
	
КонецФункции


