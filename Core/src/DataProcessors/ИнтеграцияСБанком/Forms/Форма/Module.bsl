&НаСервере
Функция ПолучитьСтруктуруВалют();
	
	СтруктураВозврата = Новый Структура("Коммерческий, Кросс");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Валюты.Ссылка
		|ИЗ
		|	Справочник.Валюты КАК Валюты
		|ГДЕ
		|	НЕ Валюты.ПометкаУдаления
		|	И Валюты.Ссылка <> &НациональнаяВалюта";
	
	Запрос.УстановитьПараметр("НациональнаяВалюта", НациональнаяВалюта);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	МассивКомерческихВалют = Новый Массив;
	СоответствиеКроссВалют = Новый Соответствие;
	Для Каждого Строк Из РезультатЗапроса Цикл 
		МассивКомерческихВалют.Добавить(Строк.Ссылка);
		СоответствиеКроссВалют.Вставить(Строк.Ссылка);
	КонецЦикла;
	
	Для Каждого ЭлеметСоответствия Из СоответствиеКроссВалют Цикл 
		//ЭлеметСоответствия.Значение = МассивКомерческихВалют;
		СоответствиеКроссВалют[ЭлеметСоответствия.Ключ] = МассивКомерческихВалют;
	КонецЦикла;
	
	СтруктураВозврата.Коммерческий = МассивКомерческихВалют;
	СтруктураВозврата.Кросс = СоответствиеКроссВалют;
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаСервере
Процедура ОбновитьКоммерческиеКурсыСервер()	
	
	Если Не ЗначениеЗаполнено(Объект.Банк) Тогда //Или Не ЗначениеЗаполнено(Объект.Валюта) Тогда 		
		ТекстСообщения = НСтр("ka='ბანკი და ვალუტა არის აუცილებლად შესავსები ველები!';ru='Банк и валюта обязательны для заполнения!';en='Bank and currency are required!'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);	
		Возврат;
	КонецЕсли;	
	
	СтруктураВалют = ПолучитьСтруктуруВалют();
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;	
	//КоличествоОбновленныхСтатусов = 0;
	
	Для Каждого ЭлементаМассива Из СтруктураВалют.Коммерческий Цикл 
		ПараметрыЗапроса = Новый Структура;
		
		ПараметрыЗапроса.Вставить("currency", ЭлементаМассива);
		
		СтруктураКурсов = МенеджерОбработки.ВыполнитьМетодСервиса("api/rates/commercial/", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
		
		Если Не СтруктураКурсов = Неопределено Тогда 
			//
			//НаборЗаписей = РегистрыСведений.КоммерческиеКурсыВалют.СоздатьНаборЗаписей();
			//
			//НаборЗаписей.Отбор.Банк.Установить(Объект.Банк);
			//НаборЗаписей.Отбор.Валюта.Установить(Объект.Валюта);
			//НаборЗаписей.Отбор.Период.Установить(ТекущаяДата());
			//
			//Запись = НаборЗаписей.Добавить();
			//Запись.Период      = ТекущаяДата(); 
			//Запись.Банк        = Объект.Банк;
			//Запись.Валюта      = Объект.Валюта;
			//Запись.КурсПродажи = СтруктураКурсов.КурсПродажи;
			//Запись.КурсПокупки = СтруктураКурсов.КурсПокупки;
			//Запись.Кратность   = 1;
			
			
			НаборЗаписей = РегистрыСведений.КурсыВалютБанков.СоздатьНаборЗаписей();
			
			НаборЗаписей.Отбор.ВидКурса.Установить(Перечисления.ВидыКурсовВалютБанка.Коммерческий);
			НаборЗаписей.Отбор.Банк.Установить(Объект.Банк);
			НаборЗаписей.Отбор.Валюта.Установить(ЭлементаМассива);
			НаборЗаписей.Отбор.Период.Установить(ТекущаяДата());
			
			Запись = НаборЗаписей.Добавить();
			Запись.Период      = ТекущаяДата(); 
			Запись.ВидКурса    = Перечисления.ВидыКурсовВалютБанка.Коммерческий;
			Запись.Банк        = Объект.Банк;
			Запись.Валюта      = ЭлементаМассива;
			//Запись.КурсПродажи = СтруктураКурсов.КурсПродажи;
			//Запись.КурсПокупки = СтруктураКурсов.КурсПокупки;
			// Меняем продажу банка на нашу покупку
			Запись.КурсПокупки = СтруктураКурсов.КурсПродажи;
			Запись.КратностьПокупки   = 1;
			Запись.КурсПродажи = СтруктураКурсов.КурсПокупки;
			Запись.КратностьПродажи   = 1;
			
			НаборЗаписей.ОбменДанными.Загрузка = Истина;
			НаборЗаписей.Записать();
			
			Сообщение = Новый СообщениеПользователю;
			//Сообщение.Текст = НСтр("ka='კომერციული კურსები განახლებულია.';ru='Комерческие курсы обновлены.';en='Commercial courses updated.'");
			Сообщение.Текст = НСтр("ru = 'Курс "+ЭлементаМассива+" обновлены.'; ka = 'კურსები "+ЭлементаМассива+" განახლებულია.'");	
			Сообщение.Сообщить();
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
