Функция ПолучитьСчетОрганизации(НомерСчетаБезВалюты, НомерСчетаСВалютой, ВалютаСчета)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка КАК СчетОрганизации
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	(БанковскиеСчета.НомерСчета = &НомерСчетаСВалютой
	|			ИЛИ БанковскиеСчета.НомерСчета = &НомерСчетаБезВалюты)
	|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаСчета
	|	И НЕ БанковскиеСчета.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("НомерСчетаСВалютой", НомерСчетаСВалютой);
	Запрос.УстановитьПараметр("НомерСчетаБезВалюты", НомерСчетаБезВалюты);
	Запрос.УстановитьПараметр("ВалютаСчета", ?(ТипЗнч(ВалютаСчета) = Тип("Строка"),ПолучитьВалюту(ВалютаСчета),ВалютаСчета));	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.СчетОрганизации;

