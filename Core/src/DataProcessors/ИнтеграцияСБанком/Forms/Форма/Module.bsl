	КонецЕсли;	
	
	//Если ЗначениеЗаполнено(Объект.До) И ЗначениеЗаполнено(Объект.От) Тогда
	Если ЗначениеЗаполнено(ПериодВходящиеДоументы.ДатаОкончания) И ЗначениеЗаполнено(ПериодВходящиеДоументы.ДатаНачала) Тогда
		//Если Не Объект.ДатаНачалаВыписки <= Объект.ДатаОкончанияВыписки Тогда 
		//	ТекстСообщения = НСтр("ka='დაწყების თარიღი არ უნდა იყოს დასრულების თარიღზე მეტი ან ტოლი!';ru='Дата начала не может быть больше или ровна дате окончания!';en='Start date can not be greater than or equal to the end date!'");
		//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);
		//	Возврат;
		//КонецЕсли;
	Иначе 
		ТекстСообщения = НСтр("ka='დაწყების თარიღი და დასრულების თარიღი აუცილებლად შესავსები ველებია!';ru='Дата начала и дата окончания обязательны для заполнения!';en='Start date and end date are required!'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);	
		Возврат;
	КонецЕсли;	
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;	
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("currency", Объект.СчетДляППВ.ВалютаДенежныхСредств);
	ПараметрыЗапроса.Вставить("accountNumber", Лев(Объект.СчетДляППВ.НомерСчета, 22));
	ПараметрыЗапроса.Вставить("startDate", ДельтаНСФ.ДатаВСтроку(ПериодВходящиеДоументы.ДатаНачала));
	ПараметрыЗапроса.Вставить("endDate", ДельтаНСФ.ДатаВСтроку(ПериодВходящиеДоументы.ДатаОкончания));
	
	IDИКоличествоСтрок = МенеджерОбработки.ВыполнитьМетодСервиса("api/statement/", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
	
	Если Не IDИКоличествоСтрок = Неопределено Тогда 
		IDВыписки = СтрЗаменить(IDИКоличествоСтрок.ID, ",", "");
		КоличествоСтрок  = СтрЗаменить(IDИКоличествоСтрок.Count, ",", "");
		IDВыпискиПолучен = Истина;
		НомерСтраницыППВ = ?(Цел(КоличествоСтрок / 1000) < КоличествоСтрок / 1000, Цел(КоличествоСтрок / 1000) + 1, Цел(КоличествоСтрок / 1000));
		ПоследняяСтраница = НомерСтраницыППВ;
		УстановитьВидимость();
	КонецЕсли;
	
	Если IDВыпискиПолучен Тогда 
		ЗаполнитьТЧПлатежныеПорученияВходящие();		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
