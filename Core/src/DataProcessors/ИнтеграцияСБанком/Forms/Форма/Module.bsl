// выписка
&НаКлиенте
Процедура ПолучитьВыписку(Команда)
	
	ОчиститьСообщения();
	ПолучитьIDВыписки();
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьIDВыписки()
	
	Если Не ЗначениеЗаполнено(Объект.СчетВыписки) Тогда 		
		ТекстСообщения = НСтр("ka='ანგარიში არის აუცილებლად შესავსები ველი!';ru='Счет обязателен для заполнения!';en='Account mandatory to fill in!'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);	
		Возврат;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Объект.ДатаОкончанияВыписки) И ЗначениеЗаполнено(Объект.ДатаНачалаВыписки) Тогда 
		Если Не Объект.ДатаНачалаВыписки <= Объект.ДатаОкончанияВыписки Тогда 
			ТекстСообщения = НСтр("ka='დაწყების თარიღი არ უნდა იყოს დასრულების თარიღზე მეტი ან ტოლი!';ru='Дата начала не может быть больше или ровна дате окончания!';en='Start date can not be greater than or equal to the end date!'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);
			Возврат;
		КонецЕсли;
	Иначе 
		ТекстСообщения = НСтр("ka='დაწყების თარიღი და დასრულების თარიღი აუცილებლად შესავსები ველებია!';ru='Дата начала и дата окончания обязательны для заполнения!';en='Start date and end date are required!'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,Объект,, Истина);	
		Возврат;
	КонецЕсли;	
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;	
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("currency", Объект.СчетВыписки.ВалютаДенежныхСредств);
	ПараметрыЗапроса.Вставить("accountNumber", Лев(Объект.СчетВыписки.НомерСчета, 22));
	ПараметрыЗапроса.Вставить("startDate", ДельтаНСФ.ДатаВСтроку(Объект.ДатаНачалаВыписки));
	ПараметрыЗапроса.Вставить("endDate", ДельтаНСФ.ДатаВСтроку(Объект.ДатаОкончанияВыписки));
	
	IDИКоличествоСтрок = МенеджерОбработки.ВыполнитьМетодСервиса("api/statement/", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
	
	Если Не IDИКоличествоСтрок = Неопределено Тогда 
		IDВыписки = СтрЗаменить(IDИКоличествоСтрок.ID, ",", "");
		КоличествоСтрок  = СтрЗаменить(IDИКоличествоСтрок.Count, ",", "");
		IDВыпискиПолучен = Истина;
		НомерСтраницы = ?(Цел(КоличествоСтрок / 1000) < КоличествоСтрок / 1000, Цел(КоличествоСтрок / 1000) + 1, Цел(КоличествоСтрок / 1000));
		ПоследняяСтраница = НомерСтраницы;
		УстановитьВидимость();
	КонецЕсли;
	
	Если НомерСтраницы <> 0 И НомерСтраницы <> Неопределено ИЛИ IDВыпискиПолучен И IDИКоличествоСтрок <> Неопределено Тогда 
		ЗаполнитьТЧВыписки();		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Следующая(Команда)
	
	НомерСтраницыПред = НомерСтраницы;
	НомерСтраницы = ?(НомерСтраницы + 1 > ПоследняяСтраница, НомерСтраницы, НомерСтраницы + 1);
	Если НомерСтраницыПред <> НомерСтраницы Тогда 
		ЗаполнитьТЧВыписки();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Предыдущая(Команда)
	
	НомерСтраницыПред = НомерСтраницы;
	НомерСтраницы = ?(НомерСтраницы = 1 ИЛИ НомерСтраницы = 0, НомерСтраницы, НомерСтраницы - 1); 
	// если не измениласть страница нет смысла запусткат всю байду
	Если НомерСтраницыПред <> НомерСтраницы Тогда 
		ЗаполнитьТЧВыписки();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧВыписки()	
	
	МенеджерОбработки = Обработки.ИнтеграцияСБанком;
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("currency", Объект.СчетВыписки.ВалютаДенежныхСредств);
	ПараметрыЗапроса.Вставить("accountNumber", Лев(Объект.СчетВыписки.НомерСчета, 22));
	ПараметрыЗапроса.Вставить("id", IDВыписки);
	ПараметрыЗапроса.Вставить("page", НомерСтраницы);
	
	МассивЗаписей = МенеджерОбработки.ВыполнитьМетодСервиса("api/statement////", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
	
	СуммарныеДанные = МенеджерОбработки.ВыполнитьМетодСервиса("api/statement/summary/", ПараметрыЗапроса, Режим, Токен, Объект.ЗапускатьРеальныйБанк);
	ШапкаВыписки = СуммарныеДанные["GlobalSummary"];
	ДанныепоДням = СуммарныеДанные["DailySummaries"]; 
	
	Если ШапкаВыписки.Количество() > 0 Тогда 
		
		Объект.OutAmountBase   = ШапкаВыписки["OutAmountBase"];
		Объект.OutAmount       = ШапкаВыписки["OutAmount"];				
		Объект.InAmountBase    = ШапкаВыписки["InAmountBase"];			
		Объект.InAmount        = ШапкаВыписки["InAmount"];
		Объект.CreditSum       = ШапкаВыписки["CreditSum"];			
		Объект.DebitSum        = ШапкаВыписки["DebitSum"];
		Объект.StartDate       = ШапкаВыписки["StartDate"];
		Объект.InRate          = ШапкаВыписки["InRate"];
		Объект.AccountNumber   = ШапкаВыписки["AccountNumber"];
		Объект.PeriodEndDate   = ШапкаВыписки["PeriodEndDate"];
		Объект.Currency        = ШапкаВыписки["Currency"];
		Объект.EndDate         = ШапкаВыписки["EndDate"];
		Объект.PeriodStartDate = ШапкаВыписки["PeriodStartDate"];
		Объект.OutRate         = ШапкаВыписки["OutRate"];
		
	КонецЕсли;	
	
	
	Если ДанныепоДням.Количество() > 0 Тогда
		
		ТаблицаОстатковПоДням = Новый ТаблицаЗначений;  
		ТаблицаОстатковПоДням.Колонки.Добавить("BalanceBase", Новый ОписаниеТипов("Строка"));
		ТаблицаОстатковПоДням.Колонки.Добавить("DebitSum", Новый ОписаниеТипов("Строка"));
		ТаблицаОстатковПоДням.Колонки.Добавить("Balance", Новый ОписаниеТипов("Строка"));
		ТаблицаОстатковПоДням.Колонки.Добавить("Date", Новый ОписаниеТипов("Дата"));
		ТаблицаОстатковПоДням.Колонки.Добавить("Rate", Новый ОписаниеТипов("Строка"));
		ТаблицаОстатковПоДням.Колонки.Добавить("CreditSum", Новый ОписаниеТипов("Строка"));
		ТаблицаОстатковПоДням.Колонки.Добавить("EntryCount", Новый ОписаниеТипов("Строка"));
		
		Для Каждого Элемент ИЗ ДанныепоДням Цикл			
			НоваяСтрока = ТаблицаОстатковПоДням.Добавить();
			
			НоваяСтрока.BalanceBase = Элемент.Получить("BalanceBase");
			НоваяСтрока.DebitSum    = Элемент.Получить("DebitSum");
			НоваяСтрока.Balance     = Элемент.Получить("Balance");
			НоваяСтрока.Date        = ДельтаНСФ.ПереводВДату(Элемент.Получить("Date"));
			НоваяСтрока.Rate        = Элемент.Получить("Rate");
			НоваяСтрока.CreditSum   = Элемент.Получить("CreditSum");
			НоваяСтрока.EntryCount  = Элемент.Получить("EntryCount");			
		КонецЦикла;
	КонецЕсли;		
	
	Объект.Выписка.Очистить();
	
	Если Не МассивЗаписей = Неопределено Тогда 
		Если МассивЗаписей.Количество() > 0 Тогда 
			
			Для Каждого ЭлементМассива ИЗ МассивЗаписей Цикл
				
				НоваяСтрокаТЧ = Объект.Выписка.Добавить();
				
				НоваяСтрокаТЧ.BeneficiaryName                    = ЭлементМассива.Получить("BeneficiaryDetails").Получить("Name");
				НоваяСтрокаТЧ.BeneficiaryBankName                = ЭлементМассива.Получить("BeneficiaryDetails").Получить("BankName");
				НоваяСтрокаТЧ.BeneficiaryAccountNumber           = ЭлементМассива.Получить("BeneficiaryDetails").Получить("AccountNumber");
				НоваяСтрокаТЧ.BeneficiaryBankCode                = ЭлементМассива.Получить("BeneficiaryDetails").Получить("BankCode");
				НоваяСтрокаТЧ.BeneficiaryInn                     = ЭлементМассива.Получить("BeneficiaryDetails").Получить("Inn");	
				НоваяСтрокаТЧ.SenderName                         = ЭлементМассива.Получить("SenderDetails").Получить("Name");
				НоваяСтрокаТЧ.SenderBankName                     = ЭлементМассива.Получить("SenderDetails").Получить("BankName");
				НоваяСтрокаТЧ.SenderAccountNumber                = ЭлементМассива.Получить("SenderDetails").Получить("AccountNumber");
				НоваяСтрокаТЧ.SenderBankCode                     = ЭлементМассива.Получить("SenderDetails").Получить("BankCode");
				НоваяСтрокаТЧ.SenderInn                          = ЭлементМассива.Получить("SenderDetails").Получить("Inn");						
				НоваяСтрокаТЧ.DocumentActualDate                 = ЭлементМассива.Получить("DocumentActualDate");				
				НоваяСтрокаТЧ.DocumentBeneficiaryInstitution     = ЭлементМассива.Получить("DocumentBeneficiaryInstitution");
				НоваяСтрокаТЧ.DocumentBranch                     = ЭлементМассива.Получить("DocumentBranch");
				НоваяСтрокаТЧ.DocumentCorrespondentAccountNumber = ЭлементМассива.Получить("DocumentCorrespondentAccountNumber");
				НоваяСтрокаТЧ.DocumentCorrespondentBankCode      = ЭлементМассива.Получить("DocumentCorrespondentBankCode");
				НоваяСтрокаТЧ.DocumentCorrespondentBankName      = ЭлементМассива.Получить("DocumentCorrespondentBankName");
				НоваяСтрокаТЧ.DocumentDepartment                 = ЭлементМассива.Получить("DocumentDepartment");
				НоваяСтрокаТЧ.DocumentDestinationAmount          = ЭлементМассива.Получить("DocumentDestinationAmount");
				НоваяСтрокаТЧ.DocumentDestinationCurrency        = ЭлементМассива.Получить("DocumentDestinationCurrency");
				НоваяСтрокаТЧ.DocumentExpiryDate                 = ЭлементМассива.Получить("DocumentExpiryDate");
				НоваяСтрокаТЧ.DocumentIntermediaryInstitution    = ЭлементМассива.Получить("DocumentIntermediaryInstitution");
				НоваяСтрокаТЧ.DocumentInformation                = ЭлементМассива.Получить("DocumentInformation");
				НоваяСтрокаТЧ.DocumentKey                        = ЭлементМассива.Получить("DocumentKey");
				НоваяСтрокаТЧ.DocumentNomination                 = ЭлементМассива.Получить("DocumentNomination");
				НоваяСтрокаТЧ.DocumentPayee                      = ЭлементМассива.Получить("DocumentPayee");
				НоваяСтрокаТЧ.DocumentProductGroup               = ЭлементМассива.Получить("DocumentProductGroup");
				НоваяСтрокаТЧ.DocumentRate                       = ЭлементМассива.Получить("DocumentRate");
				НоваяСтрокаТЧ.DocumentRateLimit                  = ЭлементМассива.Получить("DocumentRateLimit");
				НоваяСтрокаТЧ.DocumentReceiveDate                = ЭлементМассива.Получить("DocumentReceiveDate");
				НоваяСтрокаТЧ.DocumentRegistrationRate           = ЭлементМассива.Получить("DocumentRegistrationRate");
				НоваяСтрокаТЧ.DocumentSenderInstitution          = ЭлементМассива.Получить("DocumentSenderInstitution");
				НоваяСтрокаТЧ.DocumentSourceAmount               = ЭлементМассива.Получить("DocumentSourceAmount");
