		ПараметрыОтбора.Вставить("Поле", Стр.Имя);
		
		ПолеВыбрано = ВыбранныеПоля.НайтиСтроки(ПараметрыОтбора);
		
		Если Не ПолеВыбрано.Количество() > 0 Тогда 		
			ТаблицаExcel.Колонки.Удалить(Стр.Имя);
		КонецЕсли;
		
	КонецЦикла;
	
	// создаем txcel
	Попытка
		Excel = Новый COMОбъект("Excel.Application"); 
	Исключение
		Возврат ОписаниеОшибки();
	КонецПопытки;
	
	//Excel.Visible = Истина;
	Книга = Excel.WorkBooks.Add();
