	ТекСтрока.Проведен = ПолучитьПроведениеНаСервере(ДокПлатежа);
	ТекСтрока.Видимость = ОпределитьВидимость(ТекСтрока.СозданныйДокумент, ТекСтрока.Контрагент, ТекСтрока.ДоговорКонтрагента, ТекСтрока.СчетКонтрагента, "Входящие");
	
КонецПроцедуры

