&НаСервереБезКонтекста
Функция ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданных)

	Позиция	= Найти(ИмяМетаданных,".");
	Если Позиция = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТипДанных	= Лев(ИмяМетаданных, Позиция - 1);
	Имя			= Сред(ИмяМетаданных, Позиция + 1);

	Если ТипДанных = "РегистрСведений" Тогда
		Возврат РегистрыСведений[Имя].СоздатьНаборЗаписей();
	ИначеЕсли ТипДанных = "РегистрНакопления" Тогда
		Возврат РегистрыНакопления[Имя].СоздатьНаборЗаписей();
	ИначеЕсли ТипДанных = "РегистрБухгалтерии" Тогда
		Возврат РегистрыБухгалтерии[Имя].СоздатьНаборЗаписей();
	ИначеЕсли ТипДанных = "РегистрРасчета" Тогда
		Возврат РегистрыРасчета[Имя].СоздатьНаборЗаписей();
	ИначеЕсли ТипДанных = "Последовательность" Тогда
		Возврат Последовательности[Имя].СоздатьНаборЗаписей();
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции // ПолучитьНаборЗаписиПоИмениМетаданных()

&НаСервереБезКонтекста
Процедура ПроизвестиПроизвольнуюРегистрациюОбъектаНаСервере(УзелОбмена, ВключаяДвиженияДокументов, МассивДанных, СоответствиеИменМетаданных)

	Для каждого ЭлементДанных Из МассивДанных Цикл
		Ссылка			= ЭлементДанных.СсылкаНаОбъект;
		ИмяМетаданных	= ЭлементДанных.ИмяМетаданных;
		КлючНабораЗаписей	= ЭлементДанных.КлючНабораЗаписей;
		СоответствиеИменМетаданных[ИмяМетаданных] = Истина;
		Если ЗначениеЗаполнено(Ссылка) Тогда
			НаборЗаписей	= ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданных);
			Если НаборЗаписей = Неопределено Тогда
				//Ссылочный тип данных
				ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, Ссылка);
				Если ВключаяДвиженияДокументов И Лев(ИмяМетаданных, 9) = "Документ." Тогда
					МетаданныеОбъекта	= Ссылка.Метаданные();
					СоставПланаОбмена	= УзелОбмена.Метаданные().Состав;
					Для каждого МетаданныеДвижения Из МетаданныеОбъекта.Движения Цикл
						Если СоставПланаОбмена.Содержит(МетаданныеДвижения) Тогда
							ИмяМетаданныхДвижения	= МетаданныеДвижения.ПолноеИмя();
							НаборЗаписей	= ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданныхДвижения);
							НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
							ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, НаборЗаписей);
							СоответствиеИменМетаданных[ИмяМетаданныхДвижения] = Истина;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Иначе
				//Регистр с подчинением регистратору
				НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
				ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, НаборЗаписей);
			КонецЕсли; 
		ИначеЕсли ЗначениеЗаполнено(КлючНабораЗаписей) Тогда
			//Может быть только у регистра сведений с независимой записью
			НаборЗаписей	= ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданных);
			НаборЗаписей.Отбор	= ЗначениеИзСтрокиВнутр(КлючНабораЗаписей);
			ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, НаборЗаписей);
		КонецЕсли; 
	КонецЦикла; 

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПроизвестиПроизвольнуюОтменуРегистрацииОбъектаНаСервере(УзелОбмена, ВключаяДвиженияДокументов, МассивДанных, СоответствиеИменМетаданных)

	Для каждого ЭлементДанных Из МассивДанных Цикл
		Ссылка			= ЭлементДанных.СсылкаНаОбъект;
		ИмяМетаданных	= ЭлементДанных.ИмяМетаданных;
		КлючНабораЗаписей	= ЭлементДанных.КлючНабораЗаписей;
		СоответствиеИменМетаданных[ИмяМетаданных] = Истина;
		Если ЗначениеЗаполнено(Ссылка) Тогда
			НаборЗаписей	= ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданных);
			Если НаборЗаписей = Неопределено Тогда
				//Ссылочный тип данных
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, Ссылка);
				Если ВключаяДвиженияДокументов И Лев(ИмяМетаданных, 9) = "Документ." Тогда
					МетаданныеОбъекта	= Ссылка.Метаданные();
					СоставПланаОбмена	= УзелОбмена.Метаданные().Состав;
					Для каждого МетаданныеДвижения Из МетаданныеОбъекта.Движения Цикл
						Если СоставПланаОбмена.Содержит(МетаданныеДвижения) Тогда
							ИмяМетаданныхДвижения	= МетаданныеДвижения.ПолноеИмя();
							НаборЗаписей	= ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданныхДвижения);
							НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
							ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, НаборЗаписей);
							СоответствиеИменМетаданных[ИмяМетаданныхДвижения] = Истина;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			Иначе
				//Регистр с подчинением регистратору
				НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, НаборЗаписей);
			КонецЕсли;

		ИначеЕсли ЗначениеЗаполнено(КлючНабораЗаписей) Тогда
			//Может быть только у регистра сведений с независимой записью
			НаборЗаписей	= ПолучитьНаборЗаписиПоИмениМетаданных(ИмяМетаданных);
			НаборЗаписей.Отбор	= ЗначениеИзСтрокиВнутр(КлючНабораЗаписей);
			ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, НаборЗаписей);
		КонецЕсли;
	
	КонецЦикла; 
	

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеОбменаНаКлиенте(СтрокаДерева)
	Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;
	ОчиститьОбъектыРегистрацииИОбновитьКоличествоНаКлиенте(СтрокаДерева);
	МассивПоказыватьОбъекты	= Новый Массив();
	ЕстьВыключенные	= Ложь;
	КоличествоПолучаемыхОбъектов	= 0;
	СформироватьМассивПоказыватьОбъектыРекурсивно(СтрокаДерева, МассивПоказыватьОбъекты, КоличествоПолучаемыхОбъектов, ЕстьВыключенные);
	Если МассивПоказыватьОбъекты.Количество() = 0 Тогда
		Возврат;
	ИначеЕсли СтрокаДерева = ДанныеОбмена.ПолучитьЭлементы()[0] И НЕ ЕстьВыключенные Тогда
		//Для корневой строки в случае включенного показа для всех объектов метаданных получаем все изменения для узла
		МассивПоказыватьОбъекты	= Неопределено;
	КонецЕсли;

	Получено	= 0;
	Пояснение	= "";

	Пока ПоказатьОбъекты(МассивПоказыватьОбъекты, 500, Пояснение) Цикл
		Получено	= Получено + 500;
		Если КоличествоПолучаемыхОбъектов = 0 Тогда
			Состояние("Получение данных о зарегистрированных объектах: "+Строка(Получено) + "...",,Пояснение);
		Иначе

			Прогресс	= Окр((Получено / КоличествоПолучаемыхОбъектов) * 100);
			Прогресс	= ?(Прогресс > 100, 100, Прогресс);

			Состояние("Получение данных о зарегистрированных объектах: "+Строка(Получено) + "...", Прогресс, Пояснение);

		КонецЕсли;
		ОбработкаПрерыванияПользователя();
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИменМетаданных, МассивОбъектов, КоличествоОбъектов)
	
	КоличествоМетаданных	= 0;
	КоличествоОбъектов		= 0;
	СоответствиеМетаданных	= Новый Соответствие();
    ВременныйМассивСтрокСОбъектами	= Новый Массив();
	
	КореньДерева	= ДанныеОбмена.ПолучитьЭлементы()[0];
	Для каждого СтрокаПервогоУровня Из КореньДерева.ПолучитьЭлементы() Цикл
		КоличествоМетаданных	= КоличествоМетаданных + СтрокаПервогоУровня.ПолучитьЭлементы().Количество();
	КонецЦикла;
	Для каждого ИдентификаторСтроки Из Элементы.ДанныеОбмена.ВыделенныеСтроки Цикл
		СтрокаДерева	= ДанныеОбмена.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если СтрокаДерева.Уровень = 0 Тогда
			МассивИменМетаданных = Неопределено;
			МассивОбъектов = Неопределено;
			Возврат;
		ИначеЕсли СтрокаДерева.Уровень = 1 Тогда
			Для каждого СтрокаВторогоУровня Из СтрокаДерева.ПолучитьЭлементы() Цикл
				Ид	= СтрокаВторогоУровня.ПолучитьИдентификатор();
				Если МассивИменМетаданных.Найти(Ид) = Неопределено Тогда
					МассивИменМетаданных.Добавить(Ид);
					КоличествоОбъектов	= КоличествоОбъектов + СтрокаВторогоУровня.Количество;
					КоличествоМетаданных	= КоличествоМетаданных - 1;
					СоответствиеМетаданных[Ид]	= Истина;
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли СтрокаДерева.Уровень = 2 Тогда
			Ид	= СтрокаДерева.ПолучитьИдентификатор();
			Если МассивИменМетаданных.Найти(Ид) = Неопределено Тогда
				МассивИменМетаданных.Добавить(Ид);
				КоличествоОбъектов	= КоличествоОбъектов + СтрокаДерева.Количество;
				КоличествоМетаданных	= КоличествоМетаданных - 1;
				СоответствиеМетаданных[Ид]	= Истина;
			КонецЕсли;
		ИначеЕсли СтрокаДерева.Уровень = 3 Тогда
			Если МассивОбъектов = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			//Отмеченные объекты будем обрабатывать позже
			ВременныйМассивСтрокСОбъектами.Добавить(СтрокаДерева);
		Иначе
			Продолжить;
		КонецЕсли;
	КонецЦикла;

	Если МассивОбъектов <> Неопределено Тогда
		Для каждого СтрокаДерева Из ВременныйМассивСтрокСОбъектами Цикл
			Если СоответствиеМетаданных[СтрокаДерева.ПолучитьРодителя().ПолучитьИдентификатор()] <> Неопределено Тогда
				//Отмечены все метаданные (первый или второй уровень), поэтому объект не учитываем
				Продолжить;
			КонецЕсли;
			МассивОбъектов.Добавить(СтрокаДерева.ПолучитьИдентификатор());
			КоличествоОбъектов	= КоличествоОбъектов + 1;
		КонецЦикла;
	КонецЕсли;

	Если КоличествоМетаданных = 0 Тогда
		//Включены все объекты метаданных
		МассивИменМетаданных	= Неопределено;
		МассивОбъектов			= Неопределено;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СформироватьМассивПоказыватьОбъектыРекурсивно(СтрокаДерева, Массив, Количество, ЕстьВыключенные)
	Если СтрокаДерева.Уровень < 2 Тогда
		Для каждого ПодСтрока Из СтрокаДерева.ПолучитьЭлементы() Цикл
			СформироватьМассивПоказыватьОбъектыРекурсивно(ПодСтрока, Массив, Количество, ЕстьВыключенные);
		КонецЦикла;
	ИначеЕсли  СтрокаДерева.Уровень > 2 Тогда
		Возврат;
	КонецЕсли;
	Если СтрокаДерева.ПоказыватьОбъекты Тогда
		Массив.Добавить(СтрокаДерева.ИмяДляЗапроса);
		Количество	= Количество + СтрокаДерева.Количество;
	Иначе
		ЕстьВыключенные = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОбъектыРегистрацииИОбновитьКоличествоНаКлиенте(СтрокаДерева)
 	ОчиститьОбъектыРегистрацииВДанныхОбменаКлиент(СтрокаДерева);
 	ОбновитьКоличествоЗарегистрированныхДляСтрокиДереваКлиент(СтрокаДерева);
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьОбъектыРегистрацииВДанныхОбменаКлиент(СтрокаДерева, ОчищатьПоказыватьОбъекты = Ложь)
	Если СтрокаДерева.Уровень < 2 Тогда
		Для каждого ПодСтрокаДерева Из СтрокаДерева.ПолучитьЭлементы() Цикл
			ОчиститьОбъектыРегистрацииВДанныхОбменаКлиент(ПодСтрокаДерева, ОчищатьПоказыватьОбъекты);
		КонецЦикла;
	Иначе
		СтрокаДерева.ПолучитьЭлементы().Очистить();
		Если ОчищатьПоказыватьОбъекты Тогда
			СтрокаДерева.ПоказыватьОбъекты	= Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьКоличествоЗарегистрированныхДляСтрокиДереваКлиент(СтрокаДерева)

	Если СтрокаДерева.Уровень < 2 Тогда
		Для каждого ПодСтрока Из СтрокаДерева.ПолучитьЭлементы() Цикл
			ОбновитьКоличествоЗарегистрированныхДляСтрокиДереваКлиент(ПодСтрока);
		КонецЦикла;
		Возврат;
	ИначеЕсли СтрокаДерева.Уровень > 2 Тогда
		РабочаяСтрока	= СтрокаДерева;
		Пока РабочаяСтрока.Уровень > 2 Цикл
			РабочаяСтрока	= РабочаяСтрока.ПолучитьРодителя();
		КонецЦикла; 
	Иначе
		РабочаяСтрока	= СтрокаДерева;
	КонецЕсли; 
	
	СтароеКоличествоЗарегистрированныхОбъектов = РабочаяСтрока.Количество;

	КоличествоОбъектовСРегистрацией = ПолучитьКоличествоЗарегистрированныхОбъектов(УзелОбмена, РабочаяСтрока.ИмяДляЗапроса);
	РабочаяСтрока.Количество = КоличествоОбъектовСРегистрацией;
	ОбновитьСтрокуДереваНаКлиенте(РабочаяСтрока);
	
	Родитель = РабочаяСтрока.ПолучитьРодителя();

	Пока Родитель <> Неопределено Цикл

		Родитель.Количество = Родитель.Количество - СтароеКоличествоЗарегистрированныхОбъектов + КоличествоОбъектовСРегистрацией;		
		ОбновитьСтрокуДереваНаКлиенте(Родитель);
		Родитель = Родитель.ПолучитьРодителя();

	КонецЦикла;	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьКлючФормыНаСервере(КлючЗаписиСтрокой, ИмяРегистра)
	КлючЗаписи	= ЗначениеИзСтрокиВнутр(КлючЗаписиСтрокой);
	СтруктураОтбора	= Новый Структура();
	Для каждого ЭлементОтбора Из КлючЗаписи Цикл
		СтруктураОтбора.Вставить(ЭлементОтбора.ПутьКДанным, ЭлементОтбора.Значение);
	КонецЦикла; 

	КлючЗаписи	= РегистрыСведений[ИмяРегистра].СоздатьКлючЗаписи(СтруктураОтбора);
	
	Возврат КлючЗаписи;

КонецФункции

&НаСервере
Процедура ОчиститьТретийУровень(ТекущиеДанные)
	Если ТекущиеДанные.Уровень = 3 Тогда
		Коллекция	= ТекущиеДанные.ПолучитьРодителя().ПолучитьЭлементы();
		Индекс		= Коллекция.Индекс(ТекущиеДанные);
		Коллекция.Удалить(Индекс);
	ИначеЕсли  ТекущиеДанные.Уровень = 2 Тогда
		Коллекция	= ТекущиеДанные.ПолучитьЭлементы();
		Коллекция.Очистить();
	ИначеЕсли  ТекущиеДанные.Уровень < 2 Тогда
		Для каждого ПодСтрока Из ТекущиеДанные.ПолучитьЭлементы() Цикл
			ОчиститьТретийУровень(ПодСтрока);
		КонецЦикла; 
	КонецЕсли; 

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗарегистрироватьОбъектыНаСервере(УзелОбмена, ИмяМетаданных)

	Если Не ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;

	Если ИмяМетаданных = Неопределено Тогда
		//Удаление всех регистраций объектов
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, Неопределено);
	ИначеЕсли ТипЗнч(ИмяМетаданных) = Тип("Строка") И ЗначениеЗаполнено(ИмяМетаданных) Тогда
		ОбъектРегистрации	= Метаданные.НайтиПоПолномуИмени(ИмяМетаданных);
		ПланыОбмена.ЗарегистрироватьИзменения(УзелОбмена, ОбъектРегистрации);
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция УдалитьРегистрациюИзмененийНаСервере(УзелОбмена, ИмяМетаданных, Ссылка = Неопределено, КлючНабораЗаписей = Неопределено, ЭтоУдаление = Ложь)

	Если Не ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат Ложь;
	КонецЕсли;

	Если ИмяМетаданных = Неопределено Тогда
		//Удаление всех регистраций объектов
		ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, Неопределено);
	ИначеЕсли ТипЗнч(ИмяМетаданных) = Тип("Строка") И ЗначениеЗаполнено(ИмяМетаданных) Тогда
		Если Ссылка = Неопределено И КлючНабораЗаписей = Неопределено Тогда
			//Удаление регистраций объекта метаданных
			ОбъектРегистрации	= Метаданные.НайтиПоПолномуИмени(ИмяМетаданных);
			ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ОбъектРегистрации);
		Иначе
			ОбъектРегистрации	= Метаданные.НайтиПоПолномуИмени(ИмяМетаданных);
			Если Метаданные.РегистрыСведений.Содержит(ОбъектРегистрации) Тогда
				ЭтоРегистр			= Истина;
				НаборЗаписей		= РегистрыСведений[ОбъектРегистрации.Имя].СоздатьНаборЗаписей();
			ИначеЕсли Метаданные.РегистрыНакопления.Содержит(ОбъектРегистрации) Тогда
				ЭтоРегистр			= Истина;
				НаборЗаписей		= РегистрыНакопления[ОбъектРегистрации.Имя].СоздатьНаборЗаписей();
			ИначеЕсли Метаданные.РегистрыБухгалтерии.Содержит(ОбъектРегистрации) Тогда
				ЭтоРегистр			= Истина;
				НаборЗаписей		= РегистрыБухгалтерии[ОбъектРегистрации.Имя].СоздатьНаборЗаписей();
			ИначеЕсли Метаданные.РегистрыРасчета.Содержит(ОбъектРегистрации) Тогда
				ЭтоРегистр			= Истина;
				НаборЗаписей		= РегистрыРасчета[ОбъектРегистрации.Имя].СоздатьНаборЗаписей();
			ИначеЕсли Метаданные.Последовательности.Содержит(ОбъектРегистрации) Тогда
				ЭтоРегистр			= Истина;
				НаборЗаписей		= Последовательности[ОбъектРегистрации.Имя].СоздатьНаборЗаписей();
			Иначе
				ЭтоРегистр			= Ложь;
				НаборЗаписей		= Неопределено;
			КонецЕсли; 
			
			Если ЭтоРегистр Тогда
				Если ЗначениеЗаполнено(КлючНабораЗаписей) Тогда
					НаборЗаписей.Отбор	= ЗначениеИзСтрокиВнутр(КлючНабораЗаписей);
					ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, НаборЗаписей);
				ИначеЕсли  ЗначениеЗаполнено(Ссылка) Тогда
					НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
					ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, НаборЗаписей);
				Иначе
					Возврат Ложь;
				КонецЕсли;
			ИначеЕсли ЗначениеЗаполнено(Ссылка) Тогда
				Если ЭтоУдаление Тогда
					ОбъектРегистрации	= Новый УдалениеОбъекта(Ссылка);
				Иначе
					ОбъектРегистрации	= Ссылка;
				КонецЕсли;
				ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ОбъектРегистрации);
			Иначе
				Возврат Ложь;
			КонецЕсли;
		КонецЕсли;
	Иначе
		Возврат Ложь;
	КонецЕсли;

	Возврат Истина;

КонецФункции

&НаСервере
Процедура УстановитьЗаголовокФормы()
	
	Если ЗначениеЗаполнено(УзелОбмена) Тогда
		МетаданныеОбъекта	= УзелОбмена.Метаданные();
		Заголовок	= "Монитор состояния узла """ +Строка(УзелОбмена) + """ плана обмена """ + ?(ЗначениеЗаполнено(МетаданныеОбъекта.Синоним), МетаданныеОбъекта.Синоним, МетаданныеОбъекта.Имя) +"""";
	Иначе
		Заголовок	= "Узел обмена не выбран";
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПриИзмененииУзлаОбменаСервер()

	УстановитьЗаголовокФормы();
	Если ЗначениеЗаполнено(УзелОбмена) Тогда
		МетаданныеОбъекта	= УзелОбмена.Метаданные();
		ЭтотУзел	= (УзелОбмена = ПланыОбмена[МетаданныеОбъекта.Имя].ЭтотУзел());

//		Элементы.ОтображатьКоличествоЗарегистрированныхОбъектов.Видимость	= Не ЭтотУзел;
		Элементы.ДанныеОбмена.КонтекстноеМеню.Доступность	= НЕ ЭтотУзел;

		Если ПравоДоступа("Редактирование", МетаданныеОбъекта) Тогда
			Элементы.Редактировать.Видимость = Истина;
		Иначе
			Элементы.Редактировать.Видимость = Ложь;
		КонецЕсли; 
	Иначе
		Элементы.Редактировать.Видимость = Ложь;

//		Элементы.ОтображатьКоличествоЗарегистрированныхОбъектов.Видимость	= Ложь;
		Элементы.ДанныеОбмена.КонтекстноеМеню.Доступность	= Ложь;
	КонецЕсли;

	ЗаполнитьДеревоОбъектов();

КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииУзлаОбменаКлиент()
	РазвернутьДерево();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоОбъектов()

	ЭлементыДерева	= ДанныеОбмена.ПолучитьЭлементы();
	
	ЭлементыДерева.Очистить();
	//Создаем корневой уровень

	Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли; 

	НоваяСтрока = ЭлементыДерева.Добавить();
	НоваяСтрока.Имя 			= Метаданные.Имя;
	НоваяСтрока.Представление	= ?(ЗначениеЗаполнено(Метаданные.Синоним), Метаданные.Синоним, Метаданные.Имя);
	НоваяСтрока.Картинка 		= 0;
	НоваяСтрока.Уровень			= 0;
	НоваяСтрока.Авторегистрация	= 2;

    СоответствиеСоставаПланаОбмена	= Новый Соответствие();
	МетаданныеПланаОбмена	= УзелОбмена.Метаданные();
	Для каждого ЭлементСостава Из МетаданныеПланаОбмена.Состав Цикл
		СоответствиеСоставаПланаОбмена[ЭлементСостава.Метаданные] = ?(ЭлементСостава.АвтоРегистрация = АвтоРегистрацияИзменений.Разрешить, Истина, Ложь);
	КонецЦикла;
	
	СоответствиеСтрок	= Новый Соответствие();
	
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "Константы", "Константы", СоответствиеСоставаПланаОбмена, 1, 2, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "Справочники", "Справочники", СоответствиеСоставаПланаОбмена, 3, 4, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "Последовательности", "Последовательности", СоответствиеСоставаПланаОбмена, 5, 6, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "Документы", "Документы", СоответствиеСоставаПланаОбмена, 7, 8, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "ПланыВидовХарактеристик", "Планы видов характеристик", СоответствиеСоставаПланаОбмена, 9, 10, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "ПланыСчетов", "Планы счетов", СоответствиеСоставаПланаОбмена, 11, 12, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "ПланыВидовРасчета", "Планы видов расчета", СоответствиеСоставаПланаОбмена, 13, 14, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "РегистрыСведений", "Регистры сведений", СоответствиеСоставаПланаОбмена, 15, 16, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "РегистрыНакопления", "Регистры накопления", СоответствиеСоставаПланаОбмена, 17, 18, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "РегистрыБухгалтерии", "Регистры бухгалтерии", СоответствиеСоставаПланаОбмена, 19, 20, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "РегистрыРасчета", "Регистры расчета", СоответствиеСоставаПланаОбмена, 21, 22, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "БизнесПроцессы", "Бизнес-процессы", СоответствиеСоставаПланаОбмена, 23, 24, СоответствиеСтрок);
	НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(НоваяСтрока, "Задачи", "Задачи", СоответствиеСоставаПланаОбмена, 26, 26, СоответствиеСтрок);
	
	СоответствиеСтрокДереваМетаданным	= Новый ФиксированноеСоответствие(СоответствиеСтрок);

	ОбновитьСтрокуДереваНаСервере(НоваяСтрока);

КонецПроцедуры

&НаСервере
Функция ЗаполнитьДеревоОбъектов_КоллекцияМетаданных(Родитель, ИмяКоллекцииМетаданных, Представление, СоответствиеПланаОбмена, Картинка, КартинкаОбъекта, СоответствиеСтрок)

	Таб	= Новый ТаблицаЗначений();
	Таб.Колонки.Добавить("Метаданные");
	Таб.Колонки.Добавить("ПолеСортировки");
	Таб.Колонки.Добавить("Авторегистрация");

	Для каждого ОбъектМетаданных Из Метаданные[ИмяКоллекцииМетаданных] Цикл
		Если СоответствиеПланаОбмена[ОбъектМетаданных] <> Неопределено Тогда
			НоваяСтрока	= Таб.Добавить();
			НоваяСтрока.Метаданные	= ОбъектМетаданных;
			НоваяСтрока.ПолеСортировки	= ОбъектМетаданных.Синоним;
			НоваяСтрока.Авторегистрация	= СоответствиеПланаОбмена[ОбъектМетаданных];
		КонецЕсли;
	КонецЦикла;

	Если Таб.Количество() = 0 Тогда
		Возврат 0;
	КонецЕсли;

	Таб.Сортировать("ПолеСортировки Возр");

	НоваяСтрока					= Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Имя				= ИмяКоллекцииМетаданных;
	НоваяСтрока.Представление	= Представление;
	НоваяСтрока.Картинка		= Картинка;
	НоваяСтрока.Уровень			= 1;
 	НоваяСтрока.Авторегистрация	= 2;
	
	Для каждого СтрокаТаб Из Таб Цикл
		НоваяСтрока.Количество	= НоваяСтрока.Количество + ЗаполнитьДеревоОбъектов_ОбъектМетаданных(НоваяСтрока, СтрокаТаб.Метаданные, КартинкаОбъекта, СтрокаТаб.Авторегистрация, СоответствиеСтрок);
	КонецЦикла;

	ОбновитьСтрокуДереваНаСервере(НоваяСтрока);

	Возврат НоваяСтрока.Количество;
	
КонецФункции

&НаСервере
Функция ЗаполнитьДеревоОбъектов_ОбъектМетаданных(Родитель, МетаданныеОбъекта, КартинкаОбъекта, Авторегистрация, СоответствиеСтрок)

	НоваяСтрока					= Родитель.ПолучитьЭлементы().Добавить();
	НоваяСтрока.Имя				= МетаданныеОбъекта.Имя;
	НоваяСтрока.ИмяДляЗапроса	= МетаданныеОбъекта.ПолноеИмя();
	НоваяСтрока.Представление	= ?(ЗначениеЗаполнено(МетаданныеОбъекта.Синоним), МетаданныеОбъекта.Синоним, МетаданныеОбъекта.Имя);
	НоваяСтрока.Картинка		= КартинкаОбъекта;
	НоваяСтрока.Уровень			= 2;
	НоваяСтрока.Авторегистрация	= ?(Авторегистрация, 1, 0);

	СоответствиеСтрок[МетаданныеОбъекта.ПолноеИмя()]	= НоваяСтрока.ПолучитьИдентификатор();

	НоваяСтрока.Количество	= ПолучитьКоличествоЗарегистрированныхОбъектов(УзелОбмена, НоваяСтрока.ИмяДляЗапроса);

	ОбновитьСтрокуДереваНаСервере(НоваяСтрока);

	Возврат НоваяСтрока.Количество;

КонецФункции

&НаСервере
Процедура ОчиститьОбъектыРегистрацииВДанныхОбмена(ИдентификаторИлиСтрокаДерева, ОчищатьПоказыватьОбъекты = Ложь)

	Если ТипЗнч(ИдентификаторИлиСтрокаДерева) = Тип("Число") Тогда
		СтрокаДерева	= ДанныеОбмена.НайтиПоИдентификатору(ИдентификаторИлиСтрокаДерева);
	Иначе
		СтрокаДерева	= ИдентификаторИлиСтрокаДерева;
	КонецЕсли;

	Если СтрокаДерева.Уровень < 2 Тогда
		Для каждого ПодСтрокаДерева Из СтрокаДерева.ПолучитьЭлементы() Цикл
			ОчиститьОбъектыРегистрацииВДанныхОбмена(ПодСтрокаДерева, ОчищатьПоказыватьОбъекты);
		КонецЦикла;
	Иначе
		СтрокаДерева.ПолучитьЭлементы().Очистить();
		Если ОчищатьПоказыватьОбъекты Тогда
			СтрокаДерева.ПоказыватьОбъекты	= Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПоказатьОбъекты(МассивИменМетаданных, Знач РазмерРазовойВыборки = 0, Пояснение = "")

	Если РазмерРазовойВыборки = 0 Тогда
		РазмерРазовойВыборки = 500;
	КонецЕсли;
	Если АдресВременногоХранилищаВыборкиИзменений = "" Тогда

		Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
			Возврат Ложь;
		ИначеЕсли МассивИменМетаданных <> Неопределено И
				  МассивИменМетаданных.Количество() = 0 Тогда
			Возврат Ложь;
		КонецЕсли;

		Если МассивИменМетаданных = Неопределено Тогда
			КореньДерева	= ДанныеОбмена.ПолучитьЭлементы()[0]; //Корень дерева
		 	ОчиститьОбъектыРегистрацииВДанныхОбмена(КореньДерева);
		Иначе
			ФильтрМетаданных	= Новый Массив();
			Для каждого ПолноеИмяМетаданного Из МассивИменМетаданных Цикл
				ИдентификаторРодителя	= СоответствиеСтрокДереваМетаданным[ПолноеИмяМетаданного];
			 	СтрокаРодитель	= ДанныеОбмена.НайтиПоИдентификатору(ИдентификаторРодителя);
			 	ОчиститьОбъектыРегистрацииВДанныхОбмена(СтрокаРодитель);
				ФильтрМетаданных.Добавить(Метаданные.НайтиПоПолномуИмени(ПолноеИмяМетаданного));
			КонецЦикла;
		КонецЕсли;

		ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(УзелОбмена, УзелОбмена.НомерОтправленного + 1, ФильтрМетаданных);//Выбираем все изменения

	Иначе

		ВыборкаИзменений	= ПолучитьИзВременногоХранилища(АдресВременногоХранилищаВыборкиИзменений);

	КонецЕсли;

	КоличествоОбработанныхОбъектов = 0;
	ВыборкаИзмененийЗакончена	= Истина;
	ТипДанныхУдаления = Тип("УдалениеОбъекта");

	Пока ВыборкаИзменений.Следующий() Цикл

		// зарегистрированный объект
		Данные = ВыборкаИзменений.Получить();

		Если Данные = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ЭтоУдаление = (ТипДанныхУдаления = ТипЗнч(Данные));

		Если ЭтоУдаление Тогда
			МетаданныеОбъекта = Данные.Ссылка.Метаданные();
		Иначе
			МетаданныеОбъекта = Данные.Метаданные();
		КонецЕсли;

		ИдентификаторРодителя	= СоответствиеСтрокДереваМетаданным[МетаданныеОбъекта.ПолноеИмя()];
		Если ИдентификаторРодителя = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		СтрокаРодитель	= ДанныеОбмена.НайтиПоИдентификатору(ИдентификаторРодителя);

		ТипДанных		= СтрокаРодитель.ПолучитьРодителя().Имя;

		СсылкаНаОбъект	= Неопределено;
        КлючНабораЗаписей	= "";
		
		Если ТипДанных = "Справочники" ИЛИ
			 ТипДанных = "Документы" ИЛИ
			 ТипДанных = "ПланыВидовХарактеристик" ИЛИ
			 ТипДанных = "ПланыСчетов" ИЛИ
			 ТипДанных = "ПланыВидовРасчета" ИЛИ
			 ТипДанных = "БизнесПроцессы" ИЛИ
			 ТипДанных = "Задачи" Тогда
			Если ЭтоУдаление Тогда
				Представление = Строка(Данные.Ссылка);
			Иначе
				Представление = Строка(Данные);
				СсылкаНаОбъект	= Данные.Ссылка;
			КонецЕсли;
		ИначеЕсли ТипДанных = "РегистрыСведений" ИЛИ
				  ТипДанных = "РегистрыНакопления" ИЛИ
				  ТипДанных = "РегистрыБухгалтерии" ИЛИ
				  ТипДанных = "РегистрыРасчета" ИЛИ
				  ТипДанных = "Последовательности" Тогда

				Если ТипДанных <> "РегистрыСведений" Тогда
					Представление = Строка(Данные.Отбор.Регистратор);
					СсылкаНаОбъект	= Данные.Отбор.Регистратор.Значение;
				ИначеЕсли МетаданныеОбъекта.ПериодичностьРегистраСведений = Метаданные.СвойстваОбъектов.ПериодичностьРегистраСведений.ПозицияРегистратора Тогда
					Представление = Строка(Данные.Отбор.Регистратор);
					СсылкаНаОбъект	= Данные.Отбор.Регистратор.Значение;
				Иначе
					Представление = "Набор записей " + Строка(СтрокаРодитель.ПолучитьЭлементы().Количество() + 1);
					КлючНабораЗаписей		= ЗначениеВСтрокуВнутр(Данные.Отбор);
				КонецЕсли;
		Иначе
			Представление = Строка(Данные);
		КонецЕсли;

		Пояснение	= Представление;

		СтрокаРодитель.ПоказыватьОбъекты	= Истина;
		НоваяСтрока	= СтрокаРодитель.ПолучитьЭлементы().Добавить();
		НоваяСтрока.Имя				= МетаданныеОбъекта.Имя;
		НоваяСтрока.ИмяДляЗапроса	= МетаданныеОбъекта.ПолноеИмя();
		НоваяСтрока.Представление	= Представление;
		Если ЭтоУдаление Тогда
			НоваяСтрока.Картинка = БиблиотекаКартинок.Удалить;
		Иначе
			НоваяСтрока.Картинка = СтрокаРодитель.Картинка;
		КонецЕсли;
		НоваяСтрока.Уровень			= 3;
		НоваяСтрока.Авторегистрация	= 2;
		НоваяСтрока.СсылкаНаОбъект	= СсылкаНаОбъект;
		НоваяСтрока.КлючНабораЗаписей	= КлючНабораЗаписей;
		НоваяСтрока.УдалениеОбъекта	= ЭтоУдаление;

		ОбновитьСтрокуДереваНаСервере(НоваяСтрока);

		КоличествоОбработанныхОбъектов = КоличествоОбработанныхОбъектов + 1;
		//Если КоличествоОбработанныхОбъектов >= РазмерРазовойВыборки Тогда
		//	ВыборкаИзмененийЗакончена	= Ложь;
		//	Прервать;
		//КонецЕсли; 

	КонецЦикла;

	Если ВыборкаИзмененийЗакончена Тогда
		Если АдресВременногоХранилищаВыборкиИзменений <> "" Тогда
			УдалитьИзВременногоХранилища(АдресВременногоХранилищаВыборкиИзменений);
			АдресВременногоХранилищаВыборкиИзменений	= "";
		КонецЕсли;
		
		Если МассивИменМетаданных = Неопределено Тогда
			КореньДерева	= ДанныеОбмена.ПолучитьЭлементы()[0]; //Корень дерева
		 	ОбновитьКоличествоЗарегистрированныхДляСтрокиДерева(КореньДерева);
		Иначе
			Для каждого ПолноеИмяМетаданного Из МассивИменМетаданных Цикл
				ИдентификаторРодителя	= СоответствиеСтрокДереваМетаданным[ПолноеИмяМетаданного];
			 	СтрокаРодитель	= ДанныеОбмена.НайтиПоИдентификатору(ИдентификаторРодителя);
			 	ОбновитьКоличествоЗарегистрированныхДляСтрокиДерева(СтрокаРодитель);
			КонецЦикла;
		КонецЕсли;
		
		Возврат Ложь;
	ИначеЕсли АдресВременногоХранилищаВыборкиИзменений = "" Тогда
		АдресВременногоХранилищаВыборкиИзменений	= ПоместитьВоВременноеХранилище(ВыборкаИзменений, УникальныйИдентификатор);
	Иначе
		ПоместитьВоВременноеХранилище(ВыборкаИзменений, АдресВременногоХранилищаВыборкиИзменений);
	КонецЕсли;

	Возврат Истина;

КонецФункции

&НаКлиенте
Процедура РазвернутьДерево()
	Для Каждого Стр Из ДанныеОбмена.ПолучитьЭлементы() Цикл
		Элементы.ДанныеОбмена.Развернуть(Стр.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОбновитьКоличествоЗарегистрированныхДляСтрокиДерева(ИдентификаторИлиСтрокаДерева)

	Если ТипЗнч(ИдентификаторИлиСтрокаДерева) = Тип("Число") Тогда
		СтрокаДерева	= ДанныеОбмена.НайтиПоИдентификатору(ИдентификаторИлиСтрокаДерева);
	Иначе
		СтрокаДерева	= ИдентификаторИлиСтрокаДерева;
	КонецЕсли;

	Если СтрокаДерева.Уровень < 2 Тогда
		Для каждого ПодСтрока Из СтрокаДерева.ПолучитьЭлементы() Цикл
			ОбновитьКоличествоЗарегистрированныхДляСтрокиДерева(ПодСтрока);
		КонецЦикла;
		Возврат;
	ИначеЕсли СтрокаДерева.Уровень > 2 Тогда
		РабочаяСтрока	= СтрокаДерева;
		Пока РабочаяСтрока.Уровень > 2 Цикл
			РабочаяСтрока	= РабочаяСтрока.ПолучитьРодителя();
		КонецЦикла; 
	Иначе
		РабочаяСтрока	= СтрокаДерева;
	КонецЕсли; 
	
	СтароеКоличествоЗарегистрированныхОбъектов = РабочаяСтрока.Количество;

	КоличествоОбъектовСРегистрацией = ПолучитьКоличествоЗарегистрированныхОбъектов(УзелОбмена, РабочаяСтрока.ИмяДляЗапроса);
	РабочаяСтрока.Количество = КоличествоОбъектовСРегистрацией;
	ОбновитьСтрокуДереваНаСервере(РабочаяСтрока);
	
	Родитель = РабочаяСтрока.ПолучитьРодителя();

	Пока Родитель <> Неопределено Цикл

		Родитель.Количество = Родитель.Количество - СтароеКоличествоЗарегистрированныхОбъектов + КоличествоОбъектовСРегистрацией;		
		ОбновитьСтрокуДереваНаСервере(Родитель);
		Родитель = Родитель.ПолучитьРодителя();

	КонецЦикла;	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьКоличествоЗарегистрированныхОбъектов(УзелОбмена, ИмяДляЗапроса)
	
	Если НЕ ЗначениеЗаполнено(ИмяДляЗапроса) Тогда
		Возврат 0;
	КонецЕсли; 
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Узел", УзелОбмена);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Количество(*) КАК Количество
	|ИЗ
	|	" + ИмяДляЗапроса + ".Изменения КАК Таб
	|ГДЕ
	|	Таб.Узел = &Узел";

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.Количество) Тогда
			Возврат Выборка.Количество;
		КонецЕсли; 
	КонецЕсли; 
	
	Возврат 0;
	
КонецФункции

&НаСервере
Процедура ОбновитьСтрокуДереваНаСервере(СтрокаДерева)
	Если СтрокаДерева.Уровень = 2 Тогда
		СтрокаДерева.АвторегистрацияПредставление	= ?(СтрокаДерева.Авторегистрация = 1, "Разрешить", "Запретить");
	Иначе
		СтрокаДерева.Авторегистрация				= 2;
		СтрокаДерева.АвторегистрацияПредставление	= "";
	КонецЕсли;
	Если ОтображатьКоличествоЗарегистрированныхОбъектов Тогда
		Если СтрокаДерева.Уровень = 2 Тогда
			СтрокаДерева.АвторегистрацияПредставление	=  СтрокаДерева.АвторегистрацияПредставление + " (" + Строка(СтрокаДерева.Количество) + ")";
		ИначеЕсли СтрокаДерева.Уровень < 2 Тогда
			СтрокаДерева.АвторегистрацияПредставление	=  "Зарегистрировано: " + Строка(СтрокаДерева.Количество) + "";
		КонецЕсли; 
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтрокуДереваНаКлиенте(СтрокаДерева)
	Если СтрокаДерева.Уровень = 2 Тогда
		СтрокаДерева.АвторегистрацияПредставление	= ?(СтрокаДерева.Авторегистрация = 1, "Разрешить", "Запретить");
	Иначе
		СтрокаДерева.Авторегистрация				= 2;
		СтрокаДерева.АвторегистрацияПредставление	= "";
	КонецЕсли;
	Если ОтображатьКоличествоЗарегистрированныхОбъектов Тогда
		Если СтрокаДерева.Уровень = 2 Тогда
			СтрокаДерева.АвторегистрацияПредставление	=  СтрокаДерева.АвторегистрацияПредставление + " (" + Строка(СтрокаДерева.Количество) + ")";
		ИначеЕсли СтрокаДерева.Уровень < 2 Тогда
			СтрокаДерева.АвторегистрацияПредставление	=  "Зарегистрировано: " + Строка(СтрокаДерева.Количество) + "";
		КонецЕсли; 
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПредставлениеАвтоРегистрацииРекурсивно(СтрокаДанныхОбмена)
	
	Если СтрокаДанныхОбмена.Уровень < 2 Тогда
		Для каждого ПодСтрока Из СтрокаДанныхОбмена.ПолучитьЭлементы() Цикл
			ИзменитьПредставлениеАвтоРегистрацииРекурсивно(ПодСтрока);
		КонецЦикла;
	КонецЕсли;
	ОбновитьСтрокуДереваНаКлиенте(СтрокаДанныхОбмена);
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьПолноеИмяФормы(ИмяФормы)
	
	СимволТочка = ".";
	ПозицияПоследнейТочки = СтрДлина(ЭтаФорма.ИмяФормы);
	Пока Сред(ЭтаФорма.ИмяФормы, ПозицияПоследнейТочки, 1) <> СимволТочка Цикл 
		ПозицияПоследнейТочки = ПозицияПоследнейТочки - 1;
	КонецЦикла; // 
	Возврат Лев(ЭтаФорма.ИмяФормы, ПозицияПоследнейТочки) + ИмяФормы;
	
КонецФункции

