////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;

    УзелОбмена	= Параметры.УзелОбмена;
	Если ЗначениеЗаполнено(УзелОбмена) Тогда
		Элементы.УзелОбмена.Видимость = Ложь;
	КонецЕсли; 

	ПриИзмененииУзлаОбменаСервер();

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПриИзмененииУзлаОбменаКлиент();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ИзмененыРеквизитыПланаОбмена" И
		 Параметр = УзелОбмена Тогда
		УстановитьЗаголовокФормы();
		ОтобразитьИзменениеДанных(УзелОбмена, ВидИзмененияДанных.Изменение);
	КонецЕсли;
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ПОЛЕЙ ФОРМЫ

&НаКлиенте
Процедура УзелОбменаПриИзменении(Элемент)
	ПриИзмененииУзлаОбменаСервер();
	ПриИзмененииУзлаОбменаКлиент();
КонецПроцедуры

&НаКлиенте
Процедура ДанныеОбменаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекущиеДанные.СсылкаНаОбъект) Тогда
		СтандартнаяОбработка = Ложь;
		ОткрытьЗначение(ТекущиеДанные.СсылкаНаОбъект);
	ИначеЕсли ЗначениеЗаполнено(ТекущиеДанные.КлючНабораЗаписей) Тогда
		Родитель	= ТекущиеДанные;
		Пока Родитель.Уровень > 2 Цикл
			Родитель	= Родитель.ПолучитьРодителя();
		КонецЦикла;
		ПараметрыФормы	= Новый Структура("Ключ", ПолучитьКлючФормыНаСервере(ТекущиеДанные.КлючНабораЗаписей, Родитель.Имя));
		ОткрытьФорму(Родитель.ИмяДляЗапроса + ".ФормаЗаписи", ПараметрыФормы);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтображатьКоличествоЗарегистрированныхОбъектовПриИзменении(Элемент)
	ИзменитьПредставлениеАвтоРегистрацииРекурсивно(ДанныеОбмена.ПолучитьЭлементы()[0]);
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ПоказатьВсеОбъекты(Команда)
	
	Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.ДанныеОбмена.ВыделенныеСтроки.Количество() = 1 Тогда
		
		ТекущиеДанные	= Элементы.ДанныеОбмена.ТекущиеДанные;
		
		Пока ТекущиеДанные.Уровень > 2 Цикл
			ТекущиеДанные	= ТекущиеДанные.ПолучитьРодителя();
		КонецЦикла;
		
		ИдентификаторСтроки	= ТекущиеДанные.ПолучитьИдентификатор();
		
		//Если ТекущиеДанные.Уровень = 0 Тогда
		//	ТекстПодтверждения = "Показать все зарегистрированные объекты для узла """+Строка(УзелОбмена)+"""?";
		//ИначеЕсли ТекущиеДанные.Уровень = 1 Тогда
		//	ТекстПодтверждения = "Показать все зарегистрированные объекты из вида """ + ТекущиеДанные.Представление + """?";
		//ИначеЕсли ТекущиеДанные.Уровень = 2 Тогда
		//	ТекстПодтверждения = "Показать все зарегистрированные объекты с типом: " + ТекущиеДанные.ИмяДляЗапроса + "?";
		//КонецЕсли;

	Иначе
		//ТекстПодтверждения = "Показать все зарегистрированные объекты для выбранных строк?";
	КонецЕсли;
	
	//Если Вопрос(ТекстПодтверждения, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
	//	Возврат;
	//КонецЕсли;

	Количество	= 0;
	
	МассивИдСтрок	= Новый Массив();
	
	ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИдСтрок, Неопределено, Количество);

	Если МассивИдСтрок = Неопределено Тогда
		МассивИменМетаданных	= Неопределено;
	Иначе
		МассивИменМетаданных	= Новый Массив();
		Для каждого Ид Из МассивИдСтрок Цикл
			МассивИменМетаданных.Добавить(ДанныеОбмена.НайтиПоИдентификатору(Ид).ИмяДляЗапроса);
		КонецЦикла; 
	КонецЕсли; 

    Получено	= 0;
	Пояснение	= "";

	Пока ПоказатьОбъекты(МассивИменМетаданных, 500, Пояснение) Цикл
		Получено	= Получено + 500;
		Если Количество = 0 Тогда
			Состояние("Получение данных о зарегистрированных объектах: "+Строка(Получено) + "...",,Пояснение);
		Иначе
			
			Прогресс	= Окр((Получено / Количество) * 100);
			Прогресс	= ?(Прогресс > 100, 100, Прогресс);

			Состояние("Получение данных о зарегистрированных объектах: "+Строка(Получено) + "...", Прогресс, Пояснение);

		КонецЕсли;
		ОбработкаПрерыванияПользователя();
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СкрытьОбъекты(Команда)
	
	ТекущиеДанные	= Элементы.ДанныеОбмена.ТекущиеДанные;

	Пока ТекущиеДанные.Уровень > 2 Цикл
		ТекущиеДанные	= ТекущиеДанные.ПолучитьРодителя();
	КонецЦикла;

	ОчиститьОбъектыРегистрацииВДанныхОбмена(ТекущиеДанные.ПолучитьИдентификатор(), Истина);

КонецПроцедуры

&НаКлиенте
Процедура Редактировать(Команда)
	СтруктураПараметров	= Новый Структура("УзелОбмена", УзелОбмена);
	ОткрытьФорму(ПолучитьПолноеИмяФормы("ФормаРедактирования"), СтруктураПараметров, ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеОбмена(Команда)
	ОбновитьДанныеОбменаНаКлиенте(ДанныеОбмена.ПолучитьЭлементы()[0]);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеОбменаКонтекстноеМеню(Команда)

	Количество	= 0;
	МассивИдСтрокМетаданных	= Новый Массив();
	ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИдСтрокМетаданных, Неопределено, Количество);
	Если МассивИдСтрокМетаданных = Неопределено Тогда
		ОбновитьДанныеОбменаНаКлиенте(ДанныеОбмена.ПолучитьЭлементы()[0]);
	Иначе
		Для каждого Ид Из МассивИдСтрокМетаданных Цикл
			ОбновитьДанныеОбменаНаКлиенте(ДанныеОбмена.НайтиПоИдентификатору(Ид));
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура УдалитьРегистрациюОбъектов(Команда)

	Если Не ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;

	ТекстВопроса = "Операция удаления регистрации изменений необратима." + Символы.ПС;
	Если Элементы.ДанныеОбмена.ВыделенныеСтроки.Количество() = 1 Тогда
		ТекущиеДанные	= ДанныеОбмена.НайтиПоИдентификатору(Элементы.ДанныеОбмена.ВыделенныеСтроки[0]);
		Если ТекущиеДанные.Уровень = 0 Тогда
			ТекстВопроса = ТекстВопроса + "Удалить регистрацию изменений для узла """+Строка(УзелОбмена)+"""?";
		ИначеЕсли ТекущиеДанные.Уровень = 1 Тогда
			ТекстВопроса = ТекстВопроса + "Удалить регистрацию изменений для всех объектов вида """ + ТекущиеДанные.Представление + """?";
		ИначеЕсли ТекущиеДанные.Уровень = 2 Тогда
			ТекстВопроса = ТекстВопроса + "Удалить регистрацию изменений объектов типа: " + ТекущиеДанные.ИмяДляЗапроса + "?";
		ИначеЕсли ТекущиеДанные.Уровень = 3 Тогда
			ТекстВопроса = "";
		КонецЕсли;
	Иначе
		ТекстВопроса = ТекстВопроса + "Удалить регистрацию изменений для всех выбранных строк?";
	КонецЕсли;

	Если ТекстВопроса <> "" И Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;

	Количество	= 0;

	МассивИдСтрокМетаданных	= Новый Массив();
	МассивИдСтрокОбъектов	= Новый Массив();

	ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИдСтрокМетаданных, МассивИдСтрокОбъектов, Количество);

	Если МассивИдСтрокМетаданных = Неопределено Тогда
		//Полное удаление всех регистраций
		Состояние("Удаление всех регистраций плана обмена "+Строка(УзелОбмена)+"...");
	    УдалитьРегистрациюИзмененийНаСервере(УзелОбмена, Неопределено);
		//Удалим все объекты 3 уровня и обновим количество зарегистрированных объектов
		КореньДерева	= ДанныеОбмена.ПолучитьЭлементы()[0]; //Корень дерева
		ОчиститьОбъектыРегистрацииИОбновитьКоличествоНаКлиенте(КореньДерева);
	Иначе
		Всего	= МассивИдСтрокМетаданных.Количество() * 50 + МассивИдСтрокОбъектов.Количество();
		ТекущийНомер	= 0;
		Для каждого Ид Из МассивИдСтрокМетаданных Цикл
			Прогресс	= Окр(ТекущийНомер / Всего * 100);
			СтрокаДерева	= ДанныеОбмена.НайтиПоИдентификатору(Ид);
			Состояние("Удаление регистраций для плана обмена"+Строка(УзелОбмена)+"...", Прогресс, СтрокаДерева.ИмяДляЗапроса);
			Если УдалитьРегистрациюИзмененийНаСервере(УзелОбмена, СтрокаДерева.ИмяДляЗапроса) Тогда
				//Очистить объекты регистрации и скорректировать количество
				ОчиститьОбъектыРегистрацииИОбновитьКоличествоНаКлиенте(СтрокаДерева);
				ТекущийНомер	= ТекущийНомер + 50;
			КонецЕсли;
		КонецЦикла;
		Для каждого Элемент Из МассивИдСтрокОбъектов Цикл
			ТекущаяСтрока	= ДанныеОбмена.НайтиПоИдентификатору(Элемент);
			Если ТекущийНомер % 50 = 0 Тогда
				Прогресс	= Окр(ТекущийНомер / Всего * 100);
				Состояние("Удаление регистраций для плана обмена"+Строка(УзелОбмена)+"...", Прогресс, Строка(ТекущаяСтрока.Представление));
			КонецЕсли;
			Если УдалитьРегистрациюИзмененийНаСервере(УзелОбмена, ТекущаяСтрока.ИмяДляЗапроса, ТекущаяСтрока.СсылкаНаОбъект, ТекущаяСтрока.КлючНабораЗаписей, ТекущаяСтрока.УдалениеОбъекта) Тогда
				//Очищаем строку с объектом и корректируем количество зарегистрированных объектов
				Родитель	= ТекущаяСтрока.ПолучитьРодителя();
				Коллекция	= Родитель.ПолучитьЭлементы();
				Коллекция.Удалить(Коллекция.Индекс(ТекущаяСтрока));
				Пока Родитель <> Неопределено Цикл
					Родитель.Количество = Родитель.Количество - 1;
					ОбновитьСтрокуДереваНаКлиенте(Родитель);
					Родитель = Родитель.ПолучитьРодителя();
				КонецЦикла;
				ТекущийНомер	= ТекущийНомер + 1;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьОбъекты(Команда)
	
	Если Не ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;

	ТекстВопроса = "Операция регистрации изменений необратима." + Символы.ПС;
	Если Элементы.ДанныеОбмена.ВыделенныеСтроки.Количество() = 1 Тогда
		ТекущиеДанные	= ДанныеОбмена.НайтиПоИдентификатору(Элементы.ДанныеОбмена.ВыделенныеСтроки[0]);
		Если ТекущиеДанные.Уровень = 0 Тогда
			ТекстВопроса = ТекстВопроса + "Зарегистрировать изменения для узла """+Строка(УзелОбмена)+"""?";
		ИначеЕсли ТекущиеДанные.Уровень = 1 Тогда
			ТекстВопроса = ТекстВопроса + "Зарегистрировать изменения для всех объектов вида """ + ТекущиеДанные.Представление + """?";
		ИначеЕсли ТекущиеДанные.Уровень = 2 Тогда
			ТекстВопроса = ТекстВопроса + "Зарегистрировать изменения объектов типа: " + ТекущиеДанные.ИмяДляЗапроса + "?";
		ИначеЕсли ТекущиеДанные.Уровень = 3 Тогда
			Возврат;
		КонецЕсли;
	Иначе
		ТекстВопроса = ТекстВопроса + "Зарегистрировать изменения для всех выбранных строк?";
	КонецЕсли;

	Если Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;

	Количество	= 0;

	МассивИдСтрокМетаданных	= Новый Массив();

	ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИдСтрокМетаданных, Неопределено, Количество);
	
	Если МассивИдСтрокМетаданных = Неопределено Тогда
		//Полная регистрация всех объектов
		Состояние("Полная регистрация всех объектов для плана обмена "+Строка(УзелОбмена)+"...");
	    ЗарегистрироватьОбъектыНаСервере(УзелОбмена, Неопределено);
		//Обновляем дерево ДанныхОбмена
		ОбновитьДанныеОбменаНаКлиенте(ДанныеОбмена.ПолучитьЭлементы()[0]);
	Иначе
		Всего	= МассивИдСтрокМетаданных.Количество();
		ТекущийНомер	= 0;
		Для каждого Ид Из МассивИдСтрокМетаданных Цикл
			Прогресс	= Окр(ТекущийНомер / Всего * 100);
			СтрокаДерева	= ДанныеОбмена.НайтиПоИдентификатору(Ид);
			Состояние("Регистрация всех объектов для плана обмена"+Строка(УзелОбмена)+"...", Прогресс, СтрокаДерева.ИмяДляЗапроса);
			ЗарегистрироватьОбъектыНаСервере(УзелОбмена, СтрокаДерева.ИмяДляЗапроса);
			ОбновитьДанныеОбменаНаКлиенте(СтрокаДерева);
			ТекущийНомер	= ТекущийНомер + 1;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПроизвольнаяРегистрация(Команда)
	Количество	= 0;
	МассивИдСтрокМетаданных	= Новый Массив();
	МассивИдСтрокОбъектов	= Новый Массив();
	ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИдСтрокМетаданных, МассивИдСтрокОбъектов, Количество);

	СписокИменМетаданных	= Новый СписокЗначений();
	Если МассивИдСтрокМетаданных <> Неопределено Тогда
		Для каждого Ид Из МассивИдСтрокМетаданных Цикл
			СписокИменМетаданных.Добавить(ДанныеОбмена.НайтиПоИдентификатору(Ид).ИмяДляЗапроса);
		КонецЦикла; 
	КонецЕсли; 
	
	Если МассивИдСтрокОбъектов <> Неопределено Тогда
		Для каждого Ид Из МассивИдСтрокОбъектов Цикл
			ИмяМетаданных	= ДанныеОбмена.НайтиПоИдентификатору(Ид).ИмяДляЗапроса;
			Если СписокИменМетаданных.НайтиПоЗначению(ИмяМетаданных) = Неопределено Тогда
				СписокИменМетаданных.Добавить(ИмяМетаданных);
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	
	СтруктураПараметров	= Новый Структура();
	СтруктураПараметров.Вставить("РегистрацияОбъектов", Истина);
	СтруктураПараметров.Вставить("СписокИменМетаданных", СписокИменМетаданных);
	СтруктураПараметров.Вставить("УзелОбмена", УзелОбмена);

	Результат = ОткрытьФормуМодально(ПолучитьПолноеИмяФормы("ФормаПроизвольнойРегистрации"), СтруктураПараметров, ЭтаФорма);

	Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;

	СоответствиеОбъектовМетаданных	= Новый Соответствие();

	Если Результат <> Неопределено Тогда
		ВключаяДвиженияДокументов	= Результат.ВключаяДвиженияДокументов;
		ТаблицаСсылок	= Результат.Таблица;
		ВсегоСтрок		= ТаблицаСсылок.Количество();
		
		РазмерПорции	= Макс(Окр(ВсегоСтрок / 20), 50);
		МассивДанных	= Новый Массив();
		Представление	= "";

	    Сч	= 0;
		Для каждого СтрокаТаблицыСсылок Из ТаблицаСсылок Цикл
			
			СтруктураДанных	= Новый Структура("ИмяМетаданных, СсылкаНаОбъект, КлючНабораЗаписей",
												СтрокаТаблицыСсылок.ИмяМетаданных,
												СтрокаТаблицыСсылок.СсылкаНаОбъект,
												СтрокаТаблицыСсылок.КлючНабораЗаписей);
			Представление	= СтрокаТаблицыСсылок.Представление;
			МассивДанных.Добавить(СтруктураДанных);
			Сч	= Сч + 1;

			Если Сч % РазмерПорции = 0 Тогда
				ПроизвестиПроизвольнуюРегистрациюОбъектаНаСервере(УзелОбмена,
																ВключаяДвиженияДокументов,
																МассивДанных,
																СоответствиеОбъектовМетаданных);
				МассивДанных.Очистить();
				Прогресс	= Окр((Сч / ВсегоСтрок) * 100);
				Прогресс	= ?(Прогресс > 100, 100, Прогресс);
				Состояние("Регистрации объектов: " + Строка(Сч) + "...", Прогресс, Представление);
				ОбработкаПрерыванияПользователя();
			КонецЕсли;
		КонецЦикла;
		Если МассивДанных.Количество() > 0 Тогда
			ПроизвестиПроизвольнуюРегистрациюОбъектаНаСервере(УзелОбмена,
									ВключаяДвиженияДокументов,
									МассивДанных,
									СоответствиеОбъектовМетаданных);
			Прогресс	= Окр((Сч / ВсегоСтрок) * 100);
			Прогресс	= ?(Прогресс > 100, 100, Прогресс);
			Состояние("Регистрации объектов: " + Строка(Сч) + "...", Прогресс, Представление);
		КонецЕсли;
		Для каждого КлючИЗначение Из СоответствиеОбъектовМетаданных Цикл
			ИдСтроки	= СоответствиеСтрокДереваМетаданным[КлючИЗначение.Ключ];
			Если ИдСтроки <> Неопределено Тогда
				ОбновитьДанныеОбменаНаКлиенте(ДанныеОбмена.НайтиПоИдентификатору(ИдСтроки));
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПроизвольнаяОтменаРегистрации(Команда)
	Количество	= 0;
	МассивИдСтрокМетаданных	= Новый Массив();
	МассивИдСтрокОбъектов	= Новый Массив();
	ПодготовитьМассивДанныхПоВыделеннымСтрокам(МассивИдСтрокМетаданных, МассивИдСтрокОбъектов, Количество);
	
	СписокИменМетаданных	= Новый СписокЗначений();
	Если МассивИдСтрокМетаданных <> Неопределено Тогда
		Для каждого Ид Из МассивИдСтрокМетаданных Цикл
			СписокИменМетаданных.Добавить(ДанныеОбмена.НайтиПоИдентификатору(Ид).ИмяДляЗапроса);
		КонецЦикла; 
	КонецЕсли; 
	
	Если МассивИдСтрокОбъектов <> Неопределено Тогда
		Для каждого Ид Из МассивИдСтрокОбъектов Цикл
			ИмяМетаданных	= ДанныеОбмена.НайтиПоИдентификатору(Ид).ИмяДляЗапроса;
			Если СписокИменМетаданных.НайтиПоЗначению(ИмяМетаданных) = Неопределено Тогда
				СписокИменМетаданных.Добавить(ИмяМетаданных);
			КонецЕсли; 
		КонецЦикла; 
	КонецЕсли; 
	

	СтруктураПараметров	= Новый Структура();
	СтруктураПараметров.Вставить("РегистрацияОбъектов", Ложь);
	СтруктураПараметров.Вставить("СписокИменМетаданных", СписокИменМетаданных);
	СтруктураПараметров.Вставить("УзелОбмена", УзелОбмена);

	Результат = ОткрытьФормуМодально(ПолучитьПолноеИмяФормы("ФормаПроизвольнойРегистрации"), СтруктураПараметров, ЭтаФорма);

	Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат;
	КонецЕсли;

	СоответствиеОбъектовМетаданных	= Новый Соответствие();

	Если Результат <> Неопределено Тогда
		ВключаяДвиженияДокументов	= Результат.ВключаяДвиженияДокументов;
		ТаблицаСсылок	= Результат.Таблица;
		ВсегоСтрок		= ТаблицаСсылок.Количество();
		
		РазмерПорции	= Макс(Окр(ВсегоСтрок / 20), 50);
		МассивДанных	= Новый Массив();
		Представление	= "";

	    Сч	= 0;
		Для каждого СтрокаТаблицыСсылок Из ТаблицаСсылок Цикл
			
			СтруктураДанных	= Новый Структура("ИмяМетаданных, СсылкаНаОбъект, КлючНабораЗаписей",
												СтрокаТаблицыСсылок.ИмяМетаданных,
												СтрокаТаблицыСсылок.СсылкаНаОбъект,
												СтрокаТаблицыСсылок.КлючНабораЗаписей);
			Представление	= СтрокаТаблицыСсылок.Представление;
			МассивДанных.Добавить(СтруктураДанных);
			Сч	= Сч + 1;

			Если Сч % РазмерПорции = 0 Тогда
				ПроизвестиПроизвольнуюОтменуРегистрацииОбъектаНаСервере(УзелОбмена,
															ВключаяДвиженияДокументов,
															МассивДанных,
															СоответствиеОбъектовМетаданных);
				МассивДанных.Очистить();
				Прогресс	= Окр((Сч / ВсегоСтрок) * 100);
				Прогресс	= ?(Прогресс > 100, 100, Прогресс);
				Состояние("Отмена регистрации объектов: " + Строка(Сч) + "...", Прогресс, Представление);
				ОбработкаПрерыванияПользователя();
			КонецЕсли;

		КонецЦикла;
		Если МассивДанных.Количество() > 0 Тогда
			ПроизвестиПроизвольнуюОтменуРегистрацииОбъектаНаСервере(УзелОбмена,
														ВключаяДвиженияДокументов,
														МассивДанных,
														СоответствиеОбъектовМетаданных);
			Прогресс	= Окр((Сч / ВсегоСтрок) * 100);
			Прогресс	= ?(Прогресс > 100, 100, Прогресс);
			Состояние("Отмена регистрации объектов: " + Строка(Сч) + "...", Прогресс, Представление);
		КонецЕсли;

        Для каждого КлючИЗначение Из СоответствиеОбъектовМетаданных Цикл
			ИдСтроки	= СоответствиеСтрокДереваМетаданным[КлючИЗначение.Ключ];
			Если ИдСтроки <> Неопределено Тогда
				ОбновитьДанныеОбменаНаКлиенте(ДанныеОбмена.НайтиПоИдентификатору(ИдСтроки));
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

