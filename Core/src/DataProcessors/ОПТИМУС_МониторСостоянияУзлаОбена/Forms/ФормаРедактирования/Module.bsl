////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Параметры.УзелОбмена) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	УзелОбмена	= Параметры.УзелОбмена;

	МетаданныеОбъекта	= УзелОбмена.Метаданные();
	ЭтотУзел	= (УзелОбмена = ПланыОбмена[МетаданныеОбъекта.Имя].ЭтотУзел());
	
	Для каждого Реквизит Из МетаданныеОбъекта.СтандартныеРеквизиты Цикл
		Если Реквизит.Имя = "ПометкаУдаления" ИЛИ
			 Реквизит.Имя = "Ссылка" Тогда
			Продолжить;
		ИначеЕсли ЭтотУзел И
				  (Реквизит.Имя = "НомерПринятого" ИЛИ
				   Реквизит.Имя = "НомерОтправленного") Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока	= ТаблицаРеквизитовУзлаОбмена.Добавить();
		НоваяСтрока.Имя	= Реквизит.Имя;
		НоваяСтрока.Заголовок	= ?(ЗначениеЗаполнено(Реквизит.Синоним), Реквизит.Синоним, Реквизит.Имя);
		НоваяСтрока.Блокировка	= Истина;
		НоваяСтрока.Включить	= Истина;
		НоваяСтрока.ТипЗначения	= Реквизит.Тип;
		Если Реквизит.Имя = "Код" ИЛИ
			 Реквизит.Имя = "Наименование"  Тогда
			НоваяСтрока.ИмяРодительскогоЭлемента	= "ГруппаКодНаименование";
		Иначе
			НоваяСтрока.ИмяРодительскогоЭлемента	= "ГруппаНомераСообщений";
			Если НоваяСтрока.Заголовок = "НомерПринятого" Тогда
				НоваяСтрока.Заголовок	= "Номер принятого";
			ИначеЕсли НоваяСтрока.Заголовок = "НомерОтправленного" Тогда
				НоваяСтрока.Заголовок	= "Номер отправленного";
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	Для каждого Реквизит Из МетаданныеОбъекта.Реквизиты Цикл
		НоваяСтрока	= ТаблицаРеквизитовУзлаОбмена.Добавить();
		НоваяСтрока.Имя	= Реквизит.Имя;
		НоваяСтрока.Заголовок	= ?(ЗначениеЗаполнено(Реквизит.Синоним), Реквизит.Синоним, Реквизит.Имя);
		НоваяСтрока.Блокировка	= Ложь;
		НоваяСтрока.Включить	= Ложь;
		НоваяСтрока.ТипЗначения	= Реквизит.Тип;
		НоваяСтрока.ИмяРодительскогоЭлемента	= "ГруппаРеквизитов";
	КонецЦикла;

	Заголовок	= "Редактирование реквизитов узла """ +Строка(УзелОбмена) + """ плана обмена """ + МетаданныеОбъекта.Синоним +"""";

	РедактированиеРазрешено	= ПравоДоступа("Редактирование", МетаданныеОбъекта);

	УстановитьРеквизитыФормы();

	ЗадатьВопрос	= Истина;

КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ОБРАБОТЧИКИ КОМАНД ФОРМЫ

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)
	ЗадатьВопрос	= Ложь;
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)

	Если НЕ РедактированиеРазрешено Тогда
		Возврат;
	КонецЕсли; 
	Если Модифицированность Тогда
		Если ЗадатьВопрос Тогда
			Результат	= Вопрос("Реквизиты узла обмена были изменены. Записать изменения?", РежимДиалогаВопрос.ДаНетОтмена, 60, КодВозвратаДиалога.Отмена);
			Если Результат = КодВозвратаДиалога.Нет Тогда
				Возврат;
			ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда
				СтандартнаяОбработка = Ложь;
				Отказ  = Истина;
				Возврат;
			КонецЕсли; 
		КонецЕсли; 
		ЗаписатьИзмененныеРеквизиты();
		Оповестить("ИзмененыРеквизитыПланаОбмена", УзелОбмена, ЭтаФорма);
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьСоставРеквизитов(Команда)
	СписокРеквизитовУзлаОбмена	= Новый СписокЗначений();
	Для каждого СтрокаТаблицы Из ТаблицаРеквизитовУзлаОбмена Цикл
		Если СтрокаТаблицы.Блокировка Тогда
			Продолжить;
		КонецЕсли;
		СписокРеквизитовУзлаОбмена.Добавить(СтрокаТаблицы.Имя, СтрокаТаблицы.Заголовок, СтрокаТаблицы.Включить);
	КонецЦикла; 
	Если СписокРеквизитовУзлаОбмена.ОтметитьЭлементы("Реквизиты узла обмена") Тогда
		Для каждого Элемент Из СписокРеквизитовУзлаОбмена Цикл
			НС	= ТаблицаРеквизитовУзлаОбмена.НайтиСтроки(Новый Структура("Имя", Элемент.Значение));
			НС[0].Включить	= Элемент.Пометка;
		КонецЦикла; 
		УстановитьРеквизитыФормы();
	КонецЕсли;
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// СЛУЖЕБНЫЕ ПРОЦЕДУРЫ И ФУНКЦИИ
&НаСервере
Процедура УстановитьРеквизитыФормы()
	//Реквизиты
	МассивДобавляемыхРеквизитов	= Новый Массив();
	МассивУдаляемыхРеквизитов	= Новый Массив();
	СоответствиеСтрокТаблицыРеквизитам	= Новый Соответствие();
	Для каждого СтрокаТаблицы Из ТаблицаРеквизитовУзлаОбмена Цикл
		Если НЕ СтрокаТаблицы.Включить И ЗначениеЗаполнено(СтрокаТаблицы.ИмяРеквизита) Тогда
			МассивУдаляемыхРеквизитов.Добавить(СтрокаТаблицы.ИмяРеквизита);
			СтрокаТаблицы.ИмяРеквизита	= Неопределено;
		ИначеЕсли СтрокаТаблицы.Включить И НЕ ЗначениеЗаполнено(СтрокаТаблицы.ИмяРеквизита) Тогда
			ИмяРеквизита	= "__" + СтрокаТаблицы.Имя+"__";
			РеквизитФормы	= Новый РеквизитФормы(ИмяРеквизита, СтрокаТаблицы.ТипЗначения,,СтрокаТаблицы.Заголовок, Истина);
			СтрокаТаблицы.ИмяРеквизита	= ИмяРеквизита;
			МассивДобавляемыхРеквизитов.Добавить(РеквизитФормы);
			СоответствиеСтрокТаблицыРеквизитам[РеквизитФормы] = СтрокаТаблицы;
		КонецЕсли;
	КонецЦикла;
	ИзменитьРеквизиты(МассивДобавляемыхРеквизитов, МассивУдаляемыхРеквизитов);
	//Элементы
	Для каждого УдаленныйРеквизит Из МассивУдаляемыхРеквизитов Цикл
		Элементы.Удалить(Элементы.Найти(УдаленныйРеквизит));
	КонецЦикла;
	Для каждого ДобавленныйРеквизит Из МассивДобавляемыхРеквизитов Цикл
		СтрокаТаблицы	= СоответствиеСтрокТаблицыРеквизитам[ДобавленныйРеквизит];
		НовыйЭлемент	= Элементы.Добавить(ДобавленныйРеквизит.Имя, Тип("ПолеФормы"), Элементы[СтрокаТаблицы.ИмяРодительскогоЭлемента]);
		НовыйЭлемент.Вид = ?(ДобавленныйРеквизит.ТипЗначения.СодержитТип(Тип("Булево")), ВидПоляФормы.ПолеФлажка, ВидПоляФормы.ПолеВвода);
		НовыйЭлемент.ПутьКДанным	= ДобавленныйРеквизит.Имя;
		НовыйЭлемент.ТолькоПросмотр	= НЕ РедактированиеРазрешено;
		ЭтаФорма[ДобавленныйРеквизит.Имя]	= УзелОбмена[СтрокаТаблицы.Имя];
	КонецЦикла;
	РеквизитыИзменены	= Ложь;
	Для каждого СтрокаТаблицы Из ТаблицаРеквизитовУзлаОбмена Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ИмяРеквизита) Тогда
			Продолжить;
		ИначеЕсли ЭтаФорма[СтрокаТаблицы.ИмяРеквизита] <> УзелОбмена[СтрокаТаблицы.Имя] Тогда
			РеквизитыИзменены	= Истина;
			Прервать;
		КонецЕсли; 
	КонецЦикла;
	Модифицированность	= РеквизитыИзменены;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьИзмененныеРеквизиты()

	Если НЕ РедактированиеРазрешено Тогда
		Возврат;
	КонецЕсли;

	ОбъектУзла	= УзелОбмена.ПолучитьОбъект();
	Для каждого СтрокаТаблицы Из ТаблицаРеквизитовУзлаОбмена Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.ИмяРеквизита) Тогда
			Продолжить;
		ИначеЕсли ЭтаФорма[СтрокаТаблицы.ИмяРеквизита] <> ОбъектУзла[СтрокаТаблицы.Имя] Тогда
			ОбъектУзла[СтрокаТаблицы.Имя]	= ЭтаФорма[СтрокаТаблицы.ИмяРеквизита];
		КонецЕсли; 
	КонецЦикла; 
	ОбъектУзла.Записать();

КонецПроцедуры
