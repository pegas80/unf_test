&НаКлиенте
Процедура СоздатьЭлНакладную(Команда)
	
	Если Элементы.Группа1.ТекущаяСтраница.Имя = "ВидСписокПеремещений" Тогда 
		Для итер = 0 По СписокПеремещений.Количество()-1 Цикл 
			//Если ПроверитьФункционалРезерва() Тогда
			Стр = СписокПеремещений[итер];
			Если Стр.Создать И (ЗначениеЗаполнено(стр.ДокРасНак) ИЛИ ЗначениеЗаполнено(стр.ДокПерем)) Тогда
				Буфер = СоздатьЭлНакладнуюНаСервере(Стр.ДокРасНак,Стр.ДокПерем);
				Стр.ДокЭлНакл = Буфер;
				Стр.Статус = ПолучитьСтатус();
				СписокРасходнаяНакладная[итер].ДокЭлНакл = Стр.ДокЭлНакл; 
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "ПриходнаяНакладная" Тогда 
		Для итер = 0 по СписокПриходнаяНакладная.Количество()-1 Цикл
			Стр = СписокПриходнаяНакладная[итер];
			//Если ПроверитьФункционалРезерва() Тогда
			
			Если Стр.Создать Тогда
				Буфер = СоздатьЭлНакладнуюНаСервере(Стр.Ссылка,Неопределено);
				Стр.ДокЭлНакл = Буфер;
				СписокПриходнаяНакладная[итер].ДокЭлНакл = Стр.ДокЭлНакл;
				//Стр.Статус = ПолучитьСтатус(); 
			КонецЕсли;	
		КонецЦикла;
	ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "РасходнаяНакладная" Тогда 
		Для итер = 0 по СписокРасходнаяНакладная.Количество()-1 Цикл 
			//Если ПроверитьФункционалРезерва() Тогда
			Стр = СписокРасходнаяНакладная[итер];
			Если Стр.Печать Тогда
				Буфер = СоздатьЭлНакладнуюНаСервере(Стр.Ссылка,Неопределено); 
				Стр.ДокЭлНакл = Буфер;
				СписокРасходнаяНакладная[итер].ДокЭлНакл = Стр.ДокЭлНакл;
				//Стр.Статус = ПолучитьСтатус(); 
			КонецЕсли;	
		КонецЦикла;	
		
	КонецЕсли;
		
	//ЗаполнитьСписокРасходнаяНакладная();
КонецПроцедуры	

&НаСервере
Функция СоздатьЭлНакладнуюНаСервере(Ссылка,ДокПерем)
	
	
	ЭлНакладная = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(Ссылка);
	
	БылаСоздана = Ложь;
		
	Если Не ЗначениеЗаполнено(ЭлНакладная) И ЗначениеЗаполнено(Ссылка) Тогда 
		
		Док = Документы.РС_ЭлектроннаяНакладная.СоздатьДокумент();
		
		Док.Заполнить(Ссылка);
		//Док.Дата = ТекущаяДата();
		
		//++Lazare 21.07.202
		Если ЗначениеЗаполнено(НачалнаяДатаТранспортировки) Тогда 
			Док.Дата = НачалнаяДатаТранспортировки;
		Иначе 
			Док.Дата = ТекущаяДата();
		КонецЕсли;
	    //--Lazare 21.07.202		
		
		Док.СформироватьТаблицуЭлНакладных();
		
		Если ЗначениеЗаполнено(ДокПерем) Тогда
			Док.ТипТН = Перечисления.РС_ТипыТН.ПодчиненнаяТН;
			Док.НакладнаяДистрибюций = ДокПерем.Ссылка;
			
			ДокПеремОбъект = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(ДокПерем).Ссылка;
			
			Док.ТранспортноеСредство = ДокПеремОбъект.ТранспортноеСредство;
			Док.ГосНомерАвтомобиля = ДокПеремОбъект.ТранспортноеСредство.Код;
			Док.Водитель = ДокПеремОбъект.Водитель;
			Док.НомерУдостоверения =  ДокПеремОбъект.Водитель.ИНН;
		КонецЕсли;

		Если ЗначениеЗаполнено(ЭтотОбъект.НачалнаяДатаТранспортировки) Тогда 
			Док.ДатаНачалаТранспортировки = ЭтотОбъект.НачалнаяДатаТранспортировки;
		Иначе  Док.ДатаНачалаТранспортировки = ТекущаяДата();
		КонецЕсли;    	

		//Док.Товары.Загрузить(Ссылка.Запасы.Выгрузить());	
		//+ ONESOFT-3432
		ТаблицаТовары = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.СформироватьТаблицуРеализации(Ссылка);
		Док.Товары.Загрузить(ТаблицаТовары); 
		//- ONESOFT-3432
		
		НоваяСтрока = Док.ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = Ссылка;
		
		// Олег Литвиненко 12.10.22 --->
		//--------------------------------------------------------------------------
		// © Шишка В.В. [28 октября 2022]  НАЧАЛО
		//!!!!!@#%$@$#%@%$#@$%@##@%$!!!!!
		//Тип реквизита может быть не только Контрагенты!
		//Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док.ГрузоПолучатель, "ПересчитатьКоличество") Тогда
		Если ТипЗнч(Док.ГрузоПолучатель) = Тип("СправочникСсылка.Контрагенты")
			И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док.ГрузоПолучатель, "ПересчитатьКоличество") Тогда
		// © Шишка В.В. [28 октября 2022]  КОНЕЦ
		//--------------------------------------------------------------------------
		
			Документы.РС_ЭлектроннаяНакладная.ПересчитатьКоличествоИзДополнительнойЕдиницыИзмеренияВОсновнуюЕдиницуИзмерения(Док.Товары);
		КонецЕсли;
		// Олег Литвиненко <---
		
		// Олег Литвиненко 22.09.22 --->
		Если Не Док.Товары.Найти(Истина, "ЭтоПодарок")=Неопределено Тогда
			Док.Комментарий = "უსასყიდლო რეალიზაცია";
			Док.КомментарийТН = "უსასყიდლო რეალიზაცია";
		КонецЕсли;
		// Олег Литвиненко <---
		
		Если ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
			Док.ТранспортноеСредство = ТранспортноеСредство;
			Док.ГосНомерАвтомобиля =  ТранспортноеСредство.Код;
		КонецЕсли;
		Если ЗначениеЗаполнено(Водитель) Тогда 
			Док.Водитель = Водитель;
			Док.НомерУдостоверения =  Водитель.ИНН;
		КонецЕсли;
		
		Док.Записать(РежимЗаписиДокумента.Запись);
		Сообщить("დოკუმენტი: " + Док + " 	ჩაწერილია!");
		
		СтрокаСписокНологовое = СписокНологовое.Добавить();
		СтрокаСписокНологовое.Ссылка = Док.Ссылка;
		СтрокаСписокНологовое.Дата   = Док.Дата;
		СтрокаСписокНологовое.Автор  = Док.Автор;
		СтрокаСписокНологовое.Номер  = Док.Номер;
		СтрокаСписокНологовое.Создать  = Истина;
		
		БылаСоздана = Истина; 
		
	КонецЕсли;
	
	ЭлНакладная = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(ДокПерем);
	Если Не ЗначениеЗаполнено(ЭлНакладная) И ЗначениеЗаполнено(ДокПерем) Тогда
		Док = Документы.РС_ЭлектроннаяНакладная.СоздатьДокумент();
		
		Док.Заполнить(ДокПерем);
		Док.Дата = ТекущаяДата();
		
		Если ЗначениеЗаполнено(ЭтотОбъект.НачалнаяДатаТранспортировки) Тогда 
			Док.ДатаНачалаТранспортировки = ЭтотОбъект.НачалнаяДатаТранспортировки;
		Иначе  Док.ДатаНачалаТранспортировки = ТекущаяДата();
		КонецЕсли;
		Док.Товары.Загрузить(ДокПерем.Запасы.Выгрузить());
		НоваяСтрока = Док.ДокументыОснования.Добавить();
		НоваяСтрока.ДокументОснование = ДокПерем;
		Док.СформироватьТаблицуЭлНакладных();
				
		Для х = 0 по Док.Товары.Количество() - 1 Цикл
			Док.Товары[х].Количество = ДокПерем.Запасы[х].Количество;
			Док.Товары[х].Цена = ДокПерем.Запасы[х].СуммаЗаказа / ДокПерем.Запасы[х].Количество;
			Док.Товары[х].Сумма = ДокПерем.Запасы[х].СуммаЗаказа;
			Док.Товары[х].СуммаНДС = Окр(Док.Товары[х].Сумма * Док.Товары[х].СтавкаНДС.Ставка/(100 + Док.Товары[х].СтавкаНДС.Ставка), 2);
		КонецЦикла;
		
		// Олег Литвиненко 12.10.22 --->
		Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Док.ГрузоПолучатель, "ПересчитатьКоличество") Тогда
			Документы.РС_ЭлектроннаяНакладная.ПересчитатьКоличествоИзДополнительнойЕдиницыИзмеренияВОсновнуюЕдиницуИзмерения(Док.Товары);
		КонецЕсли;
		// Олег Литвиненко <---
		
		Если ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
			Док.ТранспортноеСредство = ТранспортноеСредство;
			Док.ГосНомерАвтомобиля =  ТранспортноеСредство.Код;
		КонецЕсли;
		Если ЗначениеЗаполнено(Водитель) Тогда 
			Док.Водитель = Водитель;
			Док.НомерУдостоверения =  Водитель.ИНН;
		КонецЕсли;
		
		Док.Записать(РежимЗаписиДокумента.Запись);
		Сообщить("დოკუმენტი: " + Док + " 	ჩაწერილია!");
		
		СтрокаСписокНологовое = СписокНологовое.Добавить();
		СтрокаСписокНологовое.Ссылка = Док.Ссылка;
		СтрокаСписокНологовое.Дата   = Док.Дата;
		СтрокаСписокНологовое.Автор  = Док.Автор;
		СтрокаСписокНологовое.Номер  = Док.Номер;
		СтрокаСписокНологовое.Создать  = Истина;
		
		

		БылаСоздана = Истина; 
	КонецЕсли;
	Если НЕ БылаСоздана тогда
		Попытка
			Сообщить("ელექტორნული დოკუმენტი უკვე არსებობს, ნომერი: " + ЭлНакладная.Номер);
			Возврат ЭлНакладная
		Исключение
		КонецПопытки;
	КонецЕсли;
	Если БылаСоздана Тогда
		Возврат Док.Ссылка;
	КонецЕсли;

КонецФункции

&НаКлиенте
Процедура работатьТН(Команда)
	
	Если Элементы.Группа1.ТекущаяСтраница.Имя = "НалоговыеДокументы" Тогда 
		//Если ЗначениеЗаполнено(Водитель) Или ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
		//	изменитьТоварнуюНакладную(СписокНологовое);
		//КонецЕсли;
		
		Для Каждого Документ Из СписокНологовое Цикл
			Если Документ.Создать Тогда 
				ТекОбъект = ПолучитьФорму("Документ.РС_ЭлектроннаяНакладная.Форма.ФормаДокумента", Новый Структура("Ключ", Документ.Ссылка));
				ТекОбъект.СоздатьТН(Команда);
			КонецЕсли;
		КонецЦикла;
	
	ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "ПриходнаяНакладная" Тогда
		//Если ЗначениеЗаполнено(Водитель) Или ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
		//	изменитьТоварнуюНакладную(СписокПриходнаяНакладная);
		//КонецЕсли;
		
		Для Каждого Документ Из СписокПриходнаяНакладная Цикл
			Если Документ.Создать Тогда 
				ТекОбъект = ПолучитьФорму("Документ.РС_ЭлектроннаяНакладная.Форма.ФормаДокумента", Новый Структура("Ключ", Документ.ДокЭлНакл));
				ТекОбъект.СоздатьТН(Команда);
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "РасходнаяНакладная" Тогда
		//Если ЗначениеЗаполнено(Водитель) Или ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
		//	изменитьТоварнуюНакладную(СписокРасходнаяНакладная);
		//КонецЕсли;
		
		Для Каждого Документ Из СписокРасходнаяНакладная Цикл
			Если Документ.Печать Тогда 
				ТекОбъект = ПолучитьФорму("Документ.РС_ЭлектроннаяНакладная.Форма.ФормаДокумента", Новый Структура("Ключ", Документ.ДокЭлНакл));
				ТекОбъект.СоздатьТН(Команда);
			КонецЕсли;
		КонецЦикла;	
		
	ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "Возврат" Тогда		
		СписокТТН = СписокВозврат.НайтиСтроки(Новый Структура("СоздатьТТН",Истина));	
		Для Каждого Стр Из СписокТТН Цикл
			Если ЗначениеЗаполнено(Стр.ДокЭлНакл) Тогда			
				ТекОбъект = ПолучитьФорму("Документ.РС_ЭлектроннаяНакладная.Форма.ФормаДокумента", Новый Структура("Ключ", Стр.ДокЭлНакл));
				ТекОбъект.СоздатьТН(Команда);
			КонецЕсли;
		КонецЦикла;	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [18 августа 2022]  НАЧАЛО
	ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "ЭлектронныеНакладные" Тогда		
		СписокТТН = СписокЭлектронныеДокументы.НайтиСтроки(Новый Структура("Создать",Истина));	
		Для Каждого Стр Из СписокТТН Цикл
			Если ЗначениеЗаполнено(Стр.Ссылка) Тогда			
				
				Если Стр.Водитель <> Водитель И ЗначениеЗаполнено(Водитель)
					ИЛИ Стр.ТранспортноеСредство <> ТранспортноеСредство И ЗначениеЗаполнено(ТранспортноеСредство)
					Тогда
					
					ЗаменитьВодителяТранспортноеСредствоВЭН(Стр.Ссылка, Водитель, ТранспортноеСредство);
					
				КонецЕсли;
				
				ТекОбъект = ПолучитьФорму("Документ.РС_ЭлектроннаяНакладная.Форма.ФормаДокумента", Новый Структура("Ключ", Стр.Ссылка));
				

				ТекОбъект.СоздатьТН(Команда);
			КонецЕсли;
		КонецЦикла;	
	// © Шишка В.В. [18 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	КонецЕсли;
	
	Если Элементы.Группа1.ТекущаяСтраница.Имя = "ВидСписокПеремещений" Тогда
		//Если ЗначениеЗаполнено(Водитель) Или ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
		//	изменитьТоварнуюНакладную(СписокПеремещений);
		//КонецЕсли;
		
		Для Каждого Стр Из СписокПеремещений Цикл 
			//Если ПроверитьФункционалРезерва() Тогда
			
			Если Стр.Создать Тогда
				ТекОбъект = ПолучитьФорму("Документ.РС_ЭлектроннаяНакладная.Форма.ФормаДокумента", Новый Структура("Ключ", Стр.ДокЭлНакл));
				ТекОбъект.СоздатьТН(Команда); 
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
		
	
	
