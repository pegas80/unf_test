	// © Шишка В.В. [14 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	МассивЗаказов = Новый Массив;	
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [14 июля 2022]  НАЧАЛО
	//Для Каждого стр Из СписокПеремещений Цикл 
	//	
	//	Если стр.Создать Тогда 
	Для Каждого стр Из ЭтотОбъект[ИмяСписка] Цикл 
		
		Если  стр[?(ИмяСписка = "СписокРасходнаяНакладная", "Печать", "Создать")] Тогда 
