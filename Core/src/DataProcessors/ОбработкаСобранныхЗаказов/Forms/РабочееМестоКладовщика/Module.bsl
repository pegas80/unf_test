Функция СформироватьСуммуПрописьюБезЦифр(Сумма, Валюта)
	
	//Если Валюта.ПараметрыПрописи = "" Тогда
	//	Возврат ФорматСумм(Сумма);                           
	//Иначе                                          		
	Если Валюта.ПараметрыПрописиНаРусском = "" Тогда
		Возврат ФорматСумм(Сумма);
	Иначе
		лСтрока = СтрЗаменить(Валюта.ПараметрыПрописиНаРусском, ",", Символы.ПС);
		ФормСтрока = "Л = ka_RU; ДП = Истина";				
		ПараметрыПрописи = СтрПолучитьСтроку(лСтрока, 1) + ", " + СтрПолучитьСтроку(лСтрока, 5);
		Возврат ЧислоПрописью(Сумма, ФормСтрока, ПараметрыПрописи);
	КонецЕсли;
	//КонецЕсли;                                          
	
КонецФункции
Функция ФорматСумм(Сумма, Валюта = Неопределено, ЧН = "", ЧРГ = "")
	
	ФорматнаяСтрока = "ЧЦ=15;ЧДЦ=2" +
	?(ПустаяСтрока(ЧН), "", ";" + "ЧН=" + ЧН) +
	?(ПустаяСтрока(ЧРГ),"", ";" + "ЧРГ=" + ЧРГ);
	РезультирующаяСтрока = СокрЛ(Формат(Сумма, ФорматнаяСтрока));
	
	Если Валюта <> Неопределено Тогда
		РезультирующаяСтрока = РезультирующаяСтрока + " " + СокрП(Валюта);		
	КонецЕсли;
	
	
	
	Возврат РезультирующаяСтрока;
	
КонецФункции

