&НаКлиенте
Процедура печать(Команда)
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [14 июля 2022]  НАЧАЛО
	//Если ЗначениеЗаполнено(СписокПеремещений) Тогда 
	//	ТабДок = печатьНаСервере();	
	//	ТабДок.Показать();
	//Иначе Сообщить("შეკვეთების ცხრილი ცარიელია");
	//	
	//КонецЕсли;
	ТекущаяСтраница = Элементы.Группа1.ТекущаяСтраница;
	ИмяТаблицы = "";
	ИмяСписка = "";
	Если ТекущаяСтраница.Имя = "ВидСписокПеремещений" Тогда
	
		Если НЕ ЗначениеЗаполнено(СписокПеремещений) Тогда 
		
			Сообщить("შეკვეთების ცხრილი ცარიელია");
			Возврат;
			
		КонецЕсли;
		ИмяТаблицы = "ЗаказПокупателя";
		ИмяСписка = "СписокПеремещений";
		
	ИначеЕсли ТекущаяСтраница.Имя = "РасходнаяНакладная" Тогда
	
		Если НЕ ЗначениеЗаполнено(СписокРасходнаяНакладная) Тогда 
		
			Сообщить("შეკვეთების ცხრილი ცარიელია");
			Возврат;
			
		КонецЕсли;
		ИмяТаблицы = "РасходнаяНакладная";
		ИмяСписка = "СписокРасходнаяНакладная";
		
	ИначеЕсли ТекущаяСтраница.Имя = "ПриходнаяНакладная" Тогда
	
		Если НЕ ЗначениеЗаполнено(СписокПриходнаяНакладная) Тогда 
		
			Сообщить("შეკვეთების ცხრილი ცარიელია");
			Возврат;
			
		КонецЕсли;
		ИмяТаблицы = "ПриходнаяНакладная";
		ИмяСписка = "СписокПриходнаяНакладная";
		
	ИначеЕсли ТекущаяСтраница.Имя = "Возврат" Тогда
	
		Если НЕ ЗначениеЗаполнено(СписокВозврат) Тогда 
		
			Сообщить("შეკვეთების ცხრილი ცარიელია");
			Возврат;
			
		КонецЕсли;
		//ИмяТаблицы = "ЗаказНаВозврат";
		ИмяТаблицы = "ПриходнаяНакладная";//Lazare 25.07.2022
		ИмяСписка = "СписокВозврат";
	
	КонецЕсли; 
	ТабДок = печатьНаСервере(ИмяТаблицы, ИмяСписка);	
	ТабДок.Показать();
	// © Шишка В.В. [14 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	
КонецПроцедуры

