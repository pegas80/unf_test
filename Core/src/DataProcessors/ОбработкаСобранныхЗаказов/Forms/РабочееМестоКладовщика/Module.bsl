Процедура изменитьТоварнуюНакладную(Список)
	
	Для Каждого Документ Из Список Цикл
		
		ДокументОбъект=Документ.Ссылка.ПолучитьОбъект();
		Если ЗначениеЗаполнено(Водитель) Тогда 
			ДокументОбъект.Водитель = Водитель;
			ДокументОбъект.НомерУдостоверения = Водитель.ИНН;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
			ДокументОбъект.ТранспортноеСредство = ТранспортноеСредство;
			ДокументОбъект.ГосНомерАвтомобиля =  ТранспортноеСредство.Код;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НачалнаяДатаТранспортировки) Тогда 
			ДокументОбъект.ДатаНачалаТранспортировки = НачалнаяДатаТранспортировки;
		КонецЕсли;
		
		ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
		
	КонецЦикла;
	
	
КонецПроцедуры

&НаКлиенте
Функция печатьТоварных()
	
	табДок = Новый Массив;
	
	имя= ЭтаФорма.Элементы.Группа1.ТекущаяСтраница.Имя;
	

	Если имя = "НалоговыеДокументы" И ЗначениеЗаполнено(СписокНологовое)Тогда 
		//
		Для Каждого документПечати Из СписокНологовое Цикл 
			Если документПечати.Создать Тогда 
				табДок.Добавить(печатьТоварныхНаСервере(документПечати.Ссылка));
			КонецЕсли;
		КонецЦикла;	
		
	ИначеЕсли имя = "РасходнаяНакладная" Тогда 
		
		Для Каждого документПечати Из СписокРасходнаяНакладная Цикл 
			
			Если документПечати.Печать Тогда 
				табДок.Добавить(печатьТоварныхНаСервере(документПечати.ДокЭлНакл));
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли имя = "ПриходнаяНакладная" Тогда 
		
		Для Каждого документПечати Из СписокПриходнаяНакладная Цикл 
			
			Если документПечати.Создать Тогда 
				табДок.Добавить(печатьТоварныхНаСервере(документПечати.ДокЭлНакл));
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли имя = "ВидСписокПеремещений" Тогда
		
		Для Каждого документПечати Из СписокПеремещений Цикл
			
			Если документПечати.Создать Тогда
				табДок.Добавить(печатьТоварныхНаСервере(документПечати.ДокЭлНакл));
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли имя = "Возврат" Тогда
		Для Каждого документПечати Из СписокВозврат Цикл 
			
			Если документПечати.Создать Тогда 
				табДок.Добавить(печатьТоварныхНаСервере(документПечати.ДокЭлНакл));
			КонецЕсли;
		КонецЦикла;
		
	//--------------------------------------------------------------------------
	// © Шишка В.В. [18 августа 2022]  НАЧАЛО
	ИначеЕсли имя = "ЭлектронныеНакладные" Тогда
		Для Каждого документПечати Из СписокЭлектронныеДокументы Цикл 
			
			Если документПечати.Создать Тогда 
				табДок.Добавить(печатьТоварныхНаСервере(документПечати.Ссылка));
			КонецЕсли;
		КонецЦикла;
	// © Шишка В.В. [18 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
		
	КонецЕсли;
	
	финальныйТабДок = возврашатьФинальныйТабдок(ТабДок);
	
	финальныйТабДок.Показать();
	
	
	//Если ЗначениеЗаполнено(табДок) Тогда 
	//	
	//	Для  Каждого стр Из табДок Цикл 
	//		стр.Показать();
	//	КонецЦикла;
	//	
	//КонецЕсли;
	//
	//
	
	
