		|	И РасходнаяНакладная.ВидОперации = &ВидОперации
		|	И РасходнаяНакладная.Дата МЕЖДУ &ДатаНач И &ДатаКон
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	втНакладные.Ссылка КАК Ссылка,
		|	втНакладные.Дата КАК Дата,
		|	втНакладные.Контрагент КАК Контрагент,
		|	втНакладные.Договор КАК Договор,
		|	втНакладные.ТорговыйПредставитель КАК ТорговыйПредставитель,
		|	втНакладные.Водитель КАК Водитель,
		|	втНакладные.Ответственный КАК Ответственный,
		|	МАКСИМУМ(ЕСТЬNULL(РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка, ЗНАЧЕНИЕ(Документ.РС_ЭлектроннаяНакладная.ПустаяСсылка))) КАК ДокЭлНакл
		|ИЗ
		|	втНакладные КАК втНакладные
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
		|		ПО (НЕ РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.ПометкаУдаления)
		|			И (РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование ССЫЛКА Документ.РасходнаяНакладная)
		|			И (втНакладные.Ссылка = ВЫРАЗИТЬ(РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование КАК Документ.РасходнаяНакладная).Ссылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	втНакладные.Ссылка,
		|	втНакладные.Дата,
		|	втНакладные.Контрагент,
		|	втНакладные.Договор,
		|	втНакладные.ТорговыйПредставитель,
		|	втНакладные.Водитель,
		|	втНакладные.Ответственный";
		
		Запрос.УстановитьПараметр("ФильтрТорговойТочки", ФильтрТорговойТочкиРасходнаяНакладная);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВидОперации", ВидОперации);
	//--------------------------------------------------------------------------
	// © Шишка В.В. [12 июля 2022]  НАЧАЛО
	Если ЗначениеЗаполнено(ФильтрТорговыйПредставительРасходнаяНакладная)
		ИЛИ ЗначениеЗаполнено(ФильтрВодительРасходнаяНакладная)
		Тогда
		
		ТекстДопФильтр = "";
		Если ЗначениеЗаполнено(ФильтрТорговыйПредставительРасходнаяНакладная) Тогда
			
			ТекстДопФильтр = "РасходнаяНакладная.Ответственный = &ТорговыйПредставитель";
			Запрос.УстановитьПараметр("ТорговыйПредставитель", ФильтрТорговыйПредставительРасходнаяНакладная);
			
		КонецЕсли; 
		Если ЗначениеЗаполнено(ФильтрВодительРасходнаяНакладная) Тогда
			
			ТекстДопФильтр = ТекстДопФильтр + ?(ПустаяСтрока(ТекстДопФильтр), "", " И ") + "РасходнаяНакладная.Договор.Водитель = &Водитель";
			Запрос.УстановитьПараметр("Водитель", ФильтрВодительРасходнаяНакладная);
			
		КонецЕсли; 
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ", "ГДЕ" + Символы.ПС + ТекстДопФильтр + " И ");
		
