		ОбластьШапки = Макет.ПолучитьОбласть("ШапкаВодитель");
		ОбластьШапки.Параметры.Водитель = мВодитель;
		ТабличныйДокумент.Вывести(ОбластьШапки);
	
	КонецЕсли; 	
	ОбластьШапки = Макет.ПолучитьОбласть("ШапкаОтступ");
	ТабличныйДокумент.Вывести(ОбластьШапки);
	// © Шишка В.В. [14 июля 2022]  КОНЕЦ
