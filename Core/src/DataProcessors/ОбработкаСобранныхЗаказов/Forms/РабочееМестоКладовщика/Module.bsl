&НаСервере
Функция ПолучитьСреднееЗначениеСебестоимости(СтруктураДанные, Цена, Док) //+++ Дмгг

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыОстатки.Организация КАК Организация,
		|	ЗапасыОстатки.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ЗапасыОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыОстатки.Характеристика КАК Характеристика,
		|	ЗапасыОстатки.Партия КАК Партия,
		|	ЗапасыОстатки.ЗаказПокупателя КАК ЗаказПокупателя,
		|	ЗапасыОстатки.СчетУчетаРегл КАК СчетУчетаРегл,
		|	ЗапасыОстатки.КоличествоОстаток КАК КоличествоОстаток,
		|	ЗапасыОстатки.СуммаОстаток КАК СуммаОстаток
		|ПОМЕСТИТЬ ВременнаяТаблицаОстатки
		|ИЗ
		|	РегистрНакопления.Запасы.Остатки(
		|			&МоментКонтроля,
		|			Организация = &Организация
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|				И СчетУчетаРегл = &СчетУчетаРегл
		|				И Номенклатура = &Номенклатура
		|				И Характеристика = &Характеристика) КАК ЗапасыОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗапасыОстаткиИОбороты.Организация КАК Организация,
		|	ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница КАК СтруктурнаяЕдиница,
		|	ЗапасыОстаткиИОбороты.Номенклатура КАК Номенклатура,
		|	ЗапасыОстаткиИОбороты.Характеристика КАК Характеристика,
		|	ЗапасыОстаткиИОбороты.СчетУчетаРегл КАК СчетУчетаРегл,
		|	СУММА(ЗапасыОстаткиИОбороты.КоличествоОборот) КАК КоличествоОборот,
		|	СУММА(ЗапасыОстаткиИОбороты.СуммаОборот) КАК СуммаОборот
		|ПОМЕСТИТЬ ВременнаяТаблицаОбороты
		|ИЗ
		|	РегистрНакопления.Запасы.ОстаткиИОбороты(
		|			НАЧАЛОПЕРИОДА(&МоментКонтроля, МЕСЯЦ),
		|			&МоментКонтроля,
		|			Регистратор,
		|			,
		|			Организация = &Организация
		|				И СтруктурнаяЕдиница = &СтруктурнаяЕдиница
		|				И СчетУчетаРегл = &СчетУчетаРегл
		|				И Номенклатура = &Номенклатура
		|				И Характеристика = &Характеристика) КАК ЗапасыОстаткиИОбороты
		|ГДЕ
		|	ЗапасыОстаткиИОбороты.СуммаОборот = 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыОстаткиИОбороты.Организация,
		|	ЗапасыОстаткиИОбороты.СтруктурнаяЕдиница,
		|	ЗапасыОстаткиИОбороты.Номенклатура,
		|	ЗапасыОстаткиИОбороты.Характеристика,
		|	ЗапасыОстаткиИОбороты.СчетУчетаРегл
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ЕСТЬNULL(ВременнаяТаблицаОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(ВременнаяТаблицаОбороты.КоличествоОборот, 0)), 0) КАК КоличествоОстаток,
		|	ЕСТЬNULL(СУММА(ЕСТЬNULL(ВременнаяТаблицаОстатки.СуммаОстаток, 0) - ЕСТЬNULL(ВременнаяТаблицаОбороты.СуммаОборот, 0)), 0) КАК СуммаОстаток
		|ИЗ
		|	ВременнаяТаблицаОстатки КАК ВременнаяТаблицаОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблицаОбороты КАК ВременнаяТаблицаОбороты
		|		ПО ВременнаяТаблицаОстатки.Организация = ВременнаяТаблицаОбороты.Организация
		|			И ВременнаяТаблицаОстатки.СтруктурнаяЕдиница = ВременнаяТаблицаОбороты.СтруктурнаяЕдиница
		|			И ВременнаяТаблицаОстатки.Номенклатура = ВременнаяТаблицаОбороты.Номенклатура
		|			И ВременнаяТаблицаОстатки.Характеристика = ВременнаяТаблицаОбороты.Характеристика
		|			И ВременнаяТаблицаОстатки.СчетУчетаРегл = ВременнаяТаблицаОбороты.СчетУчетаРегл";
	
	Запрос.УстановитьПараметр("МоментКонтроля", ?(ЗначениеЗаполнено(Док.Дата), Док.Дата-1, ТекущаяДата()-1));
	Запрос.УстановитьПараметр("Номенклатура", СтруктураДанные.Номенклатура);
	Запрос.УстановитьПараметр("Организация", Док.Организация);
	Запрос.УстановитьПараметр("СтруктурнаяЕдиница", Док.СтруктурнаяЕдиница);
	Запрос.УстановитьПараметр("СчетУчетаРегл", СтруктураДанные.Номенклатура.СчетУчетаЗапасовРегл);
	Запрос.УстановитьПараметр("Характеристика", СтруктураДанные.Характеристика);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.КоличествоОстаток = 0 Тогда 
			СебестоимостьЕдиницы = 0;
		Иначе
			СебестоимостьЕдиницы = ВыборкаДетальныеЗаписи.СуммаОстаток / ВыборкаДетальныеЗаписи.КоличествоОстаток;
		КонецЕсли;
		Цена = СебестоимостьЕдиницы;
	КонецЦикла;
	Возврат Цена;
КонецФункции

&НаСервере
Функция НайтиВизитПоВозврату(Ссылка) //++giga
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Визит.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.Визит КАК Визит
	|ГДЕ
	|	Визит.Номер = &Номер
	//--------------------------------------------------------------------------
	// © Шишка В.В. [11 июля 2022]  НАЧАЛО
	|	И  НАЧАЛОПЕРИОДА(Визит.Дата, ГОД) = НАЧАЛОПЕРИОДА(&Дата, ГОД)
	// © Шишка В.В. [11 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	|";
	
	Запрос.УстановитьПараметр("Номер", Ссылка.НомерВходящегоДокумента);
	//--------------------------------------------------------------------------
	// © Шишка В.В. [11 июля 2022]  НАЧАЛО
	Запрос.УстановитьПараметр("Дата", Ссылка.Дата);
	// © Шишка В.В. [11 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи;	
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

