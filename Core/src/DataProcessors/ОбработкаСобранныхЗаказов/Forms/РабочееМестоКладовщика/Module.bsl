&НаСервере
Процедура ПолучитьТекстУсловийЭН(Запрос)

	ТекстУсловий = "";
	Если ЗначениеЗаполнено(ДатаНач) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.Дата >= &ДатаНач";
		Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ДатаКон) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.Дата <= &ДатаКон";
		Запрос.УстановитьПараметр("ДатаКон", ДатаКон);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрТипТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.ТипТН = &ТипТН";
		Запрос.УстановитьПараметр("ТипТН", ФильтрТипТН);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрСтатусТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.СтатусТН = &СтатусТН";
		Запрос.УстановитьПараметр("СтатусТН", ФильтрСтатусТН);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрВидТранспортировкиТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.ВидТранспортировки = &ВидТранспортировки";
		Запрос.УстановитьПараметр("ВидТранспортировки", ФильтрВидТранспортировкиТН);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрВодительТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.Водитель = &Водитель";
		Запрос.УстановитьПараметр("Водитель", ФильтрВодительТН);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрГрузоотправительТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.ГрузоОтправитель = &ГрузоОтправитель";
		Запрос.УстановитьПараметр("ГрузоОтправитель", ФильтрГрузоотправительТН);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрГрузоПолучательТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.ГрузоПолучатель = &ГрузоПолучатель";
		Запрос.УстановитьПараметр("ГрузоПолучатель", ФильтрГрузоПолучательТН);
	
	КонецЕсли; 
	Если ЗначениеЗаполнено(ФильтрТранспортноеСредствоТН) Тогда
	
		ТекстУсловий = ТекстУсловий + Символы.ПС + " И РС_ЭлектроннаяНакладная.ТранспортноеСредство = &ТранспортноеСредство";
		Запрос.УстановитьПараметр("ТранспортноеСредство", ФильтрТранспортноеСредствоТН);
	
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + Символы.ПС + ТекстУсловий;

КонецПроцедуры // ПолучитьТекстУсловийЭН()

&НаКлиенте
