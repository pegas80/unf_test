			Док.СтруктурнаяЕдиница = Визит.Ссылка.СтруктурнаяЕдиницаДляВозврата; 
		
		Иначе
		
			Док.СтруктурнаяЕдиница = Визит.Ссылка.СтруктурнаяЕдиница; 
		
		КонецЕсли; 	
		Док.ДокументВизита = Визит.Ссылка;
		// © Шишка В.В. [10 июля 2022]  КОНЕЦ
		//--------------------------------------------------------------------------
		Док.Ответственный = Визит.Ссылка.Ответственный; 
	КонецЕсли;
	
	Док.Запасы.Загрузить(Ссылка.Запасы.Выгрузить());
	Для каждого строка из Док.Запасы цикл
		Строка.ЕдиницаИзмерения = Строка.Номенклатура.ЕдиницаИзмерения;
		Строка.СтавкаНДС = Строка.Номенклатура.СтавкаНДС;
		//Строка.СуммаНДС = Окр(Строка.Сумма - Строка.Сумма*((100-Строка.Номенклатура.СтавкаНДС.Ставка)/100), 2);
		РассчитатьСуммуНДС(строка,Док); //+Lazare 02.03.2023

		Строка.Всего = Строка.Сумма;
		
		СтруктураДанные = Новый Структура;
		СтруктураДанные.Вставить("ДатаОбработки",	 Док.Дата);
		СтруктураДанные.Вставить("МоментКонтроля", ?(ЗначениеЗаполнено(Док.Дата), Док.Дата-1, ТекущаяДата()-1));
		СтруктураДанные.Вставить("ВалютаДокумента",  Док.ВалютаДокумента);
		СтруктураДанные.Вставить("Номенклатура", Строка.Номенклатура);
		СтруктураДанные.Вставить("СуммаВключаетНДС", Док.СуммаВключаетНДС);
		СтруктураДанные.Вставить("Характеристика", Строка.Характеристика);
		СтруктураДанные.Вставить("СчетУчетаРегл", Строка.Номенклатура.СчетУчетаЗапасовРегл);
		СтруктураДанные.Вставить("СтруктурнаяЕдиница", Док.СтруктурнаяЕдиница);
		СтруктураДанные.Вставить("Организация", Док.Организация);
		СтруктураДанные.Вставить("ВидЦен",Док.ВидЦен);
		СтруктураДанные.Вставить("Коэффициент", 1);  
		//СтруктураДанные.Удалить("ВидЦенКонтрагента");
		
		Если НЕ ЗначениеЗаполнено(Док.Дата) Тогда
			ДатаДокумента = ТекущаяДата();
			ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ТекущаяДата()); //+++ Дмгг
	    Иначе
			ИспользоватьТолькоРегламентированныйПланСчетов = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(Док.Дата);
		КонецЕсли;
		
		цена = 0;
		цена = ПолучитьСреднееЗначениеСебестоимости(СтруктураДанные, Цена, Док);
		Строка.СебестоимостьЕдиницы = цена;
		Строка.Себестоимость = Цена * Строка.Количество;
	
	КонецЦикла;
	
	Док.ДокументОснование = Ссылка;
	док.Договор = Ссылка.Договор;
	
	Док.Контрагент = Ссылка.Контрагент;
	
	Док.ВидОперации = ВидОперации;

	//Док.Дистрибуция_ЗаполнитьПродажамиНаСервере();
	//--------------------------------------------------------------------------
	// © Шишка В.В. [30 октября 2023]  НАЧАЛО
	//Док.Записать(РежимЗаписиДокумента.Проведение);
	//Сообщить("დოკუმენტი: " + Док + " 	შექმნილია!");
	Попытка
		
		Док.Записать(РежимЗаписиДокумента.Проведение);
		Сообщить("დოკუმენტი: " + Док + " 	შექმნილია!");
		
		
	Исключение
	
		ТекстОшибки = ОписаниеОшибки();
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ТекстОшибки + Символы.ПС + "დოკუმენტი: " + Док + " 	შექმნილია!";
		Сообщение.Сообщить();
		Док.Записать(РежимЗаписиДокумента.Запись);
		
	КонецПопытки;	
	// © Шишка В.В. [30 октября 2023]  КОНЕЦ
	//--------------------------------------------------------------------------
		
	СписокПриходнаяНакладная.Очистить();
	
	ЗаполнитьСписокПриходнаяНакладная();	
	
	ПриходнаяНакладная = Док.Ссылка;
	
	Возврат Док.Ссылка;
КонецФункции

Функция ПолучитьПодчиненныйПриходнаяНакладная(ДокументОснование) Экспорт

	Если Не ЗначениеЗаполнено(ДокументОснование) Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;

	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка КАК Ссылка,
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.Номер КАК Номер,
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.Дата КАК Дата
	|ИЗ
	|	Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
	|ГДЕ
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование = &ДокументОснование";
	
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Ссылка", Выборка.Ссылка);
	СтруктураВозврата.Вставить("Номер", Выборка.Номер);
	СтруктураВозврата.Вставить("Дата", Выборка.Дата);
	
	Возврат СтруктураВозврата;

КонецФункции

