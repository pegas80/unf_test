&НаСервереБезКонтекста
Процедура ЗаменитьВодителяТранспортноеСредствоВЭН(СсылкаНаДокументЭН, Водитель, ТранспортноеСредство)

	ДокументЭН = СсылкаНаДокументЭН.ПолучитьОбъект();
	ДокументЭН.ТранспортноеСредство = Неопределено;
	ДокументЭН.ГосНомерАвтомобиля = Неопределено;
	Если ДокументЭН.ТранспортноеСредство <> ТранспортноеСредство Тогда
	
		ДокументЭН.ТранспортноеСредство = Неопределено;
		ДокументЭН.ГосНомерАвтомобиля = Неопределено;
		Если ЗначениеЗаполнено(ТранспортноеСредство) Тогда
		
			ДокументЭН.ТранспортноеСредство = ТранспортноеСредство;
			ДокументЭН.ГосНомерАвтомобиля = ТранспортноеСредство.Код;
		
		КонецЕсли; 
		
	
	КонецЕсли; 
	
	Если ДокументЭН.Водитель <> Водитель Тогда
		
		ДокументЭН.Водитель = Неопределено;
		ДокументЭН.НомерУдостоверения = Неопределено;
		Если ЗначениеЗаполнено(Водитель) Тогда
		
			ДокументЭН.Водитель = Водитель;
			ДокументЭН.НомерУдостоверения = Водитель.ИНН;
		
		ИначеЕсли ЗначениеЗаполнено(ДокументЭН.ТранспортноеСредство) Тогда
			
			
			ОсновнойВодитель = ДокументЭН.ТранспортноеСредство.ОсновнойВодитель;
			Если ЗначениеЗаполнено(ОсновнойВодитель) Тогда
				ДокументЭН.Водитель 			= ОсновнойВодитель;
				ДокументЭН.НомерУдостоверения 	= ОсновнойВодитель.ИНН;
			КонецЕсли;
			
			
		КонецЕсли; 
		
	КонецЕсли;
	
	ДокументЭН.Записать();
	
КонецПроцедуры // ЗаменитьВодителяТранспортноеСредствоВЭН()

&НаСервере
Процедура РассчитатьСуммуНДС(СтрокаТабличнойЧасти,Док)
	
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);	
	СтрокаТабличнойЧасти.СуммаНДС = ?(Док.СуммаВключаетНДС, СтрокаТабличнойЧасти.Сумма - (СтрокаТабличнойЧасти.Сумма) / ((СтавкаНДС + 100) / 100),
	СтрокаТабличнойЧасти.Сумма * СтавкаНДС / 100);
	
КонецПроцедуры 
 
 
 
