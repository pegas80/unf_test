	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_ОбработкаСобранныхЗаказов_ЗаказаннаяПродукция";
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	
	
	
	ОбластьШапки = Макет.ПолучитьОбласть("Шапка");
	ОбластьЗагаловокТабличнойЧасти = Макет.ПолучитьОбласть("ЗагаловокТабличнойЧасти");
	ОбластьТабличнаяЧасть = Макет.ПолучитьОбласть("ТабличнаяЧасть");	
	//ПримерСтруктуры = Новый Структура("Номенклатура, Количество, Единицаизмирения", "reg.ru", "www.craft1c.ru", 2019);
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [14 июля 2022]  НАЧАЛО
	//Для Каждого Документ Из СписокПеремещений Цикл    
		//Если  Документ.Создать Тогда 
			//ОбластьШапки.Параметры.ДатаДокумента =Формат(Документ.Дата, "ДФ=dd.MM.yyyy");
	Для Каждого Документ Из ЭтотОбъект[ИмяСписка] Цикл    
		Если  Документ[?(ИмяСписка = "СписокРасходнаяНакладная", "Печать", "Создать")] Тогда 
	// © Шишка В.В. [14 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
			//ОбластьШапки.Параметры.ДатаДокумента =Формат(Документ.Ссылка.Дата, "ДФ=dd.MM.yyyy");
			ОбластьШапки.Параметры.ДатаДокумента =Формат(?(ИмяСписка = "СписокВозврат",Документ.ПриходнаяНакладная.Ссылка.Дата,Документ.Ссылка.Дата), "ДФ=dd.MM.yyyy"); //Lazare 25.07.2022

			//--------------------------------------------------------------------------
			// © Шишка В.В. [14 июля 2022]  НАЧАЛО
			//склад = Документ.Ссылка.ДокументВизита.СтруктурнаяЕдиница;
			склад = ?(ИмяСписка = "СписокПеремещений", Документ.Ссылка.ДокументВизита.СтруктурнаяЕдиница, ?(ИмяСписка = "СписокВозврат",Документ.ПриходнаяНакладная.СтруктурнаяЕдиница,Документ.Ссылка.СтруктурнаяЕдиница)); //Lazare 25.07.2022
			// © Шишка В.В. [14 июля 2022]  КОНЕЦ
			//--------------------------------------------------------------------------
			//Ответственный = Документ.Ссылка.Ответственный;
			//ТипТорговойТочки = Документ.Ссылка.Договор.ВидТорговойТочки;
			Ответственный = ?(ИмяСписка = "СписокВозврат",Документ.ПриходнаяНакладная.Ответственный,Документ.Ссылка.Ответственный); //Lazare 25.07.2022
			ТипТорговойТочки = ?(ИмяСписка = "СписокВозврат",Документ.ПриходнаяНакладная.Договор.ВидТорговойТочки,Документ.Ссылка.Договор.ВидТорговойТочки); //Lazare 25.07.2022
		
		КонецЕсли;
	КонецЦикла;	
	ОбластьШапки.Параметры.Склад = склад;
