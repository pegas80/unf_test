Процедура печатьГодность(Команда)
	
	МассивОбъектов = Новый Массив;
	Если ЗначениеЗаполнено(СписокРасходнаяНакладная) Тогда
		Для Каждого документ Из СписокРасходнаяНакладная Цикл 
			Если документ.Печать Тогда 
				МассивОбъектов.Добавить(документ.Ссылка); 
				ТабДок = печатьГодностьНаСервере(МассивОбъектов);	
				ТабДок.Показать();
			КонецЕсли;
		КонецЦикла;
	Иначе Сообщить("გასავლის ზედნადების ცხრილი ცარიელია");
		
	КонецЕсли;
	
	
	
