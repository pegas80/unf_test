	|	РасходнаяНакладная.Договор.ТорговыйПредставитель КАК ТорговыйПредставитель,
	|	РасходнаяНакладная.Договор.Водитель КАК Водитель,
	|	РасходнаяНакладная.Ответственный КАК Ответственный
	|ПОМЕСТИТЬ втНакладные
	|ИЗ
	|	Документ.РасходнаяНакладная КАК РасходнаяНакладная
	|ГДЕ
	|	РасходнаяНакладная.ВидОперации = &ВидОперации
	|	И РасходнаяНакладная.Дата МЕЖДУ &ДатаНач И &ДатаКон
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	втНакладные.Ссылка КАК Ссылка,
	|	втНакладные.Дата КАК Дата,
	|	втНакладные.Контрагент КАК Контрагент,
	|	втНакладные.Договор КАК Договор,
	|	втНакладные.ТорговыйПредставитель КАК ТорговыйПредставитель,
	|	втНакладные.Водитель КАК Водитель,
	|	втНакладные.Ответственный КАК Ответственный,
	|	МАКСИМУМ(ЕСТЬNULL(РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка, ЗНАЧЕНИЕ(Документ.РС_ЭлектроннаяНакладная.ПустаяСсылка))) КАК ДокЭлНакл
	|ИЗ
	|	втНакладные КАК втНакладные
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
	|		ПО (НЕ РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.ПометкаУдаления)
	|			И (РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование ССЫЛКА Документ.РасходнаяНакладная)
	|			И (втНакладные.Ссылка = ВЫРАЗИТЬ(РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование КАК Документ.РасходнаяНакладная).Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	втНакладные.Ссылка,
	|	втНакладные.Дата,
	|	втНакладные.Контрагент,
	|	втНакладные.Договор,
	|	втНакладные.ТорговыйПредставитель,
	|	втНакладные.Водитель,
	|	втНакладные.Ответственный";
	
	Если ФильтрТорговойТочкиРасходнаяНакладная.Наименование <> "" Тогда
		Запрос.Текст = 
		//"ВЫБРАТЬ
		//|	РасходнаяНакладная.Ссылка КАК Ссылка,
		//|	РасходнаяНакладная.Дата КАК Дата,
		//|	РасходнаяНакладная.Контрагент КАК Контрагент,
