		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
		|		ПО (НЕ РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.ПометкаУдаления)
		|			И (РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование ССЫЛКА Документ.ПриходнаяНакладная)
		|			И (втНакладные.Ссылка = ВЫРАЗИТЬ(РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование КАК Документ.ПриходнаяНакладная).Ссылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	втНакладные.Ссылка,
		|	втНакладные.Дата,
		|	втНакладные.Контрагент,
		|	втНакладные.Договор,
		|	втНакладные.ТорговыйПредставитель,
		|	втНакладные.Водитель,
		|	втНакладные.Ответственный";
		
		Запрос.УстановитьПараметр("ФильтрТорговойТочки", ФильтрТорговойТочкиПриходнаяНакладная);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВидОперации", ВидОперации);
	//--------------------------------------------------------------------------
	// © Шишка В.В. [12 июля 2022]  НАЧАЛО
	Если ЗначениеЗаполнено(ФильтрТорговыйПредставительПриходнаяНакладная)
		ИЛИ ЗначениеЗаполнено(ФильтрВодительПриходнаяНакладная)
		Тогда
		
		ТекстДопФильтр = "";
		Если ЗначениеЗаполнено(ФильтрТорговыйПредставительПриходнаяНакладная) Тогда
			
			ТекстДопФильтр = "ПриходнаяНакладная.Ответственный = &ТорговыйПредставитель";
			Запрос.УстановитьПараметр("ТорговыйПредставитель", ФильтрТорговыйПредставительПриходнаяНакладная);
			
		КонецЕсли; 
		Если ЗначениеЗаполнено(ФильтрВодительПриходнаяНакладная) Тогда
			
			ТекстДопФильтр = ТекстДопФильтр + ?(ПустаяСтрока(ТекстДопФильтр), "", " И ") + "ПриходнаяНакладная.Договор.Водитель = &Водитель";
			Запрос.УстановитьПараметр("Водитель", ФильтрВодительПриходнаяНакладная);
			
