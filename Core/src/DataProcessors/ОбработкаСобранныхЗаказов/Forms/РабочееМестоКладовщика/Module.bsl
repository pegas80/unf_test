Процедура ЗаполнитьСписокВозврат()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаказНаВозврат.Ссылка КАК Ссылка,
	|	ЗаказНаВозврат.Дата КАК Дата,
	|	ЗаказНаВозврат.Контрагент КАК Контрагент,
	|	ЗаказНаВозврат.Договор КАК Договор,
	|	ЗаказНаВозврат.Договор.ТорговыйПредставитель КАК ТорговыйПредставитель,
	|	ЗаказНаВозврат.Договор.Водитель КАК Водитель,
	|	ЗаказНаВозврат.Автор КАК Автор
	|ИЗ
	|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
	//--------------------------------------------------------------------------
	// © Шишка В.В. [14 июля 2022]  НАЧАЛО
	|	ГДЕ ИСТИНА
	// © Шишка В.В. [14 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	|";
	
	Если ФильтрТорговойТочкиВозврат.Наименование <> "" Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗаказНаВозврат.Ссылка КАК Ссылка,
		|	ЗаказНаВозврат.Дата КАК Дата,
		|	ЗаказНаВозврат.Контрагент КАК Контрагент,
		|	ЗаказНаВозврат.Договор КАК Договор,
		|	ЗаказНаВозврат.Договор.ТорговыйПредставитель КАК ТорговыйПредставитель,
		|	ЗаказНаВозврат.Договор.Водитель КАК Водитель,
		|	ЗаказНаВозврат.Автор КАК Автор
		|ИЗ
		|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
		|ГДЕ
		|   ЗаказНаВозврат.Договор.ВидТорговойТочки = &ФильтрТорговойТочки";
		
	КонецЕсли;
	
	Если (ЗначениеЗаполнено(ДатаНач) или ЗначениеЗаполнено(ДатаКон)) Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗаказНаВозврат.Ссылка КАК Ссылка,
		|	ЗаказНаВозврат.Дата КАК Дата,
		|	ЗаказНаВозврат.Контрагент КАК Контрагент,
		|	ЗаказНаВозврат.Договор КАК Договор,
		|	ЗаказНаВозврат.Договор.ТорговыйПредставитель КАК ТорговыйПредставитель,
		|	ЗаказНаВозврат.Договор.Водитель КАК Водитель,
		|	ЗаказНаВозврат.Автор КАК Автор
		|ИЗ
		|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
		|ГДЕ
		|	ЗаказНаВозврат.Дата МЕЖДУ &ДатаНач И &ДатаКон";
		
	КонецЕсли;
	
	Если ФильтрТорговойТочкиВозврат.Наименование <> "" И (ЗначениеЗаполнено(ДатаНач) или ЗначениеЗаполнено(ДатаКон)) Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЗаказНаВозврат.Ссылка КАК Ссылка,
		|	ЗаказНаВозврат.Дата КАК Дата,
		|	ЗаказНаВозврат.Контрагент КАК Контрагент,
		|	ЗаказНаВозврат.Договор КАК Договор,
		|	ЗаказНаВозврат.Договор.ТорговыйПредставитель КАК ТорговыйПредставитель,
		|	ЗаказНаВозврат.Договор.Водитель КАК Водитель,
		|	ЗаказНаВозврат.Автор КАК Автор
		|ИЗ
		|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
		|ГДЕ
		|   ЗаказНаВозврат.Договор.ВидТорговойТочки = &ФильтрТорговойТочки
		|	И ЗаказНаВозврат.Дата МЕЖДУ &ДатаНач И &ДатаКон";
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ФильтрТорговойТочки", ФильтрТорговойТочкиВозврат);

	Если НЕ ЗначениеЗаполнено(ДатаНач) Тогда
		Запрос.УстановитьПараметр("ДатаНач",НачалоДня(Дата("10000101")));
	Иначе 
		Запрос.УстановитьПараметр("ДатаНач",НачалоДня(ДатаНач));
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ДатаКон) Тогда
		Запрос.УстановитьПараметр("ДатаКон",КонецДня(ТекущаяДата()));
	Иначе 
		Запрос.УстановитьПараметр("ДатаКон",КонецДня(ДатаКон));
	КонецЕсли;
	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [12 июля 2022]  НАЧАЛО
	Если ЗначениеЗаполнено(ФильтрТорговыйПредставительВозврат)
		ИЛИ ЗначениеЗаполнено(ФильтрВодительВозврат)
		Тогда
		
		ТекстДопФильтр = "";
		Если ЗначениеЗаполнено(ФильтрТорговыйПредставительВозврат) Тогда
			
			ТекстДопФильтр = "ЗаказНаВозврат.ДокументВизита.Ответственный = &ТорговыйПредставитель";
			Запрос.УстановитьПараметр("ТорговыйПредставитель", ФильтрТорговыйПредставительВозврат);
			
		КонецЕсли; 
		Если ЗначениеЗаполнено(ФильтрВодительВозврат) Тогда
			
			ТекстДопФильтр = ТекстДопФильтр + ?(ПустаяСтрока(ТекстДопФильтр), "", " И ") + "ЗаказНаВозврат.Договор.Водитель = &Водитель";
			Запрос.УстановитьПараметр("Водитель", ФильтрВодительВозврат);
			
		КонецЕсли; 
		
		Если Найти(Врег(Запрос.Текст), "ГДЕ ИСТИНА") > 0 Тогда
		
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ ИСТИНА", "ГДЕ" + Символы.ПС + ТекстДопФильтр);
		
		Иначе
		
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ГДЕ", "ГДЕ" + Символы.ПС + ТекстДопФильтр + " И ");
		
		КонецЕсли; 
		
	КонецЕсли; 	
	// © Шишка В.В. [12 июля 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	
	СписокВозврат.Загрузить(Запрос.Выполнить().Выгрузить());
	//--------------------------------------------------------------------------
	// © Шишка В.В. [22 августа 2022]  НАЧАЛО
	МассивСтрокУдаления = Новый Массив;
	СписокСтатусов = ПолучитьСтатусыЗаявокНаВозврат(СписокВозврат.Выгрузить(, "Ссылка").ВыгрузитьКолонку("Ссылка"));
	СтруктураПоиска = Новый Структура("Ссылка"); 
	// © Шишка В.В. [22 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	
	Для Каждого стр Из СписокВозврат Цикл 
		НайденныйЭлНакладная = УправлениеНебольшойФирмойСервер.ПолучитьПодчиненныйЭлНакладная(стр.Ссылка);
		Если ЗначениеЗаполнено(НайденныйЭлНакладная) Тогда 
			стр.ДокЭлНакл = НайденныйЭлНакладная.Ссылка;
			//--------------------------------------------------------------------------
			// © Шишка В.В. [22 августа 2022]  НАЧАЛО
			стр.СтатусТН = ?(ЗначениеЗаполнено(стр.ДокЭлНакл), стр.ДокЭлНакл.СтатусТН, Перечисления.РС_СтатусыТН.НеСоздана);
			// © Шишка В.В. [22 августа 2022]  КОНЕЦ
			//--------------------------------------------------------------------------
			
		КонецЕсли;
		//--------------------------------------------------------------------------
		// © Шишка В.В. [24 августа 2022]  НАЧАЛО
		Если Не ЗначениеЗаполнено(стр.ДокЭлНакл) Тогда
		
			СтруктураПоиска.Ссылка = стр.Ссылка;
			СтрокиСтатуса = СписокСтатусов.НайтиСтроки(СтруктураПоиска);
			Если СтрокиСтатуса.Количество() Тогда
			
				ЗаполнитьЗначенияСвойств(стр, СтрокиСтатуса[0], "СтатусТН, ПриходнаяНакладная");
				Если Не ЗначениеЗаполнено(стр.ДокЭлНакл) Тогда
				
					стр.ДокЭлНакл = СтрокиСтатуса[0].ДокументЭН;
				
				КонецЕсли; 
			
			Иначе
				
				стр.СтатусТН = Перечисления.РС_СтатусыТН.НеСоздана;
				
			КонецЕсли; 
			Если ЗначениеЗаполнено(стр.СтатусТН) И НЕ (стр.СтатусТН = Перечисления.РС_СтатусыТН.Сохраненая ИЛИ стр.СтатусТН = Перечисления.РС_СтатусыТН.НеСоздана) Тогда
				
				МассивСтрокУдаления.Добавить(СписокВозврат.Индекс(стр));	
				
			КонецЕсли;
		
		КонецЕсли; 	
		// © Шишка В.В. [24 августа 2022]  КОНЕЦ
		//--------------------------------------------------------------------------
		
		
	КонецЦикла;	
	//--------------------------------------------------------------------------
	// © Шишка В.В. [22 августа 2022]  НАЧАЛО
	КоличествоУдаляемых = МассивСтрокУдаления.Количество();
	Если КоличествоУдаляемых > 0 Тогда
	
		Для Сч = 0 По КоличествоУдаляемых - 1 Цикл
			
			ТекИндекс = МассивСтрокУдаления[КоличествоУдаляемых - 1 - Сч];	
			СписокВозврат.Удалить(ТекИндекс);	
			
		КонецЦикла; 
	
	КонецЕсли; 
	// © Шишка В.В. [22 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
	
	
КонецПроцедуры

