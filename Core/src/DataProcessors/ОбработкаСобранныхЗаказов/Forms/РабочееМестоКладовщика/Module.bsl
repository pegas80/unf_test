	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.ОбработкаСобранныхЗаказов.Макет_ЗаказаннаяПродукция");
	ТабличныйДокумент = Новый ТабличныйДокумент; 	
	ТабличныйДокумент.ИмяПараметровПечати	= "ПараметрыПечати_ЗаказаннаяПродукция";
	ТабличныйДокумент.КлючПараметровПечати	= "ПАРАМЕТРЫ_ПЕЧАТИ_ОбработкаСобранныхЗаказов_ЗаказаннаяПродукция";
	ТабличныйДокумент.АвтоМасштаб			= Истина;
	
	
	
	ОбластьШапки = Макет.ПолучитьОбласть("Шапка");
	ОбластьЗагаловокТабличнойЧасти = Макет.ПолучитьОбласть("ЗагаловокТабличнойЧасти");
	ОбластьТабличнаяЧасть = Макет.ПолучитьОбласть("ТабличнаяЧасть");	
	//ПримерСтруктуры = Новый Структура("Номенклатура, Количество, Единицаизмирения", "reg.ru", "www.craft1c.ru", 2019);
	
	Для Каждого Документ Из СписокПеремещений Цикл    
		Если  Документ.Создать Тогда 
			ОбластьШапки.Параметры.ДатаДокумента =Формат(Документ.Дата, "ДФ=dd.MM.yyyy");
			склад = Документ.Ссылка.ДокументВизита.СтруктурнаяЕдиница;
		КонецЕсли;
	КонецЦикла;	
	ОбластьШапки.Параметры.Склад = склад;
	ТабличныйДокумент.Вывести(ОбластьШапки);
	ТабличныйДокумент.Вывести(ОбластьЗагаловокТабличнойЧасти);
	
	
	МассивСоздать = СписокПеремещений.Выгрузить().ВыгрузитьКолонку("Создать");
	МассивЗаказов = Новый Массив;	
	
	Для Каждого стр Из СписокПеремещений Цикл 
		
		Если стр.Создать Тогда 
			МассивЗаказов.Добавить(стр.Ссылка);
		КонецЕсли;
		
	КонецЦикла;	
	
	
	//	МассивЗаказов = СписокПеремещений.Добавить();
	//Выгрузить().;
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказПокупателяЗапасы.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказПокупателяЗапасы.Количество) КАК Количество,
	|	ЗаказПокупателяЗапасы.ЕдиницаИзмерения
	|ИЗ
	|	Документ.ЗаказПокупателя.Запасы КАК ЗаказПокупателяЗапасы
	|ГДЕ
	|	ЗаказПокупателяЗапасы.Ссылка В(&МассивЗаказов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказПокупателяЗапасы.Номенклатура,
	|	ЗаказПокупателяЗапасы.ЕдиницаИзмерения";
	
	Запрос.УстановитьПараметр("МассивЗаказов", МассивЗаказов);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	
	номерСтроки = 0;
	
	Для Каждого стр Из РезультатЗапроса Цикл 
		номерСтроки  = номерСтроки + 1;
		ОбластьТабличнаяЧасть.Параметры.НомерСтроки = номерСтроки;
		ОбластьТабличнаяЧасть.Параметры.Номенлатура = стр.Номенклатура;
		ОбластьТабличнаяЧасть.Параметры.Количество = стр.Количество;
		ОбластьТабличнаяЧасть.Параметры.ЕдиницаИзмирения = стр.ЕдиницаИзмерения;
		ТабличныйДокумент.Вывести(ОбластьТабличнаяЧасть);	
	КонецЦикла;
	
	
	ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	ТабличныйДокумент.ОтображатьСетку = Ложь;
	ТабличныйДокумент.ОтображатьЗаголовки = Ложь;
	
	Возврат ТабличныйДокумент;
	
КонецФункции


&НаСервере
Процедура изменитьТоварнуюНакладную()
	
	Для Каждого Документ Из СписокНологовое Цикл
		
		ДокументОбъект=Документ.Ссылка.ПолучитьОбъект();
		Если ЗначениеЗаполнено(Водитель) Тогда 
			ДокументОбъект.Водитель = Водитель;
			ДокументОбъект.НомерУдостоверения = Водитель.ИНН;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(ТранспортноеСредство) Тогда 
			ДокументОбъект.ТранспортноеСредство = ТранспортноеСредство;
			ДокументОбъект.ГосНомерАвтомобиля =  ТранспортноеСредство.Код;
		КонецЕсли;
		
		
		Если ЗначениеЗаполнено(НачалнаяДатаТранспортировки) Тогда 
			ДокументОбъект.ДатаНачалаТранспортировки = НачалнаяДатаТранспортировки;
		КонецЕсли;
		
		ДокументОбъект.записать(РежимЗаписиДокумента.Запись);
		
	КонецЦикла;
	
	
КонецПроцедуры

