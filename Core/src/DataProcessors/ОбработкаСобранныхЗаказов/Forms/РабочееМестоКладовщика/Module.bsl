Функция  печатьНаСервере(ИмяТаблицы = "ЗаказПокупателя", ИмяСписка = "СписокПеремещений")
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Макет = ОбработкаОбъект.ПолучитьМакет("Макет_ЗаказаннаяПродукция");
	мВодитель = Неопределено;
	Если ИмяТаблицы = "ЗаказПокупателя" Тогда
	
		мВодитель = ФильтрВодительЗаказыПокупателей;	
	
	ИначеЕсли ИмяТаблицы = "РасходнаяНакладная" Тогда
	
		мВодитель = ФильтрВодительРасходнаяНакладная;	
	
	ИначеЕсли ИмяТаблицы = "ПриходнаяНакладная" Тогда
	
		мВодитель = ФильтрВодительПриходнаяНакладная;	
	
	ИначеЕсли ИмяТаблицы = "Возврат" Тогда
	
		мВодитель = ФильтрВодительВозврат;	
		
	//ИначеЕсли ИмяТаблицы = "ЗаказНаВозврат" Тогда

	
	КонецЕсли; 
// © Шишка В.В. [14 июля 2022]  КОНЕЦ
//--------------------------------------------------------------------------
	ТабличныйДокумент = Новый ТабличныйДокумент; 	
