	//--------------------------------------------------------------------------
	// © Шишка В.В. [26 августа 2022]  НАЧАЛО
	//Док = Документы.ПриходнаяНакладная.СоздатьДокумент();
	Док = ?(ЗначениеЗаполнено(ПриходнаяНакладная), ПриходнаяНакладная.ПолучитьОбъект(), Документы.ПриходнаяНакладная.СоздатьДокумент());
	// © Шишка В.В. [26 августа 2022]  КОНЕЦ
	//--------------------------------------------------------------------------
		
	Док.Заполнить(Ссылка);
	//Док.Дата = ТекущаяДата();
	
