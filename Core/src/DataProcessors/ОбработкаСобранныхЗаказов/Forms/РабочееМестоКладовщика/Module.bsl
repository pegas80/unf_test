// © Шишка В.В. [24 августа 2022]  НАЧАЛО
&НаСервереБезКонтекста
Функция ПолучитьСтатусыЗаявокНаВозврат(СписокЗаявок)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаказНаВозврат.Ссылка КАК Ссылка,
	|	ЗаказНаВозврат.Дата КАК Дата,
	|	ЗаказНаВозврат.Контрагент КАК Контрагент,
	|	ЗаказНаВозврат.Договор КАК Договор,
	|	ЗаказНаВозврат.ДокументВизита КАК ДокументВизита
	|ПОМЕСТИТЬ ВТ_Возврат
	|ИЗ
	|	Документ.ЗаказНаВозврат КАК ЗаказНаВозврат
	|ГДЕ
	|	ЗаказНаВозврат.Ссылка В(&СписокЗаявок)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ДокументВизита
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_Возврат.Ссылка КАК Ссылка,
	|	ВТ_Возврат.Дата КАК Дата,
	|	ВТ_Возврат.Контрагент КАК Контрагент,
	|	ВТ_Возврат.Договор КАК Договор,
	|	ВТ_Возврат.ДокументВизита КАК ДокументВизита,
	|	МАКСИМУМ(ПриходнаяНакладная.Ссылка) КАК ПриходнаяНакладная
	|ПОМЕСТИТЬ ВТ_ВозвратыПН
	|ИЗ
	|	ВТ_Возврат КАК ВТ_Возврат
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
	|		ПО (ВЫБОР
	|				КОГДА ПриходнаяНакладная.ДокументВизита = ЗНАЧЕНИЕ(Документ.Визит.ПустаяСсылка)
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ВТ_Возврат.ДокументВизита = ПриходнаяНакладная.ДокументВизита
	|			КОНЕЦ)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Возврат.Ссылка,
	|	ВТ_Возврат.ДокументВизита,
	|	ВТ_Возврат.Дата,
	|	ВТ_Возврат.Контрагент,
	|	ВТ_Возврат.Договор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПриходнаяНакладная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка КАК ДокументЭН,
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.Дата КАК ДатаЭН,
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование КАК ПриходнаяНакладная
	|ПОМЕСТИТЬ ВТ_ДокументыЭН
	|ИЗ
	|	Документ.РС_ЭлектроннаяНакладная.ДокументыОснования КАК РС_ЭлектроннаяНакладнаяДокументыОснования
	|ГДЕ
	|	РС_ЭлектроннаяНакладнаяДокументыОснования.ДокументОснование В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				ВТ_ВозвратыПН.ПриходнаяНакладная КАК ПриходнаяНакладная
	|			ИЗ
	|				ВТ_ВозвратыПН КАК ВТ_ВозвратыПН)
	|	И НЕ РС_ЭлектроннаяНакладнаяДокументыОснования.Ссылка.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ВТ_ВозвратыПН.Ссылка КАК Ссылка,
	|	ВТ_ВозвратыПН.Дата КАК Дата,
	|	ВТ_ВозвратыПН.Контрагент КАК Контрагент,
	|	ВТ_ВозвратыПН.Договор КАК Договор,
	|	ВТ_ВозвратыПН.ДокументВизита КАК ДокументВизита,
	|	ВТ_ВозвратыПН.ПриходнаяНакладная КАК ПриходнаяНакладная,
	|	ЕСТЬNULL(ВТ_ВозвратыПН.ПриходнаяНакладная.СтатусТН, ЗНАЧЕНИЕ(Перечисление.РС_СтатусыТН.НеСоздана)) КАК СтатусТН,
	|	НайденныеЭН.ДокументЭН КАК ДокументЭН
	|ИЗ
	|	ВТ_ВозвратыПН КАК ВТ_ВозвратыПН
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			МАКСИМУМ(ВТ_ДокументыЭН.ДокументЭН) КАК ДокументЭН,
	|			ВТ_ДокументыЭН.ПриходнаяНакладная КАК ПриходнаяНакладная
	|		ИЗ
	|			ВТ_ДокументыЭН КАК ВТ_ДокументыЭН
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|					ВТ_ДокументыЭН.ПриходнаяНакладная КАК ПриходнаяНакладная,
	|					МАКСИМУМ(ВТ_ДокументыЭН.ДатаЭН) КАК ДатаЭН
	|				ИЗ
	|					ВТ_ДокументыЭН КАК ВТ_ДокументыЭН
	|				
	|				СГРУППИРОВАТЬ ПО
	|					ВТ_ДокументыЭН.ПриходнаяНакладная) КАК ДокументыЭН_Даты
	|				ПО ВТ_ДокументыЭН.ПриходнаяНакладная = ДокументыЭН_Даты.ПриходнаяНакладная
	|					И ВТ_ДокументыЭН.ДатаЭН = ДокументыЭН_Даты.ДатаЭН
	|					И ВТ_ДокументыЭН.ДокументЭН.СтатусТН = ДокументыЭН_Даты.ПриходнаяНакладная.СтатусТН
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ВТ_ДокументыЭН.ПриходнаяНакладная) КАК НайденныеЭН
	|		ПО ВТ_ВозвратыПН.ПриходнаяНакладная = НайденныеЭН.ПриходнаяНакладная";
	Запрос.Параметры.Вставить("СписокЗаявок", СписокЗаявок);
	ТаблицаЗаявок = Запрос.Выполнить().Выгрузить();
	ТаблицаЗаявок.Индексы.Добавить("Ссылка");
	Возврат ТаблицаЗаявок;
	
КонецФункции // ПолучитьСтатусыЗаявокНаВозврат()
 	
