	               |					КОГДА ВТ_ВыпискаКонтрагенты.operationCode = ""GIC""
	               |							И ВТ_ВыпискаКонтрагенты.debitCredit = ""1""
	               |						ТОГДА &БанковскийСчетОрганизации
	               |					КОГДА ВТ_ВыпискаКонтрагенты.operationCode <> ""GIC""
	               |							И ВТ_ВыпискаКонтрагенты.debitCredit = ""0""
	               |						ТОГДА ЕСТЬNULL(ВТ_БанковскиеСчетаКонтрагентов.Ссылка, ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка))
	               |					КОГДА ВТ_ВыпискаКонтрагенты.operationCode <> ""GIC""
	               |							И ВТ_ВыпискаКонтрагенты.debitCredit = ""1""
	               |						ТОГДА &БанковскийСчетОрганизации
	               |					ИНАЧЕ ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
	               |				КОНЕЦ
	               |		ИНАЧЕ ВТ_ВыпискаКонтрагенты.БанковскийСчетПолучателя
	               |	КОНЕЦ КАК БанковскийСчетПолучателя,
	               |	ВТ_ВыпискаКонтрагенты.ВидОперации,
	               |	ВЫБОР
	               |		КОГДА ВТ_ВыпискаКонтрагенты.debitCredit = ""1""
	               |				И ВТ_ВыпискаКонтрагенты.operationCode <> ""GIC""
	               |			ТОГДА ""Поступления""
	               |		КОГДА ВТ_ВыпискаКонтрагенты.debitCredit = ""0""
	               |				И ВТ_ВыпискаКонтрагенты.operationCode <> ""GIC""
	               |			ТОГДА ""Расходы""
	               |		КОГДА ВТ_ВыпискаКонтрагенты.operationCode = ""GIC""
	               |			ТОГДА ""Конвертации""
	               |	КОНЕЦ КАК Таблица,
	               |	ВТ_ВыпискаКонтрагенты.exchangeRate,
	               |	ВТ_ВыпискаКонтрагенты.additionalDescription,
	               |	ВТ_ВыпискаКонтрагенты.taxpayerCode,
	               |	ВТ_ВыпискаКонтрагенты.taxpayerName,
	               |	ВТ_ВыпискаКонтрагенты.paymentId,
	               |	ТаблицаНастройкиРеквПоУмолчанию.Корреспонденция,
	               |	ТаблицаНастройкиРеквПоУмолчанию.КорреспонденцияРегл,
	               |	ТаблицаНастройкиРеквПоУмолчанию.Статья,
	               |	ВТ_ВыпискаКонтрагенты.ДокументСсылка.Проведен КАК Проведен,
	               |	ВТ_ВыпискаКонтрагенты.ОбновлятьСтатус
	               |ИЗ
	               |	ВТ_ВыпискаКонтрагенты КАК ВТ_ВыпискаКонтрагенты
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_БанковскиеСчетаДляПодстановки КАК ВТ_БанковскиеСчетаКонтрагентов
	               |		ПО (ПОДСТРОКА(ВТ_ВыпискаКонтрагенты.partnerAccountNumber, 1, 22) = ПОДСТРОКА(ВТ_БанковскиеСчетаКонтрагентов.НомерСчета, 1, 22))
	               |			И (ВЫБОР
	               |				КОГДА ВТ_ВыпискаКонтрагенты.Контрагент <> ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |						ИЛИ ВТ_ВыпискаКонтрагенты.Контрагент <> ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	               |						ИЛИ ВТ_ВыпискаКонтрагенты.Контрагент <> ЗНАЧЕНИЕ(Справочник.КодыКазначейства.ПустаяСсылка)
	               |					ТОГДА ВТ_ВыпискаКонтрагенты.Контрагент = ВТ_БанковскиеСчетаКонтрагентов.Владелец
	               |				ИНАЧЕ ЛОЖЬ
	               |			КОНЕЦ)
	               |			И ВТ_ВыпискаКонтрагенты.partnerPersonalNumber = ВТ_БанковскиеСчетаКонтрагентов.ИНН
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаНастройкиРеквПоУмолчанию КАК ТаблицаНастройкиРеквПоУмолчанию
	               |		ПО ВТ_ВыпискаКонтрагенты.ВидОперации = ТаблицаНастройкиРеквПоУмолчанию.ВидОперации
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_БанковскиеСчетаДляПодстановки КАК ВТ_БанковскиеСчетаОрганизации
	               |		ПО (ПОДСТРОКА(ВТ_ВыпискаКонтрагенты.partnerAccountNumber, 1, 22) = ПОДСТРОКА(ВТ_БанковскиеСчетаОрганизации.НомерСчета, 1, 22))
	               |			И (ВЫБОР
	               |				КОГДА &Организация ССЫЛКА Справочник.Организации
	               |					ТОГДА &Организация = ВТ_БанковскиеСчетаОрганизации.Владелец
	               |				ИНАЧЕ ЛОЖЬ
	               |			КОНЕЦ)
	               |			И ВТ_ВыпискаКонтрагенты.partnerPersonalNumber = ВТ_БанковскиеСчетаОрганизации.ИНН";
	
	тзВыписки = Запрос.Выполнить().Выгрузить();
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуВыпискиНаСервере(СтруктураЗаполнения, тзВыписки)
	
	СтрокаВыписки = тзВыписки.Добавить();
	
	ЗаполнитьЗначенияСвойств(СтрокаВыписки, СтруктураЗаполнения);
	
	Если СтруктураЗаполнения.Свойство("amount") Тогда 
		ЗаполнитьЗначенияСвойств(СтрокаВыписки, СтруктураЗаполнения.amount);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура GetAccountMovementsHTTPrequest(Команда)
	
	Nonce = "";
	Подсказка = НСтр("ka='შეიყვანეთ DigiPass –ის პაროლი';ru='Введите пароль DigiPass!';en='Enter the password of DigiPass!'");
	Если НЕ ВвестиСтроку(Nonce, Подсказка, 0, Истина) Тогда
		// запомнить текст напоминания
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				Логин);
	СтруктураПараметров.Вставить("PASSWORD",  			Пароль);
	СтруктураПараметров.Вставить("Nonce",  				Nonce);
	СтруктураПараметров.Вставить("Метод",   			"GetAccountMovements");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo");
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"">");
	
	//СтруктураПараметров.Вставить("Объект",	Объект);
	
	GetAccountMovementsHTTPrequestНаСервере(СтруктураПараметров);
	
КонецПроцедуры

&НаСервере
Процедура ПлатежНаСервере(СтруктураПараметров)
	
	ТаблицаПозиций.Очистить();	
	СтруктураПараметров.Вставить("ТаблицаПозиций", ТаблицаПозиций);
	
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	
	
	МассивОтправляемыхДокументов = Новый Массив;
	
	МассивПомеченыхДокументов = Объект[СтруктураПараметров.ИмяТабличнойЧасти].НайтиСтроки(Новый Структура("Пометка", Истина));
	
	Для Каждого Строк Из МассивПомеченыхДокументов Цикл 
		МассивОтправляемыхДокументов.Добавить(Строк.ДокументСсылка);
	КонецЦикла;
	
	КолвоВыгруженныхДоков = 0;
	
	ПустойСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	
	Если МассивОтправляемыхДокументов.Количество() > 0 Тогда 
		
		СтруктураПараметров.Вставить("МассивДокументов", МассивОтправляемыхДокументов);
		
		МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
		Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
		
		МассивПакетов = Неопределено;
		Если Структураответа.Свойство("МассивСсылокДокументовПакетов") Тогда 
			МассивПакетов = Структураответа.МассивСсылокДокументовПакетов;
		КонецЕсли;
		
		
		Если Структураответа.Свойство("PaymentOrdersResults") Тогда 
			
			Если ТипЗнч(Структураответа.PaymentOrdersResults) = Тип("Массив") Тогда 
				
				ДобавитьСтатусБезСотрудника = ЛОЖЬ;
				Для Каждого ЭлемМассива Из Структураответа.PaymentOrdersResults Цикл 
					
					Позиция = ЭлемМассива.position;
					УИД_Документа = ЭлемМассива.paymentId;
					
					МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
					Если МассивНайденныхСтрок.Количество() > 0 Тогда 
						
						ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
						
						ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
						Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
						Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
						
						Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
							ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
							
							ЗначениеСотрудника = МассивНайденныхСтрок[0].Сотрудник;
							
							ВнестиИнформациюСтатусаУИД(ДокументСсылка, ПустойСотрудник, УИД_Документа, Банк, Статус);
							
						КонецЕсли;
						
						ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Документа, Банк, Статус);
						
						Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
						КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
					КонецЕсли;
				КонецЦикла;
			ИначеЕсли ТипЗнч(Структураответа.PaymentOrdersResults) = Тип("Структура") Тогда
				
				Позиция = Структураответа.PaymentOrdersResults.position;
				УИД_Документа = Структураответа.PaymentOrdersResults.paymentId;
				
				МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
				Если МассивНайденныхСтрок.Количество() > 0 Тогда 
					
					ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
					
					ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
					Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
					Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
					
					Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
						ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
						
						ЗначениеСотрудника = МассивНайденныхСтрок[0].Сотрудник;
						
						ВнестиИнформациюСтатусаУИД(ДокументСсылка, ПустойСотрудник, УИД_Документа, Банк, Статус);
						
					КонецЕсли;
					
					ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Документа, Банк, Статус);
					
					Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
					КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда 
			
			Сообщить(Структураответа.ТекстОшибки);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Сообщить(НСтр("ru = 'Всего выгруженно документов: "+КолвоВыгруженныхДоков+"'; ka = 'Всего выгруженно документов: "+КолвоВыгруженныхДоков+"'"));
	
КонецПроцедуры

&НаСервере
Процедура ВнестиИнформациюСтатусаУИД(ДокументСсылка, Сотрудник, УИД_Документа, Банк, Статус, ТолькоСтатус = Ложь)
	
	Если НЕ ТолькоСтатус Тогда 
		НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
		НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
		НаборЗаписейУИДДокумента.Отбор.Сотрудник.Установить(Сотрудник);
		НаборЗаписейУИДДокумента.Отбор.Банк.Установить(Банк);
		
		НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
		НовыйУИД.ДокументСсылка = ДокументСсылка;
		НовыйУИД.Сотрудник = Сотрудник;
		НовыйУИД.Банк = Банк;
		НовыйУИД.УИДДокументаВБанке = УИД_Документа;
		НовыйУИД.Выгружен = Истина;
		
		НаборЗаписейУИДДокумента.Записать();
	КонецЕсли;
	
	// Запись нового статуса
	
	ДатаОбновления = ТекущаяДата();
	НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
	НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
	НаборЗаписейСтатусовДокумента.Отбор.Сотрудник.Установить(Сотрудник);
	НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ДатаОбновления);
	НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(Банк);
	
	НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
	НовыйСтатус.ДокументСсылка = ДокументСсылка;
	НовыйСтатус.Период = ДатаОбновления;
	НовыйСтатус.Сотрудник = Сотрудник;
	НовыйСтатус.СтатусДокументаВИнтернетБанке = Статус;
	НовыйСтатус.Банк = Банк;
	
	НаборЗаписейСтатусовДокумента.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура Платеж(Команда)
	
	ОчиститьСообщения();
	
	Nonce = "";
	Подсказка = НСтр("ka='შეიყვანეთ DigiPass –ის პაროლი';ru='Введите пароль DigiPass!';en='Enter the password of DigiPass!'");
	Если НЕ ВвестиСтроку(Nonce, Подсказка, 0, Истина) Тогда
		// запомнить текст напоминания
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				Логин);
	СтруктураПараметров.Вставить("PASSWORD",  			Пароль);
	СтруктураПараметров.Вставить("Nonce",  				Nonce);
	СтруктураПараметров.Вставить("ИмяТабличнойЧасти",	"РасходыСоСчета");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo"); 
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"" xmlns:xsi=""http://www.w3.org/2001/XMLSchema-instance"">");
	
	Если ВыгружатьПакетомРасходыСоСчета Тогда 
		
		СтруктураПараметров.Вставить("Метод",   			"ImportBatchPaymentOrder");
		СтруктураПараметров.Вставить("СтруктурыТэгов",		СтруктураТеговПакетнойВыгрузкиРасходаСоСчета);
		
		ПакетПлатежейНаСервере(СтруктураПараметров);
		
	Иначе
		
		СтруктураПараметров.Вставить("Метод",   			"ImportSinglePaymentOrders");
		СтруктураПараметров.Вставить("СтруктурыТэгов",		СтруктураТеговВыгрузкиРасходаСоСчета);
		
		ПлатежНаСервере(СтруктураПараметров);
		
	КонецЕсли;

	
	
КонецПроцедуры

&НаСервере
Функция ПроверитьПравильностьЗаолнения(ТаблицаПакетнойВыгрузки)

	Отказ = ЛОЖЬ;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаПакетнойВыгрузки", ТаблицаПакетнойВыгрузки);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаПакетнойВыгрузки.ИмяПакета КАК ИмяПакета,
	|	ТаблицаПакетнойВыгрузки.БанковскийСчет КАК БанковскийСчет,
	|	1 КАК Количество
	|ПОМЕСТИТЬ ВТ_ТабВыбранных
	|ИЗ
	|	&ТаблицаПакетнойВыгрузки КАК ТаблицаПакетнойВыгрузки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ТабВыбранных.ИмяПакета,
	|	ВТ_ТабВыбранных.БанковскийСчет,
	|	ВТ_ТабВыбранных.Количество
	|ПОМЕСТИТЬ ВТ_ДанныеГруп
	|ИЗ
	|	ВТ_ТабВыбранных КАК ВТ_ТабВыбранных
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ТабВыбранных.ИмяПакета,
	|	ВТ_ТабВыбранных.БанковскийСчет,
	|	ВТ_ТабВыбранных.Количество
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДанныеГруп.ИмяПакета,
	|	СУММА(ВТ_ДанныеГруп.Количество) КАК Количество
	|ИЗ
	|	ВТ_ДанныеГруп КАК ВТ_ДанныеГруп
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ДанныеГруп.ИмяПакета";
	
	тзРезультат = Запрос.Выполнить().Выгрузить();
	
	ТекстСообщения = "";
	Для Каждого Строк из тзРезультат Цикл 
		
		Если Строк.Количество > 1 Тогда 
			Отказ = ИСТИНА;
			ТекстСообщения = ТекстСообщения + Символы.ПС + НСтр("ru = 'Имя пакета: """+ Строк.ИмяПакета + """, присвоено двум или более счетам'; ka = 'Имя пакета: """+ Строк.ИмяПакета + """, присвоено двум или более счетам'");
		КонецЕсли;
		
	КонецЦикла;
	
	Если Отказ Тогда 
		Сообщить(НСтр("ka='გადატვირთვა გაუქმებულია';ru='Выгрузка отменена';en='Uploading canceled'") + ТекстСообщения);
	КонецЕсли;
	
	Возврат Отказ;
	
КонецФункции

&НаСервере
Процедура ПакетПлатежейНаСервере(СтруктураПараметров)
	
	ТаблицаПозиций.Очистить();	
	СтруктураПараметров.Вставить("ТаблицаПозиций", ТаблицаПозиций);
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	
	ТаблицаПакетнойВыгрузки = Объект[СтруктураПараметров.ИмяТабличнойЧасти].Выгрузить(Новый СТруктура("Пометка", Истина));//НайтиСтроки(Новый Структура("Пометка", Истина));
	
	Отказ = ПроверитьПравильностьЗаолнения(ТаблицаПакетнойВыгрузки);
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	
	тзПакетов = ТаблицаПакетнойВыгрузки.Скопировать(, "ИмяПакета");
	тзПакетов.Свернуть("ИмяПакета");
	
	ПредДокументСсылка = Неопределено;
	Для Каждого ИмяПакета Из тзПакетов Цикл 
		
		СтруктураПараметров.ТаблицаПозиций.Очистить();
		
		тзОдногоПакета = ТаблицаПакетнойВыгрузки.Скопировать(Новый Структура("ИмяПакета", ИмяПакета.ИмяПакета));
		КолвоВыгруженныхДоков = 0;
		
		Если тзОдногоПакета.Количество() > 0 Тогда 
			
			СтруктураПараметров.Вставить("ТаблицаПакетнойВыгрузки", тзОдногоПакета);
			
			МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
			Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
			
			Если Структураответа.Свойство("mygeminiBatchId") Тогда 
				
				ЗначениеСотрудника = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
				ПустойСотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
				Статус = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
				
				УИД_Пакета = Структураответа.mygeminiBatchId;
				СтруктураУИД = ЗапроситьСтатусПакета(СокрЛП(УИД_Пакета), Истина, СтруктураПараметров);
				
				Если СтруктураУИД.Свойство("status") Тогда 
					СтатусПакета = СтруктураУИД.status;
				КонецЕсли;
				
				СтатусПакетаСсылка = ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.INIT");
				МассивОдиночныхДокументов = Новый Массив;
				Если СтруктураУИД.Свойство("status") Тогда 
					
					СтатусПакетаСтрока = СтруктураУИД.status;
					СтатусПакетаСсылка = Перечисления.СтатусыПакетныхПеречисленийВИнтернетБанке[СтатусПакетаСтрока];
					
					Если СтруктураУИД.Свойство("batchPaymentData") Тогда
						МассивОдиночныхДокументов = СтруктураУИД.batchPaymentData;
					КонецЕсли;
					
				КонецЕсли;
				
				Если ТипЗнч(МассивОдиночныхДокументов) = Тип("Массив") Тогда 
					Для Каждого Элем Из МассивОдиночныхДокументов Цикл 
						
						Позиция = Элем.position;
						СтатусСтрокой = Элем.paymentStatus;
						УИД_Позиции = Элем.paymentId;
						
						//Свойства ошибки 
						
						
						МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
						Если МассивНайденныхСтрок.Количество() > 0 Тогда 
							
							ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
							Сотрудник = МассивНайденныхСтрок[0].Сотрудник;
							
							Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
							
							Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
								ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
								
								ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Пакета, Банк, СтатусПакетаСсылка, ЛОЖЬ);
								
							КонецЕсли;
							
							СтатусСсылка = Перечисления.СтатусыДокументовВИнтернетБанке[СтатусСтрокой];//ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
							
							ВнестиИнформациюСтатусаУИД(ДокументСсылка, Сотрудник, УИД_Позиции, Банк, СтатусСсылка);
							
							Если ДокументСсылка <> ПредДокументСсылка Тогда 
								Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
								КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
								ПредДокументСсылка = ДокументСсылка;
							КонецЕсли;
							
						КонецЕсли;
					КонецЦикла;
					
				ИначеЕсли ТипЗнч(МассивОдиночныхДокументов) = Тип("Структура") Тогда
					Позиция = МассивОдиночныхДокументов.position;
					СтатусСтрокой = МассивОдиночныхДокументов.paymentStatus;
					УИД_Позиции = МассивОдиночныхДокументов.paymentId;
					
					//Свойства ошибки 
					
					
					МассивНайденныхСтрок = СтруктураПараметров.ТаблицаПозиций.НайтиСтроки(Новый Структура("Позиция", Позиция));
					Если МассивНайденныхСтрок.Количество() > 0 Тогда 
						
						ДокументСсылка = МассивНайденныхСтрок[0].ДокументСсылка;
						Сотрудник = МассивНайденныхСтрок[0].Сотрудник;
						
						Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
						
						Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата")
							ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников") Тогда 
							
							ВнестиИнформациюСтатусаУИД(ДокументСсылка, ЗначениеСотрудника, УИД_Пакета, Банк, СтатусПакетаСсылка, ЛОЖЬ);
							
						КонецЕсли;
						
						СтатусСсылка = Перечисления.СтатусыДокументовВИнтернетБанке[СтатусСтрокой];//ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.T");
						
						ВнестиИнформациюСтатусаУИД(ДокументСсылка, Сотрудник, УИД_Позиции, Банк, СтатусСсылка);
						
						Если ДокументСсылка <> ПредДокументСсылка Тогда 
							Сообщить(НСтр("ru = 'Документ: """+ДокументСсылка+""" был успешно выгружен'; ka = 'Документ: """+ДокументСсылка+""" был успешно выгруже'"));
							КолвоВыгруженныхДоков = КолвоВыгруженныхДоков + 1;
							ПредДокументСсылка = ДокументСсылка;
						КонецЕсли;
						
					КонецЕсли;
				КонецЕсли;
				
			ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда
				
				 Сообщить(Структураответа.ТекстОшибки);
				 
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	СтруктураПараметров.ТаблицаПакетнойВыгрузки = Неопределено;
	Сообщить(НСтр("ru = 'Всего выгруженно документов: "+КолвоВыгруженныхДоков+"'; ka = 'Всего выгруженно документов: "+КолвоВыгруженныхДоков+"'"));
	
КонецПроцедуры

