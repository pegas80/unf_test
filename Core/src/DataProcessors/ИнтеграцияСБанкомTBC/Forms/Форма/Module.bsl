&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	ЗадатьВопрос = Истина;
	
	Для Каждого Элем Из ВыбранноеЗначение Цикл 
		Если ТипЗнч(Элем) = Тип("ДокументСсылка.РасходСоСчета") Тогда 
			
			Если ОтказДляОдиночнойЗарплаты(Элем) И НЕ ВыгружатьПакетомРасходыСоСчета Тогда 
				Сообщить(НСтр("ru = 'Зарплатный документы можно выгружать только пакетом: """+ Элем +"""!'; ka = 'Зарплатный документы можно выгружать только пакетом: """+ Элем +"""!'"));
				Продолжить;
			КонецЕсли;
			
			Если ЗадатьВопрос И Объект.РасходыСоСчета.Количество() > 0 Тогда
				ТекстВопроса = НСтр("ka='ცხრილური ნაწილი გასუფთავდება. გავაგრძელოთ?';ru='Табличная часть будет очищена. Продолжить?';en='Tabular section is cleared. Proceed?'");
				Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да,);
				
				Если Ответ <> КодВозвратаДиалога.Да Тогда
					ЗадатьВопрос = Ложь;
					Прервать;
				Иначе 
					Объект.РасходыСоСчета.Очистить();
					ЗадатьВопрос = Ложь;
				КонецЕсли;
			Иначе 
				ЗадатьВопрос = Ложь;
			КонецЕсли;
			
			СтрокаТабЧасти = Объект.РасходыСоСчета.Добавить();
			СтруктураСчетОтправитель = ПолучитьБанковскийСчетДокументаНаСервере(Элем, "РасходСоСчета");
			
		ИначеЕсли ТипЗнч(Элем) = Тип("ДокументСсылка.Конвертация") Тогда
			
			Если Объект.Конвертации.Количество() > 0 Тогда
				ТекстВопроса = НСтр("ka='ცხრილური ნაწილი გასუფთავდება. გავაგრძელოთ?';ru='Табличная часть будет очищена. Продолжить?';en='Tabular section is cleared. Proceed?'");
				Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да,);
				
				Если Ответ <> КодВозвратаДиалога.Да Тогда
					ЗадатьВопрос = Ложь;
					Прервать;
				Иначе 
					ЗадатьВопрос = Ложь;
					Объект.Конвертации.Очистить();
				КонецЕсли;
			Иначе 
				ЗадатьВопрос = Ложь;
			КонецЕсли;
			
			СтрокаТабЧасти = Объект.Конвертации.Добавить();
			СтруктураСчетОтправитель = ПолучитьБанковскийСчетДокументаНаСервере(Элем, "Конвертация");
			
		КонецЕсли;
		
		СтрокаТабЧасти.ДокументСсылка = Элем;
		СтрокаТабЧасти.ИмяПакета = "Package " + СтруктураСчетОтправитель.НомерСчтеа;
		СтрокаТабЧасти.БанковскийСчет = СтруктураСчетОтправитель.СчетОтправитель;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ОтказДляОдиночнойЗарплаты(ДокСсылка)
	
	Возврат ДокСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Зарплата") ИЛИ ДокСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников");
	
КонецФункции

&НаСервере
Функция ПолучитьБанковскийСчетДокументаНаСервере(ДокСсылка, ИмяДок)
	
	Если ИмяДок = "РасходСоСчета" Тогда 
		Возврат Новый Структура("СчетОтправитель,НомерСчтеа", ДокСсылка.БанковскийСчет, ДокСсылка.БанковскийСчет.НомерСчета);	
	ИначеЕсли ИмяДок = "Конвертация" Тогда 
		Возврат Новый Структура("СчетОтправитель,НомерСчтеа", ДокСсылка.Отправитель, ДокСсылка.Отправитель.НомерСчета);
	Иначе
		Возврат Новый Структура("СчетОтправитель,НомерСчтеа", ПредопределенноеЗначение("Справочник.БанковскиеСчета.ПустаяСсылка"), "");
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьДокументыКонвертации(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Проведен", Истина);
	ПараметрыОтбора.Вставить(СокрЛП("КодБанкаСчетаОтправителя"), "TBCBGE22");
	ПараметрыОтбора.Вставить("УИДДокументаВБанке", "");
	
	НовыйМассив = Новый Массив;
	НовыйМассив.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ПустаяСсылка"));
	НовыйМассив.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.ПустаяСсылка"));
	НовыйМассив.Добавить(Неопределено);
	
	ФиксированныйМассив = Новый ФиксированныйМассив(НовыйМассив);
	ПараметрыОтбора.Вставить("СтатусВИнтернетБанке", ФиксированныйМассив);
	
	СтруктураВыбора = Новый Структура("Отбор", ПараметрыОтбора);
	
	ТекСтрока = Элементы.Конвертации.ТекущиеДанные;
	Если Не ТекСтрока = Неопределено И ЗначениеЗаполнено(ТекСтрока.ДокументСсылка) Тогда 
		СтруктураВыбора.Вставить("ТекущаяСтрока", ТекСтрока.ДокументСсылка);
	КонецЕсли;
	
	СтруктураВыбора = Новый Структура("МножественныйВыбор, Отбор", Истина, ПараметрыОтбора);
	
	ФормаКонвертации = ПолучитьФорму("Документ.Конвертация.ФормаВыбора", СтруктураВыбора, ЭтаФорма); 
	Если Не ФормаКонвертации = Неопределено Тогда 
		
		НоваяГруппа = ФормаКонвертации.Список.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		НоваяГруппа.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		НоваяГруппа.Использование = Истина;
		
		НоваяГруппа1 = НоваяГруппа.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		НоваяГруппа1.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
		НоваяГруппа1.Использование = Истина;
		
		НовыйЭлемент1 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент1.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОперации"); 
		НовыйЭлемент1.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета");
		НовыйЭлемент1.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент1.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком"); 
		НовыйЭлемент3.ПравоеЗначение = Истина;
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Отправитель.Банк.СВИФТБИК"); 
		НовыйЭлемент3.ПравоеЗначение = "TBCBGE22";
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Выгружен"); 
		НовыйЭлемент3.ПравоеЗначение = Ложь;
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("УИДДокументаВБанке"); 
		НовыйЭлемент3.ПравоеЗначение = "";
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		ФормаКонвертации.Открыть();
		
	КонецЕсли;
	
