&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.Банк = НайтиTBCБанк();
	НациональнаяВалюта = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("НациональнаяВалюта");
	
	Если ЗначениеЗаполнено(объект.Банк) Тогда 
		//Элементы.Банк.Доступность = Ложь;
	Иначе
		Сообщить(НСтр("ka='მუშაობის დაწყებამდე შეავსეთ რეკვიზიტი ""ბანკი"" აწყობებში';ru='Перед началом работы заполните реквизит ""Банк"" на вкладке настройки';en='Before you begin, fill props ""Bank"" in the Settings tab'"));
	КонецЕсли;
	
	Логин = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Login");
	Пароль = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_Password");
	
КонецПроцедуры

&НаСервере
Функция НайтиTBCБанк()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Банки.Ссылка
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	НЕ Банки.ЭтоГруппа
		|	И НЕ Банки.ПометкаУдаления
		|	И ПОДСТРОКА(Банки.СВИФТБИК, 1, 8) = ""TBCBGE22""";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	СтруктураТеговВыгрузкиРасходаСоСчета = ЗаполнитьСтрукутуруТеговВыгрузкиРасходаСоСчета();
	СтруктураТеговПакетнойВыгрузкиРасходаСоСчета = ЗаполнитьСтрукутуруТеговПакетнойВыгрузкиРасходаСоСчета();
		
КонецПроцедуры


&НаСервере
Процедура GetAccountMovementsHTTPrequestНаСервере(СтруктураПараметров)
	
	Объект.Выписка.Очистить();
	
	СтруктураФильтра = Новый Структура;
	
	Если ЗначениеЗаполнено(НомерСчетаВыписки) Тогда 
		СтруктураФильтра.Вставить("accountNumber", 				Лев(НомерСчетаВыписки.НомерСчета,22));
		СтруктураФильтра.Вставить("accountCurrencyCode", 		НомерСчетаВыписки.ВалютаДенежныхСредств.Наименование);
		//СтруктураФильтра.Вставить("movementId", ); Пока что не уверен возможно придеться доработать справочник БанковскиеСчета
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПериодВыписки.ДатаНачала) И ЗначениеЗаполнено(ПериодВыписки.ДатаОкончания) Тогда 
		СтруктураФильтра.Вставить("periodFrom", 			ПериодВыписки.ДатаНачала);
		СтруктураФильтра.Вставить("periodTo", 				ПериодВыписки.ДатаОкончания);
	ИначеЕсли ЗначениеЗаполнено(ПериодВыписки.ДатаОкончания) Тогда         
		СтруктураФильтра.Вставить("lastMovementTimestamp", 	ПериодВыписки.ДатаОкончания);
	Иначе
		СтруктураФильтра.Вставить("lastMovementTimestamp", 	ТекущаяДата());
	КонецЕсли;
	
	
	
	Если СтруктураПараметров.Количество() > 0 Тогда 
		СтруктураПараметров.Вставить("ФильтраЗапроса", СтруктураФильтра);	
	КонецЕсли;
	
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	
	МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
	Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
	
	тзВыписки = Объект.Выписка.Выгрузить();
	тзВыписки.Очистить();
	
	Если Структураответа.Свойство("accountMovement") Тогда 
		
		Если ТипЗнч(Структураответа.accountMovement) = Тип("Массив") Тогда 
			Для Каждого ЭлемМассива Из Структураответа.accountMovement Цикл 
				СтруктураЗаполнения = ЭлемМассива;
				ДобавитьСтрокуВыпискиНаСервере(СтруктураЗаполнения, тзВыписки);
			КонецЦикла;
		ИначеЕсли ТипЗнч(Структураответа.accountMovement) = Тип("Структура") Тогда	
			СтруктураЗаполнения = Структураответа.accountMovement;
			ДобавитьСтрокуВыпискиНаСервере(СтруктураЗаполнения, тзВыписки);
		КонецЕсли;
		
	ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда 
			
		Сообщить(Структураответа.ТекстОшибки);
		
	КонецЕсли;
	
	тзВыписки.Сортировать("valueDate Возр");
	
	//Объект.Выписка.Загрузить(тзВыписки);
	
	ДополнитьИнформациейБазы(тзВыписки);
	
	Объект.Выписка.Загрузить(тзВыписки);
	
	Объект.ВходящиеДокументыПоступления.Загрузить(тзВыписки.Скопировать(Новый Структура("Таблица", "Поступления")));
	Объект.ВходящиеДокументыРасходы.Загрузить(тзВыписки.Скопировать(Новый Структура("Таблица, transactionType", "Расходы", "33")));
	Объект.ВходящиеДокументыКонвертации.Загрузить(тзВыписки.Скопировать(Новый Структура("Таблица", "Конвертации")));
	
	ОбновитьВидимость("Поступления");
	ОбновитьВидимость("Расходы");
	ОбновитьВидимость("Конвертации");
	
	Элементы.ГруппаВыписка.ТолькоПросмотр = Ложь;
	Элементы.ГруппаРасходы.ТолькоПросмотр = Ложь;
	Элементы.ГруппаПоступления.ТолькоПросмотр = Ложь;
	Элементы.ГруппаКонвертации.ТолькоПросмотр = Ложь;
	Элементы.ВходящиеДокументыКонвертацииСоздатьДокументыКонвертации.Доступность = Истина;
	Элементы.ВходящиеДокументыРасходыСоздатьДокументыРасходы.Доступность = Истина;
	Элементы.ВходящиеДокументыПоступленияСоздатьДокументыПоступления.Доступность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьИнформациейБазы(тзВыписки)
	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("тзВыписки", 					тзВыписки);
	Запрос.УстановитьПараметр("СчетаУчетаПоУмолчаниюПриходы",СчетаУчетаПоУмолчаниюПриходы.Выгрузить());
	Запрос.УстановитьПараметр("СчетаУчетаПоУмолчаниюРасход",СчетаУчетаПоУмолчаниюРасход.Выгрузить());
	Запрос.УстановитьПараметр("БанковскийСчетОрганизации", 	НомерСчетаВыписки);
	Запрос.УстановитьПараметр("Организация", 				Организация);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТЗНастройкиВходящие.ВидОперации КАК ВидОперации,
	               |	ТЗНастройкиВходящие.Корреспонденция,
	               |	ТЗНастройкиВходящие.КорреспонденцияРегл,
	               |	ТЗНастройкиВходящие.Статья
	               |ПОМЕСТИТЬ ТаблицаНастройкиВходящие
	               |ИЗ
	               |	&СчетаУчетаПоУмолчаниюПриходы КАК ТЗНастройкиВходящие
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗНастройкиРасход.ВидОперации КАК ВидОперации,
	               |	ТЗНастройкиРасход.Корреспонденция,
	               |	ТЗНастройкиРасход.КорреспонденцияРегл,
	               |	ТЗНастройкиРасход.Статья
	               |ПОМЕСТИТЬ ТаблицаНастройкиРасход
	               |ИЗ
	               |	&СчетаУчетаПоУмолчаниюРасход КАК ТЗНастройкиРасход
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТаблицаНастройкиВходящие.ВидОперации КАК ВидОперации,
	               |	ТаблицаНастройкиВходящие.Корреспонденция,
	               |	ТаблицаНастройкиВходящие.КорреспонденцияРегл,
	               |	ТаблицаНастройкиВходящие.Статья
	               |ПОМЕСТИТЬ ТаблицаНастройкиРеквПоУмолчанию
	               |ИЗ
	               |	ТаблицаНастройкиВходящие КАК ТаблицаНастройкиВходящие
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТаблицаНастройкиРасход.ВидОперации,
	               |	ТаблицаНастройкиРасход.Корреспонденция,
	               |	ТаблицаНастройкиРасход.КорреспонденцияРегл,
	               |	ТаблицаНастройкиРасход.Статья
	               |ИЗ
	               |	ТаблицаНастройкиРасход КАК ТаблицаНастройкиРасход
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВЫРАЗИТЬ(ТЗ.debitCredit КАК СТРОКА(1)) КАК debitCredit,
	               |	ВЫРАЗИТЬ(ТЗ.MovementId КАК СТРОКА(100)) КАК MovementId,
	               |	ВЫРАЗИТЬ(ТЗ.ExternalPaymentId КАК СТРОКА(100)) КАК ExternalPaymentId,
	               |	ВЫРАЗИТЬ(ТЗ.currency КАК СТРОКА(100)) КАК currency,
	               |	ВЫРАЗИТЬ(ТЗ.valueDate КАК СТРОКА(100)) КАК valueDate,
	               |	ВЫРАЗИТЬ(ТЗ.description КАК СТРОКА(100)) КАК description,
	               |	ВЫРАЗИТЬ(ТЗ.amount КАК СТРОКА(100)) КАК amount,
	               |	ВЫРАЗИТЬ(ТЗ.accountNumber КАК СТРОКА(100)) КАК accountNumber,
	               |	ВЫРАЗИТЬ(ТЗ.accountName КАК СТРОКА(100)) КАК accountName,
	               |	ВЫРАЗИТЬ(ТЗ.additionalInformation КАК СТРОКА(100)) КАК additionalInformation,
	               |	ВЫРАЗИТЬ(ТЗ.documentDate КАК СТРОКА(100)) КАК documentDate,
	               |	ВЫРАЗИТЬ(ТЗ.documentNumber КАК СТРОКА(100)) КАК documentNumber,
	               |	ВЫРАЗИТЬ(ТЗ.partnerAccountNumber КАК СТРОКА(100)) КАК partnerAccountNumber,
	               |	ВЫРАЗИТЬ(ТЗ.partnerName КАК СТРОКА(100)) КАК partnerName,
	               |	ВЫРАЗИТЬ(ТЗ.partnerTaxCode КАК СТРОКА(100)) КАК partnerTaxCode,
	               |	ВЫРАЗИТЬ(ТЗ.partnerBankCode КАК СТРОКА(100)) КАК partnerBankCode,
	               |	ВЫРАЗИТЬ(ТЗ.partnerBank КАК СТРОКА(100)) КАК partnerBank,
	               |	ВЫРАЗИТЬ(ТЗ.operationCode КАК СТРОКА(100)) КАК operationCode,
	               |	ВЫРАЗИТЬ(ТЗ.partnerPersonalNumber КАК СТРОКА(100)) КАК partnerPersonalNumber,
	               |	ВЫРАЗИТЬ(ТЗ.partnerDocumentType КАК СТРОКА(100)) КАК partnerDocumentType,
	               |	ВЫРАЗИТЬ(ТЗ.statusCode КАК СТРОКА(100)) КАК statusCode,
	               |	ВЫРАЗИТЬ(ТЗ.transactionType КАК СТРОКА(2)) КАК transactionType,
	               |	ВЫРАЗИТЬ(ТЗ.exchangeRate КАК СТРОКА(100)) КАК exchangeRate,
	               |	ВЫРАЗИТЬ(ТЗ.additionalDescription КАК СТРОКА(100)) КАК additionalDescription,
	               |	ВЫРАЗИТЬ(ТЗ.taxpayerCode КАК СТРОКА(100)) КАК taxpayerCode,
	               |	ВЫРАЗИТЬ(ТЗ.taxpayerName КАК СТРОКА(100)) КАК taxpayerName,
	               |	ВЫРАЗИТЬ(ТЗ.paymentId КАК СТРОКА(100)) КАК paymentId
	               |ПОМЕСТИТЬ тзВыписки
	               |ИЗ
	               |	&тзВыписки КАК ТЗ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Контрагенты.Ссылка,
	               |	Контрагенты.ИНН,
	               |	Контрагенты.ДоговорПоУмолчанию,
	               |	1 КАК Приоритет
	               |ПОМЕСТИТЬ ВТ_ДанныеПартнера
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	НЕ Контрагенты.ПометкаУдаления
	               |	И НЕ Контрагенты.ЭтоГруппа
	               |	И (Контрагенты.ИНН В
	               |				(ВЫБРАТЬ
	               |					а.partnerPersonalNumber
	               |				ИЗ
	               |					тзВыписки КАК а
	               |				ГДЕ
	               |					а.partnerPersonalNumber <> """")
	               |			ИЛИ Контрагенты.ИНН В
	               |				(ВЫБРАТЬ
	               |					а.partnerTaxCode
	               |				ИЗ
	               |					тзВыписки КАК а
	               |				ГДЕ
	               |					а.partnerTaxCode <> """"))
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка,
	               |	Сотрудники.Физлицо.ИНН,
	               |	NULL,
	               |	2
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	НЕ Сотрудники.ПометкаУдаления
	               |	И НЕ Сотрудники.ЭтоГруппа
	               |	И (Сотрудники.Физлицо.ИНН В
	               |				(ВЫБРАТЬ
	               |					а.partnerPersonalNumber
	               |				ИЗ
	               |					тзВыписки КАК а
	               |				ГДЕ
	               |					а.partnerPersonalNumber <> """")
	               |			ИЛИ Сотрудники.Физлицо.ИНН В
	               |				(ВЫБРАТЬ
	               |					а.partnerTaxCode
	               |				ИЗ
	               |					тзВыписки КАК а
	               |				ГДЕ
	               |					а.partnerTaxCode <> """"))
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	КодыКазначейства.Ссылка,
	               |	КодыКазначейства.ИНН,
	               |	NULL,
	               |	3
	               |ИЗ
	               |	Справочник.КодыКазначейства КАК КодыКазначейства
	               |ГДЕ
	               |	НЕ КодыКазначейства.ПометкаУдаления
	               |	И (КодыКазначейства.ИНН В
	               |				(ВЫБРАТЬ
	               |					а.partnerPersonalNumber
	               |				ИЗ
	               |					тзВыписки КАК а
	               |				ГДЕ
	               |					а.partnerPersonalNumber <> """")
	               |			ИЛИ КодыКазначейства.ИНН В
	               |				(ВЫБРАТЬ
	               |					а.partnerTaxCode
	               |				ИЗ
	               |					тзВыписки КАК а
	               |				ГДЕ
	               |					а.partnerTaxCode <> """"))
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ДанныеПартнера.ИНН,
	               |	МИНИМУМ(ВТ_ДанныеПартнера.Приоритет) КАК Приоритет
	               |ПОМЕСТИТЬ ВТ_ДанныеПартнераМинГрупп
	               |ИЗ
	               |	ВТ_ДанныеПартнера КАК ВТ_ДанныеПартнера
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_ДанныеПартнера.ИНН
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ДанныеПартнераМинГрупп.ИНН,
	               |	ВТ_ДанныеПартнераМинГрупп.Приоритет,
	               |	ВТ_ДанныеПартнера.Ссылка КАК Контрагент,
	               |	ЕСТЬNULL(ВТ_ДанныеПартнера.ДоговорПоУмолчанию, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК ДоговорКонтрагента
	               |ПОМЕСТИТЬ ВТ_КонтрагентыДляПодстановки
	               |ИЗ
	               |	ВТ_ДанныеПартнераМинГрупп КАК ВТ_ДанныеПартнераМинГрупп
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеПартнера КАК ВТ_ДанныеПартнера
	               |		ПО ВТ_ДанныеПартнераМинГрупп.ИНН = ВТ_ДанныеПартнера.ИНН
	               |			И ВТ_ДанныеПартнераМинГрупп.Приоритет = ВТ_ДанныеПартнера.Приоритет
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	БанковскиеСчета.Ссылка,
	               |	БанковскиеСчета.Владелец,
	               |	БанковскиеСчета.НомерСчета,
	               |	ВЫБОР
	               |		КОГДА БанковскиеСчета.Владелец ССЫЛКА Справочник.КодыКазначейства
	               |				ИЛИ БанковскиеСчета.Владелец ССЫЛКА Справочник.Контрагенты
	               |				ИЛИ БанковскиеСчета.Владелец ССЫЛКА Справочник.Организации
	               |			ТОГДА БанковскиеСчета.Владелец.ИНН
	               |		ИНАЧЕ БанковскиеСчета.Владелец.Физлицо.ИНН
	               |	КОНЕЦ КАК ИНН
	               |ПОМЕСТИТЬ ВТ_БанковскиеСчетаДляПодстановки
	               |ИЗ
	               |	Справочник.БанковскиеСчета КАК БанковскиеСчета
	               |ГДЕ
	               |	НЕ БанковскиеСчета.ПометкаУдаления
	               |	И (ПОДСТРОКА(БанковскиеСчета.НомерСчета, 1, 22) В
	               |				(ВЫБРАТЬ
	               |					ПОДСТРОКА(а.partnerAccountNumber, 1, 22)
	               |				ИЗ
	               |					тзВыписки КАК а
