		НоваяГруппа1.Использование = Истина;
		
		НовыйЭлемент1 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент1.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОперации"); 
		НовыйЭлемент1.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОперацийКонвертация.СоСчета");
		НовыйЭлемент1.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент1.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Отправитель.Банк.ИспользуетсяДляИнтеграцииСБанком"); 
		НовыйЭлемент3.ПравоеЗначение = Истина;
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Отправитель.Банк.СВИФТБИК"); 
		НовыйЭлемент3.ПравоеЗначение = "TBCBGE22";
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Выгружен"); 
		НовыйЭлемент3.ПравоеЗначение = Ложь;
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		НовыйЭлемент3 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент3.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("УИДДокументаВБанке"); 
		НовыйЭлемент3.ПравоеЗначение = "";
		НовыйЭлемент3.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент3.Использование = Истина;
		
		ФормаППИ.Открыть();
		
	КонецЕсли;
	
