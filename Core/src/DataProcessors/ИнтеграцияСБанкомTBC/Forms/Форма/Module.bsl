&НаКлиенте
Процедура ДокументСсылкаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ИмяТаблицы = Элемент.Родитель.Имя;
	ИмяКолонки = Элемент.Имя;
	
	ИдентефикаторСтроки = Элементы[ИмяТаблицы].ТекущиеДанные.ПолучитьИдентификатор();
	
	//Проверка на дубль
	ПроверитьДублиИДобавитьСтрокуНаСервере(ВыбранноеЗначение, ИмяТаблицы, ИдентефикаторСтроки);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьДублиИДобавитьСтрокуНаСервере(ДокументСсылка, ИмяТаблицы, ИдентефикаторСтроки)
	
	МассивСтрок = Объект[ИмяТаблицы].НайтиСтроки(Новый Структура("ДокументСсылка", ДокументСсылка));
	
	Если МассивСтрок.Количество() <> 0 Тогда
		Сообщить(НСтр("ru = 'Документ: """ + ДокументСсылка + """ уже присутствует в таблице'; ka = 'Документ: """ + ДокументСсылка + """ уже присутствует в таблице'"));
		
	ИначеЕсли ОтказДляОдиночнойЗарплаты(ДокументСсылка) И НЕ ВыгружатьПакетомРасходыСоСчета Тогда 
		
		Сообщить(НСтр("ru = 'Зарплатный документы можно выгружать только пакетом: """+ ДокументСсылка +"""!'; ka = 'Зарплатный документы можно выгружать только пакетом: """+ ДокументСсылка +"""!'"));
		
	Иначе
		
		СтрокаЗаполнения = Объект[ИмяТаблицы].НайтиПоИдентификатору(ИдентефикаторСтроки);
		
		СтрокаЗаполнения.ДокументСсылка = ДокументСсылка;	
		СтрокаЗаполнения.БанковскийСчет = ?(ИмяТаблицы = "РасходыСоСчета", ДокументСсылка.БанковскийСчет, ДокументСсылка.Отправитель);
		
		Если СокрЛП(СтрокаЗаполнения.ИмяПакета) = "" Тогда 
			СтрокаЗаполнения.ИмяПакета = НСтр("ru = 'Package '; ka = 'Package '") + СтрокаЗаполнения.БанковскийСчет.НомерСчета;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПроверкаНаСуществованиеДанногоДокумента(ExternalPaymentId)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	УИДДокументовВИнтернетБанке.ДокументСсылка КАК Ссылка
	               |ПОМЕСТИТЬ ВТ_Ссылки
	               |ИЗ
	               |	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	               |ГДЕ
	               |	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") = &ExternalPaymentId
	               |	И УИДДокументовВИнтернетБанке.Банк.СВИФТБИК = &СВИФТБИК
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_Ссылки.Ссылка
	               |ИЗ
	               |	ВТ_Ссылки КАК ВТ_Ссылки";
	
	Запрос.УстановитьПараметр("ExternalPaymentId", ExternalPaymentId);
	Запрос.УстановитьПараметр("СВИФТБИК", Объект.Банк.СВИФТБИК);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда 
		Возврат Ложь;
	Иначе 
		Возврат Истина;
	КонецЕсли;	
	
КонецФункции

&НаСервере
Функция ПолучитьбанкПоСВИФТБИК(ИмяБанка, СвифтБанка)
	
	БанкВозврат = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Банки.Ссылка
		|ИЗ
		|	Справочник.Банки КАК Банки
		|ГДЕ
		|	НЕ Банки.ПометкаУдаления
		|	И Банки.СВИФТБИК = &СВИФТБИК
		|	ИЛИ Банки.Код = &СВИФТБИК";
	
	Запрос.УстановитьПараметр("СВИФТБИК", СвифтБанка);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Если РезультатЗапроса.Количество() = 0 Тогда 
		НовыйБанк = Справочники.Банки.СоздатьЭлемент();
		НовыйБанк.Наименование = ИмяБанка;
		НовыйБанк.Код = СвифтБанка;
		НовыйБанк.СВИФТБИК = СвифтБанка;
		
		Попытка
			НовыйБанк.Записать();
			БанкВозврат = НовыйБанк.Ссылка;
			Сообщить(НСтр("ru = 'В справочник банки, добавлен новый банк: "+ИмяБанка+"'; ka = 'В справочник банки, добавлен новый банк: "+ИмяБанка+"'"));
		Исключение
			//укажем пользователю чтобы поправил после загрузки
		КонецПопытки;
		
	Иначе
		БанкВозврат = РезультатЗапроса[0].Ссылка;
	КонецЕсли;
	
	Возврат БанкВозврат;
	
КонецФункции

&НаСервере
Процедура ПроверитьЗаполнениеКонтрагентаДоговораСчета(СтрокаЗаполнения, СтруктураЗаполненияКонтрагента, ВалютаЗаполнения, ИмяТаблицы);
	
	ЕстьКонтрагент = ЗначениеЗаполнено(СтрокаЗаполнения.Контрагент);
	ЕстьДоговор = ЗначениеЗаполнено(СтрокаЗаполнения.ДоговорКонтрагента);
	Если ИмяТаблицы = "Поступления"	Тогда 
		ЕстьСтчет = ЗначениеЗаполнено(СтрокаЗаполнения.БанковскийСчетОтправителя);
		ИмяРеквизитаСтрокиСчета = "БанковскийСчетОтправителя";
	ИначеЕсли ИмяТаблицы = "Расходы"	Тогда
		ЕстьСтчет = ЗначениеЗаполнено(СтрокаЗаполнения.БанковскийСчетПолучателя);
		ИмяРеквизитаСтрокиСчета = "БанковскийСчетПолучателя";
	КонецЕсли;
	
	ИННКонтрагента 				= СокрЛП(СтрокаЗаполнения.partnerTaxCode);
	ИмяКонтрагента 				= СокрЛП(СтрокаЗаполнения.partnerName);
	НомерСчетаКонтраегента 		= СокрЛП(СтрокаЗаполнения.partnerAccountNumber);
	НаименованиеБанкаКонтрагента= СокрЛП(СтрокаЗаполнения.partnerBank);
	КодБанкаКонтрагента         = СокрЛП(СтрокаЗаполнения.partnerBankCode);
	
	//Возможно уже создали или определился Счет
	Если НЕ ЕстьКонтрагент Тогда 
		Если ЕстьСтчет Тогда 
			СтрокаЗаполнения.Контрагент = СтрокаЗаполнения[ИмяРеквизитаСтрокиСчета].Владелец;
			ЕстьКонтрагент = Истина;
		Иначе
			
			ЭтоСотрудник = Ложь;
			Если СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником 
				ИЛИ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника 
				ИЛИ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику 
				ИЛИ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику Тогда
				ЭтоСотрудник = Истина;
			КонецЕсли;
			СтруктураПоиска = Новый Структура("ИНН, Наименование, ЭтоСотрудник", ИННКонтрагента, ИмяКонтрагента, ЭтоСотрудник);
			
			МассивНайденныхСтрок = ТаблицаСозданныхКонтрагентов.НайтиСтроки(СтруктураПоиска);
			
			Если МассивНайденныхСтрок.Количество() <> 0 Тогда
				СтрокаЗаполнения.Контрагент = МассивНайденныхСтрок[0].Контрагент;
				ЕстьКонтрагент = Истина;
			Иначе 
				ПоискКонтрагента = ПолучитьКонтрагентаСотрудник(ИННКонтрагента, ЭтоСотрудник);
				Если ЗначениеЗаполнено(ПоискКонтрагента) Тогда 
					СтрокаЗаполнения.Контрагент = ПоискКонтрагента;
					ЕстьКонтрагент = Истина;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником 
		ИЛИ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника 
		ИЛИ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Подотчетнику 
		ИЛИ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику Тогда 
		
		Если НЕ ЕстьКонтрагент Тогда
			
			
			НовФизЛицо = Справочники.ФизическиеЛица.СоздатьЭлемент();
			НовФизЛицо.Наименование = ИмяКонтрагента;
			НовФизЛицо.ИНН = ИННКонтрагента;
			НовФизЛицо.Гражданство = Справочники.СтраныМира.НайтиПоКоду("GEO");
			
			Попытка
				НовФизЛицо.Записать();
			Исключение
				Сообщить(НСтр("ru = 'Не удалось создать сотрудника: "+ИмяКонтрагента+"'; ka = 'Не удалось создать сотрудника: "+ИмяКонтрагента+"'"));
				// далее делать нечего
				Возврат;
			КонецПопытки;
			
			
			НовыйСотрудник = Справочники.Сотрудники.СоздатьЭлемент();
			НовыйСотрудник.Наименование = ИмяКонтрагента;
			НовыйСотрудник.Физлицо = НовФизЛицо.Ссылка;
			ЗаполнитьЗначенияСвойств(НовыйСотрудник, СтруктураЗаполненияКонтрагента);
			
			Попытка
				НовыйСотрудник.Записать();
				СтрокаЗаполнения.Контрагент = НовыйСотрудник.Ссылка;
				Сообщить(НСтр("ru = 'Был создан сотрудник: "+ИмяКонтрагента+"'; ka = 'Был создан сотрудник: "+ИмяКонтрагента+"'"));
				НовСтрокТЗ = ТаблицаСозданныхКонтрагентов.Добавить();
				НовСтрокТЗ.Контрагент 	= НовыйСотрудник.Ссылка;
				НовСтрокТЗ.ИНН          = ИННКонтрагента;
				НовСтрокТЗ.Наименование = ИмяКонтрагента;
				НовСтрокТЗ.ЭтоСотрудник = Истина;
			Исключение
				Сообщить(НСтр("ru = 'Не удалось создать сотрудника: "+ИмяКонтрагента+"'; ka = 'Не удалось создать сотрудника: "+ИмяКонтрагента+"'"));
				// далее делать нечего
				Возврат;
			КонецПопытки;
		КонецЕсли;
		
	Иначе 
		
		Если НЕ ЕстьКонтрагент Тогда 
			НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
			НовыйКонтрагент.Наименование = ИмяКонтрагента;
			НовыйКонтрагент.НаименованиеПолное = ИмяКонтрагента;
			НовыйКонтрагент.ИНН = ИННКонтрагента;
			ЗаполнитьЗначенияСвойств(НовыйКонтрагент, СтруктураЗаполненияКонтрагента);
			
			Попытка
				НовыйКонтрагент.Записать();
				СтрокаЗаполнения.Контрагент = НовыйКонтрагент.Ссылка;
				Сообщить(НСтр("ru = 'Был создан контрагент: "+ИмяКонтрагента+"'; ka = 'Был создан контрагент: "+ИмяКонтрагента+"'"));
				
				НовСтрокТЗ = ТаблицаСозданныхКонтрагентов.Добавить();
				НовСтрокТЗ.Контрагент 	= НовыйКонтрагент.Ссылка;
				НовСтрокТЗ.ИНН          = ИННКонтрагента;
				НовСтрокТЗ.Наименование = ИмяКонтрагента;
				НовСтрокТЗ.ЭтоСотрудник = Ложь;
			Исключение
				Сообщить(НСтр("ru = 'Не удалось создать контрагента: "+ИмяКонтрагента+"'; ka = 'Не удалось создать контрагента: "+ИмяКонтрагента+"'"));
				// далее делать нечего
				Возврат;
			КонецПопытки;
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ЕстьДоговор
		И НЕ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником 
		И НЕ СтрокаЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника Тогда 
		
		Если ЗначениеЗаполнено(СтрокаЗаполнения.Контрагент.ДоговорПоУмолчанию) Тогда 
			СтрокаЗаполнения.ДоговорКонтрагента = СтрокаЗаполнения.Контрагент.ДоговорПоУмолчанию;
		Иначе 
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ДоговорыКонтрагентов.Ссылка
			|ИЗ
			|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
			|ГДЕ
			|	ДоговорыКонтрагентов.Владелец = &Владелец";
			
			Запрос.УстановитьПараметр("Владелец", СтрокаЗаполнения.Контрагент);
			
			РезультатЗапроса = Запрос.Выполнить().Выгрузить();
			
			
			Если РезультатЗапроса.Количество() > 0 Тогда 
				СтрокаЗаполнения.ДоговорКонтрагента = РезультатЗапроса[0].Ссылка;
			Иначе
				
				ДоговорСоздан = ЛОЖЬ;
				НовыйДоговор = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
				НовыйДоговор.Наименование = "Основной Договор";
				НовыйДоговор.ВалютаРасчетов = ВалютаЗаполнения;
				НовыйДоговор.ВидЦен = Справочники.ВидыЦен.Оптовая;
				НовыйДоговор.Владелец = СтрокаЗаполнения.Контрагент;
				
				Попытка
					НовыйДоговор.Записать();
					СтрокаЗаполнения.ДоговорКонтрагента = НовыйДоговор.Ссылка;
					Сообщить(НСтр("ru = 'Был создан новый договор для контрагента: "+ИмяКонтрагента+"'; ka = 'Был создан новый договор для контрагента: "+ИмяКонтрагента+"'"));
					ДоговорСоздан = Истина;
				Исключение
					Сообщить(НСтр("ru = 'Не удалось создать новый договор для контрагента: "+ИмяКонтрагента+"'; ka = 'Не удалось создать новый договор для контрагента: "+ИмяКонтрагента+"'"));
				КонецПопытки;
				
				Если ДоговорСоздан Тогда 
					//Поскольку не было основного договора попробуем добавить новый договор как основной
					Попытка
						КонтрОбъект = СтрокаЗаполнения.Контрагент.ПолучитьОбъект();
						КонтрОбъект.ДоговорПоУмолчанию = НовыйДоговор.Ссылка;
					Исключение
						// Повезет в другой раз
					КонецПопытки;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЕстьСтчет Тогда 
		
		НайденныйБанковскийСчет = ПолучитьСчетОрганизации(Лев(НомерСчетаКонтраегента, 22), НомерСчетаКонтраегента, ВалютаЗаполнения);//Справочники.БанковскиеСчета.НайтиПоНаименованию(Лев(СтрокаЗаполнения.SenderAccountNumber, 22),,,СтрокаЗаполнения.Контрагент);
		
		Если НайденныйБанковскийСчет = Неопределено ИЛИ НайденныйБанковскийСчет = Справочники.БанковскиеСчета.ПустаяСсылка() Тогда 
			
			НовыйСчет						= Справочники.БанковскиеСчета.СоздатьЭлемент();
			НовыйСчет.Владелец				= СтрокаЗаполнения.Контрагент;
			НовыйСчет.ВалютаДенежныхСредств = ВалютаЗаполнения;
			НовыйСчет.ВидСчета 				= "Расчетный";
			НовыйСчет.Наименование 			= НомерСчетаКонтраегента;
			НовыйСчет.НомерСчета			= НомерСчетаКонтраегента;
			
			БанкДляСчета = ПолучитьбанкПоСВИФТБИК(НаименованиеБанкаКонтрагента, КодБанкаКонтрагента);
			Если БанкДляСчета = Неопределено Тогда 
				НовыйСчет.Банк 				= Справочники.Банки.ПустаяСсылка();
			Иначе
				НовыйСчет.Банк 				= БанкДляСчета;
			КонецЕсли;
			
			НовыйСчет.СчетУчета 			= ПредопределенноеЗначение("ПланСчетов.Управленческий.Банк");
			НовыйСчет.СчетУчетаРегл 		= ПланыСчетов.Хозрасчетный.НайтиПоКоду("1210");
			
			Попытка
				НовыйСчет.Записать();
				СтрокаЗаполнения[ИмяРеквизитаСтрокиСчета] = НовыйСчет.Ссылка;
				Сообщить(НСтр("ru = 'Был создан новый банковский счет для "+?(ТипЗНЧ(СтрокаЗаполнения.Контрагент) = Тип("СправочникСсылка.Контрагенты"), "контрагента", "сотрудника") + ": "+ИмяКонтрагента+"';
				| ka = 'Был создан новый банковский счет для "+?(ТипЗНЧ(СтрокаЗаполнения.Контрагент) = Тип("СправочникСсылка.Контрагенты"), "контрагента", "сотрудника") + ": "+ИмяКонтрагента+"'"));
			Исключение
				Сообщить(НСтр("ru = 'Не удалось создать новый банковский счет для "+?(ТипЗНЧ(СтрокаЗаполнения.Контрагент) = Тип("СправочникСсылка.Контрагенты"), "контрагента", "сотрудника") + ": "+ИмяКонтрагента+"'; 
				| ka = 'Не удалось создать новый банковский счет для "+?(ТипЗНЧ(СтрокаЗаполнения.Контрагент) = Тип("СправочникСсылка.Контрагенты"), "контрагента", "сотрудника") + ": "+ИмяКонтрагента+"'"));
			КонецПопытки;
			
		Иначе
			СтрокаЗаполнения[ИмяРеквизитаСтрокиСчета] = НайденныйБанковскийСчет;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСчетОрганизации(НомерСчетаБезВалюты, НомерСчетаСВалютой, ВалютаСчета)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	БанковскиеСчета.Ссылка КАК СчетОрганизации
	|ИЗ
	|	Справочник.БанковскиеСчета КАК БанковскиеСчета
	|ГДЕ
	|	(БанковскиеСчета.НомерСчета = &НомерСчетаСВалютой
	|			ИЛИ БанковскиеСчета.НомерСчета = &НомерСчетаБезВалюты)
	|	И БанковскиеСчета.ВалютаДенежныхСредств = &ВалютаСчета
	|	И НЕ БанковскиеСчета.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("НомерСчетаСВалютой", НомерСчетаСВалютой);
	Запрос.УстановитьПараметр("НомерСчетаБезВалюты", НомерСчетаБезВалюты);
	Запрос.УстановитьПараметр("ВалютаСчета", ?(ТипЗнч(ВалютаСчета) = Тип("Строка"), ПолучитьВалюту(ВалютаСчета),ВалютаСчета));	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.СчетОрганизации;

КонецФункции

&НаСервере
Функция ПолучитьВалюту(Валюта)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Валюты.Ссылка КАК Валюта
	|ИЗ
	|	Справочник.Валюты КАК Валюты
	|ГДЕ
	|	Валюты.Наименование = &Валюта";
	
	Запрос.УстановитьПараметр("Валюта", Валюта);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Валюта;
	
КонецФункции

&НаСервере
Функция ПолучитьКонтрагентаСотрудник(ИНН, ИскатьСотрудника = Неопределено)
	
	Если ИНН = "" Тогда Возврат Справочники.Контрагенты.ПустаяСсылка() КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Контрагенты.Ссылка КАК Контрагент
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.ИНН = &ИНН
	               |	И ВЫБОР
	               |			КОГДА &ИскатьСотрудника = НЕОПРЕДЕЛЕНО
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ НЕ &ИскатьСотрудника
	               |		КОНЕЦ
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	Сотрудники.Ссылка
	               |ИЗ
	               |	Справочник.Сотрудники КАК Сотрудники
	               |ГДЕ
	               |	Сотрудники.Физлицо.ИНН = &ИНН
	               |	И ВЫБОР
	               |			КОГДА &ИскатьСотрудника = НЕОПРЕДЕЛЕНО
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ &ИскатьСотрудника
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Запрос.УстановитьПараметр("ИскатьСотрудника", ИскатьСотрудника);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Контрагент;
	
КонецФункции

&НаСервере
Функция РазобратьКурс(СтрокаКурсов, НаименованиеОсновнойВалюты)
	
	//Пример: 1 USD = 2.5750 GEL                                                                                  
	СтруктураРазбора = Новый Структура;
	
	СтрокаРазбора = СтрокаКурсов;	
	
	ЛевоеЗначение = "";
	ПравоеЗначение = "";
	
	ПоискЗнакаРавенства = СтрНайти(СтрокаРазбора, "=");
	Если ПоискЗнакаРавенства <> 0 Тогда 
		ЛевоеЗначение = СокрЛП(Лев(СтрокаРазбора, ПоискЗнакаРавенства-1));
		ПравоеЗначение = СокрЛП(Сред(СтрокаРазбора, ПоискЗнакаРавенства + 1));
		
		ВалютаЛевТекстом = Прав(ЛевоеЗначение, 3);
		ВалютаПравТекстом = Прав(ПравоеЗначение, 3);
		
		
		//ЗаберемКурс
		СтрокаКурса = СокрЛП(СтрЗаменить(ПравоеЗначение, ВалютаПравТекстом, ""));
		
		Если ВалютаЛевТекстом = НаименованиеОсновнойВалюты Тогда 
			СтруктураРазбора.Вставить("ВалютаСчетаВыписки", ПолучитьВалюту(ВалютаЛевТекстом));
			СтруктураРазбора.Вставить("ВалютыКоррСчета", ПолучитьВалюту(ВалютаПравТекстом));
		ИначеЕсли ВалютаПравТекстом = НаименованиеОсновнойВалюты Тогда
			СтруктураРазбора.Вставить("ВалютыКоррСчета", ПолучитьВалюту(ВалютаЛевТекстом));
			СтруктураРазбора.Вставить("ВалютаСчетаВыписки", ПолучитьВалюту(ВалютаПравТекстом));
		Иначе
			СтруктураРазбора.Вставить(ВалютаЛевТекстом, ПолучитьВалюту(ВалютаЛевТекстом));
			СтруктураРазбора.Вставить(ВалютаПравТекстом, ПолучитьВалюту(ВалютаПравТекстом));
		КонецЕсли;
		СтруктураРазбора.Вставить("Курс", СтрокаКурса);
		
	КонецЕсли;
	
	Возврат СтруктураРазбора;
	
КонецФункции


&НаСервере
Процедура ПроверитьЗаполнениеСчетовОрганизации(СтрокаТЧ, Владелец, ВалютаОтправитель, ВалютаПолучатель)
	
	ПустойБанковскийСчет = ПредопределенноеЗначение("Справочник.БанковскиеСчета.ПустаяСсылка");
	ЕстьСчетОтправителя = ЗначениеЗаполнено(СтрокаТЧ.БанковскийСчетОтправителя); 
	ЕстьСчетПолучателя  = ЗначениеЗаполнено(СтрокаТЧ.БанковскийСчетПолучателя);
	
	НомерСчетаОтправителя = "";
	НомерСчетаПолучателя = "";
	
	Если СтрокаТЧ.debitCredit = "0" Тогда 
		
		НомерСчетаОтправителя = СокрЛП(СтрокаТЧ.accountNumber);
		НомерСчетаПолучателя = СокрЛП(СтрокаТЧ.partnerAccountNumber);
		
	ИначеЕсли СтрокаТЧ.debitCredit = "1" Тогда
		
		НомерСчетаОтправителя = СокрЛП(СтрокаТЧ.partnerAccountNumber);
		НомерСчетаПолучателя = СокрЛП(СтрокаТЧ.accountNumber);
		
	КонецЕсли;
	
	
	ДобавитьНайденныйСчет = Ложь;
	
	Если НЕ ЕстьСчетОтправителя Тогда 
		
		//Попробуем ОтыскатьСчет по номеру и в таблице созданных
		НайденныйСчет = ПустойБанковскийСчет;
		СтруктураПоиска = Новый Структура("НомерСчета", Лев(НомерСчетаОтправителя, 22));
		МассивПоиска = ТаблицаСозданныхСчетовОрганизации.НайтиСтроки(СтруктураПоиска);
		
		Если МассивПоиска.Количество() <> 0 Тогда 
			НайденныйСчет = МассивПоиска[0].БанковскийСчет;
		Иначе
			НайденныйСчет = ПолучитьСчетОрганизации(Лев(НомерСчетаОтправителя,22), НомерСчетаОтправителя, ВалютаОтправитель);
			ДобавитьНайденныйСчет = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НайденныйСчет) Тогда 
			
			СтрокаТЧ.БанковскийСчетОтправителя = НайденныйСчет;
			
			Если ДобавитьНайденныйСчет Тогда 
				
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = Лев(НомерСчетаОтправителя, 22);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НайденныйСчет;
				ДобавитьНайденныйСчет = Ложь;
				
			КонецЕсли;
			
		Иначе
			
			НовыйСчет = НомерСчетаВыписки.Скопировать();
			// Меняем только номерСчета, валюту, наименование
			НовыйСчет.НомерСчета 			= Лев(НомерСчетаОтправителя, 22);
			НовыйСчет.ВалютаДенежныхСредств = ВалютаОтправитель;
			НаименованиеБанка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НовыйСчет.Банк, "Наименование");
			НовыйСчет.Наименование 			= Лев(СокрЛП(НовыйСчет.НомерСчета) + ?(ЗначениеЗаполнено(НаименованиеБанка), ", в " + НаименованиеБанка, ""), 100);
			
			Попытка
				
				НовыйСчет.Записать();
				Сообщить(НСтр("ru = 'Был создан новый банковский счет организации: """+ Лев(НомерСчетаОтправителя, 22) +"""!'; ka = 'Был создан новый банковский счет организации: """+ Лев(НомерСчетаОтправителя, 22) +"""!'"));
				СтрокаТЧ.БанковскийСчетОтправителя = НовыйСчет.Ссылка;
				
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = Лев(СокрЛП(СтрокаТЧ.partnerAccountNumber), 22);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НовыйСчет.Ссылка;
				
			Исключение
				
				Сообщить(НСтр("ru = 'Не удалось создать банковский счет организации: """+ Лев(НомерСчетаОтправителя, 22) +"""!'; ka = 'Не удалось создать банковский счет организации: """+ Лев(НомерСчетаОтправителя, 22) +"""!'"));
				
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
	ДобавитьНайденныйСчет = Ложь;
	
	Если НЕ ЕстьСчетПолучателя Тогда 
		
		//Попробуем ОтыскатьСчет по номеру и в таблице созданных
		НайденныйСчет = ПустойБанковскийСчет;
		СтруктураПоиска = Новый Структура("НомерСчета", Лев(НомерСчетаПолучателя, 22));
		МассивПоиска = ТаблицаСозданныхСчетовОрганизации.НайтиСтроки(СтруктураПоиска);
		
		Если МассивПоиска.Количество() <> 0 Тогда 
			НайденныйСчет = МассивПоиска[0].БанковскийСчет;
		Иначе
			НайденныйСчет = ПолучитьСчетОрганизации(Лев(НомерСчетаПолучателя,22), НомерСчетаПолучателя, ВалютаПолучатель);
			ДобавитьНайденныйСчет = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НайденныйСчет) Тогда 
			
			СтрокаТЧ.БанковскийСчетПолучателя = НайденныйСчет;
			
			Если ДобавитьНайденныйСчет Тогда 
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = Лев(НомерСчетаПолучателя,22);
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НайденныйСчет;
				ДобавитьНайденныйСчет = Ложь;
			КонецЕсли;
			
		Иначе
			
			НовыйСчет = НомерСчетаВыписки.Скопировать();
			// Меняем только номерСчета, валюту, наименование
			НовыйСчет.НомерСчета 			= Лев(НомерСчетаПолучателя,22);
			НовыйСчет.ВалютаДенежныхСредств = ВалютаПолучатель;
			НаименованиеБанка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НовыйСчет.Банк, "Наименование");
			НовыйСчет.Наименование 			= Лев(СокрЛП(НовыйСчет.НомерСчета) + ?(ЗначениеЗаполнено(НаименованиеБанка), ", в " + НаименованиеБанка, ""), 100);
			
			Попытка
				
				НовыйСчет.Записать();
				Сообщить(НСтр("ru = 'Был создан новый банковский счет организации: """+ Лев(НомерСчетаПолучателя,22) +"""!'; ka = 'Был создан новый банковский счет организации: """+ Лев(НомерСчетаПолучателя,22) +"""!'"));
				СтрокаТЧ.БанковскийСчетПолучателя = НовыйСчет.Ссылка;
				
				НоваяСтрокаСозданныхСчетов = ТаблицаСозданныхСчетовОрганизации.Добавить();
				НоваяСтрокаСозданныхСчетов.НомерСчета = НомерСчетаПолучателя;
				НоваяСтрокаСозданныхСчетов.БанковскийСчет = НовыйСчет.Ссылка;
				
			Исключение
				
				Сообщить(НСтр("ru = 'Не удалось создать банковский счет организации: """+ Лев(НомерСчетаПолучателя,22) +"""!'; ka = 'Не удалось создать банковский счет организации: """+ Лев(НомерСчетаПолучателя,22) +"""!'"));
				
			КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументыРасходыНаСервере(ИмяТаблицы)
	
	Если ИмяТаблицы = "Поступления" Тогда 
		ТаблицаЗагрузки = Объект.ВходящиеДокументыПоступления;
		КолекцияКолонокТабЧасти = ТаблицаЗагрузки.Выгрузить().Колонки;
		МассивСоздаваемыхДокументов = ТаблицаЗагрузки.НайтиСтроки(Новый Структура("Пометка", Истина));
	ИначеЕсли ИмяТаблицы = "Расходы" Тогда	
		ТаблицаЗагрузки = Объект.ВходящиеДокументыРасходы;
		КолекцияКолонокТабЧасти = ТаблицаЗагрузки.Выгрузить().Колонки;
		МассивСоздаваемыхДокументов = ТаблицаЗагрузки.НайтиСтроки(Новый Структура("Пометка", Истина));
	ИначеЕсли ИмяТаблицы = "Конвертации" Тогда	
		ТаблицаЗагрузки = Объект.ВходящиеДокументыКонвертации;
		КолекцияКолонокТабЧасти = ТаблицаЗагрузки.Выгрузить().Колонки;
		МассивСоздаваемыхДокументов = ТаблицаЗагрузки.НайтиСтроки(Новый Структура("Пометка", Истина));
	КонецЕсли;
	
	КолВоСозданныхДокументов = 0;		
	КоличествоПовторныхПопыток = 0;
	
	МассивНомеровСтрок = Новый Массив;
	
	ТаблицаСозданныхДокументов = Новый ТаблицаЗначений;
	//ТаблицаСозданныхДокументов.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.ПлатежноеПоручениеВходящее"));
	Если ИмяТаблицы = "Поступления" Тогда 
		ТаблицаСозданныхДокументов.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.ПоступлениеНаСчет"));
	ИначеЕсли ИмяТаблицы = "Расходы" Тогда	
		ТаблицаСозданныхДокументов.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.РасходСоСчета"));
	ИначеЕсли ИмяТаблицы = "Конвертации" Тогда	
		ТаблицаСозданныхДокументов.Колонки.Добавить("ДокументСсылка", Новый ОписаниеТипов("ДокументСсылка.Конвертация"));
	КонецЕсли;
	
	ТаблицаСозданныхДокументов.Колонки.Добавить("EntryId", Новый ОписаниеТипов("Строка"));
	
	СтруктураЗаполненияКонтрагента = Новый Структура;
	
	СтруктураЗаполненияКонтрагента.Вставить("Покупатель", Истина);
	СтруктураЗаполненияКонтрагента.Вставить("ВестиРасчетыПоДоговорам", Истина);
	СтруктураЗаполненияКонтрагента.Вставить("ВестиРасчетыПоДокументам", Истина);
	СтруктураЗаполненияКонтрагента.Вставить("ВестиРасчетыПоЗаказам", Истина);
	СтруктураЗаполненияКонтрагента.Вставить("ВестиУчетОплатыПоСчетам", Истина);
	СтруктураЗаполненияКонтрагента.Вставить("ВидКонтрагента", Перечисления.ВидыКонтрагентов.ЮридическоеЛицо);
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаРасчетовСПокупателем", ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыСПокупателями"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаАвансовПокупателя", ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыПоАвансамПолученным"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаРасчетовСПоставщиком", ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыСПоставщиками"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаАвансовПоставщику", ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыПоАвансамВыданным"));
	СтруктураЗаполненияКонтрагента.Вставить("НалогообложениеНДС", Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС);
	СтруктураЗаполненияКонтрагента.Вставить("ВидВыдачиНДФЛ", "7");
	
	СчетаУчета = РегламентированныйУчетСервер.ПолучитьСчетаКонтрагентаПоУмолчанию();	
	
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаРасчетовСПокупателемРегл", СчетаУчета.СчетУчетаРасчетовСПокупателемРегл);
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаАвансовПокупателяРегл", СчетаУчета.СчетУчетаАвансовПокупателяРегл);
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаРасчетовСПоставщикомРегл", СчетаУчета.СчетУчетаРасчетовСПоставщикомРегл);
	СтруктураЗаполненияКонтрагента.Вставить("СчетУчетаАвансовПоставщикуРегл", СчетаУчета.СчетУчетаАвансовПоставщикуРегл);
	
	СтруктураЗаполненияКонтрагента.Вставить("СчетРасчетовСПерсоналом", ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыСПерсоналомПоОплатеТруда"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетРасчетовСПодотчетниками", ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыСПодотчетниками"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетРасчетовПоПерерасходу", ПредопределенноеЗначение("ПланСчетов.Управленческий.ПерерасходПодотчетников"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетРасчетовСПерсоналомРегл", РегламентированныйУчетСервер.ПолучитьСчетПоНомеру("3130"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетРасчетовСПодотчетникамиРегл", РегламентированныйУчетСервер.ПолучитьСчетПоНомеру("1430"));
	СтруктураЗаполненияКонтрагента.Вставить("СчетРасчетовПоПерерасходуРегл", РегламентированныйУчетСервер.ПолучитьСчетПоНомеру("3160"));
	СтруктураЗаполненияКонтрагента.Вставить("Гражданство", Справочники.СтраныМира.НайтиПоКоду("GEO"));
	
	Для Каждого Транзакция ИЗ МассивСоздаваемыхДокументов Цикл
		
		IDВходящегоДокумента = СтрЗаменить(СтрЗаменить(СтрЗаменить(Транзакция.ExternalPaymentId,",",""),Символы.НПП,""), " ", "");
		СуществуетДокумент = ПроверкаНаСуществованиеДанногоДокумента(IDВходящегоДокумента);
		
		Если Транзакция.Пометка И НЕ ЗначениеЗаполнено(Транзакция.ДокументСсылка) И Не СуществуетДокумент Тогда 
			//		
			
			Для Каждого КолонкаТаблицы Из КолекцияКолонокТабЧасти Цикл 
				Если КолонкаТаблицы.Имя <> "НомерСтроки" И КолонкаТаблицы.Имя <> "ИсходныйНомерСтроки" И ТипЗнч(Транзакция[КолонкаТаблицы.Имя]) = Тип("Строка") Тогда 
					Транзакция[КолонкаТаблицы.Имя] = СокрЛП(Транзакция[КолонкаТаблицы.Имя]);
				КонецЕсли;
			КонецЦикла;
			
			//		
			ДатаПодстановки = ДельтаНСФ.ПереводВДату(СокрЛП(Транзакция.valueDate));
			
			Если ИмяТаблицы = "Поступления" Тогда 
				НовыйДокумент 								= Документы.ПоступлениеНаСчет.СоздатьДокумент();
			ИначеЕсли ИмяТаблицы = "Расходы" Тогда
				НовыйДокумент 								= Документы.РасходСоСчета.СоздатьДокумент();
			ИначеЕсли ИмяТаблицы = "Конвертации" Тогда
				НовыйДокумент 								= Документы.Конвертация.СоздатьДокумент();
			КонецЕсли;
			
			Если ИмяТаблицы = "Конвертации" Тогда
				
				СтруктураВалютКупсв = РазобратьКурс(Транзакция.exchangeRate, Транзакция.currency);
				
				Если СтруктураВалютКупсв.Количество() = 0 Тогда 
					Сообщить("Не верно определены валюты");
					Продолжить;
				КонецЕсли;
				
				Если СокрЛП(Транзакция.debitCredit) = "0" Тогда 
					//Если Транзакция.БанковскийСчетОтправителя = НомерСчетаВыписки ТОгда
					Если СтруктураВалютКупсв.Свойство("ВалютаСчетаВыписки") Тогда 
						ВалютаОтправитель = СтруктураВалютКупсв.ВалютаСчетаВыписки;
						ВалютаПолучатель = СтруктураВалютКупсв.ВалютыКоррСчета;
					КонецЕсли;
				ИначеЕсли СокрЛП(Транзакция.debitCredit) = "1" Тогда
					Если СтруктураВалютКупсв.Свойство("ВалютаСчетаВыписки") Тогда
						ВалютаОтправитель = СтруктураВалютКупсв.ВалютыКоррСчета;
						ВалютаПолучатель = СтруктураВалютКупсв.ВалютаСчетаВыписки;
					КонецЕсли;
				КонецЕсли;
				
				Если СоздаватьСчетаКонвертации Тогда 
					ПроверитьЗаполнениеСчетовОрганизации(Транзакция, Организация, ВалютаОтправитель, ВалютаПолучатель);
				КонецЕсли;
				
				НовыйДокумент 						= Документы.Конвертация.СоздатьДокумент();
				
				НовыйДокумент.Автор 				= ПараметрыСеанса.ТекущийПользователь;
				НовыйДокумент.ВалютаОтправитель     = ВалютаОтправитель;
				НовыйДокумент.ВалютаПолучатель      = ВалютаПолучатель;
				НовыйДокумент.ВидОперации           = Транзакция.ВидОперации;
				НовыйДокумент.Дата                  = ДатаПодстановки;
				НовыйДокумент.Комментарий           = Транзакция.additionalInformation;
				
				
				
				НовыйДокумент.Организация           = Организация;
				НовыйДокумент.Отправитель           = Транзакция.БанковскийСчетОтправителя;
				НовыйДокумент.Получатель            = Транзакция.БанковскийСчетПолучателя;
				
				ВалютаОтправитель = Транзакция.БанковскийСчетОтправителя.ВалютаДенежныхСредств;
				ВалютаПолучатель = Транзакция.БанковскийСчетПолучателя.ВалютаДенежныхСредств;
				
				НовыйДокумент.ВалютаОтправитель     = ВалютаОтправитель;
				НовыйДокумент.ВалютаПолучатель      = ВалютаПолучатель;
				НовыйДокумент.Статья                = СтатьяПоУмолчаниюКонвертации;
				НовыйДокумент.СуммаКонвертации      = Число(Транзакция.amount);
				
				Если СтруктураВалютКупсв.Свойство("Курс") Тогда 
					
					Если ВалютаОтправитель = НациональнаяВалюта ИЛИ ВалютаПолучатель = НациональнаяВалюта Тогда 
						НовыйДокумент.КоммерческийКурс      = Число(СтруктураВалютКупсв.Курс); 
					Иначе
						НовыйДокумент.КроссКурс             = Число(СтруктураВалютКупсв.Курс);
					КонецЕсли;
					
					Если ВалютаОтправитель = НациональнаяВалюта Тогда 
						НовыйДокумент.КурсОтправитель       = 1;
						НовыйДокумент.КурсПолучатель        = Число(СтруктураВалютКупсв.Курс);
					ИначеЕсли ВалютаПолучатель = НациональнаяВалюта Тогда
						НовыйДокумент.КурсОтправитель       = Число(СтруктураВалютКупсв.Курс);
						НовыйДокумент.КурсПолучатель        = 1;
					Иначе 
						НовыйДокумент.КурсОтправитель       = 1;
						НовыйДокумент.КурсПолучатель        = 1;
					КонецЕсли;
					
					РасчитатьСуммуПолучателя(НовыйДокумент);
					
				Иначе 
					НовыйДокумент.СуммаПолучено         = Число(Транзакция.amount);
					НовыйДокумент.КоммерческийКурс      = 1;
					НовыйДокумент.КроссКурс             = 1;
					
					НовыйДокумент.КурсОтправитель       = 1;
					НовыйДокумент.КурсПолучатель        = 1;
					
				КонецЕсли;
				
				НовыйДокумент.УникальныйКлючВИнтернетБанке = IDВходящегоДокумента;
				
				НовыйДокумент.КратностьОтправитель  = 1;
				НовыйДокумент.КратностьПолучатель   = 1;
				
			Иначе
				
				ВалютаЗаполнения = ПолучитьВалюту(Транзакция.currency);
				Если ЭтаФорма["СоздаватьКонтрагентовСчета"+ИмяТаблицы] Тогда 
					ПроверитьЗаполнениеКонтрагентаДоговораСчета(Транзакция, СтруктураЗаполненияКонтрагента, ВалютаЗаполнения, ИмяТаблицы);
				КонецЕсли;
				//		
				НовыйДокумент.ВариантЗаполненияРасшифровки = ПредопределенноеЗначение("Перечисление.ВариантыЗаполненияРасшифровкиПлатежа.Вручную");
				Сотрудник = Ложь;
				Если  ТипЗнч(Транзакция.Контрагент) = Тип("СправочникСсылка.Контрагенты") Тогда
					НовыйДокумент.Контрагент = Транзакция.Контрагент; 
					НовыйДокумент.НалогообложениеНДС = ?(ЗначениеЗаполнено(НовыйДокумент.Контрагент), НовыйДокумент.Контрагент.НалогообложениеНДС, Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС);
				Иначе
					Сотрудник = Истина;
					НовыйДокумент.Подотчетник = Транзакция.Контрагент;
				КонецЕсли;
				//		
				НовыйДокумент.ВалютаДенежныхСредств           	= ВалютаЗаполнения;
				НовыйДокумент.ВидОперации               		= Транзакция.ВидОперации;
				НовыйДокумент.Дата                          	= ДатаПодстановки;
				НовыйДокумент.ДатаВходящегоДокумента        	= ДатаПодстановки;
				НовыйДокумент.Комментарий                   	= Транзакция.additionalInformation;
				
				НовыйДокумент.НазначениеПлатежа             	= Транзакция.description;
				НовыйДокумент.Оплачено                      	= Истина;
				НовыйДокумент.Организация                   	= Организация;
				НовыйДокумент.Автор			                	= ПараметрыСеанса.ТекущийПользователь;
				НовыйДокумент.СуммаДокумента                	= Число(Транзакция.amount);
				
				СтрокаРасшифровки = НовыйДокумент.РасшифровкаПлатежа.Добавить();
				СтрокаРасшифровки.Договор = Транзакция.ДоговорКонтрагента;
				СтрокаРасшифровки.ПризнакАванса = Истина;
				
				СуммаДокументаПриИзмененииРасход(НовыйДокумент);
				
				Если ИмяТаблицы = "Поступления" Тогда 
					НовыйДокумент.СчетКонтрагента               = Транзакция.БанковскийСчетОтправителя;
					НовыйДокумент.ВариантЗаполненияРасшифровки 	= Перечисления.ВариантыЗаполненияРасшифровкиПлатежа.Автоматически;
					
					СтрокаДоговора 								= НовыйДокумент.ДоговорыАвтоЗачетаДолгов.Добавить();
					СтрокаДоговора.Договор 						= Транзакция.ДоговорКонтрагента;
					СтрокаДоговора.СуммаПлатежа 				= Число(Транзакция.amount);
				ИначеЕсли ИмяТаблицы = "Расходы" Тогда
					НовыйДокумент.СчетКонтрагента               = Транзакция.БанковскийСчетПолучателя;
				КонецЕсли;
				
				НовыйДокумент.БанковскийСчет                = НомерСчетаВыписки;
				
				НовыйДокумент.Корреспонденция 				= Транзакция.Корреспонденция;
				НовыйДокумент.КорреспонденцияРегл			= Транзакция.КорреспонденцияРегл;
				НовыйДокумент.Статья						= Транзакция.Статья;
				
			КонецЕсли;
		
			НовыйДокумент.Записать();
			КолВоСозданныхДокументов = КолВоСозданныхДокументов + 1;
			
			НаборЗаписейУИДДокумента = РегистрыСведений.УИДДокументовВИнтернетБанке.СоздатьНаборЗаписей();
			НаборЗаписейУИДДокумента.Отбор.ДокументСсылка.Установить(НовыйДокумент.Ссылка);
			НаборЗаписейУИДДокумента.Отбор.Сотрудник.Установить(Справочники.Сотрудники.ПустаяСсылка());
			НаборЗаписейУИДДокумента.Отбор.Банк.Установить(НомерСчетаВыписки.Банк);
			
			НовыйУИД = НаборЗаписейУИДДокумента.Добавить();
			НовыйУИД.ДокументСсылка = НовыйДокумент.Ссылка;
			НовыйУИД.Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
			НовыйУИД.Банк = НомерСчетаВыписки.Банк;
			НовыйУИД.УИДДокументаВБанке = IDВходящегоДокумента;
			НовыйУИД.Выгружен = Истина;
			
			НаборЗаписейУИДДокумента.Записать();
			
			// Запись нового статуса
			ДатаЗаписи = ТекущаяДата();
			НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
			НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(НовыйДокумент.Ссылка);
			НаборЗаписейСтатусовДокумента.Отбор.Сотрудник.Установить(Справочники.Сотрудники.ПустаяСсылка());
			НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ДатаЗаписи);
			НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(НомерСчетаВыписки.Банк);
			
			НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
			НовыйСтатус.ДокументСсылка = НовыйДокумент.Ссылка;
			НовыйСтатус.Период = ДатаЗаписи;
			НовыйСтатус.Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
			НовыйСтатус.Банк = НомерСчетаВыписки.Банк;
			НовыйСтатус.СтатусДокументаВИнтернетБанке = Перечисления.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка;
			
			НаборЗаписейСтатусовДокумента.Записать();
			
			Если ЭтаФорма["ПытатьсяПровестиДокумент"+ИмяТаблицы] Тогда 
				Попытка
					НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
					Транзакция.Проведен = Истина;
				Исключение
					а=1;
				КонецПопытки;
				
			КонецЕсли;
			Транзакция.ДокументСсылка = НовыйДокумент.Ссылка;
			//		
		КонецЕсли;	
		//	
		Если СуществуетДокумент И Транзакция.Пометка Тогда
			
			СозданныйДокумент = ПолучитьСуществующийДокумент(IDВходящегоДокумента);
			
			НоваяСтрока = ТаблицаСозданныхДокументов.Добавить();
			НоваяСтрока.ДокументСсылка = СозданныйДокумент;
			НоваяСтрока.EntryId = IDВходящегоДокумента;
			
			МассивНомеровСтрок.Добавить(Транзакция.НомерСтроки);			
			КоличествоПовторныхПопыток = КоличествоПовторныхПопыток + 1;
		КонецЕсли;	
		
		Если ИмяТаблицы = "Поступления" Тогда
			
			Для Каждого СтрокаТЧ ИЗ Объект.ВходящиеДокументыПоступления Цикл
				
				// Дозаполним поле контрагент
				СтруктураПоиска = Новый Структура("ИНН, Наименование", ?(СокрЛП(СтрокаТЧ.partnerPersonalNumber)="", СокрЛП(СтрокаТЧ.partnerTaxCode),СокрЛП(СтрокаТЧ.partnerPersonalNumber)), СокрЛП(СтрокаТЧ.partnerName));
				
				МассивНайденныхСтрок = ТаблицаСозданныхКонтрагентов.НайтиСтроки(СтруктураПоиска);
				
				Если МассивНайденныхСтрок.Количество() <> 0 Тогда
					СтрокаТЧ.Контрагент = МассивНайденныхСтрок[0].Контрагент;
				КонецЕсли;
			КонецЦикла;
			
		ИначеЕсли ИмяТаблицы = "Расходы" Тогда 
			
			Для Каждого СтрокаТЧ ИЗ Объект.ВходящиеДокументыРасходы Цикл
				
				// Дозаполним поле контрагент
				СтруктураПоиска = Новый Структура("ИНН, Наименование",?(СокрЛП(СтрокаТЧ.partnerPersonalNumber)="", СокрЛП(СтрокаТЧ.partnerTaxCode),СокрЛП(СтрокаТЧ.partnerPersonalNumber)), СокрЛП(СтрокаТЧ.partnerName));
				
				МассивНайденныхСтрок = ТаблицаСозданныхКонтрагентов.НайтиСтроки(СтруктураПоиска);
				
				Если МассивНайденныхСтрок.Количество() <> 0 Тогда
					СтрокаТЧ.Контрагент = МассивНайденныхСтрок[0].Контрагент;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;	
//
	ТекстКолВоСозданныхДокументов = Нстр("ka='შექმნილია "+ КолВоСозданныхДокументов + " დოკუმენტი! ';ru='Создано "+ КолВоСозданныхДокументов + " документа/ов'");
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстКолВоСозданныхДокументов,,,, ЛОЖЬ);
	
	Если КоличествоПовторныхПопыток > 0 Тогда 		
		Для Каждого ЭлементМассива ИЗ МассивНомеровСтрок Цикл 
			ТекстКолВоСозданныхДокументов = Нстр("ka='სტრიქონისთვის № "+ ЭлементМассива + " არ შეიქმნა დოკუმენტი, რადგან ამ ჩანაწერისთვის სისტემაში უკვე არსებობს დოკუმენტი! ';ru='Для строки № "+ ЭлементМассива + " не создано документа, так как для этой записи в системе уже создан документ!'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстКолВоСозданныхДокументов,,,, ЛОЖЬ);		
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РасчитатьСуммуПолучателя(ДокОбъект)
	
	Если НЕ ЗначениеЗаполнено(ДокОбъект.КурсПолучатель) Тогда 
		Возврат;
	КонецЕсли;
	
	Если НациональнаяВалюта = ДокОбъект.ВалютаОтправитель ИЛИ НациональнаяВалюта = ДокОбъект.ВалютаПолучатель Тогда 
			
			Если ДокОбъект.ВалютаОтправитель = НациональнаяВалюта И НациональнаяВалюта <> ДокОбъект.ВалютаПолучатель Тогда 
				ДокОбъект.СуммаПолучено = ДокОбъект.СуммаКонвертации / ДокОбъект.КоммерческийКурс; //кратность = 1
			ИначеЕсли ДокОбъект.ВалютаОтправитель <> НациональнаяВалюта И НациональнаяВалюта = ДокОбъект.ВалютаПолучатель Тогда 
				ДокОбъект.СуммаПолучено = ДокОбъект.СуммаКонвертации * ДокОбъект.КоммерческийКурс;
			КонецЕсли;
			
		Иначе
			
			// Крос Курс учитывает отправителя и получателя
			ДокОбъект.СуммаПолучено = ДокОбъект.СуммаКонвертации * ДокОбъект.КроссКурс;
		КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция ПолучитьСуществующийДокумент(EntryId)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	УИДДокументовВИнтернетБанке.ДокументСсылка
	               |ИЗ
	               |	РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
	               |ГДЕ
	               |	УИДДокументовВИнтернетБанке.УИДДокументаВБанке = &EntryId";
	
	Запрос.УстановитьПараметр("EntryId", EntryId);
	
	Результат = Запрос.Выполнить();	
	Выборка = Результат.Выбрать();	
	Выборка.Следующий();
	
	Возврат Выборка.ДокументСсылка;
	
КонецФункции

&НаСервере
Процедура СуммаДокументаПриИзмененииРасход(Объект)
	
	Компания = УправлениеНебольшойФирмойСервер.ПолучитьОрганизацию(Объект.Организация);
	СтруктураПоВалюте = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(Объект.Дата, Новый Структура("Валюта", Объект.ВалютаДенежныхСредств));
	Курс = ?(
		СтруктураПоВалюте.Курс = 0,
		1,
		СтруктураПоВалюте.Курс
	);
	Кратность = ?(
		СтруктураПоВалюте.Курс = 0,
		1,
		СтруктураПоВалюте.Кратность
	);
	
	Если Объект.РасшифровкаПлатежа.Количество() = 1 И
		НЕ (Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.Поставщику И 
		Объект.ВариантЗаполненияРасшифровки = Перечисления.ВариантыЗаполненияРасшифровкиПлатежа.СПомощником) Тогда
		
		СтрокаТабличнойЧасти = Объект.РасшифровкаПлатежа[0];
		
		СтрокаТабличнойЧасти.СуммаПлатежа = Объект.СуммаДокумента;
		
		// Эквайринг
		Если Объект.ВидОперации = Перечисления.ВидыОперацийРасходСоСчета.ВозвратОплатыНаПлатежныеКарты Тогда
			СтрокаТабличнойЧасти.СуммаПлатежа = СтрокаТабличнойЧасти.СуммаПлатежа + Объект.СуммаКомиссииДокумента;
		КонецЕсли;
		// Конец Эквайринг
		
		СтрокаТабличнойЧасти.Курс = ?(
			СтрокаТабличнойЧасти.Курс = 0,
			1,
			СтрокаТабличнойЧасти.Курс
		);
		
		СтрокаТабличнойЧасти.Кратность = ?(
			СтрокаТабличнойЧасти.Кратность = 0,
			1,
			СтрокаТабличнойЧасти.Кратность
		);
		
		СтрокаТабличнойЧасти.СуммаРасчетов = ПересчитатьИзВалютыВВалюту(
			СтрокаТабличнойЧасти.СуммаПлатежа,
			Курс,
			СтрокаТабличнойЧасти.Курс,
			Кратность,
			СтрокаТабличнойЧасти.Кратность
		);
		
		Если НЕ ЗначениеЗаполнено(СтрокаТабличнойЧасти.СтавкаНДС) Тогда
			СтрокаТабличнойЧасти.СтавкаНДС = Справочники.СтавкиНДС.НДС18;
		КонецЕсли;
		
		//СтрокаТабличнойЧасти.Аванс = ?(СтрокаТабличнойЧасти.ПризнакАванса, СтрокаТабличнойЧасти.СуммаПлатежа, 0);
		
		РассчитатьСуммуНДС(СтрокаТабличнойЧасти);
		
	КонецЕсли;
	
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ТипОтправки", Объект.Метаданные()) Тогда 
		Если Объект.СуммаДокумента < 10000 Тогда 
			Объект.ТипОтправки = ПредопределенноеЗначение("Перечисление.ТипыОтправки.BULK");
		Иначе
			Объект.ТипОтправки = ПредопределенноеЗначение("Перечисление.ТипыОтправки.MT103");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьСуммуНДС(СтрокаТабличнойЧасти)
	
	СтавкаНДС = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(СтрокаТабличнойЧасти.СтавкаНДС);
	
	СтрокаТабличнойЧасти.СуммаНДС = СтрокаТабличнойЧасти.СуммаПлатежа - (СтрокаТабличнойЧасти.СуммаПлатежа) / ((СтавкаНДС + 100) / 100);
	
КонецПроцедуры

&НаСервере
Функция ПересчитатьИзВалютыВВалюту(Сумма, КурсНач, КурсКон,	КратностьНач = 1, КратностьКон = 1) Экспорт
	
	Если (КурсНач = КурсКон) И (КратностьНач = КратностьКон) Тогда
		Возврат Сумма;
	КонецЕсли;
	
	Если КурсНач = 0 ИЛИ КурсКон = 0 ИЛИ КратностьНач = 0 ИЛИ КратностьКон = 0 Тогда
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = НСтр("ka='აღმოჩენილია ვალუტის ნულოვანი კურსი. გადათვლა არ შესრულდა.';ru='Обнаружен нулевой курс валюты. Пересчет не выполнен.';en='Discovered a zero rate. Adjustment is not performed.'");
		Сообщение.Сообщить();
		Возврат Сумма;
	КонецЕсли;
	
	СуммаПересчитанная = Окр((Сумма * КурсНач * КратностьКон) / (КурсКон * КратностьНач), 2);
	
	Возврат СуммаПересчитанная;
	
КонецФункции

