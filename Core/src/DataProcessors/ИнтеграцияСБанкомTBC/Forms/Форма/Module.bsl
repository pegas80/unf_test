Процедура ФильтрПриИзменении(Элемент)
	
	ИмяТаблицы = "";
	Если Найти(Элемент.Имя, "Расходы") <> 0 Тогда 
		ИмяТаблицы = "Расходы";
	ИначеЕсли Найти(Элемент.Имя, "Конвертации") <> 0 Тогда
		ИмяТаблицы = "Конвертации";
	ИначеЕсли Найти(Элемент.Имя, "Поступления") <> 0 Тогда
		ИмяТаблицы = "Поступления"; 
	КонецЕсли;
	
	ОбновитьВидимость(ИмяТаблицы);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимость(ИмяТаблицы)
	
	Для Каждого Строк Из Объект["ВходящиеДокументы" + ИмяТаблицы] Цикл
		
		Строк.Видимость = ЛОЖЬ;
		
		Контрагент = Неопределено;
		ДоговорКонтрагента = Неопределено;
		
		Если ИмяТаблицы <> "Конвертации" Тогда 
			
			Контрагент = Строк.Контрагент;
			ДоговорКонтрагента = Строк.ДоговорКонтрагента;
			
		КонецЕсли;
		
		Строк.Видимость = ОпределитьВидимость(Строк.ДокументСсылка, Контрагент, ДоговорКонтрагента, Строк.БанковскийСчетПолучателя, ИмяТаблицы, Строк.БанковскийСчетОтправителя);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ОпределитьВидимость(ДокСсылка, Контрагент, Договор, БанковскийСчет, ИмяТаблицы, СчетОтправителя = Неопределено)
	                          
	Если ЭтаФорма["ФильтрЗеленого"+ИмяТаблицы] Тогда 
		
		Если ЗначениеЗаполнено(ДокСсылка) И ДокСсылка.Проведен Тогда 
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтаФорма["ФильтрСерого"+ИмяТаблицы] Тогда 
		
		Если ЗначениеЗаполнено(ДокСсылка) И НЕ ДокСсылка.Проведен Тогда 
			Возврат Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтаФорма["ФильтрКрасного"+ИмяТаблицы] Тогда 
		
		Если ИмяТаблицы = "Конвертации" Тогда 
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И (НЕ ЗначениеЗаполнено(БанковскийСчет) 
				ИЛИ НЕ ЗначениеЗаполнено(СчетОтправителя)) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		Иначе
			
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И (НЕ ЗначениеЗаполнено(Контрагент)
				ИЛИ НЕ ЗначениеЗаполнено(Договор)
				ИЛИ НЕ ЗначениеЗаполнено(БанковскийСчет)) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЭтаФорма["ФильтрЖолтого"+ИмяТаблицы] Тогда 
		
		Если ИмяТаблицы = "Конвертации" Тогда 
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И ЗначениеЗаполнено(БанковскийСчет) 
				И ЗначениеЗаполнено(СчетОтправителя) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		Иначе
			Если НЕ ЗначениеЗаполнено(ДокСсылка) 
				И ЗначениеЗаполнено(Контрагент)
				И ЗначениеЗаполнено(Договор)
				И ЗначениеЗаполнено(БанковскийСчет) Тогда 
				
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЛОЖЬ;
	
КонецФункции


