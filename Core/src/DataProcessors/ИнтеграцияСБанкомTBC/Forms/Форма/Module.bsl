&НаСервере
Процедура ПерезаполнитьДанныеПриИзмененииЗначенияДокументСсылка(СтрокаТабЧасти, ИмяТаблицы, ИмяКолонки)
	
	ДокументСсылка = СтрокаТабЧасти[ИмяКолонки];
	
	СтрокаТабЧасти.ВидОперации = ДокументСсылка.ВидОперации;
	
	Если ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику")
		ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику")
		ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником")
		ИЛИ ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника") Тогда 
		
		СтрокаТабЧасти.Контрагент = ДокументСсылка.Подотчетник;
		
	ИначеЕсли ДокументСсылка.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Налоги") Тогда 
		
		СтрокаТабЧасти.Контрагент = ДокументСсылка.КодКазначейства;
		
	ИначеЕсли ИмяТаблицы <> "ВходящиеДокументыКонвертации" Тогда  
		
		СтрокаТабЧасти.Контрагент = ДокументСсылка.Контрагент;
		
	КонецЕсли;
	
	Если ИмяТаблицы <> "ВходящиеДокументыКонвертации" Тогда
		СтрокаТабЧасти.ДоговорКонтрагента = ДокументСсылка.ДоговорДляЗачетаАвансаСПомощником;
	КонецЕсли;
	
	Если ИмяТаблицы = "ВходящиеДокументыПоступления" Тогда 
		
		СтрокаТабЧасти.БанковскийСчетПолучателя = ДокументСсылка.БанковскийСчет;
		СтрокаТабЧасти.БанковскийСчетОтправителя = ДокументСсылка.СчетКонтрагента;
		
	ИначеЕсли ИмяТаблицы = "ВходящиеДокументыРасходы" Тогда
		
		СтрокаТабЧасти.БанковскийСчетПолучателя = ДокументСсылка.СчетКонтрагента;
		СтрокаТабЧасти.БанковскийСчетОтправителя = ДокументСсылка.БанковскийСчет;
		
	ИначеЕсли ИмяТаблицы = "ВходящиеДокументыКонвертации" И СокрЛП(СтрокаТабЧасти.debitCredit) = "0" Тогда
		
		СтрокаТабЧасти.БанковскийСчетПолучателя = ДокументСсылка.Получатель;
		СтрокаТабЧасти.БанковскийСчетОтправителя = ДокументСсылка.Отправитель;
		
	ИначеЕсли ИмяТаблицы = "ВходящиеДокументыКонвертации" И СокрЛП(СтрокаТабЧасти.debitCredit) = "1" Тогда
		
		СтрокаТабЧасти.БанковскийСчетПолучателя = ДокументСсылка.Отправитель;
		СтрокаТабЧасти.БанковскийСчетОтправителя = ДокументСсылка.Получатель;
		
	КонецЕсли;
	
	СтрокаТабЧасти.Статья = ДокументСсылка.Статья;
	СтрокаТабЧасти.Проведен = ДокументСсылка.Проведен;
	
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьДанныеПриИзмененииЗначенияКонтрагент(СтрокаТабЧасти, ИмяТаблицы, ИмяКолонки)
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("Контрагент",		СтрокаТабЧасти.Контрагент);
	СтруктураВозврата.Вставить("ДоговорКонтрагента",СтрокаТабЧасти.ДоговорКонтрагента);
	
	Если ИмяТаблицы = "ВходящиеДокументыПоступления" Тогда 
		СтруктураВозврата.Вставить("СчетКонтрагента",	СтрокаТабЧасти.БанковскийСчетОтправителя);
	ИначеЕсли ИмяТаблицы = "ВходящиеДокументыРасходы" Тогда
		СтруктураВозврата.Вставить("СчетКонтрагента",	СтрокаТабЧасти.БанковскийСчетПолучателя);
	КонецЕсли;
	
	ПриоритетПоиска = ?(ТипЗнч(СтрокаТабЧасти.Контрагент) = Тип("СправочникСсылка.Контрагенты"), 1, 2);
	
	// 1-контрагент, 2-Сотрудник, 0-Любого найденного
	НайтиКонтрагентаСотрудникаПоИНН(СокрЛП(СтрокаТабЧасти.partnerPersonalNumber), ПриоритетПоиска, СтруктураВозврата);
	
	Если СтруктураВозврата.Контрагент = Неопределено ИЛИ СтруктураВозврата.Контрагент = ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка") Тогда 
		// Мало вероятно, но всё же
		СтрокаТабЧасти.Контрагент 			= ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка");
		СтрокаТабЧасти.ДоговорКонтрагента	= СтруктураВозврата.ДоговорКонтрагента;
		
		Если ИмяТаблицы = "ВходящиеДокументыПоступления" Тогда 
			СтрокаТабЧасти.БанковскийСчетОтправителя = СтруктураВозврата.СчетКонтрагента;
		ИначеЕсли ИмяТаблицы = "ВходящиеДокументыРасходы" Тогда
			СтрокаТабЧасти.БанковскийСчетПолучателя = СтруктураВозврата.СчетКонтрагента;
		КонецЕсли;
		
	Иначе
		СтрокаТабЧасти.Контрагент 			= СтруктураВозврата.Контрагент;
		СтрокаТабЧасти.ДоговорКонтрагента	= СтруктураВозврата.ДоговорКонтрагента;
		
		Если ИмяТаблицы = "ВходящиеДокументыПоступления" Тогда 
			СтрокаТабЧасти.БанковскийСчетОтправителя = СтруктураВозврата.СчетКонтрагента;
		ИначеЕсли ИмяТаблицы = "ВходящиеДокументыРасходы" Тогда
			СтрокаТабЧасти.БанковскийСчетПолучателя = СтруктураВозврата.СчетКонтрагента;
		КонецЕсли;
		
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьДанныеПриИзмененииЗначенияВидОперации(СтрокаТабЧасти, ИмяТаблицы, ИмяКолонки)
	
	ИНН = ?(СокрЛП(СтрокаТабЧасти.partnerPersonalNumber) = "", СокрЛП(СтрокаТабЧасти.partnerTaxCode), СокрЛП(СтрокаТабЧасти.partnerPersonalNumber)); 
	СтруктураНастройки = ПолучитьСтруктуруСтаатьиКорреспонденциюКонтрагентаПоВидуОперации(ИмяТаблицы, СтрокаТабЧасти.ВидОперации, СтрокаТабЧасти.Контрагент, ИНН);
	
	СтрокаТабЧасти.Корреспонденция 			= СтруктураНастройки.Корреспонденция;
	СтрокаТабЧасти.КорреспонденцияРегл   	= СтруктураНастройки.КорреспонденцияРегл;
	СтрокаТабЧасти.Статья                	= СтруктураНастройки.Статья;
	
	// Если СтруктураНастройки.Контрагент <> Неопределено, то менять ничего не нужно
	Если СтруктураНастройки.Контрагент <> Неопределено Тогда 
		СтрокаТабЧасти.Контрагент 			= СтруктураНастройки.Контрагент;
		
		Если ИмяТаблицы = "ВходящиеДокументыПоступления" Тогда 
			СтрокаТабЧасти.БанковскийСчетОтправителя = СтруктураНастройки.СчетКонтрагента;
		ИначеЕсли ИмяТаблицы = "ВходящиеДокументыРасходы" Тогда
			СтрокаТабЧасти.БанковскийСчетПолучателя = СтруктураНастройки.СчетКонтрагента;
		КонецЕсли;
		//СтрокаТабЧасти.СчетКонтрагента   	= СтруктураНастройки.СчетКонтрагента;
		СтрокаТабЧасти.Контрагент 			= СтруктураНастройки.Контрагент;
		СтрокаТабЧасти.ДоговорКонтрагента	= СтруктураНастройки.ДоговорКонтрагента;
	КонецЕсли;
	
	ПредыдущиеЗначениеВидаОперации = СтрокаТабЧасти.ВидОперации;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруСтаатьиКорреспонденциюКонтрагентаПоВидуОперации(ИмяТаблицыНастройки, ВидОперации, КонтрагентСотрудник, ИННКонтрагента)
	
	СтруктураВозврата = Новый Структура("Корреспонденция, КорреспонденцияРегл, Статья, Контрагент, СчетКонтрагента, ДоговорКонтрагента");
	
	СтруктураОтбора = Новый Структура("ВидОперации", ВидОперации);
	
	МассивНайденныхСтрок = Новый Массив;
	Если ИмяТаблицыНастройки = "ВходящиеДокументыПоступления" Тогда 
		МассивНайденныхСтрок = СчетаУчетаПоУмолчаниюПриходы.НайтиСтроки(СтруктураОтбора);
	ИначеЕсли ИмяТаблицыНастройки = "ВходящиеДокументыРасходы" Тогда 
		МассивНайденныхСтрок = СчетаУчетаПоУмолчаниюРасход.НайтиСтроки(СтруктураОтбора);
	КонецЕсли;
	
	Если МассивНайденныхСтрок.Количество() <> 0 Тогда 
		СтруктураВозврата.Корреспонденция 		= МассивНайденныхСтрок[0].Корреспонденция;
		СтруктураВозврата.КорреспонденцияРегл 	= МассивНайденныхСтрок[0].КорреспонденцияРегл;
		СтруктураВозврата.Статья 				= МассивНайденныхСтрок[0].Статья;
	КонецЕсли;
	
	НуженСотрудник = (ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику")
			ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику")
			ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником")
			ИЛИ ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника"));
	
	Если ВидОперации <> ПредыдущиеЗначениеВидаОперации Тогда 
		Если НуженСотрудник 
			И (ТипЗнч(КонтрагентСотрудник) = Тип("СправочникСсылка.Контрагенты") 
				ИЛИ НЕ ЗначениеЗаполнено(КонтрагентСотрудник)) Тогда 
			
			// 1-контрагент, 2-Сотрудник, 0-Любого найденного
			НайтиКонтрагентаСотрудникаПоИНН(ИННКонтрагента, 2, СтруктураВозврата); 
			
			Если СтруктураВозврата.Контрагент = Неопределено Тогда 
				СтруктураВозврата.Контрагент = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
			КонецЕсли;
			
		ИначеЕсли НЕ НуженСотрудник 
			И (ТипЗнч(КонтрагентСотрудник) = Тип("СправочникСсылка.Сотрудники") 
				ИЛИ НЕ ЗначениеЗаполнено(КонтрагентСотрудник)) Тогда 
			
			// 1-контрагент, 2-Сотрудник, 0-Любого найденного
			НайтиКонтрагентаСотрудникаПоИНН(ИННКонтрагента, 1, СтруктураВозврата); 
			
			Если СтруктураВозврата.Контрагент = Неопределено Тогда 
				СтруктураВозврата.Контрагент = ПредопределенноеЗначение("Справочник.Контрагенты.ПустаяСсылка");
			КонецЕсли;
			
		Иначе 
			СтруктураВозврата.Контрагент = Неопределено;
		КонецЕсли;
	Иначе
		СтруктураВозврата.Контрагент = Неопределено;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
		
КонецФункции

&НаСервере
Процедура ВходящиеДокументыПоступленияПриИзмененииНаСервере(УИДСтроки, ИмяТаблицы, ИмяКолонки)
	                  
	СтрокаТабЧасти = Объект[ИмяТаблицы].НайтиПоИдентификатору(УИДСтроки);
	
	Если ИмяКолонки = "ДокументСсылка" Тогда 
		ПерезаполнитьДанныеПриИзмененииЗначенияДокументСсылка(СтрокаТабЧасти, ИмяТаблицы, ИмяКолонки);
	ИначеЕсли ИмяКолонки = "Контрагент" Тогда
		ПерезаполнитьДанныеПриИзмененииЗначенияКонтрагент(СтрокаТабЧасти, ИмяТаблицы, ИмяКолонки);
	ИначеЕсли ИмяКолонки = "ВидОперации" Тогда 
		ПерезаполнитьДанныеПриИзмененииЗначенияВидОперации(СтрокаТабЧасти, ИмяТаблицы, ИмяКолонки);
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ВходящиеДокументыПоступленияПриИзменении(Элемент)
	
	Если ТипЗнч(Элемент.Родитель) = Тип("ТаблицаФормы") Тогда 
		ИмяТаблицы = Элемент.Родитель.Имя;
	Иначе       
		
		ЭлемПоиска = Элемент;
		Пока ТипЗнч(ЭлемПоиска.Родитель) <> Тип("ТаблицаФормы") Цикл 
			ЭлемПОиска = ЭлемПоиска.Родитель;
		КонецЦикла;
		
		ИмяТаблицы = ЭлемПоиска.Родитель.Имя;
		
	КонецЕсли;
	
	ИмяКолонки = СтрЗаменить(Элемент.Имя, ИмяТаблицы, "");
	
	УИДСтроки = Элементы[ИмяТаблицы].ТекущиеДанные.ПолучитьИдентификатор();
	
	ВходящиеДокументыПоступленияПриИзмененииНаСервере(УИДСтроки, ИмяТаблицы, ИмяКолонки);
	
КонецПроцедуры


&НаКлиенте
Процедура ВходящиеДокументыКонтрагентНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ИмяТаблицы = Элемент.Родитель.Имя;
	
	ТекущаяСтрока = Элементы[ИмяТаблицы].ТекущиеДанные;
	
	Массив = Новый Массив;
	
	Если ТекущаяСтрока.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.ВыдачаЗаймаСотруднику") 
		ИЛИ ТекущаяСтрока.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Подотчетнику")
		ИЛИ ТекущаяСтрока.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ВозвратЗаймаСотрудником") 
		ИЛИ ТекущаяСтрока.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеНаСчет.ОтПодотчетника") Тогда 
		
		Массив.Добавить(Тип("СправочникСсылка.Сотрудники")); 
		
	ИначеЕсли ТекущаяСтрока.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Налоги") Тогда 
		
		Массив.Добавить(Тип("СправочникСсылка.КодыКазначейства"));
		
	ИНаче
		
		Массив.Добавить(Тип("СправочникСсылка.Контрагенты"));
		
	КонецЕсли;
	
	Если Массив.Количество() > 0 Тогда 
		Элемент.ОграничениеТипа = новый ОписаниеТипов(Массив);
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
Процедура НайтиКонтрагентаСотрудникаПоИНН(ИННКонтрагента, ПриоритетеПоиска, СтруктураВозврата)
	
	СтруктураВозврата.Контрагент = Неопределено;
	СтруктураВозврата.СчетКонтрагента = ПредопределенноеЗначение("Справочник.БанковскиеСчета.ПустаяСсылка");
	СтруктураВозврата.ДоговорКонтрагента = ПредопределенноеЗначение("Справочник.ДоговорыКонтрагентов.ПустаяСсылка");
	
	Если ИННКонтрагента = "" Тогда 
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка,
		|	1 КАК ПриоритетПоиска,
		|	Контрагенты.ДоговорПоУмолчанию,
		|	Контрагенты.БанковскийСчетПоУмолчанию
		|ПОМЕСТИТЬ ВТ_КонтрагентСотрудник
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ИНН = &ИННКонтрагента
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка,
		|	2,
		|	ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка),
		|	Сотрудники.БанковскийСчетПоУмолчанию
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Физлицо.ИНН = &ИННКонтрагента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ДоговорыКонтрагентов.Ссылка,
		|	ДоговорыКонтрагентов.Владелец
		|ПОМЕСТИТЬ ВТ_Договра
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|ГДЕ
		|	ДоговорыКонтрагентов.Владелец В
		|			(ВЫБРАТЬ
		|				а.Ссылка
		|			ИЗ
		|				ВТ_КонтрагентСотрудник КАК а
		|			ГДЕ
		|				а.Ссылка ССЫЛКА Справочник.Контрагенты)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	БанковскиеСчета.Ссылка,
		|	БанковскиеСчета.Владелец
		|ПОМЕСТИТЬ ВТ_БанковскиеСчета
		|ИЗ
		|	Справочник.БанковскиеСчета КАК БанковскиеСчета
		|ГДЕ
		|	БанковскиеСчета.Владелец В
		|			(ВЫБРАТЬ
		|				а.Ссылка
		|			ИЗ
		|				ВТ_КонтрагентСотрудник КАК а)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_КонтрагентСотрудник.Ссылка КАК Контрагент,
		|	ВТ_КонтрагентСотрудник.ПриоритетПоиска,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_КонтрагентСотрудник.ДоговорПоУмолчанию, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)
		|			ТОГДА ЕСТЬNULL(ВТ_Договра.Ссылка, ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка))
		|		ИНАЧЕ ВТ_КонтрагентСотрудник.ДоговорПоУмолчанию
		|	КОНЕЦ КАК ДоговорКонтрагента,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ВТ_КонтрагентСотрудник.БанковскийСчетПоУмолчанию, ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)) = ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка)
		|			ТОГДА ЕСТЬNULL(ВТ_БанковскиеСчета.Ссылка, ЗНАЧЕНИЕ(Справочник.БанковскиеСчета.ПустаяСсылка))
		|		ИНАЧЕ ВТ_КонтрагентСотрудник.БанковскийСчетПоУмолчанию
		|	КОНЕЦ КАК СчетКонтрагента
		|ИЗ
		|	ВТ_КонтрагентСотрудник КАК ВТ_КонтрагентСотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Договра КАК ВТ_Договра
		|		ПО ВТ_КонтрагентСотрудник.Ссылка = ВТ_Договра.Владелец
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_БанковскиеСчета КАК ВТ_БанковскиеСчета
		|		ПО ВТ_КонтрагентСотрудник.Ссылка = ВТ_БанковскиеСчета.Владелец";
	
	Запрос.УстановитьПараметр("ИННКонтрагента", ИННКонтрагента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ПриоритетеПоиска = 0 Тогда 
			СтруктураВозврата.Контрагент = ВыборкаДетальныеЗаписи.Контрагент;
			СтруктураВозврата.СчетКонтрагента = ВыборкаДетальныеЗаписи.СчетКонтрагента;
			СтруктураВозврата.ДоговорКонтрагента = ВыборкаДетальныеЗаписи.ДоговорКонтрагента;
			Прервать;
		ИначеЕсли ВыборкаДетальныеЗаписи.ПриоритетПоиска = ПриоритетеПоиска Тогда 
			СтруктураВозврата.Контрагент = ВыборкаДетальныеЗаписи.Контрагент;
			СтруктураВозврата.СчетКонтрагента = ВыборкаДетальныеЗаписи.СчетКонтрагента;
			СтруктураВозврата.ДоговорКонтрагента = ВыборкаДетальныеЗаписи.ДоговорКонтрагента;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СменаПароля(Команда)
	
	ФормаСменыПароля = ПолучитьФорму("Обработка.ИнтеграцияСБанкомTBC.Форма.ФормаСменыПароля", ,ЭтаФорма);
	
	ФормаСменыПароля.Открыть();
	
КонецПроцедуры

&НаКлиенте
Процедура ВходящиеДокументыРасходыВидОперацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	// Вставити вміст обробника.
КонецПроцедуры
