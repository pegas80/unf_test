Процедура ДатьИмяПакетамВыбраннымДокументамКонвертации(Команда)
	
	МассивСчетов = ДатьИмяПакетамВыбраннымДокументамНаСервере("Конвертации");
	
	СтруктураПараметров = Новый Структура;
	
	СтруктураПараметров.Вставить("МассивВыделеныхСтрок", Элементы.Конвертации.ВыделенныеСтроки);
	СтруктураПараметров.Вставить("ИмяТаблицы", "Конвертации");
	СтруктураПараметров.Вставить("МассивСчетов", МассивСчетов);
	
	ФормаПрисвоенияИмениПакета = ПолучитьФорму("Обработка.ИнтеграцияСБанкомTBC.Форма.ФормаПрисвоенияИмениПакета", СтруктураПараметров, ЭтаФорма);
	
	ФормаПрисвоенияИмениПакета.Открыть();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтатусыДокументовНаСервере(СтруктураПараметров, ВсеДокументы = ЛОЖЬ, МассивДокументов = Неопределено)
	
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	
	Объект.Выписка.Очистить();
	
	МенеджерОбработкиTBC = Обработки.ИнтеграцияСБанкомTBC;
	
	ДатаНачала = Дата(1, 1, 1, 0, 0, 0);
	ДатаОкончания = ТекущаяДата();
	Если СтруктураПараметров.Свойство("ДатаНачала") Тогда 
		ДатаНачала = СтруктураПараметров.ДатаНачала;
	КонецЕсли;
	
	Если СтруктураПараметров.Свойство("ДатаОкончания") Тогда 
		ДатаОкончания = ?(СтруктураПараметров.ДатаОкончания = Дата(1, 1, 1, 0, 0, 0), ДатаОкончания, СтруктураПараметров.ДатаОкончания);;
	КонецЕсли;
	
	КоллекцияОбхода = Неопределено;
	Если ВсеДокументы Тогда 
		КоллекцияОбхода = ПолучитьВыборкуУИД(объект.Банк.СВИФТБИК, , ДатаНачала, ДатаОкончания);
	Иначе
		КоллекцияОбхода = ПолучитьВыборкуУИД(объект.Банк.СВИФТБИК, МассивДокументов, ДатаНачала, ДатаОкончания);
	КонецЕсли;
	
	Сотрудник = ПредопределенноеЗначение("Справочник.Сотрудники.ПустаяСсылка");
	Для каждого Строк из КоллекцияОбхода Цикл 
		
		СтруктураПараметров.Вставить("УИД", Строк.УИД);
		СтруктураПараметров.Вставить("ЭтоПакет", Строк.ЭтоПакет);
		ДокументСсылка = Строк.ДокументСсылка;
		Структураответа = МенеджерОбработкиTBC.ОтправитьЗапросXML(СтруктураПараметров);
		
		Банк = ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.РасходСоСчета"), ДокументСсылка.БанковскийСчет.Банк, ДокументСсылка.Отправитель.Банк);
		
		Если Структураответа.Свойство("status") Тогда 
			
			Попытка
				Статусобновления = Перечисления.СтатусыДокументовВИнтернетБанке[СокрЛП(Структураответа.status)];
			Исключение
				Сообщить("Не определен статус: """+СокрЛП(Структураответа.status)+"");
				Продолжить;
			КонецПопытки;
			
			Если Статусобновления <> Строк.СтатусДокументаВИнтернетБанке Тогда 
				ДатаОбновления = ТекущаяДата();
				НаборЗаписейСтатусовДокумента = РегистрыСведений.СтатусыДокументовВИнтернетБанке.СоздатьНаборЗаписей();
				НаборЗаписейСтатусовДокумента.Отбор.ДокументСсылка.Установить(ДокументСсылка);
				НаборЗаписейСтатусовДокумента.Отбор.Сотрудник.Установить(Сотрудник);
				НаборЗаписейСтатусовДокумента.Отбор.Период.Установить(ДатаОбновления);
				НаборЗаписейСтатусовДокумента.Отбор.Банк.Установить(Банк);
				
				НовыйСтатус = НаборЗаписейСтатусовДокумента.Добавить();
				НовыйСтатус.ДокументСсылка = ДокументСсылка;
				НовыйСтатус.Период = ДатаОбновления;
				НовыйСтатус.Сотрудник = Сотрудник;
				НовыйСтатус.СтатусДокументаВИнтернетБанке = Статусобновления;
				НовыйСтатус.Банк = Банк;
				
				НаборЗаписейСтатусовДокумента.Записать();
				
				Сообщить(НСтр( "ru = 'Документу: """+ ДокументСсылка + """, присвоен статус: """ + Статусобновления + """'; en = 'Документу: """+ ДокументСсылка + """, присвоен статус: """ + Статусобновления + """'"));
			Иначе
				Сообщить(НСтр( "ru = 'Для документа: """+ ДокументСсылка + """, не было изменений'; en = 'Для документа: """+ ДокументСсылка + """, не было изменений'"));
			КонецЕсли;
			
		ИначеЕсли Структураответа.Свойство("ТекстОшибки") Тогда 
			
			Сообщить(Структураответа.ТекстОшибки);
			
		КонецЕсли;
		
		Если Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.S")
			ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.P")
			ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка")
			ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.F")
			ИЛИ Статусобновления = ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.FINISHED") Тогда 
			
			Попытка
				Докобъект = ДокументСсылка.ПолучитьОбъект();
				Докобъект.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
			Исключение
				Сообщить("ru = 'Не Удалось провести документ: """+ ДокументСсылка + """'; ka = 'Не Удалось провести документ: """+ ДокументСсылка + """'");
			КонецПопытки;
			
		КонецЕсли;
	КонецЦикла;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСтатусыДокументов(Команда)
	
	ОчиститьСообщения();
	
	Nonce = "";
	Подсказка = НСтр("ka='შეიყვანეთ DigiPass –ის პაროლი';ru='Введите пароль DigiPass!';en='Enter the password of DigiPass!'");
	Если НЕ ВвестиСтроку(Nonce, Подсказка, 0, Истина) Тогда
		// запомнить текст напоминания
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				Логин);
	СтруктураПараметров.Вставить("PASSWORD",  			Пароль);
	СтруктураПараметров.Вставить("Nonce",  				Nonce);
	СтруктураПараметров.Вставить("Метод",   			"GetPaymentOrderStatus");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo");
	СтруктураПараметров.Вставить("ДатаНачала",   		ПериодЗапросаОбновленияСтатуса.ДатаНачала);
	СтруктураПараметров.Вставить("ДатаОкончания",   	ПериодЗапросаОбновленияСтатуса.ДатаОкончания);
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"">");
	
	ОбновитьСтатусыДокументовНаСервере(СтруктураПараметров, Истина);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьВыборкуУИД(Банк, МассивДокументов = Неопределено, ДатаНачала, ДатаОкончания)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.ДокументСсылка,
		|	СтатусыДокументовВИнтернетБанкеСрезПоследних.СтатусДокументаВИнтернетБанке
		|ПОМЕСТИТЬ ТаблицаСрезСтатусов
		|ИЗ
		|	РегистрСведений.СтатусыДокументовВИнтернетБанке.СрезПоследних(
		|			,
		|			Банк.СВИФТБИК = &Банк
		|				И ВЫБОР
		|					КОГДА &МассивДокументов = НЕОПРЕДЕЛЕНО
		|						ТОГДА ИСТИНА
		|					ИНАЧЕ ДокументСсылка В (&МассивДокументов)
		|				КОНЕЦ
		|				И (ДокументСсылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания)) КАК СтатусыДокументовВИнтернетБанкеСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаСрезСтатусов.ДокументСсылка,
		|	ТаблицаСрезСтатусов.СтатусДокументаВИнтернетБанке,
		|	ЕСТЬNULL(УИДДокументовВИнтернетБанке.УИДДокументаВБанке, """") КАК УИД
		|ПОМЕСТИТЬ ТаблицаПред
		|ИЗ
		|	ТаблицаСрезСтатусов КАК ТаблицаСрезСтатусов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УИДДокументовВИнтернетБанке КАК УИДДокументовВИнтернетБанке
		|		ПО ТаблицаСрезСтатусов.ДокументСсылка = УИДДокументовВИнтернетБанке.ДокументСсылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПред.ДокументСсылка,
		|	ТаблицаПред.СтатусДокументаВИнтернетБанке,
		|	ТаблицаПред.УИД,
		|	ВЫБОР
		|		КОГДА ТаблицаПред.ДокументСсылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыоперацийРасходСоСчета.Зарплата)
		|				ИЛИ ТаблицаПред.ДокументСсылка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыоперацийРасходСоСчета.ЗарплатаВРазрезеСотрудников)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЭтоПакет
		|ИЗ
		|	ТаблицаПред КАК ТаблицаПред
		|ГДЕ
		|	ТаблицаПред.СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.S)
		|	И ТаблицаПред.СтатусДокументаВИнтернетБанке <> ЗНАЧЕНИЕ(Перечисление.СтатусыДокументовВИнтернетБанке.ЗагруженИзИнтернетБанка)
		|	И ТаблицаПред.УИД <> """"
		|	И (ТаблицаПред.ДокументСсылка ССЫЛКА Документ.РасходСоСчета
		|			ИЛИ ТаблицаПред.ДокументСсылка ССЫЛКА Документ.Конвертация)";
	
	Запрос.УстановитьПараметр("Банк", Банк);
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

&НаСервере
Функция ЗапроситьСтатусПакета(УИД, ЭтоПакет = Истина, СтарыйСтруктураПараметров);
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("USER",   				СтарыйСтруктураПараметров.USER);
	СтруктураПараметров.Вставить("PASSWORD",  			СтарыйСтруктураПараметров.PASSWORD);
	СтруктураПараметров.Вставить("Nonce",  				СтарыйСтруктураПараметров.Nonce);
	СтруктураПараметров.Вставить("Метод",   			"GetPaymentOrderStatus");
	СтруктураПараметров.Вставить("ПрефиксОтвета",   	"ns2:");
	СтруктураПараметров.Вставить("СуфиксОтвета",   		"ResponseIo");
	СтруктураПараметров.Вставить("ПрефиксЗапроса",  	"myg:");
	СтруктураПараметров.Вставить("СуфиксЗапроса",   	"RequestIo");
	СтруктураПараметров.Вставить("ЭтоПакет",   			ЭтоПакет);
	СтруктураПараметров.Вставить("ПервыйТэгСАтрибутами","<soapenv:Envelope xmlns:soapenv=""http://schemas.xmlsoap.org/soap/envelope/"" xmlns:myg=""http://www.mygemini.com/schemas/mygemini"" xmlns:wsse=""http://docs.oasis-open.org/wss/2004/01/oasis-200401-wss-wssecurity-secext-1.0.xsd"">");
	СтруктураПараметров.Вставить("УИД", 				УИД);
	
	//ОбновитьСтатусыДокументовНаСервере(СтруктураПараметров, Ложь, ДокументСсылка);
	Возврат ЗапроситьСтатусыНаСервере(СтруктураПараметров);
	
КонецФункции

&НаСервере
Функция ЗапроситьСтатусыНаСервере(СтруктураПараметров);
	
	СтруктураПараметров.Вставить("ИспользоватьТестовыйРежим", УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(Пользователи.ТекущийПользователь(),"TBC_ТестовыйРежим"));
	
	ОбработкаМенеджер = Обработки.ИнтеграцияСБанкомTBC;
	
	Возврат ОбработкаМенеджер.ОтправитьЗапросXML(СтруктураПараметров);
	
КонецФункции


&НаКлиенте
Процедура ЗагрузитьДокументыРасходаСоСчета(Команда)
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Проведен", Истина);
	ПараметрыОтбора.Вставить(СокрЛП("КодБанкаСчетаОтправителя"), "TBCBGE22");
	ПараметрыОтбора.Вставить("УникальныйКлючВИнтернетБанке", "");
	
	НовыйМассив = Новый Массив;
	НовыйМассив.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыДокументовВИнтернетБанке.ПустаяСсылка"));
	НовыйМассив.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыПакетныхПеречисленийВИнтернетБанке.ПустаяСсылка"));
	НовыйМассив.Добавить(Неопределено);
	
	ФиксированныйМассив = Новый ФиксированныйМассив(НовыйМассив);
	ПараметрыОтбора.Вставить("СтатусВИнтернетБанке", ФиксированныйМассив);
	
	СтруктураВыбора = Новый Структура("Отбор", ПараметрыОтбора);
	
	ТекСтрока = Элементы.РасходыСоСчета.ТекущиеДанные;
	Если Не ТекСтрока = Неопределено И ЗначениеЗаполнено(ТекСтрока.ДокументСсылка) Тогда 
		СтруктураВыбора.Вставить("ТекущаяСтрока", ТекСтрока.ДокументСсылка);
	КонецЕсли;	

	СтруктураВыбора = Новый Структура("МножественныйВыбор, Отбор", Истина, ПараметрыОтбора);
	
	ФормаППИ = ПолучитьФорму("Документ.РасходСоСчета.ФормаВыбора", СтруктураВыбора, ЭтаФорма);
	
	Если Не ФормаППИ = Неопределено Тогда 
		НоваяГруппа = ФормаППИ.Список.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		НоваяГруппа.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли;
		НоваяГруппа.Использование = Истина;
		
		НоваяГруппа1 = НоваяГруппа.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		НоваяГруппа1.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;
		НоваяГруппа1.Использование = Истина;
		
		НовыйЭлемент2 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент2.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Оплачено"); 
		НовыйЭлемент2.ПравоеЗначение = Ложь;
		НовыйЭлемент2.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлемент2.Использование = Истина;
		
		НовыйЭлемент1 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент1.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОперации"); 
		НовыйЭлемент1.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.Прочее");
		НовыйЭлемент1.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
		НовыйЭлемент1.Использование = Истина;
		
		НовыйЭлемент2 = НоваяГруппа1.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		НовыйЭлемент2.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОперации"); 
		НовыйЭлемент2.ПравоеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходСоСчета.НаРасходы");
		НовыйЭлемент2.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
		НовыйЭлемент2.Использование = Истина;
		
