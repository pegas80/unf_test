
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Объект.ПериодРегистрации = НачалоМесяца(ТекущаяДата());
	ОтображениеПериодаРегистрации = Формат(Объект.ПериодРегистрации, "ДФ='MMMM yyyy'");
КонецПроцедуры

&НаКлиенте
Процедура Заполнить(Команда)
	
	ОчиститьСообщения();
	Ответ = Вопрос("При загрузке изменится данные в документах в текущем периоде. Продолжить?", РежимДиалогаВопрос.ОКОтмена);
	Если НЕ Ответ = КодВозвратаДиалога.ОК Тогда
		Возврат;
	КонецЕсли;
	Объект.ЗаполненныеДокументы.Очистить();
	КолДнейВМесяце = День(КонецМесяца(Объект.ПериодРегистрации));
	ПриЗагрузкеВозниклиОшибки = Ложь;
	ЗаполнитьНаСервере();
	Если ПриЗагрузкеВозниклиОшибки Тогда
		Предупреждение("ტრანზაქცია დასრულდა შეცდომებით!")
	Иначе
	    Предупреждение("ტრანზაქცია წარმატებით დასრულდა!");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	
	СерверИсточник 	= "192.168.0.123";
	Адрес			= "GetScheduleReport?";	
	НТТР = Новый HTTPСоединение(СерверИсточник,,,,,,);
	
	ПериодРегистрации = Объект.ПериодРегистрации;
	Фильтр	= "from=" + Формат(ПериодРегистрации, "ДФ=yyyy.MM.dd") +"&"+"to="+Формат(КонецМесяца(ПериодРегистрации), "ДФ=yyyy.MM.dd");
	Адрес = Адрес + Фильтр;
	
	
	ИмяВременногоФайла = КаталогВременныхФайлов() + "Table.json";
	Попытка
		НТТР.Получить(Адрес, ИмяВременногоФайла);
		ТаблицаТабеля = ПолучитьТабель(ИмяВременногоФайла, ПериодРегистрации);
	Исключение
		ПриЗагрузкеВозниклиОшибки = Истина;
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
	
	СерверИсточник 	= "192.168.0.123";
	Адрес			= "GetStuff?active=true";	
	НТТР = Новый HTTPСоединение(СерверИсточник,,,,,,);
	
	ИмяВременногоФайла = КаталогВременныхФайлов() + "Stuff.json";
	Попытка
		НТТР.Получить(Адрес, ИмяВременногоФайла);
		ЗаполнитьКолонки_InDeviceID_Сотрудник(ТаблицаТабеля, ИмяВременногоФайла);
		ЗаполнитьЧасыВДокументах(ТаблицаТабеля, ПериодРегистрации);
	Исключение
		ПриЗагрузкеВозниклиОшибки = Истина;
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

