&НаСервере
Процедура ЗаполнитьКолонки_InDeviceID_Сотрудник(ТаблицаТабеля, ИмяВременногоФайла)
	
	тЧтениеJSON = Новый ЧтениеJSON;
	тЧтениеJSON.ОткрытьФайл(ИмяВременногоФайла);
	тДанные = ПрочитатьJSON(тЧтениеJSON);
	
	КС_100	= Новый КвалификаторыСтроки(100);
	КЧ_15	= Новый КвалификаторыЧисла(15, 0);

	ТаблицаСотрудники = Новый ТаблицаЗначений;
	ТаблицаСотрудники.Колонки.Добавить("Сотрудник",		Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаСотрудники.Колонки.Добавить("InDeviceID",	Новый ОписаниеТипов("Число", , , КЧ_15));
	ТаблицаСотрудники.Очистить();

	Копия = ТаблицаСотрудники.Скопировать();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	ПОДСТРОКА(Сотрудники.Код, 6, 5) КАК InDeviceID
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СтрокаСотрудник = ТаблицаСотрудники.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаСотрудник, Выборка);
	КонецЦикла;

	
	ТаблицаStaff = Новый ТаблицаЗначений;
	ТаблицаStaff.Колонки.Добавить("Сотрудник",	Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаStaff.Колонки.Добавить("ID",			Новый ОписаниеТипов("Число", , , , КЧ_15));
	ТаблицаStaff.Колонки.Добавить("InDeviceID",	Новый ОписаниеТипов("Строка" , , , КЧ_15));
	ТаблицаStaff.Очистить();
	Для Каждого СтрокаИзТурникета Из тДанные Цикл
		СтрStaff = ТаблицаStaff.Добавить();
		ЗаполнитьЗначенияСвойств(СтрStaff, СтрокаИзТурникета);
		НайденныеСтрокиСотрудника = ТаблицаСотрудники.НайтиСтроки(Новый Структура("InDeviceID", СтрокаИзТурникета.InDeviceID));
		Если НайденныеСтрокиСотрудника.Количество() > 0 Тогда
			ЗаполнитьЗначенияСвойств(СтрStaff, НайденныеСтрокиСотрудника[0]);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого СтрокаТабеля ИЗ ТаблицаТабеля Цикл
		НайденныеСтрокиStaff = ТаблицаStaff.НайтиСтроки(Новый Структура("ID", СтрокаТабеля.StuffId));
		Если НайденныеСтрокиStaff.Количество() > 0 Тогда
			ЗаполнитьЗначенияСвойств(СтрокаТабеля, НайденныеСтрокиStaff[0]);
		КонецЕсли;
	КонецЦикла;
	ТаблицаТабеля.Сортировать("Department");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЧасыВДокументах(ТаблицаТабеля, ПериодРегистрации)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТабельУчетаРабочегоВремени.Ссылка
		|ИЗ
		|	Документ.Табель КАК ТабельУчетаРабочегоВремени
		|ГДЕ
		|	НЕ ТабельУчетаРабочегоВремени.ПометкаУдаления
		|	И ТабельУчетаРабочегоВремени.ПериодРегистрации = &ПериодРегистрации";
	Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
	ВыборкаСсылка = Запрос.Выполнить().Выбрать();
	
	
	Явка 			= Справочники.ВидыРабочегоВремени.Работа;
	Сверхурочные 	= Справочники.ВидыРабочегоВремени.Сверхурочные;
	//ВыходныеДни 	= Справочники.ВидыРабочегоВремени.ВыходныеДни;
	пМесяц			= Месяц(ПериодРегистрации);
	пГод			= Год(ПериодРегистрации);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		
		ПроиденныеСотрудники = Новый Массив;
		ПроиденныеСотрудники.Очистить();
		МассивУдаляемыхСтрок = Новый Массив;
		МассивУдаляемыхСтрок.Очистить();
		
		ДокументТабеля = ВыборкаСсылка.Ссылка.ПолучитьОбъект();
		
		Для Каждого СтрокаТЧ ИЗ ДокументТабеля.ОтработанноеВремяПоДням Цикл
			Если ПроиденныеСотрудники.Найти(СтрокаТЧ.Сотрудник) = Неопределено Тогда
				ПроиденныеСотрудники.Добавить(СтрокаТЧ.Сотрудник);
				НайденныеСтрокиЧасов = ТаблицаТабеля.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
				Если НайденныеСтрокиЧасов.Количество() = 0 Тогда
					Для Инд = 1 По 31 Цикл
						СтрокаТЧ["ПервыйЧасы"+Инд]			= 0;
						СтрокаТЧ["ПервыйВидВремени"+Инд]	= Неопределено;
						СтрокаТЧ["ВторойЧасы"+Инд]			= 0;
						СтрокаТЧ["ВторойВидВремени"+Инд]	= Неопределено;
						СтрокаТЧ["ТретийЧасы"+Инд]			= 0;
						СтрокаТЧ["ТретийВидВремени"+Инд]	= Неопределено;
					КонецЦикла;
				Иначе
					СтрокаТурникета = НайденныеСтрокиЧасов[0];
					Для Инд = 1 По КолДнейВМесяце Цикл
						ЧасыВсего = СтрокаТурникета["ToTalHours"+Инд];
						Если Выходной(пГод, пМесяц, Инд) Тогда
							СтрокаТЧ["ПервыйЧасы"+Инд] 			= ЧасыВсего;
							СтрокаТЧ["ПервыйВидВремени"+Инд]	= ?(ЧасыВсего>0, Сверхурочные, Неопределено);
							//СтрокаТурникета["ToTalHours"+Инд] 	= 0;
						Иначе
							Если ЧасыВсего > 8 Тогда
								СтрокаТЧ["ПервыйЧасы"+Инд] 			= 8;
								СтрокаТЧ["ПервыйВидВремени"+Инд]	= Явка;
								//СтрокаТурникета["ToTalHours"+Инд] = ЧасыВсего - 8;
								СтрокаТЧ["ВторойЧасы"+Инд] 			= ЧасыВсего - 8;
								СтрокаТЧ["ВторойВидВремени"+Инд]	= Сверхурочные;
							Иначе
								СтрокаТЧ["ПервыйЧасы"+Инд] 			= ЧасыВсего;
								СтрокаТЧ["ПервыйВидВремени"+Инд]	= ?(ЧасыВсего>0, Явка, Неопределено);
								//СтрокаТурникета["ToTalHours"+Инд] 	= 0;
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
			//Прервать;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
		КонецЦикла;
		Для Каждого УдаляемаяСтрока ИЗ МассивУдаляемыхСтрок Цикл
			ДокументТабеля.ОтработанноеВремяПоДням.Удалить(УдаляемаяСтрока);
		КонецЦикла;
		
		ДокументТабеля.Записать(РежимЗаписиДокумента.Проведение);
		
		ПерепроведенныйДокумент = Объект.ЗаполненныеДокументы.Добавить();
		ПерепроведенныйДокумент.Табель = ДокументТабеля.Ссылка;
		
		//Прервать;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
	КонецЦикла;
	
	
КонецПроцедуры

Функция Выходной(пГод, пМесяц, пДень)
	
	пДеньНедели = ДеньНедели(Дата(пГод, пМесяц, пДень));
	Если пДеньНедели = 6 Тогда
		Возврат Истина;
	ИначеЕсли пДеньНедели = 7 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПериодРегистрацииНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка	 = Ложь;
	
	ДатаКалендаряПриОткрытии = ?(ЗначениеЗаполнено(Объект.ПериодРегистрации), Объект.ПериодРегистрации, УправлениеНебольшойФирмойПовтИсп.ПолучитьТекущуюДатаСеанса());
	
	ОткрытьФорму("ОбщаяФорма.ФормаКалендаря", УправлениеНебольшойФирмойКлиент.ПолучитьПараметрыОткрытияФормыКалендаря(ДатаКалендаряПриОткрытии), ЭтотОбъект);
	
КонецПроцедуры
&НаКлиенте
Процедура ПериодРегистрацииРегулирование(Элемент, Направление, СтандартнаяОбработка)
	
	УправлениеНебольшойФирмойКлиент.ПриРегулированииПериодаРегистрации(ЭтотОбъект, Направление);
	УправлениеНебольшойФирмойКлиент.ПриИзмененииПериодаРегистрации(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ТипЗнч(ИсточникВыбора) = Тип("УправляемаяФорма")
		И СтрНайти(ИсточникВыбора.ИмяФормы, "ФормаКалендаря") > 0 Тогда
		
		Объект.ПериодРегистрации = КонецДня(ВыбранноеЗначение);
		УправлениеНебольшойФирмойКлиент.ПриИзмененииПериодаРегистрации(ЭтотОбъект);
		
	КонецЕсли;
	
КонецПроцедуры



