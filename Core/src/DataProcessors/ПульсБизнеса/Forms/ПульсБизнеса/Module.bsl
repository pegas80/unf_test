		ОбновитьПредставленияПериодов(ЭтаФорма);
		
		ДобавленныеПоказатели.Очистить();
		ОтобразитьПоказатель("Деньги", "СуммаОстаток");
		ОтобразитьПоказатель("Товары", "СуммаОстаток", НСтр("ka='საქონელი';ru='Товары';en='Products'"));
		ОтобразитьПоказатель("Долги", "ДолгиНам");
		ОтобразитьПоказатель("Долги", "ДолгиНаши");
		ОтобразитьПоказатель("ФинАнализ", "ЧистыеАктивы", НСтр("ka='სულ წმინდა აქტივები';ru='Итого чистые активы';en='Total net assets'"));
		ОтобразитьПоказатель("Продажи", "Выручка", НСтр("ka='გაყიდვები';ru='Продажи';en='the sale'"));
		ОтобразитьПоказатель("Деньги", "Поступления", НСтр("ka='შემოსვლები';ru='Поступления';en='receipts'"));
		ОтобразитьПоказатель("Деньги", "Платежи", НСтр("ka='გადახდები';ru='Платежи';en='payments'"));
		
	КонецЕсли; 
	
	СохранитьНастройки("Показатели");
