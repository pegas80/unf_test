		МассивФильтров = Новый Массив;
		МассивФильтров.Добавить(Структура);
		ОтобразитьДиаграмму(
		"СтруктураДенег", 
		"Аналитика", 
		"СуммаРасход", 
		ПериодДиаграмм,, 
