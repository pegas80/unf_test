	ИначеЕсли ТипДаты="Неделя" Тогда
		СтандартнаяДата.Дата = СтандартнаяДата.Дата+3600*24*7;
	ИначеЕсли ТипДаты="Декада" Тогда
		СтандартнаяДата.Дата = СтандартнаяДата.Дата+3600*24*10;
