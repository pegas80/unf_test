    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПодписатьИсх.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	ВложенныйЗапрос.СуммаДокумента,
	ВложенныйЗапрос.Ответственный,
	ВложенныйЗапрос.Организация,
	ВложенныйЗапрос.Контрагент,
	ЭДПрисоединенныеФайлы.Ссылка,
	ВложенныйЗапрос.ВидЭД,
	ВложенныйЗапрос.ПричинаОтклонения КАК ПричинаОтклонения,
	ВложенныйЗапрос.Дата КАК Дата,
	ВложенныйЗапрос.СостояниеВерсииЭД КАК СостояниеВерсииЭД,
	ВложенныйЗапрос.ДополнительнаяИнформация,
	ВложенныйЗапрос.Описание,
	ВложенныйЗапрос.НаправлениеЭД
ИЗ
	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		ЭДПрисоединенныеФайлы.Ссылка КАК Ссылка,
		ЭлектронныйДокументИсходящий.ВидЭД КАК ВидЭД,
		ЭлектронныйДокументИсходящий.СуммаДокумента КАК СуммаДокумента,
		ЭлектронныйДокументИсходящий.Ответственный КАК Ответственный,
		ЭлектронныйДокументИсходящий.Организация КАК Организация,
		ЭлектронныйДокументИсходящий.Контрагент КАК Контрагент,
		ВЫРАЗИТЬ(ЭлектронныйДокументИсходящий.ПричинаОтклонения КАК СТРОКА(100)) КАК ПричинаОтклонения,
		ЭлектронныйДокументИсходящий.Дата КАК Дата,
		ЭлектронныйДокументИсходящий.СостояниеЭДО КАК СостояниеВерсииЭД,
		ЭДПрисоединенныеФайлы.ДополнительнаяИнформация КАК ДополнительнаяИнформация,
		ВЫРАЗИТЬ(ЭДПрисоединенныеФайлы.Описание КАК СТРОКА(255)) КАК Описание,
		ЭДПрисоединенныеФайлы.НаправлениеЭД КАК НаправлениеЭД
	ИЗ
		Документ.ЭлектронныйДокументИсходящий КАК ЭлектронныйДокументИсходящий
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЭДПрисоединенныеФайлы КАК ЭДПрисоединенныеФайлы
			ПО ЭлектронныйДокументИсходящий.Ссылка = ЭДПрисоединенныеФайлы.ВладелецФайла
				И (ЭлектронныйДокументИсходящий.СостояниеЭДО = ЗНАЧЕНИЕ(Перечисление.СостоянияВерсийЭД.НаПодписи))
				И (ЭДПрисоединенныеФайлы.ТипЭлементаВерсииЭД В (ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ПервичныйЭД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ЭСФ), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.СЧФДОПУПД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.СЧФУПД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ДОПУПД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.КСЧФДИСУКД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.КСЧФУКД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ДИСУКД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ДОП)))
	ГДЕ
		НЕ ЭлектронныйДокументИсходящий.ПрофильНастроекЭДО.СпособОбменаЭД = ЗНАЧЕНИЕ(Перечисление.СпособыОбменаЭД.УдалитьЧерезВебРесурсБанка)
		И НЕ ЭлектронныйДокументИсходящий.ПометкаУдаления
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ РАЗЛИЧНЫЕ
		ЭДПрисоединенныеФайлы.Ссылка,
		ЭДПрисоединенныеФайлы.ТипЭлементаВерсииЭД,
		ЭлектронныйДокументИсходящий.СуммаДокумента,
		ЭлектронныйДокументИсходящий.Ответственный,
		ЭлектронныйДокументИсходящий.Организация,
		ЭлектронныйДокументИсходящий.Контрагент,
		ВЫРАЗИТЬ(ЭлектронныйДокументИсходящий.ПричинаОтклонения КАК СТРОКА(100)),
		ЭлектронныйДокументИсходящий.Дата,
		ЭлектронныйДокументИсходящий.СостояниеЭДО,
		ЭДПрисоединенныеФайлы.ДополнительнаяИнформация,
		ВЫРАЗИТЬ(ЭДПрисоединенныеФайлы.Описание КАК СТРОКА(255)),
		ЭДПрисоединенныеФайлы.НаправлениеЭД
	ИЗ
		Документ.ЭлектронныйДокументИсходящий КАК ЭлектронныйДокументИсходящий
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЭДПрисоединенныеФайлы КАК ЭДПрисоединенныеФайлы
			ПО ЭлектронныйДокументИсходящий.Ссылка = ЭДПрисоединенныеФайлы.ВладелецФайла
				И (НЕ ЭлектронныйДокументИсходящий.СостояниеЭДО = ЗНАЧЕНИЕ(Перечисление.СостоянияВерсийЭД.ЗакрытПринудительно))
				И (ЭДПрисоединенныеФайлы.ТипЭлементаВерсииЭД В (ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИППДОИПУПДУКД), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИППДОИПЭСФ), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИППДОЭСФ), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИППДПЭСФ), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИПУУЭСФ), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИОП), ЗНАЧЕНИЕ(Перечисление.ТипыЭлементовВерсииЭД.ИПЭСФ)))
				И (ЭДПрисоединенныеФайлы.СтатусЭД = ЗНАЧЕНИЕ(Перечисление.СтатусыЭД.Утвержден))
	ГДЕ
		НЕ ЭлектронныйДокументИсходящий.ПрофильНастроекЭДО.СпособОбменаЭД = ЗНАЧЕНИЕ(Перечисление.СпособыОбменаЭД.УдалитьЧерезВебРесурсБанка)
		И НЕ ЭлектронныйДокументИсходящий.ПометкаУдаления) КАК ВложенныйЗапрос
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЭДПрисоединенныеФайлы КАК ЭДПрисоединенныеФайлы
		ПО ВложенныйЗапрос.Ссылка = ЭДПрисоединенныеФайлы.Ссылка</queryText>
      <mainTable>Catalog.ЭДПрисоединенныеФайлы</mainTable>
