    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	СостоянияЭДО.СсылкаНаОбъект КАК Документ,
	ДАТАВРЕМЯ(2012, 1, 1) КАК Дата,
	NULL КАК Организация,
	NULL КАК Контрагент,
	0 КАК СуммаДокумента
ИЗ
	РегистрСведений.СостоянияЭД КАК СостоянияЭДО
ГДЕ
	СостоянияЭДО.СостояниеВерсииЭД = ЗНАЧЕНИЕ(Перечисление.СостоянияВерсийЭД.НеСформирован)</queryText>
