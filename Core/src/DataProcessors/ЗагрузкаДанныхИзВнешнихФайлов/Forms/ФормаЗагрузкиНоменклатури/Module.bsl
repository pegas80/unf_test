
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьПустуюТабДОк();
	
	ИспользоватьПартии = ПолучитьФункциональнуюОпцию("АвтоматическаяМаркировкаИспользованияПартии"); //+++ Дмгг, 06.03.24, ONESOFT-2986
	
	Если Параметры.Свойство("НесущестующиеНоменклатури")  Тогда
		НесущестующиеНоменклатури  = Параметры.НесущестующиеНоменклатури;
		СтроковыйНомер = 2;
		Для каждого стр Из НесущестующиеНоменклатури Цикл
			ТабличныйДокумент.Область("R" + СтроковыйНомер + "C1").Текст = стр;   
			//+++ Дмгг, 06.03.24, ONESOFT-2986
			Если ИспользоватьПартии Тогда 
				ТабличныйДокумент.Область("R" + СтроковыйНомер + "C13").Текст = "y";  
			Иначе
				ТабличныйДокумент.Область("R" + СтроковыйНомер + "C13").Текст = "N";    
			КонецЕсли;                                                               
			//--- Дмгг, 06.03.24, ONESOFT-2986
			СтроковыйНомер = СтроковыйНомер + 1 ;
		КонецЦикла;		 		  	 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНоменклатуру(Команда)
	СоответствиеРодителей = Новый Соответствие;
	СоздатьНоменклатуруНаСервере(СоответствиеРодителей);
КонецПроцедуры

&НаСервере
Процедура СоздатьНоменклатуруНаСервере(СоответствиеРодителей)

	НаборЗаписей = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
	НомераКолонок = ПолучитьСоответсвяКолонок();
	
	
	НомерСтроки = 2;
	СтроковыйНомер = Формат(НомерСтроки, "ЧН=0; ЧГ=0");
	
	ЗаполненоАртикулИНаименование = ЗначениеЗаполнено(ТабличныйДокумент.Область("R" + СтроковыйНомер + НомераКолонок.Получить("КолонкаАртикул")).Текст)
									Или ЗначениеЗаполнено(ТабличныйДокумент.Область("R" + СтроковыйНомер + НомераКолонок.Получить("КолонкаНаименование")).Текст);
	
	КолонкаАртикул	    =  НомераКолонок.Получить("КолонкаАртикул");	
	КолонкаШтрихкод	    =  НомераКолонок.Получить("КолонкаШтрихкод");
	КолонкаНаименование =  НомераКолонок.Получить("КолонкаНаименование");	
	КолонкаНаименованиеПолное	  =  НомераКолонок.Получить("КолонкаНаименованиеПолное");	
	КолонкаРодитель	 			  =  НомераКолонок.Получить("КолонкаРодитель");	
	КолонкаЕдиницаИзмерения		  =  НомераКолонок.Получить("КолонкаЕдиницаИзмерения");	
	
	КолонкаСтранаПроисхождения	  =  НомераКолонок.Получить("КолонкаСтранаПроисхождения");	
	КолонкаHSСode	  =  НомераКолонок.Получить("КолонкаHSСode");	
	КолонкаBrutto	  =  НомераКолонок.Получить("КолонкаBrutto");	
	КолонкаNetto	  =  НомераКолонок.Получить("КолонкаNetto");	
	КолонкаGenerlPrice	  =  НомераКолонок.Получить("КолонкаGenerlPrice");	
	//КолонкаEuroPrice	  =  НомераКолонок.Получить("КолонкаEuroPrice");
	//КолонкаEuroPriceVEF	  =  НомераКолонок.Получить("КолонкаEuroPriceVEF");
	//КолонкаEuroPriceMZM	  =  НомераКолонок.Получить("КолонкаEuroPriceMZM");
	////
	КолонкаНоменклатурнаяГруппа =  НомераКолонок.Получить("КолонкаНоменклатурнаяГруппа");
	КолонкаИспользоватьПартии =  НомераКолонок.Получить("КолонкаИспользоватьПартии");
	КолонкаArticlgroup	      =  НомераКолонок.Получить("КолонкаArticlgroup");
	
	Пока ЗаполненоАртикулИНаименование  Цикл
		
		
		врАртикул = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаАртикул).Текст) ;
		врШтрихкод = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаШтрихкод).Текст);
		Наличия = ПроверкаНаличия(врАртикул, врШтрихкод);
		Если Наличия.НоменклатураНеСуществует И Наличия.ШтрихкодНеСуществует Тогда 
			врНаименование = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаНаименование).Текст) ;
			врНаименованиеПолное = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаНаименованиеПолное).Текст) ;
			врРодитель = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаРодитель).Текст) ;
			врЕдиницаИзмерения = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаЕдиницаИзмерения).Текст) ;
			
			
			врСтранаПроисхождения = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаСтранаПроисхождения).Текст) ;
			врHSСode = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаHSСode).Текст);
			врBrutto = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаBrutto).Текст);
			врNetto  = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаNetto).Текст);
			врGenerlPrice = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаGenerlPrice).Текст);
			//врEuroPrice   = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаEuroPrice).Текст);
			//врEuroPriceVEF   = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаEuroPriceVEF).Текст);
			//врEuroPriceMZM   = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаEuroPriceMZM).Текст);
			//////
			НоменклатурнаяГруппа   = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаНоменклатурнаяГруппа).Текст);
			врИспользоватьПартии     = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаИспользоватьПартии).Текст);
			//врArticlgroup   = СокрЛП(ТабличныйДокумент.Область("R" + СтроковыйНомер + КолонкаArticlgroup).Текст);
			
			
			новаяНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();
			обрПриСозданииНаСервере(новаяНоменклатура);
			
			новаяНоменклатура.Артикул = врАртикул;
			
			новаяНоменклатура.ОсновнойШтрихКод = врШтрихкод;
			
			новаяНоменклатура.Наименование = врНаименование;
			новаяНоменклатура.НаименованиеПолное  = врНаименованиеПолное;
			новаяНоменклатура.ЕдиницаИзмерения    = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию(врЕдиницаИзмерения);
			
			Попытка
				новаяНоменклатура.СтранаПроисхождения = Справочники.СтраныМира.НайтиПоРеквизиту("КодАльфа2",врСтранаПроисхождения);
			Исключение
			КонецПопытки;
			
			Попытка
				новаяНоменклатура.ТоварнаяНоменклатураВЭД = Справочники.КлассификаторТНВЭД.НайтиПоНаименованию(врHSСode);
			Исключение
			КонецПопытки;
			
			Попытка
				новаяНоменклатура.Вес = Число(врBrutto);	
			Исключение
			КонецПопытки;
			
			Попытка
				новаяНоменклатура.ВесНетто = Число(врNetto);	
			Исключение
			КонецПопытки;
			
			Попытка
				новаяНоменклатура.КатегорияНоменклатуры = Справочники.КатегорииНоменклатуры.НайтиПоНаименованию(НоменклатурнаяГруппа);	
			Исключение
			КонецПопытки;
												
			////
			//новаяНоменклатура.Родитель = Справочники.Номенклатура.НайтиПоНаименованию(врРодитель);
			Если ЗначениеЗаполнено(врРодитель) Тогда
				Если СоответствиеРодителей.Получить(врРодитель) = Неопределено Тогда
					Запрос = Новый Запрос;
					Запрос.Текст = 
						"ВЫБРАТЬ ПЕРВЫЕ 1
						|	Номенклатура.Ссылка КАК Родитель
						|ИЗ
						|	Справочник.Номенклатура КАК Номенклатура
						|ГДЕ
						|	Номенклатура.ЭтоГруппа
						|	И Номенклатура.Наименование = &Наименование";
					Запрос.УстановитьПараметр("Наименование", врРодитель);
					Выборка = Запрос.Выполнить().Выбрать();
					Если Выборка.Следующий() Тогда
						новаяНоменклатура.Родитель = Выборка.Родитель;
						СоответствиеРодителей.Вставить(врРодитель, Выборка.Родитель);
					КонецЕсли;
				Иначе
					новаяНоменклатура.Родитель = СоответствиеРодителей.Получить(врРодитель);
				КонецЕсли;
			КонецЕсли;
			////
			//новаяНоменклатура.НоменклатурнаяГруппа    = Справочники.НоменклатурныеГруппы.НайтиПоНаименованию(НоменклатурнаяГруппа);
			новаяНоменклатура.ИспользоватьПартии = ?(врИспользоватьПартии = "y",Истина,Ложь);
			
			Если НЕ ЗначениеЗаполнено(новаяНоменклатура.НаименованиеПолное) Тогда
				новаяНоменклатура.НаименованиеПолное = новаяНоменклатура.Наименование;
			КонецЕсли;
			
			Если НЕ ЗначениеЗаполнено(новаяНоменклатура.ЕдиницаИзмерения) Тогда
				новаяНоменклатура.ЕдиницаИзмерения = Справочники.КлассификаторЕдиницИзмерения.шт;
			КонецЕсли;  
			
			//Попитка записи доп реквизитов 
			Попытка
				
				допРеквВесБрутто = ПланыВидовХарактеристик.Параметры.ДопРеквизит_ВесБрутто.Значение;
				допРеквВесНетто  = ПланыВидовХарактеристик.Параметры.ДопРеквизит_ВесНетто.Значение;
				допРеквHS_Code   = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("HS Code");
				допРеквArticlgroup   = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Article group");
				допРеквСтранаПроисхождения  = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("წარმოშობის ქვეყანა");
				
				стрВесБрутто = новаяНоменклатура.ДополнительныеРеквизиты.Добавить();
				стрВесБрутто.Свойство = допРеквВесБрутто;
				стрВесБрутто.Значение = врBrutto;
				
				стрВесНетто  = новаяНоменклатура.ДополнительныеРеквизиты.Добавить();
				стрВесНетто.Свойство = допРеквВесНетто;
				стрВесНетто.Значение = врNetto;
				
				стрHS_Code   = новаяНоменклатура.ДополнительныеРеквизиты.Добавить();
				стрHS_Code.Свойство = допРеквHS_Code;
				стрHS_Code.Значение = врHSСode;
				
				стрСтранаПроисхождения   = новаяНоменклатура.ДополнительныеРеквизиты.Добавить();
				стрСтранаПроисхождения.Свойство = допРеквСтранаПроисхождения;
				стрСтранаПроисхождения.Значение = ПолучитЗначениеЗначенийСвойств(допРеквСтранаПроисхождения, врСтранаПроисхождения);
				
				
				//стрArticlgroup   = новаяНоменклатура.ДополнительныеРеквизиты.Добавить();
				//стрArticlgroup.Свойство = допРеквArticlgroup;
				//стрArticlgroup.Значение = ПолучитЗначениеЗначенийСвойств(допРеквArticlgroup, врArticlgroup);//врArticlgroup;
				//
			Исключение
				
			КонецПопытки;
			
						
			Попытка
				новаяНоменклатура.Записать();
				Сообщить("შეიქმნა ნომენკლატურა არტიკულით " + врАртикул );
				
				//შტრიხკოდის შექმნა_
				Если ЗначениеЗаполнено(врШтрихкод) Тогда
					НаборЗаписей.Отбор.Штрихкод.Установить(врШтрихкод);
					НаборЗаписей.Очистить();
					НоваяЗапись = НаборЗаписей.Добавить();
					НоваяЗапись.Штрихкод			= врШтрихкод;
					НоваяЗапись.Номенклатура		= новаяНоменклатура.Ссылка;
					НоваяЗапись.ЕдиницаИзмерения	= новаяНоменклатура.Ссылка.ЕдиницаИзмерения;
					НаборЗаписей.Записать();
				КонецЕсли;
				//_შტრიხკოდის შექმნა
				
				//ЗаполнитьЦени
				Попытка
					УстановкаЦен(новаяНоменклатура,врGenerlPrice);
				Исключение
					
				КонецПопытки;

			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		Иначе 
			//Сообщить(НСтр("ru = 'Номенклатура существует '; ka = 'ნომენლატურა მითითებული არტიკულით არსებობს '" + врАртикул ));
			
		КонецЕсли;
		
		НомерСтроки = НомерСтроки + 1;
		СтроковыйНомер = Формат(НомерСтроки, "ЧН=0; ЧГ=0");		
		
		ЗаполненоАртикулИНаименование = ЗначениеЗаполнено(ТабличныйДокумент.Область("R" + СтроковыйНомер + НомераКолонок.Получить("КолонкаАртикул")).Текст)
		Или ЗначениеЗаполнено(ТабличныйДокумент.Область("R" + СтроковыйНомер + НомераКолонок.Получить("КолонкаНаименование")).Текст);

	КонецЦикла;								
	
	
КонецПроцедуры

&НаКлиенте
Процедура ФайлПриИзменении(Элемент)
	

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИзФайла(Команда)

	ОчиститьСообщения();
	Если НЕ ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	НомераКолонок = ПолучитьСоответсвяКолонок();
	
	ФайлЭкселПолноеИмя = Файл;
	
	Попытка
		ExcelApp 	= New COMОбъект("excel.application");
		workbook 	= ExcelApp.Workbooks.open(ФайлЭкселПолноеИмя);
	Исключение 
		Сообщить("Внимание! Файл для загрузки "+ФайлЭкселПолноеИмя+" не открыт!");
	КонецПопытки;
	
	worksheet		= workbook.worksheets(1);
	
	//Сч = 2;
	//////
	ПерваяСтрока_Excel		= 2;
	ПоследняяСтрока_Excel	= worksheet.Cells.SpecialCells(11).Row;
	/////
	СтроковыйНомер = 2;
	КолонкаАртикул = 1;
	ЗаполнитьПустуюТабДОк();
	//Пока ЗначениеЗаполнено(worksheet.Cells(Сч,КолонкаАртикул).Text) Цикл
	Для Сч = ПерваяСтрока_Excel По ПоследняяСтрока_Excel Цикл
		врАртикул = СокрЛП(worksheet.Cells(Сч,КолонкаАртикул).Text);
		врШтрихкод = СокрЛП(worksheet.Cells(Сч,2).Text);
		Наличия = ПроверкаНаличия(врАртикул, врШтрихкод);
		Если Наличия.НоменклатураНеСуществует И Наличия.ШтрихкодНеСуществует Тогда
			ткстСтроковыйНомер =  Формат(СтроковыйНомер, "ЧН=0; ЧГ=0");
			Для кол = 1 По 16 Цикл 
				текКол = Формат(кол, "ЧН=0; ЧГ=0");
				ТабличныйДокумент.Область("R" + ткстСтроковыйНомер +"C" +  текКол).Текст = worksheet.Cells(Сч,кол).Text;
			КонецЦикла;
			СтроковыйНомер = СтроковыйНомер + 1;
		Иначе
			Если НЕ Наличия.НоменклатураНеСуществует Тогда
				Сообщить(НСтр("ru = 'Номенклатура существует '; ka = 'ნომენლატურა მითითებული არტიკულით არსებობს '") + врАртикул);
			КонецЕсли;
			Если НЕ Наличия.ШтрихкодНеСуществует Тогда
				Сообщить(НСтр("ru = 'Штрихкод существует '; ka = 'შტრიხკოდი არსებობს '") + врШтрихкод);
			КонецЕсли;
		КонецЕсли;
		
		//Сч = Сч + 1;    
		
	КонецЦикла;
	ExcelApp.Quit();
	
КонецПроцедуры


