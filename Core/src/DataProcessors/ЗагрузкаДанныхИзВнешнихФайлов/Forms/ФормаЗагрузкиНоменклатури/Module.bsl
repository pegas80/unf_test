Функция ПроверкаНаличия(врАртикул, врШтрихкод)
		
	//Возврат Справочники.Номенклатура.НайтиПоРеквизиту("Артикул",врАртикул) = Справочники.Номенклатура.ПустаяСсылка();
	ШтрихкодНеСуществует = Истина;	
	Если ЗначениеЗаполнено(врШтрихкод) Тогда
		НаборЗаписей = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Штрихкод.Установить(врШтрихкод);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() > 0 Тогда
			ШтрихкодНеСуществует = Ложь;
		КонецЕсли;
	КонецЕсли;

	НоменклатураНеСуществует = Истина;
	Если ЗначениеЗаполнено(врАртикул) Тогда
		НоменклатураНеСуществует = Справочники.Номенклатура.НайтиПоРеквизиту("Артикул",врАртикул) = Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("НоменклатураНеСуществует",	НоменклатураНеСуществует);
	СтруктураВозврата.Вставить("ШтрихкодНеСуществует",		ШтрихкодНеСуществует);	
	
	Возврат СтруктураВозврата;
	
КонецФункции
	
