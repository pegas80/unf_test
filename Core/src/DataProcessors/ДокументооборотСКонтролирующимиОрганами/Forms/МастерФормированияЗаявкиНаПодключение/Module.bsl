		ПаспортРФ = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент(
			"Справочник.ВидыДокументовФизическихЛиц.ПаспортРФ");
			
		Если ВладелецЭЦПВидДокумента = ПаспортРФ Тогда
			КодПодразделенияБезТире = СтрЗаменить(ВладелецЭЦПКодПодразделения, "-","");
			Если ПустаяСтрока(КодПодразделенияБезТире) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Код подразделения""';ru='Заполните поле ""Код подразделения""';en='Fill in the ""Unit Code""'"), ,"ВладелецЭЦПКодПодразделения");
				МастерДалее = Ложь;
			ИначеЕсли СтрДлина(ВладелецЭЦПКодПодразделения) <> 7
				ИЛИ НЕ КонтекстЭДОКлиент.ПроверитьЦифровойКодЗаданнойДлины(КодПодразделенияБезТире, 6, Истина) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Некорректно указан код подразделения. Не соответствует маске ХХХ-ХХХ, где X – любая цифра';ru='Некорректно указан код подразделения. Не соответствует маске ХХХ-ХХХ, где X – любая цифра';en='Incorrectly specified department code. Do not conform to the mask XXX-XXX, where X - any number'"), ,"ВладелецЭЦПКодПодразделения");
				МастерДалее = Ложь;
			КонецЕсли;
		КонецЕсли;
		
		// Место рождения
		Если ПустаяСтрока(ВладелецЭЦПМестоРождения) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Место рождения""';ru='Заполните поле ""Место рождения""';en='Fill in the ""Place of Birth""'"), ,"ВладелецЭЦПМестоРождения");
			МастерДалее = Ложь;
		КонецЕсли;
		
		Если МастерДалее Тогда
			Если СдаватьВПФР Тогда
				ВывестиНадписьПоДокументамДляПодключенияКПФР();
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ТекущаяСтраница = Элементы.Направления Тогда
		
		// коды ФНС
		Если СдаватьВФНС И ПолучателиФНС.Количество()=0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните коды ФНС';ru='Заполните коды ФНС';en='Fill FTS codes'"), ,"ПолучателиФНС");
			МастерДалее = Ложь;
		ИначеЕсли СдаватьВФНС Тогда
			Для каждого Получатель Из ПолучателиФНС Цикл
				Если КонтекстЭДОКлиент.НайденыЗапрещенныеСимволы(Получатель.КПП, НСтр("ka='КПП';ru='КПП';en='PPC'"), "ПолучателиФНС") Тогда
					МастерДалее = Ложь;
					Прервать;
				КонецЕсли;
				Если КонтекстЭДОКлиент.НайденыЗапрещенныеСимволы(Получатель.КодПолучателя, НСтр("ka='კოდიФНС';ru='Код ФНС';en='FNS code'"), "ПолучателиФНС") Тогда
					МастерДалее = Ложь;
					Прервать;
				КонецЕсли;
			КонецЦикла; 
		КонецЕсли;
		
		// код отделения ПФР
		Если СдаватьВПФР Тогда
			Если ПустаяСтрока(СтрЗаменить(КодПФР,"-","")) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Код отделения ПФР""';ru='Заполните поле ""Код отделения ПФР""';en='Fill in the ""Code of FIU department""'"), ,"КодПФР");
				МастерДалее = Ложь;
			ИначеЕсли СтрДлина(СокрЛП(КодПФР))<> 7 Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Код отделения ПФР должен состоять из 6 цифр';ru='Код отделения ПФР должен состоять из 6 цифр';en='FIU branch code must contain 6 digits'"), ,"КодПФР");
				МастерДалее = Ложь;
			ИначеЕсли КонтекстЭДОКлиент.НайденыЗапрещенныеСимволы(КодПФР, НСтр("ka='Код отделения ПФР';ru='Код отделения ПФР';en='Code of FIU department'"), "КодПФР") Тогда
				МастерДалее = Ложь;
			КонецЕсли;
		КонецЕсли;
		
		// код органа Росстата
		Если СдаватьВРосстат Тогда
			
			Если ПолучателиФСГС.Количество() = 0 Тогда
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните коды органа Росстата';ru='Заполните коды органа Росстата';en='Fill in the body of the Federal State Statistics Service Codes'"), ,"ПолучателиФСГС");
				МастерДалее = Ложь;
				
			ИначеЕсли ПолучателиФСГС.Количество() > 0 Тогда
				
				Для каждого Получатель Из ПолучателиФСГС Цикл
					
					Если ПустаяСтрока(СтрЗаменить(Получатель.КодПолучателя,"-","")) Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Код органа Росстата""';ru='Заполните поле ""Код органа Росстата""';en='Fill in the ""body of Federal State Statistics Service Code""'"), ,"ПолучателиФСГС");
						МастерДалее = Ложь;
					ИначеЕсли СтрДлина(СокрЛП(Получатель.КодПолучателя))<> 5 Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Код органа Росстата должен состоять из 4 цифр';ru='Код органа Росстата должен состоять из 4 цифр';en='Code body Rosstat must be 4 digits'"), ,"ПолучателиФСГС");
						МастерДалее = Ложь;
					ИначеЕсли КонтекстЭДОКлиент.НайденыЗапрещенныеСимволы(Получатель.КодПолучателя, НСтр("ka='Код органа Росстата';ru='Код органа Росстата';en='Code of Federal State Statistics Service Authority'"), "ПолучателиФСГС") Тогда
						МастерДалее = Ложь;
					КонецЕсли;
				
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если МастерДалее Тогда
			ЗаполнитьПараметрыЭДО();
			Если НЕ ОтображатьПодключениеЭДО Тогда
				СформироватьТаблицуДляПодтвержденияДанных();
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ТекущаяСтраница = Элементы.ПодключениеЭДО Тогда 
		
		// подключение ЭДО
		Если ПодключитьЭДО Тогда
			
			// оператор ЭДО
			Если НЕ ЗначениеЗаполнено(ОператорЭДО) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Оператор ЭДО""';ru='Заполните поле ""Оператор ЭДО""';en='Fill in the ""Operator EDI""'"), ,"ОператорЭДО");
				МастерДалее = Ложь;
			КонецЕсли;
			
			// код ФНС
			Если ПустаяСтрока(КодНалоговогоОрганаЭДО) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Код ФНС""';ru='Заполните поле ""Код ФНС""';en='Fill in the ""Code of Federal Tax Service""'"), ,"КодНалоговогоОрганаЭДО");
				МастерДалее = Ложь;
			ИначеЕсли СтрДлина(СокрЛП(КодНалоговогоОрганаЭДО))<> 4 Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Код ФНС должен состоять из 4 цифр';ru='Код ФНС должен состоять из 4 цифр';en='FNS code must be 4 digits'"), ,"КодНалоговогоОрганаЭДО");
				МастерДалее = Ложь;
			КонецЕсли;
		
		КонецЕсли;
		
		Если МастерДалее Тогда
			СформироватьТаблицуДляПодтвержденияДанных();
		КонецЕсли;

	ИначеЕсли ТекущаяСтраница = Элементы.Подтверждение Тогда 
		
		Если ЭтоРежимОграниченнойФункциональности И Не ФайлЗаявленияДобавлен(ЭтаФорма) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				СтрШаблон(НСтр("ka='Добавьте файлы для документа ""%1""';ru='Добавьте файлы для документа ""%1""';en='Add files to document ""%1""'"), ВидыДокументов().Заявление),,
				"СсылкаЗаявление");
					
			МастерДалее = Ложь;
			Возврат;
		КонецЕсли;
		
		// создание документа заявления
		СоздатьНовыйДокументЗаявление(2);
		
		ОповеститьОбИзменении(ДокументЗаявление.Ссылка);
				
		Если РежимРаботыСКлючами = 1 Тогда // Облачная ЭП
			СформироватьИОтправитьЗаявление();
			Возврат;
		КонецЕсли;
						
	ИначеЕсли ТекущаяСтраница = Элементы.ИнструкцияПоСозданиюКлючаЭЦП Тогда 
		
		// создание заявления и его отправка
		СформироватьИОтправитьЗаявление();
		Возврат;
		
	ИначеЕсли ТекущаяСтраница = Элементы.ПолучениеРезультатаОтправкиЗаявления Тогда
		
		Если ДокументЗаявление.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявленияАбонентаСпецоператораСвязи.Отклонено") Тогда
			
			ПараметрыФормы = Новый Структура("ЗначениеКопирования",ДокументЗаявление.Ссылка);
			ОткрытьФорму("Документ.ЗаявлениеАбонентаСпецоператораСвязи.ФормаОбъекта",ПараметрыФормы,,Истина);
			
			ПрограммноеЗакрытие = Истина;
			Закрыть();
		ИначеЕсли ДокументЗаявление.Статус =  ПредопределенноеЗначение("Перечисление.СтатусыЗаявленияАбонентаСпецоператораСвязи.Подготовлено") Тогда
			СформироватьИОтправитьЗаявление();
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если МастерДалее Тогда
		ПоказатьСледующуюСтраницу();
	КонецЕсли;
	
КонецПроцедуры

