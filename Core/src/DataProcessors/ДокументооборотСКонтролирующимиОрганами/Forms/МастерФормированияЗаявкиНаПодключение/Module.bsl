			КонецЕсли;
			
			// ОГРН
			Если ПустаяСтрока(ОГРН) Тогда 
			    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните ОГРН';ru='Заполните ОГРН';en='fill BIN'"), ,"ОГРН");
				МастерДалее = Ложь;
			ИначеЕсли НЕ (КонтекстЭДОКлиент.ПроверитьЦифровойКодЗаданнойДлины(ОГРН,13)) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='ОГРН должен состоять из 13 цифр';ru='ОГРН должен состоять из 13 цифр';en='BIN must consist of 13 digits'"), ,"ОГРН");
				МастерДалее = Ложь;
			КонецЕсли;
			
		Иначе
			
			// ИНН
			Если ПустаяСтрока(ИНН) Тогда 
			    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните ИНН';ru='Заполните ИНН';en='fill INN'"), ,"ДекорацияИНН");
				МастерДалее = Ложь;
			ИначеЕсли НЕ КонтекстЭДОКлиент.ПроверитьЦифровойКодЗаданнойДлины(ИНН,12) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='ИНН должен состоять из 12 цифр';ru='ИНН должен состоять из 12 цифр';en='VAT number must consist of 12 digits'"), ,"ДекорацияИНН");
				МастерДалее = Ложь;
			КонецЕсли;
			
			// ОГРН
			Если ПустаяСтрока(ОГРН) Тогда 
			    ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните ОГРНИП';ru='Заполните ОГРНИП';en='fill OGRN'"), ,"ОГРН");
				МастерДалее = Ложь;
			ИначеЕсли ЗначениеЗаполнено(ОГРН) И НЕ КонтекстЭДОКлиент.ПроверитьЦифровойКодЗаданнойДлины(ОГРН,15, Истина) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='ОГРНИП должен состоять из 15 цифр';ru='ОГРНИП должен состоять из 15 цифр';en='OGRN must consist of 15 digits'"), ,"ОГРН");
				МастерДалее = Ложь;
			КонецЕсли;
			
		КонецЕсли;
		
		// регистрационный номер в ПФР
		Если СдаватьВПФР Тогда		
			Если ПустаяСтрока(СтрЗаменить(РегНомерПФР,"-","")) Тогда 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните регистрационный номер в ПФР';ru='Заполните регистрационный номер в ПФР';en='Fill out the registration number of the FIU'"), ,"ДекорацияРегНомерПФР");
				МастерДалее = Ложь;
			ИначеЕсли НЕ КонтекстЭДОКлиент.ПроверитьРегистрационныйНомерПФР(РегНомерПФР, Истина) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Регистрационный номер в ПФР должен состоять из 12 цифр (ХХХ-ХХХ-ХХХХХХ)';ru='Регистрационный номер в ПФР должен состоять из 12 цифр (ХХХ-ХХХ-ХХХХХХ)';en='Registration number of the FIU shall be composed of 12 digits (XXXXXX-XXXXXX)'"), ,"ДекорацияРегНомерПФР");
				МастерДалее = Ложь;
			КонецЕсли;
		КонецЕсли;
				
		Если СдаватьВФСС Тогда
			// регистрационный номер в ФСС
			Если ПустаяСтрока(РегНомерФСС) Тогда 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните регистрационный номер в ФСС';ru='Заполните регистрационный номер в ФСС';en='Fill in the registration number in the FSS'"), ,"ДекорацияРегНомерФСС");
				МастерДалее = Ложь;
			ИначеЕсли НЕ КонтекстЭДОКлиент.ПроверитьЦифровойКодЗаданнойДлины(РегНомерФСС, 10, Истина) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Регистрационный номер в ФСС должен состоять из 10 цифр';ru='Регистрационный номер в ФСС должен состоять из 10 цифр';en='Registration number in the FSS should be 10 digits'"), ,"ДекорацияРегНомерФСС");
				МастерДалее = Ложь;
			КонецЕсли;
		
			// дополнительный код ФСС
			Если ПризнакОбособленногоПодразделения И ЭтоЮридическоеЛицо И СдаватьВФСС Тогда
				Если ПустаяСтрока(ДополнительныйКодФСС) Тогда 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните дополнительный код ФСС';ru='Заполните дополнительный код ФСС';en='Fill in the additional code FSS'"), ,"ДополнительныйКодФСС");
					МастерДалее = Ложь;
				ИначеЕсли НЕ КонтекстЭДОКлиент.ПроверитьЦифровойКодЗаданнойДлины(ДополнительныйКодФСС, 10, Истина) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Дополнительный код ФСС должен состоять из 10 цифр';ru='Дополнительный код ФСС должен состоять из 10 цифр';en='Additional FSS Code should be 10 digits'"), ,"ДополнительныйКодФСС");
					МастерДалее = Ложь;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// юридический адрес
		Если ПустаяСтрока(СтрЗаменить(АдрЮР,",","")) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Юридический адрес""';ru='Заполните поле ""Юридический адрес""';en='Fill in the ""Legal address""'"), ,"АдресЮридический");
			МастерДалее = Ложь;
		Иначе	
			СтрокаОшибкаАдреса = КонтекстЭДОКлиент.ПроверитьАдрес(АдрЮР);
			Если НЕ ПустаяСтрока(СтрокаОшибкаАдреса) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka='Юридический адрес: %1';ru='Юридический адрес: %1';en='Legal address:% 1'"),СтрокаОшибкаАдреса), ,"АдресЮридический");
				МастерДалее = Ложь;
			ИначеЕсли КонтекстЭДОКлиент.НайденыЗапрещенныеСимволы(АдрЮР, НСтр("ka='იურიდიული მისამართი';ru='Юридический адрес';en='Legal address'"), "АдресЮридический") Тогда
				МастерДалее = Ложь;
			Иначе
				
				СтруктураАдреса 		= РегламентированнаяОтчетностьКлиентСервер.РазложитьАдрес(АдрЮР);
				КвартираВВидеДляXML 	= СтруктураАдреса.Квартира;
				
				Если СтрДлина(КвартираВВидеДляXML) > 8 Тогда
					ТекстОшибки = НСтр("ru='Часть юридического адреса ""%1"" превышает допустимые 8 символов."
"Сократите длину адреса, убрав некоторые его части (например, оставив только дом и корпус)';ka='Часть юридического адреса ""%1"" превышает допустимые 8 символов."
"Сократите длину адреса, убрав некоторые его части (например, оставив только дом и корпус)'");
					ТекстОшибки = СтрШаблон(ТекстОшибки, КвартираВВидеДляXML);
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки, ,"АдресЮридический");
					МастерДалее = Ложь;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		// фактический адрес
		Если ПустаяСтрока(СтрЗаменить(АдрФакт,",","")) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='Заполните поле ""Фактический адрес""';ru='Заполните поле ""Фактический адрес""';en='Fill in the ""Actual address""'"), ,"АдресФактический");
			МастерДалее = Ложь;
		Иначе
			СтрокаОшибкаАдреса = КонтекстЭДОКлиент.ПроверитьАдрес(АдрФакт);
			Если НЕ ПустаяСтрока(СтрокаОшибкаАдреса) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ka='Фактический адрес: %1';ru='Фактический адрес: %1';en='Current address:% 1'"),СтрокаОшибкаАдреса), ,"АдресФактический");
				МастерДалее = Ложь;
			ИначеЕсли КонтекстЭДОКлиент.НайденыЗапрещенныеСимволы(АдрФакт, НСтр("ka='ფაქტობრივი მისამართი';ru='Фактический адрес';en='Actual address'"), "АдресФактический") Тогда
				МастерДалее = Ложь;
			Иначе
				
