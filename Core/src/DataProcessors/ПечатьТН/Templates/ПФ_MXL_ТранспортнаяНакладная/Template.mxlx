						</v8:item>
						<v8:item>
							<v8:lang>en</v8:lang>
							<v8:content>(Shipping name of the goods (for dangerous goods - in accordance with ADR), its state and other necessary information on the cargo)</v8:content>
						</v8:item>
					</tl>
				</c>
