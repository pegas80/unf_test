КонецПроцедуры


&НаКлиенте
Процедура МеилПриИзменении(Элемент)
	пЮрЛицо = (ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ВидыКонтрагентов.ЮридическоеЛицо"));
	Элементы.Меил.ОтметкаНезаполненного		= пЮрЛицо И НЕ ЗначениеЗаполнено(Меил);
	Элементы.Меил.АвтоОтметкаНезаполненного = пЮрЛицо И НЕ ЗначениеЗаполнено(Меил);
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьИнфоИзRS(Команда)
	
	Если Не ЗначениеЗаполнено(ИНН) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ka='ს.კ / პ.ნ არ არის შევსებული';ru='ИНН не заполнено.';en='VAT is not filled.'"));
		Возврат;
	КонецЕсли;
	
	ПолучитьИнфоИзRSСервер()
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьИнфоИзRSСервер()
	
	ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервере(ИНН);
	
	Если ДанныеКонтрагента = Неопределено Или ДанныеКонтрагента.Статус = ""  Тогда
		Сообщить(НСтр("ka='კონტრაგენტი მიმდინარე გსნ-თ ვერ მოიძებნა RS-ზე';ru='Контрагент с данным ИНН не найден на RS.';en='Counterparty with the INN is not found in the RS.'"));
		Возврат;
	КонецЕсли;	
	
	НаименованиеПолное = ДанныеКонтрагента.Имя;
	
	Контрагент = НаименованиеПолное;
	
	Если ДанныеКонтрагента.ТипОрганизаций = "ფიზიკური პირი" Тогда
		ЮрФизЛицо = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
		КонтактноеЛицо = Контрагент; 
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "შ\პ\ს" ИЛИ "სააქციო საზოგადოება" ИЛИ "საჯარო სამართლის იურიდიული პირი" Тогда	
		ЮрФизЛицо = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "სახელმწიფო ორგანოები" Тогда	
		ЮрФизЛицо = Перечисления.ВидыКонтрагентов.ГосударственныйОрган;
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
	ИначеЕсли ДанныеКонтрагента.ТипОрганизаций = "ინდივიდუალური მეწარმე" Тогда	
		ЮрФизЛицо = Перечисления.ВидыКонтрагентов.ИндивидуальныйПредприниматель;
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
	Иначе
		ЮрФизЛицо = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС;
	КонецЕсли;	
			
	// Юридический адрес	
	ЮридическийАдрес = ДанныеКонтрагента.Адрес;
	ФактическийАдрес = ДанныеКонтрагента.Адрес;
	
	ДанныеКонтрагента = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьИнфоИзRSНаСервереНов(ИНН);
	
	Если ДанныеКонтрагента = Неопределено Или ДанныеКонтрагента.UnID = 0  Тогда
		Возврат;
	КонецЕсли;	
	
	Если ДанныеКонтрагента.IsVatPayer Тогда
		ОблагаетсяНДС = Истина; 		
	Иначе 
		ОблагаетсяНДС = Ложь;
	КонецЕсли;
	
КонецПроцедуры	
	



