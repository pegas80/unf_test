Процедура кТестУстройства(Команда)
	
	пОшибка = Ложь;
	Попытка
		Драйвер = Новый COMОбъект("DigiSM.TDigiSM");
		Драйвер.IPAddress = ОбменСВесамиСПечатьюЭтикетокСервер.ПолучитьIPАдресВесов();
	Исключение
		Сообщить(ОписаниеОшибки());		
		тОписаниеОшибки = "Невозможно подключить OLE драйвер.
		| Проверьте, что OLE драйвер корректно установлен.";
		Сообщить(тОписаниеОшибки);
		пОшибка = Истина;
	КонецПопытки;
	
	Если НЕ пОшибка Тогда
		//подключить
		Попытка		
			//Драйвер.Connect = Истина;
			ОчиститьТоварыВВесах(Драйвер);
		Исключение
			Сообщить(ОписаниеОшибки());
			пОшибка = Истина;
		КонецПопытки;
		
		Если НЕ Драйвер.Connect Тогда
			Сообщить("Не удалось установить соединение с весами.");
		Иначе
			//отключить
			Попытка
				Драйвер.Connect = Ложь;
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;	
	Сообщить("Тест пройден...");
	Драйвер = "";
	
