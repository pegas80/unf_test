	               |	ВЫРАЗИТЬ(ШтрихкодыНоменклатуры.Номенклатура.НаименованиеПолное КАК СТРОКА(256)) КАК Наименование,
	               |	ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 1, 7) КАК ШтрихКод,
	               |	ШтрихкодыНоменклатуры.PLU КАК PLU,
	               |	ШтрихкодыНоменклатуры.Номенклатура.СрокГодности КАК СрокГодности,
	               |	ШтрихкодыНоменклатуры.Штрихкод КАК ШтрихкодПолный,
	               |	МАКСИМУМ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0)) КАК Цена,
	               |	ВЫБОР
	               |		КОГДА ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 2, 1) = ""2""
	               |			ТОГДА 0
	               |		ИНАЧЕ 1
	               |	КОНЕЦ КАК Весовой
	               |ИЗ
	               |	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&НаДату, ) КАК ЦеныНоменклатурыСрезПоследних
	               |		ПО (ЦеныНоменклатурыСрезПоследних.ВидЦен В (&СпВидЦен))
	               |			И ШтрихкодыНоменклатуры.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	               |ГДЕ
	               |	ШтрихкодыНоменклатуры.Номенклатура.ВыгружатьВВесы = ИСТИНА
	               |	И ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 1, 1) = ""2""
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВЫРАЗИТЬ(ШтрихкодыНоменклатуры.Номенклатура.НаименованиеПолное КАК СТРОКА(256)),
	               |	ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 1, 7),
	               |	ШтрихкодыНоменклатуры.PLU,
	               |	ШтрихкодыНоменклатуры.Номенклатура.СрокГодности,
	               |	ШтрихкодыНоменклатуры.Штрихкод,
	               |	ВЫБОР
	               |		КОГДА ПОДСТРОКА(ШтрихкодыНоменклатуры.Штрихкод, 2, 1) = ""2""
	               |			ТОГДА 0
	               |		ИНАЧЕ 1
	               |	КОНЕЦ
	               |
	               |ИМЕЮЩИЕ
	               |	НЕ МАКСИМУМ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0)) = 0";
	МасВидовЦен = Новый Массив;
	МасВидовЦен.Добавить(Справочники.ВидыЦен.НайтиПоНаименованию("საცალო ფასი",Истина));
	МасВидовЦен.Добавить(Справочники.ВидыЦен.НайтиПоНаименованию("ფასი - საცალო",Истина));
	Запрос.УстановитьПараметр("СпВидЦен",МасВидовЦен);
	Запрос.УстановитьПараметр("НаДату",	 ТекущаяДата());
	
	Объект.ТабНоменклатуры.Очистить();
	ВыборкаЗапроса = Запрос.Выполнить().Выбрать();
	Пока ВыборкаЗапроса.Следующий() Цикл
		НовСтр = Объект.ТабНоменклатуры.Добавить();
		
		Если ВыборкаЗапроса.PLU = 0 Тогда
			//сгенерируем новый PLU
			НовСтр.PLU = СгенерироватьНовыйPLU(ВыборкаЗапроса.ШтрихкодПолный);					
		КонецЕсли;
				
		ЗаполнитьЗначенияСвойств(НовСтр,ВыборкаЗапроса);
	КонецЦикла;	
		
КонецПроцедуры

&НаСервере
Функция СгенерироватьНовыйPLU(ТекШК)
	
	ЗапросМаксПЛУ = Новый Запрос;
	ЗапросМаксПЛУ.Текст = "ВЫБРАТЬ
	                      |	МАКСИМУМ(ШтрихкодыНоменклатуры.PLU) КАК PLU
	                      |ИЗ
	                      |	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры";
	РезЗапроса = ЗапросМаксПЛУ.Выполнить();
	Если РезЗапроса.Пустой() Тогда
		ТекPLU = 1;
	Иначе
		ВыборкаЗап = РезЗапроса.Выбрать();
		ВыборкаЗап.Следующий();
		ТекPLU = ВыборкаЗап.PLU + 1;
	КонецЕсли;
		
	НЗ = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
	НЗ.Отбор.Штрихкод.Установить(ТекШК);
	НЗ.Прочитать();
	Для Каждого Зап Из НЗ Цикл
		Зап.PLU = ТекPLU;	
	КонецЦикла;
	НЗ.Записать();
	
	Возврат ТекPLU;
КонецФункции	

