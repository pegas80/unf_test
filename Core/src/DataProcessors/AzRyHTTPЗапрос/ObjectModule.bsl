Функция ПарамертыСоединение()

	Соединение = Новый Структура;
	Соединение.Вставить("Сервер", Неопределено);
	Соединение.Вставить("Порт", Неопределено);
	Соединение.Вставить("Пользователь", Неопределено);
	Соединение.Вставить("Пароль", Неопределено);
	Соединение.Вставить("Прокси", Неопределено);
	Соединение.Вставить("Таймаут", Неопределено);
	Соединение.Вставить("ЗащищенноеСоединение", Неопределено);

	Возврат Соединение; 
	
КонецФункции

