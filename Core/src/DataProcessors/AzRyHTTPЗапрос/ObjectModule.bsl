Функция GET(Парам) Экспорт
	
	Соединение = Новый HTTPСоединение(Парам.Соединение.Сервер, Парам.Соединение.Порт, Парам.Соединение.Пользователь, 
									  Парам.Соединение.Пароль, Парам.Соединение.Прокси, Парам.Соединение.Таймаут, Парам.Соединение.ЗащищенноеСоединение);
		
	Возврат Соединение.Получить(Новый HTTPЗапрос(Парам.Resource, Парам.Headers), Парам.ИмяФайлаЗапроса);
	
КонецФункции

Функция POST(Парам) Экспорт
	
	Соединение = Новый HTTPСоединение(Парам.Соединение.Сервер, Парам.Соединение.Порт, Парам.Соединение.Пользователь, 
									  Парам.Соединение.Пароль, Парам.Соединение.Прокси, Парам.Соединение.Таймаут, Парам.Соединение.ЗащищенноеСоединение);
									  
	Запрос = Новый HTTPЗапрос(Парам.Resource, Парам.Headers);
	Запрос.УстановитьТелоИзСтроки(Парам.Parameters, "CESU-8");
	
	Возврат Соединение.ОтправитьДляОбработки(Запрос);
	
КонецФункции

Функция PUT(Парам) Экспорт
	

	Возврат "";
	
КонецФункции

Функция DELETE(Парам) Экспорт
	

	Возврат "";
	
КонецФункции

Функция ПарамертыHTTPЗапрос() Экспорт
		
	Парам = Новый Структура;
	Парам.Вставить("Headers", ПарамертыHeaders());
	Парам.Вставить("Parameters", "");	
	Парам.Вставить("Соединение", ПарамертыСоединение());
	Парам.Вставить("Resource", Неопределено);
	Парам.Вставить("ИмяФайлаЗапроса", Неопределено);

	Возврат Парам; 
	
КонецФункции

