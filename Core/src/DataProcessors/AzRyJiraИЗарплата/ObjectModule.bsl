Функция РедактироватьДокументыЗаданияНаРаботу(ТЗ) Экспорт 
	
	ОбменДаннымиСервер.ПропуститьПроверкуЗапретаИзменения();
	ФилтрТЗ1(ТЗ, "Регистратор", Документы.ЗаданиеНаРаботу.ПустаяСсылка());
		
	НачатьТранзакцию();
	Попытка
		
		Для каждого ТекСтрока Из ТЗ Цикл
			
			Если ТекСтрока.Статус Тогда
				
				ДокОбъект = ТекСтрока.Регистратор.ПолучитьОбъект();
				ДокОбъект.Сотрудник                    = ТекСтрока.Сотрудник;
				ДокОбъект.Организация                  = ТекСтрока.ОрганизацияЗаданияНаРаботу;
				//ДокОбъект.Работы[0].Заказчик           = ТекСтрока.ЗаказПокупателя;
				ДокОбъект.Работы[0].Трудоемкость       = ТекСтрока.ЗагрузкаПлан;
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			КонецЕсли; 	
			
		КонецЦикла;		
		
	Исключение
		Сообщить(ОписаниеОшибки());
		ОтменитьТранзакцию();
		ОбменДаннымиСервер.ПропуститьПроверкуЗапретаИзменения(Ложь);
		Возврат Ложь;
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	ОбменДаннымиСервер.ПропуститьПроверкуЗапретаИзменения(Ложь);
	
	Возврат Истина;
	
КонецФункции

Процедура ФилтрТЗ(ТЗ, КолонкаТЗ, ПроверкаЗнач) Экспорт
          
	МассивСтрок = Новый Массив;
	Для каждого ТекСтрока Из ТЗ Цикл           
		Если ПроверкаЗнач.НайтиПоЗначению(ТекСтрока[КолонкаТЗ]) = Неопределено Тогда 
			МассивСтрок.Добавить(ТекСтрока);
		КонецЕсли;	
	КонецЦикла;
	
	Для каждого ТекМассив Из МассивСтрок Цикл
		ТЗ.Удалить(ТекМассив);		
	КонецЦикла;

КонецПроцедуры

Процедура ФилтрТЗ1(ТЗ, КолонкаТЗ, ПроверкаЗнач) Экспорт
          
	МассивСтрок = Новый Массив;
	Для каждого ТекСтрока Из ТЗ Цикл
  		Если ТекСтрока[КолонкаТЗ] = ПроверкаЗнач Тогда 
			МассивСтрок.Добавить(ТекСтрока);
		КонецЕсли;	
	КонецЦикла;
	
	Для каждого ТекМассив Из МассивСтрок Цикл
		ТЗ.Удалить(ТекМассив);		
	КонецЦикла;

КонецПроцедуры

Функция СотрудникиИзДжира(Дата) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаданиеНаРаботу.Сотрудник
		|ИЗ
		|	Документ.ЗаданиеНаРаботу КАК ЗаданиеНаРаботу
		|ГДЕ
		|	ЗаданиеНаРаботу.Дата МЕЖДУ &Дата1 И &Дата2
		|	И ЗаданиеНаРаботу.ПометкаУдаления = ЛОЖЬ";

	Запрос.УстановитьПараметр("Дата1", НачалоМесяца(Дата));
	Запрос.УстановитьПараметр("Дата2", КонецМесяца(Дата));

	ТЗ = Запрос.Выполнить().Выгрузить();
	
	СП = Новый СписокЗначений;
	Для каждого ТекСтрока Из ТЗ Цикл
		СП.Добавить(ТекСтрока.Сотрудник);
	КонецЦикла;
	
	Возврат СП;

КонецФункции
 

