					ДокОбъект.СтруктурнаяЕдиницаПолучатель	= СтрокаСклада.Склад;
				Иначе
					ДокОбъект.СтруктурнаяЕдиницаПолучатель	= Неопределено;
				КонецЕсли;
				
			Иначе
				ДокОбъект.СтруктурнаяЕдиницаПолучатель	= Неопределено;
			КонецЕсли;
		ИначеЕсли СтрокаТТН.TYPE = 5 Тогда  //Возврат от покупателя
			Если ЗначениеЗаполнено(СтрокаТТН.START_ADDRESS) Тогда
				СтрокаСклада =  ТаблицаСкладов.Найти(СтрокаТТН.END_ADDRESS, "Адрес");
				Если ЗначениеЗаполнено(СтрокаСклада) Тогда
					ДокОбъект.СтруктурнаяЕдиница	= СтрокаСклада.Склад;
				Иначе
					ДокОбъект.СтруктурнаяЕдиница	= Неопределено;
				КонецЕсли;
			Иначе
				ДокОбъект.СтруктурнаяЕдиница	= Неопределено;
			КонецЕсли;
		Иначе //Реализация
			Если ЗначениеЗаполнено(СтрокаТТН.END_ADDRESS) Тогда
				СтрокаСклада =  ТаблицаСкладов.Найти(СтрокаТТН.START_ADDRESS, "Адрес");
