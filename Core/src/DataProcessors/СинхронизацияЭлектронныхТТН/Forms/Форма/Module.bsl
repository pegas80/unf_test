				ТранспортноеСредство = Справочники.ТранспортныеСредства.НайтиПоКоду(СтрокаТТН.CAR_NUMBER);
				
				СтрокаСклада =  ТаблицаСкладов.Найти(ТранспортноеСредство, "ТранспортноеСредство");
				
