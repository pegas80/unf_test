
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СтавкаНДС18 = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеСтавкиНДС(УправлениеНебольшойФирмойПовтИсп.ПолучитьСтавкуНДС("НДС18"));
	ИспользоватьДокументыВА = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеКонстанты("ИспользоватьДокументыВАДляЭлектронныхНакладных");
	Элементы.ТоварныеНакладныеНаПорталеЭтаИмущество.Видимость = ИспользоватьДокументыВА;
	
	Полученный						= Истина;
	СтатусТТНАктивный				= Истина;
	ВнутреннееПеремещение 			= Истина;
	РеализацияСТранспортировкой		= Истина;
	РеализацияБезТранспортировки	= Истина;
	Дистрибуция 					= Ложь;
	ВозвратПокупателяПокупателю 	= Истина;
	ПодчиненнаяТН					= Ложь;
	
	ДатаКон 			= ТекущаяДата();
	ДатаНач 			= ДатаКон - 86400*2;
	НациональнаяВалюта 	= УправлениеНебольшойФирмойПовтИсп.ПолучитьНациональнуюВалюту();
	
	Если НЕ ЗначениеЗаполнено(Организация) Тогда
		Организация = УправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеПоУмолчаниюПользователя(
		Пользователи.ТекущийПользователь(),
		"ОсновнаяОрганизация");
		Если НЕ ЗначениеЗаполнено(Организация) Тогда
			Организация = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.Организации.ОсновнаяОрганизация");
		КонецЕсли;
	КонецЕсли;
	ЗаполнитьСоответствиеНоменклатуры();
	УчетЦенКонтрагентов = ПолучитьФункциональнуюОпцию("УчетЦенКонтрагентов");
	
КонецПроцедуры
&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗаполнитьСоответствиеНоменклатуры();
КонецПроцедуры
&НаКлиенте
Процедура ДатаНачПриИзменении(Элемент)
	
	ДанныеНеСоответствуютФильтру = Истина;
	УстановитьТекстПодсказки();
	
КонецПроцедуры
&НаКлиенте
Процедура ДатаКонПриИзменении(Элемент)
	
	ДанныеНеСоответствуютФильтру = Истина;
	УстановитьТекстПодсказки();
	
КонецПроцедуры
&НаКлиенте
Процедура ПоставщикПриИзменении(Элемент)
	
	ДанныеНеСоответствуютФильтру = Истина;
	УстановитьТекстПодсказки();
	
КонецПроцедуры
&НаКлиенте
Процедура ТоварныеНакладныеНаПорталеКонтрагентПриИзменении(Элемент)
	
	ТекДанные = Элементы.ТоварныеНакладныеНаПортале.ТекущиеДанные;
	ПоставщикПокупатель = УправлениеНебольшойФирмойСервер.ЗначенияРеквизитовОбъекта(ТекДанные.Контрагент, "Поставщик,Покупатель");
	ТекДанные.Поставщик		= ПоставщикПокупатель.Поставщик;
	ТекДанные.Покупатель	= ПоставщикПокупатель.Покупатель;
	
КонецПроцедуры


&НаКлиенте
Процедура ОбновитьДанные(Команда)
	
	ОчиститьСообщения();
	ОбновитьДанныеНаСервере();
	
КонецПроцедуры
&НаСервере
Процедура ОбновитьДанныеНаСервере()
	
	Объект.ТоварныеНакладныеНаПортале.Очистить();
	Объект.ТоварыНаПортале.Очистить();
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Сообщить(НСтр("ka='არ არის შევსებული შევსებული ველი ""ორგანიზაცია"".';ru='Не заполнен поле ""Организация""'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаНач) Или Не ЗначениеЗаполнено(ДатаКон) Тогда
		Сообщить(НСтр("ka='არ არის შევსებული პერიოდი';ru='Не заполнен период'"));
		Возврат;
	КонецЕсли;
	
	Колво = 0;
	ТаблицаНакладных		= Объект.ТоварныеНакладныеНаПортале.Выгрузить();
	ТаблицаТоварыНакладных	= Объект.ТоварыНаПортале.Выгрузить();
	ИННКонтрагента			= СокрЛП(Контрагент.ИНН);
	itypes = "";
	Если ВнутреннееПеремещение 			Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",1", "1"); КонецЕсли;//1 გადაადგილება
	Если РеализацияСТранспортировкой 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",2", "2"); КонецЕсли;//2 რეალიზაცია ტრანსპორტირებით
	Если РеализацияБезТранспортировки 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",3", "3"); КонецЕсли;//3 რეალიზაცია ტრანსპორტირების გარეშე
	Если Дистрибуция 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",4", "4"); КонецЕсли;//4 დისტრიბუცია
	Если ВозвратПокупателяПокупателю 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",5", "5"); КонецЕсли;//5 უკან დაბრუნება
	Если ПодчиненнаяТН 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",6", "6"); КонецЕсли;//6 ქვე-ზედნადები
	
	П_Обработки = Новый Структура;
	П_Обработки.Вставить("Организация", 		Организация);
	П_Обработки.Вставить("ДатаНач", 			НачалоДня(ДатаНач));
	П_Обработки.Вставить("ДатаКон", 			КонецДня(ДатаКон));
	П_Обработки.Вставить("ИННКонтрагента",		ИННКонтрагента);
	П_Обработки.Вставить("itypes", 				itypes);
	
	
	Statuses = ",";
	Если СтатусТТНАктивный		Тогда statuses = ?(statuses = ",", statuses + "1", 	statuses + ",1");	КонецЕсли;//1 აქტიური
	Если СтатусТТНДоставленный	Тогда statuses = ?(statuses = ",", statuses + "2", 	statuses + ",2");	КонецЕсли;//2 დასრულებული
	
	//მიღებული
	Если Полученный И НЕ Statuses = "," Тогда
		П_Обработки.Вставить("Statuses", 			Statuses + ",");
	
		триДня 			= 86400 * 2;
		Если НачалоДня(ДатаКон) - НачалоДня(ДатаНач) <= триДня Тогда
			ТаблицаНакладных.Очистить();
			ТаблицаТоварыНакладных.Очистить();
			П_Обработки.Вставить("SoapAction", 		"get_buyer_waybills");
			
			ДанныеПриниятихНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
			Если НЕ ДанныеПриниятихНакладных = Неопределено Тогда
				П_Обработки.Вставить("SoapAction", 		"get_buyer_waybilll_goods_list");
				ДанныеТабПриниятихНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
				Если НЕ ДанныеТабПриниятихНакладных = Неопределено Тогда
					Объект.ТоварныеНакладныеНаПортале.Загрузить(ТаблицаНакладных);	
					Объект.ТоварыНаПортале.Загрузить(ТаблицаТоварыНакладных);
					Для Каждого нТоварыНаПортале ИЗ Объект.ТоварыНаПортале Цикл
						Если нТоварыНаПортале.VAT_TYPE = "0" Тогда
							нТоварыНаПортале.СуммаНДС = нТоварыНаПортале.AMOUNT - (нТоварыНаПортале.AMOUNT) /((100 + СтавкаНДС18)/100);
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;				
			КонецЕсли;
		Иначе
			МассивДней = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьМассивДней(ДатаНач, ДатаКон);
			Для Каждого СтрокаДаты Из МассивДней Цикл
				ТаблицаНакладных.Очистить();
				ТаблицаТоварыНакладных.Очистить();
				П_Обработки.Вставить("ДатаНач", 		НачалоДня(СтрокаДаты.ДатаНач));
				П_Обработки.Вставить("ДатаКон", 		КонецДня(СтрокаДаты.ДатаКон));
				П_Обработки.Вставить("SoapAction", 		"get_buyer_waybills");
				
				ДанныеПриниятихНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
				Если НЕ ДанныеПриниятихНакладных = Неопределено Тогда
					П_Обработки.Вставить("SoapAction", 		"get_buyer_waybilll_goods_list");
					ДанныеТабПриниятихНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьПолученныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
					Если НЕ ДанныеТабПриниятихНакладных = Неопределено Тогда
						Для Каждого СтрокаНакладной Из ТаблицаНакладных Цикл
							нТоварныеНакладныеНаПортал = Объект.ТоварныеНакладныеНаПортале.Добавить();	
							ЗаполнитьЗначенияСвойств(нТоварныеНакладныеНаПортал, СтрокаНакладной);	
						КонецЦикла;
						
						Для Каждого СтокаТовара Из ТаблицаТоварыНакладных Цикл
							нТоварыНаПортале = Объект.ТоварыНаПортале.Добавить();	
							ЗаполнитьЗначенияСвойств(нТоварыНаПортале, СтокаТовара);
							Если СтокаТовара.VAT_TYPE = "0" Тогда
								нТоварыНаПортале.СуммаНДС = СтокаТовара.AMOUNT - (СтокаТовара.AMOUNT) /((100 + СтавкаНДС18)/100);
							КонецЕсли;
						КонецЦикла;						
					КонецЕсли;					
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Состояние", "მიღებული")).Количество() > 0 Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокНакладных("მიღებული", Объект.ТоварныеНакладныеНаПортале);
		КонецЕсли;
	КонецЕсли;
	
	Statuses = ",";
	//Если СтатусТТНСохраненный	Тогда statuses = ?(statuses = ",", statuses + "0", 	statuses + ",0");	КонецЕсли;//0 შენახული
	Если СтатусТТНАктивный		Тогда statuses = ?(statuses = ",", statuses + "1", 	statuses + ",1");	КонецЕсли;//1 აქტიური
	Если СтатусТТНДоставленный	Тогда statuses = ?(statuses = ",", statuses + "2", 	statuses + ",2");	КонецЕсли;//2 დასრულებული
	Если СтатусТТНОтмененный	Тогда statuses = ?(statuses = ",", statuses + "-2", statuses + ",-2");	КонецЕсли;//-2 გაუქმებული
	
	itypes = "";
	//Если ВнутреннееПеремещение 		Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",1", "1"); КонецЕсли;//1 გადაადგილება
	Если РеализацияСТранспортировкой 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",2", "2"); КонецЕсли;//2 რეალიზაცია ტრანსპორტირებით
	Если РеализацияБезТранспортировки 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",3", "3"); КонецЕсли;//3 რეალიზაცია ტრანსპორტირების გარეშე
	Если Дистрибуция 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",4", "4"); КонецЕсли;//4 დისტრიბუცია
	Если ВозвратПокупателяПокупателю 	Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",5", "5"); КонецЕсли;//5 უკან დაბრუნება
	Если ПодчиненнаяТН 					Тогда itypes = ?(ЗначениеЗаполнено(itypes), itypes + ",6", "6"); КонецЕсли;//6 ქვე-ზედნადები
	
	//გაცემული
	Если Отправленный И НЕ Statuses = "," Тогда
		ТаблицаНакладных.Очистить();
		ТаблицаТоварыНакладных.Очистить();
		П_Обработки.Вставить("ДатаНач", 					НачалоДня(ДатаНач));
		П_Обработки.Вставить("ДатаКон", 					КонецДня(ДатаКон));
		П_Обработки.Вставить("Statuses", 					Statuses + ",");
		П_Обработки.Вставить("itypes", 						itypes);
		П_Обработки.Вставить("SoapAction", 					"get_waybills");
		
		ДанныеРасходныхНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
		Если НЕ ДанныеРасходныхНакладных = Неопределено Тогда
			П_Обработки.Вставить("SoapAction", 				"get_waybill_goods_list");
			ДанныеТоваровНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
			Если НЕ ДанныеТоваровНакладных = Неопределено Тогда
				Для Каждого СтрокаНакладной Из ТаблицаНакладных Цикл
					нТоварныеНакладныеНаПортал = Объект.ТоварныеНакладныеНаПортале.Добавить();	
					ЗаполнитьЗначенияСвойств(нТоварныеНакладныеНаПортал,СтрокаНакладной);	
				КонецЦикла;
				
				Для Каждого СтокаТовара Из ТаблицаТоварыНакладных Цикл
					нТоварыНаПортале = Объект.ТоварыНаПортале.Добавить();	
					ЗаполнитьЗначенияСвойств(нТоварыНаПортале,СтокаТовара);
					Если СтокаТовара.VAT_TYPE = "0" Тогда
						нТоварыНаПортале.СуммаНДС = СтокаТовара.AMOUNT - (СтокаТовара.AMOUNT) /((100 + СтавкаНДС18)/100);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		Если Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Состояние", "გაგზავნილი")).Количество() > 0 Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокНакладных("გაგზავნილი", Объект.ТоварныеНакладныеНаПортале);
		КонецЕсли;
	КонецЕсли;
	
	
	//შენახული
	Если СтатусТТНСохраненный Тогда
		ТаблицаНакладных.Очистить();
		ТаблицаТоварыНакладных.Очистить();
		П_Обработки.Вставить("ДатаНач", 					НачалоДня(ДатаНач));
		П_Обработки.Вставить("ДатаКон", 					КонецДня(ДатаКон));
		П_Обработки.Вставить("Statuses", 					",0,");
		П_Обработки.Вставить("СоответствиеНоменклатуры", 	Организация.СоответствиеПриВыгрузкеОтправленныхНоменклатур);
		П_Обработки.Вставить("SoapAction", 					"get_waybills");
		
		ДанныеРасходныхНакладных    = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаНакладных);//ქუდი
		Если НЕ ДанныеРасходныхНакладных = Неопределено Тогда
			П_Обработки.Вставить("SoapAction", 				"get_waybill_goods_list");
			ДанныеТоваровНакладных = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ПолучитьВыданныеНакладные(П_Обработки, ТаблицаТоварыНакладных);//ცხრილი
			Если НЕ ДанныеТоваровНакладных = Неопределено Тогда
				Для Каждого СтрокаНакладной Из ТаблицаНакладных Цикл
					нТоварныеНакладныеНаПортал = Объект.ТоварныеНакладныеНаПортале.Добавить();	
					ЗаполнитьЗначенияСвойств(нТоварныеНакладныеНаПортал,СтрокаНакладной);	
				КонецЦикла;
				
				Для Каждого СтокаТовара Из ТаблицаТоварыНакладных Цикл
					нТоварыНаПортале = Объект.ТоварыНаПортале.Добавить();	
					ЗаполнитьЗначенияСвойств(нТоварыНаПортале,СтокаТовара);
					Если СтокаТовара.VAT_TYPE = "0" Тогда
						нТоварыНаПортале.СуммаНДС = СтокаТовара.AMOUNT - (СтокаТовара.AMOUNT) /((100 + СтавкаНДС18)/100);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		Если Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Состояние", "შენახული")).Количество() > 0 Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписокНакладных("შენახული", Объект.ТоварныеНакладныеНаПортале);
		КонецЕсли;
	КонецЕсли;
	
	//დოკუმენტებისთვის სტატუსების მინიჭება
	СтрокиСДокументами = Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("ДокументПревязан", Истина));
	Если СтрокиСДокументами.Количество() > 0 Тогда
		
		ТаблицаТоваров = Объект.ТоварыНаПортале.Выгрузить();
		ТаблицаТоваров.Свернуть("ID, WAYBILL_NUMBER", "AMOUNT, QUANTITY, СуммаНДС");
		
		Для Каждого СтрокаСДок ИЗ СтрокиСДокументами Цикл
			Если СтрокаСДок.Состояние = "მიღებული" Тогда 
				НайденныеСтрокиТоваров = ТаблицаТоваров.НайтиСтроки(Новый Структура("WAYBILL_NUMBER", СтрокаСДок.WAYBILL_NUMBER));
			Иначе //"შენახული" "გაგზავნილი"
				НайденныеСтрокиТоваров = ТаблицаТоваров.НайтиСтроки(Новый Структура("ID", СтрокаСДок.ID));
			КонецЕсли;
			Если НайденныеСтрокиТоваров.Количество() > 0 Тогда
				СтрокаТ = НайденныеСтрокиТоваров[0];
				Если СтрокаСДок.TYPE = 4 ИЛИ СтрокаСДок.TYPE = 1 Тогда
					Если СтрокаТ.QUANTITY = СтрокаСДок.КоличествоДокумента Тогда
						СтрокаСДок.СтатусСинхронизации = "სრულად სინქრონიზირებული";
					Иначе
						СтрокаСДок.СтатусСинхронизации = "ნაწილობრივ სინქრონიზირებული";
						СтрокаСДок.РасшифровкаСтатуса = СтрокаСДок.РасшифровкаСтатуса + "განსხვავდება რაოდენობა. RS: " + СтрокаТ.QUANTITY + ", დოკუმენტი: " + СтрокаСДок.КоличествоДокумента + ";";
					КонецЕсли;
				Иначе
					Если СтрокаТ.СуммаНДС = СтрокаСДок.СуммаНДСДокумента И СтрокаТ.AMOUNT = СтрокаСДок.СуммаДокумента И СтрокаТ.QUANTITY = СтрокаСДок.КоличествоДокумента Тогда
						Если СтрокаСДок.ЕстьУслугиВДокументе И НЕ СтрокаСДок.ЕстьТоварыВДокументе Тогда
							СтрокаСДок.СтатусСинхронизации = "ჩამოწერილი მომსახურებაში";
						ИначеЕсли СтрокаСДок.ЕстьУслугиВДокументе Тогда
							СтрокаСДок.СтатусСинхронизации = "ნაწილობრივ ჩამოწერილი მომსახურებაში";
						Иначе
							СтрокаСДок.СтатусСинхронизации = "სრულად სინქრონიზირებული";
						КонецЕсли;
					Иначе
						СтрокаСДок.СтатусСинхронизации = "ნაწილობრივ სინქრონიზირებული";
						Если НЕ СтрокаТ.AMOUNT = СтрокаСДок.СуммаДокумента Тогда
							СтрокаСДок.РасшифровкаСтатуса = "განსხვავდება თანხა. RS: " + СтрокаТ.AMOUNT + ", დოკუმენტი: " + СтрокаСДок.СуммаДокумента + "; ";
						КонецЕсли;
						Если НЕ СтрокаТ.СуммаНДС = СтрокаСДок.СуммаНДСДокумента Тогда
							СтрокаСДок.РасшифровкаСтатуса = СтрокаСДок.РасшифровкаСтатуса + "განსხვავდება დღგ-ს თანხა. RS: " + СтрокаТ.СуммаНДС + ", დოკუმენტი: " + СтрокаСДок.СуммаНДСДокумента + "; ";
						КонецЕсли;
						Если НЕ СтрокаТ.QUANTITY = СтрокаСДок.КоличествоДокумента Тогда
							СтрокаСДок.РасшифровкаСтатуса = СтрокаСДок.РасшифровкаСтатуса + "განსხვავდება რაოდენობა. RS: " + СтрокаТ.QUANTITY + ", დოკუმენტი: " + СтрокаСДок.КоличествоДокумента + "; ";
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	СтрокиСПустымиДокументами =  Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("ДокументПревязан", Ложь));
	Для Каждого СтрокаПуст ИЗ СтрокиСПустымиДокументами Цикл
		СтрокаПуст.СтатусСинхронизации = "არსებობს მხოლოდ პორტალზე";
	КонецЦикла;
	
	ЗаполнитьНоменклатуруОтправленные_НаСервере();
	ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ЗаполнитьСписок_Контрагентов(Объект.ТоварныеНакладныеНаПортале);	
	ДанныеНеСоответствуютФильтру = Ложь;
	
	ОбновитьЦеныНоменклатуры();
	
КонецПроцедуры



&НаСервере
Процедура ОбновитьЦеныНоменклатуры(Идентификатор = Неопределено)
	
	
	Если
		 Не ЗначениеЗаполнено(Контрагент) Или
		 Не ЗначениеЗаполнено(ВидЦен) Тогда
		Возврат;
	КонецЕсли;
	
	Если Идентификатор = Неопределено Тогда
		Для Каждого СтрокаТЧ Из Объект.ТоварыНаПортале Цикл 
			Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда 
				Цены = РегистрыСведений.ЦеныНоменклатурыКонтрагентов.СрезПоследних(, Новый Структура("Номенклатура, Характеристика",  СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));//Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка()
				Если Не Цены.Количество() = 0 Тогда
					СтрокаТЧ.Цена = Цены[0].Цена;
				Иначе
					СтрокаТЧ.Цена = 0;
				КонецЕсли;
			Иначе
				СтрокаТЧ.Цена = 0;
			КонецЕсли;
			
			Если СтрокаТЧ.PRICE = СтрокаТЧ.Цена Тогда
				СтрокаТЧ.ЦветСравнения = 0;
			ИначеЕсли СтрокаТЧ.PRICE < СтрокаТЧ.Цена Тогда
				СтрокаТЧ.ЦветСравнения = 1;
			Иначе
				СтрокаТЧ.ЦветСравнения = -1;
			КонецЕсли;
		КонецЦикла;
	Иначе
		СтрокаТЧ = Объект.ТоварыНаПортале.НайтиПоИдентификатору(Идентификатор);
		Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда 
			Цены = РегистрыСведений.ЦеныНоменклатурыКонтрагентов.СрезПоследних(, Новый Структура("Номенклатура, Характеристика",  СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));//Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка()
			Если Не Цены.Количество() = 0 Тогда
				СтрокаТЧ.Цена = Цены[0].Цена;
			Иначе
				СтрокаТЧ.Цена = 0;
			КонецЕсли;
		Иначе
			СтрокаТЧ.Цена = 0;
		КонецЕсли;
		
		Если СтрокаТЧ.PRICE = СтрокаТЧ.Цена Тогда
			СтрокаТЧ.ЦветСравнения = 0;
		ИначеЕсли СтрокаТЧ.PRICE < СтрокаТЧ.Цена Тогда
			СтрокаТЧ.ЦветСравнения = 1;
		Иначе
			СтрокаТЧ.ЦветСравнения = -1;
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЦеныПродаж(Идентификатор = Неопределено)
	
	ВидЦенПродажи = Справочники.ВидыЦен.Оптовая;
	
	Если Идентификатор = Неопределено Тогда
		Для Каждого СтрокаТЧ Из Объект.ТоварыНаПортале Цикл 
			Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
				ЦеныПродажи = РегистрыСведений.ЦеныНоменклатуры.СрезПоследних(, Новый Структура("ВидЦен, Номенклатура, Характеристика", ВидЦенПродажи, СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));
				Если Не ЦеныПродажи.Количество() = 0 Тогда
					СтрокаТЧ.ЦенаНоменклатуры = ЦеныПродажи[0].Цена;
				Иначе
					СтрокаТЧ.ЦенаНоменклатуры = 0;
				КонецЕсли;
			Иначе
				СтрокаТЧ.ЦенаНоменклатуры = 0;
			КонецЕсли;
		КонецЦикла;
	Иначе
		СтрокаТЧ = Объект.ТоварыНаПортале.НайтиПоИдентификатору(Идентификатор);
		Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура) Тогда
			ЦеныПродажи = РегистрыСведений.ЦеныНоменклатуры.СрезПоследних(, Новый Структура("ВидЦен, Номенклатура, Характеристика", ВидЦенПродажи, СтрокаТЧ.Номенклатура, СтрокаТЧ.Характеристика));
			Если Не ЦеныПродажи.Количество() = 0 Тогда
				СтрокаТЧ.ЦенаНоменклатуры = ЦеныПродажи[0].Цена;
			Иначе
				СтрокаТЧ.ЦенаНоменклатуры = 0;
			КонецЕсли;
		Иначе
			СтрокаТЧ.ЦенаНоменклатуры = 0;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры



&НаКлиенте
Процедура СоздатьНакладные(Команда)
	
	ОчиститьСообщения();
	Если ДанныеНеСоответствуютФильтру Тогда 
		Возврат;
	КонецЕсли;
	
	ЕстьОшибки = Ложь;
	СоздатьДокументы_НаСервере(ЕстьОшибки);
	Если НЕ ЕстьОшибки Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.ГруппаСозданныеДокументы;
		ЗаполнитьНоменклатуруПолученные_НаСервере();
		ЗаполнитьНоменклатуруОтправленные_НаСервере();
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура СоздатьДокументы_НаСервере(ЕстьОшибки)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Представление КАК Адрес,
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка КАК Склад,
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ТранспортноеСредство
		|ИЗ
		|	Справочник.СтруктурныеЕдиницы.КонтактнаяИнформация КАК СтруктурныеЕдиницыКонтактнаяИнформация
		|ГДЕ
		|	СтруктурныеЕдиницыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресСтруктурнойЕдиницы)
		|	И СтруктурныеЕдиницыКонтактнаяИнформация.Ссылка.ТипСтруктурнойЕдиницы = ЗНАЧЕНИЕ(Перечисление.ТипыСтруктурныхЕдиниц.Склад)";
	ТаблицаСкладов = Запрос.Выполнить().Выгрузить();
	
	ПроверитьПередСозданиемДокументов(ЕстьОшибки);
	
	//ТаблицаКонтрагентов = Новый ТаблицаЗначений;
	//ТаблицаКонтрагентов.Колонки.Добавить("Контрагент",	Новый ОписаниеТипов("СправочникСсылка.Контрагенты"));
	//ТаблицаКонтрагентов.Колонки.Добавить("ИНН", 			Новый ОписаниеТипов("Строка", , , ,Новый КвалификаторыСтроки(13)));
	//ТаблицаКонтрагентов.Колонки.Добавить("Поставщик", 	Новый ОписаниеТипов("Булево"));
	//ТаблицаКонтрагентов.Колонки.Добавить("Покупатель", 	Новый ОписаниеТипов("Булево"));
	
	СчетаУчета = РегламентированныйУчетСервер.ПолучитьСчетаКонтрагентаПоУмолчанию();
	
	СоздатьДокументы_Полученные_НаСервере(ТаблицаСкладов, 	ЕстьОшибки, СчетаУчета);
	СоздатьДокументы_Отправленные_НаСервере(ТаблицаСкладов, ЕстьОшибки, СчетаУчета);
	
КонецПроцедуры
&НаСервере
Процедура СоздатьДокументы_Полученные_НаСервере(ТаблицаСкладов, 	ЕстьОшибки, СчетаУчета)
	
	ОтмеченныеСтроки = Объект.ТоварныеНакладныеНаПортале.НайтиСтроки(Новый Структура("Флаг, ЕстьОшибки, Полученный", Истина, Ложь, Истина));
	Для Каждого СтрокаТТН Из ОтмеченныеСтроки Цикл
		//Создать документ
		Если СтрокаТТН.TYPE = 1 Тогда
			Если СтрокаТТН.ЭтаИмущество Тогда
				ДокОбъект = Документы.ПеремещениеВА.СоздатьДокумент();
			Иначе
			    ДокОбъект = Документы.ПеремещениеЗапасов.СоздатьДокумент();
				ДокОбъект.ВидОперации	= Перечисления.ВидыОперацийПеремещениеЗапасов.Перемещение;
			КонецЕсли;
		ИначеЕсли СтрокаТТН.TYPE = 5 Тогда
			ДокОбъект = Документы.РасходнаяНакладная.СоздатьДокумент();
			ДокОбъект.ВидОперации				= Перечисления.ВидыОперацийРасходнаяНакладная.ВозвратПоставщику;
			Если ЗначениеЗаполнено(СтрокаТТН.Контрагент) Тогда
				ДокОбъект.Контрагент				= СтрокаТТН.Контрагент;
			Иначе
				Если СоздатьНовыйКонтрагентЕслиНеНайден Тогда
					НайденныйКонтрагенты = ТаблицаКонтрагентов.НайтиСтроки(Новый Структура("ИНН", СтрокаТТН.SELLER_TIN));
					Если НайденныйКонтрагенты.Количество() = 0 Тогда
						КонтрагентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
						КонтрагентОбъект.Наименование	= СтрокаТТН.SELLER_NAME;
						КонтрагентОбъект.ИНН			= СтрокаТТН.SELLER_TIN;
						КонтрагентОбъект.Поставщик		= Истина;
						Если СтрДлина(СтрокаТТН.SELLER_TIN) = 9 Тогда
							КонтрагентОбъект.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
						Иначе
							КонтрагентОбъект.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
						КонецЕсли;
						ЗаполнитьЗначенияСвойств(КонтрагентОбъект, СчетаУчета);
						КонтрагентОбъект.Заполнить(Неопределено);
						КонтрагентОбъект.Записать();
						ДокОбъект.Контрагент				= КонтрагентОбъект.Ссылка;
					Иначе
						ДокОбъект.Контрагент				= НайденныйКонтрагенты[0].Контрагент;
					КонецЕсли;
					СтрокаТТН.Контрагент = ДокОбъект.Контрагент;
				КонецЕсли;
			КонецЕсли;
			ДокОбъект.Договор 	 				= ДокОбъект.Контрагент.ДоговорПоУмолчанию;
			ДокОбъект.ВалютаДокумента	 		= НациональнаяВалюта;
		Иначе
			ДокОбъект = Документы.ПриходнаяНакладная.СоздатьДокумент();
			ДокОбъект.ВидОперации				= Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
			Если ЗначениеЗаполнено(СтрокаТТН.Контрагент) Тогда
				ДокОбъект.Контрагент				= СтрокаТТН.Контрагент;
			Иначе
				Если СоздатьНовыйКонтрагентЕслиНеНайден Тогда
					НайденныйКонтрагенты = ТаблицаКонтрагентов.НайтиСтроки(Новый Структура("ИНН", СтрокаТТН.SELLER_TIN));
					Если НайденныйКонтрагенты.Количество() = 0 Тогда
						КонтрагентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
						КонтрагентОбъект.Наименование	= СтрокаТТН.SELLER_NAME;
						КонтрагентОбъект.ИНН			= СтрокаТТН.SELLER_TIN;
						КонтрагентОбъект.Поставщик		= Истина;
						Если СтрДлина(СтрокаТТН.SELLER_TIN) = 9 Тогда
							КонтрагентОбъект.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
						Иначе
							КонтрагентОбъект.ВидКонтрагента = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
						КонецЕсли;
						ЗаполнитьЗначенияСвойств(КонтрагентОбъект, СчетаУчета);
						КонтрагентОбъект.Заполнить(Неопределено);
						КонтрагентОбъект.Записать();
						ДокОбъект.Контрагент				= КонтрагентОбъект.Ссылка;
					Иначе
						ДокОбъект.Контрагент				= НайденныйКонтрагенты[0].Контрагент;
					КонецЕсли;
					СтрокаТТН.Контрагент = ДокОбъект.Контрагент;
				КонецЕсли;
			КонецЕсли;
			ДокОбъект.Договор 	 				= ДокОбъект.Контрагент.ДоговорПоУмолчанию;
			ДокОбъект.ВалютаДокумента	 		= НациональнаяВалюта;
			//Если УчетЦенКонтрагентов Тогда
			ДокОбъект.ВидЦенКонтрагента 	    	= ДокОбъект.Договор.ВидЦенКонтрагента;
			//	ДокОбъект.РегистрироватьЦеныПоставщика	= Истина;
			//КонецЕсли;
		КонецЕсли;
		
		//Шапка
		ДокОбъект.Дата 						= СтрокаТТН.BEGIN_DATE;
		ДокОбъект.Организация 				= Организация;
		ДокОбъект.Заполнить(Неопределено);
		Если СтрокаТТН.TYPE = 1 Тогда
