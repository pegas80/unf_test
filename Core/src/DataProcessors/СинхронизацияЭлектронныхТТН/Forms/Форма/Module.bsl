				НоваяСтрокаТЧ.Количество		  	= СтрокаТовары.QUANTITY;
				
				//РегистрыСведений.ТоварыПоставщиковВТТН.ЗаписатьВРегистрТоварыПоставщиков(СтрокаТовары);
