			ДокОбъект.Договор 	 				= ДокОбъект.Контрагент.ДоговорПоУмолчанию;
			ДокОбъект.ВалютаДокумента	 		= НациональнаяВалюта;
		КонецЕсли;
		
		//Шапка
		ДокОбъект.Дата 						= ?(ЗначениеЗаполнено(СтрокаТТН.BEGIN_DATE), СтрокаТТН.BEGIN_DATE, СтрокаТТН.ACTIVATE_DATE);
		ДокОбъект.Организация 				= Организация;
		ДокОбъект.Заполнить(Неопределено);
		Если СтрокаТТН.TYPE = 4 Тогда //Дистрибюция
			Если ЗначениеЗаполнено(СтрокаТТН.START_ADDRESS) Тогда
				СтрокаСклада =  ТаблицаСкладов.Найти(СтрокаТТН.START_ADDRESS, "Адрес");
