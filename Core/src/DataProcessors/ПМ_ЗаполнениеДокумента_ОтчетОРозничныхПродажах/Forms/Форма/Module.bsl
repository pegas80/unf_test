&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("КассаККМ") Тогда
		КассаККМ=Параметры.КассаККМ;
		ДатаОбмена=Параметры.Дата; //Дата документа Отчет о розничных продажах
		АдресВладельца=Параметры.Адрес;
		Организация = Параметры.Организация;
		Элементы.ГруппаОтбор.Видимость=Ложь;
		Этаформа.КоманднаяПанель.Видимость=Ложь;
		ЗаполнитьДаннымиИзРегистра();
	Иначе
		АдресВладельца=ЭтаФорма.УникальныйИдентификатор;
		Организация=Справочники.Организации.ОсновнаяОрганизация;
		Отладка=Истина;
	КонецЕсли; 	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	м1=Объект.тзНоменклатура.НайтиСтроки(Новый Структура("Флаг",Ложь));
	м2=Объект.тзОплата.НайтиСтроки(Новый Структура("Флаг",Ложь));
	Если Объект.тзНоменклатура.Количество()>0 И м1.Количество()=0 И м2.Количество()=0 Тогда
		Отказ=Истина;
		Оповестить("ПМ_ЗаполнениеДокумента",Новый Структура("АдресВоВременномХранилище,Сообщения",ПолучитьАдресВременногоХранилища(),Сообщения));
	ИначеЕсли	Не Отладка И Объект.тзНоменклатура.Количество()=0 Тогда
		Сообщения.Добавить(НСтр("ka='მონაცემები არ არის';ru='Нет данных'"));
		Отказ=Истина;
		Оповестить("ПМ_ЗаполнениеДокумента",Новый Структура("АдресВоВременномХранилище,Сообщения",ПолучитьАдресВременногоХранилища(),Сообщения));
	КонецЕсли; 
КонецПроцедуры

