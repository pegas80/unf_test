		|	И ПриходнаяНакладная.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПриходнаяНакладная.ВозвратОтПокупателя)";
	Запрос.УстановитьПараметр("НомераНакладных", НомераНакладных);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСуммуИНДСУДокумента(ДокументСсылка)

	Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ДополнительныеРасходы") Тогда
		СуммаНДСДокумент = ДокументСсылка.Расходы.Итог("СуммаНДС");
	Иначе
		СуммаНДСДокумент = ДокументСсылка.Запасы.Итог("СуммаНДС") + ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ПриходнаяНакладная"), ДокументСсылка.Расходы.Итог("СуммаНДС"), 0);
	КонецЕсли;
	СуммаВсего 			= ДокументСсылка.СуммаДокумента;
	СуммаДокумент		= СуммаВсего - СуммаНДСДокумент;
	
	Возврат Новый Структура("СуммаДокумента, СуммаНДС, Всего", СуммаДокумент, СуммаНДСДокумент, СуммаВсего);
	
КонецФункции




&НаСервере
Процедура ПроверитьПередСозданиемДокументов(ЕстьОшибки)
	
	ОтмеченныеСтроки = Объект.СписокСФ.НайтиСтроки(Новый Структура("Флаг", Истина));
	Для Каждого СтрокаСФ Из ОтмеченныеСтроки Цикл
		Если Не ЗначениеЗаполнено(СтрокаСФ.Контрагент) Тогда 
			Сообщение = Новый СообщениеПользователю;
			пНомерСтроки = Формат(СтрокаСФ.НомерСтроки-1, "ЧГ=0");
			Сообщение.Текст = "სტრიქონში ნომერი " + Формат(СтрокаСФ.НомерСтроки, "ЧГ=0") + " ფაქტურისთვი " +Формат(СтрокаСФ.ID, "ЧГ=0")+ " არ არის შევსებული კონტრაგენტი";
			Сообщение.Поле =  "Объект.СписокСФ[" + пНомерСтроки + "].Контрагент";
			Сообщение.УстановитьДанные(Объект);
			Сообщение.Сообщить();
			СтрокаСФ.ЕстьОшибки = Истина;
			ЕстьОшибки = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры



