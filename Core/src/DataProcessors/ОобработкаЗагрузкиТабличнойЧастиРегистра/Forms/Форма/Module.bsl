&НаСервере
Процедура загрузитьНаСервере1()
	
	ТаблицаЗагрузки = ТЗ.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	тзЗагрузки.ВидДвижения КАК ВидДвиженияТекст,
		|	тзЗагрузки.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
		|	тзЗагрузки.Стоимость КАК Стоимость,
		|	тзЗагрузки.Амортизация КАК Амортизация,
		|	тзЗагрузки.Период КАК Период,
		|	тзЗагрузки.ВидДвижения КАК ВидДвижения,
		|	тзЗагрузки.ВнеоборотныйАктивКод КАК ВнеоборотныйАктивКод,
		|	тзЗагрузки.СодержаниеПроводки КАК СодержаниеПроводки,
		|	тзЗагрузки.Организация КАК Организация
		|ПОМЕСТИТЬ ВТ_Загрузки
		|ИЗ
		|	&тзЗагрузки КАК тзЗагрузки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ВТ_Загрузки.ВидДвиженияТекст = ""Приход""
		|				ИЛИ ВТ_Загрузки.ВидДвиженияТекст = ""შემოსავალი""
		|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.РАСХОД)
		|	КОНЕЦ КАК ВидДвижения,
		|	ВТ_Загрузки.ВнеоборотныйАктив КАК ВнеоборотныйАктив,
		|	ВТ_Загрузки.Стоимость КАК Стоимость,
		|	ВТ_Загрузки.Амортизация КАК Амортизация,
		|	ВТ_Загрузки.Период КАК Период,
		|	ВТ_Загрузки.ВнеоборотныйАктивКод КАК ВнеоборотныйАктивКод,
		|	ВТ_Загрузки.СодержаниеПроводки КАК СодержаниеПроводки,
		|	ВТ_Загрузки.Организация КАК Организация
		|ИЗ
		|	ВТ_Загрузки КАК ВТ_Загрузки";
	
	Запрос.УстановитьПараметр("тзЗагрузки", ТаблицаЗагрузки);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	
	//Для Каждого Строк из ТаблицаЗагрузки  Цикл 
	//	Если Строк.ВидДвижения = "შემოსავალი" Или Строк.ВидДвижения = "Приход" Тогда 
	//		Строк.ВидДвижения = ВидДвиженияНакопления.Приход;
	//	ИначеЕсли Строк.ВидДвижения = "გასავალი" Или Строк.ВидДвижения = "Расход" Тогда
	//		Строк.ВидДвижения = ВидДвиженияНакопления.Расход;
	//	КонецЕсли;
	//КонецЦикла;
	
	НаборВнеоборотныеАктивы = РегистрыНакопления.ВнеоборотныеАктивы.СоздатьНаборЗаписей();
	НаборВнеоборотныеАктивы.Отбор.Регистратор.Установить(Регистратор);
	НаборВнеоборотныеАктивы.Прочитать();
	НаборВнеоборотныеАктивы.Загрузить(РезультатЗапроса);
	НаборВнеоборотныеАктивы.ОбменДанными.Загрузка = Истина;
	НаборВнеоборотныеАктивы.Записать();

	

КонецПроцедуры // загрузитьНаСервере1()


////сатестоа
&НаСервере
Функция ПолучитьЗначениеКолонки(ТаблицаПоиска, ТекстПоиска)
	
	РезультатПоиска = Неопределено;
	
	ПоискСтрок = ТаблицаПоиска.НайтиСтроки(Новый Структура("Код",ТекстПоиска));
	
	Если ПоискСтрок.Количество() > 0 Тогда 
		РезультатПоиска = ПоискСтрок[0].Ссылка;
	КонецЕсли;
	
	
	Возврат РезультатПоиска;
	
КонецФункции


&НаСервере
Функция ПолучитьЗначениеКолонки1(ТаблицаПоиска, ТекстПоиска)
	
	РезультатПоиска = Неопределено;
	
	ПоискСтрок = ТаблицаПоиска.НайтиСтроки(Новый Структура("Наименование",ТекстПоиска));
	
	Если ПоискСтрок.Количество() > 0 Тогда 
		РезультатПоиска = ПоискСтрок[0].Ссылка;
	КонецЕсли;
	
	
	Возврат РезультатПоиска;
	
КонецФункции


 
