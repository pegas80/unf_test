Функция  Домейн(IP,ДляЗадачи = Ложь)  Экспорт	
	
	   ScaleIP =  IP;    
	   
	   IPLastByte ="";
	   ИндексПоследнейТочки = СтрДлина(ScaleIP);
	   
	   НетТочки = Истина;
	   Счет = 0;
	   
	   Пока НетТочки Цикл  
		   
		   ВремСтрок = Сред (ScaleIP,ИндексПоследнейТочки,СтрДлина(ScaleIP));     		   
		   Если   Не Найти(ВремСтрок,".") = 0 Тогда   
			   НетТочки = Ложь;
			   Прервать;
		   КонецЕсли;
		   ИндексПоследнейТочки =  ИндексПоследнейТочки - 1;
		   IPLastByte =  ВремСтрок; 
		   Счет = Счет+1; 
		   
		   Если Счет >4 Тогда
			   Возврат -1;
		   КонецЕсли;	   
		 		   
	   КонецЦикла;	 
	   
	   Если ДляЗадачи Тогда   
		   Возврат  "" + Лев("000",3-СтрДлина(IPLastByte)) + IPLastByte;
	   Иначе   
		   Возврат  "S0"+Формат(IPLastByte,"ЧЦ=3; ЧВН=; ЧГ=0");
	   КонецЕсли;
	   
КонецФункции	

