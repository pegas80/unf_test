////////CSV DIGI_6000////////
&НаКлиенте
Функция СоздатьДанныеCSV(ТаблицаЗначений,разделитель,Удалить)
	Текст="";
	ОшибкаНаидено = Ложь;
	Массив = Новый Массив;
   	Массив.Добавить(",");
	Массив.Добавить("""");
    Массив.Добавить("'");
	для каждого запись из ТаблицаЗначений Цикл
		
		PLU = запись.PLU;
		
		Name = запись.НаименованиеНоменклатуры;
		Для Каждого симбол из Массив Цикл  
			Позиция = Найти(Name, симбол);
			Если Не Позиция = 0 Тогда 
				Сообщить(НСтр("ka='გამოყნებულია დაუშვებელი სიმბოლო PLU: ';ru='Используется недопустимый символ PLU: ';en='An inadmissible character is used PLU: '")+ PLU +" <"+симбол+">");
				ОшибкаНаидено = Истина;	
			КонецЕсли;
		КонецЦикла;
		Code = запись.Код;
		
		Price = запись.Цена;
		Если Price = 0 Тогда 
			Price = 0;
		КонецЕсли;
		Price = Формат( Price *100,"ЧДЦ=0; ЧГ=0" ); 
		
		IsWeightGoods = "NW";
		Если запись.Весовая Тогда 
			IsWeightGoods = "W";
		КонецЕсли;
		
		WeightUnit = запись.ПредставлениеВесовойЕдиницы;
		
		Delete = "0";
		Если Удалить Тогда 
			Delete = "1";	
		КонецЕсли;
		
		Родитель = "100";
		Если Не запись.КодРодитель = "" Тогда
			Если  запись.КодРодитель = "000100" Тогда 
				Сообщить(НСтр("ka='ჯგუფის კოდად 100 დაუშვებელი, შეცვალეთ ჯგუფის კოდი ნომეკლატურისთვის PLU: ';ru='Код группы 100 не допускается, изменить код группы для номенклатуры PLU:';en='Group code 100 not allowed, change group code for nomenclature PLU:'")+ PLU);
				ОшибкаНаидено = Истина;
			КонецЕсли;
			Родитель = Прав(запись.КодРодитель,4);	
		КонецЕсли;

		Barcode = Лев(запись.Штрихкод,2);
		ShelfLife = запись.СрокГодности;
		
		Текст = Текст + Delete + разделитель  + PLU + разделитель+ Родитель + разделитель + Barcode + разделитель + Code + разделитель + Name + разделитель + Price +  разделитель + IsWeightGoods +  разделитель + "0" +  разделитель + "17"+  разделитель + " " +  разделитель + "0" +  разделитель + "0" +  разделитель + WeightUnit + Символы.ПС;         	
		
	КонецЦикла;
	Если ОшибкаНаидено Тогда 
		Возврат  Ложь;
	КонецЕсли;
	Возврат текст;
КонецФункции

