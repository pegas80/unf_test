&НаСервере
Процедура ЗаполнитьНаСервере()
	
	ТипОборудования = ОбменСВесамиСПечатьюЭтикетокСервер.ТипОборудования(Весы);
	ПараметрыПодключения = ОбменСВесамиСПечатьюЭтикетокСервер.ПараметрыОборудования(Весы);
		
	ТаблицаТоваров = ОбменСВесамиСПечатьюЭтикетокСервер.ТаблицаВыгрузкиТоваров(Объект.ВидЦены, Неопределено);
	
	Объект.Товары.Очистить();
	
	Для Каждого СтрокТоваров Из ТаблицаТоваров Цикл
		ЗаполнитьЗначенияСвойств(Объект.Товары.Добавить(),СтрокТоваров);	
	КонецЦикла;  	
	
КонецПроцедуры	

&НаКлиенте
Процедура Выгрузка(Команда)   	
	
	ОчиститьСообщения();
	ТаблицаТоваров = Выгрузить();    	
	
КонецПроцедуры

