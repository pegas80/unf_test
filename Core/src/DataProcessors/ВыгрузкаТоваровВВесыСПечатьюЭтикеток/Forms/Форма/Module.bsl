&НаКлиенте
//გადატვირთვა
Функция Выгрузить() Экспорт   	
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("Пометка", Истина);
	
	ТаблицаТоваров = Объект.Товары.НайтиСтроки(ПараметрыОтбора);
	
	ТипОборудования = ОбменСВесамиСПечатьюЭтикетокСервер.ТипОборудования(Весы);
	ПараметрыПодключения = ОбменСВесамиСПечатьюЭтикетокСервер.ПараметрыОборудования(Весы);
	РеквизитыВесы = ОбменСВесамиСПечатьюЭтикетокСервер.ПолучитьРеквизитыОбъекта(Весы);
	
	Если РеквизитыВесы.ДрайверОборудования = ПредопределенноеЗначение("Справочник.ДрайверыОборудования.ДрайверDigiВесыСПечатьюЭтикеток")  Тогда
		
		Сообщить("გადატვირთვის დასაწყისი: " + ТекущаяДата());
		Если ТипВыгрузки = 0 Тогда 
			ВыгрузитьТоварыDIGI(ПараметрыПодключения[0], ТаблицаТоваров);
		Иначе 			
			ВыгрузитьТоварыDIGIНаСервере(ПараметрыПодключения[0], ТаблицаТоваров);
		КонецЕсли;
		Сообщить("გადატვირთვის დასასრული: " + ТекущаяДата());
		
	ИначеЕсли  РеквизитыВесы.ДрайверОборудования = ПредопределенноеЗначение("Справочник.ДрайверыОборудования.ДрайверDIGIВесы6000СПечатьюЭтикеток") Тогда 
			
		Сообщить("გადატვირთვის დასაწყისი: " + ТекущаяДата());
		
		ВыгрузитьТоварыDIGI_6000(ПараметрыПодключения[0], ТаблицаТоваров);
		
		Сообщить("გადატვირთვის დასასრული: " + ТекущаяДата());
		
	КонецЕсли;  

	Возврат ТаблицаТоваров;	
	
КонецФункции    

//გასუფთავება
&НаКлиенте
Процедура Очистить()
	
	ТипОборудования = ОбменСВесамиСПечатьюЭтикетокСервер.ТипОборудования(Весы);
	ПараметрыПодключения = ОбменСВесамиСПечатьюЭтикетокСервер.ПараметрыОборудования(Весы);
	РеквизитыВесы = ОбменСВесамиСПечатьюЭтикетокСервер.ПолучитьРеквизитыОбъекта(Весы);
	
	Если РеквизитыВесы.ДрайверОборудования = ПредопределенноеЗначение("Справочник.ДрайверыОборудования.ДрайверDigiВесыСПечатьюЭтикеток")  Тогда
		ОчиститьDIGI(ПараметрыПодключения[0]);
	КонецЕсли;   
	
КонецПроцедуры      

&НаКлиенте
Процедура Очистка(Команда)
	
	Очистить();

КонецПроцедуры

&НаКлиенте
Процедура Включить(Команда)
	
	впВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	
	Если ТипЗнч(впВыделенныеСтроки) = Тип("Массив") Тогда 
		Для Каждого ЭлементМассива Из впВыделенныеСтроки Цикл 
			Строчка =  Объект.Товары.НайтиПоИдентификатору(ЭлементМассива);
			Если Строчка <> Неопределено Тогда 
				Строчка.Пометка = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Выключить(Команда)
	
	впВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	
	Если ТипЗнч(впВыделенныеСтроки) = Тип("Массив") Тогда 
		Для Каждого ЭлементМассива Из впВыделенныеСтроки Цикл 
			Строчка =  Объект.Товары.НайтиПоИдентификатору(ЭлементМассива);
			Если Строчка <> Неопределено Тогда 
				Строчка.Пометка = Ложь;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры


