Процедура Тест_НеРезидент_ПриходнаяНакладная() Экспорт
	
	// Парам = Новый Структура("Наименование", "Тест");
	
	// Валюта
	Валюта = СоздатьСправочник("Валюты", Новый Структура("Наименование, Код", "USD", 999));
	
	// Рег сведений курсы валют
	СоздатьКурсыВалют(ТекущаяДата(), Валюта.Ссылка, 2, 1);	
	
	// ВидНалога
	ВидНалога_Нач = СоздатьСправочник("ВидыНалогов", Новый Структура("Наименование, СчетУчетаРегл, СчетУчетаКВозмещениюРегл", "დარიცხული საშემოსავლო გადასახადი",  Счет("3320/1"), Счет("3390")));
	ВидНалога_Удр = СоздатьСправочник("ВидыНалогов", Новый Структура("Наименование, СчетУчетаРегл, СчетУчетаКВозмещениюРегл", "გადასახდელი საშემოსავლო გადასახადი",  Счет("3320/2"), Счет("3390")));
	
	// ВидыНачисленийИУдержаний
	Парам = Новый Структура("Наименование, СтавкаНДФЛ, Тип, ВидНалога, ВидНалогаВыплат",   "საშემოსავლო გადასახადი (არარეზიდენტი)",  10, Перечисления.ТипыНачисленийИУдержаний.Налог, ВидНалога_Нач.Ссылка, ВидНалога_Удр.Ссылка);
	ВидыНачисленийИУдержаний = СоздатьСправочник("ВидыНачисленийИУдержаний", Парам);
	
	// Контрагент
	Парам = Новый Структура("Наименование, Поставщик, ЯвляетсяНеРезидентом, НалогообложениеНДС, СчетУчетаАвансовПокупателяРегл, СчетУчетаАвансовПоставщикуРегл, СчетУчетаРасчетовСПокупателемРегл, СчетУчетаРасчетовСПоставщикомРегл, ВестиРасчетыПоДоговорам", 
	"არარეზიდენტი", Истина, Истина, Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС, Счет("1410"), Счет("3110"), Счет("3110"), Счет("3110"), Истина);
	Контрагент = СоздатьСправочник("Контрагенты", Парам);
	
	// Контрагент
	Парам = Новый Структура("Наименование, Владелец, ВалютаРасчетов, УчитыватьНДФЛ, ВидУдержанияНДФЛ, ВидВыдачиНДФЛ, КатегорияПолучателейДоходов", 
	"არარეზიდენტის ხელშეკრულება", Контрагент.Ссылка, Валюта.Ссылка, Истина, ВидыНачисленийИУдержаний.Ссылка, 7, 26);
	Договор = СоздатьСправочник("ДоговорыКонтрагентов", Парам);
	
	// ЕдиницаИзмерения
	Парам = Новый Структура("Наименование", "ც");
	ЕдиницаИзмерения = СоздатьСправочник("КлассификаторЕдиницИзмерения", Парам);
	
	// Номенклатура
	Парам = Новый Структура("Наименование, ТипНоменклатуры, ЕдиницаИзмерения, СчетУчетаЗатратРегл", 
	"facebook პოსტის დაბუსტვა", Перечисления.ТипыНоменклатуры.Услуга, ЕдиницаИзмерения, Счет("7490"));
	Номенклатура = СоздатьСправочник("Номенклатура", Парам);
	
	// СтруктурныеЕдиницы
	Парам = Новый Структура("Наименование, ТипСтруктурнойЕдиницы", 
    "ძირითადი საწყობი (აზრი)", Перечисления.ТипыСтруктурныхЕдиниц.Склад);
	СтруктурныеЕдиницы = СоздатьСправочник("СтруктурныеЕдиницы", Парам);
	
	ВидыНалогов = СоздатьСправочник("ВидыНалогов", Новый Структура("Наименование, СчетУчетаРегл, СчетУчетаКВозмещениюРегл", "დღგ - რეზიდენტის მომსახურებიდან",  Счет("3330"), Счет("3340")));
	
	ПриходнаяНакладная = СоздатьПриходнаяНакладная(ТекущаяДата(), Контрагент.Ссылка, Договор.Ссылка, СтруктурныеЕдиницы.Ссылка, Валюта.Ссылка, Номенклатура.Ссылка, ЕдиницаИзмерения.Ссылка, ВидыНачисленийИУдержаний.Ссылка, ВидыНалогов.Ссылка);
	
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Хозрасчетный.Количество() = 3, "ბუღალტრულ გატარებაში 3 ჩანაწერი უნდა იყოს, გასარკვევია რატომ არ არის ასე!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Хозрасчетный[0].Сумма = 200, "ძირითადი თანხა უნდა უდრიდეს 200 ლარს!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Хозрасчетный[1].Сумма = 40, "დ.ღ.გ. ს თანხა უნდა უდრიდეს 40 ლარს!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Хозрасчетный[2].Сумма = 22.22, "საშემოსავლოს თანხა უნდა უდრიდეს 22.22 ლარს!");
	
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Закупки.Количество() = 1, "რეგისტრში 'შესყიდვები' ერთი ჩანაწერი უნდა იყოს!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Закупки[0].Сумма     = 200, "ძირითადი თანხა უნდა უდრიდეს 200 ლარს!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.Закупки[0].СуммаНДС  = 40, "დ.ღ.გ. ს თანხა უნდა უდრიდეს 40 ლარს!");
	
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.РасчетыПоНалогам.Количество() = 2, "რეგისტრში 'გადასახადები ანგარიშსწორებები გადასახადების მიხედვით' ერთი ჩანაწერი უნდა იყოს!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.РасчетыПоНалогам[0].Сумма     = 40, "დ.ღ.გ. ს თანხა უნდა უდრიდეს 40 ლარს!");
	Утверждения.ПроверитьИстину(ПриходнаяНакладная.Движения.РасчетыПоНалогам[1].Сумма  = 22.22, "საშემოსავლოს თანხა უნდა უდრიდეს 22.22 ლარს!");
	
	РасчетыПоНалогам = ПриходнаяНакладная.Движения.РасчетыПоНалогам.Выгрузить();
	НайденнаяСтрока = РасчетыПоНалогам.Найти(ВидыНалогов.Ссылка, "ВидНалога");
	//Если НайденнаяСтрока <> Неопределено Тогда
	//	НайденнаяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход;
	//КонецЕсли;	
	Утверждения.ПроверитьИстину(НайденнаяСтрока.ВидДвижения = ВидДвиженияНакопления.Приход, "დაგროვების რეგისტრი 'РасчетыПоНалогам' - ჩანაწერი '"+ВидыНалогов.Ссылка+"' რეკვიზიტი 'ВидДвижения' უნდა უდრიდეს 'ВидДвиженияНакопления.Приход' - ს. ეხლა ასე არ არის.");
	
	// შესამოწმებელია ასევე ცხრილურ ნაწილში არსებული ცვლილებები
	
