&НаСервере
Функция ПолучитьСпособУчетаСчетовФактур(Договор)

	Возврат ?(ЗначениеЗаполнено(Договор.СпособУчетаСчетовФактур),Договор.СпособУчетаСчетовФактур,Перечисления.СпособУчетаСчетовФактур.ВРазрезеМесяца);

КонецФункции

&НаКлиенте
Процедура ЗаполнитьДокументыДляОбработкиИзРезультатовРекурсивно(ДеревоРезультатов)

	Для каждого ТекущаяСтрока Из ДеревоРезультатов Цикл
		
		Если ЗначениеЗаполнено(ТекущаяСтрока.ДокументОснование) И ТекущаяСтрока.Выбран Тогда
			
			НоваяСтрокаДокументыДляОбработки = ДокументыДляОбработки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаДокументыДляОбработки,ТекущаяСтрока);
			НоваяСтрокаДокументыДляОбработки.ИдентификаторСтрокиДереваРезультатов = ТекущаяСтрока.ПолучитьИдентификатор();
			НоваяСтрокаДокументыДляОбработки.СпособУчетаСчетовФактур = ПолучитьСпособУчетаСчетовФактур(ТекущаяСтрока.Договор);
			
		Иначе
			
			НоваоеДеревоРезультатов = ТекущаяСтрока.ПолучитьЭлементы();
			ЗаполнитьДокументыДляОбработкиИзРезультатовРекурсивно(НоваоеДеревоРезультатов);
			
		КонецЕсли;
		
	КонецЦикла;

КонецПроцедуры 

&НаКлиенте
Процедура СформироватьСчетаФактуры(Команда)
	
	Состояние(НСтр("ka='დოკუმენტების დამუშავება';ru='Обработка документов';en='Document processing'"));
	
	ДокументыДляСчетовФактур.Очистить();
	
	ДокументыДляОбработки.Очистить();	
	ДеревоРезультатов = Результаты.ПолучитьЭлементы();
	ЗаполнитьДокументыДляОбработкиИзРезультатовРекурсивно(ДеревоРезультатов);
	
	КоличествоСтрокДляОбработк = ДокументыДляОбработки.Количество();
	
	ТекущийДоговор = НЕОПРЕДЕЛЕНО;
	
	И1=0;
	Для каждого ТекущаяСтрока Из ДокументыДляОбработки Цикл
		
		И1 = И1 + 1;
		Состояние(НСтр("ka='დოკუმენტების დამუშავება';ru='Обработка документов';en='Document processing'"), (И1 / КоличествоСтрокДляОбработк) * 100, ТекущаяСтрока.ДокументОснование);
		
		Если НЕ ТекущийДоговор = ТекущаяСтрока.Договор Тогда
			
			Если ДокументыДляСчетовФактур.Количество()>0 Тогда
			
				СформироватьСчетаФактурыНаСервере();
			
			КонецЕсли;
			
			ТекущийДоговор = ТекущаяСтрока.Договор;
			
		КонецЕсли;
		
		СтрокаДокументыДляСчетовФактур = ДокументыДляСчетовФактур.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДокументыДляСчетовФактур,ТекущаяСтрока);
		
		Если ТекущаяСтрока.СпособУчетаСчетовФактур = ПредопределенноеЗначение("Перечисление.СпособУчетаСчетовФактур.ПоДокументам") Тогда
			
			СформироватьСчетаФактурыНаСервере();
			
		КонецЕсли;
	
	КонецЦикла;
	// если последний договор был в разрезе месяца
	Если ДокументыДляСчетовФактур.Количество()>0 Тогда
		
		СформироватьСчетаФактурыНаСервере();
		
	КонецЕсли;
	
	ДокументыДляОбработки.Очистить();
	
	ПоказатьПредупреждение(,НСтр("ka='ანგარიშფაქტურების ფორმირება პროგრამაში დასრულდა';ru='Формирование счетов-фактур завершено';en='ანგარიშფაქტურების ფორმირება პროგრამაში დასრულდა'"));
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСчетаФактурыНаСервере()
	
	Если ДокументыДляСчетовФактур.Количество()>0 Тогда
	
		ТекущиеДанные = ДокументыДляСчетовФактур[0];
		
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.ДокументСчетФактураОтправленный) Тогда
			
			РезультатОбработки = СоздатьДокументСчетФактураОтправленныйГрузия();
			Если РезультатОбработки.Успешно Тогда
				
				НовыйСчетФактураОтправленныйГрузия = РезультатОбработки.ДокументСчетФактураОтправленный;
				
				Для каждого СтрокаДокументыДляСчетовФактур Из ДокументыДляСчетовФактур Цикл
				
					СтрокаРезультаты = Результаты.НайтиПоИдентификатору(СтрокаДокументыДляСчетовФактур.ИдентификаторСтрокиДереваРезультатов);
					Если НЕ СтрокаРезультаты = НЕОПРЕДЕЛЕНО Тогда
					
						СтрокаРезультаты.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
						СтрокаРезультаты.Создан = ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Ссылка);
						СтрокаРезультаты.Проведен = НовыйСчетФактураОтправленныйГрузия.Проведен;
						СтрокаРезультаты.Статус = НовыйСчетФактураОтправленныйГрузия.Статус;
					
					КонецЕсли;
				
				КонецЦикла;
				
			КонецЕсли;	
			
		КонецЕсли;
	
	КонецЕсли;
	
	ДокументыДляСчетовФактур.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьСчетаФактурыОтправитьRS(Команда)
	
	Состояние(НСтр("ka='დოკუმენტების დამუშავება';ru='Обработка документов';en='Document processing'"));
	
	ДокументыДляСчетовФактур.Очистить();
	
	ДокументыДляОбработки.Очистить();	
	ДеревоРезультатов = Результаты.ПолучитьЭлементы();
	ЗаполнитьДокументыДляОбработкиИзРезультатовРекурсивно(ДеревоРезультатов);
	
	КоличествоСтрокДляОбработк = ДокументыДляОбработки.Количество();
	
	ТекущийДоговор = НЕОПРЕДЕЛЕНО;
	
	И1=0;
	Для каждого ТекущаяСтрока Из ДокументыДляОбработки Цикл
		
		И1 = И1 + 1;
		Состояние(НСтр("ka='დოკუმენტების დამუშავება';ru='Обработка документов';en='Document processing'"), (И1 / КоличествоСтрокДляОбработк) * 100, ТекущаяСтрока.ДокументОснование);
		
		Если НЕ ТекущийДоговор = ТекущаяСтрока.Договор Тогда
			
			Если ДокументыДляСчетовФактур.Количество()>0 Тогда
			
				СформироватьСчетаФактурыОтправитьRSНаСервере();
			
			КонецЕсли;
			
			ТекущийДоговор = ТекущаяСтрока.Договор;
			
		КонецЕсли;
		
		СтрокаДокументыДляСчетовФактур = ДокументыДляСчетовФактур.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДокументыДляСчетовФактур,ТекущаяСтрока);
		
		Если ТекущаяСтрока.СпособУчетаСчетовФактур = ПредопределенноеЗначение("Перечисление.СпособУчетаСчетовФактур.ПоДокументам") Тогда
			
			СформироватьСчетаФактурыОтправитьRSНаСервере();
			
		КонецЕсли;
	
	КонецЦикла;
	// если последний договор был в разрезе месяца
	Если ДокументыДляСчетовФактур.Количество()>0 Тогда
		
		СформироватьСчетаФактурыОтправитьRSНаСервере();
		
	КонецЕсли;
	
	ДокументыДляОбработки.Очистить();
	
	ПоказатьПредупреждение(,НСтр("ka='RS.GE-ს სერვერთან მუშაობა დასრულებულია';ru='Работа с сервером RS.GE завершена';en='Working with server RS.GE completed'"));
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСчетаФактурыОтправитьRSНаСервере()
	
	Если ДокументыДляСчетовФактур.Количество()>0 Тогда
		
		МожноОтправлять = ЛОЖЬ;
	
		ТекущиеДанные = ДокументыДляСчетовФактур[0];
		
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.ДокументСчетФактураОтправленный) Тогда
			
			РезультатОбработки = СоздатьДокументСчетФактураОтправленныйГрузия();
			Если РезультатОбработки.Успешно Тогда
				
				НовыйСчетФактураОтправленныйГрузия = РезультатОбработки.ДокументСчетФактураОтправленный;
				
				Для каждого СтрокаДокументыДляСчетовФактур Из ДокументыДляСчетовФактур Цикл
				
					СтрокаРезультаты = Результаты.НайтиПоИдентификатору(СтрокаДокументыДляСчетовФактур.ИдентификаторСтрокиДереваРезультатов);
					Если НЕ СтрокаРезультаты = НЕОПРЕДЕЛЕНО Тогда
					
						СтрокаРезультаты.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
						СтрокаРезультаты.Создан = ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Ссылка);
						СтрокаРезультаты.Проведен = НовыйСчетФактураОтправленныйГрузия.Проведен;
						СтрокаРезультаты.Статус = НовыйСчетФактураОтправленныйГрузия.Статус;
						
					КонецЕсли;
					
				КонецЦикла;
				
				ТекущиеДанные = ДокументыДляСчетовФактур[0];
				
				МожноОтправлять = ИСТИНА;
				
			КонецЕсли;	
			
		ИначеЕсли НЕ ТекущиеДанные.ДокументСчетФактураОтправленный.Проведен Тогда
			
			НачатьТранзакцию();
			
			Попытка
				
				Для каждого СтрокаДокументыДляСчетовФактур Из ДокументыДляСчетовФактур Цикл
				
					СтрокаРезультаты = Результаты.НайтиПоИдентификатору(СтрокаДокументыДляСчетовФактур.ИдентификаторСтрокиДереваРезультатов);
					Если НЕ СтрокаРезультаты = НЕОПРЕДЕЛЕНО Тогда
					
						СтрокаРезультаты.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
						СтрокаРезультаты.Создан = ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Ссылка);
						СтрокаРезультаты.Проведен = НовыйСчетФактураОтправленныйГрузия.Проведен;
						СтрокаРезультаты.Статус = НовыйСчетФактураОтправленныйГрузия.Статус;
						
					КонецЕсли;
					
				КонецЦикла;
				
				МожноОтправлять = ИСТИНА;
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();
				
				ТекстСообщения = НСтр("ka='Не удалось провести Счет-фактура (отправленный) по документу ""%1""';ru='Не удалось провести Счет-фактура (отправленный) по документу ""%1""';en='Не удалось провести Счет-фактура (отправленный) по документу ""%1""'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,ТекущиеДанные.ДокументСчетФактураОтправленный);
				
				ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, ТекущиеДанные.ДокументСчетФактураОтправленный.Метаданные(), , ОписаниеОшибки());
				
				ДлительнаяОтправкаКлиентСервер.ВывестиОшибку(ТекстСообщения);
				
			КонецПопытки;
			
		Иначе
			
			МожноОтправлять = ИСТИНА;
			
		КонецЕсли;
		
		Если МожноОтправлять Тогда
			
			РезультатОтправки = ОтправитьДокументСчетФактураОтправленныйГрузияНаRS(ТекущиеДанные);
			Если РезультатОтправки.Успешно Тогда
				
				Для каждого СтрокаДокументыДляСчетовФактур Из ДокументыДляСчетовФактур Цикл
				
					СтрокаРезультаты = Результаты.НайтиПоИдентификатору(СтрокаДокументыДляСчетовФактур.ИдентификаторСтрокиДереваРезультатов);
					Если НЕ СтрокаРезультаты = НЕОПРЕДЕЛЕНО Тогда
					
						СтрокаРезультаты.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
						СтрокаРезультаты.Создан = ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Ссылка);
						СтрокаРезультаты.Проведен = НовыйСчетФактураОтправленныйГрузия.Проведен;
						СтрокаРезультаты.Статус = НовыйСчетФактураОтправленныйГрузия.Статус;
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
	
	КонецЕсли;
	
	ДокументыДляСчетовФактур.Очистить();
	
КонецПроцедуры

Функция СоздатьДокументСчетФактураОтправленныйГрузия()
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Структура("ДокументСчетФактураОтправленный,Успешно", НЕОПРЕДЕЛЕНО, ЛОЖЬ);
	
	Если ДокументыДляСчетовФактур.Количество()>0 Тогда
		
		НачатьТранзакцию(); 
		
		ТекущиеДанные = ДокументыДляСчетовФактур[0];
		
		ДокументОснование = ТекущиеДанные.ДокументОснование;
		
		НовыйСчетФактураОтправленныйГрузия = Документы.СчетФактураОтправленныйГрузия.СоздатьДокумент();
		
		ЗаполнениеОбъектовУНФ.ЗаполнитьДокумент(НовыйСчетФактураОтправленныйГрузия, ДокументОснование);
		
		ЗаполнитьЗначенияСвойств(НовыйСчетФактураОтправленныйГрузия,ТекущиеДанные);
		
		НовыйСчетФактураОтправленныйГрузия.Организация = ДокументОснование.Организация;
		Если НЕ ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Организация) Тогда
			
			НовыйСчетФактураОтправленныйГрузия.Организация = Объект.Организация;
			
		КонецЕсли;
		
		НовыйСчетФактураОтправленныйГрузия.ДатаВходящегоДокумента = НачалоМесяца(Объект.Период);
		
		ДатаСведений = ?(ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Дата), НовыйСчетФактураОтправленныйГрузия.Дата, ТекущаяДата());
		ЗначенияУчетнойПолитики = РегистрыСведений.УчетнаяПолитикаРегл.ЗначенияПолейУчетнойПолитики(
		"СчетФактураВыданныйВидНалогаПриСинхронизации,СчетФактураВыданныйСчетУчетаПриСинхронизации,ЗаполнятьСчетаВСчетахФактуры",
		НовыйСчетФактураОтправленныйГрузия.Организация,	ДатаСведений);
		
		НовыйСчетФактураОтправленныйГрузия.ВидНалога = ЗначенияУчетнойПолитики.СчетФактураВыданныйВидНалогаПриСинхронизации;
		
		Если ЗначенияУчетнойПолитики.ЗаполнятьСчетаВСчетахФактуры Тогда
			НовыйСчетФактураОтправленныйГрузия.СчетУчетаРегл = ЗначенияУчетнойПолитики.СчетФактураВыданныйСчетУчетаПриСинхронизации;
		КонецЕсли;
		
		// Заполняем табличные части
		НовыйСчетФактураОтправленныйГрузия.ДокументыОснования.Очистить();
		НовыйСчетФактураОтправленныйГрузия.Запасы.Очистить();
		
		МассивДокументов = Новый Массив();
		
		// ТЧ ДокументыОснования
		Для каждого СтрокаДокументыДляСчетовФактур Из ДокументыДляСчетовФактур Цикл
		
			СтрокаДокументыОснования = НовыйСчетФактураОтправленныйГрузия.ДокументыОснования.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДокументыОснования,СтрокаДокументыДляСчетовФактур);
			
			Если НЕ ТипЗнч(СтрокаДокументыОснования.ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
				МассивДокументов.Добавить(СтрокаДокументыОснования.ДокументОснование);
			КонецЕсли;
		
		КонецЦикла;
		
		// ТЧ Запасы
		НовыйСчетФактураОтправленныйГрузия.ЗаполнитьЗапасы(МассивДокументов);
		
		Попытка
			
			НовыйСчетФактураОтправленныйГрузия.Записать(РежимЗаписиДокумента.Проведение);
			
			РЕЗ.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка; 
			РЕЗ.Успешно = ИСТИНА;
			
			Для каждого СтрокаДокументыДляСчетовФактур Из ДокументыДляСчетовФактур Цикл
			
				СтрокаДокументыДляСчетовФактур.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
			
			КонецЦикла;
			
			ЗафиксироватьТранзакцию();
			
		Исключение
			
			ОтменитьТранзакцию();
			
			ТекстСообщения = НСтр("ka='Не удалось создать Счет-фактура (отправленный) по документу ""%1""';ru='Не удалось создать Счет-фактура (отправленный) по документу ""%1""';en='Не удалось создать Счет-фактура (отправленный) по документу ""%1""'");
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,ТекущиеДанные.Документ);
			
			ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, НовыйСчетФактураОтправленныйГрузия.Метаданные(), , ОписаниеОшибки());
			
			ДлительнаяОтправкаКлиентСервер.ВывестиОшибку(ТекстСообщения);
			
		КонецПопытки; 
		
	КонецЕсли;
	
	Возврат РЕЗ;
КонецФункции
