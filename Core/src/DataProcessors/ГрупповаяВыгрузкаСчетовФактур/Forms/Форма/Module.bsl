&НаКлиенте
Процедура ОповещениеВыбораПериода(Период, ДополнительныеПараметры) Экспорт

    ВыборПериодаМесяц = ДополнительныеПараметры.ДиалогВыборПериода;

    Если ЗначениеЗаполнено(Период) Тогда
        ВыбранныйПериод = ВыборПериодаМесяц.Период;
        Объект.Период = КонецМесяца(ВыбранныйПериод.ДатаОкончания);
	КонецЕсли;
	
	ПоказатьПериодНаФорме();

КонецПроцедуры

&НаКлиенте
Процедура ВыбратьВсеРезультатыОтправленные(Команда)
	
	Для каждого ТекущаяСтрока Из Объект.РезультатыАвансы Цикл
	
		ТекущаяСтрока.Выбран = ИСТИНА;
	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ИсключитьВсеРезультатыОтправленные(Команда)
	
	Для каждого ТекущаяСтрока Из Объект.РезультатыАвансы Цикл
		
		ТекущаяСтрока.Выбран = ЛОЖЬ;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРезультатыАвансОтправленные(Команда)
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		
		Объект.РезультатыАвансы.Очистить();
	
		ЗаполнитьРезультатыАвансОтправленныеНаСервере();
	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРезультатыАвансОтправленныеНаСервере()
	
	ТаблицаАвансов = ПолучитьОстаткиПоАвансам();
	
	Объект.РезультатыАвансы.Загрузить(ТаблицаАвансов);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОстаткиПоАвансам()

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыСПокупателямиОбороты.Документ КАК Документ,
	|	РасчетыСПокупателямиОбороты.Контрагент КАК Контрагент,
	|	РасчетыСПокупателямиОбороты.Договор КАК Договор,
	|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход - РасчетыСПокупателямиОбороты.СуммаРасход) КАК Сумма
	|ПОМЕСТИТЬ ОстаткиАвансов
	|ИЗ
	|	РегистрНакопления.РасчетыСПокупателями.Обороты(
	|			&НачалоМесяца,
	|			&КонецМесяца,
	|			Авто,
	|			ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)
	|				И Организация = &Организация) КАК РасчетыСПокупателямиОбороты
	|ГДЕ
	|	НЕ(РасчетыСПокупателямиОбороты.СуммаПриход = 0
	|				И РасчетыСПокупателямиОбороты.СуммаРасход = 0)
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСПокупателямиОбороты.Контрагент,
	|	РасчетыСПокупателямиОбороты.Договор,
	|	РасчетыСПокупателямиОбороты.Документ
	|
	|ИМЕЮЩИЕ
	|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход - РасчетыСПокупателямиОбороты.СуммаРасход) < 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТЧ_ДокументыПлатежа.Документ КАК Документ,
	|	ТЧ_ДокументыПлатежа.Ссылка.Контрагент КАК Контрагент,
	|	ТЧ_ДокументыПлатежа.Договор КАК Договор,
	|	СУММА(ТЧ_ДокументыПлатежа.Сумма) КАК Сумма
	|ПОМЕСТИТЬ ТЧ_ДокументыПлатежа
	|ИЗ
	|	Документ.СчетФактураОтправленныйГрузия.ДокументыПлатежа КАК ТЧ_ДокументыПлатежа
	|ГДЕ
	|	ТЧ_ДокументыПлатежа.Ссылка.Проведен
	//|	И ТЧ_ДокументыПлатежа.Ссылка.ДатаВходящегоДокумента = &НачалоМесяца
	|	И ТЧ_ДокументыПлатежа.Документ В
	|			(ВЫБРАТЬ
	|				ОстаткиАвансов.Документ
	|			ИЗ
	|				ОстаткиАвансов КАК ОстаткиАвансов)
	|
	|СГРУППИРОВАТЬ ПО
	|	ТЧ_ДокументыПлатежа.Документ,
	|	ТЧ_ДокументыПлатежа.Ссылка.Контрагент,
	|	ТЧ_ДокументыПлатежа.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИСТИНА КАК Выбран,
	|	ОстаткиАвансов.Документ КАК Документ,
	|	ОстаткиАвансов.Контрагент КАК Контрагент,
	|	ОстаткиАвансов.Договор КАК Договор,
	|	-(ОстаткиАвансов.Сумма + ЕСТЬNULL(ТЧ_ДокументыПлатежа.Сумма, 0)) КАК Сумма,
	|	-(ВЫРАЗИТЬ((ОстаткиАвансов.Сумма + ЕСТЬNULL(ТЧ_ДокументыПлатежа.Сумма, 0)) * 18 / 118 КАК ЧИСЛО(15, 2))) КАК СуммаНДС
	|ИЗ
	|	ОстаткиАвансов КАК ОстаткиАвансов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ТЧ_ДокументыПлатежа КАК ТЧ_ДокументыПлатежа
	|		ПО ОстаткиАвансов.Документ = ТЧ_ДокументыПлатежа.Документ
	|			И ОстаткиАвансов.Контрагент = ТЧ_ДокументыПлатежа.Контрагент
	|			И ОстаткиАвансов.Договор = ТЧ_ДокументыПлатежа.Договор
	|ГДЕ
	|	ОстаткиАвансов.Сумма + ЕСТЬNULL(ТЧ_ДокументыПлатежа.Сумма, 0) < 0";
	
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(Объект.Период));
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(Объект.Период));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции // ()

&НаСервере
Функция ПолучитьАдресТаблицыОстатков()
	
	ТаблицаАвансов = ПолучитьОстаткиПоАвансам();
	Возврат ПоместитьВоВременноеХранилище(ТаблицаАвансов);
	
КонецФункции

&НаКлиенте
Процедура ПодборРезультатыОтправленные(Команда)
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		
		АдресТаблицы = ПолучитьАдресТаблицыОстатков();
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("АдресТаблицы", АдресТаблицы);
		
		ПодборРезультатыОтправленныеЗавершение = Новый ОписаниеОповещения("ПодборРезультатыОтправленныеЗавершение", ЭтотОбъект);
		
		ОткрытьФорму("Документ.СчетФактураОтправленныйГрузия.Форма.ФормаОстаткиАвансов",ПараметрыФормы,Элементы.ПодборРезультатыОтправленные,ЭтаФорма.УникальныйИдентификатор,,,ПодборРезультатыОтправленныеЗавершение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодборРезультатыОтправленныеЗавершение(Результат, Параметры) Экспорт
	ПЕРЕМ АдресТаблицыАвансов;
	
	Если ТипЗНЧ(Результат)=Тип("Структура") Тогда
	
		Если Результат.Свойство("АдресТаблицы",АдресТаблицыАвансов) Тогда
		
			Если ЭтоАдресВременногоХранилища(АдресТаблицыАвансов) Тогда
			
				ПодборРезультатыОтправленныеЗавершениеНаСервере(АдресТаблицыАвансов);
			
			КонецЕсли;
		
		КонецЕсли;
	
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ПодборРезультатыОтправленныеЗавершениеНаСервере(АдресТаблицыАвансов)

	ТаблицаАвансов = ПолучитьИзВременногоХранилища(АдресТаблицыАвансов);
	Если ТипЗНЧ(ТаблицаАвансов)=Тип("ТаблицаЗначений") Тогда
		
		Для каждого СтрокаТаблицаАвансов Из ТаблицаАвансов Цикл
		
			СтруктураПоиска = Новый Структура("Документ", СтрокаТаблицаАвансов.Документ);
			НайденныеСтроки = Объект.РезультатыАвансы.НайтиСтроки(СтруктураПоиска);
			Если НайденныеСтроки.Количество()=0 Тогда
				
				ТекущаяСтрока = Объект.РезультатыАвансы.Добавить();
				
			Иначе
				
				ТекущаяСтрока = НайденныеСтроки[0];
			
			КонецЕсли;
			
			ЗаполнитьЗначениясвойств(ТекущаяСтрока,СтрокаТаблицаАвансов);
			
			ТекущаяСтрока.Контрагент = ТекущаяСтрока.Договор.Владелец;
			ТекущаяСтрока.Выбран = ИСТИНА;
			ТекущаяСтрока.ДокументСчетФактураОтправленный = НЕОПРЕДЕЛЕНО;
			ТекущаяСтрока.Создан = ЛОЖЬ;
			ТекущаяСтрока.Проведен = ЛОЖЬ;
			ТекущаяСтрока.Статус = НЕОПРЕДЕЛЕНО;
		
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСозданныеСчетаФактурыАвансов(Команда)
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		
		Объект.РезультатыАвансы.Очистить();
		
		ЗаполнитьСозданныеСчетаФактурыАвансовНаСервере();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСозданныеСчетаФактурыАвансовНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЛОЖЬ КАК Выбран,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Документ КАК Документ,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Контрагент КАК Контрагент,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Договор КАК Договор,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Сумма КАК Сумма,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.СуммаНДС КАК СуммаНДС,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка КАК ДокументСчетФактураОтправленный,
	|	ИСТИНА КАК Создан,
	|	ИСТИНА КАК Проведен,
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Статус КАК Статус	
	|ИЗ
	|	Документ.СчетФактураОтправленныйГрузия.ДокументыПлатежа КАК СчетФактураОтправленныйГрузияДокументыПлатежа
	|ГДЕ
	|	СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Дата МЕЖДУ &НачалоМесяца И &КонецМесяца
	|	И СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Проведен
	|	И СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Аванс
	|	И СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Организация = &Организация
	|	И (
	|		СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.ПустаяСсылка)
	|		ИЛИ
	|		НЕ (
	|			СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Отмененная) 
	//|			ИЛИ 
	//|			СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Отказано)
	//|			ИЛИ 
	//|			СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Удаленный)
	|			)
	|	)
	|//УсловиеПоКонтрагенту
	|";
	
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(Объект.Период));
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(Объект.Период));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
	
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УсловиеПоКонтрагенту", "		И СчетФактураОтправленныйГрузияДокументыПлатежа.Ссылка.Контрагент = &Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УсловиеПоКонтрагенту", "");
	
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Объект.РезультатыАвансы.Загрузить(РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьАвансы(Команда)
	
	Объект.РезультатыАвансы.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатыОтправленныеДокументПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.РезультатыОтправленные.ТекущиеДанные;
	
	РезультатыОтправленныеДокументПриИзмененииНаСервере(ТекущиеДанные.ПолучитьИдентификатор());
	
КонецПроцедуры

&НаСервере
Процедура РезультатыОтправленныеДокументПриИзмененииНаСервере(ИдентификаторСтроки)
	
	ТекущиеДанные = Объект.РезультатыАвансы.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	Если НЕ(ТекущиеДанные = НЕОПРЕДЕЛЕНО) И ЗначениеЗаполнено(ТекущиеДанные.Документ) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасчетыСПокупателямиОбороты.Документ КАК Документ,
		|	РасчетыСПокупателямиОбороты.Контрагент КАК Контрагент,
		|	РасчетыСПокупателямиОбороты.Договор КАК Договор,
		|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход - РасчетыСПокупателямиОбороты.СуммаРасход) КАК Сумма
		|ПОМЕСТИТЬ ОстаткиАвансов
		|ИЗ
		|	РегистрНакопления.РасчетыСПокупателями.Обороты(
		|			&НачалоМесяца,
		|			&КонецМесяца,
		|			Авто,
		|			ТипРасчетов = ЗНАЧЕНИЕ(Перечисление.ТипыРасчетов.Аванс)
		|				И Документ = &Документ) КАК РасчетыСПокупателямиОбороты
		|ГДЕ
		|	НЕ(РасчетыСПокупателямиОбороты.СуммаПриход = 0
		|				И РасчетыСПокупателямиОбороты.СуммаРасход = 0)
		|
		|СГРУППИРОВАТЬ ПО
		|	РасчетыСПокупателямиОбороты.Контрагент,
		|	РасчетыСПокупателямиОбороты.Договор,
		|	РасчетыСПокупателямиОбороты.Документ
		|
		|ИМЕЮЩИЕ
		|	СУММА(РасчетыСПокупателямиОбороты.СуммаПриход - РасчетыСПокупателямиОбороты.СуммаРасход) < 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧ_ДокументыПлатежа.Документ КАК Документ,
		|	ТЧ_ДокументыПлатежа.Ссылка.Контрагент КАК Контрагент,
		|	ТЧ_ДокументыПлатежа.Договор КАК Договор,
		|	СУММА(ТЧ_ДокументыПлатежа.Сумма) КАК Сумма
		|ПОМЕСТИТЬ ТЧ_ДокументыПлатежа
		|ИЗ
		|	Документ.СчетФактураПолученныйГрузия.ДокументыПлатежа КАК ТЧ_ДокументыПлатежа
		|ГДЕ
		|	ТЧ_ДокументыПлатежа.Ссылка.Проведен
		//|	И ТЧ_ДокументыПлатежа.Ссылка.ДатаВходящегоДокумента = &НачалоМесяца
		//|	И ТЧ_ДокументыПлатежа.Ссылка.Контрагент = &Контрагент
		|	И ТЧ_ДокументыПлатежа.Документ В
		|			(ВЫБРАТЬ
		|				ОстаткиАвансов.Документ
		|			ИЗ
		|				ОстаткиАвансов КАК ОстаткиАвансов)
		|
		|СГРУППИРОВАТЬ ПО
		|	ТЧ_ДокументыПлатежа.Документ,
		|	ТЧ_ДокументыПлатежа.Ссылка.Контрагент,
		|	ТЧ_ДокументыПлатежа.Договор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОстаткиАвансов.Документ КАК Документ,
		|	ОстаткиАвансов.Контрагент КАК Контрагент,
		|	ОстаткиАвансов.Договор КАК Договор,
		|	-(ОстаткиАвансов.Сумма + ЕСТЬNULL(ТЧ_ДокументыПлатежа.Сумма, 0)) КАК Сумма,
		|	-(ВЫРАЗИТЬ((ОстаткиАвансов.Сумма + ЕСТЬNULL(ТЧ_ДокументыПлатежа.Сумма, 0)) * 18 / 118 КАК ЧИСЛО(15, 2))) КАК СуммаНДС
		|ИЗ
		|	ОстаткиАвансов КАК ОстаткиАвансов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТЧ_ДокументыПлатежа КАК ТЧ_ДокументыПлатежа
		|		ПО ОстаткиАвансов.Документ = ТЧ_ДокументыПлатежа.Документ
		|			И ОстаткиАвансов.Контрагент = ТЧ_ДокументыПлатежа.Контрагент
		|			И ОстаткиАвансов.Договор = ТЧ_ДокументыПлатежа.Договор
		|ГДЕ
		|	ОстаткиАвансов.Сумма + ЕСТЬNULL(ТЧ_ДокументыПлатежа.Сумма, 0) < 0";
		
		Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(Объект.Период));
		Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(Объект.Период));
		Запрос.УстановитьПараметр("Документ", ТекущиеДанные.Документ);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ТаблицаАвансов = РезультатЗапроса.Выгрузить();
		ТаблицаАвансов.Свернуть("Документ,Контрагент,Договор","Сумма,СуммаНДС");
		
		Если ТаблицаАвансов.Количество()>0 Тогда
		
			ТекущиеДанные.Контрагент = ТаблицаАвансов[0].Контрагент;
			ТекущиеДанные.Договор = ТаблицаАвансов[0].Договор;
			ТекущиеДанные.Сумма = ТаблицаАвансов.Итог("Сумма");
			ТекущиеДанные.СуммаНДС = ТаблицаАвансов.Итог("СуммаНДС");
		
		КонецЕсли;		 
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатыОтправленныеСуммаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.РезультатыОтправленные.ТекущиеДанные;
	ТекущиеДанные.СуммаНДС = ТекущиеДанные.Сумма * 18 / 118;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьСчетаФактурыАвансов(Команда)
	
	СтруктураОтбораДляОбработки = Новый Структура("Выбран", ИСТИНА);
	МассивСтрокДляОбработки = Объект.РезультатыАвансы.НайтиСтроки(СтруктураОтбораДляОбработки);
	
	КоличествоСтрокДляОбработк = МассивСтрокДляОбработки.Количество();
	
	И1=0;
	Для каждого СтрокаТабличнойЧасти Из МассивСтрокДляОбработки Цикл
		
		И1 = И1 + 1;
		Состояние(НСтр("ka='დოკუმენტების დამუშავება';ru='Обработка документов';en='Document processing'"), (И1 / КоличествоСтрокДляОбработк) * 100, СтрокаТабличнойЧасти.Документ);		
		
		СформироватьСчетаФактурыАвансовНаСервере(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	
	КонецЦикла;
	
	ПоказатьПредупреждение(,НСтр("ka='ავანსის ანგარიშფაქტურების ფორმირება პროგრამაში დასრულდა';ru='Формирование счетов-фактур авансов завершено';en='ავანსის ანგარიშფაქტურების ფორმირება პროგრამაში დასრულდა'"));
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСчетаФактурыАвансовНаСервере(ИдентификаторСтроки)
		
	ТекущиеДанные = Объект.РезультатыАвансы.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	Если НЕ ТекущиеДанные = НЕОПРЕДЕЛЕНО Тогда
		
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.ДокументСчетФактураОтправленный) Тогда
			
			РезультатОбработки = СоздатьДокументСчетФактураОтправленныйГрузияАванс(ТекущиеДанные);
			Если РезультатОбработки.Успешно Тогда
				
				НовыйСчетФактураОтправленныйГрузия = РезультатОбработки.ДокументСчетФактураОтправленный;
				
				ТекущиеДанные.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
				ТекущиеДанные.Создан = ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Ссылка);
				ТекущиеДанные.Проведен = НовыйСчетФактураОтправленныйГрузия.Проведен;
				ТекущиеДанные.Статус = НовыйСчетФактураОтправленныйГрузия.Статус;
				
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СформироватьСчетаФактурыАвансовОтправитьRS(Команда)
	
	СтруктураОтбораДляОбработки = Новый Структура("Выбран", ИСТИНА);
	МассивСтрокДляОбработки = Объект.РезультатыАвансы.НайтиСтроки(СтруктураОтбораДляОбработки);
	
	КоличествоСтрокДляОбработк = МассивСтрокДляОбработки.Количество();
	
	И1=0;
	Для каждого СтрокаТабличнойЧасти Из МассивСтрокДляОбработки Цикл
		
		И1 = И1 + 1;
		Состояние(НСтр("ka='დოკუმენტების დამუშავება';ru='Обработка документов';en='Document processing'"), (И1 / КоличествоСтрокДляОбработк) * 100, СтрокаТабличнойЧасти.Документ);		
		
		СформироватьСчетаФактурыАвансовОтправитьRSНаСервере(СтрокаТабличнойЧасти.ПолучитьИдентификатор());
	
	КонецЦикла;
	
	ПоказатьПредупреждение(,НСтр("ka='RS.GE-ს სერვერთან მუშაობა დასრულებულია';ru='Работа с сервером RS.GE завершена';en='Working with server RS.GE completed'"));
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСчетаФактурыАвансовОтправитьRSНаСервере(ИдентификаторСтроки)
		
	ТекущиеДанные = Объект.РезультатыАвансы.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	Если НЕ ТекущиеДанные = НЕОПРЕДЕЛЕНО Тогда
		
		МожноОтправлять = ЛОЖЬ;
		
		Если НЕ ЗначениеЗаполнено(ТекущиеДанные.ДокументСчетФактураОтправленный) Тогда
			
			РезультатОбработки = СоздатьДокументСчетФактураОтправленныйГрузияАванс(ТекущиеДанные);
			Если РезультатОбработки.Успешно Тогда
				
				НовыйСчетФактураОтправленныйГрузия = РезультатОбработки.ДокументСчетФактураОтправленный;
				
				ТекущиеДанные.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка;
				ТекущиеДанные.Создан = ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Ссылка);
				ТекущиеДанные.Проведен = НовыйСчетФактураОтправленныйГрузия.Проведен;
				ТекущиеДанные.Статус = НовыйСчетФактураОтправленныйГрузия.Статус;
				
				МожноОтправлять = ИСТИНА;
				
			КонецЕсли;
			
		ИначеЕсли НЕ ТекущиеДанные.ДокументСчетФактураОтправленный.Проведен Тогда
			
			НачатьТранзакцию();
			
			Попытка
				
				ТекущиеДанные.ДокументСчетФактураОтправленный.Записать(РежимЗаписиДокумента.Проведение);
				
				ТекущиеДанные.Создан = ЗначениеЗаполнено(ТекущиеДанные.ДокументСчетФактураОтправленный.Ссылка);
				ТекущиеДанные.Проведен = ТекущиеДанные.ДокументСчетФактураОтправленный.Проведен;
				ТекущиеДанные.Статус = ТекущиеДанные.ДокументСчетФактураОтправленный.Статус;
				
				МожноОтправлять = ИСТИНА;
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();
				
				ТекстСообщения = НСтр("ka='Не удалось провести Счет-фактура (отправленный) по документу ""%1""';ru='Не удалось провести Счет-фактура (отправленный) по документу ""%1""';en='Не удалось провести Счет-фактура (отправленный) по документу ""%1""'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,ТекущиеДанные.ДокументСчетФактураОтправленный);
				
				ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, ТекущиеДанные.ДокументСчетФактураОтправленный.Метаданные(), , ОписаниеОшибки());
				
				ДлительнаяОтправкаКлиентСервер.ВывестиОшибку(ТекстСообщения);
				
			КонецПопытки;
			
		Иначе
			
			МожноОтправлять = ИСТИНА;
			
		КонецЕсли;
		
		Если МожноОтправлять Тогда
			
			РезультатОтправки = ОтправитьДокументСчетФактураОтправленныйГрузияНаRS(ТекущиеДанные);
			Если РезультатОтправки.Успешно Тогда
				
				ТекущиеДанные.Статус = ТекущиеДанные.ДокументСчетФактураОтправленный.Статус;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьДокументСчетФактураОтправленныйГрузияАванс(ТекущиеДанные)
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Структура("ДокументСчетФактураОтправленный,Успешно", НЕОПРЕДЕЛЕНО, ЛОЖЬ);
	
	НачатьТранзакцию();
	
	ДокументАванса = ТекущиеДанные.Документ;
	
	НовыйСчетФактураОтправленныйГрузия = Документы.СчетФактураОтправленныйГрузия.СоздатьДокумент();
	
	НовыйСчетФактураОтправленныйГрузия.Заполнить(ДокументАванса);
	
	НовыйСчетФактураОтправленныйГрузия.Организация = ДокументАванса.Организация;
	Если НЕ ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Организация) Тогда
		
		НовыйСчетФактураОтправленныйГрузия.Организация = Объект.Организация;
		
	КонецЕсли;
	
	ДатаСведений = ?(ЗначениеЗаполнено(НовыйСчетФактураОтправленныйГрузия.Дата), НовыйСчетФактураОтправленныйГрузия.Дата, ТекущаяДата());
	ЗначенияУчетнойПолитики = РегистрыСведений.УчетнаяПолитикаРегл.ЗначенияПолейУчетнойПолитики(
	"СчетФактураВыданныйВидНалогаПриСинхронизации,СчетФактураВыданныйСчетУчетаПриСинхронизации,ЗаполнятьСчетаВСчетахФактуры",
	НовыйСчетФактураОтправленныйГрузия.Организация,	ДатаСведений);
	
	НовыйСчетФактураОтправленныйГрузия.ВидНалога = ЗначенияУчетнойПолитики.СчетФактураВыданныйВидНалогаПриСинхронизации;
	
	Если ЗначенияУчетнойПолитики.ЗаполнятьСчетаВСчетахФактуры Тогда
		НовыйСчетФактураОтправленныйГрузия.СчетУчетаРегл = ЗначенияУчетнойПолитики.СчетФактураВыданныйСчетУчетаПриСинхронизации;
	КонецЕсли;
	
	НовыйСчетФактураОтправленныйГрузия.Договор = ТекущиеДанные.Договор;
	
	СтруктураПоискаДокумента = Новый Структура("Документ", ДокументАванса);
	НайденныеСтроки = НовыйСчетФактураОтправленныйГрузия.ДокументыПлатежа.НайтиСтроки(СтруктураПоискаДокумента);
	Если НайденныеСтроки.Количество()>0 Тогда
		
		СтрокаТабличнойЧасти = НайденныеСтроки[0];
		ЗаполнитьЗначенияСвойств(СтрокаТабличнойЧасти,ТекущиеДанные);
		
	КонецЕсли;
	
	Попытка
		
		НовыйСчетФактураОтправленныйГрузия.Записать(РежимЗаписиДокумента.Проведение);
		
		РЕЗ.ДокументСчетФактураОтправленный = НовыйСчетФактураОтправленныйГрузия.Ссылка; 
		РЕЗ.Успешно = ИСТИНА;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ТекстСообщения = НСтр("ka='Не удалось создать Счет-фактура (отправленный) по документу ""%1""';ru='Не удалось создать Счет-фактура (отправленный) по документу ""%1""';en='Не удалось создать Счет-фактура (отправленный) по документу ""%1""'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения,ТекущиеДанные.Документ);
		
		ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, НовыйСчетФактураОтправленныйГрузия.Метаданные(), , ОписаниеОшибки());
		
		ДлительнаяОтправкаКлиентСервер.ВывестиОшибку(ТекстСообщения);
		
	КонецПопытки;
	
	Возврат РЕЗ;
КонецФункции // ()

&НаСервере
Функция ОтправитьДокументСчетФактураОтправленныйГрузияНаRS(ТекущиеДанные)
	ПЕРЕМ РЕЗ;
	
	РЕЗ = Новый Структура("ДокументСчетФактураОтправленный,Успешно", НЕОПРЕДЕЛЕНО, ЛОЖЬ);
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ДокументСчетФактураОтправленный) И ТекущиеДанные.ДокументСчетФактураОтправленный.Проведен Тогда
		
		// Команда Сохранить
		Док = ТекущиеДанные.ДокументСчетФактураОтправленный;
		
		ЗначенияРеквизитов = ПроверкаДляКорректировачнойСчетФактурыСохранение(Док);
		Если ЗначенияРеквизитов = Неопределено Тогда
			Возврат РЕЗ;
		КонецЕсли;
		
		ТекСтатус 	= ЗначенияРеквизитов.Статус;
		Аванс 		= ЗначенияРеквизитов.Аванс;
		Если ТекСтатус = ПредопределенноеЗначение("Перечисление.СтатусыСФ.Отправленная") Тогда
			Возврат РЕЗ;
		КонецЕсли;
		
		ИдентификаторСФ = ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтправитьШапкуДокументаНаПортале(Док);
		Если ИдентификаторСФ = Неопределено Тогда 
			Возврат РЕЗ;
		КонецЕсли;
		
		Если ЗначенияРеквизитов.Корректировочная Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбновитьСтатусСФ(ЗначенияРеквизитов.ОснованиеКорректировки);
		КонецЕсли;
		
		Если Аванс Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтправитьСписокДокументовАвансаНаПортале(Док, ИдентификаторСФ);
		Иначе
			Если НЕ ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтправитьСписокНакладныхНаПортале(Док, ИдентификаторСФ) = Неопределено Тогда
				ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОтправитьСписокНоменклатуриНаПортале(Док, ИдентификаторСФ);	
			КонецЕсли;
		КонецЕсли;
		
	    ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбновитьИдентификаторИСтатусДокументаСФ(Док, ИдентификаторСФ, 0);
		
		// Команда Отправить
		ЗначенияРеквизитов = ПроверкаДляКорректировачнойСчетФактурыОтправка(Док);
		Если ЗначенияРеквизитов = Неопределено Тогда
			Возврат РЕЗ;
		КонецЕсли;
		Если Не ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИзменитьСтатусСчетФактуруНаПортале(Док,  ЗначенияРеквизитов.Идентификатор, ЗначенияРеквизитов.СтатусСФ) = Неопределено Тогда
			ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбновитьИдентификаторИСтатусДокументаСФ(Док, ЗначенияРеквизитов.Идентификатор, ЗначенияРеквизитов.СтатусСФ, Истина);
		КонецЕсли;
		
		// Возврат результата
		РЕЗ.ДокументСчетФактураОтправленный = ТекущиеДанные.ДокументСчетФактураОтправленный;
		РЕЗ.Успешно = ИСТИНА;
		
	КонецЕсли;

	Возврат РЕЗ;
КонецФункции // ()

&НаСервере
Функция ПроверкаДляКорректировачнойСчетФактурыСохранение(Док)
	
	ЗначенияРеквизитов = Новый Структура;
	ЗначенияРеквизитов.Вставить("Статус",	Док.Статус);
	ЗначенияРеквизитов.Вставить("Аванс",	Док.Аванс);
	ЗначенияРеквизитов.Вставить("Корректировочная",	Док.Корректировочная);
	
	Если Док.Корректировочная Тогда
		ОснованиеКорректировки = Док.ОснованиеКорректировки;
		ЗначенияРеквизитов.Вставить("ОснованиеКорректировки", ОснованиеКорректировки);
		ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбновитьСтатусСФ(ОснованиеКорректировки);
		ОснованиеКорректировки_Статус 	= ОснованиеКорректировки.Статус;
		Если ОснованиеКорректировки_Статус = Перечисления.СтатусыСФ.Подтвержденная ИЛИ
			 ОснованиеКорректировки_Статус = Перечисления.СтатусыСФ.ПодтвержденнаяКорректировочная ИЛИ
			 ОснованиеКорректировки_Статус = Перечисления.СтатусыСФ.Первичная Тогда
			Возврат ЗначенияРеквизитов;
		КонецЕсли;
	Иначе
		Возврат ЗначенияРеквизитов;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция ПроверкаДляКорректировачнойСчетФактурыОтправка(Док)
	
	ЗначенияРеквизитов = Новый Структура;
	ЗначенияРеквизитов.Вставить("Идентификатор",	Док.Идентификатор);
	ЗначенияРеквизитов.Вставить("СтатусСФ",			?(Док.Корректировочная, 5, 1));
	
	Если Док.Корректировочная Тогда
		Если Док.Идентификатор = 0 Тогда
			Возврат Неопределено;
		КонецЕсли;
		ОснованиеКорректировки = Док.ОснованиеКорректировки;
		ЗначенияРеквизитов.Вставить("ОснованиеКорректировки", ОснованиеКорректировки);
		ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ОбновитьСтатусСФ(ОснованиеКорректировки);
		ОснованиеКорректировки_Статус 	= ОснованиеКорректировки.Статус;
		Если ОснованиеКорректировки_Статус = Перечисления.СтатусыСФ.Подтвержденная ИЛИ 
			 ОснованиеКорректировки_Статус = Перечисления.СтатусыСФ.ПодтвержденнаяКорректировочная ИЛИ
			 ОснованиеКорректировки_Статус = Перечисления.СтатусыСФ.Первичная Тогда
			Возврат ЗначенияРеквизитов;
		КонецЕсли;
	Иначе
		Возврат ЗначенияРеквизитов;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура ГруппаСтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьРезультаты(ТекущийДокумент=НЕОПРЕДЕЛЕНО)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СчетФактураОтправленныйГрузияДокументыОснования.ДокументОснование КАК ДокументОснование
	|ПОМЕСТИТЬ ОбработанныеДокументыОснования
	|ИЗ
	|	Документ.СчетФактураОтправленныйГрузия.ДокументыОснования КАК СчетФактураОтправленныйГрузияДокументыОснования
	|ГДЕ
	|	СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Дата МЕЖДУ &НачалоМесяца И &КонецМесяца
	|	И СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Проведен
	|	И (
	|		СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.ПустаяСсылка)
	|		ИЛИ
	|		НЕ (
	|			СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Отмененная) 
	//|			ИЛИ 
	//|			СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Отказано)
	//|			ИЛИ 
	//|			СчетФактураОтправленныйГрузияДокументыОснования.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.Удаленный)
	|			)
	|	)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПродажиОбороты.Регистратор КАК ДокументОснование,
	|	ПродажиОбороты.Контрагент КАК Контрагент,
	|	ПродажиОбороты.Регистратор.Договор КАК Договор,
	|	СУММА(ПродажиОбороты.СуммаОборот) КАК Всего,
	|	СУММА(ПродажиОбороты.СуммаНДСОборот) КАК СуммаНДС,
	|	СУММА(ПродажиОбороты.СуммаОборот - ПродажиОбороты.СуммаНДСОборот) КАК СуммаДокумента
	|ПОМЕСТИТЬ Результаты
	|ИЗ
	|	РегистрНакопления.Продажи.Обороты(
	|		&НачалоМесяца, 
	|		&КонецМесяца, 
	|		Регистратор,
	|		Организация = &Организация
	|		И Контрагент.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ОблагаетсяНДС)
	|//УсловиеПоКонтрагенту	
	|	) КАК ПродажиОбороты
	|ГДЕ
	|	НЕ (ПродажиОбороты.Регистратор В
	|			(
	|				ВЫБРАТЬ
	|					ОбработанныеДокументыОснования.ДокументОснование
	|				ИЗ ОбработанныеДокументыОснования КАК ОбработанныеДокументыОснования
	|			)
	|		)
	|//УсловиеПоДокументу
	|
	|СГРУППИРОВАТЬ ПО
	|	ПродажиОбороты.Регистратор,
	|	ПродажиОбороты.Контрагент,
	|	ПродажиОбороты.Регистратор.Договор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Результаты.ДокументОснование КАК ДокументОснование,
	|	ЕСТЬNULL(Результаты.Контрагент, ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент,
	|	ЕСТЬNULL(Результаты.Договор,ЗНАЧЕНИЕ(Справочник.ДоговорыКонтрагентов.ПустаяСсылка)) КАК Договор,
	|	Результаты.Всего КАК Всего,
	|	Результаты.СуммаНДС КАК СуммаНДС,
	|	Результаты.СуммаДокумента КАК СуммаДокумента,
	|	ЗНАЧЕНИЕ(Документ.СчетФактураОтправленныйГрузия.ПустаяСсылка) КАК ДокументСчетФактураОтправленный,
	|	ЛОЖЬ КАК Создан,
	|	ЛОЖЬ КАК Проведен,
	|	ЗНАЧЕНИЕ(Перечисление.СтатусыСФ.ПустаяСсылка) КАК Статус,
	|	ЛОЖЬ КАК Выбран
	|ИЗ Результаты КАК Результаты
	|
	|ИТОГИ ПО
	|	Контрагент,
	|	Договор
	|";
	
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(Объект.Период));
	Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(Объект.Период));
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
	
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УсловиеПоКонтрагенту", "		И Контрагент = &Контрагент");
		Запрос.УстановитьПараметр("Контрагент", Объект.Контрагент);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УсловиеПоКонтрагенту", "");
	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущийДокумент) Тогда
	
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УсловиеПоДокументу", "	И ПродажиОбороты.Регистратор = &Документ");
		Запрос.УстановитьПараметр("Документ", ТекущийДокумент);
		
	Иначе
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"//УсловиеПоДокументу", "");
	
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ДеревоРезультатов =  РезультатЗапроса.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	Возврат ДеревоРезультатов;

КонецФункции

&НаКлиенте
Процедура ЗаполнитьРезультаты(Команда)
	
	Если ЭтаФорма.ПроверитьЗаполнение() Тогда
		
		ДеревоРезультатов = Результаты.ПолучитьЭлементы();
		ДеревоРезультатов.Очистить();
		
		ЗаполнитьРезультатыНаСервере();
		
		ДеревоРезультатов = Результаты.ПолучитьЭлементы();
		
		Для каждого ТекущаяСтрока Из ДеревоРезультатов Цикл
		
			Элементы.Результаты.Развернуть(ТекущаяСтрока.ПолучитьИдентификатор(),ИСТИНА);
		
		КонецЦикла;
	
	КонецЕсли;
	
КонецПроцедуры

