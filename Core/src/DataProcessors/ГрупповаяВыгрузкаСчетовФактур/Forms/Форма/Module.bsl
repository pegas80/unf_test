&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Объект.Организация = ОрганизацииСлужебный.ОрганизацияПоУмолчанию();
	Объект.Период = КонецМесяца(ДобавитьМесяц(ТекущаяДатаСеанса(),-1));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПоказатьПериодНаФорме();
	
	УстановитьВидимость();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимость()

	Элементы.Контрагент.Видимость = (Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаСчетаФактуры);
	
	Если НЕ Элементы.Контрагент.Видимость Тогда
	
		Объект.Контрагент = НЕОПРЕДЕЛЕНО;
	
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьПериодНаФорме()

	ПериодНаФорме = НСтр("ka='"+Формат(Объект.Период,"Л=ka; ДФ='MMMM гггг'")+"';ru='"+Формат(Объект.Период,"Л=ru; ДФ='MMMM гггг'")+"';en='"+Формат(Объект.Период,"Л=en; ДФ='MMMM гггг'")+"'");

КонецПроцедуры

&НаКлиенте
Процедура КнопкаВыбораПериода(Команда)
	
	ВыборПериодаМесяц = Новый ДиалогРедактированияСтандартногоПериода();
    ВыборПериодаМесяц.Период = Новый СтандартныйПериод;
	ВыборПериодаМесяц.Период.ДатаНачала = НачалоМесяца(Объект.Период);
	ВыборПериодаМесяц.Период.ДатаОкончания = КонецМесяца(Объект.Период);
    ОповещениеВыбора = Новый ОписаниеОповещения("ОповещениеВыбораПериода", ЭтаФорма, Новый Структура("ДиалогВыборПериода", ВыборПериодаМесяц));
    ВыборПериодаМесяц.Показать(ОповещениеВыбора);
	
КонецПроцедуры

