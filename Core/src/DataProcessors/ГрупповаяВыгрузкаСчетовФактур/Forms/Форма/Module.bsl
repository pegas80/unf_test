&НаКлиенте
Процедура ОчиститьРезультаты(Команда)
	
	ДеревоРезультатов = Результаты.ПолучитьЭлементы();
	ДеревоРезультатов.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатыОбработатьФлагиРекурсивно(ДеревоРезультатов,ЗначениеФлага)
	
	Для каждого ТекущаяСтрока Из ДеревоРезультатов Цикл
		
		ТекущаяСтрока.Выбран = ЗначениеФлага;
		
		ТекущееДеревоРезультатов = ТекущаяСтрока.ПолучитьЭлементы();
		РезультатыОбработатьФлагиРекурсивно(ТекущееДеревоРезультатов,ЗначениеФлага);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьВсеРезультаты(Команда)
	
	ДеревоРезультатов = Результаты.ПолучитьЭлементы();
	РезультатыОбработатьФлагиРекурсивно(ДеревоРезультатов,ИСТИНА);
	
КонецПроцедуры

&НаКлиенте
Процедура ИсключитьВсеРезультаты(Команда)
	
	ДеревоРезультатов = Результаты.ПолучитьЭлементы();
	РезультатыОбработатьФлагиРекурсивно(ДеревоРезультатов,ЛОЖЬ);
	
КонецПроцедуры

&НаКлиенте
Процедура РезультатыВыбранПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Результаты.ТекущиеДанные;
	
	ТекущееДеревоРезультатов = ТекущиеДанные.ПолучитьЭлементы();
	РезультатыОбработатьФлагиРекурсивно(ТекущееДеревоРезультатов,ТекущиеДанные.Выбран);
	
	
КонецПроцедуры

&НаСервере
Функция ЗначениеЭтоДокумент(Значение)

	Возврат Документы.ТипВсеСсылки().СодержитТип(ТипЗНЧ(Значение))

КонецФункции

&НаКлиенте
Процедура ОповещениеОбработкиЗавершенияВыбораРезультатыПодбор(Значение, ДополнительныеПараметры) ЭКСПОРТ
	
	Если НЕ Значение = НЕОПРЕДЕЛЕНО Тогда
		
		Если ТипЗНЧ(Значение)=Тип("Массив") Тогда
			
			Для каждого ТекущееЗначение Из Значение Цикл
				
				РезультатыОбработатьТекущийДокументНаСервере(ТекущееЗначение);
				
			КонецЦикла;
			
		ИначеЕсли ЗначениеЭтоДокумент(Значение) Тогда
			
			РезультатыОбработатьТекущийДокументНаСервере(Значение)
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДеревоРезультатов = Результаты.ПолучитьЭлементы();
	
	Для каждого ТекущаяСтрока Из ДеревоРезультатов Цикл
		
		Элементы.Результаты.Развернуть(ТекущаяСтрока.ПолучитьИдентификатор(),ИСТИНА);
		
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура РезультатыОбработатьТекущийДокументНаСервере(ТекущийДокумент)

	ДеревоДокументов = ПолучитьРезультаты(ТекущийДокумент);
	РезультатыОбработатьДеревоДляДокументаРекурсивно(ДеревоДокументов);

КонецПроцедуры

&НаСервере
Процедура РезультатыОбработатьДеревоДляДокументаРекурсивно(ДеревоДокументов)

	Для каждого ТекущаяСтрока Из ДеревоДокументов.Строки Цикл
	
		Если ЗначениеЗаполнено(ТекущаяСтрока.ДокументОснование) Тогда
			
			Если ЗначениеЗаполнено(ТекущаяСтрока.СуммаДокумента) Тогда
			
				НайтиИлиДобавитьДанныеПоТекущемуДокументу(ТекущаяСтрока);
			
			КонецЕсли;
		
		Иначе
			
			РезультатыОбработатьДеревоДляДокументаРекурсивно(ТекущаяСтрока);
		
		КонецЕсли;
	
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура НайтиИлиДобавитьДанныеПоТекущемуДокументу(ДанныеПоТекущемуДокументу)

	ТекущийКонтрагент = ДанныеПоТекущемуДокументу.Контрагент;
	ТекущийДоговор = ДанныеПоТекущемуДокументу.Договор;
	ТекущийДокументОснование = ДанныеПоТекущемуДокументу.ДокументОснование;
	
	СтрокаКонтрагент = НЕОПРЕДЕЛЕНО;
	СтрокаДоговор = НЕОПРЕДЕЛЕНО;
	СтрокаДокументОснование = НЕОПРЕДЕЛЕНО;
	
	РезультатыДерево = Результаты.ПолучитьЭлементы();
	
	// Ищем родителя-контрагента, 1-й уровень
	Для каждого СтрокаРезультаты Из РезультатыДерево Цикл
	
		Если СтрокаРезультаты.Контрагент = ТекущийКонтрагент Тогда
		
			СтрокаКонтрагент = СтрокаРезультаты;
			Прервать;
		
		КонецЕсли;
	
	КонецЦикла;
	
	Если СтрокаКонтрагент = НЕОПРЕДЕЛЕНО Тогда
	
		СтрокаКонтрагент = РезультатыДерево.Добавить();
		СтрокаКонтрагент.Контрагент = ТекущийКонтрагент;
	
	КонецЕсли;
	
	// Ищем родителя-договор, 2-й уровень
	КонтрагентДерево = СтрокаКонтрагент.ПолучитьЭлементы();
	Для каждого СтрокаКонтрагент Из КонтрагентДерево Цикл
	
		Если СтрокаКонтрагент.Договор = ТекущийДоговор Тогда
		
			СтрокаДоговор = СтрокаКонтрагент;
			Прервать;
		
		КонецЕсли;
	
	КонецЦикла;
	
	Если СтрокаДоговор = НЕОПРЕДЕЛЕНО Тогда
	
		СтрокаДоговор = КонтрагентДерево.Добавить();
		СтрокаДоговор.Контрагент = ТекущийКонтрагент;
		СтрокаДоговор.Договор = ТекущийДоговор;
	
	КонецЕсли;
	
	// Ищем строку документа-основания, 3-й уровень
	ДоговорДерево = СтрокаДоговор.ПолучитьЭлементы();
	Для каждого СтрокаДоговор Из ДоговорДерево Цикл
	
		Если СтрокаДоговор.ДокументОснование = ТекущийДокументОснование Тогда
		
			СтрокаДокументОснование = СтрокаДоговор;
			Прервать;
		
		КонецЕсли;
	
	КонецЦикла;
	
	Если СтрокаДокументОснование = НЕОПРЕДЕЛЕНО Тогда
	
		СтрокаДокументОснование = ДоговорДерево.Добавить();
		СтрокаДокументОснование.Контрагент = ТекущийКонтрагент;
		СтрокаДокументОснование.Договор = ТекущийДоговор;
	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(СтрокаДокументОснование,ДанныеПоТекущемуДокументу);

КонецПроцедуры

&НаКлиенте
