    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокХарактеристик.ХарактеристикаСсылка</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>Выбрать
	СправочникНоменклатура.Ссылка Как НоменклатураСсылка
	,ХарактеристикиНоменклатуры.Ссылка Как ХарактеристикаСсылка
Поместить ХарактеристикиКатегорий
Из Справочник.ХарактеристикиНоменклатуры Как ХарактеристикиНоменклатуры
	Левое Соединение Справочник.Номенклатура Как СправочникНоменклатура
	По ХарактеристикиНоменклатуры.Владелец = СправочникНоменклатура.КатегорияНоменклатуры
Где ХарактеристикиНоменклатуры.Владелец Ссылка Справочник.КатегорииНоменклатуры
	И СправочникНоменклатура.ТипНоменклатуры В(&amp;ТипНоменклатуры)
Индексировать по НоменклатураСсылка, ХарактеристикаСсылка

//:::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;Выбрать
	ХарактеристикиНоменклатуры.Владелец Как НоменклатураСсылка
	,ХарактеристикиНоменклатуры.Ссылка Как ХарактеристикаСсылка
Поместить ВсеХарактеристикиСНоменклатурой
Из Справочник.ХарактеристикиНоменклатуры Как ХарактеристикиНоменклатуры
Где ХарактеристикиНоменклатуры.Владелец Ссылка Справочник.Номенклатура
	И ХарактеристикиНоменклатуры.Владелец.ТипНоменклатуры В (&amp;ТипНоменклатуры)

Объединить

Выбрать
	ХарактеристикиКатегорий.НоменклатураСсылка
	,ХарактеристикиКатегорий.ХарактеристикаСсылка
Из ХарактеристикиКатегорий Как ХарактеристикиКатегорий
Индексировать по НоменклатураСсылка, ХарактеристикаСсылка

//:::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::::
;Выбрать
	ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка Как НоменклатураСсылка
	,ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка.Недействителен Как НоменклатураНедействителен
	,ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка.СтавкаНДС Как СтавкаНДС
	,ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка.СтранаПроисхождения Как СтранаПроисхождения
	,СправочникХарактеристики.Ссылка Как ХарактеристикаСсылка
	,ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка.ЕдиницаИзмерения Как ЕдиницаИзмерения
	,ЕстьNULL(ОстаткиЗапасовОтправитель.КоличествоОстаток, 0) Как ОстатокОтправитель
	,Выбор когда ЕстьNULL(РезервыЗапасовОтправитель.КоличествоОстаток, 0) = 0
		Тогда 1
		Иначе 0 Конец Как РезервОтправитель
	,ЕстьNULL(ОстаткиЗапасовОтправитель.КоличествоОстаток, 0) - ЕстьNULL(РезервыЗапасовОтправитель.КоличествоОстаток, 0) Как СвободноОтправитель
	,ЕстьNULL(ОстаткиЗапасовПолучатель.КоличествоОстаток, 0) Как ОстатокПолучатель
	,Выбор когда ЕстьNULL(РезервыЗапасовПолучатель.КоличествоОстаток, 0) = 0
		Тогда 1
		Иначе 0 Конец Как РезервПолучатель
	,ЕстьNULL(ОстаткиЗапасовПолучатель.КоличествоОстаток, 0) - ЕстьNULL(РезервыЗапасовПолучатель.КоличествоОстаток, 0) Как СвободноПолучатель
Из Справочник.ХарактеристикиНоменклатуры Как СправочникХарактеристики
	Левое соединение ВсеХарактеристикиСНоменклатурой Как ВсеХарактеристикиСНоменклатурой
		По СправочникХарактеристики.Ссылка = ВсеХарактеристикиСНоменклатурой.ХарактеристикаСсылка
	Левое соединение РегистрНакопления.ЗапасыНаСкладах.Остатки(,
			Организация = &amp;Организация
				И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель
				И Характеристика &lt;> ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяССылка)) Как ОстаткиЗапасовОтправитель
		По ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка = ОстаткиЗапасовОтправитель.Номенклатура
			И СправочникХарактеристики.Ссылка = ОстаткиЗапасовОтправитель.Характеристика
			И ОстаткиЗапасовОтправитель.Организация = &amp;Организация
			И ОстаткиЗапасовОтправитель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель
	Левое соединение РегистрНакопления.Запасы.Остатки(,
			Организация = &amp;Организация
				И СтруктурнаяЕдиница ССЫЛКА Справочник.СтруктурныеЕдиницы
				И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель
				И Характеристика &lt;> ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяССылка)
				И ЗаказПокупателя &lt;> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяССылка)) Как РезервыЗапасовОтправитель
		По ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка = РезервыЗапасовОтправитель.Номенклатура
			И СправочникХарактеристики.Ссылка = РезервыЗапасовОтправитель.Характеристика
			И РезервыЗапасовОтправитель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель
	Левое соединение РегистрНакопления.ЗапасыНаСкладах.Остатки(,
			Организация = &amp;Организация
				И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель
				И Характеристика &lt;> ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяССылка)) Как ОстаткиЗапасовПолучатель
		По ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка = ОстаткиЗапасовПолучатель.Номенклатура
			И СправочникХарактеристики.Ссылка = ОстаткиЗапасовПолучатель.Характеристика
			И ОстаткиЗапасовПолучатель.Организация = &amp;Организация
			И ОстаткиЗапасовПолучатель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель
	Левое соединение РегистрНакопления.Запасы.Остатки(,
			Организация = &amp;Организация
				И СтруктурнаяЕдиница ССЫЛКА Справочник.СтруктурныеЕдиницы
				И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель
				И Характеристика &lt;> ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяССылка)
				И ЗаказПокупателя &lt;> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяССылка)) Как РезервыЗапасовПолучатель
		По ВсеХарактеристикиСНоменклатурой.НоменклатураСсылка = РезервыЗапасовПолучатель.Номенклатура
			И СправочникХарактеристики.Ссылка = РезервыЗапасовПолучатель.Характеристика
			И РезервыЗапасовПолучатель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель</queryText>
      <mainTable>Catalog.ХарактеристикиНоменклатуры</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>СписокСкладскиеОстатки</name>
    <title>
      <key>ru</key>
      <value>Список складские остатки</value>
    </title>
    <title>
      <key>ka</key>
      <value>Список складские остатки</value>
    </title>
    <title>
      <key>en</key>
      <value>List of warehouse stock</value>
    </title>
    <id>10</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <functionalOptions>FunctionalOption.УчетПоНесколькимСкладам</functionalOptions>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокСкладскиеОстатки.Номенклатура</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница
	,ЗапасыНаСкладахОстатки.Номенклатура
	,ЕСТЬNULL(ЗапасыНаСкладахОстатки.КоличествоОстаток, 0) КАК Остаток
	,ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) КАК Резерв
	,ЕСТЬNULL(ЗапасыНаСкладахОстатки.КоличествоОстаток, 0) - ЕСТЬNULL(ЗапасыОстатки.КоличествоОстаток, 0) КАК Свободно
ИЗ
	РегистрНакопления.ЗапасыНаСкладах.Остатки(, Организация = &amp;Организация {(Характеристика = &amp;ХарактеристикаНоменклатуры)}) КАК ЗапасыНаСкладахОстатки
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(
				,
				Организация = &amp;Организация
					И СтруктурнаяЕдиница ССЫЛКА Справочник.СтруктурныеЕдиницы
					И ЗаказПокупателя &lt;> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяССылка) {(Характеристика = &amp;ХарактеристикаНоменклатуры)}) КАК ЗапасыОстатки
		ПО ЗапасыНаСкладахОстатки.СтруктурнаяЕдиница = ЗапасыОстатки.СтруктурнаяЕдиница
			И ЗапасыНаСкладахОстатки.Номенклатура = ЗапасыОстатки.Номенклатура</queryText>
      <mainTable>AccumulationRegister.ЗапасыНаСкладах.Balance</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <attributes>
    <name>СписокЗапасы</name>
    <title>
      <key>ru</key>
      <value>Список запасы</value>
    </title>
    <title>
      <key>ka</key>
      <value>სია მარაგები</value>
    </title>
    <title>
      <key>en</key>
      <value>list of stocks</value>
    </title>
    <id>11</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.НоменклатурнаяГруппа</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.ЕдиницаИзмерения</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.ИспользоватьПартии</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.ИспользоватьХарактеристики</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.КатегорияНоменклатуры</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.НоменклатураСсылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.Родитель</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.СтавкаНДС</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.СтранаПроисхождения</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.ХарактеристикаСсылка</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>СписокЗапасы.ЦеноваяГруппа</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВЫБОР
		КОГДА СправочникНоменклатура.ЭтоГруппа
			ТОГДА ВЫБОР
					КОГДА СправочникНоменклатура.ПометкаУдаления
						ТОГДА 13
					ИНАЧЕ 12
				КОНЕЦ
		ИНАЧЕ -1 + ВЫБОР
				КОГДА СправочникНоменклатура.ПометкаУдаления
					ТОГДА 1
				ИНАЧЕ 0
			КОНЕЦ + ВЫБОР
				КОГДА СправочникНоменклатура.ИспользоватьХарактеристики = ЛОЖЬ
					ТОГДА 1
				ИНАЧЕ 3
			КОНЕЦ
	КОНЕЦ КАК ИндексКартинки
	,СправочникНоменклатура.Ссылка КАК НоменклатураСсылка
	,ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК ХарактеристикаСсылка
	,СправочникНоменклатура.Родитель КАК Родитель
	,СправочникНоменклатура.Наименование
	,СправочникНоменклатура.Код
	,СправочникНоменклатура.Артикул
	,СправочникНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	,СправочникНоменклатура.НаправлениеДеятельности
	,СправочникНоменклатура.КатегорияНоменклатуры
	,СправочникНоменклатура.Поставщик
	,СправочникНоменклатура.Склад
	,СправочникНоменклатура.СпособПополнения
	,СправочникНоменклатура.СрокПополнения
	,СправочникНоменклатура.СтавкаНДС КАК СтавкаНДС
	,СправочникНоменклатура.СчетУчетаЗапасов
	,СправочникНоменклатура.СчетУчетаЗатрат
	,СправочникНоменклатура.ТипНоменклатуры
	,СправочникНоменклатура.Ячейка
	,СправочникНоменклатура.ЦеноваяГруппа
	,СправочникНоменклатура.ИспользоватьХарактеристики
	,СправочникНоменклатура.ИспользоватьПартии
	,СправочникНоменклатура.СтранаПроисхождения
	,СправочникНоменклатура.Недействителен
	,СправочникНоменклатура.Комментарий КАК Описание
	,ЕСТЬNULL(ОстаткиЗапасовОтправитель.КоличествоОстаток, 0) КАК ОстатокОтправитель
	,ВЫБОР
		КОГДА ЕСТЬNULL(РезервыЗапасовОтправитель.КоличествоОстаток, 0) = 0
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК РезервОтправитель
	,ЕСТЬNULL(ОстаткиЗапасовОтправитель.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыЗапасовОтправитель.КоличествоОстаток, 0) КАК СвободноОтправитель
	,ЕСТЬNULL(ОстаткиЗапасовПолучатель.КоличествоОстаток, 0) КАК ОстатокПолучатель
	,ВЫБОР
		КОГДА ЕСТЬNULL(РезервыЗапасовПолучатель.КоличествоОстаток, 0) = 0
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК РезервПолучатель
	,ЕСТЬNULL(ОстаткиЗапасовПолучатель.КоличествоОстаток, 0) - ЕСТЬNULL(РезервыЗапасовПолучатель.КоличествоОстаток, 0) КАК СвободноПолучатель
ИЗ
	Справочник.Номенклатура КАК СправочникНоменклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(
				,
				Организация = &amp;Организация
					И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель) КАК ОстаткиЗапасовОтправитель
		ПО СправочникНоменклатура.Ссылка = ОстаткиЗапасовОтправитель.Номенклатура
			И (ОстаткиЗапасовОтправитель.Организация = &amp;Организация)
			И (ОстаткиЗапасовОтправитель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(
				,
				Организация = &amp;Организация
					И СтруктурнаяЕдиница ССЫЛКА Справочник.СтруктурныеЕдиницы
					И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель
					И ЗаказПокупателя &lt;> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяССылка)) КАК РезервыЗапасовОтправитель
		ПО СправочникНоменклатура.Ссылка = РезервыЗапасовОтправитель.Номенклатура
			И (РезервыЗапасовОтправитель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаОтправитель)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыНаСкладах.Остатки(
				,
				Организация = &amp;Организация
					И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель) КАК ОстаткиЗапасовПолучатель
		ПО СправочникНоменклатура.Ссылка = ОстаткиЗапасовПолучатель.Номенклатура
			И (ОстаткиЗапасовПолучатель.Организация = &amp;Организация)
			И (ОстаткиЗапасовПолучатель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Запасы.Остатки(
				,
				Организация = &amp;Организация
					И СтруктурнаяЕдиница ССЫЛКА Справочник.СтруктурныеЕдиницы
					И СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель
					И ЗаказПокупателя &lt;> ЗНАЧЕНИЕ(Документ.ЗаказПокупателя.ПустаяССылка)) КАК РезервыЗапасовПолучатель
		ПО СправочникНоменклатура.Ссылка = РезервыЗапасовПолучатель.Номенклатура
			И (РезервыЗапасовПолучатель.СтруктурнаяЕдиница = &amp;СтруктурнаяЕдиницаПолучатель)
ГДЕ
	СправочникНоменклатура.ТипНоменклатуры В(&amp;ТипНоменклатуры)
	И НЕ СправочникНоменклатура.ЭтоГруппа</queryText>
      <mainTable>Catalog.Номенклатура</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
