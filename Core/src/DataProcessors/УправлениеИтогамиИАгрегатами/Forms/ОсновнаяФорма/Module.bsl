	ПараметрыИтогов.Вставить("Значение1",              Ложь);
	ПараметрыИтогов.Вставить("Значение2",              Неопределено);
	ПараметрыИтогов.Вставить("ТекстСообщенияОбОшибке", НСтр("ka='Ошибка пересчета итогов.';ru='Ошибка пересчета итогов.';en='the results of the conversion error.'"));
	
	УправлениеИтогами(ПараметрыИтогов);
	
КонецПроцедуры

