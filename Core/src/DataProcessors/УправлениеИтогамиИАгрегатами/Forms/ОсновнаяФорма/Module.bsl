	ПараметрыИтогов.Вставить("ПослеПроцесса",          НСтр("ka='Включение использования текущих итогов завершено';ru='Включение использования текущих итогов завершено';en='Enabling the use of the current results of completed'"));
	ПараметрыИтогов.Вставить("Действие",               "ИспользоватьТекущиеИтоги");
