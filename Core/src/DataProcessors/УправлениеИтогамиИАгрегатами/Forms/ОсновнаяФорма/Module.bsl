	ПараметрыИтогов.Вставить("Поле",                   "Наименование");
	ПараметрыИтогов.Вставить("Значение1",              Ложь);
	ПараметрыИтогов.Вставить("Значение2",              Неопределено);
	ПараметрыИтогов.Вставить("ТекстСообщенияОбОшибке", НСтр("ka='Ошибка пересчета текущих итогов.';ru='Ошибка пересчета текущих итогов.';en='Error current conversion results.'"));
	
