#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	// Сейчас регистр в режиме Итогов.
	Инструкция = СтандартныеПодсистемыСервер.ИнструкцияУсловногоОформления();
	Инструкция.Поля = "ИтогиАгрегатыИтоги";
	Инструкция.Отборы.Вставить("СписокИтогов.АгрегатыИтоги", 0);
	Инструкция.Оформление.Вставить("Текст", НСтр("ka='შედეგები';ru='Итоги';en='Итоги'"));
	СтандартныеПодсистемыСервер.ДобавитьЭлементУсловногоОформления(ЭтотОбъект, Инструкция);
	
	// Сейчас регистр в режиме Агрегатов.
	Инструкция = СтандартныеПодсистемыСервер.ИнструкцияУсловногоОформления();
	Инструкция.Поля = "ИтогиАгрегатыИтоги";
	Инструкция.Отборы.Вставить("СписокИтогов.АгрегатыИтоги", 1);
	Инструкция.Оформление.Вставить("Текст", НСтр("ka='Агрегаты';ru='Агрегаты';en='aggregates'"));
	СтандартныеПодсистемыСервер.ДобавитьЭлементУсловногоОформления(ЭтотОбъект, Инструкция);
	
	// Регистр, который может быть только в режиме Итогов.
	Инструкция = СтандартныеПодсистемыСервер.ИнструкцияУсловногоОформления();
	Инструкция.Поля = "ИтогиАгрегатыИтоги";
	Инструкция.Отборы.Вставить("СписокИтогов.АгрегатыИтоги", 2);
	Инструкция.Оформление.Вставить("Текст", НСтр("ka='Только итоги';ru='Только итоги';en='results only'"));
	СтандартныеПодсистемыСервер.ДобавитьЭлементУсловногоОформления(ЭтотОбъект, Инструкция);
	
	// Невозможно управлять итогами когда регистр в режиме агрегатов.
	Инструкция = СтандартныеПодсистемыСервер.ИнструкцияУсловногоОформления();
	Инструкция.Поля = "СписокИтогов";
	Инструкция.Отборы.Вставить("СписокИтогов.АгрегатыИтоги", 1);
	Инструкция.Оформление.Вставить("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	СтандартныеПодсистемыСервер.ДобавитьЭлементУсловногоОформления(ЭтотОбъект, Инструкция);
	
	// Невозможно управлять итогами когда регистр без остатков (только обороты).
	Инструкция = СтандартныеПодсистемыСервер.ИнструкцияУсловногоОформления();
	Инструкция.Поля = "ИтогиАгрегатыИтоги";
	Инструкция.Отборы.Вставить("СписокИтогов.ОстаткиИОбороты", Ложь);
	Инструкция.Оформление.Вставить("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	СтандартныеПодсистемыСервер.ДобавитьЭлементУсловногоОформления(ЭтотОбъект, Инструкция);
	
	// Нужно заменить оптимальные агрегата в метаданных.
	Инструкция = СтандартныеПодсистемыСервер.ИнструкцияУсловногоОформления();
	Инструкция.Поля = "АгрегатыПоРегистрам";
	Инструкция.Отборы.Вставить("АгрегатыПоРегистрам.ПостроениеОптимально", Ложь);
	Инструкция.Оформление.Вставить("Шрифт", Новый Шрифт(WindowsШрифты.ШрифтДиалоговИМеню, , , Истина, Ложь, Ложь, Ложь, ));
	СтандартныеПодсистемыСервер.ДобавитьЭлементУсловногоОформления(ЭтотОбъект, Инструкция);
КонецПроцедуры

