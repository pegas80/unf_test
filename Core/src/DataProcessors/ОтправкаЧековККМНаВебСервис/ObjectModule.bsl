
Функция ОтправитьPOST(НастройкиОтправки, СсылкаЧека) Экспорт

	ПЕРЕМ РЕЗ,Данные;
	
	SSL = НЕОПРЕДЕЛЕНО;
	
	Если НастройкиОтправки.ЗащищенноеСоединение Тогда 
		SSL = Новый ЗащищенноеСоединениеOpenSSL();//ИнтеграцияСНалоговойСлужбыПовтИсп.ПолучитьЗащищенноеСоединение();
	КонецЕсли;
	
	Соединение = Новый HTTPСоединение(НастройкиОтправки.Сервер,Число(НастройкиОтправки.Порт),,,,,SSL);//CORAX_Host,,,,,,SSL);	

	Заголовки = Новый Соответствие;
	
	Для Каждого Строк Из НастройкиОтправки.Заголовки Цикл 
		
		Заголовки.Вставить(СокрЛП(Строк.Заголовок), СокрЛП(Строк.Значение));
		
	КонецЦикла;
	
	СтруктураJSON = Новый Структура;
	СтруктураParams = Новый Структура;
	
	СтруктураParams.Вставить("OrderNumber", СсылкаЧека.НоммерОчереди);
	СтруктураParams.Вставить("OrderDate", СсылкаЧека.Дата);
	
	СтруктураJSON.Вставить("Action", "RegisterOrder");
	
	СтруктураJSON.Вставить("Params", СтруктураParams);
	
	КаталогВременныъхфайлов = КаталогВременныхФайлов(); 
	ПутьКФайлу = КаталогВременныъхфайлов + "PostOrders.json";
	
	тЗапись = Новый ЗаписьJSON;
	тЗапись.ОткрытьФайл(ПутьКФайлу);
	
	ЗаписатьJSON(тЗапись, СтруктураJSON, Новый НастройкиСериализацииJSON, "ФункцияПреобразования", ЭтотОбъект);
	тЗапись.Закрыть();
	
	ОстатокАдреса = "";
	Если ЗначениеЗаполнено(СокрЛП(НастройкиОтправки.ОстаткоАдреса)) Тогда 
		ПозицияПервогоСлеша = СтрНайти(СокрЛП(НастройкиОтправки.ОстаткоАдреса), "/");
		Если ПозицияПервогоСлеша = 1 Тогда 
			ОстатокАдреса = ПозицияПервогоСлеша;
		Иначе
			ОстатокАдреса = "/" + ПозицияПервогоСлеша;
		КонецЕсли;
	Иначе
		ОстатокАдреса = "/";
	КонецЕсли;
	
	Если Заголовки.Количество() > 0 Тогда 
		Запрос = Новый HTTPЗапрос(ОстатокАдреса, Заголовки);
	Иначе
		Запрос = Новый HTTPЗапрос(ОстатокАдреса);
	КонецЕсли;
	
	Запрос.УстановитьИмяФайлаТела(ПутьКФайлу);
	
	Результат = Соединение.ОтправитьДляОбработки(Запрос);
	
	РЕЗ = Новый Структура("КодСостояния"); 
	
	РЕЗ.КодСостояния = Результат.КодСостояния;
	
	Если Результат.КодСостояния = 200 Тогда
		
		//РЕЗ.Данные = Данные;
		
	Иначе
		
		Сообщить(Результат.ПолучитьТелоКакСтроку());
		
	КонецЕсли;
	
	Возврат РЕЗ;
	
КонецФункции

Функция ФункцияПреобразования(Свойство, Значение, ДополнительныеПараметры, Отказ) Экспорт
	
	Если ТипЗнч(Значение) = Тип("УникальныйИдентификатор") Тогда
		Возврат Строка(Значение);
	КонецЕсли;
	
	Отказ = Истина;
	
КонецФункции