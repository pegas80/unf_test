		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
		НоваяСтрока.Сумма = ?(ВыборкаДетальныеЗаписи.ВидДвиженияУправленческий = ВидДвиженияНакопления.Приход, НоваяСтрока.Сумма, -НоваяСтрока.Сумма);
		НоваяСтрока.Аналитика = "" + ВыборкаДетальныеЗаписи.БанковскийСчетКасса;
		НоваяСтрока.Раздел = "Денежные средства";
		
		НоваяСтрока = НаборЗаписейХозрасчетный.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
		НоваяСтрока.СчетДт = ВыборкаДетальныеЗаписи.СчетДтРегл;
		НоваяСтрока.СчетКт = ВыборкаДетальныеЗаписи.СчетКтРегл;
		
		Если ЗначениеЗаполнено(НоваяСтрока.СчетДт) И НоваяСтрока.СчетДт.Валютный Тогда
			НоваяСтрока.ВалютаДт = ВыборкаДетальныеЗаписи.Валюта;
		Иначе
			НоваяСтрока.ВалютаДт = Справочники.Валюты.ПустаяСсылка();
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(НоваяСтрока.СчетКт) И НоваяСтрока.СчетКт.Валютный Тогда
			НоваяСтрока.ВалютаКт = ВыборкаДетальныеЗаписи.Валюта;
		Иначе
			НоваяСтрока.ВалютаКт = Справочники.Валюты.ПустаяСсылка();
		КонецЕсли; 
		
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, "Валюты", ВыборкаДетальныеЗаписи.Валюта);
