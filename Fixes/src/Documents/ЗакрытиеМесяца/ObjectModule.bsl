	Если НЕ ИнтеграцияСНалоговойСлужбой_И_БухгалтерскийУчет.ИспользованиеТолькоРегламентированногоПланаСчетов(ТекущаяДата()) Тогда  //+++ Дмгг
		НаборЗаписейУправленческий.Записать(Ложь);
	КонецЕсли;  //--- Дмгг
	
	// Пишем оставшиеся записи Хозрасчетный.
	НаборЗаписейХозрасчетный.Записать(Ложь);	
	
КонецПроцедуры

&Вместо("РассчитатьФинансовыйРезультатРегл")
Процедура AzRyFix_РассчитатьФинансовыйРезультатРегл(Отказ)
	
	Если Не AzRyИспользоватьСтаруюВерсиюЗакрытияМесяца Тогда		
		ПродолжитьВызов(Отказ);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	УчетнаяПолитикаРеглСрезПоследних.СчетПрибыльУбытки КАК СчетПрибыльУбытки
		|ПОМЕСТИТЬ Вт_УчетнаяПолитикаОрганизации
		|ИЗ
		|	РегистрСведений.УчетнаяПолитикаРегл.СрезПоследних(&КонецПериода, Организация = &Организация) КАК УчетнаяПолитикаРеглСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетаФинансовогоРезультатаДоходы.СчетУчета КАК СчетУчета
		|ПОМЕСТИТЬ Вт_ФинРезСчетаДоходов
		|ИЗ
		|	РегистрСведений.СчетаФинансовогоРезультатаДоходы КАК СчетаФинансовогоРезультатаДоходы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетаФинансовогоРезультатаРасходы.СчетУчета КАК СчетУчета
		|ПОМЕСТИТЬ Вт_ФинРезСчетаРасходов
		|ИЗ
		|	РегистрСведений.СчетаФинансовогоРезультатаРасходы КАК СчетаФинансовогоРезультатаРасходы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ХозрасчетныйОбороты.Организация,
		|	ХозрасчетныйОбороты.Счет КАК СчетДт,
		|	ХозрасчетныйОбороты.Субконто1 КАК СубконтоДт1,
		|	ХозрасчетныйОбороты.Субконто2 КАК СубконтоДт2,
		|	ХозрасчетныйОбороты.Субконто3 КАК СубконтоДт3,
		|	СУММА(ХозрасчетныйОбороты.КоличествоОборотКт) КАК КоличествоОборотДт,
		|	Вт_УчетнаяПолитикаОрганизации.СчетПрибыльУбытки КАК СчетКт,
		|	&ВалютаУчета КАК СубконтоКт1,
		|	NULL КАК СубконтоКт2,
		|	NULL КАК СубконтоКт3,
		|	0 КАК КоличествоОборотКт,
		|	СУММА(ХозрасчетныйОбороты.СуммаОборотКт) КАК СуммаОборот
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			Регистратор,
		|			Счет В
		|				(ВЫБРАТЬ
		|					Вт_ФинРезСчетаДоходов.СчетУчета
		|				ИЗ
		|					Вт_ФинРезСчетаДоходов КАК Вт_ФинРезСчетаДоходов),
		|			,
		|			Организация = &Организация,
		|			,
		|			) КАК ХозрасчетныйОбороты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Вт_УчетнаяПолитикаОрганизации КАК Вт_УчетнаяПолитикаОрганизации
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ХозрасчетныйОбороты.Регистратор <> &ИсключаемыйРегистратор
		|
		|СГРУППИРОВАТЬ ПО
		|	ХозрасчетныйОбороты.Организация,
		|	ХозрасчетныйОбороты.Счет,
		|	ХозрасчетныйОбороты.Субконто1,
		|	ХозрасчетныйОбороты.Субконто2,
		|	ХозрасчетныйОбороты.Субконто3,
		|	Вт_УчетнаяПолитикаОрганизации.СчетПрибыльУбытки
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ХозрасчетныйОбороты.Организация,
		|	Вт_УчетнаяПолитикаОрганизации.СчетПрибыльУбытки,
		|	&ВалютаУчета,
		|	NULL,
		|	NULL,
		|	0,
		|	ХозрасчетныйОбороты.Счет,
		|	ХозрасчетныйОбороты.Субконто1,
		|	ХозрасчетныйОбороты.Субконто2,
		|	ХозрасчетныйОбороты.Субконто3,
		|	СУММА(ХозрасчетныйОбороты.КоличествоОборотДт),
		|	СУММА(ХозрасчетныйОбороты.СуммаОборотДт)
		|ИЗ
		|	РегистрБухгалтерии.Хозрасчетный.Обороты(
		|			&НачалоПериода,
		|			&КонецПериода,
		|			Регистратор,
		|			Счет В
		|				(ВЫБРАТЬ
		|					Вт_ФинРезСчетаРасходов.СчетУчета
		|				ИЗ
		|					Вт_ФинРезСчетаРасходов КАК Вт_ФинРезСчетаРасходов),
		|			,
		|			Организация = &Организация,
		|			,
		|			) КАК ХозрасчетныйОбороты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Вт_УчетнаяПолитикаОрганизации КАК Вт_УчетнаяПолитикаОрганизации
		|		ПО (ИСТИНА)
		|ГДЕ
		|	ХозрасчетныйОбороты.Регистратор <> &ИсключаемыйРегистратор
		|
		|СГРУППИРОВАТЬ ПО
		|	ХозрасчетныйОбороты.Организация,
		|	Вт_УчетнаяПолитикаОрганизации.СчетПрибыльУбытки,
		|	ХозрасчетныйОбороты.Счет,
		|	ХозрасчетныйОбороты.Субконто1,
		|	ХозрасчетныйОбороты.Субконто2,
		|	ХозрасчетныйОбороты.Субконто3";
	
	ВалютаУчета = Константы.ВалютаУчета.Получить();
	
	Запрос.УстановитьПараметр("НачалоПериода"			, ДополнительныеСвойства.ДляПроведения.НачальнаяДатаПериода);
	Запрос.УстановитьПараметр("КонецПериода"			, ДополнительныеСвойства.ДляПроведения.КонечнаяГраницаПериода);
	Запрос.УстановитьПараметр("Организация"				, ДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("ВалютаУчета"				, Справочники.Валюты.ПустаяСсылка());
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор"	, Ссылка);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой() Тогда
				
		// Создадим набор записей регистра бухгалтерии "Хозрасчетный".
		НаборЗаписейХозрасчетный = РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
		НаборЗаписейХозрасчетный.Отбор.Регистратор.Установить(Ссылка);
	Иначе
		
		Возврат;
		
	КонецЕсли;
	
	ВыборкаРезультатЗапроса = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаРезультатЗапроса.Следующий() Цикл
		
		// Движения по регистру Хозрасчетный.
		НоваяСтрока = НаборЗаписейХозрасчетный.Добавить();
		НоваяСтрока.Период 		= Дата;
		НоваяСтрока.Регистратор = Ссылка;
		НоваяСтрока.Организация = ВыборкаРезультатЗапроса.Организация;
		НоваяСтрока.СчетДт 		= ВыборкаРезультатЗапроса.СчетДт;
		НоваяСтрока.СчетКт 		= ВыборкаРезультатЗапроса.СчетКт;
		НоваяСтрока.Сумма 		= ВыборкаРезультатЗапроса.СуммаОборот;
		НоваяСтрока.Содержание 	= "Финансовый результат";
		
		//Если НоваяСтрока.СчетДт.Валютный Тогда
		//	НоваяСтрока.ВалютаДт = ВалютаУчета;	
		//КонецЕсли;
		
		Если НоваяСтрока.СчетДт.Количественный Тогда
			НоваяСтрока.КоличествоДт = ВыборкаРезультатЗапроса.КоличествоОборотДт;
		КонецЕсли;
		
		//Если НоваяСтрока.СчетКт.Валютный Тогда
		//	НоваяСтрока.ВалютаКт = ВалютаУчета;	
		//КонецЕсли;
		
		Если НоваяСтрока.СчетКт.Количественный Тогда
			НоваяСтрока.КоличествоКт = ВыборкаРезультатЗапроса.КоличествоОборотКт;
		КонецЕсли;
		
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, 1, ВыборкаРезультатЗапроса.СубконтоДт1);
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, 2, ВыборкаРезультатЗапроса.СубконтоДт2);
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетДт, НоваяСтрока.СубконтоДт, 3, ВыборкаРезультатЗапроса.СубконтоДт3);
		
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, 1, ВыборкаРезультатЗапроса.СубконтоКт1);
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, 2, ВыборкаРезультатЗапроса.СубконтоКт2);
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, 3, ВыборкаРезультатЗапроса.СубконтоКт3);	
		
	КонецЦикла;
	
	// Пишем Хозрасчетный.
	НаборЗаписейХозрасчетный.Записать(Ложь);
	НаборЗаписейХозрасчетный.Очистить();
		
КонецПроцедуры

&Вместо("РассчитатьКурсовыеРазницы")
Процедура AzRyFix_РассчитатьКурсовыеРазницы(Отказ, ТаблицаОшибок)
	
	Если Не AzRyИспользоватьСтаруюВерсиюЗакрытияМесяца Тогда		
		ПродолжитьВызов(Отказ, ТаблицаОшибок);
		Возврат;
	КонецЕсли;
	
	// Создадим набор записей регистра накопления ДенежныеСредства.
	НаборЗаписейДенежныеСредства = РегистрыНакопления.ДенежныеСредства.СоздатьНаборЗаписей();
	НаборЗаписейДенежныеСредства.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления ДенежныеСредстваВКассахККМ.
	НаборЗаписейДенежныеСредстваВКассахККМ = РегистрыНакопления.ДенежныеСредстваВКассахККМ.СоздатьНаборЗаписей();
	НаборЗаписейДенежныеСредстваВКассахККМ.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления РасчетыСПерсоналом.
	НаборЗаписейРасчетыСПерсоналом = РегистрыНакопления.РасчетыСПерсоналом.СоздатьНаборЗаписей();
	НаборЗаписейРасчетыСПерсоналом.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления РасчетыСПодотчетниками.
	НаборЗаписейРасчетыСПодотчетниками = РегистрыНакопления.РасчетыСПодотчетниками.СоздатьНаборЗаписей();
	НаборЗаписейРасчетыСПодотчетниками.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления РасчетыСПокупателями.
	НаборЗаписейРасчетыСПокупателями = РегистрыНакопления.РасчетыСПокупателями.СоздатьНаборЗаписей();
	НаборЗаписейРасчетыСПокупателями.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления РасчетыСПоставщиками.
	НаборЗаписейРасчетыСПоставщиками = РегистрыНакопления.РасчетыСПоставщиками.СоздатьНаборЗаписей();
	НаборЗаписейРасчетыСПоставщиками.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления УчетДоходовИРасходов.
	НаборЗаписейДоходыИРасходы = РегистрыНакопления.ДоходыИРасходы.СоздатьНаборЗаписей();
	НаборЗаписейДоходыИРасходы.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра накопления РасчетыПоКредитамИЗаймам.
	НаборЗаписейРасчетыПоКредитамИЗаймам = РегистрыНакопления.РасчетыПоКредитамИЗаймам.СоздатьНаборЗаписей();
	НаборЗаписейРасчетыПоКредитамИЗаймам.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра сведений ОтчетПоКурсовымРазницам.
	НаборЗаписейОтчетПоКурсовымРазницам = РегистрыСведений.ОтчетПоКурсовымРазницам.СоздатьНаборЗаписей();
	НаборЗаписейОтчетПоКурсовымРазницам.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра бухгалтерии Управленческий.
	НаборЗаписейУправленческий = РегистрыБухгалтерии.Управленческий.СоздатьНаборЗаписей();
	НаборЗаписейУправленческий.Отбор.Регистратор.Установить(Ссылка);
	
	// Создадим набор записей регистра бухгалтерии Хозрасчетный.
	НаборЗаписейХозрасчетный = РегистрыБухгалтерии.Хозрасчетный.СоздатьНаборЗаписей();
	НаборЗаписейХозрасчетный.Отбор.Регистратор.Установить(Ссылка);
	
	СтруктураОтраженияКурсовыхРазницРегл = РегламентированныйУчетСервер.ПолучитьСтруктуруОтраженияКурсовыхРазниц2(Дата, Организация);
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ДатаКон", ДополнительныеСвойства.ДляПроведения.КонечнаяДатаПериод);
	Запрос.УстановитьПараметр("Организация", ДополнительныеСвойства.ДляПроведения.Организация);
	Запрос.УстановитьПараметр("КурсоваяРазница", НСтр("ka='სხვაობა კურსებს შორის';ru='Курсовая разница';en='Exchange difference'"));
	
	Запрос.УстановитьПараметр("СчетДеньгиОтрицательная", СтруктураОтраженияКурсовыхРазницРегл.СчетаКурсовыхРазниц.СчетОтрицательнаяКурсоваяРазницаДеньги);
	Запрос.УстановитьПараметр("СчетДеньгиПоложительная", СтруктураОтраженияКурсовыхРазницРегл.СчетаКурсовыхРазниц.СчетПоложительнаяКурсоваяРазницаДеньги);
	Запрос.УстановитьПараметр("СчетЗадолженностьОтрицательная", СтруктураОтраженияКурсовыхРазницРегл.СчетаКурсовыхРазниц.СчетОтрицательнаяКурсоваяРазницаЗадолженность);
	Запрос.УстановитьПараметр("СчетЗадолженностьПоложительная", СтруктураОтраженияКурсовыхРазницРегл.СчетаКурсовыхРазниц.СчетПоложительнаяКурсоваяРазницаЗадолженность);
	
	Запрос.УстановитьПараметр("НеПереоцениватьСчета", СтруктураОтраженияКурсовыхРазницРегл.НеПереоцениватьСчета);
	
	// Денежные средства.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаОстатки.Организация КАК Организация,
	|	&Дата КАК Период,
	|	&Ссылка КАК Регистратор,
	|	ТаблицаОстатки.ТипДенежныхСредств КАК ТипДенежныхСредств,
	|	ТаблицаОстатки.БанковскийСчетКасса КАК БанковскийСчетКасса,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаОстатки.СуммаВалОстаток, 0) * КурсыВалютБанковскийСчетКассаСрезПоследних.Курс * КурсыВалютУчетаСрезПоследних.Кратность / (КурсыВалютУчетаСрезПоследних.Курс * КурсыВалютБанковскийСчетКассаСрезПоследних.Кратность) - ЕСТЬNULL(ТаблицаОстатки.СуммаОстаток, 0) > 0
	|			ТОГДА ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПрочиеДоходы)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ПланСчетов.Управленческий.ПрочиеРасходы)
	|	КОНЕЦ КАК Аналитика,
	|	ТаблицаОстатки.Валюта КАК Валюта,
	|	ТаблицаОстатки.СуммаОстаток КАК СуммаОстаток,
	|	ТаблицаОстатки.СуммаВалОстаток КАК СуммаВалОстаток,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаОстатки.СуммаВалОстаток, 0) * КурсыВалютБанковскийСчетКассаСрезПоследних.Курс * КурсыВалютУчетаСрезПоследних.Кратность / (КурсыВалютУчетаСрезПоследних.Курс * КурсыВалютБанковскийСчетКассаСрезПоследних.Кратность) - ЕСТЬNULL(ТаблицаОстатки.СуммаОстаток, 0) > 0
	|			ТОГДА ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|		ИНАЧЕ ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|	КОНЕЦ КАК ВидДвиженияУправленческий,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаОстатки.СуммаВалОстаток, 0) * КурсыВалютБанковскийСчетКассаСрезПоследних.Курс * КурсыВалютУчетаСрезПоследних.Кратность / (КурсыВалютУчетаСрезПоследних.Курс * КурсыВалютБанковскийСчетКассаСрезПоследних.Кратность) - ЕСТЬNULL(ТаблицаОстатки.СуммаОстаток, 0) > 0
