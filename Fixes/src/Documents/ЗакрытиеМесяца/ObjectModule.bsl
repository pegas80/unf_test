		  + " / "
		  + ВыборкаДетальныеЗаписи.Документ
		  + " / "
		  + ВыборкаДетальныеЗаписи.Заказ;
		НоваяСтрока.Раздел = "Расчеты с покупателями";
		
		НоваяСтрока = НаборЗаписейХозрасчетный.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
		НоваяСтрока.СчетДт = ВыборкаДетальныеЗаписи.СчетДтРегл;
		НоваяСтрока.СчетКт = ВыборкаДетальныеЗаписи.СчетКтРегл;
		
		Если ЗначениеЗаполнено(НоваяСтрока.СчетДт) И НоваяСтрока.СчетДт.Валютный Тогда
			НоваяСтрока.ВалютаДт = ВыборкаДетальныеЗаписи.Валюта;
		Иначе
			НоваяСтрока.ВалютаДт = Справочники.Валюты.ПустаяСсылка();
		КонецЕсли; 
		
		Если ЗначениеЗаполнено(НоваяСтрока.СчетКт) И НоваяСтрока.СчетКт.Валютный Тогда
