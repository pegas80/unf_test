&Вместо("СвернутьНаборЗаписейДоходыИРасходы")
Процедура AzRyFix_СвернутьНаборЗаписейДоходыИРасходы(НаборЗаписейРегистра)
		
	Если Не AzRyИспользоватьСтаруюВерсиюЗакрытияМесяца Тогда		
		ПродолжитьВызов(НаборЗаписейРегистра);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДоходыИРасходы.Период,
	|	ДоходыИРасходы.Активность,
	|	ДоходыИРасходы.Организация,
	|	ДоходыИРасходы.СтруктурнаяЕдиница,
