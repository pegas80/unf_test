		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "Касса", ВыборкаДетальныеЗаписи.БанковскийСчетКасса);
		БухгалтерскийУчет.УстановитьСубконто(НоваяСтрока.СчетКт, НоваяСтрока.СубконтоКт, "СтатьиДвиженияДенежныхСредств", ВыборкаДетальныеЗаписи.Статья);
		
	КонецЦикла;
	
	// Денежные средства в кассах ККМ.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ТаблицаОстатки.Организация КАК Организация,
