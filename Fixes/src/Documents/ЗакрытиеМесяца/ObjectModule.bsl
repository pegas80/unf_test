			НоваяСтрока.Содержание = НСтр("ka='ხარჯების ასახვა';ru='Отражение расходов';en='reflection expenditure'");
			НоваяСтрока.Сумма = СуммаКорректировки;
			
			// Движения по регистру Хозрасчетный.
			НоваяСтрока = НаборЗаписейХозрасчетный.Добавить();
